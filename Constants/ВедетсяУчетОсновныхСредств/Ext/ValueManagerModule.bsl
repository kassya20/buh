#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Значение Тогда
		Справочники.ВидыНоменклатуры.СоздатьЭлементыОС();
		КлассификаторыДоходовРасходов.ОбеспечитьФункциональность(
			Справочники.СтатьиЗатрат,
			"ВедетсяУчетОсновныхСредств");
		КлассификаторыДоходовРасходов.ОбеспечитьФункциональность(
			Справочники.ПрочиеДоходыИРасходы,
			"ВедетсяУчетОсновныхСредств");
	КонецЕсли;
	
	ПоказыватьРазделИмуществоПростойИнтерфейс = (Значение Или Константы.ВедетсяУчетНМА.Получить())
		И Константы.ИнтерфейсТаксиПростой.Получить();
	Константы.ПоказыватьРазделИмуществоПростойИнтерфейс.Установить(ПоказыватьРазделИмуществоПростойИнтерфейс);
	
	Обработки.ФункциональностьПрограммы.НастроитьАгрегирующуюКонстанту(Метаданные.Константы.РасширенныйФункционалОсновныеСредства.Имя);
	
	ПараметрыНабора = УправлениеСвойствами.СтруктураПараметровНабораСвойств();
	ПараметрыНабора.Используется = Значение;
	УправлениеСвойствами.УстановитьПараметрыНабораСвойств("Справочник_ОснованияЛьготПоИмущественнымНалогам", ПараметрыНабора);
	УправлениеСвойствами.УстановитьПараметрыНабораСвойств("Справочник_ДокументыПодтверждающиеЛьготыПоИмущественнымНалогам", ПараметрыНабора);
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли