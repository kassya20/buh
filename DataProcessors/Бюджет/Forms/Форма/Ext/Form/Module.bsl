&НаСервере
Процедура ЗаполнитьДанныеОбработки()
	
	Если Не ДокументСсылка.Пустая() Тогда
		
		ДанныеБюджета = Документы.Бюджет.ДанныеБюджета(ДокументСсылка);
		
		ПоследняяКорректировка = Документы.КорректировкаБюджета.ПоследняяКорректировка(ДокументСсылка);
		ВсеКорректировки.ЗагрузитьЗначения(Документы.КорректировкаБюджета.ВсеКорректировки(ДокументСсылка));
		
		Объект.СтруктураДоходов.Загрузить(ДанныеБюджета.СтруктураДоходов);
		Объект.Доходы.Загрузить(ДанныеБюджета.Доходы);
		Объект.СтруктураРасходов.Загрузить(ДанныеБюджета.СтруктураРасходов);
		Объект.РасходыПоНаправлениямДеятельности.Загрузить(ДанныеБюджета.РасходыПоНаправлениямДеятельности);
		Объект.Расходы.Загрузить(ДанныеБюджета.Расходы);
		ЗаполнитьЗначенияСвойств(Объект, ДанныеБюджета.Реквизиты[0]);
		ВывестиОтображениеПериода(ЭтотОбъект);
		
	Иначе
		
		ПоследняяКорректировка = Документы.КорректировкаБюджета.ПустаяСсылка();
		ВсеКорректировки.Очистить();
		
		Объект.СтруктураДоходов.Очистить();
		Объект.Доходы.Очистить();
		Объект.СтруктураРасходов.Очистить();
		Объект.РасходыПоНаправлениямДеятельности.Очистить();
		Объект.Расходы.Очистить();
		
		Объект.Утвержден = Ложь;
		Объект.Комментарий = "";
		Объект.ОстатокНаНачало = 0;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПоказыватьВопросЗаполнитьБюджет(Организация, Период)
	
	Возврат Документы.Бюджет.ЕстьБюджетНаПериод(Организация, ДобавитьМесяц(Период, -12))
		И Не Документы.Бюджет.ЕстьБюджетНаПериод(Организация, Период);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПоДаннымПрошлогоПериодаНаСервере(ЗаполнитьФактом)
	
	НачалоПериода = ДобавитьМесяц(НачалоГода(Объект.Период), -12);
	КонецПериода = КонецГода(НачалоПериода);
	
	ДетализацияДо = Объект.Детализация;
	
	БюджетПрошлогоГода = Документы.Бюджет.БюджетНаПериод(Объект.Организация, НачалоПериода);
	Если БюджетПрошлогоГода.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеБюджета = Документы.Бюджет.ДанныеБюджета(БюджетПрошлогоГода);
	РеквизитыБюджета = ДанныеБюджета.Реквизиты[0];
	Объект.Детализация = РеквизитыБюджета.Детализация;
	
	Если Объект.Детализация =  ДетализацияДо Тогда
		ОбновитьКолонкиДереваБюджета();
	Иначе
		СоздатьКолонкиДереваБюджета();
		УстановитьУсловноеОформление();
	КонецЕсли;
	
	Объект.Доходы.Очистить();
	Объект.СтруктураДоходов.Очистить();
	Объект.Расходы.Очистить();
	Объект.СтруктураРасходов.Очистить();
	Объект.РасходыПоНаправлениямДеятельности.Очистить();
	
	// Заполним начальный остаток
	Если Не ЗаполнитьФактом Тогда
		Объект.ОстатокНаНачало = РеквизитыБюджета.ОстатокНаНачало;
	Иначе
		ОстаткиДенежныхСредств = Отчеты.ОстаткиДенежныхСредств.ПолучитьОстаткиДенежныхСредствДляМонитораРуководителяСводно(
			Объект.Организация, КонецПериода);
		Объект.ОстатокНаНачало = ОстаткиДенежныхСредств.Итог("Сумма");
	КонецЕсли;
	
	// Заполним доходы
	ДоходыПрошлогоГода = БюджетДоходыЗаПериод(
		НачалоПериода, КонецПериода, Объект.Организация, ЗаполнитьФактом, Объект.Детализация = Перечисления.Периодичность.Месяц);
		
	Объект.Доходы.Загрузить(ДоходыПрошлогоГода.Доходы);
	Объект.СтруктураДоходов.Загрузить(ДоходыПрошлогоГода.СтруктураДоходов);
	
	// Заполним расходы
	РасходыПрошлогоГода = БюджетРасходыЗаПериод(
		НачалоПериода, КонецПериода, Объект.Организация, ЗаполнитьФактом, Объект.Детализация = Перечисления.Периодичность.Месяц);
	
	Объект.Расходы.Загрузить(РасходыПрошлогоГода.Расходы);
	Объект.СтруктураРасходов.Загрузить(РасходыПрошлогоГода.СтруктураРасходов);
	Объект.РасходыПоНаправлениямДеятельности.Загрузить(РасходыПрошлогоГода.РасходыПоНаправлениямДеятельности);
	
	ПостроитьДеревоБюджета();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция БюджетРасходыЗаПериод(НачалоПериода, КонецПериода, Организация, ЗаполнитьФактом, ПоМесяцам)
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ПоМесяцам",       ПоМесяцам);
	Запрос.УстановитьПараметр("Организация",     Организация);
	Запрос.УстановитьПараметр("НачалоПериода",   НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",    КонецПериода);
	Запрос.УстановитьПараметр("ЗаполнитьФактом", ЗаполнитьФактом);
	
	// При поквартальном бюджете из регистра выбирается Период - начало квартала, 
	// а для корректного заполнения дерева бюджета требуется ДатаПланирования - конец квартала.
	// Поэтому к выбираемому периоду добавляем 14 месяцев - один год и еще два месяца.
	Запрос.УстановитьПараметр("МесяцевДоКонцаКварталаСледующегоГода", 14);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &ПоМесяцам
	|			ТОГДА ДОБАВИТЬКДАТЕ(БюджетРасходыОборотыПоПериодам.ПериодМесяц, МЕСЯЦ, 12)
	|		ИНАЧЕ ДОБАВИТЬКДАТЕ(БюджетРасходыОборотыПоПериодам.ПериодКвартал, МЕСЯЦ, &МесяцевДоКонцаКварталаСледующегоГода)
	|	КОНЕЦ КАК Период,
	|	БюджетРасходыОборотыПоПериодам.СуммаПланОборот КАК СуммаПланОборот,
	|	БюджетРасходыОборотыПоПериодам.СуммаФактОборот КАК СуммаФактОборот,
	|	БюджетРасходыОборотыПоПериодам.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	БюджетРасходыОборотыПоПериодам.СтатьяРасхода КАК СтатьяРасхода,
	|	БюджетРасходыОборотыПоПериодам.СтатьяРасхода.Родитель КАК Родитель,
	|	БюджетРасходыОборотыПоПериодам.СтатьяРасхода.ЭтоГруппа КАК ЭтоГруппа
	|ПОМЕСТИТЬ Обороты
	|ИЗ
	|	РегистрНакопления.БюджетРасходы.Обороты(&НачалоПериода, &КонецПериода, Авто, Организация = &Организация) КАК БюджетРасходыОборотыПоПериодам
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	БюджетРасходыОборотыИтоги.СуммаПланОборот,
	|	БюджетРасходыОборотыИтоги.СуммаФактОборот,
	|	БюджетРасходыОборотыИтоги.НаправлениеДеятельности,
	|	БюджетРасходыОборотыИтоги.СтатьяРасхода,
	|	БюджетРасходыОборотыИтоги.СтатьяРасхода.Родитель,
	|	БюджетРасходыОборотыИтоги.СтатьяРасхода.ЭтоГруппа
	|ИЗ
	|	РегистрНакопления.БюджетРасходы.Обороты(&НачалоПериода, &КонецПериода, , Организация = &Организация) КАК БюджетРасходыОборотыИтоги
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктураБюджетаРасходы.НомерСтроки КАК НомерСтроки,
	|	СтруктураБюджетаРасходы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	СтруктураБюджетаРасходы.СтатьяРасхода КАК СтатьяРасхода
	|ПОМЕСТИТЬ НомераСтрок
	|ИЗ
	|	РегистрСведений.СтруктураБюджетаРасходы.СрезПоследних(&КонецПериода, Организация = &Организация) КАК СтруктураБюджетаРасходы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &ЗаполнитьФактом
	|			ТОГДА СУММА(Обороты.СуммаФактОборот)
	|		ИНАЧЕ СУММА(Обороты.СуммаПланОборот)
	|	КОНЕЦ КАК Сумма,
	|	Обороты.Период КАК ДатаПланирования,
	|	Обороты.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	Обороты.СтатьяРасхода КАК СтатьяРасхода,
	|	Обороты.Родитель КАК Родитель,
	|	Обороты.ЭтоГруппа КАК ЭтоГруппа,
	|	НомераСтрок.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Обороты КАК Обороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ НомераСтрок КАК НомераСтрок
	|		ПО Обороты.НаправлениеДеятельности = НомераСтрок.НаправлениеДеятельности
	|			И Обороты.СтатьяРасхода = НомераСтрок.СтатьяРасхода
	|
	|СГРУППИРОВАТЬ ПО
	|	Обороты.Период,
	|	Обороты.НаправлениеДеятельности,
	|	Обороты.СтатьяРасхода,
	|	Обороты.Родитель,
	|	Обороты.ЭтоГруппа,
	|	НомераСтрок.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &ЗаполнитьФактом
	|			ТОГДА СУММА(Обороты.СуммаФактОборот)
	|		ИНАЧЕ СУММА(Обороты.СуммаПланОборот)
	|	КОНЕЦ КАК Сумма,
	|	ДОБАВИТЬКДАТЕ(Обороты.Период, ГОД, 1) КАК ДатаПланирования,
	|	Обороты.НаправлениеДеятельности КАК НаправлениеДеятельности
	|ИЗ
	|	Обороты КАК Обороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ НомераСтрок КАК НомераСтрок
	|		ПО Обороты.НаправлениеДеятельности = НомераСтрок.НаправлениеДеятельности
	|			И Обороты.СтатьяРасхода = НомераСтрок.СтатьяРасхода
	|
	|СГРУППИРОВАТЬ ПО
	|	Обороты.Период,
	|	Обороты.НаправлениеДеятельности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктураБюджетаРасходы.НомерСтроки КАК НомерСтроки,
	|	СтруктураБюджетаРасходы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	СтруктураБюджетаРасходы.СтатьяРасхода КАК СтатьяРасхода,
	|	СтруктураБюджетаРасходы.СтатьяРасхода.Родитель КАК Родитель,
	|	СтруктураБюджетаРасходы.СтатьяРасхода.ЭтоГруппа КАК ЭтоГруппа
	|ИЗ
	|	РегистрСведений.СтруктураБюджетаРасходы.СрезПоследних(&КонецПериода, Организация = &Организация) КАК СтруктураБюджетаРасходы
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ТаблицаРасходы = РезультатЗапроса[2].Выгрузить();
	ТаблицаРасходыПоНаправлениямДеятельности = РезультатЗапроса[3].Выгрузить();
	ТаблицаСтруктураРасходов = РезультатЗапроса[4].Выгрузить();
	
	Возврат Новый Структура("Расходы,СтруктураРасходов,РасходыПоНаправлениямДеятельности", ТаблицаРасходы, ТаблицаСтруктураРасходов, ТаблицаРасходыПоНаправлениямДеятельности);
	
КонецФункции

&НаСервереБезКонтекста
Функция БюджетДоходыЗаПериод(НачалоПериода, КонецПериода, Организация, ЗаполнитьФактом, ПоМесяцам)
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ПоМесяцам",       ПоМесяцам);
	Запрос.УстановитьПараметр("Организация",     Организация);
	Запрос.УстановитьПараметр("НачалоПериода",   НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",    КонецПериода);
	Запрос.УстановитьПараметр("ЗаполнитьФактом", ЗаполнитьФактом);
	
	// При поквартальном бюджете из регистра выбирается Период - начало квартала, 
	// а для корректного заполнения дерева бюджета требуется ДатаПланирования - конец квартала.
	// Поэтому к выбираемому периоду добавляем 14 месяцев - один год и еще два месяца.
	Запрос.УстановитьПараметр("МесяцевДоКонцаКварталаСледующегоГода", 14);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &ПоМесяцам
	|			ТОГДА ДОБАВИТЬКДАТЕ(БюджетДоходыОборотыПоПериодам.ПериодМесяц, МЕСЯЦ, 12)
	|		ИНАЧЕ ДОБАВИТЬКДАТЕ(БюджетДоходыОборотыПоПериодам.ПериодКвартал, МЕСЯЦ, &МесяцевДоКонцаКварталаСледующегоГода)
	|	КОНЕЦ КАК Период,
	|	БюджетДоходыОборотыПоПериодам.СуммаПланОборот КАК СуммаПланОборот,
	|	БюджетДоходыОборотыПоПериодам.СуммаФактОборот КАК СуммаФактОборот,
	|	БюджетДоходыОборотыПоПериодам.СтатьяДохода КАК СтатьяДохода,
	|	БюджетДоходыОборотыПоПериодам.СтатьяДохода.Родитель КАК Родитель,
	|	БюджетДоходыОборотыПоПериодам.СтатьяДохода.ЭтоГруппа КАК ЭтоГруппа
	|ПОМЕСТИТЬ Обороты
	|ИЗ
	|	РегистрНакопления.БюджетДоходы.Обороты(&НачалоПериода, &КонецПериода, Авто, Организация = &Организация) КАК БюджетДоходыОборотыПоПериодам
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	БюджетДоходыОборотыИтоги.СуммаПланОборот,
	|	БюджетДоходыОборотыИтоги.СуммаФактОборот,
	|	БюджетДоходыОборотыИтоги.СтатьяДохода,
	|	БюджетДоходыОборотыИтоги.СтатьяДохода.Родитель,
	|	БюджетДоходыОборотыИтоги.СтатьяДохода.ЭтоГруппа
	|ИЗ
	|	РегистрНакопления.БюджетДоходы.Обороты(&НачалоПериода, &КонецПериода, , Организация = &Организация) КАК БюджетДоходыОборотыИтоги
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктураБюджетаДоходы.НомерСтроки КАК НомерСтроки,
	|	СтруктураБюджетаДоходы.СтатьяДохода КАК СтатьяДохода
	|ПОМЕСТИТЬ НомераСтрок
	|ИЗ
	|	РегистрСведений.СтруктураБюджетаДоходы.СрезПоследних(&КонецПериода, Организация = &Организация) КАК СтруктураБюджетаДоходы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА &ЗаполнитьФактом
	|			ТОГДА СУММА(Обороты.СуммаФактОборот)
	|		ИНАЧЕ СУММА(Обороты.СуммаПланОборот)
	|	КОНЕЦ КАК Сумма,
	|	Обороты.Период КАК ДатаПланирования,
	|	Обороты.СтатьяДохода КАК СтатьяДохода,
	|	Обороты.Родитель КАК Родитель,
	|	Обороты.ЭтоГруппа КАК ЭтоГруппа,
	|	НомераСтрок.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	Обороты КАК Обороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ НомераСтрок КАК НомераСтрок
	|		ПО Обороты.СтатьяДохода = НомераСтрок.СтатьяДохода
	|
	|СГРУППИРОВАТЬ ПО
	|	Обороты.Период,
	|	Обороты.СтатьяДохода,
	|	Обороты.Родитель,
	|	Обороты.ЭтоГруппа,
	|	НомераСтрок.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СтруктураБюджетаДоходы.НомерСтроки КАК НомерСтроки,
	|	СтруктураБюджетаДоходы.СтатьяДохода КАК СтатьяДохода,
	|	СтруктураБюджетаДоходы.СтатьяДохода.Родитель КАК Родитель,
	|	СтруктураБюджетаДоходы.СтатьяДохода.ЭтоГруппа КАК ЭтоГруппа
	|ИЗ
	|	РегистрСведений.СтруктураБюджетаДоходы.СрезПоследних(&КонецПериода, Организация = &Организация) КАК СтруктураБюджетаДоходы
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ТаблицаДоходы = РезультатЗапроса[2].Выгрузить();
	ТаблицаСтруктураДоходов = РезультатЗапроса[3].Выгрузить();
	
	Возврат Новый Структура("Доходы,СтруктураДоходов", ТаблицаДоходы, ТаблицаСтруктураДоходов);
	
КонецФункции

&НаКлиенте
Функция БюджетЗаполнен()
	
	БюджетЗаполнен = Ложь;
	Для Каждого СтрокаДерева Из ДеревоБюджета.ПолучитьЭлементы() Цикл
		Если СтрокаДерева.СуммаГод <> 0 Тогда
			БюджетЗаполнен = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат БюджетЗаполнен;
	
КонецФункции

#Область УправлениеФормой

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	СоздатьКолонкиДереваБюджета();
	ВывестиОтображениеПериода(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ВывестиОтображениеПериода(Форма)
	
	Объект = Форма.Объект;
	Форма.ОтображениеПериода = Формат(Объект.Период, "ДФ=yyyy");
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	
	НеТолькоПросмотр = Форма.РедактированиеРазрешено; 
	Если НеТолькоПросмотр Тогда
		РедактированиеРазрешено = Не Форма.Объект.Утвержден;
	Иначе
		РедактированиеРазрешено = Ложь;
	КонецЕсли;
	
	Элементы.ДеревоБюджетаДобавитьДоход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаДобавитьРасход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаДобавитьНаправлениеДеятельности.Доступность = РедактированиеРазрешено;

	Элементы.ДеревоБюджетаКонтекстноеМенюДобавитьДоход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаКонтекстноеМенюДобавитьРасход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаКонтекстноеМенюДобавитьНаправлениеДеятельности.Доступность = РедактированиеРазрешено;

	Элементы.ДеревоБюджетаСдвинутьВверх.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаСдвинутьВниз.Доступность = РедактированиеРазрешено;

	Элементы.Детализация.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджета.ТолькоПросмотр = Не РедактированиеРазрешено;
	
	Элементы.ДеревоБюджетаГруппаЗаполнить.Доступность = РедактированиеРазрешено;
	
	Элементы.Записать.Доступность = НеТолькоПросмотр;
	
	Если ЗначениеЗаполнено(Форма.ПоследняяКорректировка) Тогда
		ЗаголовокКорректировки = Строка(Форма.ПоследняяКорректировка);
	Иначе
		ЗаголовокКорректировки = НСтр("ru='Ввести корректировку'");
	КонецЕсли;
	
	Элементы.ДекорацияКорректировка.Заголовок = ЗаголовокКорректировки;
	
	// Видимость заголовка зависит от права на редактирование, утвержден и модифицированность
	// Если нет прав на редактирование или бюджет не утвержден или модифицированность, то надписи не будет
	Элементы.ДекорацияКорректировка.Видимость = НеТолькоПросмотр И Не Форма.Модифицированность И Форма.Объект.Утвержден;
	
	Элементы.ДекорацияВсеКорректировки.Видимость = Форма.ВсеКорректировки.Количество() > 1;
	
	Элементы.Утвержден.Доступность = Не ЗначениеЗаполнено(Форма.ПоследняяКорректировка);
	
	Элементы.ДеревоБюджетаВыгрузитьВExcel.Доступность = НеТолькоПросмотр;
	Элементы.ДеревоБюджетаЗагрузитьИзExcel.Доступность = НеТолькоПросмотр;

КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	
