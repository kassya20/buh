
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ВариантыПриложений.ЭтоВерсияКОРП() Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	РедактированиеРазрешено = ПравоДоступа("Редактирование", Метаданные.Документы.Бюджет);
	// Установим реквизиты шапки
	Если ЗначениеЗаполнено(Параметры.ДокументСсылка) Тогда
		ДокументСсылка = Параметры.ДокументСсылка;
		// Организацию берем из документа
		Объект.Организация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Организация");
	Иначе
		// Берем организацию по умолчанию
		Объект.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
		// Ищем документ по организации
		ДокументСсылка = Документы.Бюджет.ПоследнийБюджет(Объект.Организация);
	КонецЕсли;
	
	Если ДокументСсылка.Пустая() Тогда
		Объект.Детализация = Перечисления.Периодичность.Квартал;
		Объект.Период      = НачалоГода(ТекущаяДатаСеанса());
	КонецЕсли;
	
	ТекущаяОрганизация = Объект.Организация;
	
	// Получим данные, по которым строим дерево бюджета
	ЗаполнитьДанныеОбработки();
	
	ПодготовитьФормуНаСервере();
	
	ПостроитьДеревоБюджета();
	
	УстановитьУсловноеОформление();
	
	БюджетДоходовРасходов.УстановитьТекущуюСтрокуИзПланФактногоАнализа(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	РазвернутьДерево();
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	ПроверитьБюджетНаНезаполненныеЭлементы(Отказ);
	
	ШаблонСообщения = НСтр("ru='Статья ""%1"" указана в разделе Финансирование %2'");
	ПроверитьТаблицуНаДублирующиеЭлементы(Объект.Доходы, "СтатьяДохода", ШаблонСообщения, Отказ);
	
	ШаблонСообщения = НСтр("ru='Направление деятельности ""%1"" указано %2'");
	ПроверитьТаблицуНаДублирующиеЭлементы(
		Объект.РасходыПоНаправлениямДеятельности, "НаправлениеДеятельности", ШаблонСообщения, Отказ);
		
	ПроверитьРасходыНаДублирующиеЭлементы(Отказ);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		Отказ = Истина;
		СтандартнаяОбработка = Ложь;
		ОписаниеОповещения = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект, Новый Структура);
		ПоказатьВопросСохранитьИзменения(ОписаниеОповещения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "Запись_КорректировкаБюджета" Тогда
		
		ЗаполнитьДанныеОбработки();
	
		ПодготовитьФормуНаСервере();
	
		ПостроитьДеревоБюджета();
		
		РазвернутьДерево();
		
		УправлениеФормой(ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОтображениеПериодаПриИзменении(Элемент)
	
	Отказ = Ложь;
	ПроверитьКорректностьГода(Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОтображениеПериодаПриИзмененииЗавершение", ЭтотОбъект, Новый Структура);
		ПоказатьВопросСохранитьИзменения(ОписаниеОповещения);
	Иначе
		ОтображениеПериодаПриИзмененииНаКлиенте();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УтвержденПриИзменении(Элемент)
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДетализацияПриИзменении(Элемент)
	
	ДетализацияПриИзмененииНаСервере();
	РазвернутьДерево();
	
КонецПроцедуры

&НаКлиенте
Процедура ТекущаяОрганизацияПриИзменении(Элемент)
	
	Если Модифицированность Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОрганизацияПриИзмененииЗавершение", ЭтотОбъект, Новый Структура);
		ПоказатьВопросСохранитьИзменения(ОписаниеОповещения);
	Иначе
		Объект.Организация = ТекущаяОрганизация;
		ПерезаполнитьБюджет();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияКорректировкаНажатие(Элемент)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Бюджет", ДокументСсылка);
	ПараметрыФормы.Вставить("ДокументСсылка", ПоследняяКорректировка);
	
	Если ПоследняяКорректировка.Пустая() Тогда
		ПараметрыФормы.Вставить("Период", ОбщегоНазначенияКлиент.ДатаСеанса());
	КонецЕсли;
	
	ОткрытьФорму("Обработка.КорректировкаБюджета.Форма", ПараметрыФормы, , Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияВсеКорректировкиНажатие(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Бюджет", ДокументСсылка);
	
	ОткрытьФорму("Обработка.КорректировкаБюджета.Форма.ВсеКорректировки", ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормы

&НаКлиенте
Процедура ДеревоБюджетаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Отказ = Истина;
	
	Если Объект.Утвержден Тогда
		Возврат;
	КонецЕсли;
	
	Строка = Элементы.ДеревоБюджета.ТекущиеДанные;
	
	Если Копирование Тогда
		СкопироватьСтрокуДерева(Строка);
	Иначе
		ДобавитьНовуюСтрокуДерева(Строка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаПередУдалением(Элемент, Отказ)
	
	Если Элемент.ТекущиеДанные.ЭтоРаздел Или Объект.Утвержден Тогда
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаПослеУдаления(Элемент)
	
	РассчитатьИтогиПоВсемРазделам();
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаНаправлениеДеятельностиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СоздатьНовоеНаправлениеДеятельности(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаНаправлениеДеятельностиАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	Если Не ПустаяСтрока(Текст) Тогда
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = НаправленияДеятельностиДанныеВыбораКомандаСоздать(ПараметрыПолученияДанных, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаНаправлениеДеятельностиОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Если Не ПустаяСтрока(Текст) Тогда
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = НаправленияДеятельностиДанныеВыбораКомандаСоздать(ПараметрыПолученияДанных, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	СтатьяДДС = ТекущиеДанные.СтатьяДДС;
	ТекущиеДанные.ЭтоГруппаСтатей = ЭтоГруппа(СтатьяДДС);
	Если ТекущиеДанные.ЭтоГруппаСтатей Тогда
		ТекущиеДанные.КартинкаСтроки = БиблиотекаКартинок.Папка;
	Иначе
		ТекущиеДанные.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СоздатьНовуюСтатьюДДС(Элемент, ВыбранноеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	Если Не ПустаяСтрока(Текст) Тогда
		СтандартнаяОбработка = Ложь;
		Если Элементы.ДеревоБюджета.ТекущиеДанные.Раздел = ИмяРазделРасходы() Тогда
			ПараметрыПолученияДанных.Отбор.Вставить("ВидСтатьиДДС", ВидСтатьиДДСРасход());
		Иначе
			ПараметрыПолученияДанных.Отбор.Вставить("ВидСтатьиДДС", ВидСтатьиДДСДоход());
		КонецЕсли;
		
		ДанныеВыбора = СтатьяДДСДанныеВыбораКомандаСоздать(ПараметрыПолученияДанных, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	Если Не ПустаяСтрока(Текст) Тогда
		СтандартнаяОбработка = Ложь;
		Если Элементы.ДеревоБюджета.ТекущиеДанные.Раздел = ИмяРазделРасходы() Тогда
			ПараметрыПолученияДанных.Отбор.Вставить("ВидСтатьиДДС", ВидСтатьиДДСРасход());
		Иначе
			ПараметрыПолученияДанных.Отбор.Вставить("ВидСтатьиДДС", ВидСтатьиДДСДоход());
		КонецЕсли;
		ДанныеВыбора = СтатьяДДСДанныеВыбораКомандаСоздать(ПараметрыПолученияДанных, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСуммаПриИзменении(Элемент)
	
	РассчитатьИтоги(Элемент);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	
	Отказ = Ложь;
	ЗаписатьДанные(Отказ);
	Если Не Отказ Тогда
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Записать(Команда)
	
	ЗаписатьДанные();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПланом(Команда)
	
	Если БюджетЗаполнен() Тогда
		ДополнительныеПараметры = Новый Структура("ЗаполнитьФактом", Ложь);
		ОписаниеОповещения = Новый ОписаниеОповещения("ВопросЗаполнитьБюджетЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru='Перед заполнением бюджет будет очищен. Продолжить?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗаполнитьПоДаннымПрошлогоПериодаНаСервере(Ложь);
		РазвернутьДерево();
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьФактом(Команда)
	
	Если БюджетЗаполнен() Тогда
		ДополнительныеПараметры = Новый Структура("ЗаполнитьФактом", Истина);
		ОписаниеОповещения = Новый ОписаниеОповещения("ВопросЗаполнитьБюджетЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru='Перед заполнением бюджет будет очищен. Продолжить?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		ЗаполнитьПоДаннымПрошлогоПериодаНаСервере(Истина);
		РазвернутьДерево();
		Модифицированность = Истина;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	ПерезаполнитьБюджет();
	
КонецПроцедуры

&НаКлиенте
Процедура БюджетДоходовИРасходов(Команда)
	
	Если Объект.Расходы.Итог("Сумма") = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru='Сначала заполните и запишите бюджет доходов и расходов'"));
	ИначеЕсли Модифицированность Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("БюджетДоходовИРасходовЗавершение", ЭтотОбъект, Новый Структура);
		ПоказатьВопросСохранитьПродолжить(ОписаниеОповещения, НСтр("ru='Для печати документа требуется его сохранить'"));
	Иначе
		ВывестиТабличныйДокументНаПечать(СформироватьПечатнуюФормуНаСервере());
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПланФактныйАнализ(Команда)
	
	Если Модифицированность Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытьПланФактныйАнализЗавершение", ЭтотОбъект, Новый Структура);
		ПоказатьВопросСохранитьПродолжить(ОписаниеОповещения, НСтр("ru='Для формирования отчета требуется сохранить изменения'"));
	Иначе
		ОткрытьПланФактныйАнализ();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьДоход(Команда)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	Отбор = Новый Структура;
	
	Если ТекущиеДанные.ЭтоГруппаСтатей Тогда
		Родитель = ТекущиеДанные;
		Отбор.Вставить("Родитель", ТекущиеДанные.СтатьяДДС);
	ИначеЕсли ТекущиеДанные.ЭтоРаздел И ТекущиеДанные.Раздел = ИмяРазделДоходы() Тогда
		Родитель = ТекущиеДанные;
	ИначеЕсли ТекущиеДанные.ЭтоСтатьяДДС И ТекущиеДанные.Раздел = ИмяРазделДоходы() Тогда
		Родитель = ТекущиеДанные.ПолучитьРодителя();
		Если Родитель.ЭтоГруппаСтатей Тогда
			Отбор.Вставить("Родитель", Родитель.СтатьяДДС);
		КонецЕсли;
	Иначе
		Родитель = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторДоходы);
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Родитель", Родитель);
	ДополнительныеПараметры.Вставить("ВидСтатьиДДС", ВидСтатьиДДСДоход());
	ДополнительныеПараметры.Вставить("Раздел", ИмяРазделДоходы());
	Отбор.Вставить("ВидСтатьиДДС", ДополнительныеПараметры.ВидСтатьиДДС);
	ПараметрыФормы = Новый Структура("Отбор", Отбор);
	ПараметрыФормы.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.ГруппыИЭлементы);
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьСтатьюДДСЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ОткрытьФорму("Справочник.СтатьиДвиженияДенежныхСредств.ФормаВыбора", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьРасход(Команда)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	Отбор = Новый Структура;
	Если ТекущиеДанные.ЭтоГруппаСтатей Тогда
		Родитель = ТекущиеДанные;
		Отбор.Вставить("Родитель", ТекущиеДанные.СтатьяДДС);
	ИначеЕсли ТекущиеДанные.ЭтоСтатьяДДС И ТекущиеДанные.Раздел = ИмяРазделРасходы() Тогда
		Родитель = ТекущиеДанные.ПолучитьРодителя();
		Если Родитель.ЭтоГруппаСтатей Тогда
			Отбор.Вставить("Родитель", Родитель.СтатьяДДС);
		КонецЕсли;
	ИначеЕсли ТекущиеДанные.ЭтоНаправлениеДеятельности Тогда 
		Родитель = ТекущиеДанные;
	Иначе
		РазделРасходы = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторРасходы);
		КоличествоЭлементов = РазделРасходы.ПолучитьЭлементы().Количество();
		Если КоличествоЭлементов = 0 Тогда
			ПоказатьПредупреждение(, НСтр("ru='Сначала добавьте направление деятельности'"));
			Возврат;
		Иначе
			Родитель = РазделРасходы.ПолучитьЭлементы()[КоличествоЭлементов - 1];
		КонецЕсли;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Родитель", Родитель);
	ДополнительныеПараметры.Вставить("ВидСтатьиДДС", ВидСтатьиДДСРасход());
	ДополнительныеПараметры.Вставить("Раздел", ИмяРазделРасходы());
	Отбор.Вставить("ВидСтатьиДДС", ДополнительныеПараметры.ВидСтатьиДДС);
	ПараметрыФормы = Новый Структура("Отбор", Отбор);
	ПараметрыФормы.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.ГруппыИЭлементы);
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьСтатьюДДСЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ОткрытьФорму("Справочник.СтатьиДвиженияДенежныхСредств.ФормаВыбора", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения);
	
КонецПроцедуры

