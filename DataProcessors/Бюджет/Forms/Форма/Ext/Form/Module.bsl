&НаСервере
Процедура ПерезаполнитьБюджетНаСервере()
	
	ДетализацияДо = Объект.Детализация;
	ДокументСсылка = Документы.Бюджет.БюджетНаПериод(Объект.Организация, Объект.Период);
	
	ЗаполнитьДанныеОбработки();
	Если ДетализацияДо = Объект.Детализация Тогда
		ОбновитьКолонкиДереваБюджета();
	Иначе
		СоздатьКолонкиДереваБюджета();
		УстановитьУсловноеОформление();
	КонецЕсли;
	
	ПостроитьДеревоБюджета();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтображениеПериодаПриИзмененииНаКлиенте()
	
	Объект.Период = Дата(ОтображениеПериода, 1, 1);
	ВывестиОтображениеПериода(ЭтотОбъект);
	ПерезаполнитьБюджет();
	Если ПоказыватьВопросЗаполнитьБюджет(Объект.Организация, Объект.Период) Тогда
		ДополнительныеПараметры = Новый Структура("ЗаполнитьФактом", Истина);
		ОписаниеОповещения = Новый ОписаниеОповещения("ВопросЗаполнитьБюджетЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьВопрос(
			ОписаниеОповещения,
			СтрШаблон(НСтр("ru='Бюджет на %1 год еще не составлялся. Заполнить по фактическим данным прошлого года?'"), ОтображениеПериода), 
			РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьГод(Шаг)
	
	ОтображениеПериода = Формат(Год(ДобавитьМесяц(Объект.Период, Шаг * 12)), "ЧГ=0");
	Отказ = Ложь;
	ПроверитьКорректностьГода(Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Модифицированность Тогда
		ОтображениеПериодаПриИзмененииНаКлиенте();
	Иначе
		ДополнительныеПараметры = Новый Структура("Шаг", Шаг);
		ОписаниеОповещения = Новый ОписаниеОповещения("ИзменитьГодЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьВопросСохранитьИзменения(ОписаниеОповещения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьГодЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		ЗаписатьДанные(Отказ);
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
	ИначеЕсли Результат = КодВозвратаДиалога.Отмена Тогда
		ВывестиОтображениеПериода(ЭтотОбъект);
		Возврат;
	КонецЕсли;
	
	ОтображениеПериодаПриИзмененииНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтображениеПериодаПриИзмененииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		ЗаписатьДанные(Отказ);
		Если Не Отказ Тогда
			ОтображениеПериодаПриИзмененииНаКлиенте();
		КонецЕсли;
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		ОтображениеПериодаПриИзмененииНаКлиенте();
	Иначе
		ВывестиОтображениеПериода(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		ЗаписатьДанные(Отказ);
		Если Не Отказ Тогда
			Закрыть();
		КонецЕсли;
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзмененииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		ЗаписатьДанные(Отказ);
		Если Не Отказ Тогда
			Объект.Организация = ТекущаяОрганизация;
			ПерезаполнитьБюджет();
		КонецЕсли;
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		Объект.Организация = ТекущаяОрганизация;
		ПерезаполнитьБюджет();
	ИначеЕсли Результат = КодВозвратаДиалога.Отмена Тогда
		ТекущаяОрганизация = Объект.Организация;
	КонецЕсли;
	
КонецПроцедуры

