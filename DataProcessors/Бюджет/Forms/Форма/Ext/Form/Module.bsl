Процедура ВыгрузитьВExcelЗавершение(ДополнительныеПараметры) Экспорт
	
	ФайловаяСистемаКлиент.ОткрытьФайл(ДополнительныеПараметры.Файл);

КонецПроцедуры   

&НаКлиенте
Процедура СозданиеКорректировкиБюджета(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузитьИзExcelЗавершение", ЭтотОбъект);	
		ПараметрыЗагрузки = ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла();
		ПараметрыЗагрузки.ИдентификаторФормы = УникальныйИдентификатор;
		ПараметрыЗагрузки.Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		ПараметрыЗагрузки.Диалог.Фильтр = НСтр("ru = 'Лист Excel|*.xls; *.xlsx'");
		
		ФайловаяСистемаКлиент.ЗагрузитьФайл(ОписаниеОповещения, ПараметрыЗагрузки);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияЗагрузкиФайлаНаСервере(Знач АдресФайла, Знач РасширениеФайла, Знач ИдентификаторФормы)
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайла);
	ХранилищеДанных = Новый ХранилищеЗначения(ДвоичныеДанные);
	УдалитьИзВременногоХранилища(АдресФайла); 
		
	ПараметрыЗадания = Новый Структура;
	ПараметрыЗадания.Вставить("РасширениеФайла", РасширениеФайла);
	ПараметрыЗадания.Вставить("ХранилищеДанныхФайла", ХранилищеДанных); 
	ПараметрыЗадания.Вставить("ДокументБюджета", ДокументСсылка);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Загрузка данных файла в бюджет.'");
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(
		"Обработки.ЗагрузкаБюджетаИзФайла.ВыполнитьЗагрузкуФайлаВФоне",
		ПараметрыЗадания, ПараметрыВыполнения);
	
КонецФункции 
	
&НаКлиенте
Процедура ЗагрузитьИзExcelЗавершение(Результат, ДополнительныеПараметры) Экспорт

    Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	РасширениеФайла = ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(Результат.Имя);
		
	ДлительнаяОперация = ДлительнаяОперацияЗагрузкиФайлаНаСервере(Результат.Хранение, РасширениеФайла, УникальныйИдентификатор);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	
	ДополнительныеПараметры = Новый Структура("АдресФайла, РасширениеФайла", Результат.Хранение, РасширениеФайла); 
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ВыполнитьЗагрузкуФайлаСерверЗавершение", ЭтотОбъект, ДополнительныеПараметры);	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
        
КонецПроцедуры 

&НаКлиенте
Процедура ВыполнитьЗагрузкуФайлаСерверЗавершение(ДлительнаяОперация, ДополнительныеПараметры) Экспорт
	
	ЗагруженныеДанные = ЗагруженныеДанныеХранилища(ДлительнаяОперация.АдресРезультата);	
	
	Если ЗначениеЗаполнено(ЗагруженныеДанные.Ошибки) Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("АдресФайла", ДополнительныеПараметры.АдресФайла);
		ПараметрыФормы.Вставить("ТабличныйДокумент", ЗагруженныеДанные.ТабличныйДокумент);
		ПараметрыФормы.Вставить("Документ", ДокументСсылка); 
		ОткрытьФорму("Обработка.ЗагрузкаБюджетаИзФайла.Форма", ПараметрыФормы, ЭтотОбъект);
	Иначе
		Если Объект.Утвержден Тогда
			ПараметрыФормы = Новый Структура("ДокументСсылка", ЗагруженныеДанные.ДокументКорректировки); 
			ОткрытьФорму("Обработка.КорректировкаБюджета.Форма.Форма", ПараметрыФормы);
			Оповестить("Запись_КорректировкаБюджета", , ЗагруженныеДанные.ДокументКорректировки);	
		Иначе
			Оповестить("Запись_КорректировкаБюджета", , ДокументСсылка);
		КонецЕсли;

		ПоказатьОповещениеПользователя(НСтр("ru = 'Загрузка бюджета успешно произведена.'"), , , БиблиотекаКартинок.ВыполненоУспешно);
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Функция  ЗагруженныеДанныеХранилища(АдресРезультата)
	
	ЗагруженныеДанные = ПолучитьИзВременногоХранилища(АдресРезультата);
	УдалитьИзВременногоХранилища(АдресРезультата);
	
	Возврат ЗагруженныеДанные; 

КонецФункции
#КонецОбласти

&НаКлиенте
Процедура ОтправитьПоЭлектроннойПочтеНастройкаУчетнойЗаписиПредложена(УчетнаяЗаписьНастроена, ДополнительныеПараметры) Экспорт
	
	Если УчетнаяЗаписьНастроена <> Истина Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыПисьма = РаботаСПочтовымиСообщениямиКлиент.ПараметрыОтправкиПисьма();
	ПараметрыПисьма.Получатель = "bp@1c.ru";
	ПараметрыПисьма.Тема = НСтр("ru = 'Отзыв о функциональности ""Бюджет денежных средств""'");
	
	РаботаСПочтовымиСообщениямиКлиент.СоздатьНовоеПисьмо(ПараметрыПисьма);
	
КонецПроцедуры
#КонецОбласти