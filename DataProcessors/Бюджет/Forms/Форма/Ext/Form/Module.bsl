	КнопкиОтвета = Новый СписокЗначений;
	КнопкиОтвета.Добавить(КодВозвратаДиалога.Да, НСтр("ru='Да, сохранить'"));
	КнопкиОтвета.Добавить(КодВозвратаДиалога.Нет, НСтр("ru='Нет'"));
	КнопкиОтвета.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru='Отмена'"));
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, КнопкиОтвета);
	
