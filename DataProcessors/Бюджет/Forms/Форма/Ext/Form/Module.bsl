&НаКлиенте
Процедура ПроверитьКорректностьГода(Отказ)
	
	ГодЧислом = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(ОтображениеПериода);
	
	Если ГодЧислом < 2000 Тогда
		ТекстОшибки = НСтр("ru = 'Дата бюджета должна быть не ранее 2000 года'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки, , "ОтображениеПериода", , Отказ);
		
	ИначеЕсли ГодЧислом > 3999 Тогда
		ТекстОшибки = НСтр("ru = 'Дата бюджета должна быть не позднее 3999 года'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки, , "ОтображениеПериода", , Отказ);
	КонецЕсли;
	
КонецПроцедуры

