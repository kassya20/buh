			,
			,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НовыйДокументыБезСоответствия()
	
	Результат = Новый ТаблицаЗначений;
	ТипыДокументов = Новый Массив;
	ТипыДокументов.Добавить(Тип("ДокументСсылка.СписаниеСРасчетногоСчета"));
	ТипыДокументов.Добавить(Тип("ДокументСсылка.ПоступлениеНаРасчетныйСчет"));
	Результат.Колонки.Добавить("Документ", Новый ОписаниеТипов(ТипыДокументов));
	Результат.Колонки.Добавить("Признак", Новый ОписаниеТипов("ПеречислениеСсылка.ПризнакиНалоговойБазыАУСН"));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ОбновитьФорму(Документ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазметкаАУСНОбороты.БанковскаяОперация КАК БанковскаяОперация,
		|	РазметкаАУСНОбороты.ПризнакНалоговойБазы КАК ПризнакНалоговойБазы1С,
		|	РазметкаАУСНОбороты.СуммаОборот КАК Сумма1С,
		|	НАЧАЛОПЕРИОДА(РазметкаАУСНОбороты.БанковскаяОперация.Дата, ДЕНЬ) КАК Дата1С
		|ИЗ
		|	РегистрНакопления.РазметкаАУСН.Обороты(, , , БанковскаяОперация = &БанковскаяОперация) КАК РазметкаАУСНОбороты";
	
	Запрос.УстановитьПараметр("БанковскаяОперация", Документ);
	
	Разметка = Запрос.Выполнить().Выгрузить();
	Отбор = Новый Структура("БанковскаяОперация", Документ);
	СтрокиТаблицыФормы = ДанныеСверки.НайтиСтроки(Отбор);
	
	ВыполнитьСопоставлениеСтрок(Разметка, СтрокиТаблицыФормы);
	ВыполнитьСопоставлениеСтрок(Разметка, СтрокиТаблицыФормы, Ложь);
	
	Если ЗначениеЗаполнено(Разметка) Тогда
		Отбор.БанковскаяОперация = ЗначениеОперацияНеНайдена();
		Отбор.Вставить("Дата", Разметка[0].Дата1С);
		СтрокиСНезаполненнымДокументом = ДанныеСверки.НайтиСтроки(Отбор);
		ВыполнитьСопоставлениеСтрок(Разметка, СтрокиСНезаполненнымДокументом);
		ВыполнитьСопоставлениеСтрок(Разметка, СтрокиСНезаполненнымДокументом, Ложь);
	КонецЕсли;
	
	Для Каждого СтрокаРазметки Из Разметка Цикл
		ДобавитьСтроку(СтрокаРазметки, Ложь);
	КонецЦикла;
	
	Для Каждого СтрокаФормы Из СтрокиТаблицыФормы Цикл
		Если СтрокаФормы.ПризнакНалоговойБазыФНС <> ЗначениеОперацияНеНайдена() Тогда
			СтрокаФормы.БанковскаяОперация = ЗначениеОперацияНеНайдена();
			СтрокаФормы.ПризнакНалоговойБазы1С = ЗначениеОперацияНеНайдена();
			СтрокаФормы.ЕстьРасхождение = Истина;
		Иначе
			ДанныеСверки.Удалить(СтрокаФормы);
		КонецЕсли;
	КонецЦикла;
	
	УстановитьВариантОтображенияДанныхСверки();
	ДанныеСверки.Сортировать("Дата Убыв");
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьСопоставлениеСтрок(Разметка, СтрокиТаблицыФормы, ТолькоПолноеСоответствие = Истина)
	
	СоответствиеСтрок = Новый Соответствие;
	
	Для Каждого СтрокаРазметки Из Разметка Цикл
		Для Каждого СтрокаФормы Из СтрокиТаблицыФормы Цикл
			Если СоответствиеСтрок.Получить(СтрокаФормы) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;
			Если СтрокаФормы.Сумма = СтрокаРазметки.Сумма1С И СтрокаФормы.Дата = СтрокаРазметки.Дата1С Тогда
				Если ТолькоПолноеСоответствие
					И СтрокаФормы.ПризнакНалоговойБазыФНС <> СтрокаРазметки.ПризнакНалоговойБазы1С Тогда
					Продолжить;
				Иначе
					СоответствиеСтрок.Вставить(СтрокаФормы, СтрокаРазметки);
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Для Каждого Элемент Из СоответствиеСтрок Цикл
		СтрокаФормы = Элемент.Ключ;
		СтрокаРазметки = Элемент.Значение;
		СтрокаФормы.Дата = СтрокаРазметки.Дата1С;
		СтрокаФормы.БанковскаяОперация = СтрокаРазметки.БанковскаяОперация;
		СтрокаФормы.ПризнакНалоговойБазы1С = СтрокаРазметки.ПризнакНалоговойБазы1С;
		СтрокаФормы.ЕстьРасхождение = СтрокаФормы.ПризнакНалоговойБазы1С <> СтрокаФормы.ПризнакНалоговойБазыФНС;
		Разметка.Удалить(СтрокаРазметки);
		Индекс = СтрокиТаблицыФормы.Найти(СтрокаФормы);
		СтрокиТаблицыФормы.Удалить(Индекс);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьУдаленныеБанковскиеОперации()
	
	ДокументыСверки = ДанныеСверки.Выгрузить( , "БанковскаяОперация");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СписаниеСРасчетногоСчета.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.СписаниеСРасчетногоСчета КАК СписаниеСРасчетногоСчета
		|ГДЕ
		|	НЕ СписаниеСРасчетногоСчета.Проведен
		|	И СписаниеСРасчетногоСчета.Ссылка В(&Документы)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПоступлениеНаРасчетныйСчет.Ссылка
		|ИЗ
		|	Документ.ПоступлениеНаРасчетныйСчет КАК ПоступлениеНаРасчетныйСчет
		|ГДЕ
		|	НЕ ПоступлениеНаРасчетныйСчет.Проведен
		|	И ПоступлениеНаРасчетныйСчет.Ссылка В(&Документы)";
	
	Запрос.УстановитьПараметр("Документы", ДокументыСверки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Отбор = Новый Структура("БанковскаяОперация", Выборка.Ссылка);
		НайденныеСтроки = ДанныеСверки.НайтиСтроки(Отбор);
		Для Каждого Строка Из НайденныеСтроки Цикл
			Если Строка.ПризнакНалоговойБазыФНС = ЗначениеОперацияНеНайдена() Тогда
				ДанныеСверки.Удалить(Строка);
			Иначе
				Строка.БанковскаяОперация = ЗначениеОперацияНеНайдена();
				Строка.ПризнакНалоговойБазы1С = ЗначениеОперацияНеНайдена();
				Строка.ЕстьРасхождение = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	УстановитьВариантОтображенияДанныхСверки();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВариантОтображенияДанныхСверки()
	
	СтрокиСРасхождениями = ДанныеСверки.НайтиСтроки(Новый Структура("ЕстьРасхождение", Истина));
	Если СтрокиСРасхождениями.Количество() > 0 Тогда
		ВариантОтображенияОпераций = "Расхождения";
		СостояниеФормы = СостоянияФормы().ВыполненоСРасхождениями;
	Иначе
		ВариантОтображенияОпераций = "Все";
		СостояниеФормы = СостоянияФормы().СверкаУспешноЗавершена;
	КонецЕсли;
	
	УстановитьОтборСтрок(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти