#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Параметры.Организация) Тогда
		Организация = Параметры.Организация;
	Иначе
		ВызватьИсключение НСтр("ru = 'Не заполнена организация'");
	КонецЕсли;
	
	СхемаЗапроса = Новый СхемаЗапроса;
	Запрос = Новый Запрос;
	СхемаЗапроса.УстановитьТекстЗапроса(
		"ВЫБРАТЬ
		|	БанковскиеСчета.Банк КАК Банк,
		|	БанковскиеСчета.Банк.Код КАК Код,
		|	БанковскиеСчета.Банк.Наименование КАК Наименование
		|ПОМЕСТИТЬ ВТ_Банки
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	НЕ БанковскиеСчета.ПометкаУдаления
		|	И БанковскиеСчета.Владелец = &Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СостоянияИнтеграцииАУСН.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияИнтеграцииАУСН.Отсутствует)) КАК СостояниеИнтеграции,
		|	ВТ_Банки.Наименование КАК Наименование
		|ИЗ
		|	ВТ_Банки КАК ВТ_Банки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияИнтеграцииАУСН КАК СостоянияИнтеграцииАУСН
		|		ПО ВТ_Банки.Код = СостоянияИнтеграцииАУСН.Банк.Код
		|ГДЕ
		|	СостоянияИнтеграцииАУСН.Организация = &Организация");
	
	Если ЗначениеЗаполнено(Параметры.Банки) Тогда
		СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Отбор.Добавить("БанковскиеСчета.Банк В (&Банки)");
		Банки = Параметры.Банки.ВыгрузитьЗначения();
		Запрос.УстановитьПараметр("Банки", Банки);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Выборка = Запрос.Выполнить().Выбрать();
	ИнтегрированныеБанки = Новый Массив;
	НеИнтегрированныеБанки = Новый Массив;
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.СостояниеИнтеграции = ПредопределенноеЗначение("Перечисление.СостоянияИнтеграцииАУСН.Подключено") Тогда
			ИнтегрированныеБанки.Добавить(Выборка.Наименование);
		Иначе
			НеИнтегрированныеБанки.Добавить(Выборка.Наименование);
		КонецЕсли;
	КонецЦикла;
	
	Если НеИнтегрированныеБанки.Количество() > 0 Тогда
		Элементы.ПереченьНеИнтегрированныхБанков.Видимость = Истина;
		Элементы.ИнструкцияНеИнтегрированныеБанки.Видимость = Истина;
		ПереченьБанков = СтрСоединить(НеИнтегрированныеБанки, ", ");
		Если НеИнтегрированныеБанки.Количество() = 1 Тогда
			Элементы.ПереченьНеИнтегрированныхБанков.Заголовок = СтрШаблон(
				НСтр("ru = '%1 (не подключен к сервису АУСН)'"), ПереченьБанков);
		Иначе
			Элементы.ПереченьНеИнтегрированныхБанков.Заголовок = СтрШаблон(
				НСтр("ru = '%1 (не подключены к сервису АУСН)'"), ПереченьБанков);
		КонецЕсли;
		Элементы.ИнструкцияБанкиНеНайдены.Видимость = Ложь;
	Иначе
		Элементы.ПереченьНеИнтегрированныхБанков.Видимость = Ложь;
		Элементы.ИнструкцияНеИнтегрированныеБанки.Видимость = Ложь;
	КонецЕсли;
	
	Если ИнтегрированныеБанки.Количество() > 0 Тогда
		Элементы.ПереченьИнтегрированныхБанков.Видимость = Истина;
		Элементы.ИнструкцияИнтегрированныеБанки.Видимость = Истина;
		ПереченьБанков = СтрСоединить(ИнтегрированныеБанки, ", ");
		Если ИнтегрированныеБанки.Количество() = 1 Тогда
			Элементы.ПереченьИнтегрированныхБанков.Заголовок = СтрШаблон(
				НСтр("ru = '%1 (подключен к сервису АУСН)'"), ПереченьБанков);
		Иначе
			Элементы.ПереченьИнтегрированныхБанков.Заголовок = СтрШаблон(
				НСтр("ru = '%1 (подключены к сервису АУСН)'"), ПереченьБанков);
		КонецЕсли;
		Элементы.ИнструкцияБанкиНеНайдены.Видимость = Ложь;
	Иначе
		Элементы.ПереченьИнтегрированныхБанков.Видимость = Ложь;
		Элементы.ИнструкцияИнтегрированныеБанки.Видимость = Ложь;
	КонецЕсли;
	
	Если ИнтегрированныеБанки.Количество() = 0 И НеИнтегрированныеБанки.Количество() = 0 Тогда
		Элементы.ИнструкцияБанкиНеНайдены.Видимость = Истина;
		Элементы.ИнструкцияБанкиНеНайдены.Заголовок = СтрШаблон(
			НСтр("ru = 'У организации ""%1"" нет банковских счетов в программе.'"), Организация);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "Обмен" Тогда
		СтандартнаяОбработка = Ложь;
		Если Не ДоступенОбменССервисомАУСН() Тогда
			ТекстСообщения = НСтр(
				"ru = 'Недостаточно прав доступа для выполнения обмена с сервисом АУСН. Обратитесь к администратору информационной базы.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
		ПараметрыОткрываемойФормы = Новый Структура;
		ПараметрыОткрываемойФормы.Вставить("РежимПоУмолчанию", "ГруппаЗагрузка");
		ПараметрыОткрываемойФормы.Вставить("РежимЗагрузки", "");
		ПараметрыОткрываемойФормы.Вставить("Организация", Организация);
		ПараметрыОткрываемойФормы.Вставить("БанковскийСчет", БанковскийСчет(Организация));
		ОткрытьФорму("Обработка.КлиентБанк.Форма.Форма", ПараметрыОткрываемойФормы, ЭтотОбъект);
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ЖР" Тогда
		СтандартнаяОбработка = Ложь;
		Если Не ОбщегоНазначенияБПВызовСервера.ДоступенПросмотрЖурналаРегистрации() Тогда
			ТекстСообщения = НСтр(
				"ru = 'Просмотр журнала регистрации запрещен. Обратитесь к администратору информационной базы.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			Возврат;
		КонецЕсли;
		ОтборЖурнала = Новый Структура;
		ОтборЖурнала.Вставить("СобытиеЖурналаРегистрации", ИнтеграцияАУСНКлиентСервер.ИмяСобытияЖурналаРегистрации());
		ОтборЖурнала.Вставить("Уровень", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Ошибка"));
		ЖурналРегистрацииКлиент.ОткрытьЖурналРегистрации(ОтборЖурнала);
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "Техподдержка" Тогда
		СтандартнаяОбработка = Ложь;
		ОбратитьсяВТехподдержку();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция БанковскийСчет(Организация)
	
	БанкПоКлассификатору = РегистрыСведений.СостоянияИнтеграцииАУСН.БанкИнтеграции(Организация);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	БанковскиеСчета.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	БанковскиеСчета.Владелец = &Организация
		|	И БанковскиеСчета.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанкПоКлассификатору, "Код"));
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
	
КонецФункции

&НаКлиенте
Процедура ОбратитьсяВТехподдержку()
	
	ДанныеСообщения = СообщенияВСлужбуТехническойПоддержкиКлиентСервер.ДанныеСообщения();
	
	ДанныеСообщения.Тема = ТемаСообщенияВПоддержку();
	ДанныеСообщения.Сообщение = ТекстСообщенияВПоддержку();
	ДанныеСообщения.Получатель = "v8";
	ДанныеСообщения.ИНН = ИННОрганизации(Организация);
	ДанныеСообщения.ИспользоватьСтандартныйШаблон = Ложь;
	
	ОтборЖурналаРегистрации = Новый Структура;
	
	ОтборЖурналаРегистрации.Вставить("ДатаНачала", НачалоДня(ТекущаяДата()));
	ОтборЖурналаРегистрации.Вставить("ДатаОкончания", КонецДня(ТекущаяДата()));
	ОтборЖурналаРегистрации.Вставить(
		"События",
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИнтеграцияАУСНКлиентСервер.ИмяСобытияЖурналаРегистрации()));
	ОтборЖурналаРегистрации.Вставить("Метаданные", Неопределено);
	ОтборЖурналаРегистрации.Вставить("Уровень", "Ошибка");
	
	СообщенияВСлужбуТехническойПоддержкиКлиент.ОтправитьСообщение(
		ДанныеСообщения, Неопределено, ОтборЖурналаРегистрации);
	
КонецПроцедуры

&НаКлиенте
Функция ТемаСообщенияВПоддержку()
	
	Возврат НСтр("ru = 'Ошибка обмена с сервисом АУСН'");
	
КонецФункции

&НаКлиенте
Функция ТекстСообщенияВПоддержку()
	
	Возврат НСтр(
		"ru = 'Не получается выполнить сверку разметки АУСН с данными ЛК ФНС.
		|Файл с ошибками из журнала регистрации во вложении.'");
	
КонецФункции

&НаСервереБезКонтекста
Функция ИННОрганизации(Организация)
	
	ИНН = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ИНН");
	Возврат ИНН;
	
КонецФункции

Функция ДоступенОбменССервисомАУСН()
	
	Возврат ПравоДоступа("Изменение", Метаданные.РегистрыСведений.СостоянияИнтеграцииАУСН);
	
КонецФункции

#КонецОбласти