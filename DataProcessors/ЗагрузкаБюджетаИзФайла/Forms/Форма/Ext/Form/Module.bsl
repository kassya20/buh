
#Область ОбработчикиСобытийФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не Параметры.Свойство("Документ") Тогда	
		ВызватьИсключение НСтр("ru = 'Обработка не предназначена для непосредственного использования.'");
	КонецЕсли;
	
	УстановитьУсловноеОформление();
	
	АдресФайла = Параметры.АдресФайла;
	ДокументБюджета = Параметры.Документ; 
	ДанныеФайла = Параметры.ТабличныйДокумент;  
	НужнаКорректировка  = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументБюджета, "Утвержден"); 
	Детализация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументБюджета, "Детализация"); 
	
	Если Детализация = Перечисления.Периодичность.Квартал Тогда
		ИмяПериода = "СуммаКвартал";
		КоличествоПериодов = 4;
	Иначе 
		ИмяПериода = "СуммаМесяц";
		КоличествоПериодов = 12;
	КонецЕсли;

	Если Не ЗначениеЗаполнено(АдресФайла) Или Не ЭтоАдресВременногоХранилища(АдресФайла) Тогда
		ТекстИсключения = НСтр("ru = 'Не выбран файл для загрузки.
		|Откройте обработку из формы бюджета с помощью команды ""Загрузить из Excel"".'");
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	ОписаниеКолонок.Загрузить(Обработки.ЗагрузкаБюджетаИзФайла.ОписаниеЗагружаемыхКолонок(Детализация));
	Элементы.ГруппаШаг1.Видимость = Ложь;
	Элементы.ГруппаШаг2.Видимость = Ложь;
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ТабличнаяЧастьИзменена = Ложь;
	ПодключитьОбработчикОжидания("Подключаемый_ПодготовитьТабличныйДокумент", 0.1, Истина);
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	ОтборТаблицы = 0;
	Для Каждого СтрокаТаблицы Из Объект.Бюджет Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.СтатьяДДС) И ПустаяСтрока(СтрокаТаблицы.НаименованиеСтатьиДДС) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Поле", "Заполнение", "Статья доходов и расходов"); 
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Отказ);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.НаправлениеДеятельности) И ПустаяСтрока(СтрокаТаблицы.НаименованиеНаправленияДеятельности) 
			И СтрокаТаблицы.Раздел = "Расход" Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Поле", "Заполнение", "Направление деятельности");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Отказ);
		КонецЕсли;
		
		Если СтрокаТаблицы.ЕстьДубли Тогда
			Если СтрокаТаблицы.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль() Тогда 	
				ТекстСообщения = СтрШаблон(НСтр("ru = 'Найдено несколько статей %1. Двойным кликом выберите одну из списка.'"), 
					СтрокаТаблицы.НаименованиеСтатьиДДС);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Отказ);
			КонецЕсли;
			Если СтрокаТаблицы.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль() Тогда
				ТекстСообщения = СтрШаблон(НСтр("ru = 'Найдено несколько направлений деятельности %1. Двойным кликом выберите одну из списка.'"), 
					СтрокаТаблицы.НаименованиеНаправленияДеятельности);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Отказ);
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
		
	ПроверитьНаДублирующиеЭлементы("Финансирование", Отказ); 
	ПроверитьНаДублирующиеЭлементы("Расход", Отказ);

КонецПроцедуры 

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ИсточникВыбора.ИмяФормы = "Справочник.СтатьиДвиженияДенежныхСредств.Форма.ФормаВыбора" Тогда
		
		ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли; 
		МодификацияДерево = Истина;
		ТекущиеДанные.СтатьяДДС = ВыбранноеЗначение;
		ТекущиеДанные.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный(); 
		ТекущиеДанные.ЕстьДубли = Ложь;
		ТекущиеДанные.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
		Если ТекущиеДанные.Раздел = "Расход" Тогда
			СтрокаНаправленияДеятельности = ТекущиеДанные.ПолучитьРодителя(); 
			Если СтрокаНаправленияДеятельности.СтатусНаправленияДеятельности <> ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль() Тогда
				СтрокаНаправленияДеятельности.ЕстьДубли = Ложь; 
				ТекущиеДанные.НайденнаяСтрока = Истина;
			КонецЕсли;
		Иначе 
			ТекущиеДанные.НайденнаяСтрока = Истина;
		КонецЕсли;
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Справочник.НаправленияДеятельности.Форма.ФормаВыбора" Тогда
		ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
		Если ТекущиеДанные = Неопределено Тогда
			Возврат;
		КонецЕсли;
		МодификацияДерево = Истина;
		ТекущиеДанные.НаправлениеДеятельности = ВыбранноеЗначение;
		ТекущиеДанные.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный(); 
		Если Не ТекущиеДанные.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль() Тогда
			ТекущиеДанные.ЕстьДубли = Ложь;	
		КонецЕсли;      
		ТекущиеДанные.НайденнаяСтрока = Истина; 
		ТекущиеДанные.КартинкаСтроки = БиблиотекаКартинок.ПриложитьФайл;
		
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти  

#Область ОбработчикиСобытийТабличногоДокумента
&НаКлиенте
Процедура ДанныеФайлаВыбор(Элемент, Область, СтандартнаяОбработка)
	
	Если Область.Верх = 1 И Область.Лево <= ДанныеФайла.ШиринаТаблицы Тогда
		
		ДополнительныеПараметры = Новый Структура("ТекущаяОбласть", Область);
		ОписаниеОповещения = Новый ОписаниеОповещения("ДанныеФайлаВыборЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ОписаниеКолонок", ОписаниеКолонокВоВременномХранилище());
		ОткрытьФорму("ОбщаяФорма.ВыборКолонокПриЗагрузкеИзФайла", ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДанныеФайлаВыборЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Или РезультатЗакрытия = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ТекстНезаполненногоЗаголовка = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.ТекстЗаголовкаНесопоставленнойКолонки();
	Для НомерКолонки = 1 По ДанныеФайла.ШиринаТаблицы Цикл
		
		Область = ДанныеФайла.Область(1, НомерКолонки);
		Если Область.ПараметрРасшифровки = РезультатЗакрытия.Идентификатор Тогда
			Область.Текст = ТекстНезаполненногоЗаголовка;
			Область.ПараметрРасшифровки = "";
			Область.ЦветТекста = ОбщегоНазначенияКлиентПовтИсп.ЦветСтиля("НезаполненныйРеквизит");
		КонецЕсли;
		
	КонецЦикла;
	
	ДополнительныеПараметры.ТекущаяОбласть.Текст      = РезультатЗакрытия.Представление;
	ДополнительныеПараметры.ТекущаяОбласть.ЦветТекста = ОбщегоНазначенияКлиентПовтИсп.ЦветСтиля("ЦветГиперссылки");
	ДополнительныеПараметры.ТекущаяОбласть.ПараметрРасшифровки = РезультатЗакрытия.Идентификатор;
	
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийДеревоБюджета
&НаКлиенте
Процедура ДеревоБюджетаПриИзменении(Элемент)
	
	МодификацияДерево = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.СтатьяДДС) Тогда		
		ТекущиеДанные.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();
		ТекущиеДанные.ЕстьНовыеСтроки = Ложь;	
		ТекущиеДанные.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
		Если ТекущиеДанные.Раздел = "Расход" Тогда
			СтрокаНаправленияДеятельности = ТекущиеДанные.ПолучитьРодителя(); 
			Если СтрокаНаправленияДеятельности.СтатусНаправленияДеятельности <> ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда
				СтрокаНаправленияДеятельности.ЕстьНовыеСтроки = Ложь; 
				ТекущиеДанные.НайденнаяСтрока = Истина;
			КонецЕсли;
		Иначе 
			ТекущиеДанные.НайденнаяСтрока = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	
	Если ТекущиеДанные.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда	
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = Новый СписокЗначений; 
		ТекстПодбора = СтрШаблон(НСтр("ru = 'Создать: %1'"), ТекущиеДанные.НаименованиеСтатьиДДС);
		ДанныеВыбора.Добавить(ТекстПодбора);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	
	Если ТекущиеДанные.Раздел = "Финансирование" Тогда
		ОтборВидСтатьи = Новый ПараметрВыбора("Отбор.ВидСтатьиДДС", ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.Доход"));
	Иначе
		ОтборВидСтатьи = Новый ПараметрВыбора("Отбор.ВидСтатьиДДС", ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.Расход"));
	КонецЕсли;  
	
	МассивОтборов = Новый Массив();  
	ОтборПометкаНаУдаление = Новый ПараметрВыбора("Отбор.ПометкаУдаления", Ложь);
	МассивОтборов.Добавить(ОтборПометкаНаУдаление);
	МассивОтборов.Добавить(ОтборВидСтатьи);
	ПараметрыОтбора = Новый ФиксированныйМассив(МассивОтборов);
	Элемент.ПараметрыВыбора = ПараметрыОтбора;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаСтатьяДДСОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") И СтрНайти(ВыбранноеЗначение, НСтр("ru = 'Создать:'")) > 0 Тогда
		
		СтандартнаяОбработка = Ложь;
		ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
		
		ДанныеЗаполнения = Новый Структура;
		ДанныеЗаполнения.Вставить("Наименование", ТекущиеДанные.НаименованиеСтатьиДДС); 
		
		Если ТекущиеДанные.Раздел = "Финансирование" Тогда
			ДанныеЗаполнения.Вставить("ВидСтатьиДДС", ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.Доход"));
		Иначе
			ДанныеЗаполнения.Вставить("ВидСтатьиДДС", ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.Расход"));
		КонецЕсли;
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РежимВыбора", Истина);
		ПараметрыФормы.Вставить("ТекстЗаполнения", ТекущиеДанные.НаименованиеСтатьиДДС);
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", ДанныеЗаполнения);
		
		ОткрытьФорму("Справочник.СтатьиДвиженияДенежныхСредств.ФормаОбъекта", ПараметрыФормы, Элемент);
		
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ДеревоБюджетаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	
	Если ТекущиеДанные.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль()
		И (Элемент.ТекущийЭлемент.Имя = "ДеревоБюджетаСтатьяДДС" ИЛИ Элемент.ТекущийЭлемент.Имя = "ДеревоБюджетаКартинкаСтатьиДДС") Тогда	
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ОтборДублей", ТекущиеДанные.СписокСтатейДДС);
		ОткрытьФорму("Справочник.СтатьиДвиженияДенежныхСредств.Форма.ФормаВыбора", ПараметрыФормы, ЭтотОбъект); 
	ИначеЕсли ТекущиеДанные.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль()
		И (Элемент.ТекущийЭлемент.Имя = "ДеревоБюджетаНаправлениеДеятельности" 
		ИЛИ Элемент.ТекущийЭлемент.Имя = "ДеревоБюджетаКартинкаНаправлениеДеятельности") Тогда	
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("ОтборДублей", ТекущиеДанные.СписокНаправленийДеятельности); 
		ОткрытьФорму("Справочник.НаправленияДеятельности.Форма.ФормаВыбора", ПараметрыФормы, ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаНаправлениеДеятельностиПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.НаправлениеДеятельности) Тогда		
		ТекущиеДанные.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();
		ТекущиеДанные.НайденнаяСтрока = Истина;
		Если Не ТекущиеДанные.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда
			ТекущиеДанные.ЕстьНовыеСтроки = Ложь;	
		КонецЕсли;   
		
		ТекущиеДанные.КартинкаСтроки = БиблиотекаКартинок.ПриложитьФайл;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаНаправлениеДеятельностиАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	
	Если ТекущиеДанные.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда	
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = Новый СписокЗначений; 
		ТекстПодбора = СтрШаблон(НСтр("ru = 'Создать: %1'"), ТекущиеДанные.НаименованиеНаправленияДеятельности);
		ДанныеВыбора.Добавить(ТекстПодбора);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоБюджетаНаправлениеДеятельностиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") И СтрНайти(ВыбранноеЗначение, НСтр("ru = 'Создать:'")) > 0 Тогда
		СтандартнаяОбработка = Ложь;
		ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
		
		ДанныеЗаполнения = Новый Структура;
		ДанныеЗаполнения.Вставить("Наименование", ТекущиеДанные.НаименованиеНаправленияДеятельности);  
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РежимВыбора", Истина);
		ПараметрыФормы.Вставить("ТекстЗаполнения", ТекущиеДанные.НаименованиеНаправленияДеятельности);
		ПараметрыФормы.Вставить("ЗначенияЗаполнения", ДанныеЗаполнения);
		
		ОткрытьФорму("Справочник.НаправленияДеятельности.ФормаОбъекта", ПараметрыФормы, Элемент);
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ДеревоБюджетаСуммаПриИзменении(Элемент)
	
	РассчитатьИтоги(Элемент);
	
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура УдалитьСтроку(Команда)
	
	Верх = ДанныеФайла.ТекущаяОбласть.Верх;
	Низ  = ДанныеФайла.ТекущаяОбласть.Низ;
	Лево = ДанныеФайла.ТекущаяОбласть.Лево;
	
	Если Верх = 1 И Низ = 1 Тогда
		
		Возврат; 		
	КонецЕсли;
	
	УдалитьСтрокиНаСервере(Верх, Низ);
	Элементы.ДанныеФайла.ТекущаяОбласть = ДанныеФайла.Область(Верх, Лево);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьКолонку(Команда)
	
	Лево  = ДанныеФайла.ТекущаяОбласть.Лево;
	Право = ДанныеФайла.ТекущаяОбласть.Право;
	Верх  = ДанныеФайла.ТекущаяОбласть.Верх;
	
	УдалитьКолонкиНаСервере(Лево, Право);
	Элементы.ДанныеФайла.ТекущаяОбласть = ДанныеФайла.Область(Верх, Лево);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЛишнее(Команда)
	
	ЗаголовкиЗаполнены = ЗагрузкаДанныхИзВнешнихФайловКлиент.ЗаполненыВсеЗаголовкиКолонок(ДанныеФайла, "ДанныеФайла", ОписаниеКолонок);
	
	Если ЗаголовкиЗаполнены Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьЛишнееПослеЗакрытияВопроса", ЭтотОбъект);
		ТекстВопроса = НСтр("ru = 'Найти и удалить строки и колонки, не содержащие информацию для загрузки?'");
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе 
		ТекстСообщения = НСтр("ru = 'Укажите названия колонок для сопоставления данных'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура Далее(Команда)
	
	ОчиститьСообщения();
	
	ЗаголовкиЗаполнены = ЗагрузкаДанныхИзВнешнихФайловКлиент.ЗаполненыВсеЗаголовкиКолонок(ДанныеФайла, "ДанныеФайла", ОписаниеКолонок);
	
	Если Не ЗаголовкиЗаполнены Тогда
		Возврат;
	КонецЕсли;
	
	ОтборТаблицы = 0;
	
	ДлительнаяОперация = ПодготовитьТаблицуБюджетаСервер();
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ВызватьИсключение ДлительнаяОперация.КраткоеПредставлениеОшибки;
	Иначе
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		Обработчик = Новый ОписаниеОповещения("ПодготовитьТаблицуДанныхДляЗагрузкиЗавершение", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)
	
	Если ТабличнаяЧастьИзменена Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаОПереходеНаПервыйШаг", ЭтотОбъект);
		ТекстВопроса = НСтр(
		"ru = 'Все изменения, произведенные вами в таблице, будут потеряны.
		|
		|Вернуться на предыдущий шаг?'");
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
		ТабличнаяЧастьИзменена = Ложь;
		
	Иначе
		
		ИзменитьШаг("Шаг1");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	
	ДлительнаяОперация = ЗагрузитьНаСервере();
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат; 
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ВызватьИсключение ДлительнаяОперация.КраткоеПредставлениеОшибки;
	Иначе
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		Обработчик = Новый ОписаниеОповещения("ЗагрузкаДанныхИзФайлаЗавершение", ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти

#Область УправлениеФормой 
&НаСервере
Процедура ИзменитьШаг(ТекущийШаг)
	
	Элементы.ГруппаОжидание.Видимость = Ложь;
	Элементы.ГруппаШаг1.Видимость = (ТекущийШаг = "Шаг1");
	Элементы.ГруппаШаг2.Видимость = (ТекущийШаг = "Шаг2");
	Элементы.Далее.КнопкаПоУмолчанию = (ТекущийШаг = "Шаг1");
	Элементы.Загрузить.КнопкаПоУмолчанию = (ТекущийШаг = "Шаг2");
	
КонецПроцедуры

