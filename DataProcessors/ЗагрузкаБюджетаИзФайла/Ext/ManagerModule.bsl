
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("ВыполнитьЗагрузкуФайлаВФоне", Истина);
	Методы.Вставить("ОбработатьДанныеИзФайла", Истина);
	Методы.Вставить("ПолучитьТаблицуДанныхБюджета", Истина);
	Методы.Вставить("ЗагрузитьДанныеФайла", Истина);
	Методы.Вставить("УдалитьВсеНенужныеСтрокиТаблицы", Истина);
	
КонецПроцедуры

// Выполняет загрузку бюджета из файла 
// Считывает данные файла в табличный документ и определяет загружаемые колонки.
// По данным табличного документа заполняет таблицу бюджета для загрузки.
// Загружает подготовленные данные в информационную базу.
// Создает новую статью ддс, направление деятельности и документ бюджет или корректировка бюджета.
//
// Параметры:
//   ПараметрыЗадания - Структура - структура с ключами:
//      * ХранилищеДанныхФайла - ХранилищеЗначения - двоичные данные файла, упакованные в хранилище значений.
//      * РасширениеФайла - Строка - расширение файла.
//      * ДокументСсылка - ДокументСсылка.Бюджет, ДокументСсылка.Бюджет  - документ бюджета.
//   АдресХранилища - УникальныйИдентификатор - адрес во временном хранилище для сохранения результатов.
//
Процедура ВыполнитьЗагрузкуФайлаВФоне(ПараметрыЗадания, АдресХранилища) Экспорт
	
	ДокументБюджета = ПараметрыЗадания.ДокументБюджета;
	ОписаниеКолонок = ОписаниеЗагружаемыхКолонок(ДокументБюджета.Детализация);	
	Детализация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументБюджета, "Детализация"); 
	
	ПараметрыЗадания.Вставить("МакетЗаголовка", ПолучитьМакет("МакетЗаголовка"));
	ПараметрыЗадания.Вставить("ОписаниеКолонок", ОписаниеКолонок);
	
	ТабличныйДокумент = ЗагрузкаДанныхИзВнешнихФайлов.ЗагрузитьФайлВТабличныйДокумент(ПараметрыЗадания);		
	 					
	Если ЕстьНезаполненныеКолонки(ТабличныйДокумент) Тогда
		ПоместитьОшибкиПоЗагрузкеБюджета(ТабличныйДокумент, АдресХранилища);
		Возврат;	
	КонецЕсли;  
	
	Бюджет = НовыйТаблицаЗагружаемыхДанных();  
	
	ЕстьОшибки = Ложь;
	ОбработкаДанныхФайла(Бюджет, ТабличныйДокумент, Детализация, АдресХранилища, ЕстьОшибки);
	Если ЕстьОшибки Тогда  
		ПоместитьОшибкиПоЗагрузкеБюджета(ТабличныйДокумент, АдресХранилища);
		Возврат;
	КонецЕсли; 
	
	Для Каждого СтрокаТаблицы Из Бюджет Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.СтатьяДДС) И ПустаяСтрока(СтрокаТаблицы.НаименованиеСтатьиДДС) Тогда
			ПоместитьОшибкиПоЗагрузкеБюджета(ТабличныйДокумент, АдресХранилища);
			Возврат;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.НаправлениеДеятельности) И ПустаяСтрока(СтрокаТаблицы.НаименованиеНаправленияДеятельности) 
			И СтрокаТаблицы.Раздел = "Расход" Тогда
			ПоместитьОшибкиПоЗагрузкеБюджета(ТабличныйДокумент, АдресХранилища);
			Возврат; 
		КонецЕсли;
		
		Если СтрокаТаблицы.ЕстьДубли Тогда
			ПоместитьОшибкиПоЗагрузкеБюджета(ТабличныйДокумент, АдресХранилища);
			Возврат;
		КонецЕсли;
		
		Если СтрокаТаблицы.Раздел = "Финансирование" Тогда
			ПараметрыПоиска = Новый Структура("Раздел, СтатьяДДС", СтрокаТаблицы.Раздел, СтрокаТаблицы.СтатьяДДС);
		Иначе
			ПараметрыПоиска = Новый Структура("Раздел, НаправлениеДеятельности, СтатьяДДС", 
				СтрокаТаблицы.Раздел, СтрокаТаблицы.НаправлениеДеятельности, СтрокаТаблицы.СтатьяДДС);
		КонецЕсли;	
		НайденныеСтроки = Бюджет.НайтиСтроки(ПараметрыПоиска);
		Если НайденныеСтроки.Количество() > 1 Тогда
			ПоместитьОшибкиПоЗагрузкеБюджета(ТабличныйДокумент, АдресХранилища);
			Возврат;
		КонецЕсли;
		
	КонецЦикла; 
	
	ПараметрыЗаданияДляЗагрузкиФайла = Новый Структура; 
	ПараметрыЗаданияДляЗагрузкиФайла.Вставить("Бюджет", Бюджет);
	ПараметрыЗаданияДляЗагрузкиФайла.Вставить("Документ", ДокументБюджета);
	ПараметрыЗаданияДляЗагрузкиФайла.Вставить("ЭтоКорректировка", ДокументБюджета.Утвержден);  
	
	ЗагрузитьДанныеФайла(ПараметрыЗаданияДляЗагрузкиФайла, АдресХранилища);	

КонецПроцедуры

// Считывает данные файла в табличный документ и определяет загружаемые колонки.
//
// Параметры:
//   ПараметрыЗадания - Структура - структура с ключами:
//      * ХранилищеДанныхФайла - ХранилищеЗначения - двоичные данные файла, упакованные в хранилище значений.
//      * РасширениеФайла - Строка - расширение файла.
//      * ОписаниеКолонок - ТаблицаЗначений - описание загружаемых колонок, см. НовыйОписаниеЗагружаемыхКолонок().
//   АдресХранилища - УникальныйИдентификатор - адрес во временном хранилище для сохранения результатов.
//
Процедура ОбработатьДанныеИзФайла(ПараметрыЗадания, АдресХранилища) Экспорт
	
	ПараметрыЗадания.Вставить("МакетЗаголовка", ПолучитьМакет("МакетЗаголовка"));

	ТабличныйДокумент = ПараметрыЗадания.ТабличныйДокумент;
		
	Результат = Новый Структура;
	Результат.Вставить("ДанныеФайла", Новый ХранилищеЗначения(ТабличныйДокумент));
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры

// По данным табличного документа заполняет таблицу бюджета для загрузки.
// Выполняет поиск существующих статей ддс и направлений деятельности.
//
// Параметры:
//   ПараметрыЗадания - Структура - структура с ключами:
//      * ХранилищеДанных - ХранилищеЗначения - табличный документ, содержащий данные.
//   АдресХранилища - УникальныйИдентификатор - адрес во временном хранилище для сохранения результатов.
//
Процедура ПолучитьТаблицуДанныхБюджета(ПараметрыЗадания, АдресХранилища) Экспорт
	
	ДанныеФайла = ПараметрыЗадания.ХранилищеДанных.Получить();
	Детализация = ПараметрыЗадания.Детализация; 
	ЕстьОшибки = Ложь;
	Бюджет = НовыйТаблицаЗагружаемыхДанных();
	ОбработкаДанныхФайла(Бюджет, ДанныеФайла, Детализация, АдресХранилища, ЕстьОшибки);
	
	Результат = Новый Структура;
	Результат.Вставить("Бюджет", Бюджет);
	
	Если ЕстьОшибки Тогда  
		ТекстОшибки = НСтр("ru = 'Раздел должен быть заполнен во всех строках. Раздел может содержать значение Финансирование или Расход.'");
		Результат.Вставить("ТекстОшибки", ТекстОшибки);
	КонецЕсли; 
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры

// Загружает подготовленные данные в информационную базу.
// Создает новую статью ддс, направление деятельности и документ бюджет или корректировка бюджета.
//
// Параметры:
//   ПараметрыЗадания - Структура - структура с ключами:
//      * Бюджет - ТаблицаЗначений - таблица бюджета для загрузки.
//      * ДокументСсылка - ДокументСсылка.Бюджет, ДокументСсылка.Бюджет  - документ бюджета.
//      * ЭтоКорректировка - Булево - признак корректировки.
//   АдресХранилища - УникальныйИдентификатор - адрес во временном хранилище для сохранения результатов.
//
Процедура ЗагрузитьДанныеФайла(ПараметрыЗадания, АдресХранилища) Экспорт
	
	Бюджет = ПараметрыЗадания.Бюджет; 
	ДокументСсылка = ПараметрыЗадания.Документ;
	ЭтоКорректировка = ПараметрыЗадания.ЭтоКорректировка;
	Детализация = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Детализация");
	
	ДатаДетализации = НачалоГода(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка, "Дата"));
	МассивДетализация = Новый Массив;
	Если Детализация = Перечисления.Периодичность.Квартал Тогда
		ДатаДетализации = ДобавитьМесяц(ДатаДетализации, 2);	
		Для НомерПериода = 1 По 4 Цикл   
			МассивДетализация.Добавить(ДатаДетализации);
			ДатаДетализации = ДобавитьМесяц(ДатаДетализации, 3);		
		КонецЦикла;
		ИмяПериода = "СуммаКвартал";
	Иначе  
		Для НомерПериода = 1 По 12 Цикл
			МассивДетализация.Добавить(ДатаДетализации);
			ДатаДетализации = ДобавитьМесяц(ДатаДетализации, 1);
		КонецЦикла;  
		ИмяПериода = "СуммаМесяц";
	КонецЕсли;
	
	Если ЭтоКорректировка Или ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.КорректировкаБюджета") Тогда
		ЗагрузитьДанныеФайлаВКорректировку(ДокументСсылка, Бюджет, Детализация, МассивДетализация, АдресХранилища, ИмяПериода);
	Иначе
		ЗагрузитьДанныеФайлаВБюджет(ДокументСсылка, Бюджет, Детализация, МассивДетализация, АдресХранилища, ИмяПериода);
	КонецЕсли;
		
КонецПроцедуры 

// Удаляет строки и колонки, не содержащие полезной информации для загрузки.
//
// Параметры:
//   ПараметрыЗадания - Структура - структура с ключами:
//      * ХранилищеДанных - ХранилищеЗначения - табличный документ, содержащий данные.
//   АдресХранилища - УникальныйИдентификатор - адрес во временном хранилище для сохранения результатов.
//
Процедура УдалитьВсеНенужныеСтрокиТаблицы(ПараметрыЗадания, АдресХранилища) Экспорт

	ТабличныйДокумент = ПараметрыЗадания.ХранилищеДанных.Получить();
	
	НайденыНенужныеСтроки = Ложь;
	
	ВысотаТаблицы = ТабличныйДокумент.ВысотаТаблицы; 
	ШиринаТаблицы = ТабличныйДокумент.ШиринаТаблицы;
	
	СоответствиеКолонок = Новый Соответствие;
	Для НомерКолонки = 1 По ШиринаТаблицы Цикл	
		Ячейка = ТабличныйДокумент.Область(1, НомерКолонки);
		ТекстЯчейки = Ячейка.ПараметрРасшифровки;
		СоответствиеКолонок.Вставить(ТекстЯчейки, НомерКолонки);		
	КонецЦикла; 

	Для НомерСтроки = 2 По ВысотаТаблицы Цикл  
		Если ТабличныйДокумент.Область(НомерСтроки, 1).ПараметрРасшифровки = "НеЗагружать" Тогда
			Продолжить; 
		КонецЕсли;
		Если НомерСтроки > ВысотаТаблицы Тогда
			Прервать;
		КонецЕсли;  
		Если Не МожноУдалитьОбласть(ТабличныйДокумент, НомерСтроки, СоответствиеКолонок) Тогда
			Продолжить;	
		КонецЕсли;	
		НайденыНенужныеСтроки = Истина;
		Область = ТабличныйДокумент.Область(НомерСтроки, , НомерСтроки);
		ТабличныйДокумент.УдалитьОбласть(Область, ТипСмещенияТабличногоДокумента.ПоВертикали);
		НомерСтроки = НомерСтроки - 1;
		ВысотаТаблицы = ВысотаТаблицы - 1;
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("НайденыНенужныеСтроки", НайденыНенужныеСтроки);
	Результат.Вставить("ХранилищеДанных", Новый ХранилищеЗначения(ТабличныйДокумент));
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыФункции

// Запрос для поиска статьи ддс по данным колонок таблицы
//
// Параметры:
//  Таблица				- 	ТаблицаЗначений - таблица с данными для поиска 
//  РеквизитыДляПоиска	- 	Строка - перечисление названий полей, по которым необходимо производить поиск. 
// 
// Возвращаемое значение:
//  Запрос - запрос для получения результата поиска
//
Функция ЗапросПоискаСтатьиДДС(Таблица, РеквизитыДляПоиска)
	
	ТаблицаДляПроверки = ТаблицаДляПроверки(Таблица);
		
	Запрос = Новый Запрос;
	ПараметрыЗапроса = ЗначенияВесовВыборки(РеквизитыДляПоиска);
	ПараметрыЗапроса.Вставить("Таблица", ТаблицаДляПроверки);   
	
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		Запрос.УстановитьПараметр(ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);
	КонецЦикла;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.СтатьяДДС КАК СтатьяДДСПоУИД,
	|	Таблица.НаименованиеСтатьиДДС КАК НаименованиеСтатьиДДС,
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.СтатьяДДСНайденоПоУИД КАК СтатьяДДСНайденоПоУИД
	|ПОМЕСТИТЬ Таблица
	|ИЗ
	|	&Таблица КАК Таблица
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СтатьяДДСНайденоПоУИД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.НаименованиеСтатьиДДС КАК НаименованиеСтатьиДДСТаблица,
	|	Таблица.СтатьяДДСНайденоПоУИД КАК СтатьяДДСНайденоПоУИД,
	|	ЕСТЬNULL(СтатьяДДСПоПолямПоиска.Ссылка, ЗНАЧЕНИЕ(Справочник.СтатьиДвиженияДенежныхСредств.ПустаяСсылка)) КАК СтатьяДДС,
	|	ЕСТЬNULL(СтатьяДДСПоПолямПоиска.Наименование, """") КАК НаименованиеСтатьиДДС
	|ПОМЕСТИТЬ ВТСтатьяДДСПоПолямПоиска
	|ИЗ
	|	Таблица КАК Таблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтатьиДвиженияДенежныхСредств КАК СтатьяДДСПоПолямПоиска
	|		ПО (Таблица.СтатьяДДСНайденоПоУИД = ЛОЖЬ)
	|			И (&ПоискПоНаименованиюСтатьиДДС)
	|			И (НЕ СтатьяДДСПоПолямПоиска.ПометкаУдаления)
	|			И Таблица.НаименованиеСтатьиДДС = СтатьяДДСПоПолямПоиска.Наименование
	|ГДЕ
	|	СтатьяДДСПоПолямПоиска.Ссылка <> ЗНАЧЕНИЕ(Справочник.СтатьиДвиженияДенежныхСредств.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСтатьяДДСПоПолямПоиска.НомерСтроки КАК НомерСтроки,
	|	ВТСтатьяДДСПоПолямПоиска.СтатьяДДС КАК СтатьяДДС,
	|	ВТСтатьяДДСПоПолямПоиска.СтатьяДДСНайденоПоУИД КАК СтатьяДДСНайденоПоУИД
	|ИЗ
	|	ВТСтатьяДДСПоПолямПоиска КАК ВТСтатьяДДСПоПолямПоиска
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Таблица.НомерСтроки,
	|	Таблица.СтатьяДДСПоУИД,
	|	Таблица.СтатьяДДСНайденоПоУИД
	|ИЗ
	|	Таблица КАК Таблица
	|ГДЕ
	|	Таблица.СтатьяДДСНайденоПоУИД
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|ИТОГИ ПО
	|	НомерСтроки";
	
	Возврат Запрос;
	
КонецФункции 

// Запрос для поиска направления деятельности по данным колонок таблицы
//
// Параметры:
//  Таблица				- 	ТаблицаЗначений - таблица с данными для поиска 
//  РеквизитыДляПоиска	- 	Строка - перечисление названий полей, по которым необходимо производить поиск. 
// 
// Возвращаемое значение:
//  Запрос - запрос для получения результата поиска
//
Функция ЗапросПоискаНаправленияДеятельности(Таблица, РеквизитыДляПоиска)
	
	ТаблицаДляПроверки = ТаблицаДляПроверки(Таблица);
		
	Запрос = Новый Запрос;
	ПараметрыЗапроса = ЗначенияВесовВыборки(РеквизитыДляПоиска);
	ПараметрыЗапроса.Вставить("Таблица", ТаблицаДляПроверки); 
	
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		Запрос.УстановитьПараметр(ПараметрЗапроса.Ключ, ПараметрЗапроса.Значение);
	КонецЦикла;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.НаправлениеДеятельности КАК НаправлениеДеятельностиПоУИД,
	|	Таблица.НаименованиеНаправленияДеятельности КАК НаименованиеНаправленияДеятельности,
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.НаправлениеДеятельностиНайденоПоУИД КАК НаправлениеДеятельностиНайденоПоУИД
	|ПОМЕСТИТЬ Таблица
	|ИЗ
	|	&Таблица КАК Таблица
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НаправлениеДеятельностиНайденоПоУИД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.НомерСтроки КАК НомерСтроки,
	|	Таблица.НаименованиеНаправленияДеятельности КАК НаименованиеНаправленияДеятельностиТаблица,
	|	Таблица.НаправлениеДеятельностиНайденоПоУИД КАК НаправлениеДеятельностиНайденоПоУИД,
	|	ЕСТЬNULL(НаправлениеДеятельностиПоПолямПоиска.Ссылка, ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)) КАК НаправлениеДеятельности,
	|	ЕСТЬNULL(НаправлениеДеятельностиПоПолямПоиска.Наименование, """") КАК НаименованиеНаправлениеДеятельности
	|ПОМЕСТИТЬ ВТНаправлениеДеятельностиПоПолямПоиска
	|ИЗ
	|	Таблица КАК Таблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаправленияДеятельности КАК НаправлениеДеятельностиПоПолямПоиска
	|		ПО (Таблица.НаправлениеДеятельностиНайденоПоУИД = ЛОЖЬ)
	|			И (&ПоискПоНаименованиюНаправлениеДеятельности) 
	|			И (НЕ НаправлениеДеятельностиПоПолямПоиска.ПометкаУдаления)
	|			И Таблица.НаименованиеНаправленияДеятельности = НаправлениеДеятельностиПоПолямПоиска.Наименование
	|ГДЕ
	|	НаправлениеДеятельностиПоПолямПоиска.Ссылка <> ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТНаправлениеДеятельностиПоПолямПоиска.НомерСтроки КАК НомерСтроки,
	|	ВТНаправлениеДеятельностиПоПолямПоиска.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ВТНаправлениеДеятельностиПоПолямПоиска.НаправлениеДеятельностиНайденоПоУИД КАК НаправлениеДеятельностиНайденоПоУИД
	|ИЗ
	|	ВТНаправлениеДеятельностиПоПолямПоиска КАК ВТНаправлениеДеятельностиПоПолямПоиска
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Таблица.НомерСтроки,
	|	Таблица.НаправлениеДеятельностиПоУИД,
	|	Таблица.НаправлениеДеятельностиНайденоПоУИД
	|ИЗ
	|	Таблица КАК Таблица
	|ГДЕ
	|	Таблица.НаправлениеДеятельностиНайденоПоУИД
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|ИТОГИ ПО
	|	НомерСтроки";
	
	Возврат Запрос;
	
КонецФункции

Функция ОписаниеЗагружаемыхКолонок(Детализация) Экспорт
	
	ОписаниеКолонок = ЗагрузкаДанныхИзВнешнихФайлов.НовыйОписаниеЗагружаемыхКолонок();
	ИменаПолей = ИменаПолей();
	
	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = ИменаПолей.Раздел;
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'Раздел'");
	НоваяСтрока.ОбязательнаДляЗаполнения = Истина;
	НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Раздел");  
	
	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = ИменаПолей.НаправлениеДеятельности;
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'Направление деятельности'");
	НоваяСтрока.ОбязательнаДляЗаполнения = Истина;
	НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Направление деятельности");    
	
	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = ИменаПолей.УИДНаправленияДеятельности;
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'УИД Направления деятельности'");
	НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("УИД Направления деятельности");

	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = ИменаПолей.ГруппаСтатей;
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'Группа статей дохода и расхода'");
	НоваяСтрока.ОбязательнаДляЗаполнения = Истина;
	НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Группа статей дохода и расхода");    
	
	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = ИменаПолей.УИДГруппыСтатей;
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'УИД Группы статей'");
	НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("УИД Группы статей");

	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = ИменаПолей.СтатьяДДС;
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'Статья доходов и расходов'"); 
	НоваяСтрока.ОбязательнаДляЗаполнения = Истина;
	НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Статья доходов и расходов"); 
	
	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = ИменаПолей.УИДСтатьиДДС;
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'УИД Статьи ДДС'");
	НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("УИД Статьи ДДС");
	
	НоваяСтрока = ОписаниеКолонок.Добавить();
	НоваяСтрока.Идентификатор = "Детализация";
	НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'Детализация'");
	
	Если Детализация = Перечисления.Периодичность.Квартал Тогда
		НоваяСтрока = ОписаниеКолонок.Добавить();
		НоваяСтрока.Идентификатор = "Кварталы";
		НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'Кварталы'");
		НоваяСтрока.Родитель = "Детализация";
		Для НомерПериода = 1 По 4 Цикл
			НоваяСтрока = ОписаниеКолонок.Добавить();
			НоваяСтрока.Идентификатор = СтрШаблон("СуммаКвартал%1", НомерПериода);
			НоваяСтрока.ПредставлениеКолонки = СтрШаблон(НСтр("ru = '%1 квартал'"), НомерПериода);
			НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СтрШаблон("%1 квартал", НомерПериода));
			НоваяСтрока.Родитель = "Кварталы"; 		
		КонецЦикла;
	Иначе
		НоваяСтрока = ОписаниеКолонок.Добавить();
		НоваяСтрока.Идентификатор = "Месяцы";
		НоваяСтрока.ПредставлениеКолонки = НСтр("ru = 'Месяцы'");
		НоваяСтрока.Родитель = "Детализация"; 
		ДатаДетализации = НачалоГода(ТекущаяДатаСеанса());
		Для НомерПериода = 1 По 12 Цикл
			НоваяСтрока = ОписаниеКолонок.Добавить();
			НоваяСтрока.Идентификатор = СтрШаблон("СуммаМесяц%1", НомерПериода);
			НоваяСтрока.ПредставлениеКолонки = СтрШаблон(НСтр("ru = '%1'"), Формат(ДатаДетализации, "ДФ=MMMM"));
			НоваяСтрока.ПодходящиеЗаголовкиФайла = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СтрШаблон("%1", Формат(ДатаДетализации, "ДФ=MMMM")));  
			НоваяСтрока.Родитель = "Месяцы"; 
			ДатаДетализации = ДобавитьМесяц(ДатаДетализации,1);
		КонецЦикла;
	КонецЕсли; 
	
	Возврат ОписаниеКолонок;
	
КонецФункции

#Область ЗагрузкаДанных
Процедура ЗагрузитьДанныеФайлаВБюджет(ДокументСсылка, Бюджет, Детализация, МассивДетализация, АдресХранилища, ИмяПериода) 
	
	ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
	ДокументОбъект.Ответственный = Пользователи.ТекущийПользователь(); 
	
	ТаблицаДоходов = ДокументОбъект.Доходы.Выгрузить();
	ТаблицаДоходов.Очистить(); 
	
	ТаблицаСтруктураДоходов = ДокументОбъект.СтруктураДоходов.Выгрузить();
	ТаблицаСтруктураДоходов.Очистить(); 
	
	ТаблицаРасходыПоНаправлениямДеятельности = ДокументОбъект.РасходыПоНаправлениямДеятельности.Выгрузить();
	ТаблицаРасходыПоНаправлениямДеятельности.Очистить();
	
	ТаблицаРасходы = ДокументОбъект.Расходы.Выгрузить();
	ТаблицаРасходы.Очистить();  
	
	ТаблицаСтруктураРасходов = ДокументОбъект.СтруктураРасходов.Выгрузить();
	ТаблицаСтруктураРасходов.Очистить(); 
		
	Ошибки = Неопределено;
	Ошибка = "";
	Для Каждого СтрокаБюджета Из Бюджет Цикл
		Если СтрокаБюджета.Раздел = "Финансирование" Тогда
			ИмяСтатьи = "СтатьяДохода";
		
			ДобавитьСтрокуВТаблицуЗагрузки(ТаблицаСтруктураДоходов, Бюджет, СтрокаБюджета, ИмяСтатьи, Ошибка);
		 
			Если ЗначениеЗаполнено(Ошибка) Тогда
				ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "", Ошибка);
				Прервать;
			КонецЕсли;
			ЭтоГруппа = Ложь;
			ДобавитьРасчетыПоПериодамВБюджет(ТаблицаДоходов, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, ЭтоГруппа);
			Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
				ПараметрыПоиска = Новый Структура("СтатьяДохода", СтрокаБюджета.ГруппаСтатей);
				НайденныеСтрокиГруппыСтатей = ТаблицаДоходов.НайтиСтроки(ПараметрыПоиска);
				Если НайденныеСтрокиГруппыСтатей.Количество() > 0 Тогда
					НайденныеСтрокиГруппыСтатей[0].Сумма = НайденныеСтрокиГруппыСтатей[0].Сумма + СтрокаБюджета.СуммаГод;
					НомерПериода = 1;
					Для Каждого СтрокаДетализации Из МассивДетализация Цикл
						НайденныеСтрокиГруппыСтатей[НомерПериода].Сумма = НайденныеСтрокиГруппыСтатей[НомерПериода].Сумма
							+ СтрокаБюджета[СтрШаблон("%1%2", ИмяПериода, НомерПериода)]; 
						НомерПериода = НомерПериода + 1;
					КонецЦикла;
				Иначе 
					// Заполняем расчетные данные по группе статей
					ЭтоГруппа = Истина;
					ДобавитьРасчетыПоПериодамВБюджет(ТаблицаДоходов, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, ЭтоГруппа);
				КонецЕсли;
			КонецЕсли;
		Иначе
			// Заполняем строку расхода по статье
			ИмяСтатьи = "СтатьяРасхода";  

			ДобавитьСтрокуВТаблицуЗагрузки(ТаблицаСтруктураРасходов, Бюджет, СтрокаБюджета, ИмяСтатьи, Ошибка);
			
			Если ЗначениеЗаполнено(Ошибка) Тогда
				ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "", Ошибка);
				Прервать;
			КонецЕсли;
			
			// Заполняем расчетные данные по статье
		    ИмяСтатьи = "СтатьяРасхода"; 
			ЭтоГруппа = Ложь;
			ДобавитьРасчетыПоПериодамВБюджет(ТаблицаРасходы, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, ЭтоГруппа); 
			
			Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
				ПараметрыПоиска = Новый Структура("СтатьяРасхода, НаправлениеДеятельности", 
					СтрокаБюджета.ГруппаСтатей, СтрокаБюджета.НаправлениеДеятельности); 
				НайденныеСтрокиГруппыСтатей = ТаблицаРасходы.НайтиСтроки(ПараметрыПоиска);
				Если НайденныеСтрокиГруппыСтатей.Количество() > 0 Тогда
					НайденныеСтрокиГруппыСтатей[0].Сумма = НайденныеСтрокиГруппыСтатей[0].Сумма + СтрокаБюджета.СуммаГод; 
					НомерПериода = 1;
					Для Каждого СтрокаДетализации Из МассивДетализация Цикл
						НайденныеСтрокиГруппыСтатей[НомерПериода].Сумма = НайденныеСтрокиГруппыСтатей[НомерПериода].Сумма
							+ СтрокаБюджета[СтрШаблон("%1%2", ИмяПериода, НомерПериода)]; 
						НомерПериода = НомерПериода + 1;
					КонецЦикла;
				Иначе 
					// Заполняем расчетные данные по группе статей
					ЭтоГруппа = Истина;
					ДобавитьРасчетыПоПериодамВБюджет(ТаблицаРасходы, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, ЭтоГруппа);
				КонецЕсли;
			КонецЕсли;
			
			ПараметрыПоиска = Новый Структура("НаправлениеДеятельности", СтрокаБюджета.НаправлениеДеятельности); 
			НайденныеСтрокиНаправленияДеятельности = ТаблицаРасходыПоНаправлениямДеятельности.НайтиСтроки(ПараметрыПоиска);
			Если НайденныеСтрокиНаправленияДеятельности.Количество() > 0 Тогда
				НайденныеСтрокиНаправленияДеятельности[0].Сумма = НайденныеСтрокиНаправленияДеятельности[0].Сумма + СтрокаБюджета.СуммаГод; 
				НомерПериода = 1;
				Для Каждого СтрокаДетализации Из МассивДетализация Цикл
					НайденныеСтрокиНаправленияДеятельности[НомерПериода].Сумма = НайденныеСтрокиНаправленияДеятельности[НомерПериода].Сумма
						+ СтрокаБюджета[СтрШаблон("%1%2", ИмяПериода, НомерПериода)];
					НомерПериода = НомерПериода + 1;
				КонецЦикла;
			Иначе 
				// Заполняем расчетные данные по направлению деятельности
				ИмяСтатьи = "";
				ЭтоГруппа = Ложь;
				ДобавитьРасчетыПоПериодамВБюджет(ТаблицаРасходыПоНаправлениямДеятельности, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, ЭтоГруппа);
			КонецЕсли;		
		КонецЕсли; 	
	КонецЦикла;
	
	ДокументОбъект.Доходы.Загрузить(ТаблицаДоходов);
	ДокументОбъект.СтруктураДоходов.Загрузить(ТаблицаСтруктураДоходов);
	ДокументОбъект.РасходыПоНаправлениямДеятельности.Загрузить(ТаблицаРасходыПоНаправлениямДеятельности);
	ДокументОбъект.Расходы.Загрузить(ТаблицаРасходы);
	ДокументОбъект.СтруктураРасходов.Загрузить(ТаблицаСтруктураРасходов);
	
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	Результат = Новый Структура;
	Результат.Вставить("Ошибки", Ошибки);
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
			
КонецПроцедуры

Процедура ЗагрузитьДанныеФайлаВКорректировку(ДокументСсылка, Бюджет, Детализация, МассивДетализация, АдресХранилища, ИмяПериода) 
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.КорректировкаБюджета") 
		И Не ДокументСсылка.Утвержден Тогда
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
		ДокументОбъект.Ответственный = Пользователи.ТекущийПользователь();
	Иначе  
		ДокументОбъект = Документы.КорректировкаБюджета.СоздатьДокумент();	
		Документы.КорректировкаБюджета.ЗаполнитьКорректировкуИзЗагрузки(ДокументОбъект, ДокументСсылка);
	КонецЕсли;	
	
	ДанныеКорректировки = Документы.КорректировкаБюджета.ДанныеКорректировки(ДокументСсылка);
	ИмяСтроки = "СтатьяДохода";
	ОбнулитьСуммыТаблицы(ДанныеКорректировки.Доходы, ИмяСтроки, Бюджет, ДокументСсылка.Утвержден); 
	ИмяСтроки = "";
	ОбнулитьСуммыТаблицы(ДанныеКорректировки.Расходы, ИмяСтроки, Бюджет, ДокументСсылка.Утвержден);
	ИмяСтроки = "НаправлениеДеятельности";
	ОбнулитьСуммыТаблицы(ДанныеКорректировки.РасходыПоНаправлениямДеятельности, ИмяСтроки, Бюджет, ДокументСсылка.Утвержден);
	
	Ошибки = Неопределено; 
	Ошибка = "";

	Для Каждого СтрокаБюджета Из Бюджет Цикл
		Если СтрокаБюджета.Раздел = "Финансирование" Тогда	
			Если ЭтоНайденныйСтатус(СтрокаБюджета.СтатусСтатьиДДС) Тогда
				Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
					ПараметрыПоиска = Новый Структура("СтатьяДохода", СтрокаБюджета.ГруппаСтатей);
					НайденныеСтрокиСтруктурыДохода = ДанныеКорректировки.СтруктураДоходов.НайтиСтроки(ПараметрыПоиска);
					Если НайденныеСтрокиСтруктурыДохода.Количество() = 0 Тогда
						НоваяСтрокаСтруктурыДохода = ДанныеКорректировки.СтруктураДоходов.Добавить();
						НоваяСтрокаСтруктурыДохода.СтатьяДохода = СтрокаБюджета.ГруппаСтатей;
						НоваяСтрокаСтруктурыДохода.ЭтоГруппа = Истина;
					КонецЕсли;
				КонецЕсли;

				ПараметрыПоиска = Новый Структура("СтатьяДохода", СтрокаБюджета.СтатьяДДС);
				НайденныеСтрокиСтруктурыДохода = ДанныеКорректировки.СтруктураДоходов.НайтиСтроки(ПараметрыПоиска);
				Если НайденныеСтрокиСтруктурыДохода.Количество() = 0 Тогда
					НоваяСтрокаСтруктурыДохода = ДанныеКорректировки.СтруктураДоходов.Добавить();
					НоваяСтрокаСтруктурыДохода.СтатьяДохода = СтрокаБюджета.СтатьяДДС;
					Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
						НоваяСтрокаСтруктурыДохода.Родитель = СтрокаБюджета.ГруппаСтатей;
					КонецЕсли;
				КонецЕсли;
			Иначе
				ИмяСтатьи = "СтатьяДохода";
				ДобавитьСтрокуВТаблицуЗагрузки(ДанныеКорректировки.СтруктураДоходов, Бюджет, СтрокаБюджета, ИмяСтатьи, Ошибка);
 
				Если ЗначениеЗаполнено(Ошибка) Тогда
					ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "", Ошибка);
					Прервать;
				КонецЕсли;
			КонецЕсли; 	 
			
			ПараметрыПоиска = Новый Структура("СтатьяДохода", СтрокаБюджета.СтатьяДДС);
			НайденныеСтрокиДохода = ДанныеКорректировки.Доходы.НайтиСтроки(ПараметрыПоиска); 
			ИмяСтатьи = "СтатьяДохода";
			ЭтоГруппа = Ложь;
			ДобавитьРасчетыПоПериодамВКорректировку(НайденныеСтрокиДохода, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи,
				ДанныеКорректировки.Доходы, ЭтоГруппа); 										
			Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда 
				ПараметрыПоиска = Новый Структура("СтатьяДохода", СтрокаБюджета.ГруппаСтатей);
				НайденныеСтрокиДохода = ДанныеКорректировки.Доходы.НайтиСтроки(ПараметрыПоиска); 
				ИмяСтатьи = "СтатьяДохода";
				ЭтоГруппа = Истина;
				ДобавитьРасчетыПоПериодамВКорректировку(НайденныеСтрокиДохода, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, 
					ДанныеКорректировки.Доходы, ЭтоГруппа); 											
            КонецЕсли;
		Иначе 
			Если ЭтоНайденныйСтатус(СтрокаБюджета.СтатусСтатьиДДС) И ЭтоНайденныйСтатус(СтрокаБюджета.СтатусНаправленияДеятельности) Тогда 
				Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
					ПараметрыПоиска = Новый Структура("СтатьяРасхода, НаправлениеДеятельности", 
						СтрокаБюджета.ГруппаСтатей, СтрокаБюджета.НаправлениеДеятельности);
					НайденныеСтрокиСтруктурыРасхода = ДанныеКорректировки.СтруктураРасходов.НайтиСтроки(ПараметрыПоиска);
					Если НайденныеСтрокиСтруктурыРасхода.Количество() = 0 Тогда
						НайденныеСтрокиСтруктурыРасхода = ДанныеКорректировки.СтруктураРасходов.Добавить(); 
						НайденныеСтрокиСтруктурыРасхода.НаправлениеДеятельности = СтрокаБюджета.НаправлениеДеятельности;
						НайденныеСтрокиСтруктурыРасхода.СтатьяРасхода = СтрокаБюджета.ГруппаСтатей;
						НайденныеСтрокиСтруктурыРасхода.ЭтоГруппа = Истина;
					КонецЕсли;
				КонецЕсли;

				ПараметрыПоиска = Новый Структура("СтатьяРасхода, НаправлениеДеятельности", 
					СтрокаБюджета.СтатьяДДС, СтрокаБюджета.НаправлениеДеятельности);
				НайденныеСтрокиСтруктурыРасхода = ДанныеКорректировки.СтруктураРасходов.НайтиСтроки(ПараметрыПоиска);
				Если НайденныеСтрокиСтруктурыРасхода.Количество() = 0 Тогда
					НайденныеСтрокиСтруктурыРасхода = ДанныеКорректировки.СтруктураРасходов.Добавить();
					НайденныеСтрокиСтруктурыРасхода.НаправлениеДеятельности = СтрокаБюджета.НаправлениеДеятельности;
					НайденныеСтрокиСтруктурыРасхода.СтатьяРасхода = СтрокаБюджета.СтатьяДДС;  
					Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
						НайденныеСтрокиСтруктурыРасхода.Родитель = СтрокаБюджета.ГруппаСтатей;
					КонецЕсли;
				КонецЕсли;
			Иначе
				
				// Заполняем строку расхода по статье
				ИмяСтатьи = "СтатьяРасхода";
				ДобавитьСтрокуВТаблицуЗагрузки(ДанныеКорректировки.СтруктураРасходов, Бюджет, СтрокаБюджета, ИмяСтатьи, Ошибка);

				Если ЗначениеЗаполнено(Ошибка) Тогда
					ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "", Ошибка);
					Прервать;
				КонецЕсли;
			КонецЕсли;
			
			ПараметрыПоиска = Новый Структура("СтатьяРасхода, НаправлениеДеятельности", СтрокаБюджета.СтатьяДДС, СтрокаБюджета.НаправлениеДеятельности);
			НайденныеСтрокиРасхода = ДанныеКорректировки.Расходы.НайтиСтроки(ПараметрыПоиска);
			
			// Заполняем расчетные данные по статье
			ИмяСтатьи = "СтатьяРасхода";
			ЭтоГруппа = Ложь;
			ДобавитьРасчетыПоПериодамВКорректировку(НайденныеСтрокиРасхода, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, 
				ДанныеКорректировки.Расходы, ЭтоГруппа);
													
			Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
				ПараметрыПоиска = Новый Структура("СтатьяРасхода, НаправлениеДеятельности", СтрокаБюджета.ГруппаСтатей, СтрокаБюджета.НаправлениеДеятельности);
				НайденныеСтрокиРасхода = ДанныеКорректировки.Расходы.НайтиСтроки(ПараметрыПоиска); 
				ИмяСтатьи = "СтатьяРасхода";
				ЭтоГруппа = Истина;
				ДобавитьРасчетыПоПериодамВКорректировку(НайденныеСтрокиРасхода, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, 
					ДанныеКорректировки.Расходы, ЭтоГруппа);
			КонецЕсли;
			
			ПараметрыПоиска = Новый Структура("НаправлениеДеятельности", СтрокаБюджета.НаправлениеДеятельности); 
			НайденныеСтрокиНаправленияДеятельности = ДанныеКорректировки.РасходыПоНаправлениямДеятельности.НайтиСтроки(ПараметрыПоиска);
			
			// Заполняем расчетные данные по направлению деятельности
			ИмяСтатьи = "";
			ЭтоГруппа = Ложь;
			ДобавитьРасчетыПоПериодамВКорректировку(НайденныеСтрокиНаправленияДеятельности, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, 
				ДанныеКорректировки.РасходыПоНаправлениямДеятельности, ЭтоГруппа);		
		КонецЕсли; 	
	КонецЦикла;
	
	ДокументОбъект.Доходы.Загрузить(ДанныеКорректировки.Доходы);
	ДокументОбъект.СтруктураДоходов.Загрузить(ДанныеКорректировки.СтруктураДоходов);
	ДокументОбъект.РасходыПоНаправлениямДеятельности.Загрузить(ДанныеКорректировки.РасходыПоНаправлениямДеятельности);
	ДокументОбъект.Расходы.Загрузить(ДанныеКорректировки.Расходы);
	ДокументОбъект.СтруктураРасходов.Загрузить(ДанныеКорректировки.СтруктураРасходов);
	
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	Результат = Новый Структура;
	Результат.Вставить("ДокументКорректировки", ДокументОбъект.Ссылка);
	Результат.Вставить("Ошибки", Ошибки);
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
			
КонецПроцедуры

Функция НовыйТаблицаЗагружаемыхДанных()
	
	ЗагружаемыеДанные = Новый ТаблицаЗначений;
	
	Для Каждого Реквизит Из Метаданные.Обработки.ЗагрузкаБюджетаИзФайла.ТабличныеЧасти.Бюджет.Реквизиты Цикл
		ЗагружаемыеДанные.Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);	
	КонецЦикла; 
	
	ЗагружаемыеДанные.Колонки.Добавить("НомерСтроки", ОбщегоНазначения.ОписаниеТипаЧисло(10, 0));
	ЗагружаемыеДанные.Колонки.Добавить("СписокСтатейДДС", Новый ОписаниеТипов("СписокЗначений"));
	ЗагружаемыеДанные.Колонки.Добавить("СписокНаправленийДеятельности", Новый ОписаниеТипов("СписокЗначений"));
	
	Возврат ЗагружаемыеДанные;
	
КонецФункции

Процедура ПроизвестиПоискСтатьиДДС(Таблица)
	
	ПоляПоискаСтатьиДДС = ПоляПоискаСтатьиДДС();

	СписокРеквизитов = Новый Массив;
	Для Каждого ЭлементСписка Из ПоляПоискаСтатьиДДС Цикл
		Если Не ЭлементСписка.Пометка Тогда
			Продолжить;
		КонецЕсли;
		СписокРеквизитов.Добавить(ЭлементСписка.Значение);
	КонецЦикла;
	РеквизитыДляПоиска = СтрСоединить(СписокРеквизитов, ",");
	
	Запрос = ЗапросПоискаСтатьиДДС(Таблица, РеквизитыДляПоиска);
	
	ВыборкаНомерСтроки = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаНомерСтроки.Следующий() Цикл
		ВыборкаСтатьиДДС = ВыборкаНомерСтроки.Выбрать();
		
		СтрокаТаблицы = Таблица[ВыборкаНомерСтроки.НомерСтроки - 1];
		ОбработкаВыборкиСтатьиДДС(СтрокаТаблицы, ВыборкаСтатьиДДС);		
	КонецЦикла;
	
КонецПроцедуры  

Процедура ПроизвестиПоискНаправленияДеятельности(Таблица)
	
	ПоляПоискаНаправленияДеятельности = ПоляПоискаНаправленияДеятельности();

	СписокРеквизитов = Новый Массив;
	Для Каждого ЭлементСписка Из ПоляПоискаНаправленияДеятельности Цикл
		Если Не ЭлементСписка.Пометка Тогда
			Продолжить;
		КонецЕсли;
		СписокРеквизитов.Добавить(ЭлементСписка.Значение);
	КонецЦикла;
	РеквизитыДляПоиска = СтрСоединить(СписокРеквизитов, ",");
	
	Запрос = ЗапросПоискаНаправленияДеятельности(Таблица, РеквизитыДляПоиска);
	
	ВыборкаНомерСтроки = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаНомерСтроки.Следующий() Цикл
		ВыборкаНаправленияДеятельности = ВыборкаНомерСтроки.Выбрать();
		
		СтрокаТаблицы = Таблица[ВыборкаНомерСтроки.НомерСтроки - 1];
		ОбработкаВыборкиНаправленияДеятельности(СтрокаТаблицы, ВыборкаНаправленияДеятельности);	
	КонецЦикла;
	
КонецПроцедуры

// В строке может быть три свойства — Новый, Дубль и Найденная.
// В случае, если Направление или Статья не найдены, то это Новый. Если и то и другое найдено, то это Найденная. Если один из двух дубль, то будет Дубль. 
//
Процедура ОбработкаВыборкиСтатьиДДС(СтрокаТаблицы, ВыборкаСтатьиДДС)

	ВыборкаКоличество = ВыборкаСтатьиДДС.Количество();
	Если ВыборкаКоличество = 1 Тогда 
		СтрокаТаблицы.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();
		ВыборкаСтатьиДДС.Следующий();
		СтрокаТаблицы.СтатьяДДС = ВыборкаСтатьиДДС.СтатьяДДС;
		Если Не СтрокаТаблицы.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда
			СтрокаТаблицы.ЕстьНовыеСтроки = Ложь;
			СтрокаТаблицы.НайденнаяСтрока = Истина;
		КонецЕсли;
	Иначе 
		СтрокаТаблицы.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль(); 
		СтрокаТаблицы.ЕстьДубли = Истина;   
		Если Не СтрокаТаблицы.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда
			СтрокаТаблицы.ЕстьНовыеСтроки = Ложь;
		КонецЕсли;
		Пока ВыборкаСтатьиДДС.Следующий() Цикл
			СтрокаТаблицы.СписокСтатейДДС.Добавить(ВыборкаСтатьиДДС.СтатьяДДС); 
			ТекстПредставления = НСтр("ru = 'Найдено %1: %2'");
			СтрокаТаблицы.ПредставлениеСтатьиДДС = 
				СтрШаблон(ТекстПредставления, ВыборкаКоличество, СтрокаТаблицы.НаименованиеСтатьиДДС);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры 

// В строке может быть три свойства — Новый, Дубль и Найденная.
// В случае, если Направление или Статья не найдены, то это Новый. Если и то и другое найдено, то это Найденная. Если один из двух дубль, то будет Дубль. 
//
Процедура ОбработкаВыборкиНаправленияДеятельности(СтрокаТаблицы, ВыборкаНаправленияДеятельности)

	ВыборкаКоличество = ВыборкаНаправленияДеятельности.Количество();
	Если ВыборкаКоличество = 1 Тогда 
		СтрокаТаблицы.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();
		ВыборкаНаправленияДеятельности.Следующий();
		СтрокаТаблицы.НаправлениеДеятельности = ВыборкаНаправленияДеятельности.НаправлениеДеятельности;
		Если Не СтрокаТаблицы.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда
			СтрокаТаблицы.ЕстьНовыеСтроки = Ложь;
			СтрокаТаблицы.НайденнаяСтрока = Истина;
		КонецЕсли;
	Иначе 
		СтрокаТаблицы.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусДубль(); 
		СтрокаТаблицы.ЕстьДубли = Истина; 
		Если Не СтрокаТаблицы.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый() Тогда
			СтрокаТаблицы.ЕстьНовыеСтроки = Ложь;
		КонецЕсли;
		Пока ВыборкаНаправленияДеятельности.Следующий() Цикл
			СтрокаТаблицы.СписокНаправленийДеятельности.Добавить(ВыборкаНаправленияДеятельности.НаправлениеДеятельности);
			ТекстПредставления = НСтр("ru = 'Найдено %1: %2'");
			СтрокаТаблицы.ПредставлениеНаправленияДеятельности = 
				СтрШаблон(ТекстПредставления, ВыборкаКоличество, СтрокаТаблицы.НаименованиеНаправленияДеятельности);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры 

Функция ЗначенияВесовВыборки(РеквизитыДляПоиска)
	
	СписокПолей = СтрРазделить(РеквизитыДляПоиска, "," + " ", Ложь);
	
	ЗначенияВесов = Новый Структура; 
	ЗначенияВесов.Вставить("ПоискПоНаименованиюСтатьиДДС", Ложь);
	ЗначенияВесов.Вставить("ПоискПоНаименованиюНаправлениеДеятельности", Ложь);
	
	УстановленоПолеПоиска = Ложь;
	Для Каждого ЭлементСписка Из СписокПолей Цикл
		Если Не (УстановленоПолеПоиска) Тогда
			ЗначенияВесов.ПоискПоНаименованиюСтатьиДДС = (ЭлементСписка = ПолеПоискаНаименованиеСтатьиДДС());
			ЗначенияВесов.ПоискПоНаименованиюНаправлениеДеятельности = (ЭлементСписка = ПолеПоискаНаименованиеНаправленияДеятельности());
			УстановленоПолеПоиска = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЗначенияВесов;
	
КонецФункции

