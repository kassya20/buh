// При нахождении ошибок помещаем их в хранилище и передаем результат
//
Процедура ПоместитьОшибкиПоЗагрузкеБюджета(ТабличныйДокумент, АдресХранилища)
	
	ЕстьОшибки = Истина; 
	Результат = Новый Структура("Ошибки, ТабличныйДокумент", ЕстьОшибки, ТабличныйДокумент);
