КонецПроцедуры 

Процедура УстановитьСтатусНовыйДляСтрокиБюджета(СтрокаТаблицы, ЭтоСтатьяДДС, Наименование)
	
	Если ЭтоСтатьяДДС Тогда 
		ОписаниеКолонок = Новый Структура("ИмяПредставления, ИмяСтатуса", "ПредставлениеСтатьиДДС", "СтатусСтатьиДДС");
	Иначе  
		ОписаниеКолонок = Новый Структура("ИмяПредставления, ИмяСтатуса", "ПредставлениеНаправленияДеятельности", "СтатусНаправленияДеятельности");
	КонецЕсли;  
	
	СтрокаТаблицы[ОписаниеКолонок.ИмяПредставления] = СтрШаблон(НСтр("ru = 'Новый: %1'"), Наименование); 
	СтрокаТаблицы[ОписаниеКолонок.ИмяСтатуса] = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНовый();	
	СтрокаТаблицы.ЕстьНовыеСтроки = Истина;
	
КонецПроцедуры  

Процедура ДобавитьСтрокуДохода(СтрокаТаблицы, ДанныеФайла, НомерСтроки, СоответствиеКолонок, МассивУИДСтатьиДоходов)
	
	ИмяУИДСтатьиДДС = "УИДСтатьиДДС";
	НаименованиеСтатьиДДС = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить("СтатьяДДС")).Текст); 
	СтрокаТаблицы.НаименованиеСтатьиДДС = НаименованиеСтатьиДДС;
	Если СоответствиеКолонок.Получить(ИмяУИДСтатьиДДС) <> Неопределено Тогда
		СтрокаТаблицы.УИДСтатьиДДС = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить(ИмяУИДСтатьиДДС)).Текст);
		Попытка
			УИДСтатьиДДС = Новый УникальныйИдентификатор(СтрокаТаблицы.УИДСтатьиДДС);
			Если МассивУИДСтатьиДоходов.Найти(УИДСтатьиДДС) = Неопределено Тогда
				СтатьяДДСПоУИД = Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСсылку(УИДСтатьиДДС);
				Если ОбщегоНазначения.СсылкаСуществует(СтатьяДДСПоУИД) 
					И СтатьяДДСПоУИД.Наименование = НаименованиеСтатьиДДС Тогда
					СтрокаТаблицы.СтатьяДДС = СтатьяДДСПоУИД; 
					СтрокаТаблицы.СтатьяДДСНайденоПоУИД = Истина;
					МассивУИДСтатьиДоходов.Добавить(УИДСтатьиДДС);
				КонецЕсли;	
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Выполнение операции'"), 
				УровеньЖурналаРегистрации.Информация, , , 
				НСтр("ru = 'Не удалось определить УИД статьи ДДС для сопоставления данных при Загрузке из файла в бюджет.
				           |Поиск выполнится по наименованию'"));
		КонецПопытки; 
	КонецЕсли;
	
	ДобавитьГруппуСтатей(СтрокаТаблицы, ДанныеФайла, НомерСтроки, СоответствиеКолонок);
		
КонецПроцедуры  

Процедура ДобавитьСтрокуРасходаИНаправленияДеятельности(СтрокаТаблицы, ДанныеФайла, НомерСтроки, СоответствиеКолонок, СоответствиеСтроки, ИмяСтроки, ИмяУИД)
	
	ЭтоСтатьяДДС = (ИмяСтроки = "СтатьяДДС");													
	
	Наименование = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить(ИмяСтроки)).Текст);
	Если ЭтоСтатьяДДС Тогда 
		ОписаниеКолонок = Новый Структура("Наименование, УИД, НайденоПоУИД, Строка", 
			"НаименованиеСтатьиДДС", "УИДСтатьиДДС", "СтатьяДДСНайденоПоУИД", "СтатьяДДС");
	Иначе 
		ОписаниеКолонок = Новый Структура("Наименование, УИД, НайденоПоУИД, Строка", 
			"НаименованиеНаправленияДеятельности", "УИДНаправленияДеятельности", "НаправлениеДеятельностиНайденоПоУИД", "НаправлениеДеятельности");	
	КонецЕсли;
	
	СтрокаТаблицы[ОписаниеКолонок.Наименование] = Наименование;
	
	Если СоответствиеКолонок.Получить(ИмяУИД) <> Неопределено Тогда
		УИДСтроки = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить(ИмяУИД)).Текст);
		СтрокаТаблицы[ОписаниеКолонок.УИД] = УИДСтроки; 
		КлючСоответствия = СтрШаблон("%1|%2", Наименование, СтрокаТаблицы[ОписаниеКолонок.УИД]);
		
		Если СоответствиеСтроки.Получить(КлючСоответствия) <> Неопределено Тогда
			СтрокаТаблицы[ОписаниеКолонок.Строка] = СоответствиеСтроки.Получить(КлючСоответствия); 
			СтрокаТаблицы[ОписаниеКолонок.НайденоПоУИД] = Истина;
		Иначе 
			Попытка 
				УИДСтроки = Новый УникальныйИдентификатор(УИДСтроки);
				Если ЭтоСтатьяДДС Тогда
					СсылкаПоУИД = Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСсылку(УИДСтроки);
				Иначе
					СсылкаПоУИД = Справочники.НаправленияДеятельности.ПолучитьСсылку(УИДСтроки); 
				КонецЕсли;	 
				Если ОбщегоНазначения.СсылкаСуществует(СсылкаПоУИД) И СсылкаПоУИД.Наименование = Наименование Тогда	
					СтрокаТаблицы[ОписаниеКолонок.Строка] = СсылкаПоУИД; 
					СтрокаТаблицы[ОписаниеКолонок.НайденоПоУИД] = Истина;
					СоответствиеСтроки.Вставить(КлючСоответствия, СсылкаПоУИД);	
				КонецЕсли;
			Исключение
				ЗаписьЖурналаРегистрации(НСтр("ru = 'Выполнение операции'"), 
					УровеньЖурналаРегистрации.Информация, , , 
					НСтр("ru = 'Не удалось определить УИД статьи ДДС или направления деятельности для сопоставления данных при Загрузке из файла в бюджет.
					           |Поиск выполнится по наименованию'"));
			КонецПопытки;
		КонецЕсли;
		Если Не ЭтоСтатьяДДС Тогда
			СтрокаТаблицы.НомерНаправленияДеятельности = СоответствиеСтроки.Количество();
		КонецЕсли;
	КонецЕсли;  
	
	ДобавитьГруппуСтатей(СтрокаТаблицы, ДанныеФайла, НомерСтроки, СоответствиеКолонок);      
	
КонецПроцедуры 

Процедура ДобавитьГруппуСтатей(СтрокаТаблицы, ДанныеФайла, НомерСтроки, СоответствиеКолонок) 
	
	ИмяУИДГруппыСтатей = "УИДГруппыСтатей";
	НаименованиеГруппыСтатей = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить("ГруппаСтатей")).Текст);
	
	Если Не ЗначениеЗаполнено(НаименованиеГруппыСтатей) Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаТаблицы.НаименованиеГруппыСтатей = НаименованиеГруппыСтатей;
	Если СоответствиеКолонок.Получить(ИмяУИДГруппыСтатей) <> Неопределено Тогда
		СтрокаТаблицы.УИДГруппыСтатей = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить(ИмяУИДГруппыСтатей)).Текст);
		Попытка
			УИДГруппыСтатей = Новый УникальныйИдентификатор(СтрокаТаблицы.УИДГруппыСтатей);
			ГруппаСтатейПоУИД = Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСсылку(УИДГруппыСтатей);
			Если ОбщегоНазначения.СсылкаСуществует(ГруппаСтатейПоУИД) 
				И ГруппаСтатейПоУИД.Наименование = НаименованиеГруппыСтатей Тогда
				СтрокаТаблицы.ГруппаСтатей = ГруппаСтатейПоУИД; 
				СтрокаТаблицы.ГруппаСтатейНайденоПоУИД = Истина;
			КонецЕсли;	
		Исключение
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Выполнение операции'"), 
				УровеньЖурналаРегистрации.Информация, , , 
				НСтр("ru = 'Не удалось определить УИД группы статей для сопоставления данных при Загрузке из файла в бюджет.
				|Поиск выполнится по наименованию'"));
		КонецПопытки; 
	КонецЕсли;  
		
КонецПроцедуры 

// Таблица для проверки используется в запросах для поиска статей и направления деятельности по наименованию
// Копируем таблицу, которую получили из фалйа и дополняем необходимыми колонками, если их нет
//
Функция ТаблицаДляПроверки(Таблица)
	
	ТаблицаДляПроверки = Таблица.Скопировать();  
	
	ТипСтрока = Новый ОписаниеТипов("Строка", , , , Новый КвалификаторыСтроки(100));
	ТипБулево = Новый ОписаниеТипов("Булево");
	КвалификаторЧисла = Новый КвалификаторыЧисла(10, 0, ДопустимыйЗнак.Неотрицательный);
	
	МассивДанных = Новый Массив;
	МассивДанных.Добавить(Новый Структура("ИмяКолонки, ОписаниеТипа", "СтатьяДДС", 
		Новый ОписаниеТипов("СправочникСсылка.СтатьиДвиженияДенежныхСредств")));
	МассивДанных.Добавить(Новый Структура("ИмяКолонки, ОписаниеТипа", "НаименованиеСтатьиДДС", ТипСтрока));
	МассивДанных.Добавить(Новый Структура("ИмяКолонки, ОписаниеТипа", "СтатьяДДСНайденоПоУИД", ТипБулево)); 
	МассивДанных.Добавить(Новый Структура("ИмяКолонки, ОписаниеТипа", "НомерСтроки", Новый ОписаниеТипов("Число", КвалификаторЧисла)));
	МассивДанных.Добавить(Новый Структура("ИмяКолонки, ОписаниеТипа", "НаправлениеДеятельности", 
		Новый ОписаниеТипов("СправочникСсылка.НаправленияДеятельности")));
	МассивДанных.Добавить(Новый Структура("ИмяКолонки, ОписаниеТипа", "НаименованиеНаправленияДеятельности", ТипСтрока));	
	МассивДанных.Добавить(Новый Структура("ИмяКолонки, ОписаниеТипа", "НаправлениеДеятельностиНайденоПоУИД", ТипБулево));
	
	Для Каждого Строка Из МассивДанных Цикл
		Если ТаблицаДляПроверки.Колонки.Найти(Строка.ИмяКолонки) = Неопределено Тогда
			ТаблицаДляПроверки.Колонки.Добавить(Строка.ИмяКолонки, Строка.ОписаниеТипа);
		КонецЕсли;	
	КонецЦикла;
	
	Возврат ТаблицаДляПроверки; 
	
КонецФункции 

Процедура ДобавитьСтатьюДДС(НоваяСтрокаТаблицы, СтрокаБюджета, ВидСтатьиДвиженияДенег, Ошибка)
	
	СтатьяДДС = Справочники.СтатьиДвиженияДенежныхСредств.СоздатьЭлемент();
	СтатьяДДС.Наименование = СтрокаБюджета.НаименованиеСтатьиДДС;
	СтатьяДДС.ВидСтатьиДДС = ВидСтатьиДвиженияДенег;
	
	Ошибка = "";
	ЗаписатьСтатьюДДС(СтатьяДДС, Ошибка);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат;
	КонецЕсли;
	
	Если ВидСтатьиДвиженияДенег = Перечисления.ВидСтатьиДвиженияДенег.Доход Тогда 
		НоваяСтрокаТаблицы.СтатьяДохода = СтатьяДДС.Ссылка;
	Иначе	
		НоваяСтрокаТаблицы.СтатьяРасхода = СтатьяДДС.Ссылка;
	КонецЕсли; 
	
	СтрокаБюджета.СтатьяДДС = СтатьяДДС.Ссылка; 
	СтрокаБюджета.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();

КонецПроцедуры

Процедура ДобавитьНаправлениеДеятельности(НоваяСтрокаТаблицы, СтрокаБюджета, Ошибка)
	
	НаправлениеДеятельности = Справочники.НаправленияДеятельности.СоздатьЭлемент();
	НаправлениеДеятельности.Наименование = СтрокаБюджета.НаименованиеНаправленияДеятельности; 
	
	Ошибка = "";
	ЗаписатьНаправлениеДеятельности(НаправлениеДеятельности, Ошибка);
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрокаТаблицы.НаправлениеДеятельности = НаправлениеДеятельности.Ссылка;
	СтрокаБюджета.НаправлениеДеятельности = НаправлениеДеятельности.Ссылка; 
	СтрокаБюджета.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();

КонецПроцедуры

Функция ИменаПолей()
	
	ИменаПолей = Новый Структура;
	ИменаПолей.Вставить("Раздел", "Раздел"); 
	ИменаПолей.Вставить("СтатьяДДС", "СтатьяДДС");
	ИменаПолей.Вставить("УИДСтатьиДДС", "УИДСтатьиДДС");
	ИменаПолей.Вставить("НаправлениеДеятельности", "НаправлениеДеятельности");
	ИменаПолей.Вставить("УИДНаправленияДеятельности", "УИДНаправленияДеятельности"); 
	ИменаПолей.Вставить("НаименованиеНаправленияДеятельности", "НаименованиеНаправленияДеятельности");
	ИменаПолей.Вставить("НаименованиеСтатьиДДС", "НаименованиеСтатьиДДС"); 
	ИменаПолей.Вставить("ГруппаСтатей", "ГруппаСтатей");
	ИменаПолей.Вставить("УИДГруппыСтатей", "УИДГруппыСтатей"); 
	ИменаПолей.Вставить("НаименованиеГруппыСтатей", "НаименованиеГруппыСтатей");

	Возврат ИменаПолей;
	
КонецФункции  

Процедура ОбработкаДанныхФайла(Бюджет, ДанныеФайла, Детализация, АдресХранилища, ЕстьОшибки)
	
	ШиринаТаблицы = ДанныеФайла.ШиринаТаблицы;
	ВысотаТаблицы = ДанныеФайла.ВысотаТаблицы; 
	
	МассивУИДСтатьиДоходов = Новый Массив;
	СоответствиеНаправлениеДеятельности = Новый Соответствие; 
	СоответствиеСтатьяРасходов = Новый Соответствие;
	
	СоответствиеКолонок = Новый Соответствие;
	Для НомерКолонки = 1 По ШиринаТаблицы Цикл	
		Ячейка = ДанныеФайла.Область(1, НомерКолонки);
		ТекстЯчейки = Ячейка.ПараметрРасшифровки;
		СоответствиеКолонок.Вставить(ТекстЯчейки, НомерКолонки);		
	КонецЦикла; 
	
	Счетчик = 0; 
	
	ИменаПолей = ИменаПолей(); 
	
	МассивСоответствий = Новый Массив;
	МассивСоответствий.Добавить(Новый Структура("СоответствиеСтроки, ИмяСтроки, ИмяУИД, ЭтоСтатьяДДС, ИмяКолонки", 
		СоответствиеНаправлениеДеятельности, ИменаПолей.НаправлениеДеятельности, ИменаПолей.УИДНаправленияДеятельности, 
		Ложь, ИменаПолей.НаименованиеНаправленияДеятельности));
	МассивСоответствий.Добавить(Новый Структура("СоответствиеСтроки, ИмяСтроки, ИмяУИД, ЭтоСтатьяДДС, ИмяКолонки", 
		СоответствиеСтатьяРасходов, ИменаПолей.СтатьяДДС, ИменаПолей.УИДСтатьиДДС, Истина, ИменаПолей.НаименованиеСтатьиДДС));
	
	Если Детализация = Перечисления.Периодичность.Квартал Тогда
		ИмяПериода = "СуммаКвартал";
		КоличествоПериодов = 4;
	Иначе 
		ИмяПериода = "СуммаМесяц";
		КоличествоПериодов = 12;
	КонецЕсли;   
	
	Для НомерСтроки = 2 По ВысотаТаблицы Цикл
		Если ДанныеФайла.Область(НомерСтроки, 1).ПараметрРасшифровки = "НеЗагружать" Тогда
			Продолжить; 
		КонецЕсли; 
		Если СоответствиеКолонок.Получить(ИменаПолей.Раздел) <> Неопределено Тогда
			Раздел = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить(ИменаПолей.Раздел)).Текст);
			Если ПустаяСтрока(Раздел) Тогда 
				ЕстьОшибки = Истина;
				ПоместитьОшибкиПоЗагрузкеБюджета(ДанныеФайла, АдресХранилища);
				Возврат;
			КонецЕсли; 
			СтрокаТаблицы = Бюджет.Добавить();
			СтрокаТаблицы.Раздел = Раздел;
			Счетчик = Счетчик + 1;
			СтрокаТаблицы.НомерСтроки = Счетчик;		
			Если СтрокаТаблицы.Раздел = "Финансирование" Тогда
				ДобавитьСтрокуДохода(СтрокаТаблицы, ДанныеФайла, НомерСтроки, СоответствиеКолонок, МассивУИДСтатьиДоходов); 
				Если Не СтрокаТаблицы.СтатьяДДСНайденоПоУИД Тогда
					ЭтоСтатьяДДС = Истина;
					УстановитьСтатусНовыйДляСтрокиБюджета(СтрокаТаблицы, ЭтоСтатьяДДС, СтрокаТаблицы.НаименованиеСтатьиДДС);	
				КонецЕсли;
			Иначе 
				Для Каждого СтрокаСоответсвия Из МассивСоответствий Цикл
					ДобавитьСтрокуРасходаИНаправленияДеятельности(СтрокаТаблицы, ДанныеФайла, НомерСтроки, 
					СоответствиеКолонок, СтрокаСоответсвия.СоответствиеСтроки, 
					СтрокаСоответсвия.ИмяСтроки, СтрокаСоответсвия.ИмяУИД);	
					Если Не ЗначениеЗаполнено(СтрокаТаблицы[СтрокаСоответсвия.ИмяСтроки]) Тогда
						УстановитьСтатусНовыйДляСтрокиБюджета(СтрокаТаблицы, СтрокаСоответсвия.ЭтоСтатьяДДС, СтрокаТаблицы[СтрокаСоответсвия.ИмяКолонки]);	
					КонецЕсли;	
				КонецЦикла;				
			КонецЕсли;
		КонецЕсли;
		
		ГодоваяСумма = 0;
		Для НомерПериода = 1 По КоличествоПериодов Цикл 
			ЭлементСтроки = СтрШаблон("%1%2", ИмяПериода, НомерПериода);
			Если СоответствиеКолонок.Получить(ЭлементСтроки) <> Неопределено Тогда
				СтрокаТаблицы[ЭлементСтроки] = СокрЛП(ДанныеФайла.Область(НомерСтроки, СоответствиеКолонок.Получить(ЭлементСтроки)).Текст);
			Иначе
				СтрокаТаблицы[ЭлементСтроки] = 0;
			КонецЕсли;
			ГодоваяСумма = ГодоваяСумма + СтрокаТаблицы[ЭлементСтроки]; 
		КонецЦикла;		
	
		СтрокаТаблицы.СуммаГод = ГодоваяСумма;
	КонецЦикла;   
	
	ПроизвестиПоискСтатьиДДС(Бюджет); 
	
	ПроизвестиПоискНаправленияДеятельности(Бюджет);
		
КонецПроцедуры

Функция ЭтоНайденныйСтатус(Статус)
	
	Возврат Статус = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();
	
КонецФункции  

Функция ЕстьНезаполненныеКолонки(ТабличныйДокумент)
	
	ШиринаТаблицы = ТабличныйДокумент.ШиринаТаблицы;
	ТекстНезаполненныйЗаголовок = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.ТекстЗаголовкаНесопоставленнойКолонки();
	
	Для НомерКолонки = 1 По ШиринаТаблицы Цикл
		
		Ячейка = ТабличныйДокумент.Область("R1C" + НомерКолонки);
		
		Если Ячейка.Текст = ТекстНезаполненныйЗаголовок Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции 

// Имя статьи может быть в 3 вариантах: статья дохода, статья расхода и пустое значение
// Статья дохода используется для строк финансирования
// Статья расхода используется для строк расхода, где заполняется статья
// Пустое значение используется для строк расхода, где заполняется направление деятельности
//
Процедура ДобавитьРасчетыПоПериодамВБюджет(Таблица, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, ЭтоГруппа)
	
	НоваяСтрока = Таблица.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаБюджета);

	Если ЭтоГруппа Тогда 
		ИмяСтроки = "ГруппаСтатей";
	Иначе
		ИмяСтроки = "СтатьяДДС";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяСтатьи) Тогда
		НоваяСтрока[ИмяСтатьи] = СтрокаБюджета[ИмяСтроки];
		НоваяСтрока.ЭтоГруппа = ЭтоГруппа;
	КонецЕсли;
	
	НоваяСтрока.Сумма = СтрокаБюджета.СуммаГод;
	НомерПериода = 1;
	Для Каждого СтрокаДетализации Из МассивДетализация Цикл
		НоваяСтрокаДетализации = Таблица.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрокаДетализации, СтрокаБюджета); 
		
		Если ЗначениеЗаполнено(ИмяСтатьи) Тогда
			НоваяСтрокаДетализации[ИмяСтатьи] = СтрокаБюджета[ИмяСтроки];	
		КонецЕсли;  
		
		НоваяСтрокаДетализации.ДатаПланирования = СтрокаДетализации;
		НоваяСтрокаДетализации.Сумма = СтрокаБюджета[СтрШаблон("%1%2", ИмяПериода, НомерПериода)];
		Если ЗначениеЗаполнено(ИмяСтатьи) Тогда
			НоваяСтрокаДетализации.ЭтоГруппа = ЭтоГруппа;
		КонецЕсли;
		НомерПериода = НомерПериода + 1;
	КонецЦикла;

КонецПроцедуры 

Процедура ДобавитьРасчетыПоПериодамВКорректировку(НайденныеСтроки, СтрокаБюджета, МассивДетализация, ИмяПериода, ИмяСтатьи, Таблица, ЭтоГруппа)
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		ИндексМассива = ИндексВМассивеПоДате(НайденныеСтроки, Дата(1, 1, 1));  
		НайденныеСтроки[ИндексМассива].СуммаКорректировки = СтрокаБюджета.СуммаГод + НайденныеСтроки[ИндексМассива].Сумма 
			- НайденныеСтроки[ИндексМассива].СуммаДоКорректировки;
		НайденныеСтроки[ИндексМассива].Сумма = СтрокаБюджета.СуммаГод + НайденныеСтроки[ИндексМассива].Сумма;
		НомерПериода = 1;
		Для Каждого СтрокаДетализации Из МассивДетализация Цикл
			ИмяКолонки = СтрШаблон("%1%2", ИмяПериода, НомерПериода);
			ИндексМассива = ИндексВМассивеПоДате(НайденныеСтроки, СтрокаДетализации); 
			Если ИндексМассива <> Неопределено Тогда 
				НайденныеСтроки[ИндексМассива].СуммаКорректировки = СтрокаБюджета[ИмяКолонки] + НайденныеСтроки[ИндексМассива].Сумма 
					- НайденныеСтроки[ИндексМассива].СуммаДоКорректировки;
				НайденныеСтроки[ИндексМассива].Сумма = СтрокаБюджета[ИмяКолонки] + НайденныеСтроки[ИндексМассива].Сумма;
				НомерПериода = НомерПериода + 1;
			КонецЕсли;
		КонецЦикла;	
	Иначе

		НоваяСтрока = Таблица.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаБюджета); 
		
		Если ЭтоГруппа Тогда 
			ИмяСтроки = "ГруппаСтатей";
		Иначе
			ИмяСтроки = "СтатьяДДС";
		КонецЕсли;   
		
		Если ЗначениеЗаполнено(ИмяСтатьи) Тогда
			НоваяСтрока[ИмяСтатьи] = СтрокаБюджета[ИмяСтроки];
			НоваяСтрока.ЭтоГруппа = ЭтоГруппа;
		КонецЕсли;

		НоваяСтрока.Сумма = СтрокаБюджета.СуммаГод;
		НоваяСтрока.СуммаКорректировки = СтрокаБюджета.СуммаГод;
		НоваяСтрока.СуммаДоКорректировки = 0;
		НомерПериода = 1;
		Для Каждого СтрокаДетализации Из МассивДетализация Цикл
			НоваяСтрокаДетализации = Таблица.Добавить();  
			ЗаполнитьЗначенияСвойств(НоваяСтрокаДетализации, СтрокаБюджета); 
			
			Если ЗначениеЗаполнено(ИмяСтатьи) Тогда
				НоваяСтрокаДетализации[ИмяСтатьи] = СтрокаБюджета[ИмяСтроки];
				НоваяСтрокаДетализации.ЭтоГруппа = ЭтоГруппа;
			КонецЕсли;

			НоваяСтрокаДетализации.ДатаПланирования = СтрокаДетализации; 
			ИмяКолонки = СтрШаблон("%1%2", ИмяПериода, НомерПериода);
			НоваяСтрокаДетализации.Сумма = СтрокаБюджета[ИмяКолонки];
			НоваяСтрокаДетализации.СуммаКорректировки = СтрокаБюджета[ИмяКолонки];
			НоваяСтрокаДетализации.СуммаДоКорректировки = 0;
			НомерПериода = НомерПериода + 1;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

Функция ИндексВМассивеПоДате(МассивДанных, ИскомаяДата)

    Для Счетчик = 0 По МассивДанных.Количество() - 1 Цикл
        ТекущаяЗапись = МассивДанных[Счетчик];
        Если ТекущаяЗапись.ДатаПланирования = ИскомаяДата Тогда
            Возврат Счетчик; 
		КонецЕсли;
    КонецЦикла;

    Возврат Неопределено;

КонецФункции

// Имя строки может быть в 3 вариантах: статья дохода, статья расхода и пустое значение
// Статья дохода используется для строк финансирования
// Статья расхода используется для строк расхода, где заполняется статья
// Пустое значение используется для строк расхода, где заполняется направление деятельности
//
Процедура ДобавитьСтрокуВТаблицуЗагрузки(Таблица, Бюджет, СтрокаБюджета, ИмяСтроки, Ошибка)
	
	Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда
		Если ИмяСтроки = "СтатьяДохода" Тогда 
			ПараметрыПоиска = Новый Структура(ИмяСтроки, СтрокаБюджета.ГруппаСтатей); 
		Иначе  
			ПараметрыПоиска = Новый Структура("СтатьяРасхода, НаправлениеДеятельности", 
				СтрокаБюджета.ГруппаСтатей, СтрокаБюджета.НаправлениеДеятельности);
		КонецЕсли;
		НайденныеСтроки = Таблица.НайтиСтроки(ПараметрыПоиска);
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = Таблица.Добавить(); 
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаБюджета); 
			НоваяСтрока[ИмяСтроки] = СтрокаБюджета.ГруппаСтатей;
			НоваяСтрока.ЭтоГруппа = Истина; 
		КонецЕсли; 
  	КонецЕсли;
		
	Если ИмяСтроки = "СтатьяДохода" Тогда
		ВидСтатьиДвиженияДенег = Перечисления.ВидСтатьиДвиженияДенег.Доход;
	Иначе
		ВидСтатьиДвиженияДенег = Перечисления.ВидСтатьиДвиженияДенег.Расход;
	КонецЕсли;
		
	НоваяСтрока = Таблица.Добавить();
	Если ЗначениеЗаполнено(СтрокаБюджета.ГруппаСтатей) Тогда	
		НоваяСтрока.Родитель = СтрокаБюджета.ГруппаСтатей; 
	КонецЕсли;

	Если ЭтоНайденныйСтатус(СтрокаБюджета.СтатусСтатьиДДС) Тогда
		НоваяСтрока[ИмяСтроки] = СтрокаБюджета.СтатьяДДС; 
		Если ИмяСтроки = "СтатьяДохода" Тогда 
			Возврат; 
		КонецЕсли;
	Иначе 
		ПараметрыПоиска = Новый Структура("НаименованиеСтатьиДДС", СтрокаБюджета.НаименованиеСтатьиДДС);
		НайденныеСтроки = Бюджет.НайтиСтроки(ПараметрыПоиска);
		Если НайденныеСтроки.Количество() > 1 
			И ЭтоНайденныйСтатус(НайденныеСтроки[0].СтатусСтатьиДДС) Тогда
			НоваяСтрока[ИмяСтроки] = НайденныеСтроки[0].СтатьяДДС;
			СтрокаБюджета.СтатьяДДС = НайденныеСтроки[0].СтатьяДДС;
			СтрокаБюджета.СтатусСтатьиДДС = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();
		Иначе	
			ДобавитьСтатьюДДС(НоваяСтрока, СтрокаБюджета, ВидСтатьиДвиженияДенег, Ошибка);
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяСтроки = "СтатьяРасхода" Тогда
		Если ЭтоНайденныйСтатус(СтрокаБюджета.СтатусНаправленияДеятельности) Тогда
			НоваяСтрока.НаправлениеДеятельности = СтрокаБюджета.НаправлениеДеятельности; 
			Возврат;
		Иначе 
			ПараметрыПоиска = Новый Структура("НаименованиеНаправленияДеятельности", СтрокаБюджета.НаименованиеНаправленияДеятельности);
			НайденныеСтроки = Бюджет.НайтиСтроки(ПараметрыПоиска);
			Если НайденныеСтроки.Количество() > 1 
				И ЭтоНайденныйСтатус(НайденныеСтроки[0].СтатусНаправленияДеятельности) Тогда
				НоваяСтрока.НаправлениеДеятельности = НайденныеСтроки[0].НаправлениеДеятельности;
				СтрокаБюджета.НаправлениеДеятельности = НайденныеСтроки[0].НаправлениеДеятельности;
				СтрокаБюджета.СтатусНаправленияДеятельности = ЗагрузкаДанныхИзВнешнихФайловКлиентСервер.СтатусНайденный();
			Иначе	
				ДобавитьНаправлениеДеятельности(НоваяСтрока, СтрокаБюджета, Ошибка);
			КонецЕсли; 
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры  

Функция МожноУдалитьОбласть(ТабличныйДокумент, НомерСтроки, СоответствиеКолонок)
	
	Раздел = СокрЛП(ТабличныйДокумент.Область(НомерСтроки, СоответствиеКолонок.Получить("Раздел")).Текст);	
	Если Не ЗначениеЗаполнено(Раздел) Тогда
		Возврат Истина;
	КонецЕсли;  
	
	СтатьяДДС = СокрЛП(ТабличныйДокумент.Область(НомерСтроки, СоответствиеКолонок.Получить("СтатьяДДС")).Текст);
	Если Не ЗначениеЗаполнено(СтатьяДДС) Тогда
		Возврат Истина;
	КонецЕсли;   
	
	НаправлениеДеятельности = СокрЛП(ТабличныйДокумент.Область(НомерСтроки, СоответствиеКолонок.Получить("НаправлениеДеятельности")).Текст);
	Если Не ЗначениеЗаполнено(НаправлениеДеятельности) И Раздел = "Расход" Тогда
		Возврат Истина;
	КонецЕсли;   
	
	Возврат Ложь;
	
КонецФункции 

Процедура ОбнулитьСуммыТаблицы(Таблица, ИмяСтроки, Бюджет, Утвержден)  
	
	ЕстьКолонкаГруппы = Таблица.Колонки.Найти("ЭтоГруппа") <> Неопределено; 
	
	Если ИмяСтроки = "СтатьяДохода" Тогда 
		ИмяПоиска = "СтатьяДДС";
	Иначе     
		ИмяПоиска = ИмяСтроки;
	КонецЕсли;    
	
	Для Каждого Строка Из Таблица Цикл 
		Если ЗначениеЗаполнено(ИмяСтроки) И ЕстьКолонкаГруппы И Строка.ЭтоГруппа Тогда       
			ПараметрыПоиска = Новый Структура("ГруппаСтатей", Строка[ИмяСтроки]);
		ИначеЕсли ЗначениеЗаполнено(ИмяСтроки) Тогда
			ПараметрыПоиска = Новый Структура(ИмяПоиска, Строка[ИмяСтроки]);
		ИначеЕсли ЕстьКолонкаГруппы И Строка.ЭтоГруппа Тогда
			ПараметрыПоиска = Новый Структура("ГруппаСтатей, НаправлениеДеятельности", Строка.СтатьяРасхода, Строка.НаправлениеДеятельности);
		Иначе
			ПараметрыПоиска = Новый Структура("СтатьяДДС, НаправлениеДеятельности", Строка.СтатьяРасхода, Строка.НаправлениеДеятельности);
		КонецЕсли;
		НайденныеСтроки = Бюджет.НайтиСтроки(ПараметрыПоиска);
		Если НайденныеСтроки.Количество() > 0 Тогда 
			Строка.Сумма = 0;
			Если Утвержден Тогда
				Строка.СуммаДоКорректировки = Строка.СуммаДоКорректировки + Строка.СуммаКорректировки;  
			КонецЕсли;
		КонецЕсли;		
	КонецЦикла;
	
КонецПроцедуры
 
