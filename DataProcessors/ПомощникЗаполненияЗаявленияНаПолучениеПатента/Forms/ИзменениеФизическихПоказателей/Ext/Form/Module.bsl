#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	
	Элементы.ГруппаАдреса.Видимость = Форма.ИмяТаблицы = "Адреса";
	Элементы.ГруппаОбъекты.Видимость = Форма.ИмяТаблицы = "Объекты";
	Элементы.ГруппаТранспортныеСредства.Видимость = Форма.ИмяТаблицы = "ТранспортныеСредства";
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Если Не ЗначениеЗаполнено(АдресДополнительныхНастроек) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеНастройки = ПолучитьИзВременногоХранилища(АдресДополнительныхНастроек);
	
	КодыПеревозкаГрузов = Новый СписокЗначений;
	КодыПеревозкаГрузов.ЗагрузитьЗначения(ДополнительныеНастройки.КодыВидовДеятельностиГрузоперевозки);
	
	ОбъектыБезПлощади = Обработки.ПомощникЗаполненияЗаявленияНаПолучениеПатента.ВидыОбъектовБезПлощади();
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУсловногоОформления.Поля, "ОбъектыПлощадь");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУсловногоОформления.Отбор,
		"Объекты.ВидОбъекта", ВидСравненияКомпоновкиДанных.ВСписке, ОбъектыБезПлощади);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<не требуется>'"));
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(
		ЭлементУсловногоОформления.Поля, "ТранспортныеСредстваГрузоподъемность");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУсловногоОформления.Отбор,
		"КодВидаДеятельности", ВидСравненияКомпоновкиДанных.НеВСписке, КодыПеревозкаГрузов);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(
		ЭлементУсловногоОформления.Поля, "ТранспортныеСредстваГрузоподъемность");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУсловногоОформления.Отбор,
		"КодВидаДеятельности", ВидСравненияКомпоновкиДанных.ВСписке, КодыПеревозкаГрузов);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Истина);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("МинимальнаяШирина", 14);
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(
		ЭлементУсловногоОформления.Поля, "ТранспортныеСредстваКоличество");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУсловногоОформления.Отбор,
		"КодВидаДеятельности", ВидСравненияКомпоновкиДанных.ВСписке, КодыПеревозкаГрузов);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	ЭлементУсловногоОформления = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(
		ЭлементУсловногоОформления.Поля, "ТранспортныеСредстваКоличество");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУсловногоОформления.Отбор,
		"КодВидаДеятельности", ВидСравненияКомпоновкиДанных.НеВСписке, КодыПеревозкаГрузов);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Истина);
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("МинимальнаяШирина", 14);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗаголовкиТаблицыТранспортныхСредств()
	
	Если ТранспортныеСредства.Количество() = 0 Или Не ЗначениеЗаполнено(АдресДополнительныхНастроек) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеНастройки = ПолучитьИзВременногоХранилища(АдресДополнительныхНастроек);
	
	Если ДополнительныеНастройки.КодыВодныйТранспорт.Найти(КодВидаДеятельности) = Неопределено Тогда
		Элементы.ТранспортныеСредстваНомер.Заголовок = "VIN";
		Элементы.ТранспортныеСредстваРегистрационныйЗнак.Заголовок = НСтр("ru = 'Регистрационный знак'");
	Иначе
		Элементы.ТранспортныеСредстваНомер.Заголовок = "IMO";
		Элементы.ТранспортныеСредстваРегистрационныйЗнак.Заголовок = НСтр("ru = 'Регистрационный номер'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблицыОбъектов()
	
	Если Объекты.Количество() = 0 Или Не ЗначениеЗаполнено(АдресДополнительныхНастроек) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеНастройки = ПолучитьИзВременногоХранилища(АдресДополнительныхНастроек);
	ЗначенияКодовВидовОбъектов = ДополнительныеНастройки.КодыВидыОбъектов;
	ВидыОбъектовПоКоду = ЗначенияКодовВидовОбъектов.Получить(КодВидаДеятельности);
	
	Для Каждого СтрокаОбъект Из Объекты Цикл
		Для Каждого СтрокаВидОбъекта Из ВидыОбъектовПоКоду Цикл
			Если СтрокаОбъект.ВидОбъекта = СтрокаВидОбъекта.ВидОбъекта Тогда
				СтрокаОбъект.ВидОбъектаСтрокой = СтрокаВидОбъекта.Наименование;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередЗакрытиемЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОповеститьОВыбореИЗакрыть();
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОповеститьОВыбореИЗакрыть()
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Ложь;
	
	РезультатВыбора = Новый Структура;
	РезультатВыбора.Вставить("ИмяТаблицы", ИмяТаблицы);
	РезультатВыбора.Вставить("АдресХранилища", СохранитьФизическиеПоказателиВоВременноеХранилище());
	
	ОповеститьОВыборе(РезультатВыбора);
	
КонецПроцедуры

&НаСервере
Функция СохранитьФизическиеПоказателиВоВременноеХранилище()
	
	ТаблицаПоказателей = ЭтотОбъект[ИмяТаблицы].Выгрузить();
	
	Возврат ПоместитьВоВременноеХранилище(ТаблицаПоказателей, АдресХранилища);
	
КонецФункции

#КонецОбласти
