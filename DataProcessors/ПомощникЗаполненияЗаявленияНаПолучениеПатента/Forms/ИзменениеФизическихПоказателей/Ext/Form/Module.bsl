
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Заголовок = Параметры.Заголовок;
	
	ИмяТаблицы = Параметры.ИмяТаблицы;
	
	АдресХранилища = Параметры.АдресХранилища;
	Если Не ЗначениеЗаполнено(АдресХранилища) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ТаблицаДляИзменения = ПолучитьИзВременногоХранилища(АдресХранилища);
	Если ТипЗнч(ТаблицаДляИзменения) = Тип("ТаблицаЗначений") Тогда
		ЭтотОбъект[ИмяТаблицы].Загрузить(ТаблицаДляИзменения);
	КонецЕсли;
	
	АдресХранилищаДоИзменения = Параметры.АдресХранилищаДоИзменения;
	Если ЗначениеЗаполнено(АдресХранилищаДоИзменения) Тогда
		ТаблицаДоИзменения = ПолучитьИзВременногоХранилища(АдресХранилищаДоИзменения);
		Если ТипЗнч(ТаблицаДоИзменения) = Тип("ТаблицаЗначений") Тогда
			ИмяТаблицыДоИзменения = СтрШаблон("%1ДоИзменения", ИмяТаблицы);
			ЭтотОбъект[ИмяТаблицыДоИзменения].Загрузить(ТаблицаДоИзменения);
		КонецЕсли;
	КонецЕсли;
	
	АдресДополнительныхНастроек = Параметры.АдресДополнительныхНастроек;
	КодВидаДеятельности = Параметры.КодВидаДеятельности;
	
	ЗаполнитьДобавленныеКолонкиТаблицыОбъектов();
	
	ОбновитьЗаголовкиТаблицыТранспортныхСредств();
	
	УправлениеФормой(ЭтотОбъект);
	
	УстановитьУсловноеОформление();

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	Если Модифицированность Тогда
		
		Отказ = Истина;
		
		Если ЗавершениеРаботы Тогда
			Возврат;
		КонецЕсли;
		
		Оповещение = Новый ОписаниеОповещения("ВопросПередЗакрытиемЗавершение", ЭтотОбъект);
		ТекстВопроса = НСтр("ru = 'Данные были изменены. Сохранить изменения?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

