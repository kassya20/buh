#Область ОписаниеПеременных

&НаКлиенте
Перем ОткрытыеФормы;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЕстьПравоПросмотрСчетаОтПоставщиков = ПравоДоступа("Просмотр", Метаданные.Документы.СчетНаОплатуПоставщика);
	ЕстьПравоПросмотрПоступления = ПравоДоступа("Просмотр", Метаданные.Документы.ПоступлениеТоваровУслуг);
	ЕстьПравоПросмотрПоступлениеДопРасходов = ПравоДоступа("Просмотр", Метаданные.Документы.ПоступлениеДопРасходов);
	ЕстьПравоПросмотрКорректировкаПоступления = ПравоДоступа("Просмотр", Метаданные.Документы.КорректировкаПоступления);
	ЕстьПравоПросмотрВозвратыПоставщикам =
		ПравоДоступа("Просмотр", Метаданные.Документы.ВозвратТоваровПоставщику);
	ЕстьПравоПросмотрСчетаФактурыПолученные =
		ПравоДоступа("Просмотр", Метаданные.Документы.СчетФактураПолученный);
	ЕстьПравоПросмотрАктОРасхождениях =
		ПравоДоступа("Просмотр", Метаданные.Документы.АктОРасхождениях);
	ЕстьПравоПросмотрПередачаТоваров = ПравоДоступа("Просмотр", Метаданные.Документы.ПередачаТоваров);
	ЕстьПравоПросмотрОтчетКомитентуОПродажах = ПравоДоступа("Просмотр", Метаданные.Документы.ОтчетКомитентуОПродажах);
	ЕстьПравоПросмотрРеестрыВыплатСамозанятым = ПравоДоступа("Просмотр", Метаданные.Документы.ВыплатыСамозанятым);
	ЕстьПравоПросмотрЗаявлениеОВвозеТоваров = ПравоДоступа("Просмотр", Метаданные.Документы.ЗаявлениеОВвозеТоваров);
	ЕстьПравоПросмотрТаможеннаяДекларацияИмпорт = ПравоДоступа("Просмотр", Метаданные.Документы.ГТДИмпорт);
	
	Элементы.КорректировкаПоступления.Видимость = ЕстьПравоПросмотрКорректировкаПоступления;
	Элементы.СчетаОтПоставщиков.Видимость = ЕстьПравоПросмотрСчетаОтПоставщиков;
	Элементы.Поступление.Видимость = ЕстьПравоПросмотрПоступления;
	Элементы.СчетаФактурыПолученные.Видимость = ЕстьПравоПросмотрСчетаФактурыПолученные;
	Элементы.ВозвратыПоставщикам.Видимость = ЕстьПравоПросмотрВозвратыПоставщикам;
	Элементы.ПоступлениеДопРасходов.Видимость = ЕстьПравоПросмотрПоступлениеДопРасходов;
	Элементы.АктыОРасхождениях.Видимость = ЕстьПравоПросмотрАктОРасхождениях;	
	Элементы.ПередачаТоваров.Видимость = ЕстьПравоПросмотрПередачаТоваров;
	Элементы.ОтчетКомитентуОПродажах.Видимость = ЕстьПравоПросмотрОтчетКомитентуОПродажах ;
	Элементы.РеестрыВыплатСамозанятым.Видимость = ЕстьПравоПросмотрРеестрыВыплатСамозанятым;
	Элементы.ЗаявлениеОВвозеТоваров.Видимость = ЕстьПравоПросмотрЗаявлениеОВвозеТоваров И Параметры.ЭтоТовары;
	Элементы.ДокументОПредстоящейПоставке.Видимость = ЕстьПравоПросмотрЗаявлениеОВвозеТоваров И Параметры.ЭтоТовары;
	Элементы.ТаможеннаяДекларацияИмпорт.Видимость = ЕстьПравоПросмотрТаможеннаяДекларацияИмпорт И Параметры.ЭтоТовары;
	Элементы.ГруппаКонтроль.Видимость = Параметры.ЭтоКонтрагенты;
	
	МобильныйКлиентАдаптацияФормы();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

