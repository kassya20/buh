		ЭтотОбъект, , , ОткрытыеФормы);
		
КонецПроцедуры

&НаКлиенте
Процедура ДокументОПредстоящейПоставке(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Заголовок",   НСтр("ru = 'Документы о предстоящей поставке товаров (ДОПП)'"));
	ПараметрыФормы.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.ВидыОперацийВвозТоваровИзЕАЭС.ДОПП"));
	
	ПростойИнтерфейсКлиент.ОткрытьФормуВОкнеФормы("Документ.ЗаявлениеОВвозеТоваров.ФормаСписка",
		ЭтотОбъект, ПараметрыФормы);
		
КонецПроцедуры

&НаКлиенте
Процедура ЗаявлениеОВвозеТоваров(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Заголовок",   НСтр("ru = 'Заявления о ввозе товаров'"));
	ПараметрыФормы.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.ВидыОперацийВвозТоваровИзЕАЭС.ЗаявлениеОВвозе"));
	
	ПростойИнтерфейсКлиент.ОткрытьФормуВОкнеФормы("Документ.ЗаявлениеОВвозеТоваров.ФормаСписка",
		ЭтотОбъект, ПараметрыФормы);
		
КонецПроцедуры

&НаКлиенте
Процедура ТаможеннаяДекларацияИмпорт(Команда)

	ПростойИнтерфейсКлиент.ОткрытьФормуВОкнеФормы("Документ.ГТДИмпорт.ФормаСписка",
		ЭтотОбъект, , , ОткрытыеФормы);
		
КонецПроцедуры

&НаКлиенте
Процедура ОригиналыПервичныхДокументовПоставщики(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимОтображенияДокументов", "Поставщики");
		
	ПростойИнтерфейсКлиент.ОткрытьФормуВОкнеФормы("ЖурналДокументов.ЖурналОпераций.Форма.ФормаУчетаОригиналовПервичныхДокументов",
		ЭтотОбъект, ПараметрыФормы, , ОткрытыеФормы);
		
КонецПроцедуры

#КонецОбласти

#Область МобильныйКлиент

&НаСервере
Процедура МобильныйКлиентАдаптацияФормы()
	
	Если Не ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		Возврат;
	КонецЕсли;
	
	АдаптироватьМКШапкаФормы();
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКШапкаФормы()
	
	МобильныйКлиентБПФормаПанели.НастроитьФорму(ЭтотОбъект);
	МобильныйКлиентБПФормаПанели.УстановитьДоступностьЭлементовПанелиПоГруппам(ЭтотОбъект,
		Элементы.ГруппаДокументыПоставщиков,
		"СчетаОтПоставщиков,Поступление,ПоступлениеДопРасходов,СчетаФактурыПолученные,ВозвратыПоставщикам");
	МобильныйКлиентБПФормаПанели.УстановитьДоступностьЭлементовПанелиПоГруппам(ЭтотОбъект,
		Элементы.ГруппаКонтроль,
		"ОригиналыПервичныхДокументовПоставщики");
	МобильныйКлиентБПФормаПанели.УстановитьДоступностьЭлементовПанелиПоГруппам(ЭтотОбъект,
		Элементы.ГруппаВнешняяТорговля);
	
КонецПроцедуры

#КонецОбласти
