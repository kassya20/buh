&НаКлиенте
Процедура СоздатьНачалоСтадииРазработкиНМА(Команда)
	
	СтруктураПараметров = ПараметрыФормыДокументаПоступления(СписокНМА);
	ОткрытьФорму("Документ.НачалоСтадииРазработокНМА.ФормаОбъекта", СтруктураПараметров, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьРегистрацияЗемельногоУчастка(Команда)
	
	ТекущиеДанные = Элементы.СписокОС.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И НЕ ТекущиеДанные.ЭтоГруппа Тогда
		
		СтруктураПараметров = ПараметрыФормыРегистрацииОС(ТекущиеДанные.Ссылка,
			ПредопределенноеЗначение("Перечисление.ВидЗаписиОРегистрации.Регистрация"));
		ОткрытьФорму("РегистрСведений.РегистрацияЗемельныхУчастков.ФормаЗаписи", СтруктураПараметров, ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьСнятиеСРегистрацииЗемельногоУчастка(Команда)
	
	ТекущиеДанные = Элементы.СписокОС.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И НЕ ТекущиеДанные.ЭтоГруппа Тогда
		
		СтруктураПараметров = ПараметрыФормыРегистрацииОС(ТекущиеДанные.Ссылка,
			ПредопределенноеЗначение("Перечисление.ВидЗаписиОРегистрации.СнятиеСРегистрационногоУчета"));
		ОткрытьФорму("РегистрСведений.РегистрацияЗемельныхУчастков.ФормаЗаписи", СтруктураПараметров, ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьРегистрацияТранспортногоСредства(Команда)
	
	ТекущиеДанные = Элементы.СписокОС.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И НЕ ТекущиеДанные.ЭтоГруппа Тогда
		
		СтруктураПараметров = ПараметрыФормыРегистрацииОС(ТекущиеДанные.Ссылка,
			ПредопределенноеЗначение("Перечисление.ВидЗаписиОРегистрации.Регистрация"));
		ОткрытьФорму("РегистрСведений.РегистрацияТранспортныхСредств.ФормаЗаписи", СтруктураПараметров, ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьСнятиеСРегистрацииТранспортногоСредства(Команда)
	
	ТекущиеДанные = Элементы.СписокОС.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И НЕ ТекущиеДанные.ЭтоГруппа Тогда
		
		СтруктураПараметров = ПараметрыФормыРегистрацииОС(ТекущиеДанные.Ссылка,
			ПредопределенноеЗначение("Перечисление.ВидЗаписиОРегистрации.СнятиеСРегистрационногоУчета"));
		ОткрытьФорму("РегистрСведений.РегистрацияТранспортныхСредств.ФормаЗаписи", СтруктураПараметров, ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьПринятиеКУчетуОС(Команда)
	
	ТекущиеДанные = Элементы.СписокОС.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И НЕ ТекущиеДанные.ЭтоГруппа Тогда
		
		ЗначенияЗаполнения = Новый Структура;
		Если ОтборОрганизацияИспользование Тогда
			ЗначенияЗаполнения.Вставить("Организация", ОтборОрганизация);
		КонецЕсли;
		ЗначенияЗаполнения.Вставить("ОсновноеСредство", ТекущиеДанные.Ссылка);
		ПараметрыОткрытия = Новый Структура("ЗначенияЗаполнения", ЗначенияЗаполнения);
		ОткрытьФорму("Документ.ПринятиеКУчетуОС.ФормаОбъекта", ПараметрыОткрытия, ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление(ВыделяемыеЗначения = Неопределено)
	
	УсловноеОформление.Элементы.Очистить();
	
	// Организация
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "СписокОСОрганизация");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "СписокНМАОрганизация");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ОтборОрганизацияИспользование", ВидСравненияКомпоновкиДанных.Равно, Истина);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ОтборОрганизация", ВидСравненияКомпоновкиДанных.Заполнено);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЭлементовФормы()
	
	ПравоПоступлениеТоваровУслуг = ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Документы.ПоступлениеТоваровУслуг);
	ПравоПоступлениеВАренду = ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Документы.ПоступлениеВАренду);
	ПравоПоступлениеНМА = ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Документы.ПоступлениеНМА);
	ПравоНачалоСтадииРазработокНМА = ПравоДоступа("ИнтерактивноеДобавление", Метаданные.Документы.НачалоСтадииРазработокНМА);
	ПравоРегистрацияЗемельныхУчастков = ПравоДоступа("Редактирование", Метаданные.РегистрыСведений.РегистрацияЗемельныхУчастков);
	ПравоРегистрацияТранспортныхСредств = ПравоДоступа("Редактирование", Метаданные.РегистрыСведений.РегистрацияТранспортныхСредств);
	
	Элементы.СоздатьПоступлениеОсновныеСредства.Видимость = ПравоПоступлениеТоваровУслуг;
	Элементы.СоздатьПриобретениеЗемельныхУчастков.Видимость = ПравоПоступлениеТоваровУслуг;
	Элементы.СоздатьПоступлениеВАренду.Видимость = ПравоПоступлениеВАренду;
	Элементы.СоздатьПоступлениеВЛизинг.Видимость = ПравоПоступлениеВАренду;
	
	Элементы.СоздатьПоступлениеНМА.Видимость = ПравоПоступлениеНМА;
	Элементы.СоздатьПриобретениеПрав.Видимость = ПравоПоступлениеТоваровУслуг;
	Элементы.СоздатьНачалоСтадииРазработкиНМА.Видимость = ПравоНачалоСтадииРазработокНМА;
	
	Элементы.СоздатьРегистрацияЗемельногоУчастка.Видимость = ПравоРегистрацияЗемельныхУчастков;
	Элементы.СоздатьСнятиеСРегистрацииЗемельногоУчастка.Видимость = ПравоРегистрацияЗемельныхУчастков;
	Элементы.СоздатьРегистрацияТранспортногоСредства.Видимость = ПравоРегистрацияТранспортныхСредств;
	Элементы.СоздатьСнятиеСРегистрацииТранспортногоСредства.Видимость = ПравоРегистрацияТранспортныхСредств;
	
	Элементы.СписокОССостояние.Видимость = ОтображатьДополнительныеКолонки;
	Элементы.СписокОСОтветственный.Видимость = ОтображатьДополнительныеКолонки;
	Элементы.СписокОСМестонахождение.Видимость = ОтображатьДополнительныеКолонки;
	
	Элементы.СписокНМАСостояние.Видимость = ОтображатьДополнительныеКолонки;
	
КонецПроцедуры

&НаКлиенте
Функция ПараметрыФормыДокументаПоступления(Список, ВидОперации = Неопределено)
	
	СтруктураПараметров = Новый Структура;
	ЗначенияЗаполнения = ОбщегоНазначенияБПВызовСервера.ЗначенияЗаполненияДинамическогоСписка(Список.КомпоновщикНастроек);
	Если ЗначениеЗаполнено(ВидОперации) Тогда
		ЗначенияЗаполнения.Вставить("ВидОперации", ВидОперации);
	КонецЕсли;
	Если ОтборОрганизацияИспользование Тогда
		ЗначенияЗаполнения.Вставить("Организация", ОтборОрганизация);
	КонецЕсли;
	СтруктураПараметров.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	Возврат СтруктураПараметров;
	
КонецФункции

&НаКлиенте
Функция ПараметрыФормыРегистрацииОС(ОсновноеСредство, ВидЗаписи)
	
	ЗначенияЗаполнения = ОбщегоНазначенияБПВызовСервера.ЗначенияЗаполненияДинамическогоСписка(СписокОС.КомпоновщикНастроек);
	ЗначенияЗаполнения.Вставить("ВидЗаписи", ВидЗаписи);
	ЗначенияЗаполнения.Вставить("ОсновноеСредство", ОсновноеСредство);
	Если ОтборОрганизацияИспользование Тогда
		ЗначенияЗаполнения.Вставить("Организация", ОтборОрганизация);
	КонецЕсли;
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	Возврат СтруктураПараметров;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьВидыИмущества(ВедетсяУчетОС, ВедетсяУчетНМА)
	
	СписокВыбора = Элементы.ВидИмущества.СписокВыбора;
	СписокВыбора.Очистить();
	
	Подсказки = Новый Массив;
	
	Если ВедетсяУчетОС Тогда
		
		ОсновныеСредства = СписокВыбора.Добавить();
		ОсновныеСредства.Значение = ВидОсновныеСредства();
		ОсновныеСредства.Представление = НСтр("ru = 'Все ОС'");
		
		ОсновныеСредства = СписокВыбора.Добавить();
		ОсновныеСредства.Значение = ВидТранспорт();
		ОсновныеСредства.Представление = НСтр("ru = 'Транспорт'");
		
		ОсновныеСредства = СписокВыбора.Добавить();
		ОсновныеСредства.Значение = ВидЗемля();
		ОсновныеСредства.Представление = НСтр("ru = 'Земля'");
		
		Подсказки.Добавить(НСтр("ru = 'ОС - основные средства'"));
		
	КонецЕсли;
	
	НематериальныеАктивы = СписокВыбора.Добавить();
	НематериальныеАктивы.Значение = ВидНематериальныеАктивы();
	Если ВедетсяУчетНМА Тогда
		НематериальныеАктивы.Представление = НСтр("ru = 'НМА'");
		Подсказки.Добавить(НСтр("ru = 'НМА - нематериальные активы'"));
	Иначе
		НематериальныеАктивы.Представление = НСтр("ru = 'Права'");
	КонецЕсли;
		
	ВидИмущества = СписокВыбора[0].Значение;
	Элементы.ВидИмущества.Видимость = СписокВыбора.Количество() > 1;
	Элементы.ВидИмущества.Подсказка = СтрСоединить(Подсказки, Символы.ПС);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриВыбореВидаИмущества()
	
	ВыбранСписокНМА = ВидИмущества = ВидНематериальныеАктивы();
	
	Если ВыбранСписокНМА Тогда
		ПоказатьСтраницуНМА();
	Иначе
		ПоказатьСтраницуОС(ВидИмущества);
	КонецЕсли;
	
	Элементы.ГруппаДополнительныеОтборыОС.Видимость = Не ВыбранСписокНМА;
	Элементы.ГруппаДополнительныеОтборыНМА.Видимость = ВыбранСписокНМА;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборПоОрганизации()
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		СписокОС.КомпоновщикНастроек.Настройки.Отбор,
		"Организация",
		ОтборОрганизация,
		,
		,
		ИспользоватьНесколькоОрганизаций И ОтборОрганизацияИспользование);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		СписокНМА.КомпоновщикНастроек.Настройки.Отбор,
		"Организация",
		ОтборОрганизация,
		,
		,
		ИспользоватьНесколькоОрганизаций И ОтборОрганизацияИспользование);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииОрганизации()
	
	УстановитьОтборПоОрганизации();
	
	ПодключитьОбработчикОжидания("Подключаемый_УстановитьБаннер", 0.1, Истина);
	ПодключитьОбработчикОжидания("ПоказатьИнформациюОПравеПримененияСпецрежима", 0.1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСтраницуОС(ВидИмущества)
	
	СписокВсеОС = ВидИмущества = ВидОсновныеСредства();
	СписокЗемля = ВидИмущества = ВидЗемля();
	СписокТранспорт = ВидИмущества = ВидТранспорт();
	
	Элементы.ГруппаСписки.ТекущаяСтраница = Элементы.ГруппаСписокОС;
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(СписокОС, "ГруппаОС");
	
	Если СписокЗемля Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(СписокОС,
			"ГруппаОС", ПредопределенноеЗначение("Перечисление.ГруппыОС.ЗемельныеУчастки"));
	ИначеЕсли СписокТранспорт Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(СписокОС,
			"ГруппаОС", ПредопределенноеЗначение("Перечисление.ГруппыОС.ТранспортныеСредства"));
	КонецЕсли;
	
	Элементы.ПоказыватьГруппыОС.Видимость = Не СписокВсеОС;
	Если СписокВсеОС Тогда
		ГруппыОСПоказать();
	Иначе
		ГруппыОССкрыть();
	КонецЕсли;
	
	Элементы.СоздатьПриобретениеЗемельныхУчастков.Видимость = СписокВсеОС Или СписокЗемля;
	Элементы.СоздатьПоступлениеВЛизинг.Видимость = Не СписокЗемля;
	Элементы.ГруппаРегистрацияЗемельныхУчастковОС.Видимость = СписокЗемля;
	Элементы.ГруппаРегистрацияТранспортныхСредствОС.Видимость = СписокТранспорт;
	
	Элементы.СписокОСРегистрационныйЗнак.Видимость = СписокТранспорт И ОтображатьДополнительныеКолонки;
	Элементы.СписокОСКадастровыйНомер.Видимость = СписокЗемля И ОтображатьДополнительныеКолонки;
	
	Если ОтображатьДополнительныеКолонки Тогда
		ПоместитьТекстЗапросаДополнительныхДанныхОС(АдресТекстаЗапросаДополнительныхДанных, ВидИмущества);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСтраницуНМА()
	
	Элементы.ГруппаСписки.ТекущаяСтраница = Элементы.ГруппаСписокНМА;
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппыОСПоказать()
	
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(СписокОС, "ЭтоГруппа");
	Элементы.СписокОС.Отображение = ПредыдущийВариантОтображенияСпискаОС;
	Элементы.ПоказыватьГруппыОС.Пометка = Истина;
	ГруппыОССкрыты = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ГруппыОССкрыть()
	
	Если ГруппыОССкрыты Тогда
		Возврат;
	КонецЕсли;
	
	ПредыдущийВариантОтображенияСпискаОС = Элементы.СписокОС.Отображение;
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(СписокОС, "ЭтоГруппа", Ложь);
	Элементы.СписокОС.Отображение = ОтображениеТаблицы.Список;
	Элементы.ПоказыватьГруппыОС.Пометка = Ложь;
	ГруппыОССкрыты = Истина;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВидОсновныеСредства()
	
	Возврат "ОсновныеСредства";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидТранспорт()
	
	Возврат "Транспорт";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидЗемля()
	
	Возврат "Земля";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВидНематериальныеАктивы()
	
	Возврат "НематериальныеАктивы";
	
КонецФункции

&НаСервереБезКонтекста
Процедура ПоместитьТекстЗапросаДополнительныхДанныхОС(Адрес, ВидИмущества)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ОсновныеСредства.ОсновноеСредство КАК ОсновноеСредство,
	|	ОсновныеСредства.Организация КАК Организация
	|ПОМЕСТИТЬ ОсновныеСредства
	|ИЗ
	|	&ОсновныеСредства КАК ОсновныеСредства
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МестонахождениеОСБУ.ОсновноеСредство КАК ОсновноеСредство,
	|	МестонахождениеОСБУ.Организация КАК Организация,
	|	ВЫБОР
	|		КОГДА МестонахождениеОСБУ.Контрагент = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	|			ТОГДА МестонахождениеОСБУ.Местонахождение
	|		ИНАЧЕ МестонахождениеОСБУ.Контрагент
	|	КОНЕЦ КАК Местонахождение,
	|	МестонахождениеОСБУ.МОЛ КАК Ответственный
	|ПОМЕСТИТЬ МестонахождениеОСБУ
	|ИЗ
	|	РегистрСведений.МестонахождениеОСБухгалтерскийУчет.СрезПоследних(, (ОсновноеСредство, Организация) В
	|		(ВЫБРАТЬ
	|			ОсновныеСредства.ОсновноеСредство,
	|			ОсновныеСредства.Организация
	|		ИЗ
	|			ОсновныеСредства КАК ОсновныеСредства)) КАК МестонахождениеОСБУ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОсновныеСредства.ОсновноеСредство КАК ОсновноеСредство,
	|	МестонахождениеОСБУ.Местонахождение КАК Местонахождение,
	|	МестонахождениеОСБУ.Ответственный КАК Ответственный
	|ИЗ
	|	ОсновныеСредства КАК ОсновныеСредства
	|		ЛЕВОЕ СОЕДИНЕНИЕ МестонахождениеОСБУ КАК МестонахождениеОСБУ
	|		ПО ОсновныеСредства.ОсновноеСредство = МестонахождениеОСБУ.ОсновноеСредство
	|		И ОсновныеСредства.Организация = МестонахождениеОСБУ.Организация";
	
	Если ВидИмущества = ВидЗемля() Тогда
		ДополнитьЗапросИнформациейПоЗемельнымУчасткам(ТекстЗапроса);
	ИначеЕсли ВидИмущества = ВидТранспорт() Тогда
		ДополнитьЗапросИнформациейПоТранспортнымСредствам(ТекстЗапроса);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(ТекстЗапроса, Адрес);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьЗапросИнформациейПоЗемельнымУчасткам(ТекстЗапроса)
	
	ТекстЗапросаПоРегистрации =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОсновныеСредства.ОсновноеСредство КАК ОсновноеСредство,
	|	ОсновныеСредства.Организация,
	|	МАКСИМУМ(РегистрацияЗемельныхУчастков.Период) КАК Период
	|ПОМЕСТИТЬ ПоследняяРегистрацияЗемельныеУчастки
	|ИЗ
	|	ОсновныеСредства КАК ОсновныеСредства
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияЗемельныхУчастков КАК РегистрацияЗемельныхУчастков
	|		ПО ОсновныеСредства.ОсновноеСредство = РегистрацияЗемельныхУчастков.ОсновноеСредство
	|		И ОсновныеСредства.Организация = РегистрацияЗемельныхУчастков.Организация
	|ГДЕ
	|	РегистрацияЗемельныхУчастков.ВидЗаписи = ЗНАЧЕНИЕ(Перечисление.ВидЗаписиОРегистрации.Регистрация)
	|СГРУППИРОВАТЬ ПО
	|	ОсновныеСредства.ОсновноеСредство,
	|	ОсновныеСредства.Организация";
	
	ТекстЗапросаПоЗемельнымУчасткам =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоследняяРегистрация.ОсновноеСредство,
	|	РегистрацияЗемельныхУчастков.КадастровыйНомер
	|ПОМЕСТИТЬ ЗемельныеУчастки
	|ИЗ
	|	ПоследняяРегистрацияЗемельныеУчастки КАК ПоследняяРегистрация
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияЗемельныхУчастков КАК РегистрацияЗемельныхУчастков
	|		ПО ПоследняяРегистрация.ОсновноеСредство = РегистрацияЗемельныхУчастков.ОсновноеСредство
	|		И ПоследняяРегистрация.Организация = РегистрацияЗемельныхУчастков.Организация
	|		И ПоследняяРегистрация.Период = РегистрацияЗемельныхУчастков.Период";
	
	Схема = Новый СхемаЗапроса();
	Схема.УстановитьТекстЗапроса(ТекстЗапроса);
	ПоследнийЗапрос = Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество() - 1];
	
	НовыйЗапрос = Схема.ПакетЗапросов.Добавить();
	НовыйЗапрос.УстановитьТекстЗапроса(ТекстЗапросаПоРегистрации);
	НовыйЗапрос = Схема.ПакетЗапросов.Добавить();
	НовыйЗапрос.УстановитьТекстЗапроса(ТекстЗапросаПоЗемельнымУчасткам);
	
	Схема.ПакетЗапросов.Переместить(ПоследнийЗапрос, Схема.ПакетЗапросов.Количество() - 1);
	ПоследнийЗапрос.Операторы[0].Источники.Добавить("ЗемельныеУчастки", "ЗемельныеУчастки");
	ПоследнийЗапрос.Операторы[0].ВыбираемыеПоля.Добавить("ЗемельныеУчастки.КадастровыйНомер");
	ПоследнийЗапрос.Операторы[0].Источники[0].Соединения.Добавить("ЗемельныеУчастки",
		"ОсновныеСредства.ОсновноеСредство = ЗемельныеУчастки.ОсновноеСредство");
	
	ТекстЗапроса = Схема.ПолучитьТекстЗапроса();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьЗапросИнформациейПоТранспортнымСредствам(ТекстЗапроса)
	
	ТекстЗапросаПоРегистрации =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ОсновныеСредства.ОсновноеСредство КАК ОсновноеСредство,
	|	ОсновныеСредства.Организация,
	|	МАКСИМУМ(РегистрацияТранспортныхСредств.Период) КАК Период
	|ПОМЕСТИТЬ ПоследняяРегистрацияТранспортныеСредства
	|ИЗ
	|	ОсновныеСредства КАК ОсновныеСредства
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияТранспортныхСредств КАК РегистрацияТранспортныхСредств
	|		ПО ОсновныеСредства.ОсновноеСредство = РегистрацияТранспортныхСредств.ОсновноеСредство
	|		И ОсновныеСредства.Организация = РегистрацияТранспортныхСредств.Организация
	|ГДЕ
	|	РегистрацияТранспортныхСредств.ВидЗаписи = ЗНАЧЕНИЕ(Перечисление.ВидЗаписиОРегистрации.Регистрация)
	|СГРУППИРОВАТЬ ПО
	|	ОсновныеСредства.ОсновноеСредство,
	|	ОсновныеСредства.Организация";
	
	ТекстЗапросаПоТранспортнымСредствам =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоследняяРегистрация.ОсновноеСредство,
	|	РегистрацияТранспортныхСредств.РегистрационныйЗнак КАК РегистрационныйЗнак
	|ПОМЕСТИТЬ ТранспортныеСредства
	|ИЗ
	|	ПоследняяРегистрацияТранспортныеСредства КАК ПоследняяРегистрация
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияТранспортныхСредств КАК РегистрацияТранспортныхСредств
	|		ПО ПоследняяРегистрация.ОсновноеСредство = РегистрацияТранспортныхСредств.ОсновноеСредство
	|		И ПоследняяРегистрация.Организация = РегистрацияТранспортныхСредств.Организация
	|		И ПоследняяРегистрация.Период = РегистрацияТранспортныхСредств.Период";
	
	Схема = Новый СхемаЗапроса();
	Схема.УстановитьТекстЗапроса(ТекстЗапроса);
	ПоследнийЗапрос = Схема.ПакетЗапросов[Схема.ПакетЗапросов.Количество() - 1];
	
	НовыйЗапрос = Схема.ПакетЗапросов.Добавить();
	НовыйЗапрос.УстановитьТекстЗапроса(ТекстЗапросаПоРегистрации);
	
	НовыйЗапрос = Схема.ПакетЗапросов.Добавить();
	НовыйЗапрос.УстановитьТекстЗапроса(ТекстЗапросаПоТранспортнымСредствам);
	
	Схема.ПакетЗапросов.Переместить(ПоследнийЗапрос, Схема.ПакетЗапросов.Количество() - 1);
	ПоследнийЗапрос.Операторы[0].Источники.Добавить("ТранспортныеСредства", "ТранспортныеСредства");
	ПоследнийЗапрос.Операторы[0].ВыбираемыеПоля.Добавить("ТранспортныеСредства.РегистрационныйЗнак");
	ПоследнийЗапрос.Операторы[0].Источники[0].Соединения.Добавить("ТранспортныеСредства",
		"ОсновныеСредства.ОсновноеСредство = ТранспортныеСредства.ОсновноеСредство");
	
	ТекстЗапроса = Схема.ПолучитьТекстЗапроса();
	
КонецПроцедуры

