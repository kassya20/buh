#Область ОбработчикиСобытийФормы  

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВывестиСчета();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции  

&НаСервере
Процедура ВывестиСчета()
	
	Макет = Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.ПолучитьМакет("МакетСчетаПоиска");
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Хозрасчетный.Родитель.Родитель.Родитель = &ПустаяСсылка
	|			ТОГДА 3
	|		КОГДА Хозрасчетный.Родитель.Родитель = &ПустаяСсылка
	|			ТОГДА 2
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Уровень, 
	|	Хозрасчетный.Представление КАК Представление, 
	|	Хозрасчетный.Наименование КАК Наименование
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В(&СписокСчетов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Хозрасчетный.КодБыстрогоВыбора";
	Запрос.УстановитьПараметр("ПустаяСсылка", ПланыСчетов.Хозрасчетный.ПустаяСсылка());
	СписокСчетовПоиска = Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.СписокСчетовПоиска();
	Запрос.УстановитьПараметр("СписокСчетов", СписокСчетовПоиска);
	Результат = Запрос.Выполнить();
	
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьСчет1Уровня = Макет.ПолучитьОбласть("Счет1Уровня");
	ОбластьСчет2Уровня = Макет.ПолучитьОбласть("Счет2Уровня");
	ОбластьСчет3Уровня = Макет.ПолучитьОбласть("Счет3Уровня");
	
	ТаблицаСписок.Очистить();
	ТаблицаСписок.Вывести(ОбластьШапка);
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.Уровень = 1 Тогда 
			Область = ОбластьСчет1Уровня;
		ИначеЕсли Выборка.Уровень = 2 Тогда 
			Область = ОбластьСчет2Уровня;
		Иначе 
			Область = ОбластьСчет3Уровня;
		КонецЕсли;
		Область.Параметры.Заполнить(Выборка);
		ТаблицаСписок.Вывести(Область);
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

