			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ВводНачальныхОстатков.Ссылка КАК ДокументОперации,
	ВводНачальныхОстатков.Дата КАК Дата,
	ВводНачальныхОстатков.Номер КАК Номер,
	ВводНачальныхОстатков.Проведен КАК Проведен,
	ВводНачальныхОстатков.РазделУчета КАК РазделУчета,
	ВводНачальныхОстатков.ПодразделениеОрганизации КАК ПодразделениеОрганизации,
	ВыполнениеРегламентныхОперацийНДС.Счет КАК Счет,
	ВводНачальныхОстатков.Организация КАК Организация,
	СУММА(ВводНачальныхОстатковНДСУчтенныйВСтоимости.НДС) КАК НДС,
	"" КАК Отступ
ИЗ
	РегистрСведений.ВыполнениеРегламентныхОперацийНДС КАК ВыполнениеРегламентныхОперацийНДС
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВводНачальныхОстатков КАК ВводНачальныхОстатков
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВводНачальныхОстатков.НДСУчтенныйВСтоимости КАК ВводНачальныхОстатковНДСУчтенныйВСтоимости
			ПО (ВводНачальныхОстатковНДСУчтенныйВСтоимости.Ссылка = ВводНачальныхОстатков.Ссылка)
		ПО ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент = ВводНачальныхОстатков.Ссылка
ГДЕ
	ВЫБОР
			КОГДА &amp;ОтборПоОрганизации
				ТОГДА ВыполнениеРегламентныхОперацийНДС.Организация = &amp;Организация
			ИНАЧЕ ИСТИНА
		КОНЕЦ
	И ВыполнениеРегламентныхОперацийНДС.РегламентнаяОперация = ЗНАЧЕНИЕ(Перечисление.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости)
	

СГРУППИРОВАТЬ ПО
	ВводНачальныхОстатков.Ссылка,
	ВводНачальныхОстатков.Дата,
	ВводНачальныхОстатков.Номер,
	ВводНачальныхОстатков.Проведен,
	ВводНачальныхОстатков.РазделУчета,
	ВводНачальныхОстатков.ПодразделениеОрганизации,
	ВыполнениеРегламентныхОперацийНДС.Счет,
	ВводНачальныхОстатков.Организация</QueryText>
