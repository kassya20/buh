#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СписокПараметров = "Организация, 
	|НачалоПериода, 
	|КонецПериода, 
	|ДатаПерехода, 
	|СтавкаНДС";
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры, СписокПараметров);
	
	ТекстВвестиРеквизиты = НСтр("ru = '<Ввести реквизиты>'");
	ЗагрузитьСхраненныеДанные();
	УстановитьУсловноеОформление();
	УстановитьСвойстваПолей();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.СостояниеВыполняется.Видимость = Ложь;
	РассчитатьВозможностьПодготовитьКВычету();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Модифицированность Тогда
		Если ЗавершениеРаботы Тогда
			Отказ = Истина;
			Возврат;
		Иначе 
			ОписаниеОповещения = Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект);
			ПоказатьВопрос(ОписаниеОповещения, 
			НСтр("ru = 'Данные были изменены. Сохранить изменения?'"), 
			РежимДиалогаВопрос.ДаНетОтмена);
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если СтрНайти(ИмяСобытия, "ПодготовкаКВычетуНДС") = 0 Тогда 
		Возврат
	КонецЕсли;
	
	Если ИмяСобытия = "ПодготовкаКВычетуНДСГрупповоеИзменениеРеквизитов" Тогда
		ЗагрузитьВНДСПоОстаткамИзВременногоХранилища(Параметр);
		ЗаполнитьПартии();
		Модифицированность = Истина;
		РассчитатьВозможностьПодготовитьКВычету();
	ИначеЕсли ИмяСобытия = "ПодготовкаКВычетуНДСЗакрытьФормуДозаполнения" Тогда
		Модифицированность = Ложь;
		ЭтаФорма.Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если НавигационнаяСсылкаФорматированнойСтроки = "ПомощникЗаполнения" Тогда
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("КонецПериода", КонецПериода);
		ПараметрыФормы.Вставить("АдресНДСПоОстаткам", АдресНДСПоОстаткамВоВовременномХранилище());
		ОткрытьФорму("Обработка.ПодготовкаКВычетуНДСУчтенногоВСтоимости.Форма.ФормаГрупповогоЗаполненияДанных", 
			ПараметрыФормы, ЭтотОбъект, "ФормаГрупповогоЗаполненияДанных", , , , 
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьОперацию(Команда)
	
	ОтменитьОперациюСервер(ВыполняемаяОперация);
	ЗаблокироватьФормуНаВремяДлительнойОперации(Ложь);
	РассчитатьВозможностьПодготовитьКВычету();
	Оповестить("ПодготовкаКВычетуНДСОбновитьПослеДозаполнения");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПартии

&НаКлиенте
Процедура ПартииПриИзменении(Элемент)
	
	РассчитатьВозможностьПодготовитьКВычету();
	
КонецПроцедуры

&НаКлиенте
Процедура ПартииВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "ПартииРеквизитыСчетаФактуры" Тогда
		ОткрытьФормуРеквизитовСчетаФактуры(ВыбраннаяСтрока);
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПартииПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.Партии.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда 
		Партия		 = Неопределено;
		ПартияИдентификаторСтроки = "";
	Иначе 
		Партия		 = ТекущиеДанные.Партия;
		ПартияИдентификаторСтроки = Элементы.Партии.ТекущаяСтрока;
	КонецЕсли;
	
	Если ТипЗнч(Партия) = Тип("ДокументСсылка.КомплектацияНоменклатуры") Тогда 
		Элементы.УстановитьНДСПоНоменклатуре.Видимость = Ложь;
	ИначеЕсли ТипЗнч(Партия) = Тип("ДокументСсылка.ПоступлениеТоваровУслуг") Тогда 
		Элементы.УстановитьНДСПоНоменклатуре.Видимость = Истина;
	Иначе 
		Элементы.УстановитьНДСПоНоменклатуре.Видимость = Ложь;
	КонецЕсли;
	
	ЗаполнитьТовары();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары

&НаКлиенте
Процедура ТоварыСтавкаНДСПриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;  
	ТоварыПересчитатьСуммыПриИзмененииСтавкаНДС(СтрокаТаблицы);
	ОбновитьСуммыВПартии();
	РассчитатьВозможностьПодготовитьКВычету();
	
КонецПроцедуры

#КонецОбласти

 #Область ОбработчикиКомандФормы
 
&НаКлиенте
Процедура ЗакрытьПанельПодсказок(Команда)
	
	ИзменитьВидимостьПодсказокНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьВидимостьПодсказок(Команда)
	
	ИзменитьВидимостьПодсказокНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодготовитьНДСКВычету(Команда)
	
	ЗаблокироватьФормуНаВремяДлительнойОперации(Истина);
	СохранитьДанные();
	Модифицированность = Ложь;
	
	ВыполняемаяОперация = СоздатьДокументыВводаОстатковВФоне();
	
	Обработчик = Новый ОписаниеОповещения("ПослеПодготовкиКВычету", ЭтотОбъект);
	
	НастройкиОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	НастройкиОжидания.ВыводитьОкноОжидания = Ложь;
	НастройкиОжидания.ВыводитьПрогрессВыполнения = Истина;
	ДополнительныеПараметры = Новый Структура;
	НастройкиОжидания.ОповещениеОПрогрессеВыполнения = Новый ОписаниеОповещения("ПриОбновленииПрогрессаФоновогоЗадания", 
		ЭтотОбъект, ДополнительныеПараметры);
	
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ВыполняемаяОперация, Обработчик, НастройкиОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНДС10ПоПартии(Команда)
	
	УстановитьНДСПоПартииНаСервере(ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС10"));
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНДС20ПоПартии(Команда)
	
	УстановитьНДСПоПартииНаСервере(ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС20"));
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНДС22ПоПартии(Команда)
	
	УстановитьНДСПоПартииНаСервере(ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС22"));
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНДС5ПоПартии(Команда)
	
	УстановитьНДСПоПартииНаСервере(ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС5"));
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНДС7ПоПартии(Команда)

	УстановитьНДСПоПартииНаСервере(ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС7"));
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНДСПоНоменклатуреПоПартии(Команда)
	
	УстановитьНДСПоНоменклатуреПоПартииНаСервере();
	Для Каждого СтрокаТовары Из Товары Цикл 
		ТоварыПересчитатьСуммыПриИзмененииСтавкаНДС(СтрокаТовары);
	КонецЦикла;
	ОбновитьСуммыВПартии();
	РассчитатьВозможностьПодготовитьКВычету();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗаблокироватьФормуНаВремяДлительнойОперации(Блокировка)
	
	Элементы.СохранитьИзменения.Доступность = НЕ Блокировка;
	Элементы.ГруппаПартии.Доступность = НЕ Блокировка;
	Элементы.ГруппаТовары.Доступность = НЕ Блокировка;
	Элементы.ПанельПодсказки.Доступность = НЕ Блокировка;
	
	Элементы.СостояниеВыполняется.Видимость = Блокировка;
	
КонецПроцедуры

&НаСервере
Процедура ОтменитьОперациюСервер(ВыполняемаяОперация)
	
	Если ВыполняемаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДлительныеОперации.ОтменитьВыполнениеЗадания(ВыполняемаяОперация.ИдентификаторЗадания);
	ЗагрузитьСхраненныеДанные();
	
КонецПроцедуры

&НаСервере
Функция СоздатьДокументыВводаОстатковВФоне()
	
	ПараметрыПроцедуры = РеквизитыФормы(Истина);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Создание документов ввода остатков'");
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(
		"Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.СозданиеДокументовВводаОстатков",
		ПараметрыПроцедуры,
		ПараметрыВыполнения);
	
КонецФункции

&НаКлиенте
Процедура ПослеПодготовкиКВычету(Результат, Параметры) Экспорт
	
	ЗагрузитьСхраненныеДанные();
	ЗаблокироватьФормуНаВремяДлительнойОперации(Ложь);
	РассчитатьВозможностьПодготовитьКВычету();
	Оповестить("ПодготовкаКВычетуНДСОбновитьПослеДозаполнения");
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСхраненныеДанные()
	
	Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.ЗагрузитьСхраненныеДанные(ЭтотОбъект);
	ЗаполнитьПартии();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОбновленииПрогрессаФоновогоЗадания(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат.Прогресс <> Неопределено Тогда
		Элементы.ПредставлениеПрогресса.Заголовок = Результат.Прогресс.Текст;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция РеквизитыФормы(ВыгружатьНДСПоОстаткам = Ложь)
	
	РеквизитыФормы = Новый Структура();
	РеквизитыФормы.Вставить("Организация", 	Организация);
	РеквизитыФормы.Вставить("НачалоПериода", НачалоПериода);
	РеквизитыФормы.Вставить("КонецПериода", 	КонецПериода);
	РеквизитыФормы.Вставить("ДатаПерехода", 	ДатаПерехода);
	РеквизитыФормы.Вставить("СтавкаНДС", 	СтавкаНДС);
	РеквизитыФормы.Вставить("ЗаполненоАвтоматически", Ложь);
	Если ВыгружатьНДСПоОстаткам Тогда 
		РеквизитыФормы.Вставить("НДСПоОстаткам", НДСПоОстаткам.Выгрузить());
	КонецЕсли;
	Возврат РеквизитыФормы;
	
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	//Не заполнен счет-фактура
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ПартииРеквизитыСчетаФактуры");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор, 
	"Партии.РеквизитыСчетаФактурыЗаполнены", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.НезаполненныйРеквизит);
	//Не заполнена сумма НДС
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ПартииСуммаНДС");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор, 
	"Партии.СуммаНДС", ВидСравненияКомпоновкиДанных.Равно, 0);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);
	//Можно подготовить к вычету
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	Для Каждого Поле Из Элементы.Партии.ПодчиненныеЭлементы Цикл 
		Если Поле.Вид = ВидПоляФормы.ПолеВвода Тогда 
			КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, Поле.Имя);
		КонецЕсли;
	КонецЦикла;

	ГруппаОтбор = КомпоновкаДанныхКлиентСервер.ДобавитьГруппуОтбора(ЭлементУО.Отбор.Элементы, 
		ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбор, "Партии.СуммаНДС", 
	ВидСравненияКомпоновкиДанных.Больше, 0);
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбор, "Партии.РеквизитыСчетаФактурыЗаполнены", 
	ВидСравненияКомпоновкиДанных.Равно, Истина);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.Роса);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПартии()
	
	КолонкиПартий = КолонкиПартий();
	
	СтрокиДозаполнить = НДСПоОстаткам.НайтиСтроки(ОтборДозаполнить());
	ТЗПартии = НДСПоОстаткам.Выгрузить(СтрокиДозаполнить, КолонкиПартий.Все);
	ТЗПартии.Свернуть(КолонкиПартий.КолонкиГруппировки, КолонкиПартий.КолонкиСуммирования);
	Партии.Загрузить(ТЗПартии);
	НомерСтроки = 1;
	Для Каждого СтрокаПартии Из Партии Цикл 
		СтрокаПартии.НомерСтроки = НомерСтроки;
		НомерСтроки = НомерСтроки + 1;
		ЗаполнитьРеквизитыСчетаФактуры(СтрокаПартии);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТовары()	
	
	Товары.Очистить();
	
	Если Партия = Неопределено Тогда 
		Возврат
	КонецЕсли;
	
	ПоискПоПартии = ОтборДозаполнить();
	ПоискПоПартии.Вставить("Партия", Партия);
		
	СтрокиПоПартии = НДСПоОстаткам.НайтиСтроки(ПоискПоПартии);
	
	КолонкиТоваров = КолонкиТоваров();
	
	ОстаткиПоПартии = НДСПоОстаткам.Выгрузить(СтрокиПоПартии, КолонкиТоваров.Все);
	ОстаткиПоПартии.Свернуть(КолонкиТоваров.КолонкиГруппировки, КолонкиТоваров.КолонкиСуммирования);
	Товары.Загрузить(ОстаткиПоПартии);
	
	Для Каждого СтрокаТовары Из Товары Цикл 
		СтрокаТовары.Сумма = ?(СтрокаТовары.СуммаВключаетНДС, СтрокаТовары.Всего, СтрокаТовары.СуммаБезНДС);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КолонкиПартий()
	
	КолонкиПартий = Новый Структура;
	
	КолонкиГруппировки = "Партия, 
	|Контрагент, 
	|ДокументПоступления, 
	|СчетФактура, 
	|СчетФактураДатаВх, 
	|СчетФактураНомерВх, 
	|ДатаВх, 
	|НомерВх, 
	|СуммаВключаетНДС, 
	|НДСВключенВСтоимость, 
	|Дата, 
	|Номер, 
	|ДоговорКонтрагента, 
	|Подразделение, 
	|СуммаДокумента";
	
	КолонкиСуммирования = "СуммаНДС, 
	|СуммаБезНДС, 
	|РасходУСН, 
	|УчтенныйНДС, 
	|Всего";
	
	КолонкиПартий.Вставить("КолонкиГруппировки", КолонкиГруппировки);
	КолонкиПартий.Вставить("КолонкиСуммирования", КолонкиСуммирования);
	КолонкиПартий.Вставить("Все", СтрШаблон("%1, %2", КолонкиГруппировки, КолонкиСуммирования));
	
	Возврат КолонкиПартий;
	
КонецФункции    

