КонецФункции

&НаСервере
Процедура ЗаполнитьРеквизитыСчетаФактуры(ДанныеСтроки)
	
	РеквизитыСчетаФактурыТекст = ТекстВвестиРеквизиты;
	
	Если ЗначениеЗаполнено(ДанныеСтроки.СчетФактураДатаВх) И ЗначениеЗаполнено(ДанныеСтроки.СчетФактураНомерВх) Тогда
		
		РеквизитыСчетаФактурыДляПредставления = Новый Структура();
		РеквизитыСчетаФактурыДляПредставления.Вставить("ВидСчетаФактуры", Перечисления.ВидСчетаФактурыПолученного.НаПоступление);
		РеквизитыСчетаФактурыДляПредставления.Вставить("Исправление", Ложь);
		РеквизитыСчетаФактурыДляПредставления.Вставить("НомерИсправления", 0);
		РеквизитыСчетаФактурыДляПредставления.Вставить("ДатаИсправления", Дата(1, 1, 1));
		РеквизитыСчетаФактурыДляПредставления.Вставить("НомерВходящегоДокумента", ДанныеСтроки.СчетФактураНомерВх);
		РеквизитыСчетаФактурыДляПредставления.Вставить("ДатаВходящегоДокумента", ДанныеСтроки.СчетФактураДатаВх);
		РеквизитыСчетаФактурыДляПредставления.Вставить("БланкСтрогойОтчетности", Ложь);
		
		СтруктураПредставления = Документы.СчетФактураПолученный.ПолучитьПредставлениеПоРеквизитам(РеквизитыСчетаФактурыДляПредставления);
		РеквизитыСчетаФактурыТекст = СтруктураПредставления.ТекстПредставлениеКраткое;
		
		РеквизитыСчетаФактурыЗаполнены = Истина;
	Иначе
		РеквизитыСчетаФактурыЗаполнены = Ложь;
	КонецЕсли;
	
	ДанныеСтроки.РеквизитыСчетаФактуры 				 = РеквизитыСчетаФактурыТекст;
	ДанныеСтроки.РеквизитыСчетаФактурыЗаполнены 	 = РеквизитыСчетаФактурыЗаполнены;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьВозможностьПодготовитьКВычету()
	
	СуммаНДСДоступнаяКВычету = 0;
	ТекстСуммаНДСДоступнаяКВычету = "";
	
	СтрокиСЗаполненымиСчетамиФактурами = Партии.НайтиСтроки(Новый Структура("РеквизитыСчетаФактурыЗаполнены", Истина));
	Для Каждого СтрокаСЗаполненымСчетомФактурой Из СтрокиСЗаполненымиСчетамиФактурами Цикл 
		Если СтрокаСЗаполненымСчетомФактурой.СуммаНДС > 0 Тогда
			СуммаНДСДоступнаяКВычету = СуммаНДСДоступнаяКВычету + СтрокаСЗаполненымСчетомФактурой.СуммаНДС;
		КонецЕсли;
	КонецЦикла;
	
	Если СуммаНДСДоступнаяКВычету > 0 Тогда 
		ДоступноКВычетуТекст = Формат(СуммаНДСДоступнаяКВычету, "ЧЦ = 15; ЧДЦ = 2");
		ЕстьВозможностьПодготовитьКВычету = Истина;
	Иначе 
		ДоступноКВычетуТекст = "0";
		ЕстьВозможностьПодготовитьКВычету = Ложь;
	КонецЕсли;  
	
	СуммаНДСДоступнаяКВычетуЗаголовок = СтрШаблон("%1 из максимально возможных %2", 
	ДоступноКВычетуТекст, Формат(МакисмальнаяСуммаНДСДоступнаяКВычету(), "ЧЦ = 15; ЧДЦ = 2"));
	
	Элементы.СохранитьИзменения.Доступность				 = ЕстьВозможностьПодготовитьКВычету; 
	Элементы.СохранитьИзменения.КнопкаПоУмолчанию		 = ЕстьВозможностьПодготовитьКВычету; 
	Элементы.ДекорацияСуммаНДСДоступнаяКВычету.Заголовок = СуммаНДСДоступнаяКВычетуЗаголовок;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСвойстваПолей()
	
	СписокТолькоОткрытие = "ПартииДоговорКонтрагента, 
	|ПартииКонтрагент, 
	|ПартииПартия, 
	|ПартииПодразделение, 
	|ТоварыНоменклатура";
	
	СписокТолькоПросмотр = "ПартииДата, 
	|ПартииДатаВх, 
	|ПартииНомер, 
	|ПартииНомерВх, 
	|ПартииРеквизитыСчетаФактуры, 
	|ПартииСуммаДокумента, 
	|ПартииСуммаНДС, 
	|ПартииСчетФактураДатаВх, 
	|ПартииСчетФактураНомерВх, 
	|ТоварыВсего, 
	|ТоварыКоличество, 
	|ТоварыСумма, 
	|ТоварыСуммаНДС, 
	|ТоварыЭтоКомплектующая";

	Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.УстановитьСвойстваПолей(Элементы, СписокТолькоОткрытие, СписокТолькоПросмотр);

КонецПроцедуры

&НаСервере
Функция АдресНДСПоОстаткамВоВовременномХранилище()
	
	Возврат ПоместитьВоВременноеХранилище(НДСПоОстаткам.Выгрузить());
	
КонецФункции

&НаКлиенте 
Процедура ОткрытьФормуРеквизитовСчетаФактуры(ВыбраннаяСтрока)
	
	ДанныеСтроки = Элементы.Партии.ТекущиеДанные;
	Если ДанныеСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	 
	ЗначенияЗаполнения = Новый Структура();
	ЗначенияЗаполнения.Вставить("ДатаДокумента", ДанныеСтроки.СчетФактураДатаВх);
	ЗначенияЗаполнения.Вставить("ПредъявленСФ", Истина);
	ЗначенияЗаполнения.Вставить("ДатаСФ", ДанныеСтроки.СчетФактураДатаВх);
	ЗначенияЗаполнения.Вставить("НомерСФ", ДанныеСтроки.СчетФактураНомерВх);
	ЗначенияЗаполнения.Вставить("Исправление", Ложь);
	ЗначенияЗаполнения.Вставить("НомерИсправления", "");
	ЗначенияЗаполнения.Вставить("ДатаИсправления", Дата(1, 1, 1));
	ЗначенияЗаполнения.Вставить("РазделУчета", 
		ПредопределенноеЗначение("Перечисление.РазделыУчетаДляВводаОстатков.НДСУчтенныйВСтоимости"));
	ЗначенияЗаполнения.Вставить("КорректировочныйСчетФактура", Ложь);
	ЗначенияЗаполнения.Вставить("НомерИсходногоДокумента", "");
	ЗначенияЗаполнения.Вставить("ДатаИсходногоДокумента", Дата(1, 1, 1));
	ЗначенияЗаполнения.Вставить("УчитыватьИсправлениеИсходногоДокумента", Ложь);
	ЗначенияЗаполнения.Вставить("НомерИсправленияИсходногоДокумента", 0);
	ЗначенияЗаполнения.Вставить("ДатаИсправленияИсходногоДокумента", Дата(1, 1, 1));
	ЗначенияЗаполнения.Вставить("ПродавецДоступен", Ложь);
	ЗначенияЗаполнения.Вставить("ТребуетсяСчетФактура", Истина);
	ЗначенияЗаполнения.Вставить("НомерСтрокиДокумента", ДанныеСтроки.НомерСтроки);
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("ТолькоПросмотр", Ложь);
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	ОповещениеФормы = Новый ОписаниеОповещения("ОбработчикЗакрытияФормыРеквизитовСчетаФактурыЗавершение", ЭтотОбъект);
	
	ОткрытьФорму("Документ.ВводНачальныхОстатков.Форма.ФормаРеквизитыСчетаФактуры", 
	ПараметрыФормы, ЭтотОбъект, , , , ОповещениеФормы, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикЗакрытияФормыРеквизитовСчетаФактурыЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Партии.НайтиПоИдентификатору(Элементы.Партии.ТекущаяСтрока);
	Если ТекущиеДанные.СчетФактураНомерВх = РезультатЗакрытия.НомерСФ
		И ТекущиеДанные.СчетФактураДатаВх = РезультатЗакрытия.ДатаСФ Тогда 
		Возврат;
	КонецЕсли;

	ДанныеСтроки = Новый Структура("ПредъявленСФ, 
	|СчетФактураДатаВх, СчетФактураНомерВх, Исправление, КодВидаОперации, Продавец, 
	|НомерИсправления, ДатаИсправления, КорректировочныйСчетФактура, Продавец, 
	|НомерИсходногоДокумента, ДатаИсходногоДокумента, 
	|УчитыватьИсправлениеИсходногоДокумента, НомерИсправленияИсходногоДокумента, 
	|ДатаИсправленияИсходногоДокумента, ПродавецДоступен, РеквизитыСчетаФактуры, РеквизитыСчетаФактурыЗаполнены");
	
	ЗаполнитьЗначенияСвойств(ДанныеСтроки, РезультатЗакрытия);
	ДанныеСтроки.СчетФактураНомерВх = РезультатЗакрытия.НомерСФ;
	ДанныеСтроки.СчетФактураДатаВх = РезультатЗакрытия.ДатаСФ;
	ДанныеСтроки.КорректировочныйСчетФактура = Не РезультатЗакрытия.СтандартныйСчетФактура;
	
	ЗаполнитьРеквизитыСчетаФактуры(ДанныеСтроки);
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, ДанныеСтроки);
	
	СтрокиПоПартии = НДСПоОстаткам.НайтиСтроки(Новый Структура("Партия", ТекущиеДанные.Партия));
	
	Для Каждого СтрокаПоПартии Из СтрокиПоПартии Цикл
		
		ЗаполнитьЗначенияСвойств(СтрокаПоПартии, ДанныеСтроки);
		
	КонецЦикла;
	
	Модифицированность = Истина;
	РассчитатьВозможностьПодготовитьКВычету();
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПересчитатьСуммыПриИзмененииСтавкаНДС(СтрокаТаблицы)
	
	ПоискПоНоменклатуре = Новый Структура();
	ПоискПоНоменклатуре.Вставить("Партия", СтрокаТаблицы.Партия);
	ПоискПоНоменклатуре.Вставить("Номенклатура", СтрокаТаблицы.Номенклатура);
	СвязанныеСтроки = НДСПоОстаткам.НайтиСтроки(ПоискПоНоменклатуре);
	СтрокаТаблицы.СуммаНДС = 0;
	СтрокаТаблицы.СуммаБезНДС = 0;
	Для Каждого СвязаннаяСтрока Из СвязанныеСтроки Цикл 
		СвязаннаяСтрока.СтавкаНДС = СтрокаТаблицы.СтавкаНДС;
		СвязаннаяСтрока.СуммаНДС = УчетНДСКлиентСервер.РассчитатьСуммуНДС(СвязаннаяСтрока.Всего, Истина, 
			УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(СвязаннаяСтрока.СтавкаНДС));
		СвязаннаяСтрока.СуммаБезНДС = СвязаннаяСтрока.Всего - СвязаннаяСтрока.СуммаНДС;
		
		СтрокаТаблицы.СуммаНДС = СтрокаТаблицы.СуммаНДС + СвязаннаяСтрока.СуммаНДС;
		СтрокаТаблицы.СуммаБезНДС = СтрокаТаблицы.СуммаБезНДС + СвязаннаяСтрока.СуммаБезНДС;
	КонецЦикла;
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСуммыВПартии()
	
	СтрокаПартии = Партии.НайтиПоИдентификатору(ПартияИдентификаторСтроки);
	СтрокаПартии.СуммаНДС = Товары.Итог("СуммаНДС");
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьВидимостьПодсказокНаСервере()
	
	НаименованиеРаздела = УправлениеПанельюПодсказкиКлиентСервер.НаименованиеОткрытогоРаздела(ЭтотОбъект);
	
	Если Элементы.ИзменитьВидимостьПодсказок.Пометка Тогда
		
		Состояние = Ложь;
		Элементы.ИзменитьВидимостьПодсказок.Картинка = БиблиотекаКартинок.СтрелкаВлево;
		УправлениеПанельюПодсказкиКлиентСервер.ЗаписатьОперациюБизнесСтатистики(
			СтрШаблон("%1.ЗакрытиеФормы", НаименованиеРаздела));
		
	Иначе
		
		Состояние = Истина;
		Элементы.ИзменитьВидимостьПодсказок.Картинка = БиблиотекаКартинок.СтрелкаВправо;
		УправлениеПанельюПодсказкиКлиентСервер.ЗаписатьОперациюБизнесСтатистики(
			СтрШаблон("%1.ОткрытиеФормы", НаименованиеРаздела));
		
	КонецЕсли;
	
	Элементы.ИзменитьВидимостьПодсказок.Пометка = Состояние;
	Элементы.ПанельПодсказки.Видимость = Состояние;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНДСПоПартииНаСервере(СтавкаНДС)
	
	Для Каждого СтрокаТовары Из Товары Цикл 
		СтрокаТовары.СтавкаНДС = СтавкаНДС;
		ТоварыПересчитатьСуммыПриИзмененииСтавкаНДС(СтрокаТовары);
	КонецЦикла;
	ОбновитьСуммыВПартии();
	РассчитатьВозможностьПодготовитьКВычету();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьНДСПоНоменклатуреПоПартииНаСервере()
	
	СтрокаПартии = Партии.НайтиПоИдентификатору(ПартияИдентификаторСтроки);
	
	ТЗТовары = РеквизитФормыВЗначение("Товары");
	Номенклатура = ТЗТовары.ВыгрузитьКолонку("Номенклатура");
	ВидыСтавокНДСПоТоварам = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Номенклатура, "ВидСтавкиНДС");
	
	Для Каждого ВидСтавкиНДСПоТоварам Из ВидыСтавокНДСПоТоварам Цикл 
		СтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(ВидСтавкиНДСПоТоварам.Значение, СтрокаПартии.Дата);
		СтрокиТовары = ТЗТовары.НайтиСтроки(Новый Структура("Номенклатура", ВидСтавкиНДСПоТоварам.Ключ));
		Для Каждого СтрокаТовары Из СтрокиТовары Цикл 
			СтрокаТовары.СтавкаНДС = СтавкаНДС;
		КонецЦикла;
	КонецЦикла;
	ЗначениеВРеквизитФормы(ТЗТовары, "Товары");
	
КонецПроцедуры

&НаСервере
Функция МакисмальнаяСуммаНДСДоступнаяКВычету()
	
	Возврат УчетНДСКлиентСервер.РассчитатьСуммуНДС(РеквизитФормыВЗначение("Партии").Итог("Всего"), Истина, 
		УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(СтавкаНДС));
	
КонецФункции

&НаСервере
Процедура ЗагрузитьВНДСПоОстаткамИзВременногоХранилища(Адрес)
	
	НДСПоОстаткам.Загрузить(ПолучитьИзВременногоХранилища(Адрес));
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		СохранитьДанные();
		Оповестить("ПодготовкаКВычетуНДСОбновитьПослеДозаполнения");
		Модифицированность = Ложь;
		Закрыть();
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьДанные()
	
	Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.СохранитьВХранилище(РеквизитыФормы(Истина));
	
КонецПроцедуры

#КонецОбласти





