#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("СозданиеДокументовВводаОстатков", Истина);
	
КонецПроцедуры

// Формирует таблицу с суммами НДС и подобранными партиями и сохраняет во временном хранилище
//
// Параметры: 
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации
// - ДатаПерехода - Дата
// - НачалоПериода - Дата
// - КонецПериода - Дата
//  АдресХранилища - УникальныйИдентификатор, Строка
//
Процедура ПоискНДСПоОстаткам(Параметры, АдресХранилища) Экспорт
	
	СообщитьПрогресс(НСтр("ru = 'Подготовка параметров для формирования остатков'"), 1);
	СтруктураПараметров = ПараметрыВыполненияЗапроса(Параметры);
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 07; 08...'"), СтруктураПараметров.СообщениеПрогресс), 10);
	ТаблицаИспользованныхПартий = ЗаполнитьПоСчетам0708(СтруктураПараметров);
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 10; 41; 45...'"), СтруктураПараметров.СообщениеПрогресс), 30);
	ЗаполнитьПоТоварнымСчетам(СтруктураПараметров, ТаблицаИспользованныхПартий);
	
	ЗаполнитьДополнительныеДанные(СтруктураПараметров);
	
	РезультатВыполнения = Новый Структура();
	РезультатВыполнения.Вставить("ОстаткиВведены", Истина);
	РезультатВыполнения.Вставить("НДСУчтенныйВСтоимости", СтруктураПараметров.НДСУчтенныйВСтоимости);
	ПоместитьВоВременноеХранилище(СтруктураПараметров.НДСУчтенныйВСтоимости, АдресХранилища);
	
	РегистрыСведений.ВыполнениеРегламентныхОперацийНДС.ЗафиксироватьФактВыполненияРегламентнойОперации(
		Параметры.ДатаПерехода, Параметры.Организация, Документы.ВводНачальныхОстатков.ПустаяСсылка(), 
		Перечисления.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости, Истина);
	
КонецПроцедуры

// Создает документы ввод остатков
//
// Параметры:
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации
// - ДатаПерехода - Дата - Дата создания документа ввод остатков
// - Период - Дата - Период записи регистра сведений ВыполнениеРегламентныхОперацийНДС
// - НДСПоОстаткам - Таблица значений - Таблица с остатками, партиями, суммами НДС и статусами поиска данных
//  ЗаполненоАвтоматически - Булево - Для данных, дозаполнявшихся вручную - ложь
//
Процедура СозданиеДокументовВводаОстатков(Параметры, АдресХранилища = Неопределено) Экспорт
	
	Если Параметры.Свойство("АдресРезультата") Тогда 
		Параметры.Вставить("НДСПоОстаткам", ПолучитьИзВременногоХранилища(Параметры.АдресРезультата));
	КонецЕсли;
	
	ЗаполненоАвтоматически = Параметры.ЗаполненоАвтоматически;
	УсловияПоиска = Новый Структура("Статус", "Не подготовлен к вычету");
	
	Параметры.НДСПоОстаткам.Колонки.Добавить("МожноПринятьКВычету", Новый ОписаниеТипов("Булево"));
	Если ЗаполненоАвтоматически Тогда 
		УсловияПоиска.Вставить("Группа", "Можно");
		СтрокиНДСДоступныйДляЗаявления = Параметры.НДСПоОстаткам.НайтиСтроки(УсловияПоиска);
		Для Каждого СтрокаНДСДоступныйДляЗаявления Из СтрокиНДСДоступныйДляЗаявления Цикл
			СтрокаНДСДоступныйДляЗаявления.МожноПринятьКВычету = Истина;
		КонецЦикла;
	Иначе 
		УсловияПоиска.Вставить("Группа", "НеХватаетДанныхДляВычета");
		СтрокиНеХватаетДанныхДляВычета = Параметры.НДСПоОстаткам.НайтиСтроки(УсловияПоиска);
		СтрокиНДСДоступныйДляЗаявления = Новый Массив;
		Для Каждого СтрокаНеХватаетДанныхДляВычета Из СтрокиНеХватаетДанныхДляВычета Цикл 
			Если ЗначениеЗаполнено(СтрокаНеХватаетДанныхДляВычета.СчетФактураДатаВх)
				И ЗначениеЗаполнено(СтрокаНеХватаетДанныхДляВычета.СчетФактураНомерВх)
				И СтрокаНеХватаетДанныхДляВычета.СуммаНДС > 0 Тогда 
					СтрокаНеХватаетДанныхДляВычета.МожноПринятьКВычету = Истина;
					СтрокиНДСДоступныйДляЗаявления.Добавить(СтрокаНеХватаетДанныхДляВычета);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если СтрокиНДСДоступныйДляЗаявления.Количество() = 0 Тогда 
		Возврат
	КонецЕсли;
	
	Параметры.НДСПоОстаткам.Индексы.Добавить("Партия");
	Параметры.НДСПоОстаткам.Сортировать("Партия Возр");
	
	Параметры.Вставить("СтрокВсего", СтрокиНДСДоступныйДляЗаявления.Количество());
	СтрокОбработано = 0;
	
	Партии = Параметры.НДСПоОстаткам.Скопировать(СтрокиНДСДоступныйДляЗаявления, "Дата, Партия, ДоговорКонтрагента");
	Партии.Свернуть("Дата, Партия, ДоговорКонтрагента");
	СоответствиеКодовВидаОперации = ПолучитьСоответствиеКодовВидаОперации(Партии);
	
	СчетаСОстатками = Параметры.НДСПоОстаткам.Скопировать(СтрокиНДСДоступныйДляЗаявления, "СчетУчета, Подразделение");
	СчетаСОстатками.Свернуть("СчетУчета, Подразделение");
	СчетаСОстатками.Сортировать("СчетУчета Возр, Подразделение Возр");
	
	МаксКоличествоСтрок = 9000;
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	Валюта = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	
	ДлительныеОперации.СообщитьПрогресс(, НСтр("ru = 'Выполнено 0%'"));
	
	Для Каждого СтрСчет Из СчетаСОстатками Цикл
		СчетУчета = СтрСчет.СчетУчета;
		Подразделение = СтрСчет.Подразделение;
		УсловияПоиска.Очистить();
		УсловияПоиска.Вставить("МожноПринятьКВычету", Истина);
		УсловияПоиска.Вставить("СчетУчета", СчетУчета);
		УсловияПоиска.Вставить("Подразделение", Подразделение);
		
		СчетчикСтрок = 0;
		
		НДСДоступныйДляЗаявленияПоСчету = Параметры.НДСПоОстаткам.НайтиСтроки(УсловияПоиска);
		
		ВводОстатковОбъект = СоздатьВводОстатков(Параметры, СчетУчета, Подразделение, ТекущийПользователь);
		НДСПодготовленДляЗаявления = Новый Массив;
		
		Для Каждого СтрокаОстатков Из НДСДоступныйДляЗаявленияПоСчету Цикл 
			
			НДСПодготовленДляЗаявления.Добавить(СтрокаОстатков);
			Если СчетчикСтрок = МаксКоличествоСтрок Тогда 
				Параметры.Вставить("СтрокОбработано", СтрокОбработано);
				ЗаписатьВводОстатков(Параметры, ВводОстатковОбъект, СчетУчета, НДСПодготовленДляЗаявления);
				ВводОстатковОбъект = СоздатьВводОстатков(Параметры, СчетУчета, Подразделение, ТекущийПользователь);
				СчетчикСтрок = 0;
			КонецЕсли;
			
			НоваяСтрока = ВводОстатковОбъект.НДСУчтенныйВСтоимости.Добавить();
			
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОстатков);
			
			НоваяСтрока.ДатаПартии				 = СтрокаОстатков.Дата;
			НоваяСтрока.НДС						 = СтрокаОстатков.СуммаНДС;
			НоваяСтрока.СчетФактураДокумент 	 = СтрокаОстатков.СчетФактура;
			НоваяСтрока.ДатаСФ					 = СтрокаОстатков.СчетФактураДатаВх;
			НоваяСтрока.НомерСФ					 = СтрокаОстатков.СчетФактураНомерВх;
			НоваяСтрока.ПредъявленСФ			 = Истина;
			НоваяСтрока.Валюта					 = Валюта;
			НоваяСтрока.КодВидаОперации 		 = СоответствиеКодовВидаОперации.Получить(СтрокаОстатков.Партия);
			НоваяСтрока.ЗаполненоАвтоматически	 = ЗаполненоАвтоматически;
			
			СчетчикСтрок = СчетчикСтрок + 1;
			СтрокОбработано = СтрокОбработано + 1;
			
		КонецЦикла;
		Параметры.Вставить("СтрокОбработано", СтрокОбработано);
		ЗаписатьВводОстатков(Параметры, ВводОстатковОбъект, СчетУчета, НДСПодготовленДляЗаявления);
		
	КонецЦикла;
	
	СохранитьВХранилище(Параметры);
	
КонецПроцедуры

// Показывает, есть ли созданные документы ввода остатков по организации за квартал периода.
// Сохраняет данные табличных часте созданных документов в менеджер временных таблиц
//
// Параметры:
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации
// - ДатаПерехода - Дата
//  МВТ - МенеджерВременныхТаблиц
//
// Возвращаемое значение:
//  Булево
Функция ЕстьДокументыВводНачальныхОстатков(Параметры, МВТ = Неопределено) Экспорт
	
	Если МВТ = Неопределено Тогда 
		МВТ = Новый МенеджерВременныхТаблиц;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.СчетУчета КАК СчетУчета,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Номенклатура КАК Номенклатура,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Партия КАК Партия,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Склад КАК Склад,
	|	СУММА(ВводНачальныхОстатковНДСУчтенныйВСтоимости.Количество) КАК Количество,
	|	СУММА(ВводНачальныхОстатковНДСУчтенныйВСтоимости.НДС) КАК СуммаНДС
	|ПОМЕСТИТЬ ДокументыВводНачальныхОстатков
	|ИЗ
	|	Документ.ВводНачальныхОстатков КАК ВводНачальныхОстатков
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВыполнениеРегламентныхОперацийНДС КАК ВыполнениеРегламентныхОперацийНДС
	|		ПО ВводНачальныхОстатков.Ссылка = ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВводНачальныхОстатков.НДСУчтенныйВСтоимости КАК ВводНачальныхОстатковНДСУчтенныйВСтоимости
	|		ПО ВводНачальныхОстатков.Ссылка = ВводНачальныхОстатковНДСУчтенныйВСтоимости.Ссылка
	|ГДЕ
	|	ВводНачальныхОстатков.Проведен = ИСТИНА
	|	И ВводНачальныхОстатков.Организация = &Организация
	|	И ВводНачальныхОстатков.РазделУчета = ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляВводаОстатков.НДСУчтенныйВСтоимости)
	|	И ВыполнениеРегламентныхОперацийНДС.РегламентнаяОперация = ЗНАЧЕНИЕ(Перечисление.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости)
	|	И ВыполнениеРегламентныхОперацийНДС.ПериодРегистрации = &ДатаПерехода
	|
	|СГРУППИРОВАТЬ ПО
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.СчетУчета,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Склад,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Партия,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Номенклатура";
	
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	Запрос.УстановитьПараметр("ДатаПерехода", Параметры.ДатаПерехода);
	
	Результат = Запрос.Выполнить();
	
	Возврат МВТ.Таблицы[0].ПолучитьДанные().Выгрузить().Количество() > 0;
	
КонецФункции

// Находит данные по НДС, ранее подготовленному к вычету.
//
// Параметры:
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации
// - ДатаПерехода - Дата
//
// Возвращаемое значение:
//  СтруктураОтвет - Структура содержащая следующие поля:
// - НДСПодготовленыйКВычету - ОбходРезультатаЗапроса
// - СуммаНДСПодготовленыйКВычету - Число
// - ЕстьОтклонения - Булево
//
Функция НДСПодготовленыйКВычету(Параметры) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВводНачальныхОстатков.Ссылка КАК Ссылка,
	|	ВводНачальныхОстатков.ПодразделениеОрганизации КАК Подразделение
	|ПОМЕСТИТЬ ДокументыВводНачальныхОстатков
	|ИЗ
	|	РегистрСведений.ВыполнениеРегламентныхОперацийНДС КАК ВыполнениеРегламентныхОперацийНДС
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВводНачальныхОстатков КАК ВводНачальныхОстатков
	|		ПО (ВводНачальныхОстатков.Ссылка = ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент)
	|ГДЕ
	|	ВыполнениеРегламентныхОперацийНДС.Организация = &Организация
	|	И ВыполнениеРегламентныхОперацийНДС.ПериодРегистрации = &ДатаПерехода
	|	И ВыполнениеРегламентныхОперацийНДС.РегламентнаяОперация = ЗНАЧЕНИЕ(Перечисление.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости)
	|	И ВводНачальныхОстатков.Проведен = ИСТИНА
	|	И ВводНачальныхОстатков.РазделУчета = ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляВводаОстатков.НДСУчтенныйВСтоимости)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыВводНачальныхОстатков.Подразделение КАК Подразделение,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.СчетУчета КАК СчетУчета,
	|	ДокументыВводНачальныхОстатков.Ссылка КАК ВводОстатков,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Контрагент КАК Контрагент,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Партия КАК Партия,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.ДатаПартии КАК Дата,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Номенклатура КАК Номенклатура,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.Количество КАК Количество,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.СтавкаНДС КАК СтавкаНДС,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.НДС КАК СуммаНДС,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.СуммаБезНДС КАК СуммаБезНДС,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.НДС КАК РасчетныйНДС,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.СчетФактураДокумент КАК СчетФактура,
	|	ВводНачальныхОстатковНДСУчтенныйВСтоимости.СуммаБезНДС + ВводНачальныхОстатковНДСУчтенныйВСтоимости.НДС КАК Всего,
	|	""Подготовлен к вычету"" КАК Статус
	|ИЗ
	|	ДокументыВводНачальныхОстатков КАК ДокументыВводНачальныхОстатков
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВводНачальныхОстатков.НДСУчтенныйВСтоимости КАК ВводНачальныхОстатковНДСУчтенныйВСтоимости
	|		ПО ДокументыВводНачальныхОстатков.Ссылка = ВводНачальныхОстатковНДСУчтенныйВСтоимости.Ссылка";
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	Запрос.УстановитьПараметр("ДатаПерехода", Параметры.ДатаПерехода);
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат.Выгрузить();
	
	
КонецФункции

// Возвращает дату крайнего перехода на общую ставку НДС.
// Если перехода не было, возвращает пустую дату
//
// Параметры:
// - Организация - СправочникСсылка.Организации
// - Период - Дата
//
// Возвращаемое значение:
//  Дата
Функция ДатаПереходаНаУСНСВычетами(Организация, Период) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НастройкиУчетаНДССрезПоследних.Период КАК Период
	|ИЗ
	|	РегистрСведений.НастройкиУчетаНДС.СрезПоследних(
	|			&Период, 
	|			Организация = &Организация
	|				И СтавкаНалогообложенияПриУСН = ЗНАЧЕНИЕ(Перечисление.ВидыСтавокНДС.Общая)) КАК НастройкиУчетаНДССрезПоследних";
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда 
		Возврат '00010101';
	Иначе 
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Период;
	КонецЕсли;
	
КонецФункции

// Удаляет данные из хранилища и ранее созданные документы ввода остатков
//
// Параметры:
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации
// - ДатаПерехода - Дата
//
Процедура ОтменаРезультатаВыполнения(Параметры, АдресХранилища = Неопределено) Экспорт
	
	ОбщегоНазначенияБП.УдалитьДанныеИзХранилища(Параметры.Организация, КлючХранилища());
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент КАК Документ.ВводНачальныхОстатков) КАК Документ,
	|	ВЫРАЗИТЬ(ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент КАК Документ.ВводНачальныхОстатков).Проведен КАК Проведен
	|ИЗ
	|	РегистрСведений.ВыполнениеРегламентныхОперацийНДС КАК ВыполнениеРегламентныхОперацийНДС
	|ГДЕ
	|	ВыполнениеРегламентныхОперацийНДС.Организация = &Организация
	|	И ВыполнениеРегламентныхОперацийНДС.ПериодРегистрации = &ДатаПерехода
	|	И ВыполнениеРегламентныхОперацийНДС.РегламентнаяОперация = ЗНАЧЕНИЕ(Перечисление.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости)
	|	И ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент ССЫЛКА Документ.ВводНачальныхОстатков
	|	И НЕ ВЫРАЗИТЬ(ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент КАК Документ.ВводНачальныхОстатков).ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	Запрос.УстановитьПараметр("ДатаПерехода", Параметры.ДатаПерехода);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Попытка 
			ДокументОбъект = ВыборкаДетальныеЗаписи.Документ.ПолучитьОбъект();
			ДокументОбъект.ПометкаУдаления = Истина;
			Если ВыборкаДетальныеЗаписи.Проведен Тогда 
				ДокументОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			Иначе 
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
		Исключение
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ОписаниеОшибки();
			Сообщение.Сообщить();
		КонецПопытки;
	КонецЦикла;
	
	РегистрыСведений.ВыполнениеРегламентныхОперацийНДС.УдалитьФактВыполненияРегламентнойОперации(Параметры.ДатаПерехода, 
		Параметры.Организация, Неопределено, Перечисления.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости);
		
КонецПроцедуры

// Устанавливает свойства элементов формы
// 
// Параметры:
//  ЭлементыФормы - ЭлементыФормы - Все элементы формы
//  СписокТолькоОткрытие - Строка - Имена элементов формы разделенные запятыми
//  СписокТолькоПросмотр - Строка - Имена элементов формы разделенные запятыми
//
Процедура УстановитьСвойстваПолей(ЭлементыФормы, СписокТолькоОткрытие = "", СписокТолькоПросмотр = "") Экспорт
	
	Если СписокТолькоОткрытие <> "" Тогда 
		МассивЭлементов = МассивПоСтроке(СписокТолькоОткрытие);
		
		Для Каждого ИмяЭлементаФормы Из МассивЭлементов Цикл 
			ЭлементФормы = ЭлементыФормы.Найти(ИмяЭлементаФормы);
			Если ЭлементФормы <> Неопределено Тогда
				ЭлементФормы.КнопкаВыпадающегоСписка	 = Ложь;
				ЭлементФормы.КнопкаВыбора				 = Ложь;
				ЭлементФормы.КнопкаСоздания				 = Ложь;
				ЭлементФормы.РедактированиеТекста		 = Ложь;
				ЭлементФормы.БыстрыйВыбор				 = Ложь;
				ЭлементФормы.ИсторияВыбораПриВводе		 = ИсторияВыбораПриВводе.НеИспользовать;
			КонецЕсли;
		КонецЦикла; 
		
	КонецЕсли;
	
	Если СписокТолькоПросмотр <> "" Тогда 

		МассивЭлементов = МассивПоСтроке(СписокТолькоПросмотр);
		Для Каждого ИмяЭлементаФормы Из МассивЭлементов Цикл 
			ЭлементФормы = ЭлементыФормы.Найти(ИмяЭлементаФормы);
			Если ЭлементФормы <> Неопределено Тогда
				ЭлементФормы.ТолькоПросмотр = Истина;
			КонецЕсли;
		КонецЦикла; 
		
	КонецЕсли;
	
КонецПроцедуры

// Рассчитывает возможность автоматического расчета НДС при наличии остатков на дату перехода на уплату НДС по общей ставке
// Если есть остатки и ни разу не была запущена подготовка НДС к вычету или отчетность формируется за период перехода, вернется ИСТИНА.
//
// Параметры:
// - Организация - СправочникСсылка.Организации
// - Период - Дата - Текущий период. Дата перехода рассчитывается автоматически
//
// Возвращаемое значение:
//  Булево
//
Функция НеобходимЗапускПомощника(Организация, Период) Экспорт
	
	Если НЕ ОстаткиПоСчетам(Новый Структура("Организация, Период", Организация, Период)).ЕстьОстатки Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	ДатаПерехода = ДатаПереходаНаУСНСВычетами(Организация, Период);
	
	Если ДатаПерехода = НачалоКвартала(Период) Тогда 
		
		Возврат Истина;
		
	ИначеЕсли ДатаПерехода = '00010101' Тогда
		
		Возврат Ложь;
		
	Иначе 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИСТИНА КАК Поле1
		|ИЗ
		|	РегистрСведений.ВыполнениеРегламентныхОперацийНДС КАК ВыполнениеРегламентныхОперацийНДС
		|ГДЕ
		|	ВыполнениеРегламентныхОперацийНДС.Организация = &Организация
		|	И ВыполнениеРегламентныхОперацийНДС.ПериодРегистрации = &ДатаПерехода
		|	И ВыполнениеРегламентныхОперацийНДС.Актуальность
		|	И ВыполнениеРегламентныхОперацийНДС.РегламентнаяОперация = ЗНАЧЕНИЕ(Перечисление.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости)";
		Запрос.УстановитьПараметр("ДатаПерехода", ДатаПерехода);
		Запрос.УстановитьПараметр("Организация", Организация);
		Результат = Запрос.Выполнить();
		Возврат Запрос.Выполнить().Пустой();
		
	КонецЕсли;

КонецФункции

// Все счета, по остаткам которых можно подготовить НДС к вычету
//
// Возвращаемое значение:
//  СчетаПоиска - Массив
//
Функция СписокСчетовПоиска() Экспорт
	
	СчетаПоиска = Новый Массив;
	СтруктураПараметров = Новый Структура;
	
	Для Каждого НаборСчетов Из СчетаУчета() Цикл 
		СтруктураПараметров.Вставить(НаборСчетов.Ключ,НаборСчетов.Значение);
	КонецЦикла;
	
	Для Каждого ЭлементСтруктуры Из СтруктураПараметров Цикл 
		Если ТипЗнч(ЭлементСтруктуры.Значение) = Тип("Массив") Тогда 
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаПоиска, ЭлементСтруктуры.Значение);
		Иначе 
			СчетаПоиска.Добавить(ЭлементСтруктуры.Значение);
		КонецЕсли;
	КонецЦикла;
	Возврат СчетаПоиска
	
КонецФункции

#Область РаботаСХранилищем

// Сохраняет в регистр сведений Хранилище данных таблицу НДСПоОстаткам
//
// Параметры:
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации  
// - НачалоПериода - Дата
// - КонецПериода - Дата
// - ДатаПерехода - Дата
// - НДСПоОстаткам - Таблица значений
//
Процедура СохранитьВХранилище(Параметры) Экспорт
	
	СохраненныеДанные = Новый Структура;
	СохраненныеДанные.Вставить("КонтрольнаяСумма", КонтрольнаяСуммаПоДокументам(Параметры));
	СохраненныеДанные.Вставить("НДСПоОстаткам", Параметры.НДСПоОстаткам);
	СохраненныеДанные.Вставить("ДатаПерехода", Параметры.ДатаПерехода);
	
	ОбщегоНазначенияБП.ЗаписатьДанныеВХранилище(Параметры.Организация, СохраненныеДанные, КлючХранилища());
	
КонецПроцедуры

// Получает из регистра сведений Хранилище данных таблицу НДСПоОстаткам
//
// Параметры:
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации  
// - ДатаПерехода - Дата
//
// Возвращаемое значение:
//  Структура, Неопределено
//
Функция ПолучитьСохраненныеДнные(Организация, ДатаПерехода) Экспорт
	
	СохраненныеДанные = ОбщегоНазначенияБП.ПрочитатьДанныеИзХранилища(Организация, КлючХранилища());
	Если СохраненныеДанные <> Неопределено И СохраненныеДанные.ДатаПерехода = ДатаПерехода Тогда
		Возврат СохраненныеДанные; 
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

// Получает из регистра сведений Хранилище данных таблицу НДСПоОстаткам 
// и проверяет, менялись ли документы остатков
//
// Параметры:
//  Параметры - Структура содержащая следующие поля:
// - Организация - СправочникСсылка.Организации  
// - НачалоПериода - Дата
// - КонецПериода - Дата
// - ДатаПерехода - Дата
//  АдресХранилища - УникальныйИдентификатор, Строка
//
// Возвращаемое значение:
//  Структура, Неопределено
//
Функция ПроверкаНаличияСохраненныхДанных(Параметры, АдресХранилища) Экспорт
	
	СохраненныеДанные = ПолучитьСохраненныеДнные(Параметры.Организация, Параметры.ДатаПерехода);
	
	Если СохраненныеДанные <> Неопределено И СохраненныеДанные.Свойство("КонтрольнаяСумма") Тогда 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВыполнениеРегламентныхОперацийНДС.РегламентныйДокумент КАК Документ
		|ИЗ
		|	РегистрСведений.ВыполнениеРегламентныхОперацийНДС КАК ВыполнениеРегламентныхОперацийНДС
		|ГДЕ
		|	ВыполнениеРегламентныхОперацийНДС.Организация = &Организация
		|	И ВыполнениеРегламентныхОперацийНДС.РегламентнаяОперация = ЗНАЧЕНИЕ(Перечисление.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости)
		|	И ВыполнениеРегламентныхОперацийНДС.ПериодРегистрации = &ДатаПерехода";
		Запрос.УстановитьПараметр("Организация", Параметры.Организация);
		Запрос.УстановитьПараметр("ДатаПерехода", Параметры.ДатаПерехода);
		Если Не Запрос.Выполнить().Пустой() Тогда 
			КонтрольнаяСумма = КонтрольнаяСуммаПоДокументам(Параметры);
			Если СохраненныеДанные.КонтрольнаяСумма = КонтрольнаяСумма Тогда
				СохраненныеДанные.Вставить("МенялисьДокументы", Ложь);
			Иначе 
				СохраненныеДанные.Вставить("МенялисьДокументы", Истина);
			КонецЕсли;
		Иначе 
			СохраненныеДанные = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(СохраненныеДанные, АдресХранилища);
	
КонецФункции

// При наличии сохраненных данных в регистре сведений Хранилище данных
// загружает их в табличную часть формы НДСПоОстаткам 
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//
Процедура ЗагрузитьСхраненныеДанные(Форма) Экспорт
	
	СохраненныеДанные = ПолучитьСохраненныеДнные(Форма.Организация, Форма.ДатаПерехода);
	Если СохраненныеДанные <> Неопределено И СохраненныеДанные.Свойство("НДСПоОстаткам") Тогда 
		
		СтрокиПодготовлен = СохраненныеДанные.НДСПоОстаткам.НайтиСтроки(Новый Структура("Группа", "Подготовлен"));
		Для Каждого СтрокаПодготовлен Из СтрокиПодготовлен Цикл 
			СохраненныеДанные.НДСПоОстаткам.Удалить(СтрокаПодготовлен);
		КонецЦикла;
		Форма.НДСПоОстаткам.Загрузить(СохраненныеДанные.НДСПоОстаткам);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОстаткиПоСчетам(Параметры)
	
	СтруктураОтвет = Новый Структура;
	СтруктураОтвет.Вставить("ОстаткиПоСчетамКапВложенийКоличество", 0);
	СтруктураОтвет.Вставить("ОстаткиПоСчетамКапВложенийСумма", 0);
	СтруктураОтвет.Вставить("ОстаткиПоСчетамУчетаТоваровКоличество", 0);
	СтруктураОтвет.Вставить("ОстаткиПоСчетамУчетаТоваровСумма", 0);
	СтруктураОтвет.Вставить("ЕстьОстатки", Ложь);
	
	СтруктураПараметров = ПараметрыВыполненияЗапроса(Параметры);
	ОстаткиПоСчетамКапВложений = ОстаткиПоСчетамКапВложений(СтруктураПараметров).Выгрузить();
	ОстаткиПоСчетамУчетаТоваров = ОстаткиПоСчетамУчетаТоваров(СтруктураПараметров).Выгрузить();
	
	СтруктураОтвет.Вставить("ОстаткиПоСчетамКапВложенийКоличество", ОстаткиПоСчетамКапВложений.Итог("Количество"));
	СтруктураОтвет.Вставить("ОстаткиПоСчетамКапВложенийСумма", ОстаткиПоСчетамКапВложений.Итог("Сумма"));
	СтруктураОтвет.Вставить("ОстаткиПоСчетамУчетаТоваровКоличество", ОстаткиПоСчетамУчетаТоваров.Итог("Количество"));
	СтруктураОтвет.Вставить("ОстаткиПоСчетамУчетаТоваровСумма", ОстаткиПоСчетамУчетаТоваров.Итог("Сумма"));
	СтруктураОтвет.Вставить("ЕстьОстатки", 
		(СтруктураОтвет.ОстаткиПоСчетамКапВложенийКоличество + СтруктураОтвет.ОстаткиПоСчетамУчетаТоваровКоличество) > 0);
	
	Возврат СтруктураОтвет;
	
КонецФункции

Процедура СообщитьПрогресс(ПредставлениеПрогресса, ПроцентВыполнения)
	
