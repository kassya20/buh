Процедура ЗаполнитьДополнительныеДанные(Параметры)
	
	НДСУчтенныйВСтоимости = Параметры.НДСУчтенныйВСтоимости;
	Если НДСУчтенныйВСтоимости.Количество() = 0 Тогда 
		Возврат
	КонецЕсли;
	
	ДополнительныеДанные	 = ДополнительныеДанные(Параметры);
	СчетаФактуры			 = ДополнительныеДанные[3].Выгрузить();
	НДСВРасходеУСН			 = ДополнительныеДанные[5].Выгрузить();
	СтатьиЗатратОбъектовСтроительства = ДополнительныеДанные[6].Выгрузить();
	
	ПараметрыОтбора = Новый Структура("Партия");
	Для Каждого ПартияСНДСВРасходеУСН Из НДСВРасходеУСН Цикл 
		ЗаполнитьЗначенияСвойств(ПараметрыОтбора, ПартияСНДСВРасходеУСН);
		СтрокиОстатков = НДСУчтенныйВСтоимости.НайтиСтроки(ПараметрыОтбора);
		Для Каждого СтрокаОстатки Из СтрокиОстатков Цикл 
			СтрокаОстатки.Группа = "Нельзя";
			СтрокаОстатки.Статус = "Заявлен как расход УСН";
		КонецЦикла;
	КонецЦикла;

	ПараметрыОтбора = Новый Структура("Партия, Номенклатура");
	Для Каждого СтатьяЗатратОбъектовСтроительства Из СтатьиЗатратОбъектовСтроительства Цикл 
		ЗаполнитьЗначенияСвойств(ПараметрыОтбора, СтатьяЗатратОбъектовСтроительства);
		СтрокиОстатков = НДСУчтенныйВСтоимости.НайтиСтроки(ПараметрыОтбора);
		Для Каждого СтрокаОстатки Из СтрокиОстатков Цикл 
			СтрокаОстатки.СтатьяЗатрат = СтатьяЗатратОбъектовСтроительства.СтатьяЗатрат;
		КонецЦикла;
	КонецЦикла;
	
	МассивТиповДляВозврата = УчетНДСПоОстаткам.ТипыДляВозмещенияНДС();
	
	Для Каждого СтрокаОстатки Из НДСУчтенныйВСтоимости Цикл
		
		СтруктураОтбораПартий = Новый Структура;
		СтруктураОтбораПартий.Вставить("Партия", СтрокаОстатки.Партия);
		СчетаФактурыПоПартии = СчетаФактуры.НайтиСтроки(СтруктураОтбораПартий);
		Если СчетаФактурыПоПартии.Количество() > 0 Тогда 
			СчетФактураПоПартии = СчетаФактурыПоПартии[0];
			СписокПолей = "СчетФактура, СчетФактураДатаВх, СчетФактураНомерВх";
			ЗаполнитьЗначенияСвойств(СтрокаОстатки, СчетФактураПоПартии, СписокПолей);
		КонецЕсли; 
		
		СтрокаОстатки.РасчетныйНДС = Окр(УчетНДСКлиентСервер.РассчитатьСуммуНДС(СтрокаОстатки.Всего, Истина, 
		УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(Параметры.СтавкаНДС)), 2);
		
		Если ЗначениеЗаполнено(СтрокаОстатки.Группа) И ЗначениеЗаполнено(СтрокаОстатки.Статус) Тогда 
			Продолжить;
		ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаОстатки.Партия) Тогда 
			СтрокаОстатки.Группа = "Нельзя";
			СтрокаОстатки.Статус = "Не найдена партия";
		ИначеЕсли ТипЗнч(СтрокаОстатки.Партия) = Тип("ДокументСсылка.ВозвратТоваровОтПокупателя") Тогда 
			СтрокаОстатки.Группа = "Нельзя";
			СтрокаОстатки.Статус = "По возвратам товаров вычет НДС производится по корректировочному счету-фактуре";
		ИначеЕсли НЕ МассивТиповДляВозврата.СодержитТип(ТипЗнч(СтрокаОстатки.Партия)) Тогда
			СтрокаОстатки.Группа = "Нельзя";
			СтрокаОстатки.Статус = "Для остатков с партиями данного типа не предусмотрен рассчет вычета НДС";
		ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаОстатки.Дата) Тогда
			СтрокаОстатки.Группа = "Нельзя";
			СтрокаОстатки.Статус = "У партии не заполнена дата";
		ИначеЕсли СтрокаОстатки.Дата < Параметры.ДатаНачала Тогда
			СтрокаОстатки.Группа = "Нельзя";
			СтрокаОстатки.Статус = "Истек срок заявления вычета";
		ИначеЕсли СтрокаОстатки.СуммаНДС = 0 Тогда
			СтрокаОстатки.Группа = "НеХватаетДанныхДляВычета";
			СтрокаОстатки.Статус = "Не подготовлен к вычету"
		ИначеЕсли СтрокаОстатки.СуммаНДС = СтрокаОстатки.УчтенныйНДС Тогда
			СтрокаОстатки.Группа = "УжеГотов";
			СтрокаОстатки.Статус = "Уже заявлен к вычету";
			СтрокаОстатки.УчтенныйНДС = СтрокаОстатки.СуммаНДС;
		ИначеЕсли ЗначениеЗаполнено(СтрокаОстатки.СчетФактура) Тогда 
			СтрокаОстатки.Группа = "Можно";
			СтрокаОстатки.Статус = "Не подготовлен к вычету"
		Иначе 
			СтрокаОстатки.Группа = "НеХватаетДанныхДляВычета";
			СтрокаОстатки.Статус = "Не подготовлен к вычету"
		КонецЕсли; 
		
	КонецЦикла;
	
КонецПроцедуры

Процедура РаспределитьСуммыПоПартиям(ПараметрыДляВводаОстатков, СтруктураПараметров, ЭтоТовары)
	ТаблицаОстатков			 = ПараметрыДляВводаОстатков.ТаблицаОстатков;
	ТаблицаКомплектующих	 = ПараметрыДляВводаОстатков.ТаблицаКомплектующих;
	АВКакДопРасходы			 = ПараметрыДляВводаОстатков.АВКакДопРасходы;
	СуммыДопРасходов		 = ПараметрыДляВводаОстатков.СуммыДопРасходов;
	СуммыПоПоступлениям		 = ПараметрыДляВводаОстатков.СуммыПоПоступлениям;
	Корректировки			 = ПараметрыДляВводаОстатков.Корректировки;
	НДСУчтенныйВСтоимости	 = ИнициализироватьНДСУчтенногоВСтоимости();
	
	ПараметрыДляЗаполненияСтрокиПоПартии = ПараметрыДляЗаполненияСтрокиПоПартии();
	ПараметрыДляЗаполненияСтрокиПоПартии.СчетНДСПоУмолчанию = СтруктураПараметров.СчетНДСПоУмолчанию;
	СчетаПередачи = СтруктураПараметров.СчетаПередачи;
	
	СубконтоСклад = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады;
	СубконтоПартия = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Партии;
	
	Для Каждого СтрокаСАналитикой Из ТаблицаОстатков Цикл
		ЭтоКомплектация = Ложь;
		Если ЭтоТовары Тогда
			ЭтоКомплектация = СтрокаСАналитикой.ЭтоКомплектация;
		Иначе
			ЭтоКомплектация = СтрокаСАналитикой.НуженДопПоиск;
		КонецЕсли;
		
		Если СчетаПередачи.Найти(СтрокаСАналитикой.Счет) = Неопределено Тогда 
			ЭтоСчетПередачи = Ложь;
		Иначе 
			ЭтоСчетПередачи = Истина;
		КонецЕсли;
		
		Если ЭтоКомплектация Тогда
			ОтборПоКом = Новый Структура;
			ОтборПоКом.Вставить("ИД", СтрокаСАналитикой.ИД);
			ИнфоПоКомплектующим = ТаблицаКомплектующих.НайтиСтроки(ОтборПоКом);
			Для Каждого Комплектующая Из ИнфоПоКомплектующим Цикл
				Если Комплектующая.ИскатьСуммуНДС Тогда
					
					СтруктураОтбораПоПартии = Новый Структура;
					СтруктураОтбораПоПартии.Вставить("Номенклатура", Комплектующая.Номенклатура);
					СтруктураОтбораПоПартии.Вставить("ДокументПоступления", Комплектующая.Партия);
					КонтрольноеКоличество = Комплектующая.Количество;
					
					ПараметрыДляЗаполненияСтрокиПоПартии.СчетУчета = Комплектующая.СчетУчета;
					ПараметрыДляЗаполненияСтрокиПоПартии.ЭтоКомплектация = Истина;
					ПараметрыДляЗаполненияСтрокиПоПартии.СуммовойУчет = Ложь;
					
					ЗаполнитьСтрокуПоПартии(СтрокаСАналитикой, СтруктураОтбораПоПартии, НДСУчтенныйВСтоимости, СуммыПоПоступлениям,
						ПараметрыДляЗаполненияСтрокиПоПартии, КонтрольноеКоличество, ЭтоСчетПередачи);
					
					// Добавить суммы из документов ГТД, Доп. расходы, Заявление о ввозе товаров
					СтруктураОтбораДопРасходов = Новый Структура;
					СтруктураОтбораДопРасходов.Вставить("Номенклатура", СтрокаСАналитикой.Номенклатура);
					СтруктураОтбораДопРасходов.Вставить("ДокументПоступления", СтрокаСАналитикой.Партия); 
					КонтрольноеКоличество = Комплектующая.Количество; 
					ЗаполнитьСтрокуПоДопРасходам(СтрокаСАналитикой, СтруктураОтбораДопРасходов, КонтрольноеКоличество,
						НДСУчтенныйВСтоимости, СуммыДопРасходов, ЭтоСчетПередачи, СтрокаСАналитикой.Счет); 
					
				КонецЕсли;
			КонецЦикла;
		Иначе
			Если НЕ СтрокаСАналитикой.ИскатьСуммуНДС И НЕ СтрокаСАналитикой.ИскатьДопРасходы И ЭтоТовары Тогда
				Продолжить;
			ИначеЕсли НЕ СтрокаСАналитикой.ИскатьСуммуНДС И СтрокаСАналитикой.ИскатьДопРасходы И ЭтоТовары Тогда
				
				СтруктураОтбораДопРасходов = Новый Структура;
				СтруктураОтбораДопРасходов.Вставить("Номенклатура", СтрокаСАналитикой.Номенклатура);
				СтруктураОтбораДопРасходов.Вставить("ДокументПоступления", СтрокаСАналитикой.Партия);
				КонтрольноеКоличество = СтрокаСАналитикой.Количество; 
				ЗаполнитьСтрокуПоДопРасходам(СтрокаСАналитикой, СтруктураОтбораДопРасходов, КонтрольноеКоличество,
					НДСУчтенныйВСтоимости, СуммыДопРасходов, ЭтоСчетПередачи, СтрокаСАналитикой.Счет);
					
			Иначе
				// Заполним исходные суммы из документов поступлений:
				// Авансовый отчет, возврат и ПТУ
				СтруктураОтбораПоПартии = Новый Структура;
				СтруктураОтбораПоПартии.Вставить("Номенклатура", СтрокаСАналитикой.Номенклатура);
				Корректировка = Корректировки.Найти(СтрокаСАналитикой.Партия, "Партия");
				Если Корректировка <> Неопределено Тогда 
					СтруктураОтбораПоПартии.Вставить("ДокументПоступления", Корректировка.ИсправляемыйДокументПоступления);
				Иначе 
					СтруктураОтбораПоПартии.Вставить("ДокументПоступления", СтрокаСАналитикой.Партия);
				КонецЕсли;
			
				КонтрольноеКоличество = СтрокаСАналитикой.Количество;
				
				ПараметрыДляЗаполненияСтрокиПоПартии.СчетУчета = СтрокаСАналитикой.Счет;
				ПараметрыДляЗаполненияСтрокиПоПартии.ЭтоКомплектация = Ложь;
				Если ЭтоТовары Тогда
					ПараметрыДляЗаполненияСтрокиПоПартии.СуммовойУчет = Ложь;
				Иначе
					ПараметрыДляЗаполненияСтрокиПоПартии.СуммовойУчет = Не СтрокаСАналитикой.КоличественныйУчет;	
				КонецЕсли;
				
				ЗаполнитьСтрокуПоПартии(СтрокаСАналитикой, СтруктураОтбораПоПартии, НДСУчтенныйВСтоимости, СуммыПоПоступлениям,
				ПараметрыДляЗаполненияСтрокиПоПартии, КонтрольноеКоличество, ЭтоСчетПередачи);
				
				// Суммы из документов ГТД, Доп. расходы, Заявление о ввозе товаров
				СтруктураОтбораДопРасходов = Новый Структура;
				СтруктураОтбораДопРасходов.Вставить("Номенклатура", СтрокаСАналитикой.Номенклатура);
				СтруктураОтбораДопРасходов.Вставить("ДокументПоступления", СтрокаСАналитикой.Партия);
				КонтрольноеКоличество = СтрокаСАналитикой.Количество; 
				ЗаполнитьСтрокуПоДопРасходам(СтрокаСАналитикой, СтруктураОтбораДопРасходов, КонтрольноеКоличество,
					НДСУчтенныйВСтоимости, СуммыДопРасходов, ЭтоСчетПередачи, СтрокаСАналитикой.Счет);
					
				Если НЕ ЭтоТовары Тогда
					
					СвойстваСчета = БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(СтрокаСАналитикой.Счет);
					СтруктураОтбораПоПартии = Новый Структура;
					СтруктураОтбораПоПартии.Вставить("Номенклатура", СтрокаСАналитикой.Номенклатура);
					СтруктураОтбораПоПартии.Вставить("ДокАвансовыйОтчет", СтрокаСАналитикой.Партия);
					СтруктураОтбораПоПартии.Вставить("СчетУчета", СтрокаСАналитикой.Счет);
					Если СвойстваСчета["ВидСубконто2"] = СубконтоСклад Тогда
						СтруктураОтбораПоПартии.Вставить("Субконто2", СтрокаСАналитикой.Склад);
					ИначеЕсли СвойстваСчета["ВидСубконто3"] = СубконтоСклад Тогда
						СтруктураОтбораПоПартии.Вставить("Субконто3", СтрокаСАналитикой.Склад);
					КонецЕсли;
					КонтрольноеКоличество = 0;
					ЗаполнитьСтрокуПоДопРасходам(СтрокаСАналитикой, СтруктураОтбораПоПартии, КонтрольноеКоличество,
						НДСУчтенныйВСтоимости, АВКакДопРасходы, ЭтоСчетПередачи, СтрокаСАналитикой.Счет);
					
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	КолонкиГруппировок = Новый Массив;
	Для Каждого Колонка Из НДСУчтенныйВСтоимости.Колонки Цикл
		КолонкиГруппировок.Добавить(Колонка.Имя);
	КонецЦикла;
	
	КолонкиСуммирования = Новый Массив;
	КолонкиСуммирования.Добавить("Количество");
	КолонкиСуммирования.Добавить("СуммаБезНДС");
	КолонкиСуммирования.Добавить("СуммаНДС");
	КолонкиСуммирования.Добавить("Всего");
	КолонкиСуммирования.Добавить("УчтенныйНДС");
	КолонкиСуммирования.Добавить("РасчетныйНДС");
	
	Для Каждого КолонкаСуммирования Из КолонкиСуммирования Цикл 
		КолонкаГруппировки = КолонкиГруппировок.Найти(КолонкаСуммирования);
		Если КолонкаГруппировки <> Неопределено Тогда 
			КолонкиГруппировок.Удалить(КолонкаГруппировки);
		КонецЕсли;
	КонецЦикла;
	
	НДСУчтенныйВСтоимости.Свернуть(СтрСоединить(КолонкиГруппировок, ", "),СтрСоединить(КолонкиСуммирования, ", "));
	
	Для Каждого Строка Из НДСУчтенныйВСтоимости Цикл
		Если НЕ ЗначениеЗаполнено(Строка.ВидЦенности) Тогда 
			Строка.ВидЦенности = УчетНДС.ОпределитьВидЦенности(Строка.СчетУчета);
		КонецЕсли;
	КонецЦикла;
	
	НДСУчтенныйВСтоимости.ЗаполнитьЗначения(Документы.СчетФактураПолученный.ПустаяСсылка(),"СчетФактура");
	Если СтруктураПараметров.Свойство("НДСУчтенныйВСтоимости") Тогда 
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НДСУчтенныйВСтоимости,СтруктураПараметров.НДСУчтенныйВСтоимости);
	Иначе 
		СтруктураПараметров.Вставить("НДСУчтенныйВСтоимости",НДСУчтенныйВСтоимости);
	КонецЕсли;
	
КонецПроцедуры 

Функция ПараметрыДляЗаполненияСтрокиПоПартии()
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Ключ");
	СтруктураПараметров.Вставить("СчетУчета");
	СтруктураПараметров.Вставить("СчетНДСПоУмолчанию");
	СтруктураПараметров.Вставить("ЭтоКомплектация");
	СтруктураПараметров.Вставить("СуммовойУчет", Ложь);
	
	Возврат СтруктураПараметров;
	
КонецФункции

Функция ДополнительныеДанные(Параметры)
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НДСУчтенныйВСтоимости.Партия КАК Партия,
	|	НДСУчтенныйВСтоимости.ДокументПоступления КАК ДокументПоступления,
	|	НДСУчтенныйВСтоимости.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ НДСУчтенныйВСтоимости
	|ИЗ
	|	&ТаблицаНДСУчтенныйВСтоимости КАК НДСУчтенныйВСтоимости
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НДСУчтенныйВСтоимости.Партия КАК Партия,
	|	НДСУчтенныйВСтоимости.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА НДСУчтенныйВСтоимости.Партия ССЫЛКА Документ.КорректировкаПоступления
	|			ТОГДА НДСУчтенныйВСтоимости.ДокументПоступления
	|		ИНАЧЕ НДСУчтенныйВСтоимости.Партия
	|	КОНЕЦ КАК ДокументПоступления
	|ПОМЕСТИТЬ ПартииИНоменклатура
	|ИЗ
	|	НДСУчтенныйВСтоимости КАК НДСУчтенныйВСтоимости
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПартииИНоменклатура.Партия КАК Партия,
	|	ПартииИНоменклатура.ДокументПоступления КАК ДокументПоступления
	|ПОМЕСТИТЬ Партии
	|ИЗ
	|	ПартииИНоменклатура КАК ПартииИНоменклатура
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументПоступления,
	|	Партия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Партии.Партия КАК Партия,
	|	СчетФактураПолученныйДокументыОснования.Ссылка КАК СчетФактура,
	|	СчетФактураПолученныйДокументыОснования.Ссылка.НомерВходящегоДокумента КАК СчетФактураНомерВх,
	|	СчетФактураПолученныйДокументыОснования.Ссылка.ДатаВходящегоДокумента КАК СчетФактураДатаВх,
	|	СчетФактураПолученныйДокументыОснования.Ссылка.МоментВремени КАК МоментВремени
	|ИЗ
	|	Партии КАК Партии
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученный.ДокументыОснования КАК СчетФактураПолученныйДокументыОснования
	|		ПО Партии.Партия = СчетФактураПолученныйДокументыОснования.ДокументОснование
	|ГДЕ
	|	НЕ СчетФактураПолученныйДокументыОснования.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Партии.Партия,
	|	СчетФактураВыданныйДокументыОснования.Ссылка,
	|	СчетФактураВыданныйДокументыОснования.Ссылка.Номер,
	|	СчетФактураВыданныйДокументыОснования.Ссылка.Дата,
	|	СчетФактураВыданныйДокументыОснования.Ссылка.МоментВремени
	|ИЗ
	|	Партии КАК Партии
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураВыданныйДокументыОснования
	|		ПО Партии.Партия = СчетФактураВыданныйДокументыОснования.ДокументОснование
	|ГДЕ
	|	НЕ СчетФактураВыданныйДокументыОснования.Ссылка.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	МоментВремени УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	РасходыПриУСН.Регистратор КАК Регистратор,
	|	Партии.Партия КАК Партия
	|ПОМЕСТИТЬ ПартииВРасходахПриУСН
	|ИЗ
	|	Партии КАК Партии
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РасходыПриУСН КАК РасходыПриУСН
	|		ПО Партии.ДокументПоступления = РасходыПриУСН.РасчетныйДокумент
	|ГДЕ
	|	РасходыПриУСН.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	И РасходыПриУСН.СтатусыОплатыРасходовУСН В (ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеОплачено), ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеСписаноНеОплачено), ЗНАЧЕНИЕ(Перечисление.СтатусыРасходовУСН.НеОплаченоНеОплаченоПокупателем))
	|	И РасходыПриУСН.ВидРасхода В (ЗНАЧЕНИЕ(Перечисление.ВидыРасходовУСН.Номенклатура), ЗНАЧЕНИЕ(Перечисление.ВидыРасходовУСН.ДопРасходы))
	|	И РасходыПриУСН.ОтражениеВУСН = ЗНАЧЕНИЕ(Перечисление.ОтражениеВУСН.Принимаются)
	|	И РасходыПриУСН.Количество <> 0
	|	И НЕ РасходыПриУСН.Регистратор ССЫЛКА Документ.ОтчетОРозничныхПродажах
	|	И РасходыПриУСН.Период <= &ГраницаОстатков
	|	И РасходыПриУСН.СчетУчета В(&СчетаМатериалов)
	|
	|СГРУППИРОВАТЬ ПО
	|	РасходыПриУСН.Регистратор,
	|	Партии.Партия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПартииВРасходахПриУСН.Партия КАК Партия
	|ИЗ
	|	ПартииВРасходахПриУСН КАК ПартииВРасходахПриУСН
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РасшифровкаКУДиР КАК РасшифровкаКУДиР
	|		ПО ПартииВРасходахПриУСН.Регистратор = РасшифровкаКУДиР.Регистратор
	|ГДЕ
	|	РасшифровкаКУДиР.ВидРасхода В (ЗНАЧЕНИЕ(Перечисление.ВидыРасходовУСН.НДС), ЗНАЧЕНИЕ(Перечисление.ВидыРасходовУСН.Номенклатура), ЗНАЧЕНИЕ(Перечисление.ВидыРасходовУСН.ДопРасходы))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПартииИНоменклатура.Партия КАК Партия,
	|	ПартииИНоменклатура.Номенклатура КАК Номенклатура,
	|	ПоступлениеТоваровУслугОбъектыСтроительства.СтатьяЗатрат КАК СтатьяЗатрат
	|ИЗ
	|	ПартииИНоменклатура КАК ПартииИНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.ОбъектыСтроительства КАК ПоступлениеТоваровУслугОбъектыСтроительства
	|		ПО ПартииИНоменклатура.Партия = ПоступлениеТоваровУслугОбъектыСтроительства.Ссылка
	|			И ПартииИНоменклатура.Номенклатура = ПоступлениеТоваровУслугОбъектыСтроительства.ОбъектСтроительства
	|ГДЕ
	|	НЕ ПоступлениеТоваровУслугОбъектыСтроительства.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Организация", 					Параметры.Организация);
	Запрос.УстановитьПараметр("ГраницаОстатков", 				Параметры.Период);
	Запрос.УстановитьПараметр("СчетаМатериалов", 				Параметры.СчетаМатериалов);
	Запрос.УстановитьПараметр("ТаблицаНДСУчтенныйВСтоимости", 	Параметры.НДСУчтенныйВСтоимости);
	Запрос.УстановитьПараметр("НДСПоПриобретеннымЦенностям", 	Перечисления.ВидыРасходовУСН.НДС);
	Запрос.УстановитьПараметр("НДСУчтенныйВСтоимости", 			Перечисления.РазделыУчетаДляВводаОстатков.НДСУчтенныйВСтоимости);
	
	Результат = Запрос.ВыполнитьПакет();
	Возврат Результат;
	
КонецФункции

Функция ОстаткиИДвиженияПоСчетамКапВложений(СтруктураПараметров)
	
	ТекстЗапроса = УчетНДСПоОстаткам.ТекстЗапросаПоСчетамКапвложений();
	Для Каждого ЗаменаТекста Из СтруктураПараметров.ЗаменаТекстаВЗапросеКапВложений Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&" + ЗаменаТекста.Ключ, ЗаменаТекста.Значение);
	КонецЦикла;
	
	Запрос = Новый Запрос(); 
	Запрос.Текст = ТекстЗапроса; 
	ЗаполнитьПараметрыЗапроса(Запрос, СтруктураПараметров);
	Результат = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	Возврат Результат;
	
КонецФункции

Функция ОстаткиИДвиженияПоСчетамУчетаТоваров(СтруктураПараметров, ТаблицаИспользованныхПартий)
	
	ТекстЗапроса = УчетНДСПоОстаткам.ТестЗапросаОстаткиИДвиженияПоТоварнымСчетам();
	
	Если СтруктураПараметров.ВестиПартионныйУчет Тогда 
		ТекстЗапроса = СтрШаблон("%1 ; %2", ТекстЗапроса, ТекстЗапросаОтделяемыеПартии());
	КонецЕсли;
	
	Для Каждого ЗаменаТекста Из СтруктураПараметров.ЗаменаТекстаВЗапросеУчетаТоваров Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&" + ЗаменаТекста.Ключ, ЗаменаТекста.Значение);
	КонецЦикла;
	
	Запрос = Новый Запрос();
	Запрос.Текст = ТекстЗапроса;
	ЗаполнитьПараметрыЗапроса(Запрос, СтруктураПараметров);
	Запрос.УстановитьПараметр("ТаблицаИспользованныхПартий", ТаблицаИспользованныхПартий);
	Таблицы = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	Возврат Таблицы;
	
КонецФункции

Функция ЗаполнитьПоСчетам0708(СтруктураПараметров)
	
	СтруктураОписанийТипов = УчетНДСПоОстаткам.ПолучитьСтруктуруОписанийТипов();
	ПланСчетов = ПланыСчетов.Хозрасчетный;
	
	ТаблицыОстатковДвижений = ОстаткиИДвиженияПоСчетамКапВложений(СтруктураПараметров);
	
	ТаблицаОстатков 					 = ТаблицыОстатковДвижений[11].Выгрузить();
	ТаблицаСборкаОборудования			 = ТаблицыОстатковДвижений[2].Выгрузить();
	ТаблицаДвижений0807					 = ТаблицыОстатковДвижений[7].Выгрузить();
	ТаблицаДвижений10					 = ТаблицыОстатковДвижений[10].Выгрузить();
	
	ТаблицаОстатковПоПартиям = ТаблицаОстатков.СкопироватьКолонки(); 
	ТаблицаОстатковПоПартиям.Колонки.Удалить("Партия");
	ТаблицаОстатковПоПартиям.Колонки.Добавить("Партия", Новый ОписаниеТипов(Документы.ТипВсеСсылки().Типы())); 
	ТаблицаОстатковПоПартиям.Колонки.Добавить("НуженДопПоиск", Новый ОписаниеТипов("Булево"));
	ТаблицаОстатковПоПартиям.Колонки.Добавить("ИскатьСуммуНДС", Новый ОписаниеТипов("Булево"));
	ТаблицаОстатковПоПартиям.Колонки.Добавить("ИскатьДопРасходы", Новый ОписаниеТипов("Булево")); 
	ТаблицаОстатковПоПартиям.Колонки.Добавить("ИД", Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТаблицаОстатковПоПартиям.Колонки.Добавить("НетПартииНаОстатках", Новый ОписаниеТипов("Булево"));
	ТаблицаОстатковПоПартиям.Колонки.Добавить("СчетПоступления", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ТаблицаОстатковПоПартиям.Колонки.Добавить("ЭтоКомплектация", Новый ОписаниеТипов("Булево"));
	
	ТаблицаИспользованныхПартий = Новый ТаблицаЗначений;
	ТаблицаИспользованныхПартий.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаИспользованныхПартий.Колонки.Добавить("Счет", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ТаблицаИспользованныхПартий.Колонки.Добавить("Партия", Новый ОписаниеТипов(Документы.ТипВсеСсылки().Типы()));
	ТаблицаИспользованныхПартий.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	
	// Использованные партии надо будет потом исключить, когда будем осуществляться заполнение остатков по счетам 10, 41, 45
	// Здесь материалы с 10 счета могут быть в требовании накладной и передаче оборудования в монтаж, как составные объекта строительства
	
	УчетНДСПоОстаткам.РаспределитьОстаткиВложенийПоПартиям(ТаблицаОстатков, ТаблицаДвижений0807, ТаблицаОстатковПоПартиям,
		СтруктураОписанийТипов, СтруктураПараметров);
	
	// Могут быть случаи, когда на счета 08.04.1, 07 были сделаны перемещения со счетов 10, 41
	// В этом случае надо искать партию поступления на счета, с которых осуществлялось перемещение
	СтруктураОписанийТипов = УчетНДСПоОстаткам.ПолучитьСтруктуруОписанийТипов();
	ПараметрыДляДопРаспределенияПоПартиям = ПараметрыДляДопРаспределенияПоПартиям();
	ПараметрыДляДопРаспределенияПоПартиям.СтруктураОписанийТипов = СтруктураОписанийТипов;
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("НуженДопПоиск", Истина);
	ПараметрыОтбора.Вставить("ЭтоКомплектация", Ложь);
	СтрокиТребующиеДопПоиска = ТаблицаОстатковПоПартиям.НайтиСтроки(ПараметрыОтбора);
	Для Каждого Стр Из СтрокиТребующиеДопПоиска Цикл
		ПараметрыОтбораПартии = Новый Структура;
		ПараметрыОтбораПартии.Вставить("Номенклатура", Стр.Номенклатура);
		ПараметрыОтбораПартии.Вставить("Счет", 	 Стр.СчетПоступления); 
		КоличествоКРаспределению = Стр.Количество; 
		УчетНДСПоОстаткам.РаспределитьПоПартиямДополнительно(ПараметрыОтбораПартии, ТаблицаДвижений10,
			ТаблицаОстатковПоПартиям, КоличествоКРаспределению, Стр,
			ПараметрыДляДопРаспределенияПоПартиям, ТаблицаИспользованныхПартий);
		ТаблицаОстатковПоПартиям.Удалить(Стр);
	КонецЦикла;
	
	ТаблицаКомплектующих = ТаблицаСборкаОборудования.СкопироватьКолонки();
	ТаблицаКомплектующих.Колонки.Добавить("ИД"); 	
	ТаблицаКомплектующих.Колонки.Добавить("Партия"); 
	ТаблицаКомплектующих.Колонки.Добавить("ИскатьСуммуНДС");
	ТаблицаКомплектующих.Колонки.Добавить("ИскатьДопРасходы");
	ТаблицаКомплектующих.Колонки.Добавить("Это10Счет");
	
	ПараметрыДляРаспределенияПоПартиямПоКомплектующим = ПараметрыДляРаспределенияПартийПоКомплектующим();
	ПараметрыДляРаспределенияПоПартиямПоКомплектующим.ТаблицаОстатковПоПартиям		 = ТаблицаОстатковПоПартиям;
	ПараметрыДляРаспределенияПоПартиямПоКомплектующим.ТаблицаСборкаОборудования 	 = ТаблицаСборкаОборудования;
	ПараметрыДляРаспределенияПоПартиямПоКомплектующим.ТаблицаДвижений10				 = ТаблицаДвижений10;
	ПараметрыДляРаспределенияПоПартиямПоКомплектующим.ТаблицаДвижений0807			 = ТаблицаДвижений0807;
	
	УчетНДСПоОстаткам.РаспределитьПоПартиямПоКомплектующим(ПараметрыДляРаспределенияПоПартиямПоКомплектующим,
		ТаблицаКомплектующих, ТаблицаИспользованныхПартий, СтруктураОписанийТипов);
	
	ПараметрыДляПолученияНДС = ПараметрыДляПолученияНДС(СтруктураПараметров, ТаблицаОстатковПоПартиям, ТаблицаКомплектующих);
	
	ПараметрыДляВводаОстатков = СтруктураПараметровДляЗаполненияВНО();
	
	СуммыПоНДС = УчетНДСПоОстаткам.ДанныеНДСПоДокументам(ПараметрыДляПолученияНДС);
	ПараметрыДляВводаОстатков.СуммыДопРасходов		 = СуммыПоНДС[11].Выгрузить();
	ПараметрыДляВводаОстатков.СуммыПоПоступлениям	 = СуммыПоНДС[19].Выгрузить();
	ПараметрыДляВводаОстатков.АВКакДопРасходы		 = СуммыПоНДС[20].Выгрузить();
	ПараметрыДляВводаОстатков.Корректировки			 = СуммыПоНДС[21].Выгрузить();
	ПараметрыДляВводаОстатков.ТаблицаОстатков		 = ТаблицаОстатковПоПартиям;
	ПараметрыДляВводаОстатков.ТаблицаКомплектующих	 = ТаблицаКомплектующих;
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 07; 08...'"), СтруктураПараметров.СообщениеПрогресс), 20);
	РаспределитьСуммыПоПартиям(ПараметрыДляВводаОстатков, СтруктураПараметров, Ложь);
	
	Возврат ТаблицаИспользованныхПартий;
	
КонецФункции

Процедура ЗаполнитьПоТоварнымСчетам(СтруктураПараметров, ТаблицаИспользованныхПартий) 
	
	ПланСчетов = ПланыСчетов.Хозрасчетный;
	ОтделятьПарт = СтруктураПараметров.ВестиПартионныйУчет;
	
	Таблицы = ОстаткиИДвиженияПоСчетамУчетаТоваров(СтруктураПараметров, ТаблицаИспользованныхПартий);
	
	ТаблицаСПолнойАналитикой		= Таблицы[1].Выгрузить();
	ТаблицаКомплектаций				= Таблицы[2].Выгрузить();
	ТаблицаСдокументамиДвижений		= Таблицы[6].Выгрузить();
	Если СтруктураПараметров.ВестиПартионныйУчет Тогда 
		ОтделяемыеПартии = Таблицы[8].Выгрузить();
	КонецЕсли;
	
	ТаблицаСЗаполненнымиПартиями = ТаблицаСПолнойАналитикой.СкопироватьКолонки();
	ТаблицаСЗаполненнымиПартиями.Колонки.Удалить("Партия");
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("Партия", Новый ОписаниеТипов(Документы.ТипВсеСсылки().Типы()));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("ИскатьСуммуНДС", Новый ОписаниеТипов("Булево"));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("НуженДопПоиск", Новый ОписаниеТипов("Булево"));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("СчетПоступления", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("СкладПоступления", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("ИскатьДопРасходы", Новый ОписаниеТипов("Булево"));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("ЭтоКомплектация", Новый ОписаниеТипов("Булево"));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("ИД", Новый ОписаниеТипов("УникальныйИдентификатор"));
	ТаблицаСЗаполненнымиПартиями.Колонки.Добавить("НетПартииНаОстатках", Новый ОписаниеТипов("Булево"));
	
	ТаблицаСПолнойАналитикой.Колонки.Добавить("НайденаПартия");
	ТаблицаСПолнойАналитикой.Колонки.Добавить("ОсталосьКРаспределению");
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 10; 41; 45...'"), СтруктураПараметров.СообщениеПрогресс), 40);
	
	СтруктураОписанийТипов = УчетНДСПоОстаткам.ПолучитьСтруктуруОписанийТипов();
	ПараметрыДляДопРаспределенияПоПартиям = ПараметрыДляДопРаспределенияПоПартиям();
	ПараметрыДляДопРаспределенияПоПартиям.СтруктураОписанийТипов = СтруктураОписанийТипов;
	
	// Попробуем выполнить распределение по партиям, сначала осуществляем первичный проход 
	УчетНДСПоОстаткам.РаспределитьОстаткиТоваровПоПартиям(ТаблицаСПолнойАналитикой, ТаблицаСЗаполненнымиПартиями, 
		ТаблицаСДокументамиДвижений, СтруктураОписанийТипов);
		
	//Для переноса суммы с 45 на 41 счетнеобходми склад, которого в остатках 45 счета нет
	ПартииДляПоиска = Новый Массив;
	Для Каждого СтрокаПартии Из ТаблицаСЗаполненнымиПартиями Цикл 
		Если СтруктураПараметров.СчетаПередачи.Найти(СтрокаПартии.Счет) <> Неопределено
			И ТипЗнч(СтрокаПартии.Партия) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда 
			ПартииДляПоиска.Добавить(СтрокаПартии.Партия);
		КонецЕсли;
	КонецЦикла;
	СкладыПартий = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ПартииДляПоиска, "Склад");
	Для Каждого СкладПартии Из СкладыПартий Цикл 
		СтрокиСПартией = ТаблицаСЗаполненнымиПартиями.НайтиСтроки(Новый Структура("Партия", СкладПартии.Ключ));
		Для Каждого СтрокаСПартией Из СтрокиСПартией Цикл 
			СтрокаСПартией.СкладПоступления = СкладПартии.Значение;
		КонецЦикла;
	КонецЦикла;
	
	// Для некоторых документов надо осуществить доп. поиск, например:
	// Когда идет перемещение со счета на счет или поступление на 45 счет через РТУ
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("НуженДопПоиск", Истина);
	СтрокиТребующиеДопПоиска = ТаблицаСЗаполненнымиПартиями.НайтиСтроки(ПараметрыОтбора);
	Для Каждого Стр Из СтрокиТребующиеДопПоиска Цикл
		ПараметрыОтбораПартии = Новый Структура;
		ПараметрыОтбораПартии.Вставить("Номенклатура", Стр.Номенклатура);
		ПараметрыОтбораПартии.Вставить("Счет",  Стр.СчетПоступления); 
		КоличествоКРаспределению = Стр.Количество; 
		УчетНДСПоОстаткам.РаспределитьПоПартиямДополнительно(ПараметрыОтбораПартии, ТаблицаСДокументамиДвижений,
			ТаблицаСЗаполненнымиПартиями, КоличествоКРаспределению, Стр, ПараметрыДляДопРаспределенияПоПартиям);
		ТаблицаСЗаполненнымиПартиями.Удалить(Стр);
	КонецЦикла;
	
	// Если остались не распределенные остатки, 
	// То оставшиеся остатки добавим в ТаблицуСЗаполненнымиПартиями, по таким остаткам будет заполнено только количество
	ОтборНеРаспределенныхСтрок = Новый Структура;
	ОтборНеРаспределенныхСтрок.Вставить("НайденаПартия", Ложь);
	НеРаспределенныеСтроки = ТаблицаСПолнойАналитикой.НайтиСтроки(ОтборНеРаспределенныхСтрок);
	Для Каждого Стр Из НеРаспределенныеСтроки Цикл
		НоваяСтрокаСПартией = ТаблицаСЗаполненнымиПартиями.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаСПартией, Стр);
		УчетНДСПоОстаткам.ЗаполнитьДопПараметрыСтрокиПартии(НоваяСтрокаСПартией, Истина, Ложь, Ложь, Ложь, Ложь);
		НоваяСтрокаСпартией.Количество = Стр.ОсталосьКРаспределению;
		НоваяСтрокаСПартией.Партия = Неопределено;
		НоваяСтрокаСПартией.НетПартииНаОстатках = Истина;
		Стр.НайденаПартия = Истина;
	КонецЦикла;
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 10; 41; 45...'"), СтруктураПараметров.СообщениеПрогресс), 50);
	
	// Если в качестве партии выступали комплектации, то для комплектующих надо идентифицировать документ партии
	ОтборКомплектаций = Новый Структура;
	ОтборКомплектаций.Вставить("ЭтоКомплектация", Истина);
	СтрокиКомплектации = ТаблицаСЗаполненнымиПартиями.НайтиСтроки(ОтборКомплектаций); 
	
	ПартииДляКомплектующих = ТаблицаКомплектаций.СкопироватьКолонки();
	ПартииДляКомплектующих.Колонки.Удалить("КоличествоКомплектующие");
	ПартииДляКомплектующих.Колонки.Удалить("Комплектующие");
	ПартииДляКомплектующих.Колонки.Добавить("ИД");
	ПартииДляКомплектующих.Колонки.Добавить("Партия", СтруктураОписанийТипов.ОписаниеТиповПартия); 
	ПартииДляКомплектующих.Колонки.Добавить("ИскатьСуммуНДС");
	ПартииДляКомплектующих.Колонки.Добавить("ИскатьДопРасходы");
	ПартииДляКомплектующих.Колонки.Добавить("НетПартииНаОстатках");
	
	Для Каждого Строка Из СтрокиКомплектации Цикл
		ОтборПоКомплектации = Новый Структура;
		ОтборПоКомплектации.Вставить("Комплектация", Строка.Партия);
		СтрокиСКомплектующими = ТаблицаКомплектаций.НайтиСтроки(ОтборПоКомплектации);
		Для Каждого СтрКомплектующая Из СтрокиСКомплектующими Цикл
			Если Строка.Количество < СтрКомплектующая.Количество Тогда 
				КоличествоКомплектующихКРаспределению = Окр(СтрКомплектующая.КоличествоКомплектующие /
					СтрКомплектующая.Количество * Строка.Количество, 2);
			Иначе
				КоличествоКомплектующихКРаспределению = СтрКомплектующая.КоличествоКомплектующие;
			КонецЕсли;
			ПараметрыОтбораПартии = Новый Структура;
			ПараметрыОтбораПартии.Вставить("Номенклатура", СтрКомплектующая.Комплектующие);
			ПараметрыОтбораПартии.Вставить("Счет", СтрКомплектующая.СчетУчета);
			
			ПараметрыДляДопРаспределенияПоПартиям.ЭтоКомплектация	 = Истина;
			ПараметрыДляДопРаспределенияПоПартиям.ИД				 = Строка.ИД;
			
			УчетНДСПоОстаткам.РаспределитьПоПартиямДополнительно(ПараметрыОтбораПартии, ТаблицаСДокументамиДвижений,
				ПартииДляКомплектующих, КоличествоКомплектующихКРаспределению,
				СтрКомплектующая, ПараметрыДляДопРаспределенияПоПартиям);
		КонецЦикла; 	
	КонецЦикла;	
	
	// Если при пртионном учете были возвраты товаров от покупателей или корректировки ПТиУ
	// то остатки вернулись на исходную партию. Эти остатки надо выделить из основной партии.
	Если СтруктураПараметров.ВестиПартионныйУчет Тогда 
		ОтделитьПартии(ТаблицаСЗаполненнымиПартиями, ОтделяемыеПартии);
	КонецЕсли;
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 10; 41; 45...'"), СтруктураПараметров.СообщениеПрогресс), 70);
	
	ПараметрыДляПолученияНДС = ПараметрыДляПолученияНДС(СтруктураПараметров, ТаблицаСЗаполненнымиПартиями, ПартииДляКомплектующих);
	
	СуммыПоНДС = УчетНДСПоОстаткам.ДанныеНДСПоДокументам(ПараметрыДляПолученияНДС);
	ПараметрыДляВводаОстатков = СтруктураПараметровДляЗаполненияВНО();
	ПараметрыДляВводаОстатков.СуммыДопРасходов		 = СуммыПоНДС[11].Выгрузить();
	ПараметрыДляВводаОстатков.СуммыПоПоступлениям	 = СуммыПоНДС[19].Выгрузить();
	ПараметрыДляВводаОстатков.АВКакДопРасходы		 = СуммыПоНДС[20].Выгрузить();
	ПараметрыДляВводаОстатков.АВКакДопРасходы		 = СуммыПоНДС[20].Выгрузить();
	ПараметрыДляВводаОстатков.Корректировки			 = СуммыПоНДС[21].Выгрузить();
	ПараметрыДляВводаОстатков.ТаблицаОстатков		 = ТаблицаСЗаполненнымиПартиями;
	ПараметрыДляВводаОстатков.ТаблицаКомплектующих	 = ПартииДляКомплектующих;
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 10; 41; 45...'"), СтруктураПараметров.СообщениеПрогресс), 80);
	
	РаспределитьСуммыПоПартиям(ПараметрыДляВводаОстатков, СтруктураПараметров, Истина);
	
	СообщитьПрогресс(СтрШаблон(НСтр("ru = '%1 10; 41; 45...'"), СтруктураПараметров.СообщениеПрогресс), 90);
	
КонецПроцедуры

Функция ПараметрыДляПолученияНДС(Параметры, ТаблицаОстатковПоПартиям, ТаблицаКомплектующих)
	
	ПараметрыПоискаОсновныхСуммНДС = Новый Структура;
	ПараметрыПоискаОсновныхСуммНДС.Вставить("ИскатьСуммуНДС", Истина);
	ТЧПоискаНДС = ТаблицаОстатковПоПартиям.Скопировать(ПараметрыПоискаОсновныхСуммНДС, "Номенклатура, Партия");
	
	ТЧПоискаНДСК = ТаблицаКомплектующих.Скопировать(ПараметрыПоискаОсновныхСуммНДС, "Номенклатура, Партия");
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТЧПоискаНДСК, ТЧПоискаНДС);
	
	ПараметрыПоискаДопСуммНДС = Новый Структура;
	ПараметрыПоискаДопСуммНДС.Вставить("ИскатьДопРасходы", Истина);
	ТЧПоискаДопРасходов = ТаблицаОстатковПоПартиям.Скопировать(ПараметрыПоискаДопСуммНДС, "Номенклатура, Партия");
	
	ТЧПоискаДопРасходовК = ТаблицаКомплектующих.Скопировать(ПараметрыПоискаДопСуммНДС, "Номенклатура, Партия");
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТЧПоискаДопРасходовК, ТЧПоискаДопРасходов);
	
	ТЧАвансовыйОтчетКакРасходы = ТаблицаОстатковПоПартиям.Скопировать(ПараметрыПоискаОсновныхСуммНДС,
		"Номенклатура, Партия, Счет");
	
	ТЧПоискаНДС.Свернуть("Номенклатура, Партия");
	ТЧПоискаДопРасходов.Свернуть("Номенклатура, Партия");
	ТЧАвансовыйОтчетКакРасходы.Свернуть("Номенклатура, Партия, Счет");
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Организация", Параметры.Организация);
	СтруктураПараметров.Вставить("Период", Параметры.Период);
	СтруктураПараметров.Вставить("СчетНДС", Параметры.СчетНДСПоУмолчанию);
	СтруктураПараметров.Вставить("ДокументыПартий", ТЧПоискаНДС);
	СтруктураПараметров.Вставить("ОснованияДляДопРасходов", ТЧПоискаДопРасходов);
	СтруктураПараметров.Вставить("АвансовыйОтчетКакРасходы", ТЧАвансовыйОтчетКакРасходы); 
	СтруктураПараметров.Вставить("СокращеннаяАналитика", Ложь);
	СтруктураПараметров.Вставить("СуммыБезПредъявленыхСФ",	Истина);
	
	Возврат СтруктураПараметров;
	
КонецФункции

Функция ТекстЗапросаОтделяемыеПартии()
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДокументыПоступлений.Период КАК Период,
	|	ДокументыПоступлений.Регистратор КАК Регистратор,
	|	ДокументыПоступлений.Номенклатура КАК Номенклатура,
	|	ДокументыПоступлений.Счет КАК Счет
	|ПОМЕСТИТЬ Регистраторы
	|ИЗ
	|	ДокументыПоступлений КАК ДокументыПоступлений
	|ГДЕ
	|	ДокументыПоступлений.Регистратор ССЫЛКА Документ.ВозвратТоваровОтПокупателя
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Регистраторы.Период КАК Период,
	|	Регистраторы.Регистратор КАК Регистратор,
	|	Регистраторы.Номенклатура КАК Номенклатура,
	|	Регистраторы.Счет КАК Счет,
	|	СУММА(ЕСТЬNULL(ХозрасчетныйОбороты.КоличествоОборот, 0)) КАК Количество,
	|	&ПолеПартияОбороты КАК Партия
	|ИЗ
	|	Регистраторы КАК Регистраторы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Обороты(
	|				,
	|				&ГраницаОстатков,
	|				Регистратор,
	|				Счет В
	|					(ВЫБРАТЬ
	|						Регистраторы.Счет
	|					ИЗ
	|						Регистраторы КАК Регистраторы),
	|				&ВидыСубконтоНСП,
	|				,
	|				,
	|				) КАК ХозрасчетныйОбороты
	|		ПО Регистраторы.Регистратор = ХозрасчетныйОбороты.Регистратор
	|			И Регистраторы.Номенклатура = ХозрасчетныйОбороты.Субконто1
	|			И Регистраторы.Счет = ХозрасчетныйОбороты.Счет
	|
	|СГРУППИРОВАТЬ ПО
	|	Регистраторы.Период,
	|	Регистраторы.Регистратор,
	|	Регистраторы.Номенклатура,
	|	Регистраторы.Счет,
	|	&ПолеПартияОбороты
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура,
	|	Счет,
	|	Период УБЫВ";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Процедура ОтделитьПартии(ТаблицаСЗаполненнымиПартиями, ОтделяемыеПартии)
	
	НовыеПартии = ТаблицаСЗаполненнымиПартиями.СкопироватьКолонки();
	СтрокиНаУдаление = Новый Массив;
	
	Для Каждого Партия Из ОтделяемыеПартии Цикл 
		
		КоличествоКРаспределению = Партия.Количество;
		ПараметрыОтбора = Новый Структура("Номенклатура, Счет, Партия");
		ЗаполнитьЗначенияСвойств(ПараметрыОтбора, Партия); 
		ОстаткиПоПартии = ТаблицаСЗаполненнымиПартиями.НайтиСтроки(ПараметрыОтбора);
		
		Для Каждого СтрокаОстатки Из ОстаткиПоПартии Цикл 
			
			НоваяПартия = НовыеПартии.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяПартия, СтрокаОстатки);
			НоваяПартия.Партия = Партия.Регистратор;
			
			НоваяПартия.Количество = Мин(КоличествоКРаспределению, СтрокаОстатки.Количество);
			СтрокаОстатки.Количество = СтрокаОстатки.Количество - НоваяПартия.Количество;
			КоличествоКРаспределению = КоличествоКРаспределению - НоваяПартия.Количество;
			
			Если СтрокаОстатки.Количество = 0 тогда
				СтрокиНаУдаление.Добавить(СтрокаОстатки);
			КонецЕсли;
			
			Если КоличествоКРаспределению = 0 Тогда 
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Для Каждого СтрокаНаУдаление Из СтрокиНаУдаление Цикл 
		ТаблицаСЗаполненнымиПартиями.Удалить(СтрокаНаУдаление);
	КонецЦикла;
	
	//Свернем строки для возвратов товаров, списавших остатки по нескольким партиям.
	КолонкиГруппировок = Новый Массив;
	Для Каждого Колонка Из ТаблицаСЗаполненнымиПартиями.Колонки Цикл
		КолонкиГруппировок.Добавить(Колонка.Имя);
	КонецЦикла;
	КолонкиГруппировок.Удалить(КолонкиГруппировок.Найти("Количество"));
	НовыеПартии.Свернуть(СтрСоединить(КолонкиГруппировок, ", "),"Количество");
		
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НовыеПартии, ТаблицаСЗаполненнымиПартиями);

КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли