функция СчетаУчета()
	
	ПланСчетов = ПланыСчетов.Хозрасчетный;
	
	// Массив счетов, по которым ведется только суммовой учет	
	ПредопределенныйСчетУчетаКапвложений = Новый Массив;
	ПредопределенныйСчетУчетаКапвложений.Добавить(ПланСчетов.ВложенияВоВнеоборотныеАктивы);						// 08
	СчетаВложений = БухгалтерскийУчет.СформироватьМассивСубсчетов(ПредопределенныйСчетУчетаКапвложений);
	
	ПредопределенныеИсключаемыеСчетаВложений = Новый Массив;
	ПредопределенныеИсключаемыеСчетаВложений.Добавить(ПланСчетов.ПриобретениеКомпонентовОсновныхСредств);		// 08.04.1
	ПредопределенныеИсключаемыеСчетаВложений.Добавить(ПланСчетов.ПереводМолоднякаЖивотныхВОсновноеСтадо);		// 08.06
	ПредопределенныеИсключаемыеСчетаВложений.Добавить(ПланСчетов.ПриобретениеВзрослыхЖивотных);					// 08.07
	ПредопределенныеИсключаемыеСчетаВложений.Добавить(ПланСчетов.НематериальныеПоисковыеАктивы);				// 08.11
	ПредопределенныеИсключаемыеСчетаВложений.Добавить(ПланСчетов.МатериальныеПоисковыеАктивы);					// 08.12
	СчетаВложений = ОбщегоНазначенияКлиентСервер.РазностьМассивов(СчетаВложений, 
	БухгалтерскийУчет.СформироватьМассивСубсчетов(ПредопределенныеИсключаемыеСчетаВложений));
	
	// Массив счетов, по которым ведется количественный учет	
	СчетаНПС = Новый Массив();
	СчетаНПС.Добавить(ПланСчетов.ОборудованиеКУстановке);														// 07
	СчетаНПС.Добавить(ПланСчетов.ПриобретениеКомпонентовОсновныхСредств);										// 08.04.1
	
	// Массив счетов материалов
	СчетаМатериалов = БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланСчетов.Материалы);
	ПредопределенныеИсключаемыеСчетаМатериалов = Новый Массив;
	ПредопределенныеИсключаемыеСчетаМатериалов.Добавить(ПланСчетов.ТопливоВБаке);									// 10.03.2
	ПредопределенныеИсключаемыеСчетаМатериалов.Добавить(ПланСчетов.МатериалыПереданныеВПереработку);				// 10.07 
	ПредопределенныеИсключаемыеСчетаМатериалов.Добавить(ПланСчетов.СпецоснасткаИСпецодеждаВЭксплуатации);			// 10.11
	СчетаМатериалов = ОбщегоНазначенияКлиентСервер.РазностьМассивов(СчетаМатериалов, 
	БухгалтерскийУчет.СформироватьМассивСубсчетов(ПредопределенныеИсключаемыеСчетаМатериалов));
	
	// Сформируем массив счетов с возможной аналитикой номенклатура, склад, партия
	// Это счета на которые изначально ожидаются поступления 	
	ПредопределенныеСчетаУчетаЗапасов = Новый Массив;
	ПредопределенныеСчетаУчетаЗапасов.Добавить(ПланСчетов.Материалы);											// 10
	ПредопределенныеСчетаУчетаЗапасов.Добавить(ПланСчетов.Товары);												// 41
	СчетаЗапасов = БухгалтерскийУчет.СформироватьМассивСубсчетов(ПредопределенныеСчетаУчетаЗапасов);
	
	ПредопределенныеИсключаемыеСчетаЗапасов = Новый Массив;
	ПредопределенныеИсключаемыеСчетаЗапасов.Добавить(ПланСчетов.ТопливоВБаке);									// 10.03.2
	ПредопределенныеИсключаемыеСчетаЗапасов.Добавить(ПланСчетов.МатериалыПереданныеВПереработку);				// 10.07 
	ПредопределенныеИсключаемыеСчетаЗапасов.Добавить(ПланСчетов.СпецоснасткаИСпецодеждаВЭксплуатации);			// 10.11
	ПредопределенныеИсключаемыеСчетаЗапасов.Добавить(ПланСчетов.ТоварыВРозничнойТорговлеВПродажныхЦенахАТТ);	// 41.11
	ПредопределенныеИсключаемыеСчетаЗапасов.Добавить(ПланСчетов.ТоварыВРозничнойТорговлеВПродажныхЦенахНТТ);	// 41.12
	ПредопределенныеИсключаемыеСчетаЗапасов.Добавить(ПланСчетов.КорректировкаТоваровПрошлогоПериода);			// 41.К
	
	СчетаЗапасов = ОбщегоНазначенияКлиентСервер.РазностьМассивов(СчетаЗапасов, 
	БухгалтерскийУчет.СформироватьМассивСубсчетов(ПредопределенныеИсключаемыеСчетаЗапасов));
	
	// Счет 41.11, на нем вне зависимости от ведения учета по складам есть субконто склад, 
	// Поэтому этот счет отличается от остальных в группе 41 счета
	Счет4111 = ПланСчетов.ТоварыВРозничнойТорговлеВПродажныхЦенахАТТ;												// 41.11
	
	// Массив счетов, которые используются для передачи, на них не бывает субконто "Склад", вместо него "Контрагент"
	ПредопределенныеСчетаУчетаПередачи = Новый Массив;
	ПредопределенныеСчетаУчетаПередачи.Добавить(ПланСчетов.МатериалыПереданныеВПереработку);					// 10.07
	ПредопределенныеСчетаУчетаПередачи.Добавить(ПланСчетов.ТоварыОтгруженные);									// 45
	СчетаПередачи = БухгалтерскийУчет.СформироватьМассивСубсчетов(ПредопределенныеСчетаУчетаПередачи);
	
	ПредопределенныеИсключаемыеСчетаПередачи = Новый Массив;
	ПредопределенныеИсключаемыеСчетаПередачи.Добавить(ПланСчетов.ПереданныеОбъектыНедвижимости);				// 45.04
	
	СчетаПередачи = ОбщегоНазначенияКлиентСервер.РазностьМассивов(СчетаПередачи, 
		БухгалтерскийУчет.СформироватьМассивСубсчетов(ПредопределенныеИсключаемыеСчетаПередачи));
	
	СчетаУчета = Новый Структура;
	СчетаУчета.Вставить("Счет10", 				ПланСчетов.Материалы);									// 10
	СчетаУчета.Вставить("Счет41", 				ПланСчетов.Товары);										// 41
	СчетаУчета.Вставить("Счет4111", 			Счет4111);
	СчетаУчета.Вставить("СчетаКапВложений", 	СчетаВложений);
	СчетаУчета.Вставить("СчетаНПС", 			СчетаНПС);
	СчетаУчета.Вставить("СчетаЗапасов", 		СчетаЗапасов);
	СчетаУчета.Вставить("СчетаМатериалов", 		СчетаМатериалов);
	СчетаУчета.Вставить("СчетаПередачи", 		СчетаПередачи);
	Возврат СчетаУчета;
	
КонецФункции

Функция КонтрольнаяСуммаПоДокументам(Параметры)
	
	ТаблицаДокументы		 = ДокументыОстатковЗаПериод(Параметры);
	ТаблицаДокументыСтрока	 = ТаблицаЗначенийВJSON(ТаблицаДокументы);
	Возврат ВерсионированиеОбъектов.КонтрольнаяСумма(ТаблицаДокументыСтрока);
	
КонецФункции

Функция ДокументыОстатковЗаПериод(Параметры)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Счет
	|ПОМЕСТИТЬ Счета
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В(&СписокСчетовПоиска)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОборотыДтКт.Регистратор.МоментВремени КАК РегистраторМоментВремени, 
	|	ХозрасчетныйОборотыДтКт.Регистратор.Представление КАК РегистраторПредставление, 
	|	ХозрасчетныйОборотыДтКт.Регистратор.ВерсияДанных КАК РегистраторВерсияДанных
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОборотыДтКт(
	|			&НачалоПериода, 
	|			&КонецПериода, 
	|			Регистратор, 
	|			СчетДт В
	|				(ВЫБРАТЬ
	|					счета.Счет
	|				ИЗ
	|					счета КАК счета),
	|			, 
	|			, 
	|			, 
	|			Организация = &Организация) КАК ХозрасчетныйОборотыДтКт
	|
	|СГРУППИРОВАТЬ ПО
	|	ХозрасчетныйОборотыДтКт.Регистратор.Представление, 
	|	ХозрасчетныйОборотыДтКт.Регистратор.МоментВремени, 
	|	ХозрасчетныйОборотыДтКт.Регистратор.ВерсияДанных
	|
	|УПОРЯДОЧИТЬ ПО
	|	РегистраторМоментВремени";
	
	Запрос.УстановитьПараметр("СписокСчетовПоиска", СписокСчетовПоиска());
	Запрос.УстановитьПараметр("НачалоПериода", Параметры.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецДня(Параметры.КонецПериода));
	Запрос.УстановитьПараметр("Организация", Параметры.Организация);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда 
		Возврат Новый ТаблицаЗначений;
	Иначе 
		ИсходнаяТЗ = Результат.Выгрузить();
		ИсходнаяТЗ.Колонки.Удалить(0);
		Возврат ИсходнаяТЗ;
	КонецЕсли;
	
КонецФункции

Функция ТаблицаЗначенийВJSON(Таблица)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	ЗаписьJSON.ЗаписатьНачалоМассива();
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		ЗаписьJSON.ЗаписатьНачалоОбъекта();
		
		Для Каждого Колонка Из Таблица.Колонки Цикл
			ЗаписьJSON.ЗаписатьИмяСвойства(Колонка.Имя);
			ЗаписьJSON.ЗаписатьЗначение(СтрокаТаблицы[Колонка.Имя]);
		КонецЦикла;
		
		ЗаписьJSON.ЗаписатьКонецОбъекта();
	КонецЦикла;
	ЗаписьJSON.ЗаписатьКонецМассива();
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция МассивПоСтроке(СписокЭлементов)
	
	Список = СтрЗаменить(СписокЭлементов, " ", "");
	Список = СтрЗаменить(Список, Символы.ПС, "");
	Список = СтрЗаменить(Список, Символы.НПП, "");
	Возврат СтрРазделить(Список, ", ", Ложь);
	
КонецФункции

Функция ИмяСобытияЖурналаРегистрации()
	
	Возврат НСтр("ru = 'Подготовка к вычету НДС учтенного в стоимости'", ОбщегоНазначения.КодОсновногоЯзыка());
	
КонецФункции

Функция ПолучитьСоответствиеКодовВидаОперации(Партии)
	
	СоответствиеКодовВидаОперации = Новый Соответствие;
	
	ПараметрыПоискаКода = Новый Структура;
	ПараметрыПоискаКода.Вставить("ВидСчетаФактуры", Перечисления.ВидСчетаФактурыПолученного.НаПоступление);
	
	Для Каждого Партия Из Партии Цикл 
		ПараметрыПоискаКода.Вставить("Дата", Партия.Дата);
		
		ОснованияСчетаФактуры = Новый ТаблицаЗначений;
		ОснованияСчетаФактуры.Колонки.Добавить("ДокументОснование");
		СтрокаОснования = ОснованияСчетаФактуры.Добавить();
		СтрокаОснования.ДокументОснование = Партия.Партия;
		
		ПараметрыПоискаКода.Вставить("ДокументыОснования", ОснованияСчетаФактуры);
		НДСИсчисляетсяНалоговымАгентом = Ложь;
		Если ЗначениеЗаполнено(Партия.ДоговорКонтрагента) Тогда
			ВидАгентскогоДоговора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Партия.ДоговорКонтрагента, "ВидАгентскогоДоговора");
			НДСИсчисляетсяНалоговымАгентом = ВидАгентскогоДоговора = Перечисления.ВидыАгентскихДоговоров.РеализацияТоваров;
		КонецЕсли;
		ПараметрыПоискаКода.Вставить("НДСИсчисляетсяНалоговымАгентом", НДСИсчисляетсяНалоговымАгентом);
		
		СоответствиеКодовВидаОперации.Вставить(Партия.Партия, 
		Документы.СчетФактураПолученный.ПолучитьКодВидаОперации(ПараметрыПоискаКода));
		
	КонецЦикла; 
	
	Возврат СоответствиеКодовВидаОперации;
	
КонецФункции

Функция СоздатьВводОстатков(Параметры, СчетУчета, Подразделение, Ответственный)
	
	ВводОстатковОбъект = Документы.ВводНачальныхОстатков.СоздатьДокумент();
	ВводОстатковОбъект.Дата								 = Параметры.ДатаПерехода;
	ВводОстатковОбъект.Организация						 = Параметры.Организация;
	ВводОстатковОбъект.Ответственный					 = Ответственный;
	ВводОстатковОбъект.ОтражатьВБухгалтерскомУчете		 = Истина;
	ВводОстатковОбъект.ОтражатьВНалоговомУчете			 = Ложь;
	ВводОстатковОбъект.ОтражатьПоСпециальнымРегистрам	 = Ложь;
	ВводОстатковОбъект.РазделУчета						 = Перечисления.РазделыУчетаДляВводаОстатков.НДСУчтенныйВСтоимости;
	ВводОстатковОбъект.ПодразделениеОрганизации 		 = Подразделение;
	
	Комментарий = СтрШаблон(НСтр("ru = '#Создан автоматически при поиске НДС, учтенного в стоимости, %1 %2'"), 
		СчетУчета, Подразделение);
	ВводОстатковОбъект.Комментарий = Комментарий;
	
	Возврат ВводОстатковОбъект;
	
КонецФункции

Процедура ЗаписатьВводОстатков(Параметры, ВводОстатковОбъект, СчетУчета, НДСПодготовленДляЗаявления)
	
	Попытка
		
		НачатьТранзакцию();
		
		ПроцентВыполнения = Окр(Параметры.СтрокОбработано / Параметры.СтрокВсего * 100, 0);
		//При записи первого документа процент выполнения может округлиться до 0
		ПроцентВыполнения = ?(ПроцентВыполнения = 0, 1, ПроцентВыполнения);
		ДлительныеОперации.СообщитьПрогресс(, СтрШаблон(НСтр("ru = 'Выполнено %1%%'"), ПроцентВыполнения));
		
		ВводОстатковОбъект.ДополнительныеСвойства.Вставить("ПроведенВХронологическойПоследовательности", Истина);
		ВводОстатковОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		Для Каждого СтрокаОстатков Из НДСПодготовленДляЗаявления Цикл
			СтрокаОстатков.Статус = "Подготовлен";
		КонецЦикла; 
		СохранитьВХранилище(Параметры);
		НДСПодготовленДляЗаявления.Очистить();
		
		РегистрыСведений.ВыполнениеРегламентныхОперацийНДС.ЗафиксироватьФактВыполненияРегламентнойОперации(
			Параметры.ДатаПерехода, 
			Параметры.Организация,
			ВводОстатковОбъект.Ссылка, 
			Перечисления.РегламентныеОперации.ПодготовкаКВычетуНДСУчтенногоВСтоимости, 
			Истина, 
			СчетУчета);
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации(ИмяСобытияЖурналаРегистрации(), 
			УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
			
	КонецПопытки; 
	
КонецПроцедуры

#Область ПоискНДСПоОстаткам

Процедура ДобавитьПараметрыНаборыСубконто(СтруктураПараметров)
	
	ВестиСкладскойУчет				= СтруктураПараметров.ВестиСкладскойУчет;
	ВестиПартионныйУчет				= СтруктураПараметров.ВестиПартионныйУчет;
	ВедетсяСуммовойУчетПоСкладам	= СтруктураПараметров.ВедетсяСуммовойУчетПоСкладам;
	
	ВидыСубконтоНПС = Новый Массив;
	ВидыСубконтоНПС.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура);
	Если ВестиПартионныйУчет Тогда 
		ВидыСубконтоНПС.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Партии);
	КонецЕсли;
	Если ВестиСкладскойУчет Тогда 
		ВидыСубконтоНПС.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады);
	КонецЕсли;
	
	ВидыСубконтоНП = Новый Массив;
	ВидыСубконтоНП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура);
	Если ВестиПартионныйУчет Тогда 
		ВидыСубконтоНП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Партии);
	КонецЕсли;
	Если ВедетсяСуммовойУчетПоСкладам Тогда
		ВидыСубконтоНП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады);
	КонецЕсли;
	
	ВидыСубконтоНСП = Новый Массив;
	ВидыСубконтоНСП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура);
	Если ВестиСкладскойУчет Тогда
		ВидыСубконтоНСП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады);
	КонецЕсли;
	Если ВестиПартионныйУчет Тогда 
		ВидыСубконтоНСП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Партии);
	КонецЕсли;
	
	ВидыСубконтоНКП = Новый Массив;
	ВидыСубконтоНКП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура);
	ВидыСубконтоНКП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	Если ВестиПартионныйУчет Тогда
		ВидыСубконтоНКП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Партии);
	КонецЕсли;
	
	ВидыСубконтоНСП4111 = Новый Массив;
	ВидыСубконтоНСП4111.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура);
	ВидыСубконтоНСП4111.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады);
	Если ВестиПартионныйУчет Тогда 
		ВидыСубконтоНСП4111.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Партии);
	КонецЕсли;
	
	СтруктураПараметров.Вставить("ВидыСубконтоН", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура);
	СтруктураПараметров.Вставить("ВидыСубконтоНПС", ВидыСубконтоНПС);
	СтруктураПараметров.Вставить("ВидыСубконтоНП", ВидыСубконтоНП);
	СтруктураПараметров.Вставить("ВидыСубконтоНСП", ВидыСубконтоНСП);
	СтруктураПараметров.Вставить("ВидыСубконтоНКП", ВидыСубконтоНКП);
	СтруктураПараметров.Вставить("ВидыСубконтоНСП4111", ВидыСубконтоНСП4111);
	
КонецПроцедуры

Процедура ДобавитьПараметрыЗаменыТекста(СтруктураПараметров)
	
	ВестиСкладскойУчет				= СтруктураПараметров.ВестиСкладскойУчет;
	ВестиПартионныйУчет				= СтруктураПараметров.ВестиПартионныйУчет;
	ВедетсяСуммовойУчетПоСкладам	= СтруктураПараметров.ВедетсяСуммовойУчетПоСкладам;
	
	ПолеПартия								= ?(ВестиПартионныйУчет,
													"ЕСТЬNULL(ХозрасчетныйОстатки.Субконто2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
	ОборотыПартия							= ?(ВестиПартионныйУчет,
													"ЕСТЬNULL(ХозрасчетныйОборотыДтКт.СубконтоДт2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
	Если Не ВестиПартионныйУчет Тогда
		ПолеСклад							= ?(ВестиСкладскойУчет,   "ЕСТЬNULL(ХозрасчетныйОстатки.Субконто2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО"); 
		ВедетсяСуммовойУчетПоСкладамТекст	= ?(ВедетсяСуммовойУчетПоСкладам,
													"ЕСТЬNULL(ХозрасчетныйОстатки.Субконто2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
		ОборотыСклад						= ?(ВестиСкладскойУчет,
													"ЕСТЬNULL(ХозрасчетныйОборотыДтКт.СубконтоДт2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
		ОборотыВедетсяСуммовойУчетПоСкладам = ?(ВедетсяСуммовойУчетПоСкладам,
													"ЕСТЬNULL(ХозрасчетныйОборотыДтКт.Субконто2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
	Иначе
		ПолеСклад							= ?(ВестиСкладскойУчет,
													"ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
		ВедетсяСуммовойУчетПоСкладамТекст	= ?(ВедетсяСуммовойУчетПоСкладам,
													"ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
		ОборотыСклад						= ?(ВестиСкладскойУчет,
													"ЕСТЬNULL(ХозрасчетныйОборотыДтКт.СубконтоДт3, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
		ОборотыВедетсяСуммовойУчетПоСкладам = ?(ВедетсяСуммовойУчетПоСкладам,
													"ЕСТЬNULL(ХозрасчетныйОборотыДтКт.Субконто3, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
	КонецЕсли;
	
	ЗаменаТекстаВЗапросеКапВложений = Новый Структура;
	ЗаменаТекстаВЗапросеКапВложений.Вставить("ПолеПартия", 							ПолеПартия);
	ЗаменаТекстаВЗапросеКапВложений.Вставить("ОборотыПартия", 						ОборотыПартия);
	ЗаменаТекстаВЗапросеКапВложений.Вставить("ПолеСклад", 							ПолеСклад);
	ЗаменаТекстаВЗапросеКапВложений.Вставить("ОборотыСклад", 						ОборотыСклад);
	ЗаменаТекстаВЗапросеКапВложений.Вставить("ВедетсяСуммовойУчетПоСкладам", 		ВедетсяСуммовойУчетПоСкладамТекст);
	ЗаменаТекстаВЗапросеКапВложений.Вставить("ОборотыВедетсяСуммовойУчетПоСкладам", ОборотыВедетсяСуммовойУчетПоСкладам);
	
	ПолеСклад				= ?(ВестиСкладскойУчет,   "ЕСТЬNULL(ХозрасчетныйОстатки.Субконто2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
	Если Не ВестиСкладскойУчет Тогда 
		ПолеПартияОбороты	= ?(ВестиПартионныйУчет, "ЕСТЬNULL(ХозрасчетныйОбороты.Субконто2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
		ПолеПартия			= ?(ВестиПартионныйУчет, "ЕСТЬNULL(ХозрасчетныйОстатки.Субконто2, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
	Иначе
		ПолеПартияОбороты	= ?(ВестиПартионныйУчет, "ЕСТЬNULL(ХозрасчетныйОбороты.Субконто3, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
		ПолеПартия			= ?(ВестиПартионныйУчет, "ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");
	КонецЕсли;
	ПартияКакСубконто3		= ?(ВестиПартионныйУчет, "ЕСТЬNULL(ХозрасчетныйОстатки.Субконто3, НЕОПРЕДЕЛЕНО)", "НЕОПРЕДЕЛЕНО");

	
	ЗаменаТекстаВЗапросеУчетаТоваров = Новый Структура;
	ЗаменаТекстаВЗапросеУчетаТоваров.Вставить("ПолеСклад", 			ПолеСклад);
	ЗаменаТекстаВЗапросеУчетаТоваров.Вставить("ПолеПартияОбороты", 		ПолеПартияОбороты);
	ЗаменаТекстаВЗапросеУчетаТоваров.Вставить("ПолеПартия", 		ПолеПартия);
	ЗаменаТекстаВЗапросеУчетаТоваров.Вставить("ПартияКакСубконто3", ПартияКакСубконто3);
	
	СтруктураПараметров.Вставить("ЗаменаТекстаВЗапросеКапВложений", ЗаменаТекстаВЗапросеКапВложений);
	СтруктураПараметров.Вставить("ЗаменаТекстаВЗапросеУчетаТоваров", ЗаменаТекстаВЗапросеУчетаТоваров);
	
КонецПроцедуры

Функция ПараметрыВыполненияЗапроса(Параметры)
	
	Если Параметры.Свойство("ДатаПерехода") Тогда
		ДатаНачала		= Параметры.НачалоПериода;
		ДатаОкончания	= Параметры.КонецПериода;
	Иначе 
		ДатаПерехода = ДатаПереходаНаУСНСВычетами(Параметры.Организация,Параметры.Период);
		ДатаНачала		= '00010101';
		ДатаОкончания	= ДатаПерехода - 1;
	КонецЕсли;
	
	ДатаВводаОстатков	 = Новый Граница(КонецДня(ДатаОкончания), ВидГраницы.Включая);
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Организация", Параметры.Организация);
	Если Параметры.Свойство("СтавкаНДС") Тогда 
		СтруктураПараметров.Вставить("СтавкаНДС", Параметры.СтавкаНДС);
	Иначе 
		ТекущаяДатаПользователя = ОбщегоНазначения.ТекущаяДатаПользователя();
		СтруктураПараметров.Вставить("СтавкаНДС", УчетНДСКлиентСервер.ОбщаяСтавкаНДС(ТекущаяДатаПользователя));
	КонецЕсли;
	СтруктураПараметров.Вставить("ГраницаОстатков", ДатаВводаОстатков);
	СтруктураПараметров.Вставить("Период", ДатаОкончания);
	СтруктураПараметров.Вставить("ДатаНачала", ДатаНачала);
	СтруктураПараметров.Вставить("ПодразделениеПустаяСсылка", Справочники.ПодразделенияОрганизаций.ПустаяСсылка());
	СтруктураПараметров.Вставить("СообщениеПрогресс", "Выполняется поиск НДС по остаткам на счетах");
	
	ПараметрыУчета = ОбщегоНазначенияБП.ОпределитьПараметрыУчета();
	СтруктураПараметров.Вставить("ВестиПартионныйУчет", ПараметрыУчета.ВестиПартионныйУчет);
	СтруктураПараметров.Вставить("ВестиСкладскойУчет", ПараметрыУчета.СкладскойУчет > 0);
	СтруктураПараметров.Вставить("ВедетсяСуммовойУчетПоСкладам", ПараметрыУчета.СкладскойУчет = 2);
	
	ДобавитьПараметрыНаборыСубконто(СтруктураПараметров);
	ДобавитьПараметрыЗаменыТекста(СтруктураПараметров);
	Для Каждого НаборСчетов Из СчетаУчета() Цикл 
		СтруктураПараметров.Вставить(НаборСчетов.Ключ,НаборСчетов.Значение);
	КонецЦикла;
	СтруктураПараметров.Вставить("СчетНДСПоУмолчанию", ПланыСчетов.Хозрасчетный.НДСпоПриобретеннымМПЗ);
	Возврат СтруктураПараметров;
	
КонецФункции

Процедура ЗаполнитьСтрокуПоДопРасходам(СтрокаСАналитикой, ПараметрыОтбора, КонтрольноеКоличество, НДСУчтенныйВСтоимости,
										СуммыДопРасходов, ЭтоСчетПередачи, СчетУчета)
										
	ПараметрыОтбора.Вставить("ПодготавливатьНДСКВычету", Истина); 
	СтрокиСДопРасходами = СуммыДопРасходов.НайтиСтроки(ПараметрыОтбора);
	Для Каждого СтрокаДопРасходов Из СтрокиСДопРасходами Цикл
		
		Если СтрокаДопРасходов.СуммаБезНДС = 0 И СтрокаДопРасходов.СуммаНДС = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаСФ = НДСУчтенныйВСтоимости.Добавить();  
		ЗаполнитьЗначенияСвойств(СтрокаСФ, СтрокаСАналитикой, "Склад, Подразделение");
		//Для счетов в иерархии 45 в поле "Склад" из запроса попадает значение субконто "Контрагент"; 
		Если ЭтоСчетПередачи Тогда 
			ЗаполнитьЗначенияСвойств(СтрокаСФ, СтрокаДопРасходов, , "Контрагент"); 
			СтрокаСФ.Контрагент = СтрокаСАналитикой.Склад;
		Иначе 
			ЗаполнитьЗначенияСвойств(СтрокаСФ, СтрокаДопРасходов); 
		КонецЕсли;
		
		СтрокаСФ.СчетУчета = СчетУчета;
		СтрокаСФ.Партия = СтрокаДопРасходов.СчетФактура;
		СтрокаСФ.ДокументПоступления = СтрокаДопРасходов.ДокументПоступления;
		
		Если КонтрольноеКоличество = 0 Тогда 
			СтрокаСФ.СуммаБезНДС = СтрокаДопРасходов.СуммаБезНДС;
			СтрокаСФ.СуммаНДС = СтрокаДопРасходов.СуммаНДС;
		Иначе
			СтрокаСФ.СуммаБезНДС = Окр(СтрокаДопРасходов.СуммаБезНДС / СтрокаДопРасходов.Количество * КонтрольноеКоличество, 2);
			СтрокаСФ.СуммаНДС = Окр(СтрокаДопРасходов.СуммаНДС / СтрокаДопРасходов.Количество * КонтрольноеКоличество, 2);
		КонецЕсли;
		СтрокаСФ.Всего = СтрокаСФ.СуммаБезНДС + СтрокаСФ.СуммаНДС;
		
		СтрокаСф.Количество = 0;
		
		Если СтрокаСФ.ВидЦенности = Перечисления.ВидыЦенностей.ТаможенныеПлатежи Тогда
			ВидЦенности = УчетНДС.ОпределитьВидЦенности(СтрокаДопРасходов.СчетУчета);
			Если ВидЦенности = Перечисления.ВидыЦенностей.ОС Тогда
				СтрокаСФ.ВидЦенности = Перечисления.ВидыЦенностей.ТаможенныеПлатежиОС;
			КонецЕсли;
		КонецЕсли;
		
		Если СтрокаДопРасходов.ВидЦенности = Неопределено Тогда
			СтрокаСФ.ВидЦенности = УчетНДС.ОпределитьВидЦенности(СчетУчета);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаСФ.СтавкаНДС) Тогда
			СтрокаСФ.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСтрокуПоПартии(СтрокаСАналитикой, ПараметрыОтбора, НДСУчтенныйВСтоимости, СуммыПоПоступлениям,
									ПараметрыДляЗаполненияСтрокиПоПартии, Знач КонтрольноеКоличество, ЭтоСчетПередачи)
	
	СтрокиССуммамиНДС = СуммыПоПоступлениям.НайтиСтроки(ПараметрыОтбора);
	СчетНДСПоУмолчанию = ПараметрыДляЗаполненияСтрокиПоПартии.СчетНДСПоУмолчанию;
	Для Каждого СтрокаСНДС Из СтрокиССуммамиНДС Цикл
		
		Если СтрокаСНДС.Количество = 0 И Не ПараметрыДляЗаполненияСтрокиПоПартии.СуммовойУчет Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаСФ = НДСУчтенныйВСтоимости.Добавить(); 
		//Для счетов в иерархии 45 в поле "Склад" из запроса попадает значение субконто "Контрагент"; 
		Если ЭтоСчетПередачи Тогда 
			СтрокаСФ.Подразделение	= СтрокаСАналитикой.Подразделение;
			СтрокаСФ.Комиссионер	= СтрокаСАналитикой.Склад;
			СтрокаСФ.Склад			= СтрокаСАналитикой.СкладПоступления;
		Иначе 
			ЗаполнитьЗначенияСвойств(СтрокаСФ, СтрокаСАналитикой, "Склад, Подразделение");
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаСФ, СтрокаСНДС); 
		
		СтрокаСФ.СчетУчета = СтрокаСАналитикой.Счет;
		СтрокаСФ.Партия = СтрокаСНДС.СчетФактура;   
		СтрокаСФ.ДокументПоступления = СтрокаСНДС.ДокументПоступления;
		
		Если КонтрольноеКоличество >= СтрокаСНДС.Количество Тогда
			КонтрольноеКоличество = КонтрольноеКоличество - СтрокаСНДС.Количество;
			СтрокаСФ.СуммаНДС			 = СтрокаСНДС.СуммаНДС;
			СтрокаСНДС.Количество	 = 0;
			СтрокаСНДС.СуммаБезНДС	 = 0;
			СтрокаСНДС.СуммаНДС		 = 0;
			СтрокаСНДС.Всего		 = 0;
			КонтрольноеКоличество	 = КонтрольноеКоличество - СтрокаСНДС.Количество;
		Иначе
			СтрокаСф.Количество		 = КонтрольноеКоличество;
			СтрокаСФ.СуммаБезНДС	 = Окр(СтрокаСНДС.СуммаБезНДС / СтрокаСНДС.Количество * КонтрольноеКоличество, 2);
			СтрокаСФ.СуммаНДС		 = Окр(СтрокаСНДС.СуммаНДС / СтрокаСНДС.Количество * КонтрольноеКоличество, 2);
			СтрокаСФ.Всего			 = Окр(СтрокаСНДС.Всего / СтрокаСНДС.Количество * КонтрольноеКоличество, 2);
			СтрокаСНДС.Количество	 = СтрокаСНДС.Количество - КонтрольноеКоличество;
			СтрокаСНДС.СуммаБезНДС	 = СтрокаСНДС.СуммаБезНДС - СтрокаСф.СуммаБезНДС;
			СтрокаСНДС.СуммаНДС		 = СтрокаСНДС.СуммаНДС - СтрокаСФ.СуммаНДС;
			СтрокаСНДС.Всего		 = СтрокаСНДС.Всего - СтрокаСФ.Всего;
			КонтрольноеКоличество	 = 0;
		КонецЕсли; 
		
		Если Не ЗначениеЗаполнено(СтрокаСФ.СчетУчетаНДС) Тогда
			СтрокаСФ.СчетУчетаНДС = СчетНДСПоУмолчанию;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаСФ.СтавкаНДС) Тогда
			СтрокаСФ.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
		КонецЕсли;
		
		Если КонтрольноеКоличество = 0 Тогда
			Прервать;
		КонецЕсли; 
		
	КонецЦикла;
	
КонецПроцедуры

Функция ОстаткиПоСчетамКапВложений(СтруктураПараметров)
	
	Запрос = Новый Запрос(); 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.КоличествоОстаток КАК Количество,
	|	0 КАК Сумма
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&ГраницаОстатков, Счет В (&СчетаНПС), &ВидыСубконтоНПС, Организация = &Организация) КАК ХозрасчетныйОстатки
	|ГДЕ
	|	ХозрасчетныйОстатки.КоличествоОстаток > 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	0,
	|	ХозрасчетныйОстатки.СуммаОстаток
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&ГраницаОстатков, Счет В (&СчетаКапВложений), , Организация = &Организация) КАК ХозрасчетныйОстатки
	|ГДЕ
	|	ХозрасчетныйОстатки.СуммаОстаток > 0";
	Для Каждого ЗаменаТекста Из СтруктураПараметров.ЗаменаТекстаВЗапросеКапВложений Цикл
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&" + ЗаменаТекста.Ключ, ЗаменаТекста.Значение);
	КонецЦикла;
	
	ЗаполнитьПараметрыЗапроса(Запрос, СтруктураПараметров);
	Результат = Запрос.Выполнить();
	
	Возврат Результат;
	
КонецФункции

Функция ОстаткиПоСчетамУчетаТоваров(СтруктураПараметров)
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	|	ХозрасчетныйОстатки.КоличествоОстаток КАК Количество,
