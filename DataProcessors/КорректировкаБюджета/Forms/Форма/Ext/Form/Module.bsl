	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.ШрифтНаправлениеДеятельностиБюджетаНаклонный);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветОтрицательногоЧисла);
	
КонецПроцедуры

#КонецОбласти

#Область Детализация

&НаСервере
Процедура ДобавитьКолонкиДетализацииНаФорму()
	
	// Добавим элементы на форму
	ТекущийЭлементДляВставки = Элементы.Найти("ДеревоБюджетаГруппаГод");
	ЭлементРодитель          = Элементы.Найти("ДеревоБюджета");
	ТипНовогоЭлемента        = Тип("ПолеФормы");
	
	Для Каждого Колонка Из КолонкиДетализации Цикл
		ИмяЭлемента = "ДеревоБюджета" + Колонка.ИмяКолонки;
		
		Если Элементы.Найти(ИмяЭлемента) <> Неопределено Тогда
			// Колонки уже созданы, повторно создавать не требуется
			Продолжить;
		КонецЕсли;
		
		ГруппаКолонокПериода = Элементы.Вставить("Группа" + Колонка.ИмяКолонки, Тип("ГруппаФормы"), ЭлементРодитель, ТекущийЭлементДляВставки);
		ГруппаКолонокПериода.Вид = ВидГруппыФормы.ГруппаКолонок;
		ГруппаКолонокПериода.Группировка = ГруппировкаКолонок.Горизонтальная;
		ГруппаКолонокПериода.Заголовок = Колонка.Заголовок;
		ГруппаКолонокПериода.ОтображатьВШапке = Истина;
		ГруппаКолонокПериода.ГоризонтальноеПоложениеВШапке = ГоризонтальноеПоложениеЭлемента.Центр;
		
		ЭлементДляВставки = Элементы.Вставить(ИмяЭлемента, ТипНовогоЭлемента, ГруппаКолонокПериода);
		ЭлементДляВставки.ПутьКДанным = "ДеревоБюджета." + Колонка.ИмяКолонки;
		ЭлементДляВставки.Заголовок = "Сумма";
		ЭлементДляВставки.Вид = ВидПоляФормы.ПолеВвода;
		ЭлементДляВставки.ГоризонтальноеПоложениеВШапке = ГоризонтальноеПоложениеЭлемента.Право;
		ЭлементДляВставки.Ширина = 10;
		ЭлементДляВставки.ВыделятьОтрицательные = Истина;
		ЭлементДляВставки.УстановитьДействие("ПриИзменении", "ДеревоБюджетаСуммаПриИзменении");
		ЭлементДляВставки.Формат = "ЧЦ=15; ЧДЦ=2; ЧН=0,00";
		ЭлементДляВставки.ФорматРедактирования = "ЧЦ=15; ЧДЦ=2; ЧН=0,00";
		
		ЭлементДляВставки = Элементы.Вставить(ИмяЭлемента + "Корректировка", ТипНовогоЭлемента, ГруппаКолонокПериода);
		ЭлементДляВставки.ПутьКДанным = "ДеревоБюджета." + Колонка.ИмяКолонки + "Корректировка";
		ЭлементДляВставки.Заголовок = "Корректировка";
		ЭлементДляВставки.Вид = ВидПоляФормы.ПолеВвода;
		ЭлементДляВставки.ГоризонтальноеПоложениеВШапке = ГоризонтальноеПоложениеЭлемента.Право;
		ЭлементДляВставки.Ширина = 10;
		ЭлементДляВставки.ВыделятьОтрицательные = Ложь;
		
		ЭлементДляВставки.ТолькоПросмотр = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитыФормыКолонкиДетализации()
	
	НовыеРеквизитыФормы = Новый Массив;
	УдаляемыеРеквизиты = Новый Массив;
	
	// Удалим ранее добавленные колонки
	Для Каждого Колонка Из КолонкиДетализации Цикл
		УдаляемыеРеквизиты.Добавить("ДеревоБюджета." + Колонка.ИмяКолонки);
		УдаляемыеРеквизиты.Добавить("ДеревоБюджета." + Колонка.ИмяКолонки + "Корректировка");
		УдаляемыеРеквизиты.Добавить("ДеревоБюджета." + Колонка.ИмяКолонки + "ДоКорректировки");
		УдаляемыеРеквизиты.Добавить("ЕстьКорректировка" + Колонка.ИмяКолонки);
	КонецЦикла;
	
	РеквизитыБюджета = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Бюджет, "Детализация,Период");
	БюджетДоходовРасходов.ЗаполнитьКолонкиДетализации(КолонкиДетализации, РеквизитыБюджета);
	
	// Добавим новые реквизиты по колонкам
	Для Каждого Колонка Из КолонкиДетализации Цикл
		НовыйРеквизитФормы = Новый РеквизитФормы(
			Колонка.ИмяКолонки,
			ОбщегоНазначения.ОписаниеТипаЧисло(15, 2),
			"ДеревоБюджета",
			Колонка.Заголовок,
			Истина);
		НовыеРеквизитыФормы.Добавить(НовыйРеквизитФормы);
		
		НовыйРеквизитФормы = Новый РеквизитФормы(
			Колонка.ИмяКолонки + "Корректировка",
			ОбщегоНазначения.ОписаниеТипаЧисло(15, 2),
			"ДеревоБюджета",
			Колонка.Заголовок + "(корректировка)",
			Истина);
		НовыеРеквизитыФормы.Добавить(НовыйРеквизитФормы);
		
		НовыйРеквизитФормы = Новый РеквизитФормы(
			Колонка.ИмяКолонки + "ДоКорректировки",
			ОбщегоНазначения.ОписаниеТипаЧисло(15, 2),
			"ДеревоБюджета",
			Колонка.Заголовок + "(до корректировки)",
			Истина);
			
		НовыеРеквизитыФормы.Добавить(НовыйРеквизитФормы);
		
		НовыйРеквизитФормы = Новый РеквизитФормы(
			"ЕстьКорректировка" + Колонка.ИмяКолонки,
			Новый ОписаниеТипов("Булево"),
			,
			,
			Истина);
			
		НовыеРеквизитыФормы.Добавить(НовыйРеквизитФормы);
		
	КонецЦикла;
	
	ИзменитьРеквизиты(НовыеРеквизитыФормы, УдаляемыеРеквизиты);
	
КонецПроцедуры

&НаСервере
Процедура СоздатьКолонкиДереваБюджета()
	
	ДобавитьРеквизитыФормыКолонкиДетализации();
	ДобавитьКолонкиДетализацииНаФорму();
	
КонецПроцедуры

#КонецОбласти

#Область Печать

&НаКлиенте
Процедура ВывестиТабличныйДокументНаПечать(ТабличныйДокумент, ИмяПечатнойФормы)
	
	КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_КорректировкаБюджета";
	НазваниеПечатнойФормы = НСтр("ru = 'Корректировка бюджета'");
	ЗаголовокФормы = Строка(ДокументСсылка);
	Если ИмяПечатнойФормы = "" Тогда
		КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_БюджетДоходовРасходов";
		НазваниеПечатнойФормы = НСтр("ru = 'Бюджет доходов и расходов'");
		ЗаголовокФормы = СтрШаблон(НСтр("ru = 'Бюджет доходов и расходов на %1 г.'"), Формат(Объект.Период, "ДФ=гггг"));
	КонецЕсли;
	
	ТабличныйДокумент.ТолькоПросмотр       = Истина;
	ТабличныйДокумент.АвтоМасштаб          = Истина;
	ТабличныйДокумент.ОриентацияСтраницы   = ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.ОтображатьЗаголовки  = Ложь;
	ТабличныйДокумент.ОтображатьСетку      = Ложь;
	ТабличныйДокумент.КлючПараметровПечати = КлючПараметровПечати;
	ИдентификаторПечатнойФормы = "ПечатнаяФорма";
	
	ПараметрыФормыПечати = УправлениеПечатьюКлиент.ПараметрыПечати();
	ПараметрыФормыПечати.ВладелецФормы  = ЭтотОбъект;
	ПараметрыФормыПечати.ЗаголовокФормы = ЗаголовокФормы;
	
	КоллекцияПечатныхФорм               = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм(ИдентификаторПечатнойФормы);
	ПечатнаяФорма                       = УправлениеПечатьюКлиент.ОписаниеПечатнойФормы(КоллекцияПечатныхФорм, ИдентификаторПечатнойФормы);
	ПечатнаяФорма.СинонимМакета         = НазваниеПечатнойФормы;
	ПечатнаяФорма.ТабличныйДокумент     = ТабличныйДокумент;
	ПечатнаяФорма.ИмяФайлаПечатнойФормы = НазваниеПечатнойФормы;
	
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм, , ПараметрыФормыПечати);

КонецПроцедуры

&НаСервере
Функция СформироватьПечатнуюФормуНаСервере(ИмяПечатнойФормы)
	
	ИсходныйБюджет = ИсходныйБюджет(ДокументСсылка);
	Если ИмяПечатнойФормы = "КорректировкаБюджета" Тогда
		ПараметрыОбъекта = Новый Структура;
		ПараметрыОбъекта.Вставить("Ссылка", ДокументСсылка);
		ПараметрыОбъекта.Вставить("Бюджет", ИсходныйБюджет);
		ТабличныйДокумент = Документы.КорректировкаБюджета.СформироватьПечатнуюФорму(ПараметрыОбъекта);
	ИначеЕсли ИмяПечатнойФормы = "БюджетДоходовИРасходов" Тогда
		ПараметрыОбъекта = Новый Структура;
		ПараметрыОбъекта.Вставить("Ссылка", ИсходныйБюджет);
		ТабличныйДокумент = Документы.Бюджет.СформироватьПечатнуюФорму(ПараметрыОбъекта);
	Иначе
		ТабличныйДокумент = Новый ТабличныйДокумент;
	КонецЕсли;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

#КонецОбласти

#Область ПостроениеДерева

&НаСервере
Процедура ПостроитьДеревоБюджета()
	
	// Очистим дерево
	ДеревоБюджета.ПолучитьЭлементы().Очистить();
	
	// Остаток на начало
	РазделОстатокНачало = ДобавитьРаздел(ДеревоБюджета, ИмяРазделОстатокНачало());
	ИдентификаторОстатокНачало = РазделОстатокНачало.ПолучитьИдентификатор();
	ВывестиОстатокНачало(РазделОстатокНачало);
	
	// Доходы
	РазделДоходы = ДобавитьРаздел(ДеревоБюджета, ИмяРазделДоходы());
	ИдентификаторДоходы = РазделДоходы.ПолучитьИдентификатор();
	ВывестиСтрокиДохода(РазделДоходы);
	
	// Расходы
	РазделаРасходы = ДобавитьРаздел(ДеревоБюджета, ИмяРазделРасходы());
	ИдентификаторРасходы = РазделаРасходы.ПолучитьИдентификатор();
	ВывестиСтрокаРасхода(РазделаРасходы);
	
	// Остатки
	РазделОстатки = ДобавитьРаздел(ДеревоБюджета, ИмяРазделОстатокКонец());
	ИдентификаторОстатокКонец = РазделОстатки.ПолучитьИдентификатор();
	
	// Выведем итоги
	РассчитатьИтогиПоВсемРазделам();
	
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаСервере
Функция ДобавитьРаздел(Дерево, ИмяРаздела)
	
	СтрокаРаздела           = Дерево.ПолучитьЭлементы().Добавить();
	СтрокаРаздела.Раздел    = ИмяРаздела;
	СтрокаРаздела.ЭтоРаздел = Истина;
	СтрокаРаздела.КартинкаСтроки = 2;
	Возврат СтрокаРаздела;
	
КонецФункции

&НаСервере
Процедура ВывестиОстатокНачало(РазделОстатки)
	
	ИмяПервойКолонки = КолонкиДетализации[0].ИмяКолонки;
	РазделОстатки[ИмяПервойКолонки] = Объект.ОстатокНаНачало;
	РазделОстатки.СуммаГод = Объект.ОстатокНаНачало;
	
	РазделОстатки[ИмяПервойКолонки + "ДоКорректировки"] = Объект.ОстатокНаНачалоДоКорректировки;
	РазделОстатки.СуммаГодДоКорректировки = Объект.ОстатокНаНачалоДоКорректировки;
	
	РазделОстатки[ИмяПервойКолонки + "Корректировка"] = Объект.ОстатокНаНачалоКорректировка;
	РазделОстатки.СуммаГодКорректировка = Объект.ОстатокНаНачалоКорректировка;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСтрокиДоходовСИерархией(Строка, ТаблицаСтруктурыДоходов)
	
	Для Каждого СтрокаДоходов Из ТаблицаСтруктурыДоходов Цикл
		НоваяСтрока                 = Строка.ПолучитьЭлементы().Добавить();
		НоваяСтрока.Раздел          = ИмяРазделДоходы();
		НоваяСтрока.ЭтоСтатьяДДС    = Истина;
		НоваяСтрока.СтатьяДДС       = СтрокаДоходов.СтатьяДохода;
		НоваяСтрока.ВидСтатьиДДС    = Перечисления.ВидСтатьиДвиженияДенег.Доход;
		НоваяСтрока.ЭтоГруппаСтатей = СтрокаДоходов.ЭтоГруппа;
		
		СтрокиДоходовПоСтатье = Объект.Доходы.НайтиСтроки(
			Новый Структура("СтатьяДохода", СтрокаДоходов.СтатьяДохода));
		ВывестиСуммыВСтроку(НоваяСтрока, СтрокиДоходовПоСтатье);
		
		Если Не СтрокаДоходов.ЭтоГруппа Тогда
			НоваяСтрока.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
		Иначе
			НоваяСтрока.КартинкаСтроки = БиблиотекаКартинок.Папка;
			НоваяТаблицаСтруктурыДоходов = Объект.СтруктураДоходов.Выгрузить(
				Новый Структура("Родитель", СтрокаДоходов.СтатьяДохода));
			ВывестиСтрокиДоходовСИерархией(НоваяСтрока, НоваяТаблицаСтруктурыДоходов);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСтрокиДохода(РазделДоходы)
	
	СтруктураПоиска = Новый Структура("Родитель", Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
	ТаблицаСтруктурыДоходов = Объект.СтруктураДоходов.Выгрузить(СтруктураПоиска);
	ВывестиСтрокиДоходовСИерархией(РазделДоходы, ТаблицаСтруктурыДоходов);
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСуммыВСтроку(СтрокаДерева, СтрокиССуммами)
	
	Для Каждого СтрокаССуммами Из СтрокиССуммами Цикл
		Если Не ЗначениеЗаполнено(СтрокаССуммами.ДатаПланирования) Тогда
			// У суммы за год нет даты планирования
			СтрокаДерева.СуммаГод = СтрокаССуммами.Сумма;
			СтрокаДерева.СуммаГодДоКорректировки = СтрокаССуммами.СуммаДоКорректировки;  
			СтрокаДерева.СуммаГодКорректировка = СтрокаССуммами.СуммаКорректировки;
		Иначе
			Колонки = КолонкиДетализации.НайтиСтроки(Новый Структура("Дата", СтрокаССуммами.ДатаПланирования));
			Если Колонки.Количество() > 0 Тогда
				СтрокаДерева[Колонки[0].ИмяКолонки] = СтрокаССуммами.Сумма;
				СтрокаДерева[Колонки[0].ИмяКолонки + "ДоКорректировки"] = СтрокаССуммами.СуммаДоКорректировки;
				СтрокаДерева[Колонки[0].ИмяКолонки + "Корректировка"] = СтрокаССуммами.СуммаКорректировки;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСтрокиРасходовПоНаправлениюДеятельности(Строка, Отбор)
	
	ТаблицаСтруктураРасходов = Объект.СтруктураРасходов.Выгрузить(Отбор);
	Для Каждого СтрокаРасходов Из ТаблицаСтруктураРасходов Цикл
		СтатьяРасхода = СтрокаРасходов.СтатьяРасхода;
		Если Не ЗначениеЗаполнено(СтатьяРасхода) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Строка.ПолучитьЭлементы().Добавить();
		НоваяСтрока.Раздел       = ИмяРазделРасходы();
		НоваяСтрока.ЭтоСтатьяДДС = Истина;
		НоваяСтрока.СтатьяДДС    = СтатьяРасхода;
		НоваяСтрока.ВидСтатьиДДС = Перечисления.ВидСтатьиДвиженияДенег.Расход;
		НоваяСтрока.ЭтоГруппаСтатей = СтрокаРасходов.ЭтоГруппа;
		
		СтрокиРасходов = Объект.Расходы.НайтиСтроки(
			Новый Структура("НаправлениеДеятельности, СтатьяРасхода", Отбор.НаправлениеДеятельности, СтатьяРасхода));
		ВывестиСуммыВСтроку(НоваяСтрока, СтрокиРасходов);
		
		Если Не СтрокаРасходов.ЭтоГруппа Тогда
			НоваяСтрока.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
		Иначе
			НоваяСтрока.КартинкаСтроки = БиблиотекаКартинок.Папка;
			НовыйОтбор = ОбщегоНазначения.СкопироватьРекурсивно(Отбор);
			НовыйОтбор.Родитель = СтатьяРасхода;
			ВывестиСтрокиРасходовПоНаправлениюДеятельности(НоваяСтрока, НовыйОтбор);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиСтрокаРасхода(РазделРасходы)
	
	ТаблицаПоНаправлениямДеятельности = Объект.СтруктураРасходов.Выгрузить();
	ТаблицаПоНаправлениямДеятельности.Свернуть("НаправлениеДеятельности");
	Для Каждого НаправлениеДеятельности Из ТаблицаПоНаправлениямДеятельности.ВыгрузитьКолонку("НаправлениеДеятельности") Цикл
		// Выводим направление деятельности
		НоваяСтрокаНаправлениеДеятельности = РазделРасходы.ПолучитьЭлементы().Добавить();
		НоваяСтрокаНаправлениеДеятельности.Раздел                     = ИмяРазделРасходы();
		НоваяСтрокаНаправлениеДеятельности.ЭтоНаправлениеДеятельности = Истина;
		НоваяСтрокаНаправлениеДеятельности.НаправлениеДеятельности    = НаправлениеДеятельности;
		НоваяСтрокаНаправлениеДеятельности.КартинкаСтроки = БиблиотекаКартинок.ПриложитьФайл;
		Отбор = Новый Структура("НаправлениеДеятельности", НаправлениеДеятельности);
		ВывестиСуммыВСтроку(НоваяСтрокаНаправлениеДеятельности, Объект.РасходыПоНаправлениямДеятельности.НайтиСтроки(Отбор));
		
		// Выводим подчиненные статьи расходов
		Отбор = Новый Структура(
			"НаправлениеДеятельности, Родитель",
			НаправлениеДеятельности, Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
		ВывестиСтрокиРасходовПоНаправлениюДеятельности(НоваяСтрокаНаправлениеДеятельности, Отбор);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РазвернутьДерево()
	
	Элементы.ДеревоБюджета.Развернуть(ИдентификаторДоходы, Истина);
	Элементы.ДеревоБюджета.Развернуть(ИдентификаторРасходы, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область ИнтерактивноеДобавлениеСтрокиВДерево

&НаКлиенте
Процедура СкопироватьСтрокуДерева(Строка)
	
	Если Строка.ЭтоРаздел Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаРодитель = Строка.ПолучитьРодителя();
	ТекущийИндекс = СтрокаРодитель.ПолучитьЭлементы().Индекс(Строка);
	НоваяСтрока = СтрокаРодитель.ПолучитьЭлементы().Вставить(ТекущийИндекс);
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
	СтрокаРодитель.ПолучитьЭлементы().Сдвинуть(ТекущийИндекс, 1);
	Если Строка.ЭтоНаправлениеДеятельности Тогда
		Идентификатор = НоваяСтрока.ПолучитьИдентификатор();
		Элементы.ДеревоБюджета.Развернуть(Идентификатор);
	КонецЕсли;
	
	// Установим курсор и начнем редактирование строки
	Элементы.ДеревоБюджета.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	Элементы.ДеревоБюджета.ИзменитьСтроку();
	
КонецПроцедуры

&НаКлиенте
Функция ДобавитьНовуюСтрокуДереваДоход(Строка)
	
	// Есть два варианта добавления строки дохода, в зависимости от позиционирования курсора:
	// 1. Курсор на разделе - добавляем в конец
	// 2. Курсор на статье - добавляем сразу после строки
	Если Строка.ЭтоРаздел Или Строка.ЭтоГруппаСтатей Тогда
		НоваяСтрока = Строка.ПолучитьЭлементы().Добавить();
	Иначе
		СтрокаРодитель = Строка.ПолучитьРодителя();
		ТекущийИндекс  = СтрокаРодитель.ПолучитьЭлементы().Индекс(Строка);
		НоваяСтрока    = СтрокаРодитель.ПолучитьЭлементы().Вставить(ТекущийИндекс);
		СтрокаРодитель.ПолучитьЭлементы().Сдвинуть(ТекущийИндекс, 1);
	КонецЕсли;
	
	НоваяСтрока.ЭтоСтатьяДДС   = Истина;
	НоваяСтрока.Раздел         = ИмяРазделДоходы();
	НоваяСтрока.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
	
	ВидыСтатейДДС = Новый Массив;
	ВидыСтатейДДС.Добавить(ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.Доход"));
	ВидыСтатейДДС.Добавить(ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.ДоходРасход"));
	
	НоваяСтрока.ВидСтатьиДДС = Новый ФиксированныйМассив(ВидыСтатейДДС);
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Функция ДобавитьНовуюСтрокуДереваРасход(Строка)
	
	// Есть четыре варианта добавления строки расхода, в зависимости от позиционирования курсора:
	// 1. Курсор на разделе - добавляем направление деятельности в конец
	// 2. Курсор на направлении деятельности - добавляем статью в конец
	// 3. Курсор на группе статей - добавляем статью в конец группы
	// 4. Курсор на статье - добавляем сразу после строки
	
	// Добавление направление деятельности
	Если Строка.ЭтоРаздел Тогда
		НоваяСтрока = Строка.ПолучитьЭлементы().Добавить();
		ЗаполнитьСтрокуНаправленияДеятельности(НоваяСтрока);
	ИначеЕсли Строка.ЭтоНаправлениеДеятельности Или Строка.ЭтоГруппаСтатей Тогда
		НоваяСтрока = Строка.ПолучитьЭлементы().Добавить();
		ЗаполнитьСтатьюРасходов(НоваяСтрока);
	Иначе
		СтрокаРодитель = Строка.ПолучитьРодителя();
		ТекущийИндекс  = СтрокаРодитель.ПолучитьЭлементы().Индекс(Строка);
		НоваяСтрока    = СтрокаРодитель.ПолучитьЭлементы().Вставить(ТекущийИндекс);
		ЗаполнитьСтатьюРасходов(НоваяСтрока);
		СтрокаРодитель.ПолучитьЭлементы().Сдвинуть(ТекущийИндекс, 1);
	КонецЕсли;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьНовуюСтрокуДерева(Строка)
	
	Элементы.ДеревоБюджета.ТекущийЭлемент = Элементы.ДеревоБюджетаРаздел;
	
	Если Строка.Раздел = ИмяРазделДоходы() Тогда
		НоваяСтрока = ДобавитьНовуюСтрокуДереваДоход(Строка);
	ИначеЕсли Строка.Раздел = ИмяРазделРасходы() Тогда
		НоваяСтрока = ДобавитьНовуюСтрокуДереваРасход(Строка);
	Иначе
		Возврат;
	КонецЕсли;
	
	// Установим курсор и начнем редактирование строки
	Элементы.ДеревоБюджета.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	Элементы.ДеревоБюджета.ИзменитьСтроку();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЭтоГруппа(Знач СтатьяДДС)
	
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтатьяДДС, "ЭтоГруппа");
	
КонецФункции

&НаКлиенте
Процедура ДобавитьСтатьюДДСЗавершение(СтатьяДДС, ДополнительныеПараметры) Экспорт
	
	Если СтатьяДДС = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Родитель            = ДополнительныеПараметры.Родитель;
	Строка              = Родитель.ПолучитьЭлементы().Добавить();
	Строка.Раздел       = ДополнительныеПараметры.Раздел;
	Строка.ЭтоСтатьяДДС = Истина;
	Строка.СтатьяДДС    = СтатьяДДС;
	Строка.ВидСтатьиДДС = ДополнительныеПараметры.ВидСтатьиДДС;
	
	Если Не ЭтоГруппа(СтатьяДДС) Тогда
		Строка.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
	Иначе
		Строка.ЭтоГруппаСтатей = Истина;
		Строка.КартинкаСтроки = БиблиотекаКартинок.Папка;
		
		ИдентификаторСтроки = Строка.ПолучитьИдентификатор();
		ПараметрыЗаполнения = Новый Структура("Раздел, СтатьяДДС, ВидСтатьиДДС");
		ЗаполнитьЗначенияСвойств(ПараметрыЗаполнения, ДополнительныеПараметры);
		ПараметрыЗаполнения.СтатьяДДС = СтатьяДДС;
		ЗаполнитьВсеЭлементыНаСервере(ИдентификаторСтроки, ПараметрыЗаполнения);
		Элементы.ДеревоБюджета.Развернуть(ИдентификаторСтроки, Истина);
	КонецЕсли;
	Элементы.ДеревоБюджета.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ТаблицаСтатейЗатратПоГруппе(ГруппаСтатей)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Родитель", ГруппаСтатей);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатьиДвиженияДенежныхСредств.Ссылка КАК Ссылка,
	|	СтатьиДвиженияДенежныхСредств.Родитель КАК Родитель,
	|	СтатьиДвиженияДенежныхСредств.ЭтоГруппа КАК ЭтоГруппа,
	|	СтатьиДвиженияДенежныхСредств.ВидСтатьиДДС КАК ВидСтатьиДДС
	|ИЗ
	|	Справочник.СтатьиДвиженияДенежныхСредств КАК СтатьиДвиженияДенежныхСредств
	|ГДЕ
	|	СтатьиДвиженияДенежныхСредств.Родитель В ИЕРАРХИИ(&Родитель)
	|	И НЕ СтатьиДвиженияДенежныхСредств.ПометкаУдаления
	|	И НЕ ЕСТЬNULL(СтатьиДвиженияДенежныхСредств.НеПоказыватьВСписках, ЛОЖЬ)";
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

&НаСервере
Процедура ЗаполнитьВсеЭлементыНаСервере(ИдентификаторСтроки, ПараметрыЗаполнения)
	
	СтрокаДерева = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторСтроки);
	ГруппаСтатей = ПараметрыЗаполнения.СтатьяДДС;
	ТаблицаСтатейЗатратПоГруппе = ТаблицаСтатейЗатратПоГруппе(ГруппаСтатей);
	ДобавитьВДеревоЭлементыГруппы(ТаблицаСтатейЗатратПоГруппе, ГруппаСтатей, СтрокаДерева, ПараметрыЗаполнения);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьВДеревоЭлементыГруппы(ТаблицаСтатейЗатратПоГруппе, ГруппаСтатей, СтрокаДерева, ПараметрыЗаполнения)
	
	ТаблицаПоГруппе = ТаблицаСтатейЗатратПоГруппе.Скопировать(Новый Структура("Родитель", ГруппаСтатей));
	Для Каждого Строка Из ТаблицаПоГруппе Цикл
		Если Не Строка.ЭтоГруппа И ПараметрыЗаполнения.ВидСтатьиДДС.Найти(Строка.ВидСтатьиДДС) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = СтрокаДерева.ПолучитьЭлементы().Добавить();
		НоваяСтрока.Раздел       = ПараметрыЗаполнения.Раздел;
		НоваяСтрока.ЭтоСтатьяДДС = Истина;
		НоваяСтрока.СтатьяДДС    = Строка.Ссылка;
		НоваяСтрока.ВидСтатьиДДС = ПараметрыЗаполнения.ВидСтатьиДДС;
		НоваяСтрока.ЭтоГруппаСтатей = Строка.ЭтоГруппа;
		Если Строка.ЭтоГруппа Тогда
			НоваяСтрока.КартинкаСтроки = БиблиотекаКартинок.Папка;
		Иначе
			НоваяСтрока.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
		КонецЕсли;
		Если Строка.ЭтоГруппа Тогда
			ДобавитьВДеревоЭлементыГруппы(ТаблицаСтатейЗатратПоГруппе, Строка.Ссылка, НоваяСтрока, ПараметрыЗаполнения);
			Если НоваяСтрока.ПолучитьЭлементы().Количество() = 0 Тогда
				Индекс = СтрокаДерева.ПолучитьЭлементы().Индекс(НоваяСтрока);
				СтрокаДерева.ПолучитьЭлементы().Удалить(Индекс);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьНаправлениеДеятельностиЗавершение(НаправлениеДеятельности, ДополнительныеПараметры) Экспорт
	
	Если НаправлениеДеятельности = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Родитель = ДополнительныеПараметры.Родитель;
	Строка   = Родитель.ПолучитьЭлементы().Добавить();
	Строка.НаправлениеДеятельности = НаправлениеДеятельности;
	
	ЗаполнитьСтрокуНаправленияДеятельности(Строка);
	
	Элементы.ДеревоБюджета.ТекущаяСтрока = Строка.ПолучитьИдентификатор();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСтрокуНаправленияДеятельности(Строка)

	Строка.Раздел = ИмяРазделРасходы();
	Строка.ЭтоНаправлениеДеятельности = Истина;
	Строка.КартинкаСтроки = БиблиотекаКартинок.ПриложитьФайл;
	Идентификатор = Строка.ПолучитьИдентификатор();
	Элементы.ДеревоБюджета.Развернуть(Идентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСтатьюРасходов(Строка)
	
	Строка.ЭтоСтатьяДДС = Истина;
	Строка.Раздел       = ИмяРазделРасходы();
	Строка.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
	
	ВидыСтатейДДС = Новый Массив;
	ВидыСтатейДДС.Добавить(ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.Расход"));
	ВидыСтатейДДС.Добавить(ПредопределенноеЗначение("Перечисление.ВидСтатьиДвиженияДенег.ДоходРасход"));
	
	Строка.ВидСтатьиДДС = Новый ФиксированныйМассив(ВидыСтатейДДС);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовуюСтатьюДДС(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	// Обрабатывает выполнение команды Создать, выбранной пользователем в списке выбора - см. СтатьяДДСДанныеВыбораКомандаСоздать()
	// Следует вызывать из обработчика ОбработкаВыбора
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Строка") Или ПустаяСтрока(ВыбранноеЗначение) Тогда
		Возврат;
	КонецЕсли;
	
	// Обработка команды Создать списка выбора
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	ТекущиеДанные.КартинкаСтроки = БиблиотекаКартинок.Реквизит;
	НоваяСтатьяДДС = СоздатьНоваяСтатьяДДСБыстро(ВыбранноеЗначение, ТекущиеДанные.Раздел);
	
	Если НоваяСтатьяДДС <> Неопределено Тогда
		
		ТекущиеДанные.СтатьяДДС = НоваяСтатьяДДС;
		
	Иначе
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РежимВыбора",     Истина);
		ПараметрыФормы.Вставить("ТекстЗаполнения", ВыбранноеЗначение);
		ОткрытьФорму("Справочник.СтатьиДвиженияДенежныхСредств.ФормаОбъекта", ПараметрыФормы, Элемент);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СоздатьНоваяСтатьяДДСБыстро(Наименование, Раздел)
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Наименование", Наименование);
	Если Раздел = ИмяРазделДоходы() Тогда
		ВидСтатьиДДС = Перечисления.ВидСтатьиДвиженияДенег.Доход;
	Иначе
		ВидСтатьиДДС = Перечисления.ВидСтатьиДвиженияДенег.Расход;
	КонецЕсли;
	ЗначенияЗаполнения.Вставить("ВидСтатьиДДС", ВидСтатьиДДС);
	НовыйОбъект = Справочники.СтатьиДвиженияДенежныхСредств.СоздатьЭлемент();
	НовыйОбъект.Заполнить(ЗначенияЗаполнения);
	
	Попытка
		НовыйОбъект.Записать();
	Исключение
		// Не является значимой проблемой, будет обработано интерактивно вызывающим кодом
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат НовыйОбъект.Ссылка;
	
КонецФункции

&НаСервереБезКонтекста
Функция СтатьяДДСДанныеВыбораКомандаСоздать(Знач ПараметрыПолученияДанных, Знач ОкончаниеВводаТекста)
	
	ДанныеВыбора = Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьДанныеВыбора(ПараметрыПолученияДанных);
	
	Если Не ЗначениеЗаполнено(ДанныеВыбора) Тогда
		
		// Предложим создать - непосредственно в списке
		// Выбор пользователем этой опции обрабатывается в СоздатьНовуюСтатьюДДС
		СтрокаПоиска = СокрЛП(ПараметрыПолученияДанных.СтрокаПоиска);
		ПредставлениеНового = СтрШаблон(НСтр("ru='Создать: %1'"), СтрокаПоиска);
		ДанныеВыбора.Добавить(СтрокаПоиска, ПредставлениеНового);
		Если ОкончаниеВводаТекста Тогда
			// Добавляем вторую строку, чтобы в этом режиме не срабатывал автовыбор единственной строки.
			ДанныеВыбора.Добавить("");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДанныеВыбора;
	
КонецФункции

&НаСервереБезКонтекста
Функция НаправленияДеятельностиДанныеВыбораКомандаСоздать(Знач ПараметрыПолученияДанных, Знач ОкончаниеВводаТекста)
	
	ДанныеВыбора = Справочники.НаправленияДеятельности.ПолучитьДанныеВыбора(ПараметрыПолученияДанных);
	
	Если Не ЗначениеЗаполнено(ДанныеВыбора) Тогда
		
		// Предложим создать - непосредственно в списке
		// Выбор пользователем этой опции обрабатывается в СоздатьНовоеНаправлениеДеятельности
		СтрокаПоиска = СокрЛП(ПараметрыПолученияДанных.СтрокаПоиска);
		ПредставлениеНового = СтрШаблон(НСтр("ru='Создать: %1'"), СтрокаПоиска);
		ДанныеВыбора.Добавить(СтрокаПоиска, ПредставлениеНового);
		Если ОкончаниеВводаТекста Тогда
			// Добавляем вторую строку, чтобы в этом режиме не срабатывал автовыбор единственной строки.
			ДанныеВыбора.Добавить("");
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДанныеВыбора;
	
КонецФункции

&НаКлиенте
Процедура СоздатьНовоеНаправлениеДеятельности(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	// Обрабатывает выполнение команды Создать, выбранной пользователем в списке выбора - см. НаправленияДеятельностиДанныеВыбораКомандаСоздать()
	// Следует вызывать из обработчика ОбработкаВыбора
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Строка") Или ПустаяСтрока(ВыбранноеЗначение) Тогда
		Возврат;
	КонецЕсли;
	
	// Обработка команды Создать списка выбора
	СтандартнаяОбработка = Ложь;
	
	НовоеНаправлениеДеятельности = СоздатьНовоеНаправлениеДеятельностиБыстро(ВыбранноеЗначение);
	ТекущиеДанные = Элементы.ДеревоБюджета.ТекущиеДанные;
	Если НовоеНаправлениеДеятельности <> Неопределено Тогда
		
		ТекущиеДанные.НаправлениеДеятельности = НовоеНаправлениеДеятельности;
		ЗаполнитьСтрокуНаправленияДеятельности(ТекущиеДанные);
		
	Иначе
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("РежимВыбора",     Истина);
		ПараметрыФормы.Вставить("ТекстЗаполнения", ВыбранноеЗначение);
		ОткрытьФорму("Справочник.НаправленияДеятельности.ФормаОбъекта", ПараметрыФормы, Элемент);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СоздатьНовоеНаправлениеДеятельностиБыстро(Наименование)
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Наименование", Наименование);
	
	НовыйОбъект = Справочники.НаправленияДеятельности.СоздатьЭлемент();
	НовыйОбъект.Заполнить(ЗначенияЗаполнения);
	
	Попытка
		НовыйОбъект.Записать();
	Исключение
		// Не является значимой проблемой, будет обработано интерактивно вызывающим кодом
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат НовыйОбъект.Ссылка;
	
КонецФункции

#КонецОбласти

#Область ЗаписатьДанные

&НаКлиенте
Процедура ЗаписатьДанные(Отказ = Ложь)

	ЗаписатьДанныеВОбработку();
	Если ПроверитьЗаполнение() Тогда
		ЗаписатьДанныеВДокументНаСервере();
		Модифицированность = Ложь;
		ОтобразитьИзменениеДанных(ДокументСсылка, ВидИзмененияДанных.Изменение);
	Иначе
		Отказ = Истина;
	КонецЕсли;
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьДанныеВОбработку()
	
	Для Каждого Строка Из ДеревоБюджета.ПолучитьЭлементы() Цикл
		Если Строка.Раздел = ИмяРазделОстатокНачало() Тогда
			ЗаписатьОстатокНаНачало(Строка);
		ИначеЕсли Строка.Раздел = ИмяРазделДоходы() Тогда
			ЗаписатьДоходы(Строка);
		ИначеЕсли Строка.Раздел = ИмяРазделРасходы() Тогда
			ЗаписатьРасходы(Строка);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьОстатокНаНачало(РазделОстатокНаНачало)
	
	Объект.ОстатокНаНачало = РазделОстатокНаНачало.СуммаГод;
	Объект.ОстатокНаНачалоДоКорректировки = РазделОстатокНаНачало.СуммаГодДоКорректировки;
	Объект.ОстатокНаНачалоКорректировка = РазделОстатокНаНачало.СуммаГодКорректировка;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьДоходы(РазделДоходы)
	
	Объект.Доходы.Очистить();
	Объект.СтруктураДоходов.Очистить();
	
	ЗаписатьСтруктуруДоходов(РазделДоходы);
	ЗаписатьСтрокиДохода(РазделДоходы);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьСтрокиДохода(Строка)
	
	Для Каждого СтрокаДохода Из Строка.ПолучитьЭлементы() Цикл
		Если Не СтрокаДохода.ЭтоСтатьяДДС Тогда
			Продолжить;
		КонецЕсли;
		
		// Итоговая сумма
		НоваяСтрока              = Объект.Доходы.Добавить();
		НоваяСтрока.СтатьяДохода = СтрокаДохода.СтатьяДДС;
		НоваяСтрока.ЭтоГруппа    = СтрокаДохода.ЭтоГруппаСтатей;
		НоваяСтрока.Сумма        = СтрокаДохода.СуммаГод;
		НоваяСтрока.СуммаДоКорректировки = СтрокаДохода.СуммаГодДоКорректировки;
		НоваяСтрока.СуммаКорректировки = СтрокаДохода.СуммаГодКорректировка;
		
		// Сумма по детализации
		Для Каждого КолонкаДетализации Из КолонкиДетализации Цикл
			НоваяСтрока                  = Объект.Доходы.Добавить();
			НоваяСтрока.ДатаПланирования = КолонкаДетализации.Дата;
			НоваяСтрока.СтатьяДохода     = СтрокаДохода.СтатьяДДС;
			НоваяСтрока.ЭтоГруппа        = СтрокаДохода.ЭтоГруппаСтатей;
			НоваяСтрока.Сумма            = СтрокаДохода[КолонкаДетализации.ИмяКолонки];
			
			НоваяСтрока.СуммаДоКорректировки = СтрокаДохода[КолонкаДетализации.ИмяКолонки + "ДоКорректировки"];
			НоваяСтрока.СуммаКорректировки = СтрокаДохода[КолонкаДетализации.ИмяКолонки + "Корректировка"];
		КонецЦикла;
		
		Если СтрокаДохода.ЭтоГруппаСтатей Тогда
			ЗаписатьСтрокиДохода(СтрокаДохода);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьСтруктуруДоходов(Строка, Родитель = Неопределено)

	Для Каждого СтрокаДохода Из Строка.ПолучитьЭлементы() Цикл
		Если Не СтрокаДохода.ЭтоСтатьяДДС Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока              = Объект.СтруктураДоходов.Добавить();
		НоваяСтрока.СтатьяДохода = СтрокаДохода.СтатьяДДС;
		НоваяСтрока.Родитель     = Родитель;
		НоваяСтрока.ЭтоГруппа    = СтрокаДохода.ЭтоГруппаСтатей;
		
		Если СтрокаДохода.ЭтоГруппаСтатей Тогда
			НовыйРодитель = СтрокаДохода.СтатьяДДС;
			ЗаписатьСтруктуруДоходов(СтрокаДохода, НовыйРодитель);
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьСтруктуруРасходовПоНаправлениюДеятельности(НаправлениеДеятельности, Строка, Родитель = Неопределено)
	
	Если Строка.ПолучитьЭлементы().Количество() = 0 Тогда
		// Статей по направлению деятельности нет, но все равно запишем структуру
		НоваяСтрока = Объект.СтруктураРасходов.Добавить();
		НоваяСтрока.НаправлениеДеятельности = НаправлениеДеятельности;
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаРасхода Из Строка.ПолучитьЭлементы() Цикл
		Если Не СтрокаРасхода.ЭтоСтатьяДДС Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Объект.СтруктураРасходов.Добавить();
		НоваяСтрока.НаправлениеДеятельности = НаправлениеДеятельности;
		НоваяСтрока.СтатьяРасхода           = СтрокаРасхода.СтатьяДДС;
		НоваяСтрока.Родитель                = Родитель;
		НоваяСтрока.ЭтоГруппа               = СтрокаРасхода.ЭтоГруппаСтатей;
		
		Если СтрокаРасхода.ЭтоГруппаСтатей Тогда
			НовыйРодитель = СтрокаРасхода.СтатьяДДС;
			ЗаписатьСтруктуруРасходовПоНаправлениюДеятельности(НаправлениеДеятельности, СтрокаРасхода, НовыйРодитель);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьРасходы(РазделРасходы)
	
	Объект.РасходыПоНаправлениямДеятельности.Очистить();
	Объект.Расходы.Очистить();
	Объект.СтруктураРасходов.Очистить();
	
	ЗаписатьСтруктуруРасходов(РазделРасходы);
	ЗаписатьСтрокиРасходов(РазделРасходы);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьСтруктуруРасходов(Строка)

	Для Каждого СтрокаНаправленияДеятельности Из Строка.ПолучитьЭлементы() Цикл
		Если Не СтрокаНаправленияДеятельности.ЭтоНаправлениеДеятельности Тогда
			Продолжить;
		КонецЕсли;
		НаправлениеДеятельности = СтрокаНаправленияДеятельности.НаправлениеДеятельности;
		ЗаписатьСтруктуруРасходовПоНаправлениюДеятельности(НаправлениеДеятельности, СтрокаНаправленияДеятельности);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьСтрокиРасходов(Строка)
	
	Для Каждого СтрокаНаправленияДеятельности Из Строка.ПолучитьЭлементы() Цикл
		Если Не СтрокаНаправленияДеятельности.ЭтоНаправлениеДеятельности Тогда
			Продолжить;
		КонецЕсли;
		
		// Итоговая сумма
		НоваяСтрока = Объект.РасходыПоНаправлениямДеятельности.Добавить();
		НоваяСтрока.НаправлениеДеятельности = СтрокаНаправленияДеятельности.НаправлениеДеятельности;
		НоваяСтрока.Сумма                   = СтрокаНаправленияДеятельности.СуммаГод;
		НоваяСтрока.СуммаДоКорректировки    = СтрокаНаправленияДеятельности.СуммаГодДоКорректировки;
		НоваяСтрока.СуммаКорректировки      = СтрокаНаправленияДеятельности.СуммаГодКорректировка;
		
		// Сумма по детализации
		Для Каждого КолонкаДетализации Из КолонкиДетализации Цикл
			НоваяСтрока                         = Объект.РасходыПоНаправлениямДеятельности.Добавить();
			НоваяСтрока.ДатаПланирования        = КолонкаДетализации.Дата;
			НоваяСтрока.НаправлениеДеятельности = СтрокаНаправленияДеятельности.НаправлениеДеятельности;
			НоваяСтрока.Сумма                   = СтрокаНаправленияДеятельности[КолонкаДетализации.ИмяКолонки];
			НоваяСтрока.СуммаДоКорректировки = СтрокаНаправленияДеятельности[КолонкаДетализации.ИмяКолонки + "ДоКорректировки"];
			НоваяСтрока.СуммаКорректировки = СтрокаНаправленияДеятельности[КолонкаДетализации.ИмяКолонки + "Корректировка"];
		КонецЦикла;
		
		НаправлениеДеятельности = СтрокаНаправленияДеятельности.НаправлениеДеятельности;
		ЗаписатьСтрокиРасходаПоНаправлениюДеятельности(СтрокаНаправленияДеятельности, НаправлениеДеятельности);
			
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьСтрокиРасходаПоНаправлениюДеятельности(Строка, НаправлениеДеятельности)
	
	Для Каждого СтрокаРасхода Из Строка.ПолучитьЭлементы() Цикл
		Если Не СтрокаРасхода.ЭтоСтатьяДДС Тогда
			Продолжить;
		КонецЕсли;
		
		// Итоговая сумма
		НоваяСтрока                         = Объект.Расходы.Добавить();
		НоваяСтрока.НаправлениеДеятельности = НаправлениеДеятельности;
		НоваяСтрока.СтатьяРасхода           = СтрокаРасхода.СтатьяДДС;
		НоваяСтрока.ЭтоГруппа               = СтрокаРасхода.ЭтоГруппаСтатей;
		НоваяСтрока.Сумма                   = СтрокаРасхода.СуммаГод;
		НоваяСтрока.СуммаДоКорректировки    = СтрокаРасхода.СуммаГодДоКорректировки;
		НоваяСтрока.СуммаКорректировки      = СтрокаРасхода.СуммаГодКорректировка;
		
		// Сумма по детализации
		Для Каждого КолонкаДетализации Из КолонкиДетализации Цикл
			НоваяСтрока                         = Объект.Расходы.Добавить();
			НоваяСтрока.ДатаПланирования        = КолонкаДетализации.Дата;
			НоваяСтрока.НаправлениеДеятельности = НаправлениеДеятельности;
			НоваяСтрока.СтатьяРасхода           = СтрокаРасхода.СтатьяДДС;
			НоваяСтрока.ЭтоГруппа               = СтрокаРасхода.ЭтоГруппаСтатей;
			НоваяСтрока.Сумма                   = СтрокаРасхода[КолонкаДетализации.ИмяКолонки];
			НоваяСтрока.СуммаДоКорректировки    = СтрокаРасхода[КолонкаДетализации.ИмяКолонки + "ДоКорректировки"];
			НоваяСтрока.СуммаКорректировки      = СтрокаРасхода[КолонкаДетализации.ИмяКолонки + "Корректировка"];
		КонецЦикла;
		
		Если СтрокаРасхода.ЭтоГруппаСтатей Тогда
			ЗаписатьСтрокиРасходаПоНаправлениюДеятельности(СтрокаРасхода, НаправлениеДеятельности);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьДанныеВДокументНаСервере()
	
	Если ДокументСсылка.Пустая() Тогда
		ДокументОбъект = Документы.КорректировкаБюджета.СоздатьДокумент();
	Иначе
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДокументОбъект, Объект);
	ДокументОбъект.Доходы.Загрузить(Объект.Доходы.Выгрузить());
	ДокументОбъект.СтруктураДоходов.Загрузить(Объект.СтруктураДоходов.Выгрузить());
	ДокументОбъект.РасходыПоНаправлениямДеятельности.Загрузить(Объект.РасходыПоНаправлениямДеятельности.Выгрузить());
	ДокументОбъект.Расходы.Загрузить(Объект.Расходы.Выгрузить());
	ДокументОбъект.СтруктураРасходов.Загрузить(Объект.СтруктураРасходов.Выгрузить());
	
	ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
	ДокументСсылка = ДокументОбъект.Ссылка;
	Параметры.ДокументСсылка = ДокументСсылка;
	
	ЗаблокироватьДокументДляРедактирования();
	
КонецПроцедуры

#КонецОбласти

#Область Итоги

&НаСервере
Процедура РассчитатьИтогиПоВсемРазделам()
	
	РазделДоходы        = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторДоходы);
	РазделРасходы       = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторРасходы);
	РазделОстатокНачало = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторОстатокНачало);
	РазделОстатокКонец  = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторОстатокКонец);
	
	КорректировкиПоПериодам = Новый Структура;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		КорректировкиПоПериодам.Вставить("ЕстьКорректировка" + Колонка.ИмяКолонки, Ложь);
	КонецЦикла;
	
	РассчитатьИтогиПоРазделу(РазделДоходы, КолонкиДетализации, КорректировкиПоПериодам);
	Для Каждого СтрокаНаправленияДеятельности Из РазделРасходы.ПолучитьЭлементы() Цикл
		РассчитатьИтогиПоРазделу(СтрокаНаправленияДеятельности, КолонкиДетализации, КорректировкиПоПериодам);
	КонецЦикла;
	РассчитатьИтогиПоРазделу(РазделРасходы, КолонкиДетализации, КорректировкиПоПериодам);
	
	РассчитатьОстатки(РазделОстатокНачало, РазделОстатокКонец, РазделДоходы, РазделРасходы, КолонкиДетализации, КорректировкиПоПериодам);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, КорректировкиПоПериодам);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьСуммуЗаГодПоСтроке(Строка, КолонкиДетализации)
	
	СуммаГод = 0;
	СуммаГодКорректировка = 0;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		СуммаГод = СуммаГод + Строка[Колонка.ИмяКолонки];
		СуммаГодКорректировка = СуммаГодКорректировка + Строка[Колонка.ИмяКолонки + "Корректировка"];
	КонецЦикла;
	
	Строка.СуммаГод = СуммаГод;
	Строка.СуммаГодКорректировка = СуммаГодКорректировка;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьСуммуКорректировкиПоСтроке(Строка, КолонкиДетализации)
	
	Для Каждого Колонка Из КолонкиДетализации Цикл
		Если Строка[Колонка.ИмяКолонки] <> Строка[Колонка.ИмяКолонки + "ДоКорректировки"] Тогда
			Строка[Колонка.ИмяКолонки + "Корректировка"] = Строка[Колонка.ИмяКолонки] - Строка[Колонка.ИмяКолонки + "ДоКорректировки"];
		Иначе
			Строка[Колонка.ИмяКолонки + "Корректировка"] = 0;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьИтоги(Элемент)
	
	ТекущиеДанные       = Элементы.ДеревоБюджета.ТекущиеДанные;
	РазделДоходы        = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторДоходы);
	РазделРасходы       = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторРасходы);
	РазделОстатокКонец  = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторОстатокКонец);
	РазделОстатокНачало = ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторОстатокНачало);
	
	КорректировкиПоПериодам = Новый Структура;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		КорректировкиПоПериодам.Вставить("ЕстьКорректировка" + Колонка.ИмяКолонки);
	КонецЦикла;
	
	ЗаполнитьЗначенияСвойств(КорректировкиПоПериодам, ЭтотОбъект);
	
	Если ТекущиеДанные.Раздел = ИмяРазделДоходы() Тогда
		РассчитатьСуммуКорректировкиПоСтроке(ТекущиеДанные, КолонкиДетализации);
		РассчитатьСуммуЗаГодПоСтроке(ТекущиеДанные, КолонкиДетализации);
		Родитель = ТекущиеДанные.ПолучитьРодителя();
		Пока Родитель <> РазделДоходы Цикл
			РассчитатьИтогиПоРазделу(Родитель, КолонкиДетализации, КорректировкиПоПериодам);
			Родитель = Родитель.ПолучитьРодителя();
		КонецЦикла;
		РассчитатьИтогиПоРазделу(РазделДоходы, КолонкиДетализации, КорректировкиПоПериодам);
	ИначеЕсли ТекущиеДанные.ЭтоНаправлениеДеятельности Тогда
		РассчитатьИтогиПоРазделу(РазделРасходы, КолонкиДетализации, КорректировкиПоПериодам);
	ИначеЕсли ТекущиеДанные.ЭтоСтатьяДДС Тогда
		РассчитатьСуммуКорректировкиПоСтроке(ТекущиеДанные, КолонкиДетализации);
		РассчитатьСуммуЗаГодПоСтроке(ТекущиеДанные, КолонкиДетализации);
		Родитель = ТекущиеДанные.ПолучитьРодителя();
		Пока Родитель <> РазделРасходы Цикл
			РассчитатьИтогиПоРазделу(Родитель, КолонкиДетализации, КорректировкиПоПериодам);
			Родитель = Родитель.ПолучитьРодителя();
		КонецЦикла;
		РассчитатьИтогиПоРазделу(РазделРасходы, КолонкиДетализации, КорректировкиПоПериодам);
	ИначеЕсли ТекущиеДанные.Раздел = ИмяРазделОстатокНачало() Тогда
		РассчитатьСуммуКорректировкиПоСтроке(ТекущиеДанные, КолонкиДетализации);
	КонецЕсли;
	
	РассчитатьОстатки(РазделОстатокНачало, РазделОстатокКонец, РазделДоходы, РазделРасходы, КолонкиДетализации, КорректировкиПоПериодам);
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, КорректировкиПоПериодам);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьОстатки(РазделОстатокНачало, РазделОстатокКонец, РазделДоходы, РазделРасходы, КолонкиДетализации, КорректировкиПоПериодам)
	
	// Остатки по детализации считаются накопительным итогом
	ПредыдущийОстаток = 0;
	Остаток           = 0;
	
	ПредыдущийОстатокКорректировка = 0;
	ОстатокКорректировка           = 0;
	
	ПерваяКолонка = Истина;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		ИмяКолонки = Колонка.ИмяКолонки;
		ИмяКолонкиКорректировка = Колонка.ИмяКолонки + "Корректировка";
		Если ПерваяКолонка Тогда
			ПерваяКолонка = Ложь;
			ПредыдущийОстаток = РазделОстатокНачало[ИмяКолонки];
			РазделОстатокНачало.СуммаГод = ПредыдущийОстаток;
			
			ПредыдущийОстатокКорректировка = РазделОстатокНачало[ИмяКолонкиКорректировка];
			РазделОстатокНачало.СуммаГодКорректировка = ПредыдущийОстатокКорректировка;
		Иначе
			РазделОстатокНачало[ИмяКолонки] = ПредыдущийОстаток;
			РазделОстатокНачало[ИмяКолонкиКорректировка] = ПредыдущийОстатокКорректировка;
		КонецЕсли;
		
		Остаток = ПредыдущийОстаток + РазделДоходы[ИмяКолонки] - РазделРасходы[ИмяКолонки];
		РазделОстатокКонец[ИмяКолонки] = Остаток;
		ПредыдущийОстаток = Остаток;
		
		ОстатокКорректировка = ПредыдущийОстатокКорректировка + РазделДоходы[ИмяКолонкиКорректировка] - РазделРасходы[ИмяКолонкиКорректировка];
		РазделОстатокКонец[ИмяКолонкиКорректировка] = ОстатокКорректировка;
		ПредыдущийОстатокКорректировка = ОстатокКорректировка;
		Если ОстатокКорректировка <> 0 Тогда
			КорректировкиПоПериодам["ЕстьКорректировка" + ИмяКолонки] = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	РазделОстатокКонец.СуммаГод = РазделОстатокНачало.СуммаГод + РазделДоходы.СуммаГод - РазделРасходы.СуммаГод;
	РазделОстатокКонец.СуммаГодКорректировка = РазделОстатокНачало.СуммаГодКорректировка + РазделДоходы.СуммаГодКорректировка - РазделРасходы.СуммаГодКорректировка;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьИтогиПоРазделу(Раздел, КолонкиДетализации, КорректировкиПоПериодам)
	
	// Очистим суммы
	Раздел.СуммаГод = 0;
	Раздел.СуммаГодКорректировка = 0;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		Раздел[Колонка.ИмяКолонки] = 0;
		Раздел[Колонка.ИмяКолонки + "Корректировка"] = 0;
	КонецЦикла;
	
	// Заполним суммы
	Для Каждого Строка Из Раздел.ПолучитьЭлементы() Цикл
		Раздел.СуммаГод = Раздел.СуммаГод + Строка.СуммаГод;
		Строка.СуммаГодКорректировка = 0;
		Для Каждого Колонка Из КолонкиДетализации Цикл
			ИмяКолонки = Колонка.ИмяКолонки;
			Раздел[ИмяКолонки] = Раздел[ИмяКолонки] + Строка[ИмяКолонки];
			
			Если Строка[Колонка.ИмяКолонки] <> Строка[Колонка.ИмяКолонки + "ДоКорректировки"] Тогда
				Строка[Колонка.ИмяКолонки + "Корректировка"] = Строка[Колонка.ИмяКолонки] - Строка[Колонка.ИмяКолонки + "ДоКорректировки"];
				Строка.СуммаГодКорректировка = Строка.СуммаГодКорректировка + Строка[Колонка.ИмяКолонки + "Корректировка"];
				Раздел[ИмяКолонки + "Корректировка"] = Раздел[ИмяКолонки + "Корректировка"] + Строка[ИмяКолонки + "Корректировка"];
				КорректировкиПоПериодам["ЕстьКорректировка" + Колонка.ИмяКолонки] = Истина;
			КонецЕсли;
			
		КонецЦикла;
		Раздел.СуммаГодКорректировка = Раздел.СуммаГодКорректировка + Строка.СуммаГодКорректировка;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ПроверкаЗаполнения

&НаСервере
Процедура ПроверитьКорректностьДаты(Отказ)
	
	Если Не ЗначениеЗаполнено(Объект.Период) Тогда
		// Сработает платформенная проверка
		Возврат;
	КонецЕсли;
		
	ИсходныйБюджет = ИсходныйБюджет(Объект.Бюджет);
	ПериодБюджета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИсходныйБюджет, "Период");
	ГодБюджета = Год(ПериодБюджета);
	
	Если Год(Объект.Период) <> ГодБюджета Тогда
		СообщениеПользователю = СтрШаблон(
			НСтр("ru='Дата корректировки не соответствует году бюджета. Корректировать бюджет за %1 год следует в %1 году'"),
				Формат(ГодБюджета, "ЧГ=0"));
		ОбщегоНазначения.СообщитьПользователю(СообщениеПользователю, ИсходныйБюджет, "Период", "Объект.Период", Отказ);
		Возврат;
	КонецЕсли;
	
	ПроверитьЕстьБолееПозднийДокумент(ИсходныйБюджет, Отказ);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЕстьБолееПозднийДокумент(ИсходныйБюджет, Отказ)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВсеКорректировки", Документы.КорректировкаБюджета.ВсеКорректировки(ИсходныйБюджет));
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВсеКорректировки.Ссылка КАК Ссылка,
	|	ВсеКорректировки.Период КАК Период
	|ПОМЕСТИТЬ ВТ_ВсеКорректировки
	|ИЗ
	|	Документ.КорректировкаБюджета КАК ВсеКорректировки
	|ГДЕ
	|	ВсеКорректировки.Ссылка В(&ВсеКорректировки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВТ_ВсеКорректировки.Ссылка КАК Ссылка,
	|	ВТ_ВсеКорректировки.Период КАК Период
	|ИЗ
	|	ВТ_ВсеКорректировки КАК ВТ_ВсеКорректировки
	|ГДЕ
	|	ВТ_ВсеКорректировки.Ссылка <> &ДокументСсылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_ВсеКорректировки.Период УБЫВ";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Если Объект.Период <= Выборка.Период Тогда
			СообщениеПользователю = СтрШаблон(
				НСтр("ru='В текущем году уже введен более поздний документ: %1. Дата должна быть больше %2'"), 
					Строка(Выборка.Ссылка), Формат(Выборка.Период, "ДФ=dd.MM.yyyy"));
			ОбщегоНазначения.СообщитьПользователю(СообщениеПользователю, ИсходныйБюджет, "Период", "Объект.Период", Отказ);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьБюджетНаНезаполненныеЭлементы(Отказ)
	
	// Доходы
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("СтатьяДохода", Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
	ТаблицаДоходы = Объект.Доходы.Выгрузить(ПараметрыОтбора, "СтатьяДохода");
	
	Если ТаблицаДоходы.Количество() > 0 Тогда
		ТекстСообщения = НСтр("ru='В разделе ""Финансирование"" есть незаполненные статьи'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "ДеревоБюджета" , , Отказ);
	КонецЕсли;
	
	// Направления деятельности
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("НаправлениеДеятельности", Справочники.НаправленияДеятельности.ПустаяСсылка());
	ТаблицаНаправленияДеятельности = Объект.РасходыПоНаправлениямДеятельности.Выгрузить(
		ПараметрыОтбора, "НаправлениеДеятельности");
	
	Если ТаблицаНаправленияДеятельности.Количество() > 0 Тогда
		ТекстСообщения = НСтр("ru='В разделе ""Расходы"" есть незаполненные направления деятельности'");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "ДеревоБюджета" , , Отказ);
	КонецЕсли;
	
	// Расходы
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("СтатьяРасхода", Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
	ТаблицаРасходы = Объект.Расходы.Выгрузить(ПараметрыОтбора, "НаправлениеДеятельности, СтатьяРасхода");
	ТаблицаРасходы.Свернуть("НаправлениеДеятельности");
	
	Для Каждого СтрокаРасходы Из ТаблицаРасходы Цикл
		ШаблонСообщения = НСтр("ru='В разделе ""Расходы"" есть незаполненные статьи для направления деятельности ""%1""'");
		ТекстСообщения = СтрШаблон(ШаблонСообщения, СтрокаРасходы["НаправлениеДеятельности"]);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "ДеревоБюджета" , , Отказ);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьТаблицуНаДублирующиеЭлементы(ТаблицаОбъекта, ИмяКолонки, ШаблонСообщения, Отказ)
	
	Таблица = ТаблицаОбъекта.Выгрузить(Новый Структура("ДатаПланирования", Дата(1, 1, 1)));
	Таблица.Колонки.Добавить("Количество", ОбщегоНазначения.ОписаниеТипаЧисло(10));
	Таблица.ЗаполнитьЗначения(1, "Количество"); // Количество строк с этим элементом.
	Таблица.Свернуть(ИмяКолонки, "Количество");
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		// Если элемент встречается несколько раз, то расскажем об этом пользователю.
		Если СтрокаТаблицы.Количество > 1 Тогда
			ЧислоРаз = СтроковыеФункцииКлиентСервер.ЧислоЦифрамиПредметИсчисленияПрописью(
				СтрокаТаблицы.Количество, "раз, раза, раз");
			ТекстСообщения = СтрШаблон(ШаблонСообщения, СтрокаТаблицы[ИмяКолонки], ЧислоРаз);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "ДеревоБюджета" , , Отказ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьРасходыНаДублирующиеЭлементы(Отказ)
	
	Таблица = Объект.СтруктураРасходов.Выгрузить();
	Таблица.Колонки.Добавить("Количество", ОбщегоНазначения.ОписаниеТипаЧисло(10));
	Таблица.ЗаполнитьЗначения(1, "Количество"); // Количество строк с этой статьей затрат.
	Таблица.Свернуть("НаправлениеДеятельности, СтатьяРасхода", "Количество");
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы["НаправлениеДеятельности"]) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаТаблицы["СтатьяРасхода"]) Тогда
			Продолжить;
		КонецЕсли;
		
		// Если элемент встречается несколько раз, то расскажем об этом пользователю.
		Если СтрокаТаблицы.Количество > 1 Тогда
			ШаблонСообщения = НСтр("ru='Статья ""%1"" указана %2 для направления деятельности ""%3""'");
			ЧислоРаз = СтроковыеФункцииКлиентСервер.ЧислоЦифрамиПредметИсчисленияПрописью(
				СтрокаТаблицы.Количество, "раз, раза, раз");
			ТекстСообщения = СтрШаблон(ШаблонСообщения, СтрокаТаблицы["СтатьяРасхода"], ЧислоРаз, СтрокаТаблицы["НаправлениеДеятельности"]);
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "ДеревоБюджета" , , Отказ);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

