&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		ЗаписатьДанные(Отказ);
		Если Не Отказ Тогда
			Закрыть();
		КонецЕсли;
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПланФактныйАнализЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		ЗаписатьДанные(Отказ);
		Если Не Отказ Тогда
			ОткрытьПланФактныйАнализ();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеОбработки()
	
	ПоследняяКорректировка = Документы.КорректировкаБюджета.ПустаяСсылка();
	Если ДокументСсылка.Пустая() Тогда
		// Возьмем данные исходного бюджета с учетом всех предыдущих корректировок
		ДанныеКорректировки = Документы.КорректировкаБюджета.ДанныеКорректировки(ИсходныйБюджет(Объект.Бюджет));
		ДанныеКорректировки.Реквизиты[0].Бюджет = Объект.Бюджет;
	Иначе
		ДанныеКорректировки = Документы.КорректировкаБюджета.ДанныеКорректировки(ДокументСсылка);
		ПоследняяКорректировка = Документы.КорректировкаБюджета.ПоследняяКорректировка(ДокументСсылка);
		Если ПоследняяКорректировка = ДокументСсылка Тогда
			ПоследняяКорректировка = Документы.КорректировкаБюджета.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	
	Объект.СтруктураДоходов.Загрузить(ДанныеКорректировки.СтруктураДоходов);
	Объект.Доходы.Загрузить(ДанныеКорректировки.Доходы);
	Объект.СтруктураРасходов.Загрузить(ДанныеКорректировки.СтруктураРасходов);
	Объект.РасходыПоНаправлениямДеятельности.Загрузить(ДанныеКорректировки.РасходыПоНаправлениямДеятельности);
	Объект.Расходы.Загрузить(ДанныеКорректировки.Расходы);
	
	ЗаполнитьЗначенияСвойств(Объект, ДанныеКорректировки.Реквизиты[0]);
	
КонецПроцедуры

#Область УправлениеФормой

&НаСервере
Процедура ЗаблокироватьДокументДляРедактирования()
	
	Элементы.ИнформацияДокументЗаблокирован.Заголовок = "";
	
	Если ДокументСсылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ЗаблокироватьДанныеДляРедактирования(ДокументСсылка, , УникальныйИдентификатор);
	Исключение
		Элементы.ИнформацияДокументЗаблокирован.Заголовок = 
			ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		РедактированиеРазрешено = Ложь;
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура РазблокироватьДокумент()
	
