	КонецЕсли;
	
	РазблокироватьДанныеДляРедактирования(ДокументСсылка, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере()
	
	СоздатьКолонкиДереваБюджета();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	
	ДокументЗаблокирован = Не ПустаяСтрока(Элементы.ИнформацияДокументЗаблокирован.Заголовок);
	
	НеТолькоПросмотр = Форма.РедактированиеРазрешено;
	Если НеТолькоПросмотр Тогда
		РедактированиеРазрешено = Не Форма.Объект.Утвержден;
	Иначе
		РедактированиеРазрешено = Ложь;
	КонецЕсли;
	
	Элементы.ДеревоБюджетаДобавитьДоход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаДобавитьРасход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаДобавитьНаправлениеДеятельности.Доступность = РедактированиеРазрешено;

	Элементы.ДеревоБюджетаКонтекстноеМенюДобавитьДоход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаКонтекстноеМенюДобавитьРасход.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаКонтекстноеМенюДобавитьНаправлениеДеятельности.Доступность = РедактированиеРазрешено;

	Элементы.ДеревоБюджетаСдвинутьВверх.Доступность = РедактированиеРазрешено;
	Элементы.ДеревоБюджетаСдвинутьВниз.Доступность = РедактированиеРазрешено;

	Элементы.ДеревоБюджета.ТолькоПросмотр = Не РедактированиеРазрешено;
	
	Элементы.Записать.Доступность = НеТолькоПросмотр;
	Элементы.ЗаписатьИЗакрыть.Доступность = НеТолькоПросмотр;
	
	Элементы.Период.Доступность = РедактированиеРазрешено;
	
	Если ЗначениеЗаполнено(Форма.ПоследняяКорректировка) Тогда
		ЗаголовокКорректировки = Строка(Форма.ПоследняяКорректировка);
	Иначе
		ЗаголовокКорректировки = НСтр("ru='Ввести корректировку'");
	КонецЕсли;
	
	Элементы.ДекорацияКорректировка.Заголовок = ЗаголовокКорректировки;
	
	// Видимость заголовка зависит от права на редактирование, утвержден, заблокирован документ и модифицированность
	// Если нет прав на редактирование или бюджет не утвержден или модифицированность или документ заблокирован, то надписи не будет
	Элементы.ДекорацияКорректировка.Видимость = НеТолькоПросмотр И Форма.Объект.Утвержден И Не Форма.Модифицированность И Не ДокументЗаблокирован;
	
	Элементы.ГруппаДокументЗаблокирован.Видимость = ДокументЗаблокирован;
	
	Элементы.Утвержден.Доступность = Не ЗначениеЗаполнено(Форма.ПоследняяКорректировка) И Не ДокументЗаблокирован;
	
	Элементы.ПометитьНаУдаление.Видимость = ЗначениеЗаполнено(Форма.ДокументСсылка) 
		И Не ЗначениеЗаполнено(Форма.ПоследняяКорректировка);
	Элементы.ПометитьНаУдаление.Доступность = НеТолькоПросмотр;
	
	Если ЗначениеЗаполнено(Форма.ДокументСсылка) Тогда
		Форма.Заголовок = Строка(Форма.ДокументСсылка);
	Иначе
		Форма.Заголовок = НСтр("ru='Корректировка бюджета (создание)'");
	КонецЕсли;
	
	Элементы.ДеревоБюджетаВыгрузитьВExcel.Доступность = НеТолькоПросмотр;
	Элементы.ДеревоБюджетаЗагрузитьИзExcel.Доступность = НеТолькоПросмотр;

КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджетаРаздел");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ДеревоБюджета.ЭтоРаздел", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджетаНаправлениеДеятельности");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджетаКартинкаСтрокиНаправлениеДеятельности");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ДеревоБюджета.ЭтоНаправлениеДеятельности", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджетаСтатьяДДС");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджетаКартинкаСтрокиСтатьяДДС");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ДеревоБюджета.ЭтоСтатьяДДС", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджета");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ДеревоБюджета.ЭтоРаздел", ВидСравненияКомпоновкиДанных.Равно, Истина);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ДеревоБюджета.Раздел", ВидСравненияКомпоновкиДанных.НеРавно, ИмяРазделОстатокНачало());
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Формат", "ЧЦ=15; ЧДЦ=2; ЧН=0,00");
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.ШрифтРазделБюджета);
	
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджетаРаздел");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДеревоБюджетаСуммаГод");
	ПерваяКолонка = Истина;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		Если ПерваяКолонка Тогда
			ПерваяКолонка = Ложь;
			Продолжить;
