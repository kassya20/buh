&НаКлиенте
Процедура ПередВыгрузкойИЗагрузкойИзФайлаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отказ = Ложь;
		ЗаписатьДанные(Отказ);
		Если ДополнительныеПараметры.Команда = "Выгрузить" Тогда 
			Оповещение = Новый ОписаниеОповещения("ВыгрузитьВExcelПриПодключенииРасширения", ЭтотОбъект);
		Иначе
			Оповещение = Новый ОписаниеОповещения("ЗагрузитьИзExcelПриПодключенииРасширения", ЭтотОбъект);
		КонецЕсли;
		ФайловаяСистемаКлиент.ПодключитьРасширениеДляРаботы1СПредприятия(Оповещение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьВExcelПриПодключенииРасширения(РасширениеПодключено, ДополнительныеПараметры) Экспорт
	
	ИмяФайла = НСтр("ru = 'Бюджет.xls'");
	Если РасширениеПодключено Тогда
		// Вариант для установленного расширения для работы с файлами
		ДиалогСохраненияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
		ДиалогСохраненияФайла.ПолноеИмяФайла = ИмяФайла;
		ДиалогСохраненияФайла.Фильтр = НСтр("ru = 'Лист Excel|*.xls; *.xlsx'");
		ДиалогСохраненияФайла.МножественныйВыбор = Ложь;
		ДиалогСохраненияФайла.Заголовок = НСтр("ru = 'Укажите файл сохранения бюджета в Excel'"); 
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВыгрузитьВExcelПриПодключенииРасширенияПродолжение", ЭтотОбъект); 
		ФайловаяСистемаКлиент.ПоказатьДиалогВыбора(ОписаниеОповещения, ДиалогСохраненияФайла);		
	Иначе
		// Веб клиент без расширения для работы с файлами 
		АдресВоВременномХранилище = УникальныйИдентификатор;
		СохранитьТабличныйДокументВоВременноеХранилище(АдресВоВременномХранилище);
		ПараметрыСохраненияФайла = ФайловаяСистемаКлиент.ПараметрыСохраненияФайла();
		ФайловаяСистемаКлиент.СохранитьФайл(Неопределено, АдресВоВременномХранилище,
			ИмяФайла, ПараметрыСохраненияФайла);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура СохранитьТабличныйДокументВоВременноеХранилище(АдресВоВременномХранилище)
	
	ТабличныйДокумент = ТабличныйДокументДляВыгрузкиВExcel(Объект, КолонкиДетализации); 
		
	ИмяФайла = ПолучитьИмяВременногоФайла("xls");
	ТабличныйДокумент.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.XLS);
	ДвоичныеДанные = Новый ДвоичныеДанные(ИмяФайла);
	
	АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
	
	ФайловаяСистема.УдалитьВременныйФайл(ИмяФайла);

КонецПроцедуры 

&НаКлиенте
Процедура ВыгрузитьВExcelПриПодключенииРасширенияПродолжение(РезультатВыбора, ДополнительныеПараметры) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФайла = РезультатВыбора[0];
		
	ТабличныйДокумент = ТабличныйДокументДляВыгрузкиВExcel(Объект, КолонкиДетализации);
	
	ТабличныйДокумент.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.xls);  
	ДополнительныеПараметры  = Новый Структура("Файл", ИмяФайла);
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыгрузитьВExcelЗавершение", ЭтотОбъект, ДополнительныеПараметры); 
	ТекстСообщения = НСтр("ru='Выгрузка данных бюджета успешно завершена!'");
	ПоказатьОповещениеПользователя(ТекстСообщения, ОписаниеОповещения, НСтр("ru='Открыть файл'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзExcelПриПодключенииРасширения(РасширениеПодключено, ДополнительныеПараметры) Экспорт
	
	Если Не Объект.Утвержден Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузитьИзExcelЗавершение", ЭтотОбъект);
		
		ПараметрыЗагрузки = ФайловаяСистемаКлиент.ПараметрыЗагрузкиФайла();
		ПараметрыЗагрузки.ИдентификаторФормы = УникальныйИдентификатор;
		ПараметрыЗагрузки.Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		ПараметрыЗагрузки.Диалог.Фильтр = НСтр("ru = 'Лист Excel|*.xls; *.xlsx'");
		
		ФайловаяСистемаКлиент.ЗагрузитьФайл(ОписаниеОповещения, ПараметрыЗагрузки);	
	Иначе 
		ОписаниеОповещения = Новый ОписаниеОповещения("СозданиеКорректировкиБюджета", ЭтотОбъект);
		ТекстВопроса = НСтр("ru = 'Корректировка бюджета утверждена, хотите создать новую корректировку?'"); 
		КнопкиОтвета = Новый СписокЗначений;
		КнопкиОтвета.Добавить(КодВозвратаДиалога.Да, НСтр("ru='Да, создать корректировку'"));
		КнопкиОтвета.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru='Нет'"));
		
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, КнопкиОтвета);
	КонецЕсли;

КонецПроцедуры

