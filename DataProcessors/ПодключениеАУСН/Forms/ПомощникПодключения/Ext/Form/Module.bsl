
#Область ОписаниеПеременных

&НаКлиенте
Перем КодЗаявкиВведенныйТекст;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Организация = Параметры.Организация;
	ОбменСФНСПодключен = Параметры.ОбменСФНСПодключен;
	
	АдресДополнительныхПараметров = Параметры.АдресДополнительныхПараметров;
	
	Если ЭтоАдресВременногоХранилища(АдресДополнительныхПараметров) Тогда
		
		ПараметрыПодключения = ПолучитьИзВременногоХранилища(АдресДополнительныхПараметров);
		
		ТаблицаОписанияСервисов = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
			ПараметрыПодключения, "ОписанияСервисов");
		
		Если ТаблицаОписанияСервисов <> Неопределено Тогда
			ОписанияСервисов.Загрузить(ТаблицаОписанияСервисов);
		КонецЕсли;
		
		ТаблицаУполномоченныхБанков = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
			ПараметрыПодключения, "УполномоченныеБанки");
		
		Если ТаблицаУполномоченныхБанков <> Неопределено Тогда
			УполномоченныеБанки.Загрузить(ТаблицаУполномоченныхБанков);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбменСФНСПодключен Тогда
		СостояниеФормы = ВсеСостоянияФормы().Подключение;
	Иначе
		СостояниеФормы = ВсеСостоянияФормы().ВыборПодключения;
	КонецЕсли;
	
	ЗаполнитьСписокВыбораБанка();
	
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)

	Если ЭтоПодключениеБанка(ТипПодключения) Тогда
		Если Не ЗначениеЗаполнено(Банк) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения( , "Заполнение", НСтр("ru = 'Банк'"));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "Банк", , Отказ);
		ИначеЕсли Не ЗначениеЗаполнено(КодЗаявки) Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения( , "Заполнение", НСтр("ru = 'Код заявки'"));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "КодЗаявки", , Отказ);
		ИначеЕсли СтрДлина(КодЗаявки) <> ДлинаКодаЗаявки() Тогда
			ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения( , "Корректность", НСтр("ru = 'Код заявки'"));
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "КодЗаявки", , Отказ);
		ИначеЕсли Не КодЗаявкиПроверен Тогда
			ТекстСообщения = НСтр("ru = 'Заявка не найдена. Проверьте правильность заполнения.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , "КодЗаявки", , Отказ);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)

	Если НавигационнаяСсылкаФорматированнойСтроки = "ОткрытьЖурналРегистрации" Тогда
		СтандартнаяОбработка = Ложь;
		Если ОбщегоНазначенияБПВызовСервера.ДоступенПросмотрЖурналаРегистрации() Тогда
			ИнтеграцияАУСНКлиент.ОткрытьЖурналРегистрации(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве("Ошибка"));
		Иначе
			ТекстСообщения = НСтр("ru = 'Просмотр журнала регистрации запрещен.
				|Обратитесь к администратору для выяснения причины возникновения ошибки подключения к сервису АУСН.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "Портал1С" Тогда
		СтандартнаяОбработка = Ложь;
		ИнтернетПоддержкаПользователейКлиент.ОткрытьСтраницуИнтегрированногоСайта(
			ИнтеграцияАУСНКлиентСервер.СсылкаНаПорталСКлючамиДоступа());
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ЛКАУСН" Тогда
		СтандартнаяОбработка = Ложь;
		ПерейтиПоНавигационнойСсылке(ИнтеграцияАУСНКлиентСервер.СсылкаНаЗаявкуВЛичномКабинетеАУСН());
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ШаблонОбращенияВБанк" Тогда
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Организация", Организация);
		ОткрытьФорму("Обработка.ПодключениеАУСН.Форма.ШаблонОбращенияВБанк", ПараметрыФормы, ЭтотОбъект);
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ПодключениеДиректБанк" Тогда
		СтандартнаяОбработка = Ложь;
		ОбменСБанкамиКлиент.ОткрытьНастройкиDirectBankСОтбором(Банк);
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "БанковскиеОперацииАУСН" Тогда
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Организация", Организация);
		ПараметрыФормы.Вставить("БанковскийСчет", БанковскийСчет);
		ПараметрыФормы.Вставить("СформироватьПриОткрытии",  Истина);
		ОткрытьФорму("Отчет.БанковскиеОперацииАУСН.Форма", ПараметрыФормы, ЭтотОбъект);
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ПодключитьОбменСФНС" Тогда
		СтандартнаяОбработка = Ложь;
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Организация", Организация);
		ОткрытьФорму("Обработка.ПодключениеАУСН.Форма.ФормаПодключениеФНС", ПараметрыФормы, ЭтотОбъект);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ИмяСобытия = "ПодключенСервисФНС" Тогда
		ОбменСФНСПодключен = Истина;
		УправлениеФормой(ЭтотОбъект);
	ИначеЕсли ИмяСобытия = "ИзмененаНастройкаОбменСБанками" Тогда
		Если Параметр.Организация = Организация Тогда
			ДиректБанкПодключен = Не Параметр.Недействительна;
			УправлениеФормой(ЭтотОбъект);
		КонецЕсли;
	ИначеЕсли ИмяСобытия = ИнтеграцияАУСНКлиентСервер.ИмяСобытияПроверенКлючДоступа() И Источник = ЭтотОбъект Тогда
		ОбработатьРезультатПроверкиКлючаДоступа(Параметр);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)

	Если Не ЗавершениеРаботы Тогда
		ВсеСостоянияФормы = ВсеСостоянияФормы();

		Если СостояниеФормы = ВсеСостоянияФормы.Подключено Тогда
			Если ЭтоПодключениеБанка(ТипПодключения) Тогда
				УстановитьЗначениеПередачиРасчетаНДФЛ(Организация, ПередачаРасчетаНДФЛ, Банк);
			Иначе
				УстановитьЗначениеПередачиРасчетаНДФЛ(Организация, ПередачаРасчетаНДФЛ);
			КонецЕсли;
			Оповестить("ИнтеграцияАУСН_ИзмененаПередачаРасчетаНДФЛ");
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура БанкПриИзменении(Элемент)

	БанкОбработатьИзменение();

КонецПроцедуры

&НаКлиенте
Процедура КакПолучитьКодЗаявкиОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)

	ИнтеграцияАУСНФормыКлиент.ПодсказкаПолучениеКодаЗаявкиОбработкаНавигационнойСсылки(
		ЭтотОбъект, Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка);

КонецПроцедуры

&НаКлиенте
Процедура КодЗаявкиПриИзменении(Элемент)

	КодЗаявкиОбработатьИзменение();

КонецПроцедуры

&НаКлиенте
Процедура КодЗаявкиИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)

	КодЗаявкиВведенныйТекст = СокрЛП(Текст);
	
	ПодключитьОбработчикОжидания("Подключаемый_НайтиЗаявку", 0.1, Истина);

КонецПроцедуры

&НаКлиенте
Процедура БанкНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	СписокБанков = Новый Массив;
	
	Для Каждого УполномоченныйБанк Из УполномоченныеБанки Цикл
		СписокБанков.Добавить(УполномоченныйБанк.Банк);
	КонецЦикла;
	
	ПараметрыОткрываемойФормы = Новый Структура;
	ОтборОткрываемойФормы = Новый Структура;
	ОтборОткрываемойФормы.Вставить("Ссылка", СписокБанков);
	ПараметрыОткрываемойФормы.Вставить("Отбор", ОтборОткрываемойФормы);
	ПараметрыОткрываемойФормы.Вставить("ОтображениеТаблицы", ОтображениеТаблицы.Список);
	
	ОткрытьФорму(
		"Справочник.КлассификаторБанков.ФормаВыбора",
		ПараметрыОткрываемойФормы,
		Элемент,
		УникальныйИдентификатор);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Далее(Команда)

	ОбработатьПереходДалее();

КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)

	ОбработатьПереходНазад();

КонецПроцедуры

&НаКлиенте
Процедура ОтклонитьЗаявку(Команда)

	Если ПроверитьЗаполнение() Тогда
		ТекстВопроса = НСтр("ru = 'Код заявки одноразовый, поэтому после ее отклонения повторное подключение будет недоступно.
			|Продолжить?'");
		Оповещение = Новый ОписаниеОповещения("ОтклонитьЗаявкуПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Отключить(Команда)
	
	ТекстВопроса = НСтр("ru = 'После отключения сервиса обмен данными по разметке операций и передача расчета НДФЛ в банк будут прекращены.
		|Продолжить?'");
	Оповещение = Новый ОписаниеОповещения("ОтключитьБанкПослеВопроса", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьПодключение(Команда)

	ОтключитьОбработчикОжидания("Подключаемый_ПроверитьПодключениеСервиса");
	ПроверитьПодключениеСервиса();

КонецПроцедуры

&НаКлиенте
Процедура Повторить(Команда)

	Если Не ЗначениеЗаполнено(КлючДоступа) Тогда
		СостояниеФормы = ВсеСостоянияФормы().ТребуетКлючаДоступа;
	Иначе
		СостояниеФормы = ВсеСостоянияФормы().Ожидание;
		ПривязатьНалогоплательщикаКВУС();
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьЗаявку(Команда)

	Если ПроверитьЗаполнение() Тогда
		ВыполнитьМетодВФоне("ПодтвердитьЗаявку");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтправитьЗапросНаПодключение(Команда)
	
	Если Не ЗначениеЗаполнено(КлючДоступа) Тогда
		Возврат;
	КонецЕсли;
	
	ПроверятьСостояниеКлюча = ИнтеграцияАУСНКлиентСервер.ПроверятьСостояниеКлюча();
	Если Не ИнтеграцияАУСНКлиентСервер.КлючДоступаСоответствуетТребованиям(КлючДоступа)
		Или (Не ПроверятьСостояниеКлюча И Не КлючДоступаДействителен(Организация, КлючДоступа)) Тогда
		Элементы.ПодсказкаКлючДоступа.Видимость = Истина;
		Возврат;
	КонецЕсли;
	Элементы.ПодсказкаКлючДоступа.Видимость = Ложь;
	
	ЗаписатьТокенПорталаАУСННаСервере(Организация, КлючДоступа);
	
	СостояниеФормы = ВсеСостоянияФормы().Ожидание;
	УправлениеФормой(ЭтотОбъект);
	
	Если ПроверятьСостояниеКлюча Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ОбработатьОтправкуЗапросаНаПодключение", 0.1, Истина);
	Иначе
		ВыполнитьМетодПодключения();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	
	СостояниеФормы = Форма.СостояниеФормы;
	ВсеСостоянияФормы = ВсеСостоянияФормы();
	
	ПоказыватьКомандуНазад = СостояниеФормы = ВсеСостоянияФормы.ТребуетКлючаДоступа
		Или СостояниеФормы = ВсеСостоянияФормы.Подключение
		Или СостояниеФормы = ВсеСостоянияФормы.Ошибка;
	ПоказыватьКомандуДалее = СостояниеФормы = ВсеСостоянияФормы.ВыборПодключения;
	ПоказыватьКомандуГотово = СостояниеФормы = ВсеСостоянияФормы.Подключено;
	ПоказыватьКомандуПодтвердить = СостояниеФормы = ВсеСостоянияФормы.Подключение;
	ПоказыватьКомандуОтправитьЗапрос = СостояниеФормы = ВсеСостоянияФормы.ТребуетКлючаДоступа;
	ПоказыватьКомандуПроверитьПодключение = СостояниеФормы = ВсеСостоянияФормы.ТребуетПодтверждения;
	ПоказыватьКомандуПовторить = СостояниеФормы = ВсеСостоянияФормы.Ошибка;
	ПоказыватьКомандуЗакрыть = СостояниеФормы = ВсеСостоянияФормы.ТребуетПодтверждения
		Или СостояниеФормы = ВсеСостоянияФормы.Ошибка
		Или СостояниеФормы = ВсеСостоянияФормы.ЗаявкаОтклонена;
	
	Если СостояниеФормы = ВсеСостоянияФормы.Ожидание Тогда
		
		Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
		Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Ложь;
		Элементы.СтраницаБанкПодключение.Видимость = Ложь;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаОжидание;
		
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.ВыборПодключения Тогда
		
		Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
		Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Ложь;
		Элементы.СтраницаБанкПодключение.Видимость = Ложь;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаВыборПодключения;
		
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.Подключение Тогда
		
		Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
		Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Ложь;
		Элементы.СтраницаБанкПодключение.Видимость = Истина;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаБанкПодключение;
		
		БанкВыбран = ЗначениеЗаполнено(Форма.Банк);
		
		Если БанкВыбран Тогда
			БанкПодключен = Ложь;
			НаименованиеБанка = "";
			СтруктураПоиска = Новый Структура("Банк", Форма.Банк);
			СтрокиУполномоченныхБанков = Форма.УполномоченныеБанки.НайтиСтроки(СтруктураПоиска);
			Если СтрокиУполномоченныхБанков.Количество() > 0 Тогда
				НаименованиеБанка = СтрокиУполномоченныхБанков[0].Наименование;
			КонецЕсли;
			
			СтруктураПоиска = Новый Структура("Сервис", Форма.Банк);
			СтрокиОписанияСервисов = Форма.ОписанияСервисов.НайтиСтроки(СтруктураПоиска);
			ВыбранИнтегрированныйБанк = СтрокиОписанияСервисов.Количество() > 0;
			
			Если ВыбранИнтегрированныйБанк Тогда
				СостояниеИнтеграции = СостояниеИнтеграции(Форма.Организация, Форма.Банк);
				БанкПодключен =
					СостояниеИнтеграции = ПредопределенноеЗначение("Перечисление.СостоянияИнтеграцииАУСН.Подключено");
				
				Элементы.ЗаголовокБанкПодключен.Заголовок = СтрШаблон(НСтр("ru = '%1 подключен'"), НаименованиеБанка);
			Иначе
				Элементы.ДекорацияОписаниеНеинтегрированногоБанка.Заголовок = ОписаниеНеинтегрированногоБанка(НаименованиеБанка);
				Элементы.ДекорацияОписаниеКорректировкаРазметки.Заголовок = ОписаниеПодсказкиКорректировкиРазметки();
				
				Элементы.ГруппаПодключениеДиректБанка.Видимость = Не Форма.ДиректБанкПодключен;
				Элементы.ГруппаДиректБанкПодключен.Видимость = Форма.ДиректБанкПодключен;
				
				Элементы.ГруппаПодключениеОбменаСФНС.Видимость = Не Форма.ОбменСФНСПодключен;
				Элементы.ГруппаОбменСФНСПодключен.Видимость = Форма.ОбменСФНСПодключен;
			КонецЕсли;
			
			Элементы.ГруппаИнтегрированныйБанкПодключен.Видимость = ВыбранИнтегрированныйБанк И БанкПодключен;
			Элементы.ГруппаИнтегрированныйБанкПодключение.Видимость = ВыбранИнтегрированныйБанк И Не БанкПодключен;
			Элементы.ГруппаОписаниеНеинтегрированногоБанка.Видимость = Не ВыбранИнтегрированныйБанк;
			
			ПоказыватьКомандуНазад = Не Форма.ОбменСФНСПодключен;
			ПоказыватьКомандуПодтвердить = ВыбранИнтегрированныйБанк И Не БанкПодключен;
			ПоказыватьКомандуЗакрыть = Не ВыбранИнтегрированныйБанк Или БанкПодключен;
		Иначе
			Элементы.ГруппаИнтегрированныйБанкПодключен.Видимость = Ложь;
			Элементы.ГруппаИнтегрированныйБанкПодключение.Видимость = Ложь;
			Элементы.ГруппаОписаниеНеинтегрированногоБанка.Видимость = Ложь;
			
			ПоказыватьКомандуПодтвердить = Ложь;
			ПоказыватьКомандуЗакрыть = Истина;
		КонецЕсли;
		
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.ЗаявкаОтклонена Тогда
		
		Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
		Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Ложь;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаБанкЗаявкаОтклонена;
		
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.ТребуетКлючаДоступа Тогда
		
		Элементы.СтраницаФНСКлючДоступа.Видимость = Истина;
		Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Ложь;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаФНСКлючДоступа;
		
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.ТребуетПодтверждения Тогда
		
		Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
		Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Истина;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаФНСПодтверждениеЗаявки;
		
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.Ошибка Тогда
		
		Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
		Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Ложь;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаОшибка;
		
		ПоказыватьКомандуПовторить = ЭтоПодключениеФНС(Форма.ТипПодключения);
		
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.Подключено Тогда
		
		ВключенаПередачаНДФЛ = ВключенаПередачаНДФЛИзПрограммы(Форма.Организация);
		ЭтоПодключениеБанка = ЭтоПодключениеБанка(Форма.ТипПодключения);
		
		Если ЭтоПодключениеБанка Тогда
			Элементы.СтраницыОбменПодключен.ТекущаяСтраница = Элементы.СтраницаПодключенБанк;
			
			БанкиБезПередачиНДФЛ = БанкиНеПоддерживающиеПередачуНДФЛ();
			ВозможнаПередачаНДФЛ = БанкиБезПередачиНДФЛ.Найти(Форма.Банк) = Неопределено;
			
			Элементы.ПередачаРасчетаНДФЛБанк.Видимость = Не ВключенаПередачаНДФЛ И ВозможнаПередачаНДФЛ;
			СтруктураПоиска = Новый Структура("Сервис", Форма.Банк);
			СтрокиОписанияСервисов = Форма.ОписанияСервисов.НайтиСтроки(СтруктураПоиска);
			Если СтрокиОписанияСервисов.Количество() > 0 Тогда
				Элементы.ПередачаРасчетаНДФЛБанк.Заголовок =
					СтрШаблон(НСтр("ru = 'Передавать расчет НДФЛ через %1'"), СтрокиОписанияСервисов[0].ИмяСервиса);
			КонецЕсли;
			
			Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
			Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Ложь;
		Иначе
			Элементы.СтраницыОбменПодключен.ТекущаяСтраница = Элементы.СтраницаПодключенФНС;
			Элементы.ПередачаРасчетаНДФЛБанк.Видимость = Не ВключенаПередачаНДФЛ;
			Элементы.СтраницаФНСКлючДоступа.Видимость = Ложь;
			Элементы.СтраницаФНСПодтверждениеЗаявки.Видимость = Истина;
		КонецЕсли;
		
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаПодключено;
		
	КонецЕсли;
	
	Элементы.ФормаНазад.Видимость = ПоказыватьКомандуНазад;
	Элементы.ФормаДалее.Видимость = ПоказыватьКомандуДалее;
	Элементы.ФормаПодтвердитьЗаявку.Видимость = ПоказыватьКомандуПодтвердить;
	Элементы.ФормаОтправитьЗапросНаПодключение.Видимость = ПоказыватьКомандуОтправитьЗапрос;
	Элементы.ФормаПроверитьПодключение.Видимость = ПоказыватьКомандуПроверитьПодключение;
	Элементы.Повторить.Видимость = ПоказыватьКомандуПовторить;
	Элементы.ФормаГотово.Видимость = ПоказыватьКомандуГотово;
	Элементы.ФормаЗакрыть.Видимость = ПоказыватьКомандуЗакрыть;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьСостояниеФормы(СостояниеФормы, Форма)
	
	Форма.СостояниеФормы = СостояниеФормы;
	УправлениеФормой(Форма);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВсеСостоянияФормы()

	Результат = Новый Структура;
	Результат.Вставить("Ожидание", "Ожидание фоновой операции");
	Результат.Вставить("ВыборПодключения", "Выбор варианта подключения");
	Результат.Вставить("Подключение", "Подключение обмена с банком");
	Результат.Вставить("ЗаявкаОтклонена", "Заявка отклонена");
	Результат.Вставить("ТребуетКлючаДоступа", "ТребуетКлючаДоступа");
	Результат.Вставить("ТребуетПодтверждения", "Требует подтверждения в личном кабинете");
	Результат.Вставить("Ошибка", "Ошибка");
	Результат.Вставить("Подключено", "Подключено");
	
	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ОбработатьПереходДалее()
	
	ВсеСостоянияФормы = ВсеСостоянияФормы();
	
	Если СостояниеФормы = ВсеСостоянияФормы.ВыборПодключения Тогда
		Если ЭтоПодключениеБанка(ТипПодключения) Тогда
			УстановитьСостояниеФормы(ВсеСостоянияФормы.Подключение, ЭтотОбъект);
		ИначеЕсли ЭтоПодключениеФНС(ТипПодключения) Тогда
			УстановитьСостояниеФормы(ВсеСостоянияФормы.ТребуетКлючаДоступа, ЭтотОбъект);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьПереходНазад()
	
	ВсеСостоянияФормы = ВсеСостоянияФормы();
	
	Если СостояниеФормы = ВсеСостоянияФормы.Подключение
		Или СостояниеФормы = ВсеСостоянияФормы.ТребуетКлючаДоступа Тогда
		УстановитьСостояниеФормы(ВсеСостоянияФормы.ВыборПодключения, ЭтотОбъект);
	ИначеЕсли СостояниеФормы = ВсеСостоянияФормы.Ошибка Тогда
		Если ЭтоПодключениеБанка(ТипПодключения) Тогда
			ВернутьсяКПодключениюБанка();
		ИначеЕсли ЭтоПодключениеФНС(ТипПодключения) Тогда
			ОчиститьКлючДоступаНаСервере(Организация);
			КлючДоступа = "";
			УстановитьСостояниеФормы(ВсеСостоянияФормы.ТребуетКлючаДоступа, ЭтотОбъект);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура БанкОбработатьИзменение()
	
	КодЗаявки = "";
	КодЗаявкиОбработатьИзменение();
	
	ДанныеБанка = ДанныеБанка(Организация, Банк);
	ЛичныйКабинетБанка  = ДанныеБанка.ЛичныйКабинет;
	ИдентификаторБанка  = ДанныеБанка.Идентификатор;
	БанковскийСчет      = ДанныеБанка.БанковскийСчет;
	ДиректБанкПодключен = ДанныеБанка.ДиректБанкПодключен;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокВыбораБанка()
	
	ВыбранныйБанк = Банк;
	
	КартинкаБанкПодключен = БиблиотекаКартинок.СветофорЗеленый;
	КартинкаИнтегрированныйБанк = БиблиотекаКартинок.СветофорЖелтый;
	КартинкаУполномоченныйБанк = БиблиотекаКартинок.СветофорСерый;
	
	СписокВыбораБанка = Элементы.Банк.СписокВыбора;
	СписокВыбораБанка.Очистить();
	
	Для Каждого СтрокаУполномоченныйБанк Из УполномоченныеБанки Цикл
		
		Если Не СтрокаУполномоченныйБанк.ВыводитьДляВыбора Тогда
			Продолжить;
		КонецЕсли;
		
		КартинкаПредставлениеБанка = КартинкаУполномоченныйБанк;
		
		Если СтрокаУполномоченныйБанк.Подключен Тогда
			КартинкаПредставлениеБанка = КартинкаБанкПодключен;
		ИначеЕсли СтрокаУполномоченныйБанк.ВозможноПодключить Тогда
			КартинкаПредставлениеБанка = КартинкаИнтегрированныйБанк;
		КонецЕсли;
		
		СписокВыбораБанка.Добавить(
			СтрокаУполномоченныйБанк.Банк, , , КартинкаПредставлениеБанка);
		
		ЗаполнитьВыборБанка = Не ЗначениеЗаполнено(ВыбранныйБанк) И СтрокаУполномоченныйБанк.ВозможноПодключить
			И Не СтрокаУполномоченныйБанк.Подключен И СтрокаУполномоченныйБанк.ЕстьРасчетныйСчет;
		
		Если ЗаполнитьВыборБанка Тогда
			ВыбранныйБанк = СтрокаУполномоченныйБанк.Банк;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Банк <> ВыбранныйБанк Тогда
		Банк = ВыбранныйБанк;
		ДанныеБанка = ДанныеБанка(Организация, Банк);
		ЛичныйКабинетБанка  = ДанныеБанка.ЛичныйКабинет;
		ИдентификаторБанка  = ДанныеБанка.Идентификатор;
		БанковскийСчет      = ДанныеБанка.БанковскийСчет;
		ДиректБанкПодключен = ДанныеБанка.ДиректБанкПодключен;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КодЗаявкиОбработатьИзменение()
	
	КодЗаявки = СокрЛП(КодЗаявки);
	
	ИнтеграцияАУСНФормыКлиент.ОбработатьИзменениеКодаЗаявки(ЭтотОбъект, КодЗаявки);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_НайтиЗаявку()
	
	ДлинаВведенногоКодаЗаявки = СтрДлина(КодЗаявкиВведенныйТекст);
	
	КодЗаявкиПодсказка = ИнтеграцияАУСНФормыКлиент.ПодсказкаКодаЗаявки(КодЗаявкиВведенныйТекст);
	
	Если ДлинаВведенногоКодаЗаявки = ДлинаКодаЗаявки() Тогда
		ВыполнитьМетодВФоне("НайтиЗаявку");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ДлинаКодаЗаявки()
	
	Возврат 36;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеБанка(Знач Организация, Знач Банк)
	
	Данные = НовыйДанныеБанка();
	Данные.ЛичныйКабинет = ИнтеграцияАУСНПовтИсп.СсылкаЛичныйКабинетБанка(Банк);
	Данные.Идентификатор = ИнтеграцияАУСНПовтИсп.ИдентификаторБанкаПоКлассификатору(Банк);
	Данные.БанковскийСчет = Обработки.ПодключениеАУСН.БанковскийСчетОрганизации(Организация, Банк);
	Данные.ДиректБанкПодключен = БанковскийСчетПодключенКДиректБанк(Организация, Данные.БанковскийСчет);
	
	Возврат Данные;
	
КонецФункции

&НаСервереБезКонтекста
Функция НовыйДанныеБанка()
	
	Данные = Новый Структура;
	Данные.Вставить("Идентификатор", "");
	Данные.Вставить("ЛичныйКабинет", "");
	Данные.Вставить("БанковскийСчет", Справочники.БанковскиеСчета.ПустаяСсылка());
	Данные.Вставить("ДиректБанкПодключен", Ложь);
	
	Возврат Данные;
	
КонецФункции

&НаСервереБезКонтекста
Функция БанковскийСчетПодключенКДиректБанк(Организация, БанковскийСчет)
	
	Если Не ЗначениеЗаполнено(БанковскийСчет) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	БанкРасчетногоСчета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчет, "Банк");
	
	НастройкаОбмена = ОбменСБанками.НастройкаОбмена(Организация, БанкРасчетногоСчета);
	
	УстановитьПривилегированныйРежим(Истина);
	ВключенаИнтеграцияСБанком = ЗначениеЗаполнено(БанкРасчетногоСчета)
		И Справочники.НастройкиИнтеграцииСБанками.НастройкаИнтеграцииОрганизацииСБанком(Организация, БанкРасчетногоСчета) <> Неопределено;
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ВключенаИнтеграцияСБанком И ЗначениеЗаполнено(НастройкаОбмена);
	
КонецФункции

&НаСервереБезКонтекста
Функция СостояниеИнтеграции(Знач Организация, Знач Банк)
	
	Возврат РегистрыСведений.СостоянияИнтеграцииАУСН.СостояниеИнтеграции(Организация, Банк);
	
КонецФункции

&НаСервереБезКонтекста
Функция ВключенаПередачаНДФЛИзПрограммы(Организация)
	
	Возврат РегистрыСведений.СостоянияИнтеграцииАУСН.МожемПередатьНДФЛИзПрограммы(Организация);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОписаниеНеинтегрированногоБанка(НаименованиеБанка)
	
	СтрокаОписание = НСтр("ru = 'Автоматический обмен с %1 пока не поддерживается.
	|
	|По вопросам интеграции %1 с 1С вы можете написать в поддержку банка, для удобства воспользуйтесь <a href=""ШаблонОбращенияВБанк"">Шаблоном обращения</a>.
	|
	|Если используется АУСН %1:'");
	
	#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
		Возврат СтроковыеФункции.ФорматированнаяСтрока(СтрокаОписание, НаименованиеБанка);
	#Иначе
		Возврат СтроковыеФункцииКлиент.ФорматированнаяСтрока(СтрокаОписание, НаименованиеБанка);
	#КонецЕсли
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОписаниеПодсказкиКорректировкиРазметки()
	
	Если ОбщегоНазначенияБПВызовСервера.ЭтоПростойИнтерфейс() Тогда
		ПутьКОтчету = НСтр("ru = 'Налоги - Банковские операции АУСН'");
	Иначе
		ПутьКОтчету = НСтр("ru = 'Отчеты - Банковские операции АУСН'");
	КонецЕсли;
	
	СтрокаОписание = НСтр("ru = 'Корректируйте разметку банковских операций в личном кабинете банка, сверяясь с отчетом в разделе <a href=""БанковскиеОперацииАУСН"">%1</a>'");
	
	#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
		Возврат СтроковыеФункции.ФорматированнаяСтрока(СтрокаОписание, ПутьКОтчету);
	#Иначе
		Возврат СтроковыеФункцииКлиент.ФорматированнаяСтрока(СтрокаОписание, ПутьКОтчету);
	#КонецЕсли
	
КонецФункции

