Процедура СортироватьБаннеры(ТаблицаБанков, УпорядоченнаяТаблицаБанков, Банк, КоличествоБаннеров) 
	
	// В упорядоченную таблицу записываются строки в случае, если в предыдущей строке услуга другого банка
	// В основной таблице такие строки помечаются как обработанные
	Для Каждого СтрокаТаблицы Из ТаблицаБанков Цикл
				
		Если СтрокаТаблицы.Банк <> Банк Тогда
			СтрокаУпорядоченнойТаблицы = УпорядоченнаяТаблицаБанков.Добавить(); 
			ЗаполнитьЗначенияСвойств(СтрокаУпорядоченнойТаблицы, СтрокаТаблицы);
			СтрокаТаблицы.Обработано = Истина;
		КонецЕсли;
		
		Банк = СтрокаТаблицы.Банк;
		
	КонецЦикла;
	Отбор = Новый Структура("Обработано", Ложь);
	НоваяТаблица = ТаблицаБанков.Скопировать(Отбор);
	
	// Если остались необработанные строки основной таблицы и в них есть услуги разных банков
	// то процедура выполняется рекурсивно
	Если НоваяТаблица.Количество() <> 0 И НоваяТаблица.Количество() <> ТаблицаБанков.Количество() Тогда  
		Банк = УпорядоченнаяТаблицаБанков[УпорядоченнаяТаблицаБанков.Количество() - 1].Банк;
		СортироватьБаннеры(НоваяТаблица, УпорядоченнаяТаблицаБанков, Банк, КоличествоБаннеров);
	КонецЕсли;
	
	// Оставшиеся необработанные строки исходной таблицы с услугами одного банка
	//добавляются в упорядоченную таблицу
	Если УпорядоченнаяТаблицаБанков.Количество() < КоличествоБаннеров Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НоваяТаблица, УпорядоченнаяТаблицаБанков);
	КонецЕсли;
	
КонецПроцедуры

Функция ПредложенияПоКоличествуБаннеров(КоличествоБаннеровНаФорме, УпорядоченнаяТаблицаБанков)
	
	ПодходящиеСтроки = Новый Массив;
		
	Для Каждого СтрокаТаблицы Из УпорядоченнаяТаблицаБанков Цикл 
		ПодходящиеСтроки.Добавить(СтрокаТаблицы);
		Если ПодходящиеСтроки.Количество() = КоличествоБаннеровНаФорме Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Возврат УпорядоченнаяТаблицаБанков.Скопировать(ПодходящиеСтроки);

КонецФункции

#КонецОбласти

#КонецЕсли
