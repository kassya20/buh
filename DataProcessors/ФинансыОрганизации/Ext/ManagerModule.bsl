Функция ПроверитьСреднемесячноеПоступлениеНаСчет(СведенияОКлиенте, ДатаПолучения, ФинансоваяУслуга, СтепеньСоответствия, КомпонентСоответствия)

	Если НЕ ЗначениеЗаполнено(ФинансоваяУслуга.МинСреднемесячноеПоступлениеНаСчет) Тогда
		Возврат Истина;
	КонецЕсли;
	
	ИмяПоказателя = "СредМесПоступлениеНаСчет";
	
	Если СведенияОКлиенте.ДополнительныеПоказатели[ИмяПоказателя] <> Неопределено Тогда
		ПоступлениеНаСчет = СведенияОКлиенте.ДополнительныеПоказатели[ИмяПоказателя];
	КонецЕсли;
	
	Если ПоступлениеНаСчет = Неопределено Тогда
		
		ПоступлениеНаСчетВКэше = УниверсальныйОбменСБанкамиФормы.ЗначениеПоказателяИзКэша(СведенияОКлиенте.ДатаАктуальности, СведенияОКлиенте.Организация, ИмяПоказателя);
		
		Если ПоступлениеНаСчетВКэше <> Неопределено Тогда
			ПоступлениеНаСчет = ПоступлениеНаСчетВКэше;
		Иначе
			ТаблицаПоступленияНаСчет = УниверсальныйОбменСБанкамиФормы.ПоступлениеНаСчет(СведенияОКлиенте.ДатаАктуальности, , СведенияОКлиенте.Организация);
			Если ТаблицаПоступленияНаСчет.Количество() > 0 Тогда
				ТаблицаПоступленияНаСчет.Свернуть("Организация", "Среднее");
				ПоступлениеНаСчет = ТаблицаПоступленияНаСчет[0].Среднее;
			Иначе
				ПоступлениеНаСчет = 0;
			КонецЕсли;
			РегистрыСведений.КэшПоказателейФинУслуги.ЗаписатьВРегистрПоказателиФинУслуги(ПоступлениеНаСчет,
				СведенияОКлиенте.ДатаАктуальности, СведенияОКлиенте.Организация, ИмяПоказателя)
		КонецЕсли;
		СведенияОКлиенте.ДополнительныеПоказатели.Вставить(ИмяПоказателя, ПоступлениеНаСчет);
	КонецЕсли;
	
	Если ПоступлениеНаСчет < ФинансоваяУслуга.МинСреднемесячноеПоступлениеНаСчет Тогда
		Возврат Ложь;
	Иначе
		СтепеньСоответствия = СтепеньСоответствия + КомпонентСоответствия;
	КонецЕсли;
	
	Возврат Истина;

