
#Область ОписаниеПеременных

&НаКлиенте
Перем ПараметрыОбработчикаОжидания;

&НаКлиенте
Перем ФормаДлительнойОперации;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;

	Если Константы.УчетЗарплатыИКадровВоВнешнейПрограмме.Получить() Тогда
		Элементы.ГруппаВариантыУчетаЗарплаты.ТекущаяСтраница = Элементы.СтраницаУчетЗарплатыИКадровВоВнешнейПрограмме;
		Возврат;
	КонецЕсли;
	
	Если УчетЗарплаты.ИспользоватьКадровуюИсторию() Тогда
		Обработки.ПростойИнтерфейсРазделСотрудники.ЗаменитьТекстЗапросаСпискаСотрудников(ЭтотОбъект);
	КонецЕсли;
	
	ЭтоМедленныйРежимРаботы = ОбщегоНазначенияБП.ЭтоМедленныйРежимРаботы() Или ОбщегоНазначения.ЭтоМобильныйКлиент();
	ЭтоВебКлиент            = ОбщегоНазначения.ЭтоВебКлиент();
	
	ОсновнаяОрганизация           = Справочники.Организации.ОрганизацияПоУмолчанию();
	ОтборОрганизация              = ОсновнаяОрганизация;
	ОтборОрганизацияИспользование = ЗначениеЗаполнено(ОтборОрганизация);
	
	ТекущаяДатаРаботы = ТекущаяДатаСеанса();
	Список.Параметры.УстановитьЗначениеПараметра("ТекущаяДатаРаботы", ТекущаяДатаРаботы);
	
	ПоказыватьУволенных = Истина;
	Элементы.ПоказыватьУволенных.Пометка = ПоказыватьУволенных;
	
	ПериодРегистрации = РасчетныйПериод(ОтборОрганизация, ТекущаяДатаРаботы);
	ОрганизацияПриИзмененииНаСервере();
		
	Список.Параметры.УстановитьЗначениеПараметра("ПериодРегистрации", ПериодРегистрации); 
	Список.Параметры.УстановитьЗначениеПараметра("ПериодРегистрацииНачало", НачалоМесяца(ПериодРегистрации));
	Список.Параметры.УстановитьЗначениеПараметра("ПериодРегистрацииКонец", КонецМесяца(ПериодРегистрации));
	
	АдресХранилища = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	Список.Параметры.УстановитьЗначениеПараметра("АдресХранилища", АдресХранилища);
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Список, "Работает", Истина, Ложь);
	
	ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников = ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников();
	Список.Параметры.УстановитьЗначениеПараметра("ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников",
		ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников);
	ПомеченныеНаУдалениеСервер.СкрытьПомеченныеНаУдаление(ЭтотОбъект);
	
	ПредставлениеПериодаРегистрации = ВыборПериодаКлиентСервер.ПолучитьПредставлениеПериодаОтчета(
		Перечисления.ДоступныеПериодыОтчета.Месяц, ПериодРегистрации, КонецМесяца(ПериодРегистрации));
	
	СпособВыплатыЗарплата = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.СпособыВыплатыЗарплаты.Зарплата");
	СпособВыплатыАванс    = Справочники.СпособыВыплатыЗарплаты.НайтиПоРеквизиту("ХарактерВыплаты", Перечисления.ХарактерВыплатыЗарплаты.Аванс);
	
	РасчетЗарплатыДляНебольшихОрганизаций = ПолучитьФункциональнуюОпцию("РасчетЗарплатыДляНебольшихОрганизаций");
	Элементы.ГруппаКомандыДокументы.Видимость = РасчетЗарплатыДляНебольшихОрганизаций;
	Элементы.ДокументСправкаНДФЛ.Видимость = Не РасчетЗарплатыДляНебольшихОрганизаций;
	Элементы.СотрудникОформитьДоговорРаботыУслуги.Видимость = РасчетЗарплатыДляНебольшихОрганизаций;
	
	ИспользоватьКадровыйУчет = ПолучитьФункциональнуюОпцию("ИспользоватьКадровыйУчет");
	ИспользоватьНачисленияПоДоговорам = ПолучитьФункциональнуюОпцию("ИспользоватьНачисленияПоДоговорам");
	
	Если ИспользоватьНачисленияПоДоговорам Тогда
		ОтборРолиСотрудников = Перечисления.РолиСотрудников.ПустаяСсылка();
		ДополнитьОтборНаСервере();
	КонецЕсли;
	
	ИмяРаздела = Новый Структура;
	ИмяРаздела.Вставить("ИмяФормы","Раздел.Сотрудники");
	ИмяРаздела.Вставить("Элементы",Элементы);
	УправлениеПанельюПодсказки.ПриСозданииНаСервере(ИмяРаздела);
	
	УстановитьУсловноеОформление();
	
	Если Не ЗначениеЗаполнено(ОтборОрганизация) Тогда
		УправлениеФормой(ЭтотОбъект);
	Иначе
		ПустойСписок = ПустойСписок(ОтборОрганизация);
		Если ПустойСписок Тогда
			УправлениеФормой(ЭтотОбъект);
		КонецЕсли;
	КонецЕсли;
	
	Если ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников
		И Не ПустойСписок И Не ЭтоМедленныйРежимРаботы И Не ЭтоВебКлиент Тогда
		ОбновитьИтогиРаздела();
		ЗагрузитьИтоги();
	КонецЕсли;
	
	// ИнтернетПоддержкаПользователей.Новости.КонтекстныеНовости_ПриСозданииНаСервере
	ИдентификаторыСобытийПриОткрытии = "ПриОткрытии";
	ОбработкаНовостейПереопределяемый.КонтекстныеНовости_ПриСозданииНаСервере(
		ЭтотОбъект,
		"БП.Обработка.ПростойИнтерфейсРазделСотрудники",
		"Форма",
		НСтр("ru='Новости: Сотрудники'"),
		ИдентификаторыСобытийПриОткрытии
	);
	// Конец ИнтернетПоддержкаПользователей.Новости.КонтекстныеНовости_ПриСозданииНаСервере
	
	СкрыватьПомеченныеНаУдаление = ПомеченныеНаУдалениеСервер.СкрыватьПомеченныеНаУдаление();
	ОтслеживатьПометкуУдаления = ПомеченныеНаУдалениеСервер.ОтслеживатьПометкуУдаления();
	
	МобильныйКлиентАдаптацияФормы();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если Не ПустойСписок Тогда
		
		Если (ЭтоМедленныйРежимРаботы Или ЭтоВебКлиент)  Тогда
			ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
		КонецЕсли;
		
		ПодключитьОбработчикОжидания("ПоказатьИнформациюОПравеПримененияСпецрежима", 0.1, Истина);
		
		ПодключитьОбработчикОжидания("ПоказатьПредупреждениеПревышениеЛимитаТарифа", 0.1, Истина);
		
	КонецЕсли;
	
	// ИнтернетПоддержкаПользователей.Новости.ПриОткрытии
	ОбработкаНовостейКлиент.КонтекстныеНовости_ПриОткрытии(ЭтотОбъект);
	// Конец ИнтернетПоддержкаПользователей.Новости.ПриОткрытии
	
	ПодключитьОбработчикОжидания("Подключаемый_УстановитьБаннер", 1, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	УправлениеПанельюПодсказкиКлиент.ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);

	Организация = ОрганизацияДляОтбора(ОтборОрганизацияИспользование, ОтборОрганизация);
	
	Если ИмяСобытия = "ИзменениеОсновнойОрганизации" Тогда
		ОсновнаяОрганизация = Параметр;
		Если ОсновнаяОрганизация <> ОтборОрганизация Тогда
			ОтборОрганизация                 = ОсновнаяОрганизация;
			ОтборОрганизацияИспользование    = ЗначениеЗаполнено(ОтборОрганизация);
			ОбнулитьИтоги(ЭтотОбъект);
			ОрганизацияПриИзмененииНаСервере();
			ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
			УстановитьБаннер();
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ИзменениеДанныхМестаРаботы" Тогда
		
		ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
		
	ИначеЕсли ИмяСобытия = "СозданСотрудник"
		Или ИмяСобытия = "Запись_Сотрудники" Или ИмяСобытия = "ИзменениеКадровыхДокументов" Тогда
		
		Элементы.Список.Обновить();
		ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
		
		Если ПустойСписок Тогда
			ПустойСписок = Ложь;
			УправлениеФормой(ЭтотОбъект);
		КонецЕсли;
		
		ПодключитьОбработчикОжидания("ПоказатьИнформациюОПравеПримененияСпецрежима", 0.1, Истина);
		Оповестить("ПоказатьИнформациюОПравеПримененияСпецрежима", Организация, ЭтотОбъект);
		
		ПодключитьОбработчикОжидания("ПоказатьПредупреждениеПревышениеЛимитаТарифа", 0.1, Истина);
		
	ИначеЕсли ИмяСобытия = "Запись_НачислениеЗарплаты"
		Или ИмяСобытия = "Запись_БольничныйЛист"
		Или ИмяСобытия = "Запись_Отпуск"
		Или ИмяСобытия = "Запись_ВедомостьНаВыплатуЗарплатыВБанк"
		Или ИмяСобытия = "Запись_ВедомостьНаВыплатуЗарплатыВКассу"
		Или ИмяСобытия = "Запись_ПриемНаРаботу"
		Или ИмяСобытия = "Запись_КадровыйПеревод"
		Или ИмяСобытия = "Запись_Увольнение" Тогда
		
		Элементы.Список.Обновить();
		ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
		ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
		
		ПодключитьОбработчикОжидания("ПоказатьИнформациюОПравеПримененияСпецрежима", 0.1, Истина);
		Оповестить("ПоказатьИнформациюОПравеПримененияСпецрежима", Организация, ЭтотОбъект);
		
		ПодключитьОбработчикОжидания("ПоказатьПредупреждениеПревышениеЛимитаТарифа", 0.1, Истина);
			
	ИначеЕсли ИмяСобытия = "Запись_НачислениеДивидендов"
		Или ИмяСобытия = "Запись_ДоговорРаботыУслуги" Тогда
		
		Элементы.Список.Обновить();
		ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
		ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
		
	ИначеЕсли ИмяСобытия = "Запись_СписаниеСРасчетногоСчета"
		Или ИмяСобытия = "Запись_РасходныйКассовыйОрдер" 
		Или ИмяСобытия = "ОбновитьФорму" Тогда
		
		Если ТребуетсяПолучитьДанныеОплаты(Источник) Тогда
			Элементы.Список.Обновить();
			ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
			ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ЗарплатаРассчитана_ПомощникУчетаЗарплаты" Тогда
		Элементы.Список.Обновить();
		ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
		ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
		
	ИначеЕсли ИмяСобытия = "ПоказатьИнформациюОПравеПримененияСпецрежима" Тогда
		Если Источник <> ЭтотОбъект И Параметр = Организация Тогда
			ПодключитьОбработчикОжидания("ПоказатьИнформациюОПравеПримененияСпецрежима", 0.1, Истина);
		КонецЕсли;
	ИначеЕсли ИмяСобытия = "Запись_НаборКонстант" И Источник
		= "ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников" Тогда

		ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников =
			ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников();
		Список.Параметры.УстановитьЗначениеПараметра("ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников",
			ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников);
		УправлениеФормой(ЭтотОбъект);
		ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
		ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела", 0.5, Истина);

	ИначеЕсли (ИмяСобытия = "Запись_УзелПланаОбмена" 
		Или ИмяСобытия = "ИзменениеРежимаВеденияКадровогоУчетаИРасчетаЗарплаты") И ВключенаПодсистемаЗарплата() Тогда

		ПараметрыОткрытияРаздела = Новый Структура;
		ПараметрыОткрытияРаздела.Вставить("Уникальность", Истина);
	
		ОткрытьФорму("ЖурналДокументов.ЖурналОпераций.Форма.ФормаСпискаОтражениеЗарплаты",
			,
			,
			ПараметрыОткрытияРаздела.Уникальность);
		
		Закрыть();
		
	КонецЕсли;
	
	// ИнтернетПоддержкаПользователей.Новости.ОбработкаОповещения
	ОбработкаНовостейКлиент.КонтекстныеНовости_ОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник);
	// Конец ИнтернетПоддержкаПользователей.Новости.ОбработкаОповещения
	
КонецПроцедуры


&НаКлиенте
Процедура ОбработкаНавигационнойСсылки(НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	ПерсонализированныеПредложенияСервисовКлиент.ПерейтиПоСсылкеБаннера(
		НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка, Баннер, ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	СтруктураОтбора = Неопределено;
	Если Параметры.Свойство("Отбор", СтруктураОтбора) И ЗначениеЗаполнено(СтруктураОтбора) 
		И СтруктураОтбора.Свойство("Организация") И ЗначениеЗаполнено(СтруктураОтбора.Организация) Тогда
		
		ОтборОрганизация = СтруктураОтбора.Организация;
		ОтборОрганизацияИспользование = ЗначениеЗаполнено(ОтборОрганизация);
		Параметры.Отбор.Удалить("Организация");
	Иначе
		Если ЗначениеЗаполнено(ОсновнаяОрганизация) И ОтборОрганизация <> ОсновнаяОрганизация Тогда
			ОтборОрганизация = ОсновнаяОрганизация;
			ОтборОрганизацияИспользование = ЗначениеЗаполнено(ОтборОрганизация);
		ИначеЕсли Не ОтборОрганизацияИспользование Тогда
			ОтборОрганизацияИспользование = ЗначениеЗаполнено(ОтборОрганизация);
		КонецЕсли;
	КонецЕсли;
	
	ОрганизацияПриИзмененииНаСервере();

	ДополнитьОтборНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	ОтборОрганизацияИспользование = ЗначениеЗаполнено(ОтборОрганизация);
	ОрганизацияПриИзмененииНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборОрганизацияИспользованиеПриИзменении(Элемент)
	
	ОрганизацияПриИзмененииНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеПериодаРегистрацииПриИзменении(Элемент)
	
	ПриИзмененииПериода();
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеПериодаРегистрацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыВыбора = Новый Структура("НачалоПериода, КонецПериода", ПериодРегистрации, КонецМесяца(ПериодРегистрации));
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыбратьПериодЗавершение", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.ВыборСтандартногоПериодаМесяц", ПараметрыВыбора, Элементы.ПредставлениеПериодаРегистрации, , , , ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеПериодаРегистрацииОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
