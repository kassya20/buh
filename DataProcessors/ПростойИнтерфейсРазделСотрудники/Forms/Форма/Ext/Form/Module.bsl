&НаКлиенте
Процедура РасчетЗарплаты(Команда)
	
	Организация = ОрганизацияДляОтбора(ОтборОрганизацияИспользование, ОтборОрганизация);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация",      Организация);
	ПараметрыФормы.Вставить("ПериодСобытия",    КонецМесяца(ПериодРегистрации));
	ПараметрыФормы.Вставить("Правило",          "");
	
	ОткрытьФорму("Обработка.ПомощникУчетаЗарплаты.Форма.Форма", ПараметрыФормы);
		
КонецПроцедуры

&НаКлиенте
