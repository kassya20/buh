	ПриИзмененииПериодаНаСервере();
	
	ПодключитьОбработчикОжидания("Подключаемый_ПолучитьИтогиРаздела",0.5, Истина);
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьОтборНаСервере()
	
	Список.Параметры.УстановитьЗначениеПараметра("РолиСотрудников", ОтборРолиСотрудников);
	
	ОсновнаяГруппаОтбора = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы, "ОтборРолиСотрудников" , ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
	// Очистим таблицу взаиморасчетов с работниками, чтобы обновить данные
	ПоместитьВоВременноеХранилище(Неопределено, АдресХранилища);
	
	Если ОтборРолиСотрудников = Перечисления.РолиСотрудников.Договорник Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
			ОсновнаяГруппаОтбора,
