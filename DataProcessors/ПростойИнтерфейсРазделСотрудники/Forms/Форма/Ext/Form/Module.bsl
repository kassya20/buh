#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;
	
	Если Поле.Имя = "ВидНачисленияЗарплата"
		Или Поле.Имя = "Начислено"
		Или Поле.Имя = "Удержано"
		Или Поле.Имя = "Выплачено"
		Или Поле.Имя = "КВыплате"
		Или Поле.Имя = "НачисленоДоговоры" Тогда
		ОткрытьРасчетныйДокумент("НачислениеЗарплаты");
	ИначеЕсли Поле.Имя = "ВидНачисленияДивиденды"
		Или Поле.Имя = "НачисленоДивиденды"
		Или Поле.Имя = "НДФЛДивиденды"
		Или Поле.Имя = "ВыплаченоДивиденды"
		Или Поле.Имя = "КВыплатеДивиденды" Тогда
		ОткрытьРасчетныйДокумент("НачислениеДивидендов");
	Иначе
		ОткрытьКарточкуСотрудника();
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Если Строки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	Организация = Настройки.ПараметрыДанных.Элементы.Найти("Организация").Значение;
	ПериодРегистрации = Настройки.ПараметрыДанных.Элементы.Найти("ПериодРегистрации").Значение;
	ТекущаяДатаРаботы = Настройки.ПараметрыДанных.Элементы.Найти("ТекущаяДатаРаботы").Значение;
	РолиСотрудников = Настройки.ПараметрыДанных.Элементы.Найти("РолиСотрудников").Значение;
	АдресХранилища = Настройки.ПараметрыДанных.Элементы.Найти("АдресХранилища").Значение;
	ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников =
		Настройки.ПараметрыДанных.Элементы.Найти("ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников").Значение;
	МассивСотрудников = Строки.ПолучитьКлючи();
	
	ПараметрыОбработки = Обработки.ПростойИнтерфейсРазделСотрудники.НовыйПараметрыОбработки();
	ПараметрыОбработки.Организация = Организация;
	ПараметрыОбработки.РолиСотрудников = РолиСотрудников;
	ПараметрыОбработки.ПериодРегистрации = ПериодРегистрации;
	ПараметрыОбработки.ТекущаяДатаРаботы = ТекущаяДатаРаботы;
	ПараметрыОбработки.ВключатьСведенияПоСотрудникам = Ложь;
		
	Если Не ОтображатьИтогиПоНачислениямИВыплатамВСпискеСотрудников Тогда
		ПараметрыОбработки.МассивСотрудников =  МассивСотрудников;
	КонецЕсли;
	
	ТаблицаВзаиморасчетов = ПолучитьИзВременногоХранилища(АдресХранилища);
	Если ТаблицаВзаиморасчетов = Неопределено Тогда

		Обработки.ПростойИнтерфейсРазделСотрудники.ПодготовитьДанные(
			ПараметрыОбработки, АдресХранилища);
		ПодготовленныеДанные = ПолучитьИзВременногоХранилища(АдресХранилища);
		
		Если ЗначениеЗаполнено(ПодготовленныеДанные.Список) Тогда
			ПоместитьВоВременноеХранилище(ПодготовленныеДанные.Список, АдресХранилища);
			ТаблицаВзаиморасчетов = ПодготовленныеДанные.Список;
		Иначе
			Возврат;
		КонецЕсли;
		
		ПоместитьВоВременноеХранилище(ТаблицаВзаиморасчетов, АдресХранилища);
	КонецЕсли;
	
	Если ТипЗнч(ТаблицаВзаиморасчетов) <> Тип("ТаблицаЗначений") Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Сотрудник Из МассивСотрудников Цикл
		Отбор = Новый Структура("Ссылка", Сотрудник);
		СтрокиВзаиморасчетов = ТаблицаВзаиморасчетов.НайтиСтроки(Отбор);
		Если СтрокиВзаиморасчетов.Количество() > 0 Тогда
			СтрокаВзаиморасчетов = СтрокиВзаиморасчетов[0];
			Строка = Строки.Получить(СтрокаВзаиморасчетов.Ссылка);
			ЗаполнитьЗначенияСвойств(Строка.Данные, СтрокаВзаиморасчетов, , "Работает");
			УстановитьОформлениеСтроки(Строка);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

