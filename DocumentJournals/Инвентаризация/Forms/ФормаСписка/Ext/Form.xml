			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ЖурналДокументовИнвентаризация.Ссылка КАК Ссылка,
	ЖурналДокументовИнвентаризация.Дата КАК Дата,
	ЖурналДокументовИнвентаризация.ПометкаУдаления КАК ПометкаУдаления,
	ЖурналДокументовИнвентаризация.Номер КАК Номер,
	ЖурналДокументовИнвентаризация.Проведен КАК Проведен,
	ЖурналДокументовИнвентаризация.Организация КАК Организация,
	ЖурналДокументовИнвентаризация.ПричинаПроведенияИнвентаризации КАК ПричинаПроведенияИнвентаризации,
	ЖурналДокументовИнвентаризация.Ответственный КАК Ответственный,
	ЖурналДокументовИнвентаризация.Комментарий КАК Комментарий,
	ЖурналДокументовИнвентаризация.Тип КАК Тип,
	ВЫБОР
		КОГДА ЖурналДокументовИнвентаризация.ПометкаУдаления = ИСТИНА
			ТОГДА 2
		КОГДА ЖурналДокументовИнвентаризация.Проведен = ИСТИНА
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК СостояниеДокумента,
	ВЫБОР
		КОГДА ЖурналДокументовИнвентаризация.Тип = ТИП(Документ.ИнвентаризацияОС)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляИнвентаризации.ОсновныеСредства)
		КОГДА ЖурналДокументовИнвентаризация.Тип = ТИП(Документ.ИнвентаризацияНМА)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляИнвентаризации.НематериальныеАктивы)
		КОГДА ЖурналДокументовИнвентаризация.Тип = ТИП(Документ.ИнвентаризацияТоваровНаСкладе)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляИнвентаризации.Запасы)
		КОГДА ЖурналДокументовИнвентаризация.Тип = ТИП(Документ.ИнвентаризацияНЗП)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляИнвентаризации.НезавершенноеПроизводство)
		КОГДА ЖурналДокументовИнвентаризация.Тип = ТИП(Документ.ИнвентаризацияКассы)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляИнвентаризации.Касса)
		КОГДА ЖурналДокументовИнвентаризация.Тип = ТИП(Документ.ИнвентаризацияРасчетовСКонтрагентами)
			ТОГДА ЗНАЧЕНИЕ(Перечисление.РазделыУчетаДляИнвентаризации.РасчетыСКонтрагентами)
		КОГДА ЖурналДокументовИнвентаризация.Тип = ТИП(Документ.ИнвентаризацияОбъектовУчета)
			ТОГДА ЖурналДокументовИнвентаризация.Ссылка.РазделУчета
	КОНЕЦ КАК РазделУчета
ИЗ
	ЖурналДокументов.Инвентаризация КАК ЖурналДокументовИнвентаризация</QueryText>
