&НаКлиенте
Процедура Подключаемый_ОбновитьИнформациюИБаннерыАвтозагрузки()
	
	РезультатОбновленияБаннера = ОбновитьИнформациюИБаннерыАвтозагрузкиНаСервере();
	Если РезультатОбновленияБаннера.Свойство("ОжидатьОкончанияОбмена") Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ВыполнитьОбновлениеИнформацииИБаннеровАвтозагрузки", 10, Истина);
	КонецЕсли;
	Если РезультатОбновленияБаннера.Свойство("ЗакрытьБаннер") Тогда
		ЗакрытьБаннерНажатие("");
	КонецЕсли;
	Если РезультатОбновленияБаннера.Свойство("ОбновитьИтоги") Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ОбновитьИтогиОбработчик", 0.2, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ОбновитьИнформациюИБаннерыАвтозагрузкиНаСервере()
	
	РезультатОбновления = Новый Структура;
	ПоказатьБаннерПредупрежденийПриЗагрузкеИУстановитьОтбор();
	
	Если Не ИнтеграцияАУСН.ВозможноПрочитатьДанныеОбмена() Тогда
		РезультатОбновления.Вставить("ОжидатьОкончанияОбмена", Истина);
		Возврат РезультатОбновления;
	КонецЕсли;
	
	ОбновитьИнформациюАвтозагрузки();
	ПараметрыОтображенияБаннеров = РаботаСОповещениямиОСостоянииОбменаССервисами.ПараметрыОтображенияБаннера(
		АдресДанныхСостоянияОбмена);
	
	// Правила отображения баннеров:
	// 1. Если есть ошибка автоматической загрузки, то отображем красный баннер про ошибку
	//    и прячем желтый баннер об успешной синхронизации (если он активен)
	// 2. Если необходимо повторно прочитать документы сервиса АУСН, то появится красный баннер со ссылкой на
	//    журнал обмена с сервисом АУСН, где можно вызвать повторное чтение документов
	//    и прячем желтый баннер об успешной синхронизации (если он активен)
	// 3. Если есть ошибка по учетным документам, то появится красный баннер про ошибки в учетных документах,
	//    и прячем желтый баннер об успешной синхронизации (если он активен)
	// 4. Если нет ошибок, и баннер про успешную синхронизацию не показан,
	//    то проверяем новую дату синхронизации, если она изменилась, то покажем желтый баннер об успешной синхронизации
	//
	// Правило 1
	Если ПараметрыОтображенияБаннеров.ОтображатьБаннерОшибки Тогда
		Элементы.ГруппаСостояниеАвтоЗагрузкиОшибка.Видимость = Истина;
		Элементы.ГруппаСостояниеАвтозагрузки.Видимость = Ложь; 
		Элементы.ГруппаНеобходимоПовторноеЧтение.Видимость = Ложь;
		ЭтотОбъект.ИнформацияАвтозагрузкиДиректБанк_ТекущаяДатаСинхронизации = Неопределено;
		Если Элементы.Баннер.Видимость Тогда
			РезультатОбновления.Вставить("ЗакрытьБаннер", Истина);
		КонецЕсли;
		Возврат РезультатОбновления;
	Иначе
		Элементы.ГруппаСостояниеАвтоЗагрузкиОшибка.Видимость = Ложь;
		ЭтотОбъект.ИнформацияАвтозагрузкиДиректБанк_ДатаОшибки = Неопределено;
	КонецЕсли;
	
	// Правило 2
	Если ПараметрыОтображенияБаннеров.ОтображатьНеобходимостьПовторногоЧтения Тогда
		Элементы.ГруппаНеобходимоПовторноеЧтение.Видимость = Истина;
		Элементы.ГруппаСостояниеАвтозагрузкиОшибка.Видимость = Ложь;
		Элементы.ГруппаСостояниеАвтозагрузки.Видимость = Ложь;
		Если Элементы.Баннер.Видимость Тогда
			РезультатОбновления.Вставить("ЗакрытьБаннер", Истина);
		КонецЕсли;
	Иначе
		Элементы.ГруппаНеобходимоПовторноеЧтение.Видимость = Ложь;
	КонецЕсли;
	
	// Правило 3
	Если ЕстьПредупреждения Тогда
		Элементы.ГруппаСостояниеАвтозагрузки.Видимость = Ложь;
		Если Элементы.Баннер.Видимость Тогда
			РезультатОбновления.Вставить("ЗакрытьБаннер", Истина);
		КонецЕсли;
		Возврат РезультатОбновления;
	КонецЕсли;
	
	//Правило 4
	Если ПараметрыОтображенияБаннеров.ОтображатьБаннерСостоянияЗагрузки
		И Не Элементы.ГруппаСостояниеАвтозагрузки.Видимость
		И (ИнформацияАвтозагрузкиДиректБанк_ТекущаяДатаСинхронизации <> ИнформацияАвтозагрузки_НоваяДатаСинхронизации)
		И Не ЕстьПредупреждения И ЗначениеЗаполнено(Элементы.ТекстСостояниеАвтозагрузки.Заголовок) Тогда
		Элементы.ГруппаСостояниеАвтозагрузки.Видимость = Истина;
		Элементы.ГруппаНеобходимоПовторноеЧтение.Видимость = Ложь;
		ИнформацияАвтозагрузкиДиректБанк_ТекущаяДатаСинхронизации = ИнформацияАвтозагрузки_НоваяДатаСинхронизации;
		Элементы.Список.Обновить();
		РезультатОбновления.Вставить("Подключаемый_ОбновитьИтогиОбработчик", Истина);
	КонецЕсли;
	
	Возврат РезультатОбновления;
	
КонецФункции

#КонецОбласти

#Область УправлениеФормой

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	// Организация
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Организация");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ОтборОрганизацияИспользование", ВидСравненияКомпоновкиДанных.Равно, Истина);
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ОтборОрганизация", ВидСравненияКомпоновкиДанных.Заполнено);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	// БанковскийСчет
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "БанковскийСчет");
	
	ГруппаОтбораИли = КомпоновкаДанныхКлиентСервер.ДобавитьГруппуОтбора(
		ЭлементУО.Отбор.Элементы, ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
		
	ГруппаОтбораИ = КомпоновкаДанныхКлиентСервер.ДобавитьГруппуОтбора(
		ГруппаОтбораИли.Элементы, ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбораИ,
		"ОтборБанковскийСчетИспользование", ВидСравненияКомпоновкиДанных.Равно, Истина);
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбораИ,
		"ОтборБанковскийСчет", ВидСравненияКомпоновкиДанных.Заполнено);
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ГруппаОтбораИли,
		"ОтборВсеДеньги", ВидСравненияКомпоновкиДанных.НеРавно, 1); // Банк
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	Если ИнтеграцияСБанкамиПодключена Тогда
		
		// Комментарий
		
		ЭлементУО = УсловноеОформление.Элементы.Добавить();
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Комментарий");
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"ИнтеграцияСБанкамиПодключена", ВидСравненияКомпоновкиДанных.Равно, Истина);
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
		
	КонецЕсли;
	
	// НазначениеПлатежа, НомерВходящегоДокумента, ДатаВходящегоДокумента
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НазначениеПлатежа");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НомерВходящегоДокумента");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДатаВходящегоДокумента");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ОтборВсеДеньги", ВидСравненияКомпоновкиДанных.НеРавно, 1); // Банк
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	// Тип
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Тип");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ОтборВсеДеньги", ВидСравненияКомпоновкиДанных.НеРавно, 0); // Все деньги
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	// Выделение строки с предупреждениями
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Дата");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Доход");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Расход");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "СтатусАУСН");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Контрагент");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ВидОперации");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Тип");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Комментарий");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Номер");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Организация");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "БанковскийСчет");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НазначениеПлатежа");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "НомерВходящегоДокумента");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ДатаВходящегоДокумента");
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Ответственный");
	
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Список.ЕстьПредупреждения", ВидСравненияКомпоновкиДанных.Равно, Истина);
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.БанковскиеДокументыСПредупреждениямиПриЗагрузке);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИтоги()
	
	Дата = ?(ОтборДатаОтбораИспользование, ОтборДатаОтбора, Неопределено);
	Организация = ?(ОтборОрганизацияИспользование, ОтборОрганизация, Неопределено);
	БанковскийСчет = ?(ОтборБанковскийСчетИспользование, ОтборБанковскийСчет, Неопределено);
	
	СтруктураИтогов = ПолучитьИтоги(Дата, Организация, БанковскийСчет, ОтборВсеДеньги);
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, СтруктураИтогов);
	
	Если ОбщегоНазначенияКлиентСервер.ЭтоМобильныйКлиент() Тогда
		УстановитьЗаголовкиГруппыИтогиМК(Элементы.ГруппаИтоги, ИтогДата, ИтогиНаКонецДня);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьИтоги(ДатаОтбора, Организация, БанковскийСчет, ОтборВсеДеньги)
	
	Если Не ЗначениеЗаполнено(ДатаОтбора) Тогда
		ДатаОтбора = ТекущаяДатаСеанса();
	КонецЕсли;
	
	СтруктураРезультат = Новый Структура;
	СтруктураРезультат.Вставить("ИтогДата", ДатаОтбора);
	СтруктураРезультат.Вставить("ИтогиНаНачалоДня", 0);
	СтруктураРезультат.Вставить("ИтогиПоступило", 0);
	СтруктураРезультат.Вставить("ИтогиСписано", 0);
	СтруктураРезультат.Вставить("ИтогиНаКонецДня", 0);
	
	СписокДоступныхОрганизаций = ОбщегоНазначенияБПВызовСервераПовтИсп.ВсеОрганизацииДанныеКоторыхДоступныПоRLS(Ложь);
	// Если нет доступных организаций, то Итоги не вычисляем
	Если СписокДоступныхОрганизаций.Количество() = 0 Тогда
		Возврат СтруктураРезультат;
	ИначеЕсли ЗначениеЗаполнено(Организация) Тогда
		// Если организация не числится в списке доступных, то Итоги не вычисляем
		Если СписокДоступныхОрганизаций.Найти(Организация) = Неопределено Тогда
			Возврат СтруктураРезультат;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Организация) Тогда
		СписокОрганизаций = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Организация);
	Иначе
		СписокОрганизаций = СписокДоступныхОрганизаций;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаИтоговНачалоДня", НачалоДня(ДатаОтбора));
	Запрос.УстановитьПараметр("ДатаИтоговКонецДня", КонецДня(ДатаОтбора));
	Запрос.УстановитьПараметр("Организации", СписокОрганизаций);
	
	Если Не ТолькоБанк(ОтборВсеДеньги) Тогда
		СчетаУчетаНаличныхДС = Новый Массив;
		СчетаУчетаНаличныхДС.Добавить(ПланыСчетов.Хозрасчетный.Касса);
		СчетаУчетаНаличныхДС.Добавить(ПланыСчетов.Хозрасчетный.КассаОрганизации);
		СчетаУчетаНаличныхДС.Добавить(ПланыСчетов.Хозрасчетный.ОперационнаяКасса);
		СчетаУчетаНаличныхДС.Добавить(ПланыСчетов.Хозрасчетный.КассаПлатежногоАгента);
		СчетаУчетаНаличныхДС.Добавить(ПланыСчетов.Хозрасчетный.КассаОрганизацииВал);
		Запрос.УстановитьПараметр("СчетаУчетаНаличныхДС", СчетаУчетаНаличныхДС);
	КонецЕсли;
	
	Если Не ТолькоКасса(ОтборВсеДеньги) Тогда
		Запрос.УстановитьПараметр("СчетаУчетаБезналичныхДС",
			УчетДенежныхСредствПовтИсп.ПолучитьСчетаССубконтоБанковскиеСчета());
		Запрос.УстановитьПараметр("СубконтоБанковскиеСчета",
			ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.БанковскиеСчета);
	КонецЕсли;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(ВЫБОР
	|		КОГДА ОстаткиИОбороты.ЭтоВалютныйСчет
	|			ТОГДА ОстаткиИОбороты.ВалютнаяСуммаНачальныйОстаток
	|		ИНАЧЕ ОстаткиИОбороты.СуммаНачальныйОстаток
	|	КОНЕЦ) КАК ИтогиНаНачалоДня,
	|	СУММА(ВЫБОР
	|		КОГДА ОстаткиИОбороты.ЭтоВалютныйСчет
	|			ТОГДА ОстаткиИОбороты.ВалютнаяСуммаОборотДт
	|		ИНАЧЕ ОстаткиИОбороты.СуммаОборотДт
	|	КОНЕЦ) КАК ИтогиПоступило,
	|	СУММА(ВЫБОР
	|		КОГДА ОстаткиИОбороты.ЭтоВалютныйСчет
	|			ТОГДА ОстаткиИОбороты.ВалютнаяСуммаОборотКт
	|		ИНАЧЕ ОстаткиИОбороты.СуммаОборотКт
	|	КОНЕЦ) КАК ИтогиСписано,
	|	СУММА(ВЫБОР
	|		КОГДА ОстаткиИОбороты.ЭтоВалютныйСчет
	|			ТОГДА ОстаткиИОбороты.ВалютнаяСуммаКонечныйОстаток
	|		ИНАЧЕ ОстаткиИОбороты.СуммаКонечныйОстаток
	|	КОНЕЦ) КАК ИтогиНаКонецДня
	|ИЗ
	|	(ВЫБРАТЬ
	|		ОстаткиИОборотыПоБанку.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
	|		ОстаткиИОборотыПоБанку.ВалютнаяСуммаНачальныйОстаток КАК ВалютнаяСуммаНачальныйОстаток,
	|		ОстаткиИОборотыПоБанку.СуммаОборотДт КАК СуммаОборотДт,
	|		ОстаткиИОборотыПоБанку.ВалютнаяСуммаОборотДт КАК ВалютнаяСуммаОборотДт,
	|		ОстаткиИОборотыПоБанку.СуммаОборотКт КАК СуммаОборотКт,
	|		ОстаткиИОборотыПоБанку.ВалютнаяСуммаОборотКт КАК ВалютнаяСуммаОборотКт,
	|		ОстаткиИОборотыПоБанку.СуммаКонечныйОстаток КАК СуммаКонечныйОстаток,
	|		ОстаткиИОборотыПоБанку.ВалютнаяСуммаКонечныйОстаток КАК ВалютнаяСуммаКонечныйОстаток,
	|		ВЫБОР
	|			КОГДА ОстаткиИОборотыПоБанку.ВалютнаяСуммаНачальныйОстаток <> 0
	|			ИЛИ ОстаткиИОборотыПоБанку.ВалютнаяСуммаОборотДт <> 0
	|			ИЛИ ОстаткиИОборотыПоБанку.ВалютнаяСуммаОборотКт <> 0
	|			ИЛИ ОстаткиИОборотыПоБанку.ВалютнаяСуммаКонечныйОстаток <> 0
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ КАК ЭтоВалютныйСчет
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&ДатаИтоговНачалоДня, &ДатаИтоговКонецДня,, ДвиженияИГраницыПериода,
	|			Счет В (&СчетаУчетаБезналичныхДС), &СубконтоБанковскиеСчета, Организация В (&Организации)) КАК
	|			ОстаткиИОборотыПоБанку
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		ОстаткиИОборотыПоКассе.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
	|		ОстаткиИОборотыПоКассе.ВалютнаяСуммаНачальныйОстаток КАК ВалютнаяСуммаНачальныйОстаток,
	|		ОстаткиИОборотыПоКассе.СуммаОборотДт КАК СуммаОборотДт,
	|		ОстаткиИОборотыПоКассе.ВалютнаяСуммаОборотДт КАК ВалютнаяСуммаОборотДт,
	|		ОстаткиИОборотыПоКассе.СуммаОборотКт КАК СуммаОборотКт,
	|		ОстаткиИОборотыПоКассе.ВалютнаяСуммаОборотКт КАК ВалютнаяСуммаОборотКт,
	|		ОстаткиИОборотыПоКассе.СуммаКонечныйОстаток КАК СуммаКонечныйОстаток,
	|		ОстаткиИОборотыПоКассе.ВалютнаяСуммаКонечныйОстаток КАК ВалютнаяСуммаКонечныйОстаток,
	|		ВЫБОР
	|			КОГДА ОстаткиИОборотыПоКассе.ВалютнаяСуммаНачальныйОстаток <> 0
	|			ИЛИ ОстаткиИОборотыПоКассе.ВалютнаяСуммаОборотДт <> 0
	|			ИЛИ ОстаткиИОборотыПоКассе.ВалютнаяСуммаОборотКт <> 0
	|			ИЛИ ОстаткиИОборотыПоКассе.ВалютнаяСуммаКонечныйОстаток <> 0
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ КАК ЭтоВалютныйСчет
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&ДатаИтоговНачалоДня, &ДатаИтоговКонецДня,, ДвиженияИГраницыПериода,
	|			Счет В (&СчетаУчетаНаличныхДС),, Организация В (&Организации)) КАК ОстаткиИОборотыПоКассе) КАК ОстаткиИОбороты";
	
	Если Не ВсеДеньги(ОтборВсеДеньги) Тогда
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(Запрос.Текст);
		ВложенныйЗапрос = СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Источники[0].Источник.Запрос;
		Если ТолькоБанк(ОтборВсеДеньги) Тогда
			Если ЗначениеЗаполнено(БанковскийСчет) Тогда
				ВложенныйЗапрос.Операторы[0].Источники[0].Источник.Параметры[6].Выражение = 
					Новый ВыражениеСхемыЗапроса("Организация В (&Организации) И Субконто1 = &БанковскийСчет");
				Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
			КонецЕсли;
			ВложенныйЗапрос.Операторы.Удалить(1);
		ИначеЕсли ТолькоКасса(ОтборВсеДеньги) Тогда
			ВложенныйЗапрос.Операторы.Удалить(0);
		КонецЕсли;
		Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураРезультат, Выборка);
	КонецЕсли;
	
	Возврат СтруктураРезультат;
	
КонецФункции

&НаСервере
Процедура УстановитьВосстановленныеОтборы(ТолькоОрганизацияИСчет = Ложь)
	
	ОтборыСписковКлиентСервер.УстановитьБыстрыйОтбор(ЭтотОбъект, "Организация");
	ОтборыСписковКлиентСервер.УстановитьБыстрыйОтбор(ЭтотОбъект, "БанковскийСчет");
	
	Если Не ТолькоОрганизацияИСчет Тогда
		ОтборыСписковКлиентСервер.УстановитьБыстрыйОтбор(ЭтотОбъект, "ДатаОтбора");
		УстановитьОтборВсеДеньги();
		ОбновитьБаннерИПодменюКомандУправленияКассовойСменой(ЭтотОбъект, Ложь, Истина);
	КонецЕсли;
	
	ПоказатьБаннерПредупрежденийПриЗагрузкеИУстановитьОтбор();
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьРежимИнтеграцииСБанком()
	
	// Интеграция подключена, значит основной банковский счет организации - это счет интеграции.
	БанковскийСчетОрганизации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОтборОрганизация, "ОсновнойБанковскийСчет");
	Если Не ЗначениеЗаполнено(БанковскийСчетОрганизации) Тогда
		БанковскиеСчетаИнтеграции = Справочники.НастройкиИнтеграцииСБанками.БанковскиеСчетаОрганизацииВРежимеИнтеграции(
			ОтборОрганизация);
		Если БанковскиеСчетаИнтеграции.Количество() > 0 Тогда
			БанковскийСчетОрганизации = БанковскиеСчетаИнтеграции[0];
		КонецЕсли;
	КонецЕсли;
	
	БанкИнтеграции = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчетОрганизации, "Банк");
	Если ЗначениеЗаполнено(БанкИнтеграции) Тогда
		РеквизитыБанкаИнтеграции = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(БанкИнтеграции,
			"Наименование, Код");
		НазваниеБанкаИнтеграции  = РеквизитыБанкаИнтеграции.Наименование;
		БИКБанкаИнтеграции       = РеквизитыБанкаИнтеграции.Код;
	КонецЕсли;
	
	Если Не ЕстьБанковскиеСчетаБезИнтеграции Тогда
		ВидимостьИзНастроек = ХранилищеОбщихНастроек.Загрузить(
			"ВидимостьКонтекстнаяПодсказкаИнтеграцияСБанком", БИКБанкаИнтеграции);
		ВидимостьКонтекстнаяПодсказкаИнтеграцияСБанком = ?(ВидимостьИзНастроек = Неопределено, Истина, ВидимостьИзНастроек);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		Список, "ПометкаУдаления", Ложь,,, Истина);
	
	УстановитьВидимостьЭлементовДиректБанк(ЭтотОбъект);
	
	БанкИКассаФормы.НастроитьФормуЖурналаДляРежимаИнтеграции(ЭтотОбъект, ИнтеграцияСБанкамиПодключена);
	БанкИКассаФормы.ПоказатьКонтекстнаяПодсказкаИнтеграцияСБанком(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьВидимостьПодсказокНаСервере()
	
	УправлениеПанельюПодсказки.ИзменитьВидимостьПодсказок(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ПравоПримененияСпецрежима

&НаКлиенте
Процедура ПоказатьИнформациюОПравеПримененияСпецрежима()
	
	Если Не ОтборОрганизацияИспользование
		Или Не КонтрольПраваПримененияСпецрежимаКлиент.Контролировать(ОтборОрганизация) Тогда
		Элементы.ИнформацияОПравеПримененияСпецрежима.Видимость = Ложь;
		Элементы.ДополнительнаяИнформацияОПравеПримененияСпецрежима.Видимость = Ложь;
	Иначе
		ПоказатьИнформациюОПравеПримененияСпецрежимаНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьИнформациюОПравеПримененияСпецрежимаНаСервере()
	
	ИнформацияОПравеПримененияСпецрежима = КонтрольПраваПримененияСпецрежима.ИнформацияОПравеПримененияСпецрежима(
		ОтборОрганизация,
		КонтрольПраваПримененияСпецрежима.ИмяПоказателяСпецрежимаДоходы());
		
	СледующееЗначениеНапоминания         = ИнформацияОПравеПримененияСпецрежима.СледующееЗначениеНапоминания;
	СсылкаНаПояснение                    = ИнформацияОПравеПримененияСпецрежима.СсылкаНаПояснение;
	
	Элементы.ИнформацияОПравеПримененияСпецрежима.Видимость = ИнформацияОПравеПримененияСпецрежима.Показать;
	Элементы.ИнформацияОПравеПримененияСпецрежима.ЦветФона = ИнформацияОПравеПримененияСпецрежима.ЦветФонаГруппы;
	Элементы.ТекстИнформации.Заголовок = ИнформацияОПравеПримененияСпецрежима.ТекстИнформации;
	Элементы.ТекстИнформацииРасширеннаяПодсказка.Заголовок = ИнформацияОПравеПримененияСпецрежима.ПодсказкаТекстИнформации;
	
	Элементы.Подробнее.Видимость       = ЗначениеЗаполнено(СсылкаНаПояснение);
	Элементы.Подробнее.Заголовок       = ИнформацияОПравеПримененияСпецрежима.ЗаголовокПояснения;
	
	Элементы.НапомнитьПозже.Заголовок  = ИнформацияОПравеПримененияСпецрежима.ТекстНапомнитьПозже;
	Элементы.НапомнитьПозже.Видимость  = ИнформацияОПравеПримененияСпецрежима.ОтображатьНапоминание;
	
	ДополнительнаяИнформацияСпецрежима = ИнформацияОПравеПримененияСпецрежима.ДополнительнаяИнформация;
	
	Если ДополнительнаяИнформацияСпецрежима <> Неопределено Тогда
		ИмяДополнительногоПоказателяСпецрежима      = ДополнительнаяИнформацияСпецрежима.ИмяПоказателя;
		СледующееЗначениеДополнительногоНапоминания = ДополнительнаяИнформацияСпецрежима.СледующееЗначениеНапоминания;
		СсылкаНаДополнительноеПояснение             = ДополнительнаяИнформацияСпецрежима.СсылкаНаПояснение;
		
		Элементы.ДополнительнаяИнформацияОПравеПримененияСпецрежима.Видимость = ДополнительнаяИнформацияСпецрежима.Показать;
		Элементы.ДополнительнаяИнформацияОПравеПримененияСпецрежима.ЦветФона = ДополнительнаяИнформацияСпецрежима.ЦветФонаГруппы;
		Элементы.ТекстДополнительнойИнформации.Заголовок = ДополнительнаяИнформацияСпецрежима.ТекстИнформации;
		Элементы.ТекстДополнительнойИнформацииРасширеннаяПодсказка.Заголовок = ДополнительнаяИнформацияСпецрежима.ПодсказкаТекстИнформации;
		
		Элементы.ДополнительнаяИнформацияПодробнее.Видимость = ЗначениеЗаполнено(СсылкаНаДополнительноеПояснение);
		Элементы.ДополнительнаяИнформацияПодробнее.Заголовок = ДополнительнаяИнформацияСпецрежима.ЗаголовокПояснения;
		
		Элементы.ДополнительнаяИнформацияНапомнитьПозже.Заголовок = ДополнительнаяИнформацияСпецрежима.ТекстНапомнитьПозже;
		Элементы.ДополнительнаяИнформацияНапомнитьПозже.Видимость = ДополнительнаяИнформацияСпецрежима.ОтображатьНапоминание;
	Иначе
		Элементы.ДополнительнаяИнформацияОПравеПримененияСпецрежима.Видимость = Ложь;
	КонецЕсли;
	
	ИмяНастройкиПравоПримененияПатента = КонтрольПраваПримененияСпецрежима.ИмяНастройкиПравоПримененияСпецрежимаПатент();
	ВыводитсяИнформацияОПатенте = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ИнформацияОПравеПримененияСпецрежима,
		ИмяНастройкиПравоПримененияПатента,
		Ложь);
	
КонецПроцедуры

&НаСервере
Процедура ОтложитьПоказНапоминанияНаСервере()
	
	Если ВыводитсяИнформацияОПатенте Тогда
		ИмяПоказателя = КонтрольПраваПримененияСпецрежима.ИмяНастройкиПравоПримененияСпецрежимаПатент();
	Иначе
		ИмяПоказателя = КонтрольПраваПримененияСпецрежима.ИмяПоказателяСпецрежимаДоходы();
	КонецЕсли;
	
	КонтрольПраваПримененияСпецрежима.ОтложитьПоказНапоминания(
		ОтборОрганизация,
		ИмяПоказателя,
		СледующееЗначениеНапоминания);
		
	Элементы.ИнформацияОПравеПримененияСпецрежима.Видимость = Ложь;
	
	Если ВыводитсяИнформацияОПатенте Тогда
		ПоказатьИнформациюОПравеПримененияСпецрежимаНаСервере();
	КонецЕсли;
	
КонецПроцедуры

