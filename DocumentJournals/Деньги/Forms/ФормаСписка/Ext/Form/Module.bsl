&НаКлиенте
Процедура Подключаемый_УстановитьСледующийБаннер()
	
	// Поскольку обработчик может вызываться не только интерактивно пользователем,
	// но и автоматически по таймеру, меняем баннер при условии, что форма находится в фокусе.
	Если НЕ ВводДоступен() Тогда
		ПодключитьОбработчикОжидания("Подключаемый_УстановитьСледующийБаннер",
			ПерсонализированныеПредложенияСервисовКлиент.ИнтервалПереключенияБаннеров(), Истина);
		Возврат;
	КонецЕсли;
	
	УстановитьБаннер();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УстановитьПредыдущийБаннер()
	
	УстановитьБаннер(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьБаннер(ПоказатьПредыдущий = Ложь)
	
	Если (ЕстьПредупреждения ИЛИ ЗначениеЗаполнено(ИнформацияАвтозагрузкиДиректБанк_ДатаОшибки)) Тогда
		Если Элементы.Баннер.Видимость Тогда
			ЗакрытьБаннерНажатие("");
		КонецЕсли;
	Иначе
		ДлительнаяОперация = ПолучитьБаннерНаСервере(ПоказатьПредыдущий);
		
		Если ДлительнаяОперация = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Если ДлительнаяОперация.Статус <> "Ошибка" Тогда
			
			НастройкиОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
			НастройкиОжидания.ВыводитьОкноОжидания = Ложь;
			
			Обработчик = Новый ОписаниеОповещения("ПослеПолученияБаннераВФоне", ЭтотОбъект);
			ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, НастройкиОжидания);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПолученияБаннераВФоне(ДлительнаяОперация, ДополнительныеПараметры) Экспорт
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Выполнено" Тогда
		УстановитьБаннерНаФорме(ДлительнаяОперация.АдресРезультата);
		ПодключитьОбработчикОжидания("Подключаемый_УстановитьСледующийБаннер",
			ПерсонализированныеПредложенияСервисовКлиент.ИнтервалПереключенияБаннеров(), Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьБаннерНаСервере(ПоказатьПредыдущий)
	
	НастройкиЗапуска = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	НастройкиЗапуска.НаименованиеФоновогоЗадания = НСтр("ru = 'Получение баннера в фоне'");
	НастройкиЗапуска.ЗапуститьВФоне = Истина;
	НастройкиЗапуска.ОжидатьЗавершение = 0;
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("Организация", ?(ОтборОрганизацияИспользование, ОтборОрганизация, Неопределено));
	СтруктураПараметров.Вставить("Размещение", ПерсонализированныеПредложенияСервисов.ИмяРазмещенияДеньги());
	СтруктураПараметров.Вставить("ПоказатьПредыдущий", ПоказатьПредыдущий);
	
	Возврат ДлительныеОперации.ВыполнитьВФоне(
		"ПерсонализированныеПредложенияСервисов.ПолучитьБаннер",
		СтруктураПараметров,
		НастройкиЗапуска);
	
КонецФункции

&НаСервере
Процедура УстановитьБаннерНаФорме(АдресРезультата)
	
	ПерсонализированныеПредложенияСервисов.УстановитьБаннерНаФорме(ЭтотОбъект, АдресРезультата);
	
	// Скрываем баннер ДиректБанка, если есть персонализированное предложение
	Если Элементы.Баннер.Видимость Тогда
		Элементы.ГруппаРекламаДиректБанк.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ИнтеграцияСБанком

&НаСервере
Функция НастройкиАвтозагрузкиДиректБанк()
	
	ОтборОрганизацияАвтозагрукаДиректБанк = Справочники.Организации.ПустаяСсылка();
	Если ОтборОрганизацияИспользование Тогда
		ОтборОрганизацияАвтозагрукаДиректБанк = ОтборОрганизация;
	КонецЕсли;
	ОтборБанкАвтозагрукаДиректБанк = Справочники.Банки.ПустаяСсылка();
	ОтборБанковскийСчетАвтозагрукаДиректБанк = БанковскийСчетОрганизации(ЭтотОбъект, Истина);
	Если ВсеДеньги(ОтборВсеДеньги) И Не ЗначениеЗаполнено(ОтборБанковскийСчетАвтозагрукаДиректБанк) Тогда
		БанковскиеСчетаИнтеграции = Справочники.НастройкиИнтеграцииСБанками.БанковскиеСчетаОрганизацииВРежимеИнтеграции(
			ОтборОрганизация);
		Если БанковскиеСчетаИнтеграции.Количество() > 0 Тогда
			ОтборБанковскийСчетАвтозагрукаДиректБанк = БанковскиеСчетаИнтеграции[0];
		КонецЕсли;
	КонецЕсли;
	Если ЗначениеЗаполнено(ОтборБанковскийСчетАвтозагрукаДиректБанк) Тогда
		ОтборБанкАвтозагрукаДиректБанк = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
			ОтборБанковскийСчетАвтозагрукаДиректБанк, "Банк");
	КонецЕсли;
	Возврат ЭлектронноеВзаимодействиеБПВызовСервера.НастройкиОбменаАвтоматическоеПолучениеВыписки(
		ОтборОрганизацияАвтозагрукаДиректБанк,
		ОтборБанкАвтозагрукаДиректБанк);
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_ВыполнитьОбновлениеИнформацииИБаннеровАвтозагрузки()
	
	// Сбросим видимость баннеров
	Элементы.ГруппаСостояниеАвтозагрузки.Видимость = Ложь;
	Элементы.ГруппаСостояниеАвтозагрузкиОшибка.Видимость = Ложь;
	Элементы.ГруппаНеобходимоПовторноеЧтение.Видимость = Ложь;
	// Очистим информацию по датам
	ИнформацияАвтозагрузкиДиректБанк_ДатаОшибки = Неопределено;
	ИнформацияАвтозагрузкиДиректБанк_ТекущаяДатаСинхронизации = Неопределено;
	
	Если ТолькоКасса(ОтборВсеДеньги) Тогда
		ОтключитьОбработчикОжидания("Подключаемый_ОбновитьИнформациюИБаннерыАвтозагрузки");
		Возврат;
	КонецЕсли;
	
	ПроверитьАвтоматическоеПолучениеВыпискиАктивно();
	ПодключенСервисАУСН = ИнтеграцияАУСНВызовСервераПовтИсп.СервисПодключен()
		Или ИнтеграцияАУСНВызовСервераПовтИсп.СервисЛКАУСНПодключен();
	Если АвтоматическоеПолучениеВыпискиАктивно Или ПодключенСервисАУСН Тогда
		Подключаемый_ОбновитьИнформациюИБаннерыАвтозагрузки();
		ПодключитьОбработчикОжидания("Подключаемый_ОбновитьИнформациюИБаннерыАвтозагрузки", 300);
	Иначе
		ОтключитьОбработчикОжидания("Подключаемый_ОбновитьИнформациюИБаннерыАвтозагрузки");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнформациюАвтозагрузки()
	
	НастройкиОбмена = РаботаСОповещениямиОСостоянииОбменаССервисами.НовыйНастройкиОбмена();
	НастройкиОбмена.НастройкиДиректБанк = НастройкиАвтозагрузкиДиректБанк();
	НастройкиОбмена.НастройкиАУСН = ИнтеграцияАУСНБП.НастройкиИнтеграции(ОтборОрганизацияИспользование, ОтборОрганизация);
	ДанныеСостоянияОбмена = РаботаСОповещениямиОСостоянииОбменаССервисами.ДанныеСостоянияОбмена(
		НастройкиОбмена, УникальныйИдентификатор);
	
	ИнформацияАвтозагрузкиДиректБанк_ДатаОшибки = ДанныеСостоянияОбмена.ДатаОшибкиДиректБанк;
	ИнформацияАвтозагрузки_НоваяДатаСинхронизации = Макс(
		ДанныеСостоянияОбмена.ДатаСинхронизацииДиректБанк, ДанныеСостоянияОбмена.ДатаСинхронизацииАУСН);
	
	ЗаголовкиСостоянияОбмена = РаботаСОповещениямиОСостоянииОбменаССервисами.ЗаголовкиСостоянияОбмена(
		ДанныеСостоянияОбмена);
	
	Элементы.ВариантОтбораПредупрежденийПриЗагрузке.Заголовок =
		ЗаголовкиСостоянияОбмена.ЗаголовокВариантОтбораПредупрежденийПриЗагрузке;
	Элементы.ТекстСостояниеАвтозагрузкиОшибка.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(
		ЗаголовкиСостоянияОбмена.ЗаголовокСостояниеАвтозагрузкиОшибка);
	Элементы.ТекстСостояниеАвтозагрузки.Заголовок = ЗаголовкиСостоянияОбмена.ЗаголовокСостояниеАвтозагрузки;
	
	АдресДанныхСостоянияОбмена = ПоместитьВоВременноеХранилище(ДанныеСостоянияОбмена, УникальныйИдентификатор);
	
КонецПроцедуры

