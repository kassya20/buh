		СтандартнаяОбработка = Ложь;
		РеквизитыСчета = БанкИНомерСчета(ОтборБанковскийСчет);
		ОбменСБанкамиКлиент.ОткрытьСоздатьНастройкуОбмена(
			ОтборОрганизация, РеквизитыСчета.Банк, РеквизитыСчета.НомерСчета);
		
	КонецЕсли;
	
