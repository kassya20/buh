&НаКлиентеНаСервереБезКонтекста
Функция НовыйСведенияОВладельцеБанковскогоСчетаИзКонтекста()
	
	СведенияОВладельцеБанковскогоСчетаИзКонтекста = Новый Структура;
	СведенияОВладельцеБанковскогоСчетаИзКонтекста.Вставить("Организация",               Новый Массив);
	СведенияОВладельцеБанковскогоСчетаИзКонтекста.Вставить("БанковскийСчетОрганизации", Новый Массив);
	
	Возврат СведенияОВладельцеБанковскогоСчетаИзКонтекста;
	
КонецФункции

&НаСервере
Процедура СкрытьНажатиеТекстКонтекстнаяПодсказкиИнтеграцияСБанком()
	
	БанкИКассаФормы.СкрытьНажатиеТекстКонтекстнаяПодсказкиИнтеграцияСБанком(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВсеДеньги(ЗначениеОтбора)

	Возврат ЗначениеОтбора = 0;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ТолькоБанк(ЗначениеОтбора)

	Возврат ЗначениеОтбора = 1;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ТолькоКасса(ЗначениеОтбора)

	Возврат ЗначениеОтбора = 2;

КонецФункции

&НаСервере
Процедура УстановитьОтборВсеДеньги()
	
	ОтборТипДокумента = Новый СписокЗначений;
	ОтборТипДокументаИспользование = Ложь;
	Если ТолькоБанк(ОтборВсеДеньги) Тогда
		ОтборТипДокумента.Добавить(Тип("ДокументСсылка.ПоступлениеНаРасчетныйСчет"));
		ОтборТипДокумента.Добавить(Тип("ДокументСсылка.СписаниеСРасчетногоСчета"));
		ОтборТипДокументаИспользование = Истина;
	ИначеЕсли ТолькоКасса(ОтборВсеДеньги) Тогда
		ОтборТипДокумента.Добавить(Тип("ДокументСсылка.ПриходныйКассовыйОрдер"));
		ОтборТипДокумента.Добавить(Тип("ДокументСсылка.РасходныйКассовыйОрдер"));
		ОтборТипДокументаИспользование = Истина;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		Список,
		"Тип",
		ОтборТипДокумента,
		ВидСравненияКомпоновкиДанных.ВСписке,,
		ОтборТипДокументаИспользование);
	
КонецПроцедуры

&НаСервере
Процедура ОтборВсеДеньгиПриИзмененииНаСервере()
	
	Если ОтборБанковскийСчетИспользование Тогда
		ОтборБанковскийСчетИспользование = Ложь;
		ОтборыСписковКлиентСервер.УстановитьБыстрыйОтбор(ЭтотОбъект, "БанковскийСчет");
	КонецЕсли;
	УстановитьВидимостьБанковскогоСчета();
	
	СкрытьРезультатСозданияДокументов(ЭтотОбъект);
	
	Если ВсеДеньги(ОтборВсеДеньги) Тогда
		УстановитьБанковскийСчетОрганизации();
		ОтборБанковскийСчетПриИзмененииСервер();
	КонецЕсли;
	
	ОбновитьБаннерИПодменюКомандУправленияКассовойСменой(ЭтотОбъект, Ложь, Истина);
	
	ПоказатьБаннерПредупрежденийПриЗагрузкеИУстановитьОтбор();
	
	УстановитьВидимостьЭлементовВсеДеньги();
	
	УстановитьОтборВсеДеньги();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьБанковскогоСчета()
	
	ИспользоватьНесколькоБанковскихСчетовОрганизации    = ТолькоБанк(ОтборВсеДеньги)
		И ИспользуетсяНесколькоБанковскихСчетовОрганизации(ОтборОрганизация);
	
	Элементы.ОтборБанковскийСчет.Видимость              = ИспользоватьНесколькоБанковскихСчетовОрганизации;
	Элементы.ОтборБанковскийСчетИспользование.Видимость = ИспользоватьНесколькоБанковскихСчетовОрганизации;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИспользуетсяНесколькоБанковскихСчетовОрганизации(Организация)
	
	Если ЗначениеЗаполнено(Организация) Тогда
		Возврат Справочники.БанковскиеСчета.ИспользуетсяНесколькоБанковскихСчетовОрганизации(Организация);
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Функция КлассификаторБанкаПоОтбору(БанковскийСчет)
	
	БИК = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(БанковскийСчет, "Банк.Код");
	Возврат РаботаСБанкамиБП.СсылкаПоКлассификатору(БИК);
	
КонецФункции

&НаСервере
Процедура УстановитьБанковскийСчетОрганизации()
	
	Если Не ИнтеграцияСБанкамиПодключена Тогда
		УчетДенежныхСредствБП.УстановитьБанковскийСчет(ОтборБанковскийСчет, ОтборОрганизация,
			ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета());
	КонецЕсли;
	
	Если ВсеДеньги(ОтборВсеДеньги) Тогда
		УОрганизацииТолькоОдинБанковскийСчет = Справочники.БанковскиеСчета.КоличествоБанковскихСчетовОрганизации(
			ОтборОрганизация) = 1;
		Если УОрганизацииТолькоОдинБанковскийСчет И ИнтеграцияСБанкамиПодключена Тогда
			ОтборБанковскийСчет = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОтборОрганизация, "ОсновнойБанковскийСчет");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция БанковскийСчетОрганизации(Форма, ПроверятьИспользование = Ложь)
	
	Если ВсеДеньги(Форма.ОтборВсеДеньги) Тогда
		Возврат ?(Форма.УОрганизацииТолькоОдинБанковскийСчет, Форма.ОтборБанковскийСчет, Неопределено);
	ИначеЕсли ТолькоБанк(Форма.ОтборВсеДеньги) Тогда
		Возврат ?(Не ПроверятьИспользование Или Форма.ОтборБанковскийСчетИспользование,
			Форма.ОтборБанковскийСчет, Неопределено);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьЭлементовДиректБанк(Форма)
	
	Если (Форма.ИнтеграцияСБанкамиПодключена И Не ЗначениеЗаполнено(Форма.ОтборБанковскийСчет))
		Или (ВсеДеньги(Форма.ОтборВсеДеньги) И Не Форма.УОрганизацииТолькоОдинБанковскийСчет)
		Или ТолькоКасса(Форма.ОтборВсеДеньги) Тогда
		Форма.ВидимостьЭлементовДиректБанк = "НеПоказывать";
	Иначе
		Форма.ВидимостьЭлементовДиректБанк = ЭлектронноеВзаимодействиеБПВызовСервера.ВидимостьЭлементовДиректБанк(
			Форма.ОтборОрганизация, Форма.ОтборБанковскийСчет);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЭлементовВсеДеньги()
	
	Элементы.ГруппаКомандыБанка.Видимость = Не ТолькоКасса(ОтборВсеДеньги);
	Элементы.ГруппаДоход.Видимость = ВсеДеньги(ОтборВсеДеньги);
	Элементы.ГруппаРасход.Видимость = ВсеДеньги(ОтборВсеДеньги);
	Элементы.ГруппаТолькоБанк.Видимость =ТолькоБанк(ОтборВсеДеньги); 
	Элементы.ГруппаТолькоКасса.Видимость = ТолькоКасса(ОтборВсеДеньги);
	
КонецПроцедуры

#КонецОбласти

#Область ПроверкаПредупрежденийПриЗагрузке

&НаСервере
Процедура УстановитьВариантОтбораПредупрежденийПриЗагрузкеИзПараметров(Параметры)
	
	Если Параметры.Свойство("ПоказатьПредупреждения")
		И Параметры.ПоказатьПредупреждения Тогда
		
		ВариантОтбораПредупрежденийПриЗагрузке = ВариантОтбораТребующиеПроверки();
		ОткрытаДляПроверкиЗагрузкиДокументов = Истина;
		
	Иначе
		
		ВариантОтбораПредупрежденийПриЗагрузке = ВариантОтбораВсе();
		ОткрытаДляПроверкиЗагрузкиДокументов = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВариантОтбораВсе()
	Возврат "Все";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВариантОтбораТребующиеПроверки()
	Возврат "ТребующиеПроверки";
КонецФункции

&НаСервере
Процедура ПоказатьБаннерПредупрежденийПриЗагрузкеИУстановитьОтбор()
	
	Если Не ТолькоКасса(ОтборВсеДеньги) Тогда
		ОрганизацияПредупреждений = ?(ОтборОрганизацияИспользование, ОтборОрганизация, Неопределено);
		БанковскийСчетПредупреждений = ?(ОтборБанковскийСчетИспользование, ОтборБанковскийСчет, Неопределено);
		ДатаПредупреждений = ?(ОтборДатаОтбораИспользование, ОтборДатаОтбора, Неопределено);
		
		ЕстьПредупреждения = ЕстьДокументыСПредупреждениямиПриЗагрузке(
			ОрганизацияПредупреждений, БанковскийСчетПредупреждений, ДатаПредупреждений);
	Иначе
		ЕстьПредупреждения = Ложь;
	КонецЕсли;
	
	НачальнаяВидимостьБаннера = Элементы.ГруппаПредупрежденияПриЗагрузкеИзКлиентБанка.Видимость;
	Элементы.ГруппаПредупрежденияПриЗагрузкеИзКлиентБанка.Видимость = ЕстьПредупреждения;
	ПараметрыОтбора = Новый Структура("Организация", ОрганизацияПредупреждений);
	Если Не ЕстьПредупреждения Тогда
		ВариантОтбораПредупрежденийПриЗагрузке = ВариантОтбораВсе();
	ИначеЕсли ЕстьПредупреждения И ПолучитьФункциональнуюОпцию("ПрименяетсяАУСН", ПараметрыОтбора)
		И Не НачальнаяВидимостьБаннера Тогда
		ВариантОтбораПредупрежденийПриЗагрузке = ВариантОтбораТребующиеПроверки();
	КонецЕсли;
	
	УстановитьОтборПредупрежденийПриЗагрузке(ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЕстьДокументыСПредупреждениямиПриЗагрузке(Организация, СчетОрганизации, Дата)
	
	ПараметрыОтбораПредупреждений = РегистрыСведений.ПредупрежденияПриЗагрузкеВыписки.НовыеПараметрыОтбораПредупреждений();
	ПараметрыОтбораПредупреждений.Организация = Организация;
	ПараметрыОтбораПредупреждений.СчетОрганизации = СчетОрганизации;
	ПараметрыОтбораПредупреждений.НачалоПериода = Дата;
	ПараметрыОтбораПредупреждений.КонецПериода = Дата;
	
	Возврат РегистрыСведений.ПредупрежденияПриЗагрузкеВыписки.ЕстьПредупрежденияВСписке(ПараметрыОтбораПредупреждений);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПредупрежденийПриЗагрузке(Форма)
	
	Настройки = Форма.Список.КомпоновщикНастроек.Настройки;
	
	ИмяПоля = "Ссылка";
	
	Если Форма.ВариантОтбораПредупрежденийПриЗагрузке = ВариантОтбораТребующиеПроверки() Тогда
		
		ОрганизацияПредупреждений = ?(Форма.ОтборОрганизацияИспользование, Форма.ОтборОрганизация, Неопределено);
		ДокументыСПредупреждениямиПриЗагрузке = ДокументыСПредупреждениямиПриЗагрузке(ОрганизацияПредупреждений);
		
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(
			Настройки.Отбор,
			ИмяПоля);
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
			Настройки.Отбор,
			ИмяПоля,
			ДокументыСПредупреждениямиПриЗагрузке,
			ВидСравненияКомпоновкиДанных.ВСписке,
			,
			Истина);
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбора(
			Настройки.Отбор,
			ИмяПоля);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДокументыСПредупреждениямиПриЗагрузке(Организация)
	
	ПараметрыОтбораПредупреждений = РегистрыСведений.ПредупрежденияПриЗагрузкеВыписки.НовыеПараметрыОтбораПредупреждений();
	ПараметрыОтбораПредупреждений.Организация = Организация;
	
	Возврат РегистрыСведений.ПредупрежденияПриЗагрузкеВыписки.ДокументыСПредупреждениями(ПараметрыОтбораПредупреждений);
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_АУСН()
	
	ИнтеграцияАУСНКлиент.ВыполнитьОбменССервисом(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область МобильныйКлиент

&НаСервере
Процедура МобильныйКлиентАдаптацияФормы(МожноРедактировать)
	
	Если Не ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		Возврат;
	КонецЕсли;
	
	МобильныйКлиентБПФормаСписка.НастроитьФормуОбъекта(ЭтотОбъект);
	
	Если Не ИнтеграцияСБанкамиПодключена Тогда
		ПолеМК_ВидДокумента = Элементы.Добавить("ПолеМК_ВидДокумента", Тип("ПолеФормы"), ЭтотОбъект);
		ПолеМК_ВидДокумента.ПутьКДанным = "ОтборВсеДеньги";
		ПолеМК_ВидДокумента.Вид = ВидПоляФормы.ПолеПереключателя;
		ПолеМК_ВидДокумента.ВидПереключателя = ВидПереключателя.Тумблер;
		ПолеМК_ВидДокумента.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ПолеМК_ВидДокумента.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
		ПолеМК_ВидДокумента.УстановитьДействие("ПриИзменении", "ОтборВсеДеньгиПриИзменении");
		
		ПолеМК_ВидДокумента.СписокВыбора.Очистить();
		Для каждого ЗначенияЭлементов Из Элементы.ОтборВсеДеньги.СписокВыбора Цикл
			ПолеМК_ВидДокумента.СписокВыбора.Добавить(ЗначенияЭлементов.Значение, ЗначенияЭлементов.Представление)
		КонецЦикла;

		МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКШапка(ЭтотОбъект, ПолеМК_ВидДокумента);
	КонецЕсли;
	
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКСписок(ЭтотОбъект, Элементы.Список);
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКСписок(ЭтотОбъект, Элементы.ГруппаИтоги);
	
	АдаптироватьМККоманднаяПанельФормы(МожноРедактировать);
	
	АдаптироватьМКОтборыФормы();
	
	АдаптироватьМКСписокФормы();
	
	АдаптироватьМККонтекстСписокФормы();
	
	АдаптироватьМКИтогиСпискаФормы();
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМККоманднаяПанельФормы(МожноРедактировать)
	
	КомандыПоля = МобильныйКлиентБПФормаСписка.НовыйОписаниеКомандТабличноеПоле();
	//Управляем вручную
	КомандыПоля.РазрешеноИзменение = Ложь;
	КомандыПоля.ДоступноУправлениеОтбором = Истина;
	
	МобильныйКлиентБПФормаСписка.АдаптироватьМККоманднаяПанельФормы(ЭтотОбъект, КомандыПоля);
	
	МобильныйКлиентБПФормаСписка.ПеренестиЭлементВМККомандыФормы(ЭтотОбъект, Элементы.ФормаОткрытьКлиентБанк);
	МобильныйКлиентБПФормаСписка.ПеренестиКомандыВМККомандыФормы(ЭтотОбъект, Элементы.ПодменюОтчеты.ПодчиненныеЭлементы);
	
	Если МожноРедактировать Тогда
		МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКСоздать(ЭтотОбъект, Элементы.ГруппаДоход);
		МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКСоздать(ЭтотОбъект, Элементы.ГруппаРасход);
		МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКСоздать(ЭтотОбъект, Элементы.ГруппаТолькоБанк);
		МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКСоздать(ЭтотОбъект, Элементы.ГруппаТолькоКасса);
	
		ЗаголовокГруппы = НСтр("ru = 'Создать'");
		МобильныйКлиентБПФормаСписка.АдаптироватьГруппаМКСоздать(ЭтотОбъект, Истина, ЗаголовокГруппы);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_КомандаМКПоказатьСкрытьПрочиеКолонки(Команда)
	
	МобильныйКлиентБПФормаОбъектаКлиентСервер.УправлениеФормойСпискаКолонкаПрочее(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКОтборыФормы()
	
	МобильныйКлиентБПФормаСписка.НастроитьФормуОтбораМК(ЭтотОбъект, "Список", "Организация");
	МобильныйКлиентБПФормаСписка.АдаптироватьМКЭлементОтбораОрганизация(ЭтотОбъект,
		Элементы.ОтборОрганизация,
		"",
		"Все организации");
	МобильныйКлиентБПФормаСписка.АдаптироватьМКЭлементОтбораБыстрыеОтборы(ЭтотОбъект,
		Элементы.ОтборДатаОтбора, НСтр("ru = 'Дата'"), "");
	МобильныйКлиентБПФормаСписка.АдаптироватьМКЭлементОтбораБыстрыеОтборы(ЭтотОбъект,
		Элементы.ОтборБанковскийСчет,
		НСтр("ru = 'Банковский счет'"),
		НСтр("ru = 'Все банковские счета'"));
		
	
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМКБыстрыеОтборы(ЭтотОбъект, Элементы.ГруппаДополнительныеОтборы);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_КомандаМКПоказатьСкрытьОтбор(Команда)
	
	МобильныйКлиентБПФормаОбъектаКлиентСервер.УправлениеФормойОтбораМК(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМККонтекстСписокФормы()

	МобильныйКлиентБПФормаОбъекта.АдаптироватьКонтекстноеМеню(ЭтотОбъект, "СписокКонтекстноеМенюГруппа");
	
	МобильныйКлиентБПФормаОбъекта.ПереместитьЭлементыФормы(Элементы,
		Элементы.ГруппаГлобальныеКоманды.ПодчиненныеЭлементы,
		Элементы.Список.КонтекстноеМеню);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКСписокФормы()
	
	МобильныйКлиентБПФормаСписка.ПодготовитьСписокФормы(ЭтотОбъект);
	
	//В реквизитах установить "Использовать всегда" для источника КолонкаСостояниеДокумента
	МобильныйКлиентБПФормаСписка.ДобавитьКолонкаСостояниеДокумента(ЭтотОбъект, "СтандартнаяКартинка", "Список");
	
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_СостояниеДокумента(ЭтотОбъект, Элементы.СчетВРежимеИнтеграции);
	
	Элементы.Дата.РастягиватьПоГоризонтали = Истина;
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_ДатаНомер(ЭтотОбъект, Элементы.Дата);
	
	Элементы.Доход.ЦветТекста = ЦветаСтиля.ЦветТекстаПоложительногоЗначения;
	Элементы.Расход.ЦветТекста = ЦветаСтиля.ЦветТекстаОтрицательногоЗначения;
	
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_СуммаДокумента(ЭтотОбъект, Элементы.Доход);
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_СуммаДокумента(ЭтотОбъект, Элементы.Расход);
	
	Элементы.Контрагент.РастягиватьПоГоризонтали = Истина;
	Элементы.Контрагент.АвтоВысотаЯчейки = Истина;
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_Важное(ЭтотОбъект, Элементы.Контрагент);
	
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_Строка(ЭтотОбъект, Элементы.ВидОперации, 1);
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_Строка(ЭтотОбъект, Элементы.Тип, 2);
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_Строка(ЭтотОбъект, Элементы.БанковскийСчет, 3);
	
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементВГруппуМК_Прочее(ЭтотОбъект, Элементы.Организация);
	МобильныйКлиентБПФормаСписка.ВстроитьЭлементыВГруппуМК_Прочее(ЭтотОбъект, "Список");
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Доход");
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Список.Доход", ВидСравненияКомпоновкиДанных.Равно, 0);
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
		КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "Расход");
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
			"Список.Расход", ВидСравненияКомпоновкиДанных.Равно, 0);
		ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКИтогиСпискаФормы()
	
	МобильныйКлиентБПФормаСписка.СкрытьЭлементФормыСписка(ЭтотОбъект, Элементы.ИтогДата);
	
	Элементы.ГруппаИтоги.Поведение = ПоведениеОбычнойГруппы.Свертываемая;
	Элементы.ГруппаИтоги.ЦветФона = ЦветаСтиля.ЦветФонаФормы;
	Элементы.ГруппаИтоги.ОтображатьЗаголовок = Истина;
	Элементы.ГруппаИтоги.Скрыть();
	
	Элементы.ГруппаОстаткиОбороты.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	Элементы.ГруппаОстаткиОбороты.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Авто;
	Элементы.ГруппаОстаткиОбороты.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Авто;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьЗаголовкиГруппыИтогиМК(ЭлементГруппы, ДатаИтогов, ИтогиНаКонецДня)
	
	ПредставлениеДатаИтогов = Формат(ДатаИтогов, "ДФ=dd.MM.yyyy");
	ЭлементГруппы.Заголовок = СтрШаблон(НСтр("ru = 'Остаток (%1)'"), ПредставлениеДатаИтогов);
	ЭлементГруппы.ЗаголовокСвернутогоОтображения = СтрШаблон(НСтр("ru = 'Остаток (%1): %2'"),
		ПредставлениеДатаИтогов,
		Формат(ИтогиНаКонецДня, "ЧДЦ=2; ЧН=0,00"));
	
КонецПроцедуры

#КонецОбласти