#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("ДанныеСостоянияРассылкиСообщенийВФоне", Истина);
	
КонецПроцедуры

// Создает новый элемент рассылки и записывает очередь сообщений по этой рассылке
//
// Параметры:
//  ПараметрыРассылки - Структура - см. Справочники.РассылкиСообщений.НовыйДанныеЗаполнения()
//  СпециальныеПараметрыРассылки - Структура - любые данные, специфичные для конкретного вида рассылки
//
// Возвращаемое значение:
//  СправочникСсылка.РассылкиСообщений - Ссылка на рассылку 
//
Функция ЗарегистрироватьОчередьРассылкиСообщений(ПараметрыРассылки, СпециальныеПараметрыРассылки = Неопределено) Экспорт
	
	ДанныеЗаполнения = Справочники.РассылкиСообщений.НовыйДанныеЗаполнения();
	
	ДанныеЗаполнения.Наименование =  СтрШаблон(НСтр("ru = 'Рассылка сообщений от %1'"), ТекущаяДатаСеанса());
	ДанныеЗаполнения.ВидРассылки =   ПараметрыРассылки.ВидРассылки;
	ДанныеЗаполнения.УчетнаяЗапись = ПараметрыРассылки.УчетнаяЗапись;
	
	Если ТипЗнч(СпециальныеПараметрыРассылки) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, СпециальныеПараметрыРассылки);
	КонецЕсли;

	РассылкаСообщенийПереопределяемый.ПередДобавлениемРассылки(
		ДанныеЗаполнения, ПараметрыРассылки, СпециальныеПараметрыРассылки);

	Рассылка = Справочники.РассылкиСообщений.НоваяРассылка(ДанныеЗаполнения);
	
	Если Не ЗначениеЗаполнено(Рассылка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыРассылки.РассылкаСообщений = Рассылка;
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.РассылкаСообщений.Установить(Рассылка);
	
	РассылкаСообщенийПереопределяемый.РегистрацияОчередиРассылки(
		НаборЗаписей, ПараметрыРассылки, СпециальныеПараметрыРассылки);
	
	МоментИзменения = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Если НаборЗаписей.Количество() > 0 Тогда
		Для Каждого Запись Из НаборЗаписей Цикл
			Если ЗначениеЗаполнено(Запись.МоментИзменения) Тогда
				Продолжить;
			КонецЕсли;
			Запись.МоментИзменения = МоментИзменения;
		КонецЦикла;
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
	КонецЕсли;
	
	Возврат Рассылка;
	
КонецФункции

// Записывает состояние "Отправлено" по конкретному получателю
//
// Параметры:
//  СтрокаРассылки - СтрокаТаблицыЗначений  - колонки соответствуют свойствам регистра сведений РассылкаСообщений
//  ПараметрыОтправки - Структура - см. РассылкаСообщений.НовыйПараметрыОтправкиСообщений()
//
Процедура ЗарегистрироватьУспешнуюОтправку(СтрокаРассылки, ПараметрыОтправки) Экспорт
	
	Состояние = Перечисления.СтатусыРассылки.Отправлено;
	ЗаписатьСостояниеОтправки(СтрокаРассылки, Состояние, ПараметрыОтправки);
	
КонецПроцедуры

// Записывает состояние "Не удалось отправить" по конкретному получателю
//
// Параметры:
//  СтрокаРассылки - СтрокаТаблицыЗначений  - колонки соответствуют свойствам регистра сведений РассылкаСообщений
//  ТекстОшибки - Строка - текст ошибки для записи
//  ПараметрыОтправки - Структура - см. РассылкаСообщений.НовыйПараметрыОтправкиСообщений()
//
Процедура ЗарегистрироватьОшибкуПриОтправке(СтрокаРассылки, ТекстОшибки, ПараметрыОтправки) Экспорт
	
	Состояние = Перечисления.СтатусыРассылки.Ошибка;
	ЗаписатьСостояниеОтправки(СтрокаРассылки, Состояние, ПараметрыОтправки, ТекстОшибки);
	
КонецПроцедуры

// Записывает ошибку отправки и ставит сообщение в конец очереди на отправку.
//
// Параметры:
//  СтрокаРассылки - СтрокаТаблицыЗначений  - колонки соответствуют свойствам регистра сведений РассылкаСообщений
//  ТекстОшибки - Строка - текст ошибки для записи
//  ПараметрыОтправки - Структура - см. РассылкаСообщений.НовыйПараметрыОтправкиСообщений()
//
Процедура ЗарегистрироватьОшибкуПриОтправкеИПоставитьВКонецОчереди(СтрокаРассылки, ТекстОшибки, ПараметрыОтправки) Экспорт
	
	Состояние = Перечисления.СтатусыРассылки.Ожидание;
	ЗаписатьСостояниеОтправки(СтрокаРассылки, Состояние, ПараметрыОтправки, ТекстОшибки);
	
КонецПроцедуры

// Возвращает список рассылок, по которым есть неотправленные сообщения
//
// Параметры:
//  СпособыОтправки - Массив из ПеречислениеСсылка.СпособыОтправкиСообщений- массив способов отправки
//  ПараметрыОтправки - Структура - см. РассылкаСообщений.НовыйПараметрыОтправкиСообщений()
//
// Возвращаемое значение:
//  Массив из СправочникСсылка.РассылкиСообщений - список незавершенных рассылок
//
Функция НезавершенныеРассылкиДляОтправки(СпособыОтправки, ПараметрыОтправки) Экспорт
	
	НезавершенныеРассылки = Справочники.РассылкиСообщений.НезавершенныеРассылки();
	
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("ПредельноеКоличествоПопытокОтправкиПисьма",
		ПараметрыОтправки.КоличествоПопытокОтправкиПисьма);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("НезавершенныеРассылки", НезавершенныеРассылки);
	Запрос.УстановитьПараметр("СпособыОтправки", СпособыОтправки);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Рассылка.Ссылка КАК Ссылка,
	|	Рассылка.ДатаРассылки КАК ДатаРассылки
	|ИЗ
	|	Справочник.РассылкиСообщений КАК Рассылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РассылкаСообщений КАК СостоянияРассылкиСообщений
	|		ПО Рассылка.Ссылка = СостоянияРассылкиСообщений.РассылкаСообщений
	|		И СостоянияРассылкиСообщений.Состояние = ЗНАЧЕНИЕ(Перечисление.СтатусыРассылки.Ожидание)
	|		И СостоянияРассылкиСообщений.ВыполненоПопытокОтправки <= &ПредельноеКоличествоПопытокОтправкиПисьма
	|		И СостоянияРассылкиСообщений.СпособОтправки В (&СпособыОтправки)
	|ГДЕ
	|	Рассылка.Ссылка В (&НезавершенныеРассылки)
	|	И Рассылка.СледующаяПопытка <= &ТекущаяДата
	|
	|УПОРЯДОЧИТЬ ПО
	|	Рассылка.ДатаРассылки";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Определяет, есть ли сообщения к отправке
//
// Возвращаемое значение:
//  Булево - Истина, если есть сообщения к отправке
//
Функция ОтсутствуютДанныеДляОтправки() Экспорт
	
	НезавершенныеРассылки = Справочники.РассылкиСообщений.НезавершенныеРассылки();
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СостоянияРассылкиСообщений.РассылкаСообщений КАК РассылкаСообщений
	|ИЗ
	|	РегистрСведений.РассылкаСообщений КАК СостоянияРассылкиСообщений
	|ГДЕ
	|	СостоянияРассылкиСообщений.РассылкаСообщений В (&НезавершенныеРассылки)
	|	И СостоянияРассылкиСообщений.Состояние = ЗНАЧЕНИЕ(Перечисление.СтатусыРассылки.Ожидание)";
	
	Запрос.УстановитьПараметр("НезавершенныеРассылки", НезавершенныеРассылки);
	РезультатЗапроса = Запрос.Выполнить();
	
	УстановитьПривилегированныйРежим(Ложь);

	Возврат РезультатЗапроса.Пустой();
	
КонецФункции

// Записывает состояние "Отменено" по всем сообщениям переданных рассылок
//
// Параметры:
//  НезавершенныеРассылки - Массив из СправочникСсылка.РассылкиСообщений - массив рассылок
//
Процедура ЗарегистрироватьОтменуОтправки(НезавершенныеРассылки) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СостоянияРассылкиСообщений.РассылкаСообщений КАК РассылкаСообщений,
	|	СостоянияРассылкиСообщений.Получатель КАК Получатель,
	|	СостоянияРассылкиСообщений.Организация КАК Организация,
	|	СостоянияРассылкиСообщений.ОтчетныйПериодСообщения КАК ОтчетныйПериодСообщения,
	|	СостоянияРассылкиСообщений.СпособОтправки КАК СпособОтправки
	|ИЗ
	|	РегистрСведений.РассылкаСообщений КАК СостоянияРассылкиСообщений
	|ГДЕ
	|	СостоянияРассылкиСообщений.РассылкаСообщений В (&НезавершенныеРассылки)
	|	И СостоянияРассылкиСообщений.Состояние = ЗНАЧЕНИЕ(Перечисление.СтатусыРассылки.Ожидание)";
	
	Запрос.УстановитьПараметр("НезавершенныеРассылки", НезавершенныеРассылки);
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Состояние = Перечисления.СтатусыРассылки.Отменено;
	Пока Выборка.Следующий() Цикл
		ЗаписатьСостояниеОтправки(Выборка, Состояние, Новый Структура);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

