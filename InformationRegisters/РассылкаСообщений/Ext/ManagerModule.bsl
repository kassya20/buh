#Область СлужебныеПроцедурыИФункции

Функция ИзмененияОчереди(НезавершенныеРассылки, ГраницаАктуальности)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СостояниеРассылки.РассылкаСообщений КАК РассылкаСообщений,
	|	СостояниеРассылки.Получатель КАК Получатель,
	|	СостояниеРассылки.Организация КАК Организация,
	|	СостояниеРассылки.ОтчетныйПериодСообщения КАК ОтчетныйПериодСообщения,
	|	СостояниеРассылки.СпособОтправки КАК СпособОтправки,
	|	СостояниеРассылки.Состояние КАК Состояние,
	|	СостояниеРассылки.ТекстОшибки КАК ТекстОшибки,
	|	СостояниеРассылки.ДатаОтправки КАК ДатаОтправки,
	|	СостояниеРассылки.ВыполненоПопытокОтправки КАК ВыполненоПопытокОтправки,
	|	СостояниеРассылки.МоментИзменения КАК МоментИзменения
	|ПОМЕСТИТЬ ИзмененияРассылки
	|ИЗ
	|	РегистрСведений.РассылкаСообщений КАК СостояниеРассылки
	|ГДЕ
	|	СостояниеРассылки.РассылкаСообщений В (&НезавершенныеРассылки)
	|	И СостояниеРассылки.МоментИзменения > &ГраницаАктуальности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИзмененияРассылки.РассылкаСообщений КАК РассылкаСообщений,
	|	ИзмененияРассылки.Получатель КАК Получатель,
	|	ИзмененияРассылки.Организация КАК Организация,
	|	ИзмененияРассылки.ОтчетныйПериодСообщения КАК ОтчетныйПериодСообщения,
	|	ИзмененияРассылки.СпособОтправки КАК СпособОтправки,
	|	ИзмененияРассылки.Состояние КАК Состояние,
	|	ИзмененияРассылки.ТекстОшибки КАК ТекстОшибки,
	|	ИзмененияРассылки.ДатаОтправки КАК ДатаОтправки,
	|	ИзмененияРассылки.ВыполненоПопытокОтправки КАК ВыполненоПопытокОтправки
	|ИЗ
	|	ИзмененияРассылки КАК ИзмененияРассылки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ИзмененияРассылки.МоментИзменения) КАК ГраницаАктуальности
	|ИЗ
	|	ИзмененияРассылки КАК ИзмененияРассылки";
	
	Запрос.УстановитьПараметр("НезавершенныеРассылки", НезавершенныеРассылки);
	Запрос.УстановитьПараметр("ГраницаАктуальности", ГраницаАктуальности);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТаблицаРезультат = РезультатЗапроса[1].Выгрузить();
	
	ВыборкаГраницаАктуальности = РезультатЗапроса[2].Выбрать();
	
	Если ВыборкаГраницаАктуальности.Следующий()
		 И ЗначениеЗаполнено(ВыборкаГраницаАктуальности.ГраницаАктуальности) Тогда
		ГраницаАктуальности = ВыборкаГраницаАктуальности.ГраницаАктуальности;
	КонецЕсли;
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаРезультат);
	
КонецФункции

Процедура ЗаписатьСостояниеОтправки(СтрокаРассылки, Состояние, ПараметрыОтправки, ТекстОшибки = Неопределено)
	
	Попытка
		
		Запись = СоздатьМенеджерЗаписи();
		
		ЗаполнитьЗначенияСвойств(Запись, СтрокаРассылки, 
			"РассылкаСообщений, Получатель, Организация, ОтчетныйПериодСообщения, СпособОтправки"); // все измерения
		
		Запись.Прочитать();
		Запись.Состояние = Состояние;
		
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Запись.ТекстОшибки = ТекстОшибки;
		Иначе
			Запись.ТекстОшибки = "";
		КонецЕсли;
		
		Если Состояние = Перечисления.СтатусыРассылки.Отправлено Тогда
			Запись.ИдентификаторСообщения = СтрокаРассылки.ИдентификаторСообщения;
			Запись.ИдентификаторСообщенияIMAP = СтрокаРассылки.ИдентификаторСообщенияIMAP;
			Запись.ДатаОтправки = ТекущаяУниверсальнаяДата();
		КонецЕсли;
		
		Если Состояние = Перечисления.СтатусыРассылки.Ожидание Тогда
			Запись.ДатаПостановкиВОчередь = ТекущаяУниверсальнаяДата();
			Запись.ВыполненоПопытокОтправки = Запись.ВыполненоПопытокОтправки + 1;
		КонецЕсли;
		
		Если Состояние = Перечисления.СтатусыРассылки.Ожидание
			И Запись.ВыполненоПопытокОтправки > ПараметрыОтправки.КоличествоПопытокОтправкиПисьма Тогда
			Запись.Состояние = Перечисления.СтатусыРассылки.Ошибка;
			Запись.ТекстОшибки = СтрШаблон(НСтр("ru = 'Превышено количество попыток отправки: %1'"),
				ПараметрыОтправки.КоличествоПопытокОтправкиПисьма);
		КонецЕсли;
		
		Если Состояние = Перечисления.СтатусыРассылки.Отправлено 
			 Или Состояние = Перечисления.СтатусыРассылки.Ошибка
			 Или Состояние = Перечисления.СтатусыРассылки.Отменено Тогда
			// Очистим данные для подготовки письма - они более не понадобятся
			Запись.Вложения  = Неопределено;
		КонецЕсли;
		
		Запись.МоментИзменения = ТекущаяУниверсальнаяДатаВМиллисекундах();
		Запись.Записать();
		
	Исключение
		
		ЗаписьЖурналаРегистрации(
			РассылкаСообщений.ИмяСобытияЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
КонецПроцедуры

#Область БаннерСостояниеРассылкиСообщений

Функция ОписаниеРассылкиСообщений(НезавершенныеРассылки)
	
	ОписаниеРассылкиСообщений = НовыйОписаниеРассылкиСообщений();
	
	Если НезавершенныеРассылки = Неопределено Тогда
		// Не указан массив отобранных незавершенных рассылок, поэтому выберем все виды незавершенных рассылок.
		// В данном случае считаем, что вызов функции выполнен из формы состояния рассылки сообщений,
		// поэтому требуется подробное описание состояния рассылки и баннер не закрывается.
		НезавершенныеРассылки = Справочники.РассылкиСообщений.НезавершенныеРассылки();
		Если Не ЗначениеЗаполнено(НезавершенныеРассылки) Тогда
			Возврат Неопределено;
		КонецЕсли;
		ОписаниеРассылкиСообщений.ФормаСостоянияРассылкиСообщений = Истина;
		ОписаниеРассылкиСообщений.МожноЗакрытьБаннер = Ложь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НезавершенныеРассылки) Тогда
		Возврат ОписаниеРассылкиСообщений;
	КонецЕсли;
	
	// Часть данных берем из первой незавершенной рассылки (будет наиболее ранняя по времени), т.к. обработка
	// рассылок также выполняется в хронологическом порядке.
	ДанныеРассылки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		НезавершенныеРассылки[0], "ДатаРассылки, СледующаяПопытка");
	ОписаниеРассылкиСообщений.ДатаРассылки = ДанныеРассылки.ДатаРассылки;
	ОписаниеРассылкиСообщений.СледующаяПопытка = ДанныеРассылки.СледующаяПопытка;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КОЛИЧЕСТВО(СостоянияРассылкиСообщений.Состояние) КАК Количество,
	|	СостоянияРассылкиСообщений.Состояние КАК Состояние
	|ИЗ
	|	РегистрСведений.РассылкаСообщений КАК СостоянияРассылкиСообщений
	|ГДЕ
	|	СостоянияРассылкиСообщений.РассылкаСообщений В(&НезавершенныеРассылки)
	|	И СостоянияРассылкиСообщений.Состояние <> ЗНАЧЕНИЕ(Перечисление.СтатусыРассылки.Отменено)
	|
	|СГРУППИРОВАТЬ ПО
	|	СостоянияРассылкиСообщений.Состояние";
	
	Запрос.УстановитьПараметр("НезавершенныеРассылки", НезавершенныеРассылки);
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Состояние = Перечисления.СтатусыРассылки.Отправлено Тогда
			ОписаниеРассылкиСообщений.Отправлено = Выборка.Количество;
		ИначеЕсли Выборка.Состояние = Перечисления.СтатусыРассылки.Ожидание Тогда
			ОписаниеРассылкиСообщений.ВОчередиНаОтправку = Выборка.Количество;
		ИначеЕсли Выборка.Состояние = Перечисления.СтатусыРассылки.Ошибка Тогда
			ОписаниеРассылкиСообщений.НеУдалосьОтправить = Выборка.Количество;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ОписаниеРассылкиСообщений;
	
КонецФункции

Функция НовыйОписаниеРассылкиСообщений()
	
	ОписаниеРассылкиСообщений = Новый Структура();
	
	ОписаниеРассылкиСообщений.Вставить("ДатаРассылки",        '00010101');
	ОписаниеРассылкиСообщений.Вставить("Отправлено",          0);
	ОписаниеРассылкиСообщений.Вставить("ВОчередиНаОтправку",  0);
	ОписаниеРассылкиСообщений.Вставить("НеУдалосьОтправить",  0);
	ОписаниеРассылкиСообщений.Вставить("СледующаяПопытка",    '00010101');
	ОписаниеРассылкиСообщений.Вставить("МожноЗакрытьБаннер",  Истина);
	ОписаниеРассылкиСообщений.Вставить("ФормаСостоянияРассылкиСообщений", Ложь);
	ОписаниеРассылкиСообщений.Вставить("ГраницаАктуальности", 0);
	
	Возврат ОписаниеРассылкиСообщений;
	
КонецФункции

Функция ДанныеБаннераРассылкиСообщений(Описание)
	
	ДанныеБаннера = НовыйДанныеБаннера();
	
	ДанныеБаннера.ТекстБаннера = ТекстБаннераРассылкиСообщений(Описание);
	ДанныеБаннера.ИмяКартинкиБаннера = КартинкаБаннераРассылкиСообщений(Описание);
	ДанныеБаннера.ИнтервалПроверкиСостоянияРассылкиСообщений = ИнтервалОбновленияБаннераРассылкиСообщений(Описание);
	ДанныеБаннера.ЦветБаннера = ЦветБаннераРассылкиСообщений(Описание);
	Если Не Описание.ФормаСостоянияРассылкиСообщений Тогда
		ДанныеБаннера.КартинкаЗакрытьБаннер = ВыводитьКартинкуЗакрытьБаннерРассылкиСообщений(Описание);
	КонецЕсли;
	
	ДанныеБаннера.РассылкаЗавершена = (Описание.ВОчередиНаОтправку = 0);
	
	Возврат ДанныеБаннера;
	
КонецФункции

Функция ТекстБаннераРассылкиСообщений(Описание)
	
	Отступ = "    ";

	ЭлементыСообщения = Новый Массив;
	Если Описание.Отправлено > 0 Тогда
		ЭлементыСообщения.Добавить(СтрШаблон(НСтр("ru = 'Отправлено: %1'"), Описание.Отправлено));
	КонецЕсли;
	Если Описание.ВОчередиНаОтправку > 0 Тогда
		ЭлементыСообщения.Добавить(СтрШаблон(НСтр("ru = 'В очереди на отправку: %1'"), Описание.ВОчередиНаОтправку));
	КонецЕсли;
	Если Описание.НеУдалосьОтправить > 0 Тогда
		ЭлементыСообщения.Добавить(СтрШаблон(НСтр("ru = 'Не удалось отправить: %1'"), Описание.НеУдалосьОтправить));
	КонецЕсли;
	
	ТекстСообщения = СтрСоединить(ЭлементыСообщения, Отступ);
	
	ЧастиТекста = Новый Массив;
	Если Описание.ФормаСостоянияРассылкиСообщений И Описание.СледующаяПопытка > ТекущаяДатаСеанса() И Описание.ВОчередиНаОтправку > 0 Тогда
		ЧастиТекста.Добавить(СтрШаблон(НСтр("ru = 'Возможно, на вашем почтовом сервере достигнут лимит отправки сообщений. Рассылка продолжится %1.'"), Формат(Описание.СледующаяПопытка, "ДЛФ=D")));
		ЧастиТекста.Добавить(Символы.ПС);
	ИначеЕсли Описание.ВОчередиНаОтправку = 0 Тогда
		ЧастиТекста.Добавить(СтрШаблон(НСтр("ru = 'Рассылка сообщений от %1 завершена.'"), Формат(Описание.ДатаРассылки, "ДЛФ=D")));
		ЧастиТекста.Добавить(Отступ);
	Иначе
		ЧастиТекста.Добавить(СтрШаблон(НСтр("ru = 'Рассылка сообщений от %1.'"), Формат(Описание.ДатаРассылки, "ДЛФ=D")));
		ЧастиТекста.Добавить(Отступ);
	КонецЕсли;
	
	Если Не Описание.ФормаСостоянияРассылкиСообщений Тогда
		// Подробное описание будет при переходе по ссылке на форму состояния рассылки
		ЧастиТекста.Добавить(Новый ФорматированнаяСтрока(ТекстСообщения, , , , "ОткрытьФормуСостоянияРассылкиСообщений"));
	Иначе
		ЧастиТекста.Добавить(ТекстСообщения);
	КонецЕсли;
	
	// Если рассылка не завершена, то добавляем дату возобновления рассылки
	Если Не Описание.ФормаСостоянияРассылкиСообщений И Описание.СледующаяПопытка > ТекущаяДатаСеанса() И Описание.ВОчередиНаОтправку > 0 Тогда
		ЧастиТекста.Добавить(Отступ);
		ЧастиТекста.Добавить(СтрШаблон(НСтр("ru = 'Прервана. Возобновление: %1'"), Формат(Описание.СледующаяПопытка, "ДФ='dd.MM.yy HH:mm'; ДЛФ=;")));
	КонецЕсли;

	Возврат Новый ФорматированнаяСтрока(ЧастиТекста);

КонецФункции

Функция КартинкаБаннераРассылкиСообщений(Описание)
	
	КартинкаБаннера = "";
	
	Если Описание.СледующаяПопытка > ТекущаяДатаСеанса() И Описание.ВОчередиНаОтправку > 0 Тогда
		КартинкаБаннера = "Внимание16";
	ИначеЕсли Описание.ВОчередиНаОтправку > 0 Тогда
		КартинкаБаннера = "СинхронизацияДанныхДлительнаяОперация";
	Иначе
		КартинкаБаннера = "СинхронизацияДанныхДанныеПолучены";
	КонецЕсли;
	
	Возврат КартинкаБаннера;
	
КонецФункции

Функция ЦветБаннераРассылкиСообщений(Описание)
	
	Если Описание.ВОчередиНаОтправку > 0 Тогда
		ЦветБаннера = ЦветаСтиля.ЦветБаннераБежевый;
	Иначе
		ЦветБаннера = ЦветаСтиля.ЦветБаннераЗеленый;
	КонецЕсли;
	
	Возврат ЦветБаннера;
	
КонецФункции

Функция ВыводитьКартинкуЗакрытьБаннерРассылкиСообщений(Описание)
	
	Возврат Описание.ВОчередиНаОтправку = 0;
	
КонецФункции

Функция ИнтервалОбновленияБаннераРассылкиСообщений(Описание)
	
	Если Описание.СледующаяПопытка > ТекущаяДатаСеанса() И Описание.ВОчередиНаОтправку > 0 Тогда
		// Если отправка продолжится завтра, то баннер обновляем редко, раз в час
		ИнтервалПроверкиСостоянияРассылкиСообщений = 3600;
	ИначеЕсли Описание.ВОчередиНаОтправку > 0 Тогда
		ИнтервалПроверкиСостоянияРассылкиСообщений = 5;
	Иначе
		// Баннер о том, что рассылка завершена, обновлять не нужно
		ИнтервалПроверкиСостоянияРассылкиСообщений = 0;
	КонецЕсли;
	
	Возврат ИнтервалПроверкиСостоянияРассылкиСообщений;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли