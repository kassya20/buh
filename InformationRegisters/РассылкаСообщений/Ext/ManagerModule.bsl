// Возвращаемое значение:
//  Число - Количество попыток
Функция КоличествоПопытокОтправкиПисьма() Экспорт
	
	Возврат 5;
	
КонецФункции

// Возвращает состояние рассылки сообщений: данные баннера (текст баннера, цвет баннера, картинка и т.д.)
// и измененные записи расслыки с момента прошлого обращения (если запрошены).
//
// Параметры:
//  ПараметрыЗадания - Структура - Параметры выполнения, могут быть переданы НезавершенныеРассылки.
//                                 Если указано свойство ВыбиратьИзменения = Истина, то в результат
//                                 будут добавлены записи очереди, измененные с ГраницаАктуальности.
//  АдресХранилища	 - Строка - Адрес хранилища, в который будет возвращен результат.
//
Процедура ДанныеСостоянияРассылкиСообщенийВФоне(ПараметрыЗадания, АдресХранилища) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Баннер");
	Результат.Вставить("Изменения");
	
	НезавершенныеРассылки = Неопределено;
	ВыбиратьИзменения = Ложь;
	ГраницаАктуальности = 0;
	
	ПараметрыЗадания.Свойство("НезавершенныеРассылки", НезавершенныеРассылки);
	ПараметрыЗадания.Свойство("ВыбиратьИзменения", ВыбиратьИзменения);
	ПараметрыЗадания.Свойство("ГраницаАктуальности", ГраницаАктуальности);
	
	ОписаниеРассылкиСообщений = ОписаниеРассылкиСообщений(НезавершенныеРассылки);
	Если ОписаниеРассылкиСообщений = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Результат.Баннер = ДанныеБаннераРассылкиСообщений(ОписаниеРассылкиСообщений);
	
	Если ЗначениеЗаполнено(НезавершенныеРассылки) И ВыбиратьИзменения Тогда
		// Граница актуальности также может быть изменена на основе метки времени изменных записей
		Результат.Вставить("Изменения", ИзмененияОчереди(НезавершенныеРассылки, ГраницаАктуальности));
		Результат.Вставить("ГраницаАктуальности", ГраницаАктуальности);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);
	
КонецПроцедуры

// Конструктор данных баннера рассылки сообщений
//
// Возвращаемое значение:
//  Структура - данные баннера рассылки сообщений. Свойства:
//  *ТекстБаннера - Строка - текст баннера
//  *ИмяКартинкиБаннера - Строка - имя картинки баннера
//  *ИнтервалПроверкиСостоянияРассылкиСообщений - Число - интервал проверки состояния рассылки сообщений
//  *ЦветБаннера - Цвет - цвет баннера
//  *КартинкаЗакрытьБаннер - Булево - признак того, что нужно показать картинку закрыть баннер
//  *РассылкаЗавершена - Булево - признак того, что рассылка завершена	
//
Функция НовыйДанныеБаннера() Экспорт
	
	ДанныеБаннера = Новый Структура();
	ДанныеБаннера.Вставить("ТекстБаннера", "");
	ДанныеБаннера.Вставить("ИмяКартинкиБаннера", "СинхронизацияДанныхДлительнаяОперация");
	ДанныеБаннера.Вставить("ИнтервалПроверкиСостоянияРассылкиСообщений", 0);
	ДанныеБаннера.Вставить("ЦветБаннера", ЦветаСтиля.ЦветБаннераБежевый);
	ДанныеБаннера.Вставить("КартинкаЗакрытьБаннер", Истина);
	ДанныеБаннера.Вставить("РассылкаЗавершена", Ложь);
	
	Возврат ДанныеБаннера;
	
КонецФункции

