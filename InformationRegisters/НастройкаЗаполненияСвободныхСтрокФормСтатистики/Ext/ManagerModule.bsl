#Область ПрограммныйИнтерфейс

// Заполняет настройки заполнения данными из регистра НастройкиРаспределенияВыручки.
//
// Параметры:
//  НаборЗаписейРаспределенияВыручки - РегистрСведенийНаборЗаписей.НастройкиРаспределенияВыручки или Неопределено.
//  Организация - СправочникСсылка.Организации - организация, для которой нужно записать настройку.
//  ОбъектНаблюдения - СправочникСсылка.ОбъектыСтатистическогоНаблюдения - объект наблюдения, для которого нужно записать настройку.
//  АдресДоступныеКодыПоКлассификатору - Строка - адрес во временном хранилище, содержит данные доступных кодов.
//  НаборЗаписей - РегистрСведенийНаборЗаписей.НастройкаЗаполненияСвободныхСтрокФормСтатистики.
//
Процедура ЗаполнитьНастройкиПоОбъектамНаблюдения(НаборЗаписейРаспределенияВыручки, Организация, ОбъектНаблюдения = Неопределено,
	АдресДоступныеКодыПоКлассификатору = Неопределено, СообщенияОбОшибках = Неопределено, НаборЗаписей = Неопределено) Экспорт
	
	Если ОбъектНаблюдения = Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОбъектыСтатистическогоНаблюдения.Ссылка КАК ОбъектНаблюдения
		|ИЗ
		|	Справочник.ОбъектыСтатистическогоНаблюдения КАК ОбъектыСтатистическогоНаблюдения
		|ГДЕ
		|	ОбъектыСтатистическогоНаблюдения.Детализация = ЗНАЧЕНИЕ(Перечисление.ВидыСвободныхСтрокФормСтатистики.ВидыДеятельности)
		|	И НЕ ОбъектыСтатистическогоНаблюдения.ПометкаУдаления";
		
		Выборка = Запрос.Выполнить().Выбрать();
		ОбъектНаблюдения = Неопределено;
		Пока Выборка.Следующий() Цикл
			ОбъектНаблюдения = Выборка.ОбъектНаблюдения;
			ЗаполнитьНаборЗаписей(НаборЗаписейРаспределенияВыручки, Организация, ОбъектНаблюдения, АдресДоступныеКодыПоКлассификатору, СообщенияОбОшибках);
		КонецЦикла;
		
	Иначе
		ЗаполнитьНаборЗаписей(
			НаборЗаписейРаспределенияВыручки, Организация, ОбъектНаблюдения, АдресДоступныеКодыПоКлассификатору, СообщенияОбОшибках, НаборЗаписей);
	КонецЕсли;
	
КонецПроцедуры

// Проверяет есть ли записи в регистре, по заданному отбору.
// Параметры:
//	Отбор - Структура - Отбор по которому нужно искать записи.
//	 * Организация - СправочникСсылка.Организации - Организация для которой нужно определить наличие настройки.
//	 * ОбъектНаблюдения - СправочникСсылка.ОбъектыСтатистическогоНаблюдения - 
//		Объект наблюдения для которого нужно определить наличие настройки.
// Возвращаемое значение:
//	Булево - истина - записи есть, Ложь - Записей нет.
//
Функция ЕстьЗаписи(Отбор) Экспорт
	
	Запрос = Новый ПостроительЗапроса;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	НастройкаЗаполненияСвободныхСтрокФормСтатистики.Организация
	|ИЗ
	|	РегистрСведений.НастройкаЗаполненияСвободныхСтрокФормСтатистики КАК НастройкаЗаполненияСвободныхСтрокФормСтатистики
	|{ГДЕ
	|	НастройкаЗаполненияСвободныхСтрокФормСтатистики.Организация КАК Организация,
	|	НастройкаЗаполненияСвободныхСтрокФормСтатистики.ОбъектНаблюдения КАК ОбъектНаблюдения,
	|	НастройкаЗаполненияСвободныхСтрокФормСтатистики.ДетализацияОбъектаНаблюдения КАК ДетализацияОбъектаНаблюдения}";
	
	Для Каждого КлючИЗначение Из Отбор Цикл
		ЭлементОтбора = Запрос.Отбор.Добавить(КлючИЗначение.Ключ);
		ЭлементОтбора.Установить(КлючИЗначение.Значение);
	КонецЦикла;
	
	Запрос.Выполнить();
	Возврат Не Запрос.Результат.Пустой();
	
КонецФункции

#Область ДляВызоваИзДругихПодсистем

// СтандартныеПодсистемы.УправлениеДоступом

// См. УправлениеДоступомПереопределяемый.ПриЗаполненииСписковСОграничениемДоступа.
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт

	Ограничение.Текст =
	"РазрешитьЧтениеИзменение
	|ГДЕ
	|	ЗначениеРазрешено(Организация)";

КонецПроцедуры

// Конец СтандартныеПодсистемы.УправлениеДоступом

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьНаборЗаписей(НаборЗаписейРаспределенияВыручки, Организация, ОбъектНаблюдения, АдресДоступныеКодыПоКлассификатору,
	СообщенияОбОшибках, НаборЗаписей = Неопределено)
	
	Если НаборЗаписей = Неопределено Тогда
		НаборЗаписей = СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(Организация);
		НаборЗаписей.Отбор.ОбъектНаблюдения.Установить(ОбъектНаблюдения);
	Иначе
		НаборЗаписей.Очистить();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(АдресДоступныеКодыПоКлассификатору) Тогда
		ДоступныеКодыПоКлассификатору = ПолучитьИзВременногоХранилища(АдресДоступныеКодыПоКлассификатору);
	Иначе
		ДоступныеКодыПоКлассификатору = Справочники.ОбъектыСтатистическогоНаблюдения.ЭлементыКлассификатораИзМакета(ОбъектНаблюдения);
	КонецЕсли;
	
	// Если для отчета коды нужны менее детальные, надо их определить и сохранять в РС НастройкаЗаполненияСвободныхСтрокФормСтатистики именно их.
	Для Каждого Запись Из НаборЗаписейРаспределенияВыручки Цикл
		КодОКВЭД = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Запись.Детализация, "Код");
		Если ДоступныеКодыПоКлассификатору.Найти(КодОКВЭД) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрДлина(КодОКВЭД) <= 5 Тогда
			Продолжить;
		КонецЕсли;
		
		КодВИерархии = КлассификаторОКВЭДБП.КодВИерархии(КодОКВЭД);
		ПервыйКод = Истина;
		
		Для Каждого Код Из КодВИерархии Цикл
			Если ПервыйКод Тогда
				ПервыйКод = Ложь;
				Продолжить;
			КонецЕсли;
			Если СтрДлина(Код) <= 4 Тогда
				Прервать;
			КонецЕсли;
			
			СтрокаТаблицыСпискаКодов = ДоступныеКодыПоКлассификатору.Найти(Код);
			Если СтрокаТаблицыСпискаКодов <> Неопределено Тогда
				Запись.Детализация = Справочники.КлассификаторВидовЭкономическойДеятельности.СсылкаКлассификатор(
					Код, СтрокаТаблицыСпискаКодов.Наименование);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	// Проверим на дубли коды ОКВЭД. Если получилось несколько записей с одинаковым кодом с разными настройками, то надо их объединить в одну настройку.
	Запрос = Новый Запрос;
	ТаблицаНаборЗаписейРаспределенияВыручки = НаборЗаписейРаспределенияВыручки.Выгрузить();
	Запрос.УстановитьПараметр("ТаблицаНаборЗаписей", ТаблицаНаборЗаписейРаспределенияВыручки);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаНаборЗаписей.Детализация КАК Детализация,
	|	1 КАК Количество
	|ПОМЕСТИТЬ ТаблицаНаборЗаписей
	|ИЗ
	|	&ТаблицаНаборЗаписей КАК ТаблицаНаборЗаписей
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаНаборЗаписей.Детализация КАК Детализация,
	|	СУММА(ТаблицаНаборЗаписей.Количество) КАК Количество
	|ПОМЕСТИТЬ ТаблицаДанных
	|ИЗ
	|	ТаблицаНаборЗаписей КАК ТаблицаНаборЗаписей
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаНаборЗаписей.Детализация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаДанных.Детализация КАК Детализация
	|ИЗ
	|	ТаблицаДанных КАК ТаблицаДанных
	|ГДЕ
	|	ТаблицаДанных.Количество > 1";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		СписокДетализация = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Детализация");
		СтрокиКУдалению = Новый Массив;
		
		Для Каждого Детализация Из СписокДетализация Цикл
			НайденныеСтроки = ТаблицаНаборЗаписейРаспределенияВыручки.НайтиСтроки(Новый Структура("Детализация", Детализация));
			ПерваяСтрока = Истина;
			СтрокаДляИсправления = Неопределено;
			
			Для Каждого Строка Из НайденныеСтроки Цикл
				Если ПерваяСтрока Тогда
					СтрокаДляИсправления = Строка;
				Иначе
					СтрокиКУдалению.Добавить(Строка);
				КонецЕсли;
				ПерваяСтрока = Ложь;
			КонецЦикла;
			РеквизитыДетализации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Детализация, "Код, Наименование");
			
			РезультатНастройки = Обработки.КлассификацияВыручкиПоОКВЭД.ОбъединитьНастройкиОКВЭД(НайденныеСтроки, ОбъектНаблюдения, РеквизитыДетализации.Код, РеквизитыДетализации.Наименование);
			ЗаполнитьЗначенияСвойств(СтрокаДляИсправления, РезультатНастройки);
		КонецЦикла;
		
		Для Каждого Строка Из СтрокиКУдалению Цикл
			ТаблицаНаборЗаписейРаспределенияВыручки.Удалить(Строка);
		КонецЦикла;
		НаборЗаписейРаспределенияВыручки.Загрузить(ТаблицаНаборЗаписейРаспределенияВыручки);
	КонецЕсли;
	
	Для Каждого Строка Из НаборЗаписейРаспределенияВыручки Цикл
		
		НайденнаяСтрока = ДоступныеКодыПоКлассификатору.Найти(Строка.Детализация.Код, "Код");
		Если НайденнаяСтрока = Неопределено Тогда
			Если СообщенияОбОшибках <> Неопределено Тогда
				РеквизитыДетализации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Строка.Детализация, "Код, Наименование");
				СообщенияОбОшибках.Добавить(СтрШаблон(НСтр("ru = 'Код %1 ""%2"" не нужно добавлять в отчет, т.к. его нет в списке кодов Росстата.'"),
					РеквизитыДетализации.Код, РеквизитыДетализации.Наименование));
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Запись = НаборЗаписей.Добавить();
		Запись.ОбъектНаблюдения = ОбъектНаблюдения;
		Запись.ДетализацияОбъектаНаблюдения = Строка.Детализация;
		ЗаполнитьЗначенияСвойств(Запись, Строка);
		
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Истина);
	НаборЗаписей.Записать();
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли