#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

Процедура ОчиститьРегистрПоУчастникамСверки(УчастникиСверки) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СервисСверкиРасчетовУстаревшиеIDУчастниковСверки.УчастникСверки КАК УчастникСверки,
	|	СервисСверкиРасчетовУстаревшиеIDУчастниковСверки.Идентификатор КАК Идентификатор
	|ИЗ
	|	РегистрСведений.СервисСверкиРасчетовУстаревшиеIDУчастниковСверки КАК СервисСверкиРасчетовУстаревшиеIDУчастниковСверки
	|ГДЕ
	|	СервисСверкиРасчетовУстаревшиеIDУчастниковСверки.УчастникСверки В (&УчастникиСверки)";
	
	Запрос.УстановитьПараметр("УчастникиСверки", УчастникиСверки);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат;
	КонецЕсли;
	Выборка = Результат.Выбрать();
	
	// Набор записей текущего регистра.
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.РасширенныеРежимыЗамещения = Истина;
	
	Пока Выборка.Следующий() Цикл
		Запись = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Выборка);
		СервисСверкиРасчетов.ПриАктуализацииIDУчастникаСверки(Выборка.УчастникСверки);
	КонецЦикла;
	
	НаборЗаписей.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
