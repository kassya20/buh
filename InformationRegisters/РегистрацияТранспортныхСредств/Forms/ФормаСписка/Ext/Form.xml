	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	Регистрация.Период КАК Период,
	Регистрация.Организация КАК Организация,
	Регистрация.ОсновноеСредство КАК ОсновноеСредство,
	Регистрация.ВключатьВНалоговуюБазу КАК ВключатьВНалоговуюБазу,
	Регистрация.РегистрационныйЗнак КАК РегистрационныйЗнак,
	Регистрация.Марка КАК Марка,
	Регистрация.ИдентификационныйНомер КАК ИдентификационныйНомер,
	Регистрация.ПостановкаНаУчетВНалоговомОргане КАК ПостановкаНаУчетВНалоговомОргане,
	Регистрация.НалоговыйОрган КАК НалоговыйОрган,
	ВЫБОР
		КОГДА
			Регистрация.ПостановкаНаУчетВНалоговомОргане = ЗНАЧЕНИЕ(Перечисление.ПостановкаНаУчетВНалоговомОргане.ВДругомНалоговомОргане)
			ТОГДА Регистрация.НалоговыйОрган.КодРегиона
		ИНАЧЕ Регистрация.Организация.РегистрацияВНалоговомОргане.КодРегиона
	КОНЕЦ КАК КодРегиона,
	Регистрация.КодПоОКАТОДо2014 КАК КодПоОКАТО,
	Регистрация.КодВидаТранспортногоСредстваДо2020 КАК КодВидаТранспортногоСредства,
	Регистрация.НалоговаяБаза КАК НалоговаяБаза,
	Регистрация.ЕдиницаИзмеренияНалоговойБазы КАК ЕдиницаИзмеренияНалоговойБазы,
	ВЫБОР
		КОГДА Регистрация.ЕдиницаИзмеренияНалоговойБазы = "251"
			ТОГДА &amp;ЕИ251
		КОГДА Регистрация.ЕдиницаИзмеренияНалоговойБазы = "999"
			ТОГДА &amp;ЕИ999
		КОГДА Регистрация.ЕдиницаИзмеренияНалоговойБазы = "181"
			ТОГДА &amp;ЕИ181
		КОГДА Регистрация.ЕдиницаИзмеренияНалоговойБазы = "796"
