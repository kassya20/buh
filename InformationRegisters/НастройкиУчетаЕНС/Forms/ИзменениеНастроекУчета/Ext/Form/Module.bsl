#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если ЗначениеЗаполнено(Параметры.Организация) Тогда
		Организация = Параметры.Организация;
	ИначеЕсли ТипЗнч(Параметры.Ключ) = Тип("РегистрСведенийКлючЗаписи.НастройкиУчетаЕНС") Тогда
		Организация = Параметры.Ключ.Организация;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Организация) Тогда
		Заголовок = СтрШаблон("Настройки учета ЕНС: %1", Организация);
		Элементы.Организация.Видимость = Ложь;
	КонецЕсли;
	
	ПриИзмененииОрганизацииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если Не НачислятьНалогиПоДаннымФНС Тогда
		НепроверяемыеРеквизиты = Новый Массив;
		НепроверяемыеРеквизиты.Добавить("НачалоУчетаПоДаннымФНС");
		ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, НепроверяемыеРеквизиты);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы И Модифицированность Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если Не Модифицированность Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Истина;
	ЗадатьВопросПередЗакрытием();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	ПриИзмененииОрганизацииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура НачислятьНалогиПоДаннымФНСПриИзменении(Элемент)
	
	Если НачислятьНалогиПоДаннымФНС Тогда
		НачалоУчетаПоДаннымФНС = СтароеНачалоУчетаПоДаннымФНС;
		Если Не ЗначениеЗаполнено(НачалоУчетаПоДаннымФНС) Тогда
			НачалоУчетаПоДаннымФНС = НачалоМесяца(ТекущаяДата());
		КонецЕсли;
	Иначе
		НачалоУчетаПоДаннымФНС = '0001-01-01';
	КонецЕсли;
	СформироватьПодсказкуСпособНачисления(ЭтотОбъект);
	СформироватьПредупреждение(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоУчетаПоДаннымФНСПриИзменении(Элемент)
	
	НачалоУчетаПоДаннымФНС = НачалоМесяца(НачалоУчетаПоДаннымФНС);
	СформироватьПредупреждение(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПрименитьНастройки(Команда)
	
	ПрименитьНастройкиНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьИзменения(Команда)
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПриИзмененииОрганизацииНаСервере()
	
	Если ЗначениеЗаполнено(Организация) Тогда
		НачалоУчетаПоДаннымФНС = ЕдиныйНалоговыйСчет.НачалоУчетаПоДаннымФНС(Организация);
		СервисЕНСПодключен = РегистрыСведений.СостоянияПодключенияЕНС.ЕстьНастройкаПодключенияЕНС(Организация);
		ЭтоОбособленноеПодразделение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Организация, "ОбособленноеПодразделение");
	Иначе
		НачалоУчетаПоДаннымФНС = '0001-01-01';
		СервисЕНСПодключен = Ложь;
		ЭтоОбособленноеПодразделение = Ложь;
	КонецЕсли;
	
	СтароеНачалоУчетаПоДаннымФНС = НачалоУчетаПоДаннымФНС;
	НачислятьНалогиПоДаннымФНС = ЗначениеЗаполнено(НачалоУчетаПоДаннымФНС);
	ТолькоПросмотр = Не ПравоДоступа("Изменение", Метаданные.РегистрыСведений.НастройкиУчетаЕНС)
		Или ЭтоОбособленноеПодразделение;
	
	СформироватьПодсказкуСпособНачисления(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьНастройкиНаКлиенте()
	
	Результат = ПрименитьНастройкиНаСервере();
	Если Не Результат Тогда
		Возврат;
	КонецЕсли;
	Оповестить("Запись_НастройкиУчетаЕНС", Организация);
	Модифицированность = Ложь;
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗадатьВопросПередЗакрытием()
	
	ТекстВопроса = НСтр("ru = 'Настройки были изменены. Применить изменения?'");
	Кнопки = Новый СписокЗначений;
	Кнопки.Добавить(КодВозвратаДиалога.ОК, НСтр("ru='Применить'"));
	Кнопки.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru='Отмена'"));
	Ответ = Ждать ВопросАсинх(ТекстВопроса, Кнопки);
	Если Ответ = КодВозвратаДиалога.ОК Тогда
		ПрименитьНастройкиНаКлиенте();
	Иначе
		Модифицированность = Ложь;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПрименитьНастройкиНаСервере()
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если НачислятьНалогиПоДаннымФНС Тогда
		НовоеНачалоУчетаПоДаннымФНС = НачалоУчетаПоДаннымФНС;
	Иначе
		НовоеНачалоУчетаПоДаннымФНС = '0001-01-01';
	КонецЕсли;
	ЕдиныйНалоговыйСчет.УстановитьУчетПоДаннымФНС(Организация, НачалоУчетаПоДаннымФНС, Ложь);
	
	Возврат Истина;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	НачалоУчетаИзменено = Форма.НачалоУчетаПоДаннымФНС <> Форма.СтароеНачалоУчетаПоДаннымФНС;
	Форма.Элементы.ГруппаПредупреждение.Видимость = НачалоУчетаИзменено
		И ЗначениеЗаполнено(Форма.Элементы.ДекорацияПредупреждение.Заголовок);
	Форма.Элементы.НачалоУчетаПоДаннымФНС.Видимость = Форма.НачислятьНалогиПоДаннымФНС;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура СформироватьПодсказкуСпособНачисления(Форма)
	
	ТекстПодсказки = "";
	Если Форма.НачислятьНалогиПоДаннымФНС Тогда
		Если Форма.СервисЕНСПодключен Тогда
			ТекстПодсказки = 
				НСтр("ru='Все начисления производятся документами ""Операции ЕНС"".
				|""Операции ЕНС"" и ""Сведения об уплате налогов"" формируются при обновлении ЛК ЕНС.'");
		Иначе
			ТекстПодсказки = 
				НСтр("ru='Все начисления производятся документами ""Операции ЕНС"".
				|""Операции ЕНС"" и ""Сведения об уплате налогов"" формируются вручную.'");
		КонецЕсли;
	Иначе
		Если Форма.СервисЕНСПодключен Тогда
			ТекстПодсказки = 
				НСтр("ru='Начисления производятся регламентной операцией ""Начисление налогов на ЕНС"",
				|документами начисления и выплаты зарплаты, другими документами.
				|""Сведения об уплате налогов"" формируются при обновлении ЛК ЕНС.'");
		Иначе
			ТекстПодсказки = 
				НСтр("ru='Начисления производятся регламентной операцией ""Начисление налогов на ЕНС"",
				|документами начисления и выплаты зарплаты, другими документами.
				|""Сведения об уплате налогов"" формируются вручную.'");
		КонецЕсли;
	КонецЕсли;
	Форма.Элементы.ГруппаСпособНачисления.РасширеннаяПодсказка.Заголовок = ТекстПодсказки;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура СформироватьПредупреждение(Форма)
	
	ТекстЗаголовка = "";
	Если Форма.НачислятьНалогиПоДаннымФНС Тогда
		Если ЗначениеЗаполнено(Форма.СтароеНачалоУчетаПоДаннымФНС)
			И Форма.НачалоУчетаПоДаннымФНС > Форма.СтароеНачалоУчетаПоДаннымФНС Тогда
			ТекстЗаголовка = СтрШаблон(
				НСтр("ru='После применения настроек необходимо самостоятельно:
				|- Удалить ""Операции ЕНС"", созданные из ЛК ЕНС с %1 до %2;
				|- Выполнить перепроведение, начиная с документов за %3.'"),
				Формат(Форма.СтароеНачалоУчетаПоДаннымФНС, "ДЛФ=D"),
				Формат(Форма.НачалоУчетаПоДаннымФНС, "ДЛФ=D"),
				Формат(НачалоКвартала(Форма.СтароеНачалоУчетаПоДаннымФНС) - 1, "ДФ='ММММ гггг'' г.'"));
		ИначеЕсли ЗначениеЗаполнено(Форма.НачалоУчетаПоДаннымФНС)
			И Не ЗначениеЗаполнено(Форма.СтароеНачалоУчетаПоДаннымФНС) Тогда
			ТекстЗаголовка = СтрШаблон(
				НСтр("ru='Будут удалены проводки начисления налогов на ЕНС, начиная с %1.
				|Новые проводки сформируются при первом обновлении данных ЛК ЕНС.'"),
				Формат(Форма.НачалоУчетаПоДаннымФНС, "ДЛФ=D"));
		ИначеЕсли ЗначениеЗаполнено(Форма.НачалоУчетаПоДаннымФНС)
			И Форма.НачалоУчетаПоДаннымФНС < Форма.СтароеНачалоУчетаПоДаннымФНС Тогда
			ТекстЗаголовка = СтрШаблон(
				НСтр("ru='Будут удалены проводки начисления налогов на ЕНС с %1 до %2.
				|Новые проводки сформируются при первом обновлении данных ЛК ЕНС.'"),
				Формат(Форма.НачалоУчетаПоДаннымФНС, "ДЛФ=D"),
				Формат(Форма.СтароеНачалоУчетаПоДаннымФНС, "ДЛФ=D"));
		КонецЕсли;
	Иначе
		Если ЗначениеЗаполнено(Форма.СтароеНачалоУчетаПоДаннымФНС) Тогда
			ТекстЗаголовка = СтрШаблон(
				НСтр("ru='После применения настроек необходимо самостоятельно:
				|- Удалить ""Операции ЕНС"", созданные из ЛК ЕНС с %1;
				|- Выполнить перепроведение, начиная с документов за %2.'"),
				Формат(Форма.СтароеНачалоУчетаПоДаннымФНС, "ДЛФ=D"),
				Формат(НачалоКвартала(Форма.СтароеНачалоУчетаПоДаннымФНС) - 1, "ДФ='ММММ гггг'' г.'"));
		КонецЕсли;
	КонецЕсли;
	Форма.Элементы.ДекорацияПредупреждение.Заголовок = ТекстЗаголовка;
	
КонецПроцедуры

#КонецОбласти