#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиОбновления

// Параметры:
//  ПараметрыОбновления - Структура - параметры обработчика обновления.
Процедура ЗаполнитьВыявленныеВредныеФакторыСОУТ(ПараметрыОбновления) Экспорт

	ВредныеКлассы = КлассыУсловийТрудаКлиентСервер.ВредныеИОпасныеКлассыУсловийТруда();

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВредныеКлассы", ВредныеКлассы);
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	КлассыУТ.Должность КАК Должность
		|ИЗ
		|	РегистрСведений.КлассыУсловийТрудаПоДолжностям КАК КлассыУТ
		|ГДЕ
		|	КлассыУТ.КлассУсловийТруда В (&ВредныеКлассы)
		|	И НЕ КлассыУТ.ВыявленыВредныеОпасныеФакторы";

	ОбновляемыеДанные =
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ВыполнитьЗапросПолученияОбновляемыхДанных(Запрос, ПараметрыОбновления);
	
	Если ОбновляемыеДанные.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПродолжитьОбработчик(ПараметрыОбновления);
	
	МетаданныеРегистра = Метаданные.РегистрыСведений.КлассыУсловийТрудаПоДолжностям;
	ПолноеИмяРегистра = МетаданныеРегистра.ПолноеИмя();
	
	Выборка = ОбновляемыеДанные.Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Должность.Установить(Выборка.Должность);

		НачатьТранзакцию();
		Попытка
			Блокировка = Новый БлокировкаДанных;
			ЭлементБлокировки = Блокировка.Добавить(ПолноеИмяРегистра);
			ЭлементБлокировки.УстановитьЗначение("Должность", Выборка.Должность);
			Блокировка.Заблокировать();

			НаборЗаписей.Прочитать();

			ЕстьИзменения = Ложь;
			ДокументыОснования = Новый Соответствие;
			Для Каждого Запись Из НаборЗаписей Цикл
				Если ВредныеКлассы.Найти(Запись.КлассУсловийТруда) <> Неопределено И Не Запись.ВыявленыВредныеОпасныеФакторы Тогда
					Запись.ВыявленыВредныеОпасныеФакторы = Истина;
					ЕстьИзменения = Истина;
					Если ЗначениеЗаполнено(Запись.Основание) Тогда
						ДокументыОснования.Вставить(Запись.Основание, Истина);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;

			Если ЕстьИзменения Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
			КонецЕсли;

			Для Каждого КлючИЗначение Из ДокументыОснования Цикл
				КлассыУсловийТруда.ОбновитьВыявленныеВредныеФакторыВДокументеОснования(
					КлючИЗначение.Ключ, Выборка.Должность, ВредныеКлассы);
			КонецЦикла;

			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации(
				ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
				УровеньЖурналаРегистрации.Ошибка, МетаданныеРегистра, ,
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецЕсли
