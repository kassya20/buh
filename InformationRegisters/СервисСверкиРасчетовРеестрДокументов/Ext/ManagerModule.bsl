#Область ОбработчикиОбновления

Процедура ЗаполнитьОтправленныеНаСервисЗначения(Параметры) Экспорт
	
	Если Не СервисСверкиРасчетов.ИспользуетсяСервисСверкиРасчетов() Тогда
		Возврат;
	КонецЕсли;
	
	// Обработаем записи помесячно с конца.
	ДатаНачалаСверки    = СервисСверкиРасчетов.ДатаНачалаСверкиРасчетов();
	ДатаОкончанияСверки = КонецМесяца(ТекущаяДатаСеанса());
	
	ПоследнийНеобработанныйМесяц = ПоследнийНеобработанныйМесяц(ДатаНачалаСверки, ДатаОкончанияСверки);
	
	Если Не ЗначениеЗаполнено(ПоследнийНеобработанныйМесяц) Тогда
		Параметры.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	ДатаНачала    = НачалоМесяца(ПоследнийНеобработанныйМесяц);
	ДатаОкончания = КонецМесяца(ПоследнийНеобработанныйМесяц);
	
	ИмяПроцедуры = "РегистрыСведений.СервисСверкиРасчетовРеестрДокументов.ЗаполнитьОтправленныеНаСервисЗначения()";
	ОбработаноЗаписей = 0;
	
	Пока ОбработаноЗаписей < 1000 
		И ДатаНачала >= ДатаНачалаСверки Цикл
		
		ОбработаноЗаписейЗаМесяц = 0;
		ПроблемныхЗаписей        = 0;
		
		ДанныеИнформационнойБазыКСверке = СервисСверкиРасчетовПереопределяемый.ДанныеИнформационнойБазыКСверке(Неопределено, ДатаНачала, ДатаОкончания, Истина);
		
		ВыборкаОрганизации = ДанныеИнформационнойБазыКСверке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаОрганизации.Следующий() Цикл
			
			ВыборкаДокументы = ВыборкаОрганизации.Выбрать();
			
			Пока ВыборкаДокументы.Следующий() Цикл
				
				ОбработаноЗаписей = ОбработаноЗаписей + 1;
				ОбработаноЗаписейЗаМесяц = ОбработаноЗаписейЗаМесяц + 1;
				
				НаборЗаписей = СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Организация.Установить(ВыборкаДокументы.Организация);
				НаборЗаписей.Отбор.Контрагент.Установить(ВыборкаДокументы.Контрагент);
				НаборЗаписей.Отбор.Документ.Установить(ВыборкаДокументы.Документ);
				
				НаборЗаписей.Прочитать();
				
				Если НаборЗаписей.Количество() = 0 Тогда 
					Продолжить;
				КонецЕсли;
				
				Запись = НаборЗаписей[0];
				
				ДополнительныеСведенияДляОпределенияОперации = 
				СервисСверкиРасчетовПереопределяемый.ДополнительныеСведенияДляОпределенияОперации(ВыборкаДокументы);
				ВидОперации = СервисСверкиРасчетовПереопределяемый.ВидОперации(
				ВыборкаДокументы.Документ, ДополнительныеСведенияДляОпределенияОперации);
				
				ЗаполнитьЗначенияСвойств(Запись, ВыборкаДокументы); 
				
				Запись.Операция     = ВидОперации;
				
				ТаблицаПредставленияДокумента  = СервисСверкиРасчетов.НовыйТаблицаПредставленияДокумента();
				НовыйДокументОрганизации       = ТаблицаПредставленияДокумента.Добавить();
				НовыйДокументОрганизации.Номер = ВыборкаДокументы.НомерДокумента;
				НовыйДокументОрганизации.Дата  = ВыборкаДокументы.ДатаДокумента;
				Запись.ПервичныйДокумент = СервисСверкиРасчетов.ПредставлениеДокументаПоТаблице(ТаблицаПредставленияДокумента);
				
				ТаблицаПредставленияСФ   = СервисСверкиРасчетов.НовыйТаблицаПредставленияДокумента();
				НовыйСФОрганизации       = ТаблицаПредставленияСФ.Добавить();
				Если ВыборкаДокументы.ОбрабатыватьНомерСФ Тогда
					НомерСчетаФактуры = СервисСверкиРасчетов.НомерБезПрефиксовИЛидирующихНулей(ВыборкаДокументы.НомерСчетаФактуры);
				Иначе
					НомерСчетаФактуры = ВыборкаДокументы.НомерСчетаФактуры;
				КонецЕсли;
				НовыйСФОрганизации.Номер = НомерСчетаФактуры;
				НовыйСФОрганизации.Дата  = ВыборкаДокументы.ДатаСчетаФактуры;
				Запись.СчетФактура = СервисСверкиРасчетов.ПредставлениеДокументаПоТаблице(ТаблицаПредставленияСФ);
				
				Запись.Сумма    = ?(ВыборкаДокументы.Сумма >= 0, ВыборкаДокументы.Сумма, - ВыборкаДокументы.Сумма);
				Запись.СуммаНДС = ?(ВыборкаДокументы.СуммаНДС >= 0, ВыборкаДокументы.СуммаНДС, - ВыборкаДокументы.СуммаНДС);
				
				
				Попытка
					
					ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
					
				Исключение
					
					ПроблемныхЗаписей = ПроблемныхЗаписей + 1;
					
					ТекстСообщения = СтрШаблон(НСтр("ru = 'Процедуре %1 не удалось заполнить реквизиты отправленного документа по причине:
					|%2'"), ИмяПроцедуры, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
					
					ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
					УровеньЖурналаРегистрации.Предупреждение,
					Метаданные.РегистрыСведений.СервисСверкиРасчетовОбнаруженныеРасхождения,
					,
					ТекстСообщения);
					
				КонецПопытки;
				
			КонецЦикла;
		КонецЦикла;
		
		Если ПроблемныхЗаписей > 0 Тогда
			
			ТекстСообщения = СтрШаблон(НСтр("ru = 'Процедуре %1 не удалось заполнить реквизиты отправленного документа: в %2 из %3 возникли ошибки'"),
			ИмяПроцедуры, ПроблемныхЗаписей, ОбработаноЗаписейЗаМесяц);
			ВызватьИсключение ТекстСообщения;
			
		Иначе
			
			ЗаписьЖурналаРегистрации(ОбновлениеИнформационнойБазы.СобытиеЖурналаРегистрации(),
			УровеньЖурналаРегистрации.Информация,
			Метаданные.РегистрыСведений.СервисСверкиРасчетовОбнаруженныеРасхождения,,
			СтрШаблон(НСтр("ru = 'Процедура %1 обработала очередную порцию документов: %2 записей'"),
			ИмяПроцедуры, ОбработаноЗаписейЗаМесяц));
			
		КонецЕсли;
		
		// Вычислим предыдущий месяц, который будем обрабатывать если обработали меньше 1000 документов.
		ДатаНачала = НачалоМесяца(ДатаНачала - 1);
		ДатаОкончания = КонецМесяца(ДатаНачала);
		Если ДатаНачала < ДатаНачалаСверки Тогда
			Параметры.ОбработкаЗавершена = Истина;
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПоследнийНеобработанныйМесяц(ДатаНачала, ДатаОкончания)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СервисСверкиРасчетовРеестрДокументов.ДатаДокумента КАК ДатаДокумента
	|ИЗ
	|	РегистрСведений.СервисСверкиРасчетовРеестрДокументов КАК СервисСверкиРасчетовРеестрДокументов
	|ГДЕ
	|	СервисСверкиРасчетовРеестрДокументов.ДатаДокумента >= &ДатаНачала
	|	И СервисСверкиРасчетовРеестрДокументов.Статус = ЗНАЧЕНИЕ(Перечисление.СервисСверкиРасчетовСтатусыДокументов.Получено)
	|	И СервисСверкиРасчетовРеестрДокументов.ДатаДокумента <= &ДатаОкончания
	|	И СервисСверкиРасчетовРеестрДокументов.ПервичныйДокумент = """"
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДокумента УБЫВ";
	
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	
	Выборка = Запрос.Выполнить().Выбрать();

	Если Выборка.Следующий() Тогда
		Возврат НачалоМесяца(Выборка.ДатаДокумента);
	Иначе
		Возврат Дата(1,1,1);
	КонецЕсли;

КонецФункции

#КонецОбласти

#КонецЕсли
