	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>~Список.Подраздел82</Field>
				<Field>~Список.Раздел82</Field>
				<Field>~Список.СсылкаНаИТС82</Field>
				<Field>Список.ВидОперацииДокумента</Field>
				<Field>Список.Журнал</Field>
				<Field>Список.ЗакладкаДокумента</Field>
				<Field>Список.Идентификатор</Field>
				<Field>Список.ИмяДокумента</Field>
				<Field>Список.Подраздел</Field>
				<Field>Список.Раздел</Field>
				<Field>Список.СсылкаНаИТС</Field>
				<Field>Список.ТипДокумента</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	РегистрСведенийКорреспонденцииСчетов.Идентификатор КАК Идентификатор,
	РегистрСведенийКорреспонденцииСчетов.Содержание КАК Содержание,
	ХозрасчетныйДт.Ссылка КАК СчетДт,
	ХозрасчетныйКт.Ссылка КАК СчетКт,
	РегистрСведенийКорреспонденцииСчетов.ИмяДокумента КАК ИмяДокумента,
	РегистрСведенийКорреспонденцииСчетов.ТипДокумента КАК ТипДокумента,
	РегистрСведенийКорреспонденцииСчетов.ВидОперацииДокумента КАК ВидОперацииДокумента,
	РегистрСведенийКорреспонденцииСчетов.ЗакладкаДокумента КАК ЗакладкаДокумента,
	РегистрСведенийКорреспонденцииСчетов.Раздел КАК Раздел,
	РегистрСведенийКорреспонденцииСчетов.Подраздел КАК Подраздел,
	РегистрСведенийКорреспонденцииСчетов.Журнал КАК Журнал,
	РегистрСведенийКорреспонденцииСчетов.СсылкаНаИТС КАК СсылкаНаИТС,
	ВЫБОР
		КОГДА ПОДСТРОКА(РегистрСведенийКорреспонденцииСчетов.СчетДт, 1, 3) = "000"
			ТОГДА "Я"
		ИНАЧЕ ВЫБОР
				КОГДА ХозрасчетныйДт.Забалансовый
					ТОГДА "ЯЯ"
