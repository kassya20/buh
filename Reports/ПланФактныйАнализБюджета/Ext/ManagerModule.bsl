#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// См. ВариантыОтчетовПереопределяемый.НастроитьВариантыОтчетов.
//
Процедура НастроитьВариантыОтчета(Настройки, НастройкиОтчета) Экспорт
	
	НастройкиОтчета.ОпределитьНастройкиФормы = Истина;
	
	НастройкиВарианта = ВариантыОтчетов.ОписаниеВарианта(Настройки, НастройкиОтчета, "ПланФактныйАнализБюджета");
	НастройкиВарианта.Описание = НСтр("ru = 'План-фактный анализ бюджета.'");
	НастройкиВарианта.Размещение.Вставить(Метаданные.Подсистемы.БухгалтерияПредприятияПодсистемы.Подсистемы.Бюджет, "");
	
	НастройкиВарианта = ВариантыОтчетов.ОписаниеВарианта(Настройки, НастройкиОтчета, "РасшифровкаПоказателей");
	НастройкиВарианта.Описание = НСтр("ru = 'План-фактный анализ бюджета (Расшифровка).'");
	НастройкиВарианта.Размещение.Вставить(Метаданные.Подсистемы.БухгалтерияПредприятияПодсистемы.Подсистемы.Бюджет, "");
	
КонецПроцедуры

// Инициализирует набор параметров, задающих флаги выполнения дополнительных действий над сущностями, обрабатываемыми
// в процессе формирования отчета.
//
// Возвращаемое значение:
//   Структура   - флаги, задающие необходимость дополнительных действий.
//
Функция ПолучитьПараметрыИсполненияОтчета() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользоватьПередКомпоновкойМакета",          Истина);
	Результат.Вставить("ИспользоватьПослеКомпоновкиМакета",           Ложь);
	Результат.Вставить("ИспользоватьПослеВыводаРезультата",           Истина);
	Результат.Вставить("ИспользоватьДанныеРасшифровки",               Истина);
	Результат.Вставить("ИспользоватьРасширенныеПараметрыРасшифровки", Истина);
	Результат.Вставить("ИспользоватьПриВыводеЗаголовка",              Ложь);
	Результат.Вставить("ИспользоватьПриВыводеПодвала",                Истина);
	
	Возврат Результат;
	
КонецФункции

// Формирует текст, выводимый в заголовке отчета.
//
// Параметры:
//  ПараметрыОтчета - Структура - см. ПодготовитьПараметрыОтчета() в ФормаОтчета.
//
// Возвращаемое значение:
//   Строка      - текст заголовка с учетом периода.
//
Функция ПолучитьТекстЗаголовка(ПараметрыОтчета) Экспорт 
	
	ЗаголовокОтчета = НСтр("ru='%1 за %2'");
	Если ПараметрыОтчета.РежимРасшифровки Тогда
		Название = НСтр("ru='План-фактный анализ бюджета (Расшифровка)'");
	Иначе
		Название = НСтр("ru='План-фактный анализ бюджета'");
	КонецЕсли;
	
	Если ПараметрыОтчета.ГруппироватьПоПериодам Тогда
		Период = БухгалтерскиеОтчетыКлиентСервер.ПолучитьПредставлениеПериода(ПараметрыОтчета.НачалоПериода,
			ПараметрыОтчета.КонецПериода, Истина);
	Иначе
		Период = БухгалтерскиеОтчетыКлиентСервер.ПолучитьПредставлениеПериодаСНачалаГода(
			ПараметрыОтчета.КонецПериода, ПараметрыОтчета.ПоМесяцам, Истина);
	КонецЕсли;
		
	ЗаголовокОтчета = СтрШаблон(ЗаголовокОтчета, Название, Период);
	
	Возврат ЗаголовокОтчета;
	
КонецФункции

// В процедуре можно доработать компоновщик перед выводом в отчет
// Изменения сохранены не будут
Процедура ПередКомпоновкойМакета(ПараметрыОтчета, Схема, КомпоновщикНастроек) Экспорт
	
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "Организация",  ПараметрыОтчета.Организация);
		
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(
		КомпоновщикНастроек, "НачалоПериода", НачалоДня(ПараметрыОтчета.НачалоПериода));
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(
		КомпоновщикНастроек, "КонецПериода", КонецДня(ПараметрыОтчета.КонецПериода));
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(
		КомпоновщикНастроек, "ОстатокНаНачалоГодаПлан", ПараметрыОтчета.ОстатокНаНачало);
		
	ОстаткиДенежныхСредств = Отчеты.ОстаткиДенежныхСредств.ПолучитьОстаткиДенежныхСредствДляМонитораРуководителяСводно(ПараметрыОтчета.Организация, 
		НачалоДня(ПараметрыОтчета.НачалоПериода) - 1);
		
	ОстатокНаНачалоГодаФакт = ОстаткиДенежныхСредств.Итог("Сумма");
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(
		КомпоновщикНастроек, "ОстатокНаНачалоГодаФакт", ОстатокНаНачалоГодаФакт);
		
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(
		КомпоновщикНастроек, "ПоМесяцам", ПараметрыОтчета.ПоМесяцам);
		
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(
		КомпоновщикНастроек, "ГруппироватьПоПериодам", ПараметрыОтчета.ГруппироватьПоПериодам);
		
	НастройкиКомпоновки = КомпоновщикНастроек.Настройки;
	
	Если ПараметрыОтчета.ПоказательКодСтатьи Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновки.Выбор, "КодСтатьи");
	КонецЕсли;
	Если ПараметрыОтчета.ПоказательПлан Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновки.Выбор, "План");
	КонецЕсли;
	Если ПараметрыОтчета.ПоказательФакт Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновки.Выбор, "Факт");
	КонецЕсли;
	Если ПараметрыОтчета.ПоказательОстаток Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновки.Выбор, "Остаток");
	КонецЕсли;
	Если ПараметрыОтчета.ПоказательПревышение Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновки.Выбор, "Превышение");
	КонецЕсли;
	Если ПараметрыОтчета.ПоказательОтклонение Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновки.Выбор, "Отклонение");
	КонецЕсли;
	Если ПараметрыОтчета.ПоказательПроцентИсполнения Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьВыбранноеПоле(НастройкиКомпоновки.Выбор, "ПроцентИсполнения");
	КонецЕсли;
	
	БухгалтерскиеОтчетыВызовСервера.ДобавитьОтборПоОрганизации(ПараметрыОтчета, КомпоновщикНастроек);
	
	Если Не ПараметрыОтчета.РежимРасшифровки Тогда
		НастроитьГруппировкиДляОтчета(ПараметрыОтчета, НастройкиКомпоновки);
	Иначе
		НастроитьГруппировкиДляРасшифровкиОтчета(ПараметрыОтчета, НастройкиКомпоновки);
	КонецЕсли;
	
	
КонецПроцедуры

Процедура НастроитьГруппировкиДляОтчета(ПараметрыОтчета, НастройкиКомпоновки)
	
	ИмяГруппировки = ПараметрыОтчета.РазделыОтчета;
	
	Если ПараметрыОтчета.ГруппироватьПоПериодам Тогда
		ИмяГруппировки = СтрШаблон("%1ПоПериодам", ИмяГруппировки);
	КонецЕсли;
	
	ВыбраннаяГруппировка = ГруппировкаОтчетаПоИмени(НастройкиКомпоновки.Структура, ИмяГруппировки);
	ВыбраннаяГруппировка.Использование = Истина;
	
КонецПроцедуры

Процедура НастроитьГруппировкиДляРасшифровкиОтчета(ПараметрыОтчета, НастройкиКомпоновки)
	
	ГруппировкаПоУмолчанию = ГруппировкаОтчетаПоИмени(НастройкиКомпоновки.Структура, "БезДопГруппировок");
	
	НастройкиКомпоновки.Структура.Очистить();
	Группировка = НастройкиКомпоновки.Структура;
	Для Каждого ПолеВыбраннойГруппировки Из ПараметрыОтчета.Группировка Цикл 
		Если ПолеВыбраннойГруппировки.Использование Тогда
			Если ТипЗнч(Группировка) = Тип("КоллекцияЭлементовСтруктурыНастроекКомпоновкиДанных") Тогда
				Группировка = Группировка.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
			Иначе
				Группировка = Группировка.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
			КонецЕсли;
			БухгалтерскиеОтчетыВызовСервера.ЗаполнитьГруппировку(ПолеВыбраннойГруппировки, Группировка);
		КонецЕсли;
	КонецЦикла;
	
	Если ТипЗнч(Группировка) = Тип("КоллекцияЭлементовСтруктурыНастроекКомпоновкиДанных") Тогда
		Группировка = Группировка.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	Иначе
		Группировка = Группировка.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Группировка, ГруппировкаПоУмолчанию);
	Для Каждого ПолеГруппировкиПоУмолчанию Из ГруппировкаПоУмолчанию.ПоляГруппировки.Элементы Цикл
		БухгалтерскиеОтчетыВызовСервера.ЗаполнитьГруппировку(ПолеГруппировкиПоУмолчанию, Группировка);
	КонецЦикла;
	
КонецПроцедуры

Функция ГруппировкаОтчетаПоИмени(СтруктураНастроек, ИмяГруппировки)
	
	Для Каждого ЭлементНастроек Из СтруктураНастроек Цикл
		Если (ТипЗнч(ЭлементНастроек) = Тип("ГруппировкаКомпоновкиДанных")
			Или ТипЗнч(ЭлементНастроек) = Тип("ТаблицаКомпоновкиДанных")
			Или ТипЗнч(ЭлементНастроек) = Тип("ГруппировкаТаблицыКомпоновкиДанных"))
			И ЭлементНастроек.Имя = ИмяГруппировки Тогда
			Возврат ЭлементНастроек;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

// Обработчик вывода подвала отчета.
//
// Параметры:
//	ПараметрыОтчета - Структура - Содержит ключи:
//		* Организация - СправочникСсылка.Организации - Организация, по которой формируется отчет.
//		* Период - Дата - Период формирования отчета (опционально).
//		* КонецПериода - Дата - Конец периода формирования отчета (опционально).
//	Результат - ТабличныйДокумент - Результат формирования отчета.
//
Процедура ПриВыводеПодвала(ПараметрыОтчета, Результат) Экспорт
	
	Макет = Отчеты.ПланФактныйАнализБюджета.ПолучитьМакет("МакетОтчета");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подписи");
	ОбластьПодвал.Параметры.Заполнить(Новый Структура("ТекущаяДата", ТекущаяДатаСеанса()));
	
	ДанныеОтветственного = БухгалтерскиеОтчетыВызовСервера.ПолучитьДанныеОтветственногоЛица(ПараметрыОтчета);
	ОбластьПодвал.Параметры.Заполнить(ДанныеОтветственного);
	
	Результат.Вывести(ОбластьПодвал);
	
КонецПроцедуры

// В процедуре можно изменить табличный документ после вывода в него данных.
//
// Параметры:
//  ПараметрыОтчета - Структура - см. ПодготовитьПараметрыОтчета() в ФормаОтчета.
//  Результат    - ТабличныйДокумент - сформированный отчет.
//
Процедура ПослеВыводаРезультата(ПараметрыОтчета, Результат) Экспорт
	
	БухгалтерскиеОтчетыВызовСервера.ОбработкаРезультатаОтчета(ПараметрыОтчета.ИдентификаторОтчета, Результат);
	
	БыстрыеНастройкиОтчетовСервер.ВывестиПримечанияОкругления(ПараметрыОтчета, Результат);
	
КонецПроцедуры

// Заполняет настройки расшифровки
//
// Параметры:
//  Адрес					- Строка, адрес с данными отчета во временном хранилище.
//  Расшифровка 			- ИдентификаторРасшифровкиКомпоновкиДанных, идентификатор расшифровки из ячейки для которой вызвана расшифровка.
//  ПараметрыРасшифровки	- Структура, настройки расшифровки отчета, которые нужно заполнить.
//
Процедура ЗаполнитьПараметрыРасшифровкиОтчета(Адрес, Расшифровка, ПараметрыРасшифровки) Экспорт
	
	ПользовательскиеНастройки = Новый ПользовательскиеНастройкиКомпоновкиДанных;
	ПользовательскиеОтборы = ПользовательскиеНастройки.Элементы.Добавить(Тип("ОтборКомпоновкиДанных"));
	ПользовательскиеОтборы.ИдентификаторПользовательскойНастройки = "Отбор";
	
	ДополнительныеСвойства = ПользовательскиеНастройки.ДополнительныеСвойства;
	
	ДанныеОбъекта = ПолучитьИзВременногоХранилища(Адрес);
	
	ОтчетОбъект       = ДанныеОбъекта.Объект;
	ДанныеРасшифровки = ДанныеОбъекта.ДанныеРасшифровки;
	РежимРасшифровки  = ОтчетОбъект.РежимРасшифровки;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.ЗагрузитьНастройки(ДанныеРасшифровки.Настройки);
	КомпоновщикНастроек.Инициализировать(
		Новый ИсточникДоступныхНастроекКомпоновкиДанных(ДанныеОбъекта.Объект.СхемаКомпоновкиДанных));
		
	СоответствиеПолей = Новый Соответствие;
	
	Если Не РежимРасшифровки Тогда
		ДополнительныеСвойства.Вставить("РежимРасшифровки", Истина);
		ДополнительныеСвойства.Вставить("Организация"     , ОтчетОбъект.Организация);
	
		СоответствиеПолей.Вставить("СтатьяДохода");
		СоответствиеПолей.Вставить("НаправлениеДеятельности");
		СоответствиеПолей.Вставить("СтатьяРасхода");
		СоответствиеПолей.Вставить("ТипЗаписи");
		
		// Отчет поддерживает расшифровку только этих полей
		МассивРасшифровываемыхПолей = СтрРазделить("План,Факт", ",");
	Иначе
		// Если отчет уже в режиме расшифровки - то при открытии суммы или даты открываем первичный документ
		СоответствиеПолей.Вставить("Документ");
		МассивРасшифровываемыхПолей = СтрРазделить("СуммаДокумента,ДатаРасшифровки", ",");
	КонецЕсли;
	
	МассивПолей = БухгалтерскиеОтчетыВызовСервера.ПолучитьМассивПолейРасшифровки(
		Расшифровка, ДанныеРасшифровки, КомпоновщикНастроек, Истина);
		
	Для Каждого ПолеРасшифровки Из МассивПолей Цикл
		
		Если ТипЗнч(ПолеРасшифровки) <> Тип("ЗначениеПоляРасшифровкиКомпоновкиДанных") Тогда
			Продолжить;
		КонецЕсли;
		
		Если ПолеРасшифровки.Поле = "Период" Тогда
			СоответствиеПолей.Вставить("Период");
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	РазобранныеДанныеРасшифровки = БухгалтерскиеОтчеты.ПолучитьДанныеРасшифровки(
		ДанныеРасшифровки, СоответствиеПолей, Расшифровка);
		
	Для Каждого Отбор Из МассивПолей Цикл
			
		Если ТипЗнч(Отбор) <> Тип("ЗначениеПоляРасшифровкиКомпоновкиДанных") Тогда
			Продолжить;
		КонецЕсли;
		
		Если МассивРасшифровываемыхПолей.Найти(Отбор.Поле) <> Неопределено Тогда
			ДобавитьПараметрыРасшифровки(Отбор.Поле, ОтчетОбъект, РазобранныеДанныеРасшифровки, ПараметрыРасшифровки);
			Прервать;
		ИначеЕсли Отбор.Значение = NULL Тогда
			Прервать;
		Иначе
			Если ЗначениеЗаполнено(Отбор.Значение) Тогда
				ПараметрыРасшифровки.Вставить("Значение",      Отбор.Значение);
				ПараметрыРасшифровки.Вставить("ОткрытьОбъект", Истина);
			КонецЕсли;
			Возврат;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает набор показателей отчета.
// Возвращаемое значение:
//   НаборПоказателей - Массив.
Функция ПолучитьНаборПоказателей() Экспорт
	
	НаборПоказателей = Новый Массив;
	
	НаборПоказателей.Добавить("План");
	НаборПоказателей.Добавить("Факт");
	НаборПоказателей.Добавить("Отклонение");
	НаборПоказателей.Добавить("Остаток");
	НаборПоказателей.Добавить("Превышение");
	НаборПоказателей.Добавить("КодСтатьи");
	
	Возврат НаборПоказателей;
	
КонецФункции

// Адаптирует переданные настройки для данного вида отчетов.
// Перед применением настроек расшифровки может возникнуть необходимость учесть особенности этого вида отчетов.
//
// Параметры:
//  Настройки	 - Структура - Настройки которые нужно адаптировать (см. БухгалтерскиеОтчетыКлиентСервер.НовыйУниверсальныеНастройки).
//
Процедура АдаптироватьНастройки(Настройки) Экспорт
	
	// Удалим автоотступ из условного оформления.
	БухгалтерскиеОтчеты.УдалитьАвтоотступИзУсловногоОформления(Настройки.УсловноеОформление);
	
КонецПроцедуры

