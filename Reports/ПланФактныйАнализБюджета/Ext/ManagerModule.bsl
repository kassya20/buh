#Область СлужебныeПроцедурыИФункции

Процедура ДобавитьПараметрыРасшифровки(ИмяПоля, ОтчетОбъект, РазобранныеДанныеРасшифровки, ПараметрыРасшифровки)
	
	Если ОтчетОбъект.РежимРасшифровки Тогда
		// Если отчет уже в режиме расшифровки - то при открытии суммы или даты открываем первичный документ
		Если ЗначениеЗаполнено(РазобранныеДанныеРасшифровки["Документ"]) Тогда
			ПараметрыРасшифровки.Вставить("Значение",      РазобранныеДанныеРасшифровки["Документ"]);
			ПараметрыРасшифровки.Вставить("ОткрытьОбъект", Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если ИмяПоля <> "План" И ИмяПоля <> "Факт" Тогда
		Возврат;
	КонецЕсли;
	
	Если ИмяПоля = "План" Тогда
		ДобавитьПараметрыРасшифровкиПлана(ИмяПоля, ОтчетОбъект, РазобранныеДанныеРасшифровки, ПараметрыРасшифровки);
	ИначеЕсли ИмяПоля = "Факт" Тогда
		ДобавитьПараметрыРасшифровкиФакта(ИмяПоля, ОтчетОбъект, РазобранныеДанныеРасшифровки, ПараметрыРасшифровки);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПараметрыРасшифровкиПлана(ИмяПоля, ОтчетОбъект, РазобранныеДанныеРасшифровки, ПараметрыРасшифровки)
	
	ПараметрыФормы = Новый Структура;
	БюджетОрганизации = Документы.Бюджет.БюджетНаПериод(ОтчетОбъект.Организация, ОтчетОбъект.НачалоПериода);
	ПоследняяКорректировка = Документы.КорректировкаБюджета.ПоследняяКорректировка(БюджетОрганизации);
	
	ИмяФормы = "Обработка.Бюджет.Форма";
	Если ТипЗнч(ПоследняяКорректировка) = Тип("ДокументСсылка.КорректировкаБюджета") Тогда
		ИмяФормы = "Обработка.КорректировкаБюджета.Форма";
	КонецЕсли;
	
	ПараметрыФормы.Вставить("ДокументСсылка", ПоследняяКорректировка);
	
	ПараметрыПоискаСтроки = Новый Структура;
	ПараметрыПоискаСтроки.Вставить("ПериодДетализации", ОтчетОбъект.КонецПериода);
	Если ЗначениеЗаполнено(РазобранныеДанныеРасшифровки["Период"]) Тогда
		ПараметрыПоискаСтроки.ПериодДетализации = РазобранныеДанныеРасшифровки["Период"];
		Если Не ОтчетОбъект.ПоМесяцам Тогда
			ПараметрыПоискаСтроки.ПериодДетализации = ДобавитьМесяц(ПараметрыПоискаСтроки.ПериодДетализации, 2);
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыПоискаСтроки.Вставить("ТипЗаписи", РазобранныеДанныеРасшифровки["ТипЗаписи"]);
	ПараметрыПоискаСтроки.Вставить("НаправлениеДеятельности", Справочники.НаправленияДеятельности.ПустаяСсылка());
	ПараметрыПоискаСтроки.Вставить("СтатьяДДС", Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
	
	Если РазобранныеДанныеРасшифровки["ТипЗаписи"] = ТипЗаписиДоход() Тогда
		Если ЗначениеЗаполнено(РазобранныеДанныеРасшифровки["СтатьяДохода"]) Тогда
			ПараметрыПоискаСтроки.СтатьяДДС = РазобранныеДанныеРасшифровки["СтатьяДохода"];
		КонецЕсли;
	ИначеЕсли РазобранныеДанныеРасшифровки["ТипЗаписи"] = ТипЗаписиРасход() Тогда
		Если ЗначениеЗаполнено(РазобранныеДанныеРасшифровки["НаправлениеДеятельности"]) Тогда
			ПараметрыПоискаСтроки.НаправлениеДеятельности = РазобранныеДанныеРасшифровки["НаправлениеДеятельности"];
		КонецЕсли;
		
		Если ЗначениеЗаполнено(РазобранныеДанныеРасшифровки["СтатьяРасхода"]) Тогда
			ПараметрыПоискаСтроки.СтатьяДДС = РазобранныеДанныеРасшифровки["СтатьяРасхода"];
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыФормы.Вставить("ПараметрыПоискаСтроки", ПараметрыПоискаСтроки);
	
	ПараметрыРасшифровки.Вставить("ОткрытьОбъект",  Ложь);
	ПараметрыРасшифровки.Вставить("ОткрытьФорму",   Истина);
	ПараметрыРасшифровки.Вставить("Форма",          ИмяФормы);
	ПараметрыРасшифровки.Вставить("ПараметрыФормы", ПараметрыФормы);
	
КонецПроцедуры

Процедура ДобавитьПараметрыРасшифровкиФакта(ИмяПоля, ОтчетОбъект, РазобранныеДанныеРасшифровки, ПараметрыРасшифровки)
	
	УниверсальныеНастройки = БухгалтерскиеОтчетыКлиентСервер.НовыйУниверсальныеНастройки();
	ЗаполнитьЗначенияСвойств(УниверсальныеНастройки, ОтчетОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Организация",            ОтчетОбъект.Организация);
	ПараметрыФормы.Вставить("РежимРасшифровки",       Истина);
	ПараметрыФормы.Вставить("ОткрытьРасшифровку",     Истина);
	
	НачалоПериода = ОтчетОбъект.НачалоПериода;
	КонецПериода = ОтчетОбъект.КонецПериода;
	
	ИмяФормы = "Отчет.ПланФактныйАнализБюджета.ФормаОбъекта";
	
	Если РазобранныеДанныеРасшифровки["ТипЗаписи"] = ТипЗаписиОстатокНаНачало() Тогда
		// Это расшифровка факта по остаткам денежных средств на начало периода
		ИмяФормы = "Отчет.ОстаткиДенежныхСредств.ФормаОбъекта";
		НачалоПериода = НачалоГода(НачалоПериода) - 1;
		
	ИначеЕсли РазобранныеДанныеРасшифровки["ТипЗаписи"] = ТипЗаписиДоход() Тогда
		// Это расшифровка факта по доходам
		ДобавитьОтборВРасшифровку(
			УниверсальныеНастройки.НастройкиКомпоновки,
			РазобранныеДанныеРасшифровки,
			"СтатьяДохода",
			"СтатьяДвиженияДенежныхСредств");
		
	ИначеЕсли РазобранныеДанныеРасшифровки["ТипЗаписи"] = ТипЗаписиРасход() Тогда
		// Это расшифровка факта по расходам
		ДобавитьОтборВРасшифровку(
			УниверсальныеНастройки.НастройкиКомпоновки,
			РазобранныеДанныеРасшифровки,
			"НаправлениеДеятельности",
			"НаправлениеДеятельностиРасхода");
		
		ДобавитьОтборВРасшифровку(
			УниверсальныеНастройки.НастройкиКомпоновки,
			РазобранныеДанныеРасшифровки,
			"СтатьяРасхода",
			"СтатьяДвиженияДенежныхСредств");
			
	ИначеЕсли РазобранныеДанныеРасшифровки["ТипЗаписи"] = ТипЗаписиОстатокНаКонец() Тогда
		// Это расшифровка факта по остаткам денежных средств на конец периода
		ИмяФормы = "Отчет.ОстаткиДенежныхСредств.ФормаОбъекта";
		НачалоПериода = ОтчетОбъект.КонецПериода;
	Иначе
		// Другие расшифровки не поддерживаются
		Возврат;
		
	КонецЕсли;
	
	Если ОтчетОбъект.ГруппироватьПоПериодам 
		И РазобранныеДанныеРасшифровки["Период"] <> Неопределено Тогда
		УстановитьПериодРасшифровки(НачалоПериода, КонецПериода, РазобранныеДанныеРасшифровки["ТипЗаписи"], РазобранныеДанныеРасшифровки["Период"], ОтчетОбъект.ПоМесяцам);
	КонецЕсли;
	
	Если ИмяФормы = "Отчет.ПланФактныйАнализБюджета.ФормаОбъекта" Тогда
		
		ДобавитьОтборВРасшифровку(
			УниверсальныеНастройки.НастройкиКомпоновки,
			РазобранныеДанныеРасшифровки,
			"ТипЗаписи",
			"ТипРасшифровки");
		
		УниверсальныеНастройки.КлючВарианта = "РасшифровкаПоказателей";
		
	КонецЕсли;
	
	УниверсальныеНастройки.Вставить("НачалоПериода", НачалоПериода);
	УниверсальныеНастройки.Вставить("КонецПериода", КонецПериода);
	
	ПараметрыФормы.Вставить("УниверсальныеНастройки",  УниверсальныеНастройки);
	ПараметрыФормы.Вставить("СформироватьПриОткрытии", Истина);
	
	ПараметрыРасшифровки.Вставить("ОткрытьОбъект",  Ложь);
	ПараметрыРасшифровки.Вставить("ОткрытьФорму",   Истина);
	ПараметрыРасшифровки.Вставить("Форма",          ИмяФормы);
	ПараметрыРасшифровки.Вставить("Уникальность",   Новый УникальныйИдентификатор);
	ПараметрыРасшифровки.Вставить("ПараметрыФормы", ПараметрыФормы);
	
КонецПроцедуры

Процедура ДобавитьОтборВРасшифровку(НастройкиКомпоновки, РазобранныеДанныеРасшифровки, ПолеРасшифровки, ПолеКомпоновки)
	
	ДобавлятьОтбор = Истина;
	
	Если ЗначениеЗаполнено(РазобранныеДанныеРасшифровки[ПолеРасшифровки]) Тогда
		ЗначениеРасшифровки = РазобранныеДанныеРасшифровки[ПолеРасшифровки];
		Если ПолеРасшифровки <> "ТипЗаписи" Тогда
			ЭтоГруппа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗначениеРасшифровки, "ЭтоГруппа");
			ВидСравненияРасшифровки = ?(ЭтоГруппа, 
				ВидСравненияКомпоновкиДанных.ВИерархии,
				ВидСравненияКомпоновкиДанных.Равно);
		Иначе
			ВидСравненияРасшифровки = ВидСравненияКомпоновкиДанных.Равно;
		КонецЕсли;
			
	ИначеЕсли РазобранныеДанныеРасшифровки[ПолеРасшифровки] <> Неопределено Тогда
		ЗначениеРасшифровки = Неопределено;
		ВидСравненияРасшифровки = ВидСравненияКомпоновкиДанных.НеЗаполнено;
		
	Иначе
		ДобавлятьОтбор = Ложь;
		
	КонецЕсли;
	
	Если ДобавлятьОтбор Тогда
		БухгалтерскиеОтчетыКлиентСервер.ДобавитьОтбор(
			НастройкиКомпоновки,
			ПолеКомпоновки,
			ЗначениеРасшифровки,
			ВидСравненияРасшифровки);
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьПериодРасшифровки(НачалоПериода, КонецПериода, ТипЗаписи, ПериодРасшифровки, ПоМесяцам)
	
	Если ТипЗаписи = ТипЗаписиОстатокНаНачало() Тогда
		// Это расшифровка факта по остаткам денежных средств на начало периода
		Если ПоМесяцам Тогда
			НачалоПериода = НачалоМесяца(ПериодРасшифровки) - 1;
			КонецПериода = НачалоМесяца(ПериодРасшифровки);
		Иначе
			НачалоПериода = НачалоКвартала(ПериодРасшифровки) - 1;
			КонецПериода = НачалоКвартала(ПериодРасшифровки);
		КонецЕсли;
		
	ИначеЕсли ТипЗаписи = ТипЗаписиДоход() Или ТипЗаписи = ТипЗаписиРасход() Тогда
		// Это расшифровка факта по доходам или расходам
		Если ПоМесяцам Тогда
			НачалоПериода = НачалоМесяца(ПериодРасшифровки);
			КонецПериода = КонецМесяца(ПериодРасшифровки);
		Иначе
			НачалоПериода = НачалоКвартала(ПериодРасшифровки);
			КонецПериода = КонецКвартала(ПериодРасшифровки);
		КонецЕсли;
		
	ИначеЕсли ТипЗаписи = ТипЗаписиОстатокНаКонец() Тогда
		// Это расшифровка факта по остаткам денежных средств на конец периода
		Если ПоМесяцам Тогда
			НачалоПериода = КонецМесяца(ПериодРасшифровки);
			КонецПериода = КонецМесяца(ПериодРасшифровки);
		Иначе
			НачалоПериода = КонецКвартала(ПериодРасшифровки);
			КонецПериода = КонецКвартала(ПериодРасшифровки);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли