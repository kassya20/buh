
#Область ПрограммныйИнтерфейс

Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка) Экспорт
	
	ПараметрыДанных = КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы;
	Организация = ПараметрыДанных.Найти("Организация").Значение;
	ДатаПерехода = ПараметрыДанных.Найти("ДатаПерехода").Значение;
	Группа = ПараметрыДанных.Найти("Группа").Значение;
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураВнешнихНаборовДанных = Новый Структура();
	
	Если Группа = "ПодготовленоКВычету" Тогда 
		Параметры = Новый Структура("Организация, ДатаПерехода", Организация, ДатаПерехода);
		НДСПодготовленыйКВычету = Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.НДСПодготовленыйКВычету(Параметры);
		СтруктураВнешнихНаборовДанных.Вставить("НаборДанных", НДСПодготовленыйКВычету);
	ИначеЕсли Группа = "НеХватаетДанныхДляВычета" Тогда
		НаборДанных = СохраненныйНаборДанных(Организация, ДатаПерехода, "НеХватаетДанныхДляВычета");
		Если НаборДанных = Неопределено Тогда 
			Возврат
		Иначе 
			СтруктураВнешнихНаборовДанных.Вставить("НаборДанных", НаборДанных);
		КонецЕсли;
	ИначеЕсли Группа = "ВычетНедоступен" Тогда
		НаборДанных = СохраненныйНаборДанных(Организация, ДатаПерехода, "Нельзя");
		Если НаборДанных = Неопределено Тогда 
			Возврат
		Иначе 
			СтруктураВнешнихНаборовДанных.Вставить("НаборДанных", НаборДанных);
		КонецЕсли;
	КонецЕсли;
	
	НастройкиКомпоновщика = КомпоновщикНастроек.ПолучитьНастройки();
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиКомпоновщика, ДанныеРасшифровки);
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, СтруктураВнешнихНаборовДанных, ДанныеРасшифровки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
КонецПроцедуры   

#КонецОбласти

#Область СлужебныеПроцедурыИФункции  

Функция СохраненныйНаборДанных(Организация, ДатаПерехода, Группа)
	
	СохраненныеДнные = Обработки.ПодготовкаКВычетуНДСУчтенногоВСтоимости.ПолучитьСохраненныеДнные(Организация,
		ДатаПерехода);
	Если СохраненныеДнные = Неопределено Тогда
		Возврат Неопределено
	КонецЕсли;
	НДСПоОстаткам = СохраненныеДнные.НДСПоОстаткам;
	СтрокиВарианта = НДСПоОстаткам.НайтиСтроки(Новый Структура("Группа", Группа));
		
	ИменаКолонок = "Всего, Дата, ДоговорКонтрагента, Количество, Контрагент, Номенклатура, Партия, Подразделение,
		|СтавкаНДС, Статус, СуммаБезНДС, СуммаНДС, РасчетныйНДС, СчетУчета, СчетФактура";
	
	Возврат НДСПоОстаткам.Скопировать(СтрокиВарианта, ИменаКолонок);
	
КонецФункции

#КонецОбласти