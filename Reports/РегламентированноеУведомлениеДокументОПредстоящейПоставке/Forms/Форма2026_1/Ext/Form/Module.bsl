#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом

КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Объект.ВидУведомления = Перечисления.ВидыУведомленийОСпецрежимахНалогообложения.ДокументОПредстоящейПоставке;
	УведомлениеОСпецрежимахНалогообложения.НачальныеОперацииПриСозданииНаСервере(ЭтотОбъект);
	УведомлениеОСпецрежимахНалогообложения.СформироватьСпискиВыбора(ЭтотОбъект, "СпискиВыбора2026_1");
	
	Если Параметры.Свойство("Ключ") И ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗагрузитьДанные(Параметры.Ключ);
	ИначеЕсли Параметры.Свойство("ЗначениеКопирования") И ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда
		ЗагрузитьДанные(Параметры.ЗначениеКопирования);
	ИначеЕсли Параметры.Свойство("ПредставлениеXML") Тогда 
		Параметры.Свойство("РегистрацияВНалоговомОргане", Объект.РегистрацияВИФНС);
		ЗагрузитьИзXMLНаСервере(Новый Структура("Организация, РегистрацияВНалоговомОргане, ПредставлениеXML", 
								Объект.Организация, Объект.РегистрацияВИФНС, Параметры.ПредставлениеXML));
	Иначе
		Объект.РегистрацияВИФНС = Документы.УведомлениеОСпецрежимахНалогообложения.РегистрацияВФНСОрганизации(Объект.Организация);
		СформироватьДеревоСтраниц();
		УведомлениеОСпецрежимахНалогообложения.СформироватьСтруктуруДанныхУведомленияНовогоОбразца(ЭтотОбъект);
		ЗаполнитьНачальныеДанные();
	КонецЕсли;
	
	Заголовок = УведомлениеОСпецрежимахНалогообложения.ДополнитьЗаголовокУведомления(Заголовок, Объект.Организация);
	Если НЕ ОнлайнСервисыРегламентированнойОтчетностиВызовСервера.СобытиеНаступило("Отпр.ДОПП", '20260401') Тогда
		Элементы.ОтправитьВКонтролирующийОрган.Видимость = Ложь;
	КонецЕсли;
	УведомлениеОСпецрежимахНалогообложения.СпрятатьКнопкиВыгрузкиОтправкиУНеактуальныхФорм(ЭтотОбъект);
	ЭлектронныйДокументооборотСКонтролирующимиОрганами.ИнициализироватьВыводСтатусовИВажныхСообщений_85(ЭтотОбъект);
	ИдДляСвор = УведомлениеОСпецрежимахНалогообложенияСлужебный.ПолучитьИдентификаторыДляСворачивания(ЭтотОбъект);
	ЭтотОбъект["СворачиваемыеЭлементы"] = ПоместитьВоВременноеХранилище(ИдДляСвор);
	
	Разложение = СтрРазделить(ИмяФормы, ".");
	ПараметрыОтчета = Новый Структура("Организация", Объект.Организация);
	ПоказателиОтчета = РегламентированнаяОтчетностьПереопределяемый.ПолучитьСведенияОПоказателяхОтчета(
		Разложение[1], Разложение[3], ПараметрыОтчета);
		
	Если ПоказателиОтчета = Неопределено Тогда
		Элементы.ФормаЗаполнить.Видимость = Ложь;
	ИначеЕсли ТипЗнч(ПоказателиОтчета) = Тип("Структура") Тогда
		ИмяФормыПодбораОснований = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПоказателиОтчета, "ИмяФормыПодбораОснований", "");
		Элементы.ФормаЗаполнить.Видимость = (ПоказателиОтчета.Количество() > 0);
	КонецЕсли;
	
	ДоступнаПодсистемаВалюты = ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.Валюты");
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		ПриЗакрытииНаСервере();
	КонецЕсли;
	Оповестить(РегламентированнаяОтчетностьКлиент.ИмяСобытияЗаписьУведомления(),,Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	РегламентированнаяОтчетностьКлиент.ПередЗакрытиемРегламентированногоОтчета(ЭтотОбъект, Отказ, СтандартнаяОбработка, ЗавершениеРаботы, ТекстПредупреждения);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УведомлениеОСпецрежимахНалогообложенияКлиент.ПриОткрытии(ЭтотОбъект, Отказ);
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Оповестить(РегламентированнаяОтчетностьКлиент.ИмяСобытияЗаписьУведомления(), ПараметрыЗаписи, Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "УведомлениеОСпецрежимахНалогообложения_НавигацияПоОшибкам" Тогда 
		УведомлениеОСпецрежимахНалогообложенияКлиент.ОбработкаОповещенияНавигацииПоОшибкам(ЭтотОбъект, Параметр, Источник);
	КонецЕсли;
	Если РегламентированнаяОтчетностьКлиент.ЭтоСобытиеЗавершениеОтправки(ИмяСобытия) Тогда
		ВывестиСтатусыИВыжныеСообщенияНаФормуНаСервере();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ПредставлениеУведомленияПриИзмененииСодержимогоОбласти(Элемент, Область)
	Если Область.Имя = "НДССт" Или Область.Имя = "АкцТвСт" Или Область.Имя = "АкцАдвСт"
		Или Область.Имя = "НДСБаза" Или Область.Имя = "АкцизТвБаза" Или Область.Имя = "АкцизАдвБаза" Тогда 
		
		РасчетСуммНалогов();
	ИначеЕсли Область.Имя = "КолТов" Тогда 
		КолТовПриИзменении(Область);
	ИначеЕсли Область.Имя = "КурсВалют" Тогда 
		КурсВалютПриИзменении(Область);
	Иначе
		УведомлениеОСпецрежимахНалогообложенияКлиент.ПриИзмененииСодержимогоОбласти(ЭтотОбъект, Область, Истина);
		Если Область.Имя = "ДАТА_ПОДПИСИ" Тогда
			Объект.ДатаПодписи = Область.Значение;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеУведомленияВыбор(Элемент, Область, СтандартнаяОбработка)
	Если Область.Имя = "ПодборПервичногоДокумента" Тогда 
		ПодборСданногоПервичногоДокумента();
	ИначеЕсли Область.Имя = "Пересчитать" Тогда 
		ПересчетСуммыОбеспечительногоПлатежа();
	ИначеЕсли Область.Имя = "МаркируемыйТовар" Тогда 
		Область.Значение = Не Область.Значение;
		СтандартнаяОбработка = Ложь;
		УведомлениеОСпецрежимахНалогообложенияКлиент.ПриИзмененииСодержимогоОбласти(ЭтотОбъект, Область, Истина);
	Иначе
		Если УведомлениеОСпецрежимахНалогообложенияКлиент.ТиповойВыбор(ЭтотОбъект, Область, СтандартнаяОбработка) Или ЭтотОбъект["РучнойВвод"] Тогда 
			Возврат;
		КонецЕсли;
		
		ОО = Новый ОписаниеОповещения("ПредставлениеУведомленияВыборЗавершение", ЭтотОбъект);
		УведомлениеОСпецрежимахНалогообложенияКлиент.ПредставлениеУведомленияВыбор(
			ЭтотОбъект, Область, СтандартнаяОбработка, Истина, Истина, 
			?(ДоступнаПодсистемаВалюты И Область.Имя = "КодВалют", ОО, Неопределено));
		
		Если СтандартнаяОбработка Тогда 
			Если Область.Имя = "КодНО" Тогда 
				СтандартнаяОбработка = Ложь;
				РегламентированнаяОтчетностьКлиент.ОткрытьФормуВыбораРегистрацииВИФНС(ЭтотОбъект, Область.Имя);
			ИначеЕсли Область.Имя = "НДССт" И Не ЭтотОбъект["РучнойВвод"] Тогда
				СтандартнаяОбработка = Ложь;
				ВыборСтавкиНДС();
			ИначеЕсли СтандартнаяОбработка И ЭтоОбластьОКСМ(Область) Тогда
				УведомлениеОСпецрежимахНалогообложенияКлиент.ВыборКодаСтраныИзСправочника(ЭтотОбъект, Область, СтандартнаяОбработка);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ГиперссылкаПротоколНажатие(Элемент)
	ЭлектронныйДокументооборотСКонтролирующимиОрганамиКлиент.ОткрытьПротоколИзПанелиОтправки(ЭтотОбъект, "ФНС");
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыОтправкиНажатие(Элемент)
	ЭлектронныйДокументооборотСКонтролирующимиОрганамиКлиент.ОткрытьСостояниеОтправкиИзПанелиОтправки(ЭтотОбъект, "ФНС");
КонецПроцедуры

&НаКлиенте
Процедура КритическиеОшибкиОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ЭлектронныйДокументооборотСКонтролирующимиОрганамиКлиент.ОткрытьКритическиеОшибкиИзПанелиОтправки(ЭтотОбъект, "ФНС");
КонецПроцедуры

&НаКлиенте
Процедура ГиперссылкаНаименованиеЭтапаНажатие(Элемент)
	
	ПараметрыИзменения = Новый Структура;
	ПараметрыИзменения.Вставить("Форма", ЭтотОбъект);
	ПараметрыИзменения.Вставить("Организация", Объект.Организация);
	ПараметрыИзменения.Вставить("КонтролирующийОрган",
		ПредопределенноеЗначение("Перечисление.ТипыКонтролирующихОрганов.ФНС"));
	ПараметрыИзменения.Вставить("ТекстВопроса", НСтр("ru='Вы уверены, что уведомление уже сдано?'"));
	
	РегламентированнаяОтчетностьКлиент.ИзменитьСтатусОтправки(ПараметрыИзменения);
	
КонецПроцедуры

&НаКлиенте
Процедура КомментарийПриИзменении(Элемент)
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеУведомленияПриАктивизацииОбласти(Элемент)
	Если ПредставлениеУведомления.ТекущаяОбласть <> Неопределено
		И ПредставлениеУведомления.ТекущаяОбласть.ТипОбласти = ТипОбластиЯчеекТабличногоДокумента.Прямоугольник Тогда 
		Элементы.ПредставлениеУведомленияКонтекстноеМенюОчиститьОКСМ.Доступность = ЭтоОбластьОКСМ(ПредставлениеУведомления.ТекущаяОбласть);
	Иначе
		Элементы.ПредставлениеУведомленияКонтекстноеМенюОчиститьОКСМ.Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоСтраниц

&НаКлиенте
Процедура ДеревоСтраницПриАктивизацииСтроки(Элемент)
	Если УведомлениеОСпецрежимахНалогообложенияКлиент.НеобходимоФормированиеТабличногоДокумента(ЭтотОбъект, Элемент, ЭтотОбъект["УИДПереключение"]) Тогда
		ОтключитьОбработчикОжидания("ДеревоСтраницПриАктивизацииСтрокиЗавершение");
		ПодключитьОбработчикОжидания("ДеревоСтраницПриАктивизацииСтрокиЗавершение", 0.1, Истина);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Заполнить(Команда)
	Если ЗначениеЗаполнено(ИмяФормыПодбораОснований) Тогда
		ОО = Новый ОписаниеОповещения("ЗаполнитьДаннымиДокументаПослеВыбора", ЭтотОбъект);
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Организация", Объект.Организация);
		ПараметрыФормы.Вставить("Основание", Объект.Основание);
		ПараметрыФормы.Вставить("ТолькоПросмотр", Истина);
		ОткрытьФорму(ИмяФормыПодбораОснований, ПараметрыФормы, ЭтотОбъект, , , , ОО, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		РезультатВыполнения = ЗаполнитьАвтоНаСервере();
		Если НЕ РезультатВыполнения.ЗаданиеВыполнено Тогда
			ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗаполнитьАвтоЗавершениеПослеЗаполнения", ЭтотОбъект);
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
			ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Выполняется заполнение по данным информационной базы'");
			ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатВыполнения, ОповещениеОЗавершении, ПараметрыОжидания);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Сохранить(Команда)
	СохранитьДанные();
	Оповестить(РегламентированнаяОтчетностьКлиент.ИмяСобытияЗаписьУведомления(),,Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура СформироватьXML(Команда)
	
	ВыгружаемыеДанные = СформироватьXMLНаСервере(УникальныйИдентификатор);
	Если ВыгружаемыеДанные <> Неопределено Тогда 
		РегламентированнаяОтчетностьКлиент.ВыгрузитьФайлы(ВыгружаемыеДанные);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьВКонтролирующийОрган(Команда)
	
	РегламентированнаяОтчетностьКлиент.ПриНажатииНаКнопкуОтправкиВКонтролирующийОрган(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьВИнтернете(Команда)
	
	РегламентированнаяОтчетностьКлиент.ПроверитьВИнтернете(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтправку(Команда)
	ЭлектронныйДокументооборотСКонтролирующимиОрганамиКлиент.ОбновитьОтправкуИзПанелиОтправки(ЭтотОбъект, "ФНС");
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьНеотправленноеИзвещение(Команда)
	ЭлектронныйДокументооборотСКонтролирующимиОрганамиКлиент.ОтправитьНеотправленноеИзвещениеИзПанелиОтправки(ЭтотОбъект, "ФНС");
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьВыгрузку(Команда)
	УведомлениеОСпецрежимахНалогообложенияКлиент.ПроверитьВыгрузку(ЭтотОбъект, ПроверитьВыгрузкуНаСервере());
КонецПроцедуры

&НаКлиенте
Процедура РучнойВвод(Команда)
	УведомлениеОСпецрежимахНалогообложенияКлиент.ОбработкаРучнойВвод(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура РазрешитьВыгружатьСОшибками(Команда)
	УведомлениеОСпецрежимахНалогообложенияКлиент.ОбработкаРазрешитьВыгружатьСОшибками(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОКСМ(Команда)
	ПредставлениеУведомления.ТекущаяОбласть.Значение = Неопределено;
	УведомлениеОСпецрежимахНалогообложенияКлиент.ПриИзмененииСодержимогоОбласти(ЭтотОбъект, ПредставлениеУведомления.ТекущаяОбласть, Истина);
КонецПроцедуры

&НаКлиенте
Процедура КопироватьСПодчиненными(Команда)
	УведомлениеОСпецрежимахНалогообложенияКлиент.ОбработкаКопироватьСПодчиненными(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ПечатьБРО(Команда)
	ПечатьБРОНаСервере();
	РегламентированнаяОтчетностьКлиент.ОткрытьФормуПредварительногоПросмотра(
		ЭтотОбъект, "Открыть", Ложь, ЭтотОбъект["СтруктураРеквизитовУведомления"].СписокПечатаемыхЛистов);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ЗаполнитьДаннымиДокументаПослеВыбора(Результат, ДополнительныеПараметры) Экспорт 
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РезультатВыполнения = ЗаполнитьАвтоНаСервере(Результат);
	Если НЕ РезультатВыполнения.ЗаданиеВыполнено Тогда
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗаполнитьАвтоЗавершениеПослеЗаполнения", ЭтотОбъект);
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Выполняется заполнение по данным информационной базы'");
		ДлительныеОперацииКлиент.ОжидатьЗавершение(РезультатВыполнения, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПересчетСуммыОбеспечительногоПлатежа()
	СумОбПлат = 0;
	
	Для Каждого Элт Из ЭтотОбъект["ДанныеМногостраничныхРазделов"].Договор Цикл 
		Договор = Элт.Значение;
		ПрСпецТов = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Договор, "ПрСпецТов");
		Если ПрСпецТов = "1" Тогда 
			Для Каждого Элт1 Из ЭтотОбъект["ДанныеМногостраничныхРазделов"].Спецификация Цикл 
				Если Элт1.Значение.УИДРодителя <> Договор.УИД Тогда 
					Продолжить;
				КонецЕсли;
				
				Для Каждого Элт2 Из ЭтотОбъект["ДанныеМногостраничныхРазделов"].ТоварСпецификация Цикл 
					Товар = Элт2.Значение;
					Если Товар.УИДРодителя <> Элт1.Значение.УИД Тогда 
						Продолжить;
					КонецЕсли;
					
					Коэффициент = ?(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "МаркируемыйТовар", Ложь), 0, 1);
					СумОбПлат = СумОбПлат + ЭтотОбъект["ОТЧ"].ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "СумНДС"))
						+ Коэффициент * ЭтотОбъект["ОТЧ"].ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "СумАкцизТв"))
						+ Коэффициент * ЭтотОбъект["ОТЧ"].ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "СумАкцизАдв"));
				КонецЦикла;
			КонецЦикла;
		ИначеЕсли ПрСпецТов = "2" Тогда 
			Для Каждого Элт2 Из ЭтотОбъект["ДанныеМногостраничныхРазделов"].ТоварДоговор Цикл 
				Товар = Элт2.Значение;
				Если Товар.УИДРодителя <> Договор.УИД Тогда 
					Продолжить;
				КонецЕсли;
				
				Коэффициент = ?(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "МаркируемыйТовар", Ложь), 0, 1);
				СумОбПлат = СумОбПлат + ЭтотОбъект["ОТЧ"].ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "СумНДС"))
					+ Коэффициент * ЭтотОбъект["ОТЧ"].ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "СумАкцизТв"))
					+ Коэффициент * ЭтотОбъект["ОТЧ"].ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "СумАкцизАдв"));
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Область = ПредставлениеУведомления.Области.Найти("СумОбПлат");
	Область.Значение = СумОбПлат;
	УведомлениеОСпецрежимахНалогообложенияКлиент.ПриИзмененииСодержимогоОбласти(ЭтотОбъект, Область);
КонецПроцедуры

&НаКлиенте
Процедура ПодборСданногоПервичногоДокумента()
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("ЭтоРежимВыбора", Истина);
	ДополнительныеПараметры.Вставить("Организация", Объект.Организация);
	ДополнительныеПараметры.Вставить("ОтборОрган", 
		ПредопределенноеЗначение("Перечисление.ТипыКонтролирующихОрганов.ФНС"));
	ДополнительныеПараметры.Вставить("Раздел", 
		ПредопределенноеЗначение("Перечисление.СтраницыЖурналаОтчетность.Уведомления"));
	ДополнительныеПараметры.Вставить("ВидУведомления", 
		ПредопределенноеЗначение("Перечисление.ВидыУведомленийОСпецрежимахНалогообложения.ДокументОПредстоящейПоставке"));
		
	ОО = Новый ОписаниеОповещения("ПодборСданногоПервичногоДокументаЗавершение", ЭтотОбъект, Неопределено);
	ОткрытьФорму("ОбщаяФорма.РегламентированнаяОтчетность", 
		ДополнительныеПараметры, , Новый УникальныйИдентификатор, , , ОО, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ПодборСданногоПервичногоДокументаЗавершение(ВыбранныйОбъект, Область) Экспорт
	Если ТипЗнч(ВыбранныйОбъект) = Тип("ДокументСсылка.УведомлениеОСпецрежимахНалогообложения") Тогда
		ДанныеПервичногоУведомления = РеквизитыСданногоУведомления(ВыбранныйОбъект);
		Если ТипЗнч(ДанныеПервичногоУведомления) = Тип("Структура") Тогда 
			ЗаполнитьЗначенияСвойств(ЭтотОбъект["ДанныеУведомления"].Титульная, ДанныеПервичногоУведомления);
			ПредставлениеУведомления.Области["НомерДОПП"].Значение = ДанныеПервичногоУведомления.НомерДОПП;
			ПредставлениеУведомления.Области["ДатаРегистр"].Значение = ДанныеПервичногоУведомления.ДатаРегистр;
			Модифицированность = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция РеквизитыСданногоУведомления(ВыбранныйОбъект)
	СтатусИСведенияКвитанций = Отчеты[СтрРазделить(ИмяФормы, ".")[1]].СтатусИСведенияКвитанций(ВыбранныйОбъект);
	СтатусИСведенияКвитанций.Вставить("ДатаРегистр", СтатусИСведенияКвитанций.ДатаРегистрацииДокумента);
	Возврат СтатусИСведенияКвитанций;
КонецФункции

&НаСервере
Функция ЗаполнитьАвтоНаСервере(МассивДокументов = Неопределено)
	ОснованиеЗаполнения = ?(ТипЗнч(МассивДокументов) = Тип("Массив") И МассивДокументов.Количество() = 1,
		МассивДокументов[0], Неопределено);
	
	ПараметрыОтчета = Новый Структура();
	ПараметрыОтчета.Вставить("Организация", Объект.Организация);
	ПараметрыОтчета.Вставить("УникальныйИдентификаторФормы", УникальныйИдентификатор);
	ПараметрыОтчета.Вставить("ВидУведомления", Объект.ВидУведомления);
	ПараметрыОтчета.Вставить("РегистрацияВИФНС", Объект.РегистрацияВИФНС);
	ПараметрыОтчета.Вставить("ДатаПодписи", Объект.ДатаПодписи);
	ПараметрыОтчета.Вставить("МассивДокументов" , МассивДокументов);
	
	Контейнер = Новый Структура;
	Контейнер.Вставить("РегистрацияВИФНС", Объект.РегистрацияВИФНС);
	Контейнер.Вставить("ДатаПодписи", Объект.ДатаПодписи);
	Контейнер.Вставить("Титульная", ЭтотОбъект["ДанныеУведомления"].Титульная);
	Для Каждого КЗ Из ЭтотОбъект["ДанныеМногостраничныхРазделов"] Цикл 
		ДанныеСтраницы = ОбщегоНазначения.СкопироватьРекурсивно(КЗ.Значение[0].Значение);
		ТЗСтр = Новый ТаблицаЗначений;
		Для Каждого Кол Из ДанныеСтраницы Цикл 
			ТЗСтр.Колонки.Добавить(Кол.Ключ)
		КонецЦикла;
		Контейнер.Вставить(КЗ.Ключ, ТЗСтр);
	КонецЦикла;
	
	Для Каждого КЗ Из ЭтотОбъект["ДанныеДопСтрок"] Цикл 
		Таблица = ПолучитьИзВременногоХранилища(КЗ.Значение);
		Таблица.Очистить();
		Контейнер.Вставить(КЗ.Ключ, Таблица);
	КонецЦикла;
	
	Разложение = СтрРазделить(ИмяФормы, ".");
	ПараметрыВыполненияВФоне = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполненияВФоне.ЗапуститьВФоне = Истина;
	РезультатВыполнения = ДлительныеОперации.ВыполнитьВФоне("РегламентированнаяОтчетность.ЗаполнитьОтчетВФоне_Уведомления",
		Новый Структура("ИДОтчета, ИДРедакцииОтчета, ПараметрыОтчета, Контейнер", Разложение[1], Разложение[3], ПараметрыОтчета, Контейнер),
		ПараметрыВыполненияВФоне);
	
	РезультатВыполнения.Вставить("ЗаданиеВыполнено", НРег(РезультатВыполнения.Статус) = "выполнено");
	ЭтотОбъект["АдресХранилища"] = РезультатВыполнения.АдресРезультата;
	
	Если РезультатВыполнения.ЗаданиеВыполнено Тогда
		ЗагрузитьПодготовленныеДанные();
	КонецЕсли;
	
	Возврат РезультатВыполнения;
КонецФункции

&НаКлиенте
Процедура ЗаполнитьАвтоЗавершениеПослеЗаполнения(РезультатЗагрузки, ДополнительныеПараметры) Экспорт
	Доступность = Истина;
	
	Если РезультатЗагрузки = Неопределено Или РезультатЗагрузки.Статус <> "Выполнено" Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не удалось выполнить автозаполнение...'"));
		Возврат;
	КонецЕсли;

	ЗагрузитьПодготовленныеДанные();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьПодготовленныеДанные()
	СтруктураДанных = ПолучитьИзВременногоХранилища(ЭтотОбъект["АдресХранилища"]);
	
	СформироватьДеревоСтраниц();
	УведомлениеОСпецрежимахНалогообложения.СформироватьСтруктуруДанныхУведомленияНовогоОбразца(ЭтотОбъект);
	
	СтруктураДанных.Контейнер.Свойство("РегистрацияВИФНС", Объект.РегистрацияВИФНС);
	СтруктураДанных.Контейнер.Свойство("ДатаПодписи", Объект.ДатаПодписи);
	ЭтотОбъект["ДанныеУведомления"].Титульная["КодНО"] = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.РегистрацияВИФНС, "Код");
	ЭтотОбъект["ДанныеУведомления"].Титульная["ДАТА_ПОДПИСИ"] = Объект.ДатаПодписи;
	ЗаполнитьЗначенияСвойств(ЭтотОбъект["ДанныеУведомления"].Титульная, СтруктураДанных.Контейнер.Титульная);
	
	Если СтруктураДанных.Контейнер.Договор.Количество() = 0 Тогда
		ЭтотОбъект["ТекущееИДНаименования"] = "Титульная";
		ПоказатьТекущуюСтраницу("Титульная_2026", Новый СписокЗначений, Неопределено);
		Модифицированность = Истина;
		Доступность = Истина;
		Возврат;
	КонецЕсли;
	
	ИсточникДоговор = ДеревоСтраниц.ПолучитьЭлементы()[1].ПолучитьЭлементы()[0];
	Договоры = СтруктураДанных.Контейнер.Договор;
	ТоварДоговор = СтруктураДанных.Контейнер.ТоварДоговор;
	ОбъектДоговор = ЭтотОбъект["ДанныеМногостраничныхРазделов"].Договор;
	ОбъектСпецификация = ЭтотОбъект["ДанныеМногостраничныхРазделов"].Спецификация;
	ОбъектТоварДоговор = ЭтотОбъект["ДанныеМногостраничныхРазделов"].ТоварДоговор;
	ОбъектТоварСпецификация = ЭтотОбъект["ДанныеМногостраничныхРазделов"].ТоварСпецификация;
	Для Каждого Стр1 Из Договоры Цикл 
		ПриемникДоговор = УведомлениеОСпецрежимахНалогообложения.СкопироватьСтрокуВДереве(ЭтотОбъект, ИсточникДоговор);
		ПриемникДоговор.УИД = Стр1.УИД;
		ПриемникДоговор.Наименование = "Стр. " + Формат((1 + Договоры.Индекс(Стр1)), "ЧГ=");
		ОбъектДоговор[ОбъектДоговор.Количество() - 1].Значение = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр1);
		
		ИсточникТовар = ПриемникДоговор.ПолучитьЭлементы()[0].ПолучитьЭлементы()[0];
		Товары = СтруктураДанных.Контейнер.ТоварДоговор.НайтиСтроки(Новый Структура("УИДРодителя", Стр1.УИД));
		Если Товары.Количество() > 0 Тогда 
			Для Инд1 = 1 По Товары.Количество() Цикл 
				ПриемникТовар = УведомлениеОСпецрежимахНалогообложения.СкопироватьСтрокуВДереве(ЭтотОбъект, ИсточникТовар);
				ПриемникТовар.УИД = Товары[Инд1 - 1].УИД;
				ПриемникТовар.Наименование = "Стр. " + Формат(Инд1, "ЧГ=");
				ОбъектТоварДоговор[ОбъектТоварДоговор.Количество() - 1].Значение = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Товары[Инд1 - 1]);
			КонецЦикла;
			ЭтотОбъект["УИДТекущаяСтраница"] = ИсточникТовар.УИД;
			УведомлениеОСпецрежимахНалогообложения.УдалитьСтраницуНаСервере(ЭтотОбъект);
		КонецЕсли;
		
		ИсточникСпецификация = ПриемникДоговор.ПолучитьЭлементы()[1].ПолучитьЭлементы()[0];
		Спецификации = СтруктураДанных.Контейнер.Спецификация.НайтиСтроки(Новый Структура("УИДРодителя", Стр1.УИД));
		Если Спецификации.Количество() > 0 Тогда 
			Для Инд0 = 1 По Спецификации.Количество() Цикл 
				ПриемникСпецификация = УведомлениеОСпецрежимахНалогообложения.СкопироватьСтрокуВДереве(ЭтотОбъект, ИсточникСпецификация);
				ПриемникСпецификация.УИД = Спецификации[Инд0 - 1].УИД;
				ПриемникСпецификация.Наименование = "Стр. " + Формат(Инд0, "ЧГ=");
				ОбъектСпецификация[ОбъектСпецификация.Количество() - 1].Значение = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Спецификации[Инд0 - 1]);
				
				ИсточникТовар = ПриемникСпецификация.ПолучитьЭлементы()[0].ПолучитьЭлементы()[0];
				Товары = СтруктураДанных.Контейнер.ТоварСпецификация.НайтиСтроки(Новый Структура("УИДРодителя", ПриемникСпецификация.УИД));
				Если Товары.Количество() > 0 Тогда 
					Для Инд1 = 1 По Товары.Количество() Цикл 
						ПриемникТовар = УведомлениеОСпецрежимахНалогообложения.СкопироватьСтрокуВДереве(ЭтотОбъект, ИсточникТовар);
						ПриемникТовар.УИД = Товары[Инд1 - 1].УИД;
						ПриемникТовар.Наименование = "Стр. " + Формат(Инд1, "ЧГ=");
						ОбъектТоварСпецификация[ОбъектТоварСпецификация.Количество() - 1].Значение = 
							ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Товары[Инд1 - 1]);
					КонецЦикла;
					ЭтотОбъект["УИДТекущаяСтраница"] = ИсточникТовар.УИД;
					УведомлениеОСпецрежимахНалогообложения.УдалитьСтраницуНаСервере(ЭтотОбъект);
				КонецЕсли;
			КонецЦикла;
			ЭтотОбъект["УИДТекущаяСтраница"] = ИсточникСпецификация.УИД;
			УведомлениеОСпецрежимахНалогообложения.УдалитьСтраницуНаСервере(ЭтотОбъект);
		КонецЕсли;
	КонецЦикла;
	ЭтотОбъект["УИДТекущаяСтраница"] = ИсточникДоговор.УИД;
	УведомлениеОСпецрежимахНалогообложения.УдалитьСтраницуНаСервере(ЭтотОбъект);
	
	ЭтотОбъект["ДанныеДопСтрок"].МнгСтр1 = ПоместитьВоВременноеХранилище(СтруктураДанных.Контейнер.МнгСтр1, Новый УникальныйИдентификатор);
	ЭтотОбъект["ТекущееИДНаименования"] = "Титульная";
	ПоказатьТекущуюСтраницу("Титульная_2026", Новый СписокЗначений, Неопределено);
	
	Объект.Основание = ОснованиеЗаполнения;
	Модифицированность = Истина;
	Доступность = Истина;
КонецПроцедуры

&НаКлиенте
Асинх Процедура КурсВалютПриИзменении(Область)
	ДанныеСтраницы = ТекущаяСтраницаДанными();
	ОТЧ = ЭтотОбъект["ОТЧ"];
	СтарыйКурсВалют = ОТЧ.ПривестиЗначение(ДанныеСтраницы["КурсВалют"]);
	
	Если ЗначениеЗаполнено(СтарыйКурсВалют) И
		Ждать ВопросАсинх("Выполнить пересчет налогов пропорционально курсу?", РежимДиалогаВопрос.ДаНет)
		= КодВозвратаДиалога.Да Тогда 
		
		КоэффициентПересчета = Область.Значение / СтарыйКурсВалют;
		ДанныеСтраницы["КурсВалют"] = Область.Значение;
		Поля = СтрРазделить("СтоимТов,НДСБаза,АкцизАдвБаза", ",");
		Для Каждого Элт2 Из ЭтотОбъект["ДанныеМногостраничныхРазделов"].ТоварДоговор Цикл
			Если Элт2.Значение.УИДРодителя = ДанныеСтраницы.УИД Тогда 
				ПропорциональныйПересчетТоварПоКурсу(Элт2.Значение, КоэффициентПересчета, Поля, ОТЧ);
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого Элт1 Из ЭтотОбъект["ДанныеМногостраничныхРазделов"].Спецификация Цикл
			Если Элт1.Значение.УИДРодителя <> ДанныеСтраницы.УИД Тогда
				Продолжить;
			КонецЕсли;
			Для Каждого Элт2 Из ЭтотОбъект["ДанныеМногостраничныхРазделов"].ТоварСпецификация Цикл
				Если Элт2.Значение.УИДРодителя = Элт1.Значение.УИД Тогда 
					ПропорциональныйПересчетТоварПоКурсу(Элт2.Значение, КоэффициентПересчета, Поля, ОТЧ);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	Иначе
		УведомлениеОСпецрежимахНалогообложенияКлиент.ПриИзмененииСодержимогоОбласти(ЭтотОбъект, Область, Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПропорциональныйПересчетТоварПоКурсу(Товар, КоэффициентПересчета, Поля, ОТЧ)
	Для Каждого Обл Из Поля Цикл 
		Товар[Обл] = КоэффициентПересчета * ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, Обл, 0);
	КонецЦикла;
	
	Товар["СумНДС"] = Товар["НДСБаза"] 
		* ОТЧ.ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "НДССт", 0)) / 100;
	Товар["СумАкцизАдв"] = Товар["АкцизАдвБаза"] 
		* ОТЧ.ПривестиЗначение(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Товар, "АкцАдвСт", 0)) / 100;
КонецПроцедуры

&НаКлиенте
Асинх Процедура КолТовПриИзменении(Область)
	ДанныеСтраницы = ТекущаяСтраницаДанными();
	ОТЧ = ЭтотОбъект["ОТЧ"];
	СтароеКоличество = ОТЧ.ПривестиЗначение(ДанныеСтраницы["КолТов"]);
	ЕстьДанныеДляПересчета = ЗначениеЗаполнено(СтароеКоличество) 
		И (ЗначениеЗаполнено(ДанныеСтраницы["СтоимТов"]) Или ЗначениеЗаполнено(ДанныеСтраницы["НДСБаза"]) 
			Или ЗначениеЗаполнено(ДанныеСтраницы["АкцизТвБаза"]) Или ЗначениеЗаполнено(ДанныеСтраницы["АкцизАдвБаза"]));
	
	Если ЕстьДанныеДляПересчета И
		Ждать ВопросАсинх("Выполнить пересчет стоимости пропорционально количеству?", РежимДиалогаВопрос.ДаНет)
		= КодВозвратаДиалога.Да Тогда 
		
		КоэффициентПересчета = Область.Значение / СтароеКоличество;
		Для Каждого Поле Из СтрРазделить("СтоимТов,НДСБаза,АкцизТвБаза,АкцизАдвБаза", ",") Цикл 
			ДанныеСтраницы[Поле] = ОТЧ.ПривестиЗначение(ДанныеСтраницы[Поле]) * КоэффициентПересчета;
			ПредставлениеУведомления.Области[Поле].Значение = ДанныеСтраницы[Поле];
		КонецЦикла;
		ДанныеСтраницы.Вставить("КолТов", Область.Значение);
		РасчетСуммНалогов();
	Иначе
		УведомлениеОСпецрежимахНалогообложенияКлиент.ПриИзмененииСодержимогоОбласти(ЭтотОбъект, Область, Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция ТекущаяСтраницаДанными()
	Для Каждого Элт Из ЭтотОбъект["ДанныеМногостраничныхРазделов"][ЭтотОбъект["ТекущееИДНаименования"]] Цикл 
		Если Элт.Значение.УИД = ЭтотОбъект["УИДТекущаяСтраница"] Тогда 
			Возврат Элт.Значение;
		КонецЕсли;
	КонецЦикла;
КонецФункции

&НаКлиенте
Процедура РасчетСуммНалогов()
	ДанныеСтраницы = ТекущаяСтраницаДанными();
	ОТЧ = ЭтотОбъект["ОТЧ"];
	
	ДанныеСтраницы.Вставить("СумНДС", ОТЧ.ПривестиЗначение(ПредставлениеУведомления.Области["НДССт"].Значение) 
		* ОТЧ.ПривестиЗначение(ПредставлениеУведомления.Области["НДСБаза"].Значение) / 100);
	ДанныеСтраницы.Вставить("СумАкцизТв", ОТЧ.ПривестиЗначение(ПредставлениеУведомления.Области["АкцТвСт"].Значение) 
		* ОТЧ.ПривестиЗначение(ПредставлениеУведомления.Области["АкцизТвБаза"].Значение));
	ДанныеСтраницы.Вставить("СумАкцизАдв", ОТЧ.ПривестиЗначение(ПредставлениеУведомления.Области["АкцАдвСт"].Значение) 
		* ОТЧ.ПривестиЗначение(ПредставлениеУведомления.Области["АкцизАдвБаза"].Значение) / 100);
		
	Для Каждого Элт Из СтрРазделить("НДССт,НДСБаза,АкцТвСт,АкцизТвБаза,АкцАдвСт,АкцизАдвБаза", ",") Цикл 
		ДанныеСтраницы.Вставить(Элт, ПредставлениеУведомления.Области[Элт].Значение);
	КонецЦикла;
		
	ПредставлениеУведомления.Области["СумНДС"].Значение = ДанныеСтраницы["СумНДС"];
	ПредставлениеУведомления.Области["СумАкцизТв"].Значение = ДанныеСтраницы["СумАкцизТв"];
	ПредставлениеУведомления.Области["СумАкцизАдв"].Значение = ДанныеСтраницы["СумАкцизАдв"];
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Асинх Процедура ВыборСтавкиНДС()
	СписокВыбораПризнак = Новый СписокЗначений;
	СписокВыбораПризнак.Добавить("", "пустое значение");
	СписокВыбораПризнак.Добавить("0", "0%");
	СписокВыбораПризнак.Добавить("10", "10%");
	СписокВыбораПризнак.Добавить("22", "22%");
	Результат = Ждать ВыбратьИзСпискаАсинх(СписокВыбораПризнак);
	Если ТипЗнч(Результат) = Тип("ЭлементСпискаЗначений") Тогда 
		Область = ПредставлениеУведомления.Области["НДССт"];
		Область.Значение = Результат.Значение;
		УведомлениеОСпецрежимахНалогообложенияКлиент.ПриИзмененииСодержимогоОбласти(ЭтотОбъект, Область, Истина);
		РасчетСуммНалогов();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНачальныеДанные() Экспорт
	ДанныеУведомленияТитульный = ЭтотОбъект["ДанныеУведомления"]["Титульная"];
	ДанныеУведомленияТитульный.Вставить("КодНО", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.РегистрацияВИФНС, "Код"));
	Объект.ДатаПодписи = ТекущаяДатаСеанса();
	ДанныеУведомленияТитульный.Вставить("ДАТА_ПОДПИСИ", Объект.ДатаПодписи);
	
	Если РегламентированнаяОтчетностьПереопределяемый.ЭтоЮридическоеЛицо(Объект.Организация) Тогда
		СтрокаСведений = "ИННЮЛ,НаимЮЛПол,КППЮЛ";
		СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(
			Объект.Организация, Объект.ДатаПодписи, СтрокаСведений);
		ДанныеУведомленияТитульный.Вставить("ИНН", СведенияОбОрганизации.ИННЮЛ);
		ДанныеУведомленияТитульный.Вставить("КПП", СведенияОбОрганизации.КППЮЛ);
		ДанныеУведомленияТитульный.Вставить("НаимОрг", СведенияОбОрганизации.НаимЮЛПол);
	Иначе
		СтрокаСведений = "ИННФЛ,ФамилияИП,ИмяИП,ОтчествоИП";
		СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(
			Объект.Организация, Объект.ДатаПодписи, СтрокаСведений);
		ДанныеУведомленияТитульный.Вставить("ИНН", СведенияОбОрганизации.ИННФЛ);
		ДанныеУведомленияТитульный.Вставить("Фамилия", СведенияОбОрганизации.ФамилияИП);
		ДанныеУведомленияТитульный.Вставить("Имя", СведенияОбОрганизации.ИмяИП);
		ДанныеУведомленияТитульный.Вставить("Отчество", СведенияОбОрганизации.ОтчествоИП);
	КонецЕсли;
	
	Реквизиты = РегистрацияВНОСервер.ДанныеРегистрации(Объект.РегистрацияВИФНС);
	ДанныеУведомленияТитульный.Вставить("КодНО", Реквизиты.Код);
	ДанныеУведомленияТитульный.Вставить("КПП", Реквизиты.КПП);
	
	Если ЗначениеЗаполнено(Реквизиты.Представитель) Тогда
		УведомлениеОСпецрежимахНалогообложения.УстановитьПредставителяПоФизЛицу(ЭтотОбъект);
	Иначе
		УведомлениеОСпецрежимахНалогообложения.УстановитьПредставителяПоОрганизации(ЭтотОбъект);
	КонецЕсли;
КонецПроцедуры

