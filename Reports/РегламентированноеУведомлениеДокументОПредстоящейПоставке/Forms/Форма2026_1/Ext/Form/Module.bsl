&НаСервере
Процедура ПостОбработка()
	ПризнакПоУИД = Новый Соответствие;
	Для Каждого Элт Из ЭтотОбъект["ДанныеМногостраничныхРазделов"]["ТоварДоговор"] Цикл 
		Если УведомлениеОСпецрежимахНалогообложенияКлиентСервер.СтраницаЗаполнена(Элт.Значение) Тогда 
			ПризнакПоУИД.Вставить(Элт.Значение.УИДРодителя, "2");
		КонецЕсли;
	КонецЦикла;
	Для Каждого Элт Из ЭтотОбъект["ДанныеМногостраничныхРазделов"]["Спецификация"] Цикл 
		Если УведомлениеОСпецрежимахНалогообложенияКлиентСервер.СтраницаЗаполнена(Элт.Значение) Тогда 
			ПризнакПоУИД.Вставить(Элт.Значение.УИДРодителя, "1");
		КонецЕсли;
	КонецЦикла;
	Для Каждого Элт Из ЭтотОбъект["ДанныеМногостраничныхРазделов"]["Договор"] Цикл 
		Элт.Значение.Вставить("ПрСпецТов", ПризнакПоУИД[Элт.Значение.УИД]);
	КонецЦикла;
	
	МнгСтр = ПолучитьИзВременногоХранилища(ЭтотОбъект["ДанныеДопСтрок"].МнгСтр);
	Элт = ДеревоСтраниц.ПолучитьЭлементы()[0];
	Элт.Многострочность = Ложь;
	Элт.МногострочныеЧасти.Очистить();
	Если МнгСтр.Количество() = 1 Тогда 
		ЭтотОбъект["ДанныеУведомления"].Титульная.Вставить("НомерПрицеп1", МнгСтр[0].НомерПрицеп);
	ИначеЕсли МнгСтр.Количество() = 2 Тогда 
		ЭтотОбъект["ДанныеУведомления"].Титульная.Вставить("НомерПрицеп1", МнгСтр[0].НомерПрицеп);
		ЭтотОбъект["ДанныеУведомления"].Титульная.Вставить("НомерПрицеп2", МнгСтр[1].НомерПрицеп);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["РегЗнакТС"])
		Или ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["НомерПрицеп1"])
		Или ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["НомерПрицеп2"]) Тогда 
		ЭтотОбъект["ДанныеУведомления"].Титульная["ВидТС"] = "1";
	ИначеЕсли ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["НомерНаклАвиа"])
		Или ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["ДатаНаклАвиа"]) Тогда 
		ЭтотОбъект["ДанныеУведомления"].Титульная["ВидТС"] = "2";
	ИначеЕсли ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["НомерНаклЖД"])
		Или ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["ДатаНаклЖД"]) Тогда 
		ЭтотОбъект["ДанныеУведомления"].Титульная["ВидТС"] = "3";
	ИначеЕсли ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["НомерКон"])
		Или ЗначениеЗаполнено(ЭтотОбъект["ДанныеУведомления"].Титульная["ДатаКон"]) Тогда 
		ЭтотОбъект["ДанныеУведомления"].Титульная["ВидТС"] = "4";
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИзXMLНаСервере(ПараметрыЗагрузкиXML)
	ДеревоЗагрузки = УведомлениеОСпецрежимахНалогообложения.СформироватьДеревоЗагрузки(ПараметрыЗагрузкиXML.ПредставлениеXML);
	СхемаВыгрузки = Документы.УведомлениеОСпецрежимахНалогообложения.ИзвлечьСтруктуруXMLУведомления(Объект.ИмяОтчета, "СхемаВыгрузкиФорма2026_1");
	УведомлениеОСпецрежимахНалогообложения.УстановитьОрганизациюПоПараметрамЗагрузки(ЭтотОбъект, ПараметрыЗагрузкиXML);
	ДеревоСтраниц.ПолучитьЭлементы().Очистить();
	СформироватьДеревоСтраниц();
	УведомлениеОСпецрежимахНалогообложения.СформироватьСтруктуруДанныхУведомленияНовогоОбразца(ЭтотОбъект);
	
	МнгСтр = Новый ТаблицаЗначений;
	МнгСтр.Колонки.Добавить("УИД");
	МнгСтр.Колонки.Добавить("НомерПрицеп");
	ЭтотОбъект["ДанныеДопСтрок"].Вставить("МнгСтр", ПоместитьВоВременноеХранилище(МнгСтр));
	Элт = ДеревоСтраниц.ПолучитьЭлементы()[0];
	Элт.Многострочность = Истина;
	Элт.МногострочныеЧасти.Добавить("МнгСтр");
	
	ДополнительныеПараметры = Новый Структура;
	УведомлениеОСпецрежимахНалогообложения.ЗагрузитьОбычныеСтраницы(ЭтотОбъект, ДеревоЗагрузки, СхемаВыгрузки, ДополнительныеПараметры);
	УведомлениеОСпецрежимахНалогообложения.ЗагрузитьМногостраничныеСтраницы(ЭтотОбъект, ДеревоЗагрузки, СхемаВыгрузки, ДополнительныеПараметры);
	ПостОбработка();
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПредставлениеУведомленияВыборЗавершение(КодВалюты, ДопПараметры) Экспорт 
	ТекущаяСтраницаДанными = ТекущаяСтраницаДанными();
	Если КодВалюты.Код = "643" Тогда
		ТекущаяСтраницаДанными.Вставить("КурсВалют", 1);
		ТекущаяСтраницаДанными.Вставить("БазаВалют", 1);
		ПредставлениеУведомления.Области["КурсВалют"].Значение = 1;
		ПредставлениеУведомления.Области["БазаВалют"].Значение = 1;
	ИначеЕсли ЗначениеЗаполнено(КодВалюты.Код) Тогда
		ИнформацияПоВалюте = ИнформацияПоВалюте(КодВалюты.Код, ПредставлениеУведомления.Области["ДатаКурсВалют"].Значение);
		Если ТипЗнч(ИнформацияПоВалюте) = Тип("Структура") И ЗначениеЗаполнено(ИнформацияПоВалюте.Курс) Тогда 
			ТекущаяСтраницаДанными.Вставить("КурсВалют", ИнформацияПоВалюте.Курс);
			ТекущаяСтраницаДанными.Вставить("БазаВалют", ИнформацияПоВалюте.Кратность);
			ПредставлениеУведомления.Области["КурсВалют"].Значение = ИнформацияПоВалюте.Курс;
			ПредставлениеУведомления.Области["БазаВалют"].Значение = ИнформацияПоВалюте.Кратность;
		Иначе
			ТекущаяСтраницаДанными.Вставить("КурсВалют", 0);
			ТекущаяСтраницаДанными.Вставить("БазаВалют", 0);
			ПредставлениеУведомления.Области["КурсВалют"].Значение = 0;
			ПредставлениеУведомления.Области["БазаВалют"].Значение = 0;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИнформацияПоВалюте(КодВалюты, Дата)
	ДатаКурса = ?(ЗначениеЗаполнено(Дата), КонецДня(Дата), КонецДня(ТекущаяДатаСеанса()));
	Валюта = Справочники["Валюты"].НайтиПоКоду(КодВалюты);
	Результат = Новый Структура("Курс, Кратность");
	Если ЗначениеЗаполнено(Валюта) Тогда 
		МодульРаботаСКурсамиВалют = ОбщегоНазначения.ОбщийМодуль("РаботаСКурсамиВалют");
		ЗаполнитьЗначенияСвойств(Результат, МодульРаботаСКурсамиВалют.ПолучитьКурсВалюты(Валюта, ДатаКурса));
	КонецЕсли;
	Возврат Результат;
КонецФункции

#КонецОбласти
