#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Предназначена для получения статуса и сведений квитанций ДОПП.
// Параметры:
//   СсылкаНаДОПП - Ссылка.
//
// Возвращаемое значение:
//   Структура:
//     * СтатусДОПП - Строка или Неопределено,
//     * СтатусДОППТекстом - Строка или Неопределено,
//     * НомерДОПП - Строка или Неопределено,
//     * ДатаРегистрацииДокумента - Дата или Неопределено,
//     * ДанныеКартинкиQRКода - ДвоичныеДанные или Неопределено,
//     * СведенияПоследнейКвитанции - Структура или Неопределено - результат вызова
//         "ИнтерфейсыВзаимодействияБРОВызовСервера.СведенияКвитанцииОПрисвоенииСтатусаДОПП" для последней квитанции.
//
Функция СтатусИСведенияКвитанций(СсылкаНаДОПП) Экспорт
	
	Результат = Новый Структура("СтатусДОПП, СтатусДОППТекстом, НомерДОПП, ДатаРегистрацииДокумента, "
		+ "ДанныеКартинкиQRКода, СведенияПоследнейКвитанции");
	Если НЕ ЗначениеЗаполнено(СсылкаНаДОПП) Тогда
		Возврат Результат;
	КонецЕсли;
	
	МассивКвитанцийОПрисвоенииСтатусаДОПП = ИнтерфейсыВзаимодействияБРОВызовСервера.ДокументыРеализацииПолномочийНО(
		СсылкаНаДОПП);
	Результат.СтатусДОПП = ИнтерфейсыВзаимодействияБРОВызовСервера.СтатусыДОПП(,,, МассивКвитанцийОПрисвоенииСтатусаДОПП);
	Если ЗначениеЗаполнено(Результат.СтатусДОПП) Тогда
		ДвоичныеДанныеКвитанции = ИнтерфейсыВзаимодействияБРОВызовСервера.ДокументыРеализацииПолномочийНО(
			СсылкаНаДОПП,,
			".xml",
			Новый Структура("СтатусДОПП", Результат.СтатусДОПП));
		СведенияКвитанции = ?(ЗначениеЗаполнено(ДвоичныеДанныеКвитанции),
			ИнтерфейсыВзаимодействияБРОВызовСервера.СведенияКвитанцииОПрисвоенииСтатусаДОПП(ДвоичныеДанныеКвитанции),
			Неопределено);
		Результат.СведенияПоследнейКвитанции = СведенияКвитанции;
		Если ТипЗнч(СведенияКвитанции) = Тип("Структура") Тогда
			Результат.НомерДОПП = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СведенияКвитанции.Квитанция, "НомерДОПП");
			Результат.ДатаРегистрацииДокумента = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СведенияКвитанции.Квитанция,
				"ДатаРегистрацииДокумента");
		КонецЕсли;
		Результат.СтатусДОППТекстом = ИнтерфейсыВзаимодействияБРОВызовСервера.СтатусыДОПП(Результат.СтатусДОПП,, Истина);
	КонецЕсли;
	
	Статусы = ИнтерфейсыВзаимодействияБРОВызовСервера.СтатусыДОПП();
	Если НЕ ЗначениеЗаполнено(Результат.НомерДОПП) ИЛИ НЕ ЗначениеЗаполнено(Результат.ДатаРегистрацииДокумента) Тогда
		// на случай незаполненности, получение из квитанции о присвоении статуса ДОПП "Зарегистрирован"
		ДвоичныеДанныеКвитанции = ИнтерфейсыВзаимодействияБРОВызовСервера.ДокументыРеализацииПолномочийНО(
			СсылкаНаДОПП,,
			".xml",
			Новый Структура("СтатусДОПП", Статусы.Зарегистрировано));
		СведенияКвитанции = ?(ЗначениеЗаполнено(ДвоичныеДанныеКвитанции),
			ИнтерфейсыВзаимодействияБРОВызовСервера.СведенияКвитанцииОПрисвоенииСтатусаДОПП(ДвоичныеДанныеКвитанции),
			Неопределено);
		Если ТипЗнч(СведенияКвитанции) = Тип("Структура") Тогда
			Если НЕ ЗначениеЗаполнено(Результат.НомерДОПП) Тогда
				Результат.НомерДОПП = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СведенияКвитанции.Квитанция, "НомерДОПП");
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(Результат.ДатаРегистрацииДокумента) Тогда
				Результат.ДатаРегистрацииДокумента = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СведенияКвитанции.Квитанция,
					"ДатаРегистрацииДокумента");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Результат.ДанныеКартинкиQRКода = ИнтерфейсыВзаимодействияБРОВызовСервера.ДокументыРеализацииПолномочийНО(
		СсылкаНаДОПП,,
		".png",
		Новый Структура("СтатусДОПП", Статусы.Обеспечено));
	
	Возврат Результат;
	
КонецФункции

// Возвращает контейнер, который надо заполнять данными
//
// Параметры:
//    ИмяФормы - Строка - например, Форма2026_1
// Возвращаемое значение:
//    Структура контейнера для заполнения ДОПП
//
Функция КонтейнерДляЗаполнения(ИмяФормы) Экспорт
	Если ИмяФормы = "Форма2026_1" Тогда
		Возврат КонтейнерДляЗаполнения_2026();
	Иначе
		ВызватьИсключение "Не поддерживаемый параметр";
	КонецЕсли;
КонецФункции

// Создание нового или редактирование существующего документ о предварительной поставке
//
// Параметры:
// Данные - Структура с полями:
//   Организация - СправочникСсылка.Организации
//   РегистрацияВИФНС - СправочникСсылка.РегистрацииВНалоговомОргане
//   Контейнер - Структура - получена из КонтейнерДляЗаполнения(...) и заполнена данными
//   Ссылка - ДокументСсылка.УведомлениеОСпецрежимахНалогообложения для редактирования существующего уведомления или Неопределено для создания нового
//   ДокументОснование - ОпределяемыйТип.ОснованиеУведомления или Неопределено
//   ИмяФормы - Строка - например, Форма2026_1
//
// Возвращаемое значение:
//    ДокументСсылка.УведомлениеОСпецрежимахНалогообложения ссылка на созданный ДОПП
Функция НовыйДОПП(Данные) Экспорт 
	ИмяФормы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Данные, "ИмяФормы");
	Если ИмяФормы = "Форма2026_1" Тогда
		Возврат НовыйДОПП_2026(Данные);
	Иначе
		ВызватьИсключение "Не поддерживаемый параметр";
	КонецЕсли;
КонецФункции

// Возвращает номер корректировки ДОПП
//
// Параметры:
// Ссылка - ДокументСсылка.УведомлениеОСпецрежимахНалогообложения
//
// Возвращаемое значение:
//    Число - номер корректировки
Функция НомерКорректировкиДОПП(Ссылка) Экспорт 
	Если ТипЗнч(Ссылка) <> Тип("ДокументСсылка.УведомлениеОСпецрежимахНалогообложения") Или Не ЗначениеЗаполнено(Ссылка) Тогда 
		ВызватьИсключение "Некорректный параметр";
	КонецЕсли;
	
	Реквизиты = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, "ВидУведомления,ДанныеУведомления");
	Если Реквизиты.ВидУведомления <> Перечисления.ВидыУведомленийОСпецрежимахНалогообложения.ДокументОПредстоящейПоставке Тогда 
		ВызватьИсключение "Некорректный параметр";
	КонецЕсли;
	
	Данные = Реквизиты.ДанныеУведомления.Получить();
	НомКорр = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Данные.ДанныеУведомления.Титульная, "НомКорр");
	Возврат ?(ТипЗнч(НомКорр) = Тип("Число"), НомКорр, 0);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

