		И ТекущаяДатаСеанса() < НачалоДня('20270101') Тогда 
		ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
			"Документ для Авиа/ЖД/морского транспорта оформляется с 01.01.2027", "Титульная", "ВидТС"));
	КонецЕсли;
	
	ВсеДоговоры = Новый Соответствие;
	Для Каждого Элт1 Из Данные.ДанныеМногостраничныхРазделов.Договор Цикл 
		Договор = Элт1.Значение;
		
		Если Не ЗначениеЗаполнено(Договор.НомерДог) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указан номер договора", "Договор", "НомерДог", Договор.УИД));
		ИначеЕсли ВсеДоговоры[СокрЛП(Договор.НомерДог)] = Истина Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Номер договора должен быть уникальным", "Договор", "НомерДог", Договор.УИД));
		КонецЕсли;
		ВсеДоговоры.Вставить(СокрЛП(Договор.НомерДог), Истина);
		Если Не ЗначениеЗаполнено(Договор.ДатаДог) Или НачалоДня(Договор.ДатаДог) > ТекущаяДатаСеанса() Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указана / неправильно указана дата договора", "Договор", "ДатаДог", Договор.УИД));
		КонецЕсли;
		Если Не СтрПодобнаПоРегулярномуВыражению("" + Договор.КодВалют, "[0-9]{3}") Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указан / неправильно указан код валюты", "Договор", "КодВалют", Договор.УИД));
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Договор.КурсВалют) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указан курс валюты", "Договор", "КурсВалют", Договор.УИД));
		ИначеЕсли Договор.КодВалют = "643" И Договор.КурсВалют <> 1 Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Для кода валюты 643 (рубль) курс должен быть равен 1", "Договор", "КурсВалют", Договор.УИД));
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Договор.БазаВалют) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указана база валюты", "Договор", "БазаВалют", Договор.УИД));
		ИначеЕсли Договор.КодВалют = "643" И Договор.БазаВалют <> 1 Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Для кода валюты 643 (рубль) база должна быть равеной 1", "Договор", "БазаВалют", Договор.УИД));
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Договор.ДатаКурсВалют) Или НачалоДня(Договор.ДатаКурсВалют) >= НачалоДня(ТекущаяДатаСеанса()) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указана / неправильно указана дата курса валют", "Договор", "ДатаКурсВалют", Договор.УИД));
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Договор.ПрСпецТов) Тогда 
			ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
				"Не указан признак содержимого договора", "Договор", "ПрСпецТов", Договор.УИД));
		КонецЕсли;
		
		Если Договор.ПрСпецТов = "1" Тогда
			ВсеСпецификации = Новый Соответствие;
			Для Каждого Элт2 Из Данные.ДанныеМногостраничныхРазделов.Спецификация Цикл 
				Спецификация = Элт2.Значение;
				Если Спецификация.УИДРодителя <> Договор.УИД Тогда 
					Продолжить;
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(Спецификация.НомерСп) Тогда 
					ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
						"Не указан номер спецификации", "Спецификация", "НомерСп", Спецификация.УИД));
				ИначеЕсли ВсеСпецификации[СокрЛП(Спецификация.НомерСп)] = Истина Тогда 
					ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
						"Номер спецификации должен быть уникальным", "Спецификация", "НомерСп", Спецификация.УИД));
				КонецЕсли;
				ВсеСпецификации.Вставить(СокрЛП(Спецификация.НомерСп), Истина);
				Если Не ЗначениеЗаполнено(Спецификация.ДатаСп) Тогда 
					ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
						"Не указана дата спецификации", "Спецификация", "ДатаСп", Спецификация.УИД));
				ИначеЕсли НачалоДня(Спецификация.ДатаСп) < НачалоДня(Договор.ДатаДог) Тогда 
					ТаблицаОшибок.Добавить(Документы.УведомлениеОСпецрежимахНалогообложения.ПолучитьПустуюСтруктуруНавигацииПоОшибкам(
						"Дата спецификации должна быть больше даты договора", "Спецификация", "ДатаСп", Спецификация.УИД));
				КонецЕсли;
				Для Каждого Элт3 Из Данные.ДанныеМногостраничныхРазделов.ТоварСпецификация Цикл 
					Товар = Элт3.Значение;
					Если Товар.УИДРодителя = Спецификация.УИД Тогда 
						ПроверкаТовар_Форма2026_1(ТаблицаОшибок, Товар, "ТоварСпецификация", Данные);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		ИначеЕсли Договор.ПрСпецТов = "2" Тогда 
			Для Каждого Элт2 Из Данные.ДанныеМногостраничныхРазделов.ТоварДоговор Цикл 
				Товар = Элт2.Значение;
				Если Товар.УИДРодителя = Договор.УИД Тогда 
					ПроверкаТовар_Форма2026_1(ТаблицаОшибок, Товар, "ТоварДоговор", Данные);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаОшибок;
КонецФункции

Функция ИдентификаторФайлаЭлектронногоПредставления(СведенияОтправки)
	Префикс = "NO_SPOTDOPP";
	Возврат Документы.УведомлениеОСпецрежимахНалогообложения.ИдентификаторФайлаЭлектронногоПредставления(Префикс, СведенияОтправки);
КонецФункции

Функция ОсновныеСведенияЭлектронногоПредставления(Объект, Данные)
	ОсновныеСведения = Документы.УведомлениеОСпецрежимахНалогообложения.НачальнаяИнициализацияОбщихРеквизитовВыгрузки(Объект);
	ИдентификаторФайла = ИдентификаторФайлаЭлектронногоПредставления(ОсновныеСведения);
	ОсновныеСведения.Вставить("ИдФайл", ИдентификаторФайла);
	ОсновныеСведения.Вставить("ВидТС", Данные.ДанныеУведомления.Титульная["ВидТС"]);
	ОсновныеСведения.Вставить("ОКСМПрод", Данные.ДанныеУведомления.Титульная["ОКСМПрод"]);
	ОсновныеСведения.Вставить("НомКорр", Данные.ДанныеУведомления.Титульная["НомКорр"]);
	
	СодерживоеДоговора = Новый Соответствие;
	Для Каждого Элт Из Данные.ДанныеМногостраничныхРазделов.Договор Цикл 
		СодерживоеДоговора.Вставить(Элт.Значение.УИД, Элт.Значение.ПрСпецТов);
	КонецЦикла;
	Для Каждого Элт Из Данные.ДанныеМногостраничныхРазделов.Спецификация Цикл 
		Элт.Значение.УИДРодителя = ?(СодерживоеДоговора[Элт.Значение.УИДРодителя] = "1", Элт.Значение.УИДРодителя, Неопределено);
	КонецЦикла;
	Для Каждого Элт Из Данные.ДанныеМногостраничныхРазделов.ТоварДоговор Цикл 
		Элт.Значение.УИДРодителя = ?(СодерживоеДоговора[Элт.Значение.УИДРодителя] = "2", Элт.Значение.УИДРодителя, Неопределено);
	КонецЦикла;
	
	НумерацияТоваров = Новый Соответствие;
	Для Каждого Стр Из СтрРазделить("ТоварДоговор,ТоварСпецификация", ",") Цикл 
		Для Каждого Элт Из Данные.ДанныеМногостраничныхРазделов[Стр] Цикл 
			НумерацияТоваров.Вставить(Элт.Значение.УИДРодителя, 0);
		КонецЦикла;
		Для Каждого Элт Из Данные.ДанныеМногостраничныхРазделов[Стр] Цикл 
			НумерацияТоваров[Элт.Значение.УИДРодителя] = НумерацияТоваров[Элт.Значение.УИДРодителя] + 1;
			Элт.Значение.Вставить("НомерТов", НумерацияТоваров[Элт.Значение.УИДРодителя]);
		КонецЦикла;
	КонецЦикла;
	
	Возврат ОсновныеСведения;
КонецФункции

Процедура ОбработкаДанныхУведомленияПередВыгрузкой(ДанныеУведомления)
	ОТЧ = Новый ОписаниеТипов("Число");
	Для Каждого Элт Из СтрРазделить("ТоварДоговор,ТоварСпецификация", ",") Цикл 
		Для Каждого Стр Из ДанныеУведомления.ДанныеМногостраничныхРазделов[Элт] Цикл 
			Стр.Значение.СумНДС = ?(СокрЛП(Стр.Значение.НДССт) = "0", 
				"0", Формат(Окр(ОТЧ.ПривестиЗначение(Стр.Значение.СумНДС), 2), "ЧРД=.; ЧГ="));
		КонецЦикла;
	КонецЦикла;
	
	ДанныеУведомления.ДанныеДопСтрокБД.Вставить("МнгСтр", Новый ТаблицаЗначений);
	ДанныеУведомления.ДанныеДопСтрокБД.МнгСтр.Колонки.Добавить("УИД");
	ДанныеУведомления.ДанныеДопСтрокБД.МнгСтр.Колонки.Добавить("НомерПрицеп");
	
	НовСтр = ДанныеУведомления.ДанныеДопСтрокБД["МнгСтр"].Добавить();
	НовСтр.НомерПрицеп = ДанныеУведомления.ДанныеУведомления.Титульная["НомерПрицеп1"];
	НовСтр = ДанныеУведомления.ДанныеДопСтрокБД["МнгСтр"].Добавить();
	НовСтр.НомерПрицеп = ДанныеУведомления.ДанныеУведомления.Титульная["НомерПрицеп2"];
КонецПроцедуры

Функция ЭлектронноеПредставление_Форма2026_1(Объект, УникальныйИдентификатор) 
	СведенияЭлектронногоПредставления = УведомлениеОСпецрежимахНалогообложения.СведенияЭлектронногоПредставления();
	ДанныеУведомления = УведомлениеОСпецрежимахНалогообложения.ДанныеУведомленияДляВыгрузки(Объект);
	Ошибки = ПроверитьДокументСВыводомВТаблицу_Форма2026_1(ДанныеУведомления, УникальныйИдентификатор);
	УведомлениеОСпецрежимахНалогообложения.СообщитьОшибкиПриПроверкеВыгрузки(Объект, Ошибки, ДанныеУведомления);
	
	ОбработкаДанныхУведомленияПередВыгрузкой(ДанныеУведомления);
	ОсновныеСведения = ОсновныеСведенияЭлектронногоПредставления(Объект, ДанныеУведомления);
	СтруктураВыгрузки = Документы.УведомлениеОСпецрежимахНалогообложения.ИзвлечьСтруктуруXMLУведомления(Объект.ИмяОтчета, "СхемаВыгрузкиФорма2026_1");
	УведомлениеОСпецрежимахНалогообложения.ТиповоеЗаполнениеДанными(ДанныеУведомления, ОсновныеСведения, СтруктураВыгрузки);
	УведомлениеОСпецрежимахНалогообложения.ВыгрузитьДеревоВТаблицу(СтруктураВыгрузки, ОсновныеСведения, СведенияЭлектронногоПредставления);
	Возврат СведенияЭлектронногоПредставления;
КонецФункции

Функция СформироватьСписокЛистов_Форма2026_1(Объект) Экспорт
	СтатусИСведенияКвитанций = СтатусИСведенияКвитанций(Объект.Ссылка);
	Если ТипЗнч(СтатусИСведенияКвитанций.ДанныеКартинкиQRКода) = Тип("ДвоичныеДанные") Тогда
		КартинкаQRКода = Новый Картинка(СтатусИСведенияКвитанций.ДанныеКартинкиQRКода);
	КонецЕсли;
	
	Листы = Новый СписокЗначений;
	МакетУведомления = Отчеты[Объект.ИмяОтчета].ПолучитьМакет("Печать_Форма2026_1");
	Данные = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "ДанныеУведомления").Получить();
	
	ЭтоЮЛ = РегламентированнаяОтчетностьПереопределяемый.ЭтоЮридическоеЛицо(Объект.Организация);
	Титульная = Данные.ДанныеУведомления["Титульная"];
	
	ПечатнаяФорма = УведомлениеОСпецрежимахНалогообложения.НовыйПустойЛист();
	ОбластьШапка = МакетУведомления.ПолучитьОбласть("Титульный");
	ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры, Титульная);
	ОбластьШапка.Параметры.НаименованиеЗаявителя = ?(ЭтоЮЛ, Титульная.НаимОрг
		,СокрЛП(Титульная.Фамилия + " " + Титульная.Имя + " " + Титульная.Отчество));
	ОбластьШапка.Параметры.НомерПрицеп = Титульная.НомерПрицеп1 
		+ ?(ЗначениеЗаполнено(Титульная.НомерПрицеп1), ", " + Титульная.НомерПрицеп2, "");
	
	ОбластьШапка.Параметры.НомерДОПП = СтатусИСведенияКвитанций.НомерДОПП;
	ОбластьШапка.Параметры.ДатаРегистр = СтатусИСведенияКвитанций.ДатаРегистрацииДокумента;
	ОбластьШапка.Параметры.СтатусДОПП = СтатусИСведенияКвитанций.СтатусДОППТекстом;
	
	ПечатнаяФорма.Вывести(ОбластьШапка);
	Если ТипЗнч(КартинкаQRКода) = Тип("Картинка") Тогда 
		Рисунок = ПечатнаяФорма.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка);
		Рисунок.Картинка = КартинкаQRКода;
		Рисунок.Линия = Новый Линия(ТипЛинииРисункаТабличногоДокумента.НетЛинии, 0);
		Рисунок.РазмерКартинки = РазмерКартинки.Пропорционально;
		Рисунок.Расположить(ПечатнаяФорма.Области.Найти("QR"));
	КонецЕсли;
	УведомлениеОСпецрежимахНалогообложения.ПоложитьПФВСписокЛистов(Объект, Листы, ПечатнаяФорма, Листы.Количество() + 1, Ложь);
	
	Для Каждого Элт1 Из Данные.ДанныеМногостраничныхРазделов.Договор Цикл 
		Таблица1 = Новый Массив;
		Таблица2 = Новый Массив;
		
		Договор = Элт1.Значение;
		ПечатнаяФорма = УведомлениеОСпецрежимахНалогообложения.НовыйПустойЛист();
		ПечатнаяФорма.ОриентацияСтраницы  = ОриентацияСтраницы.Ландшафт;
		ЗаголовокДоговор = МакетУведомления.ПолучитьОбласть("ЗаголовокДоговор");
		ЗаполнитьЗначенияСвойств(ЗаголовокДоговор.Параметры, Договор);
		НомПП = 0;
		Если Договор.ПрСпецТов = "2" Тогда 
			Для Каждого Элт2 Из Данные.ДанныеМногостраничныхРазделов["ТоварДоговор"] Цикл 
				Товар = Элт2.Значение;
				Если Товар.УИДРодителя <> Договор.УИД Тогда 
					Продолжить;
				КонецЕсли;
				НомПП = НомПП + 1;
				Строка = МакетУведомления.ПолучитьОбласть("СтрокаТовары");
				ЗаполнитьЗначенияСвойств(Строка.Параметры, Товар);
				Строка.Параметры.НомПП = НомПП;
				Таблица1.Добавить(Строка);
				Строка = МакетУведомления.ПолучитьОбласть("СтрокаНалоги");
				ЗаполнитьЗначенияСвойств(Строка.Параметры, Товар);
				Строка.Параметры.НомПП = НомПП;
				Таблица2.Добавить(Строка);
			КонецЦикла;
		ИначеЕсли Договор.ПрСпецТов = "1" Тогда 
			Для Каждого Спец Из Данные.ДанныеМногостраничныхРазделов["Спецификация"] Цикл 
				Если Спец.Значение.УИДРодителя <> Договор.УИД Тогда 
					Продолжить;
				КонецЕсли;
				Для Каждого Элт2 Из Данные.ДанныеМногостраничныхРазделов["ТоварСпецификация"] Цикл 
					Товар = Элт2.Значение;
					Если Товар.УИДРодителя <> Спец.Значение.УИД Тогда 
						Продолжить;
					КонецЕсли;
					НомПП = НомПП + 1;
					Строка = МакетУведомления.ПолучитьОбласть("СтрокаТовары");
					ЗаполнитьЗначенияСвойств(Строка.Параметры, Товар);
					Строка.Параметры.НомПП = НомПП;
					Таблица1.Добавить(Строка);
					Строка = МакетУведомления.ПолучитьОбласть("СтрокаНалоги");
					ЗаполнитьЗначенияСвойств(Строка.Параметры, Товар);
					Строка.Параметры.НомПП = НомПП;
					Таблица2.Добавить(Строка);
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
		
		ПечатнаяФорма.Вывести(ЗаголовокДоговор);
		ПечатнаяФорма.Вывести(МакетУведомления.ПолучитьОбласть("ШапкаТовары"));
		Для Каждого Элт Из Таблица1 Цикл 
