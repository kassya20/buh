Процедура ДобавлениеСпецификаций_2026(СтрокиВДереве, Контейнер, УИДРодителя, ДанныеМногостраничныхРазделов)
	ОтбСтроки = Контейнер["Спецификация"].НайтиСтроки(Новый Структура("УИДРодителя", УИДРодителя));
	Если ОтбСтроки.Количество() = 0 Тогда 
		НовСтр = Контейнер["Спецификация"].Добавить();
		НовСтр.УИДРодителя = УИДРодителя;
		ОтбСтроки.Добавить(НовСтр);
	КонецЕсли;
	
	Инд = 0;
	Для Каждого Стр Из ОтбСтроки Цикл
		Инд = Инд + 1;
		
		Стр001 = СтрокиВДереве.Добавить();
		Стр001.Наименование = "Стр. " + Инд;
		Стр001.ИндексКартинки = 1;
		Стр001.ИмяМакета = "Спецификация_2026";
		Стр001.Многостраничность = Истина;
		Стр001.Многострочность = Ложь;
		Стр001.УИД = Стр.УИД;
		Стр001.ИДНаименования = "Спецификация";
		
		ДанныеМногостраничныхРазделов["Спецификация"].Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
		
		Стр001 = Стр001.Строки.Добавить();
		Стр001.Наименование = "Товары";
		Стр001.ИндексКартинки = 1;
		Стр001.Многостраничность = Истина;
		Стр001.Многострочность = Истина;
		
		ДобавлениеТоваров_2026(Стр001.Строки, ДанныеМногостраничныхРазделов["ТоварСпецификация"],
			Стр.УИД, Контейнер["ТоварСпецификация"], "ТоварСпецификация");
	КонецЦикла;
КонецПроцедуры

Процедура ДобавлениеТоваров_2026(СтрокиВДереве, СписокСДанными, УИДРодителя, ДанныеЗаполнения, ИмяРаздела)
	ОтбСтроки = ДанныеЗаполнения.НайтиСтроки(Новый Структура("УИДРодителя", УИДРодителя));
	Если ОтбСтроки.Количество() = 0 Тогда 
		НовСтр = ДанныеЗаполнения.Добавить();
		НовСтр.УИДРодителя = УИДРодителя;
		ОтбСтроки.Добавить(НовСтр);
	КонецЕсли;
	
	Инд = 0;
	Для Каждого Стр Из ОтбСтроки Цикл
		Инд = Инд + 1;
		
		Стр001 = СтрокиВДереве.Добавить();
		Стр001.Наименование = "Стр. " + Инд;
		Стр001.ИндексКартинки = 1;
		Стр001.ИмяМакета = "Товар_2026";
		Стр001.Многостраничность = Истина;
		Стр001.Многострочность = Истина;
		Стр001.УИД = Стр.УИД;
		Стр001.ИДНаименования = ИмяРаздела;
		Стр001.МногострочныеЧасти.Добавить("МнгСтр1");
		
		СписокСДанными.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
	КонецЦикла;
КонецПроцедуры

