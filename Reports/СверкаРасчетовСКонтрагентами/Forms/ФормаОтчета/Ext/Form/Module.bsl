&НаСервере
Процедура НастроитьСовместимостьИнтерфейсов()
	
	ЭтоИнтерфейсТакси = СервисСверкиРасчетов.ЭтоИнтерфейсТакси();
	
	Если ЭтоИнтерфейсТакси Тогда
		
		Элементы.Настройки.Ширина               = 31;
		Элементы.Контрагент.Ширина              = 25;
		Элементы.УточнениеКритичных.Ширина      = 28;
		Элементы.ФлагиКритичных.Ширина          = 23;
		Элементы.УточнениеНезначительных.Ширина = 28;
		Элементы.ФлагиНезначительных.Ширина     = 23;
		
	Иначе
		
		СистемнаяИнформация = Новый СистемнаяИнформация();
		ДоступенИнтерфейс85 = ОбщегоНазначенияКлиентСервер.СравнитьВерсии(СистемнаяИнформация.ВерсияПриложения, "8.5.1.1150") >= 0;
		Если ДоступенИнтерфейс85 Тогда
			Элементы.Настройки.Ширина               = 35;
			Элементы.Контрагент.Ширина              = 35;
			Элементы.УточнениеКритичных.Ширина      = 33;
			Элементы.ФлагиКритичных.Ширина          = 27;
			Элементы.УточнениеНезначительных.Ширина = 33;
			Элементы.ФлагиНезначительных.Ширина     = 27;
			Элементы.ВариантОтчета.РастягиватьПоГоризонтали = Истина;
			ЭтотОбъект.ВариантМасштаба = ВариантМасштабаФормКлиентскогоПриложения.Компактный;
			
			// Свойства доступны, начиная с платформы 8.5
			Выполнить("Элементы.Настройки.ОтображатьКакКарточку = Истина");
			Выполнить("Элементы.Обновить.Важность = ВажностьКнопки.Дополнительная"); 
			Выполнить("Элементы.ВариантОтчета.РастягиватьПоГоризонтали = Истина");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьТекстЗаголовка(Форма)
	
	Отчет = Форма.Отчет;
	
	ТекстПериод = "";
	Если ЗначениеЗаполнено(Отчет.КонецПериода) Тогда 
		Если Отчет.КонецПериода >= Отчет.НачалоПериода Тогда
			ТекстПериод = " " + НСтр("ru = 'за'")+ " ";
			ТекстПериод = ТекстПериод
				+ ПредставлениеПериода(НачалоДня(Отчет.НачалоПериода), КонецДня(Отчет.КонецПериода), "ФП = Истина");	
		Иначе
			ТекстПериод = "";
		КонецЕсли;
	ИначеЕсли ЗначениеЗаполнено(Отчет.НачалоПериода) Тогда
		ТекстПериод = " " + НСтр("ru = 'за'")+ " "
			+ ПредставлениеПериода(НачалоДня(Отчет.НачалоПериода), КонецДня(Дата(3999, 11, 11)), "ФП = Истина");
		ТекстПериод = СтрЗаменить(ТекстПериод, Сред(ТекстПериод, СтрНайти(ТекстПериод, " - ")), " - ...");
	КонецЕсли;
	
	Форма.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Сверка документов с контрагентами (1С:Сверка 2.0)%1'"),
		ТекстПериод);
		
КонецПроцедуры

#КонецОбласти