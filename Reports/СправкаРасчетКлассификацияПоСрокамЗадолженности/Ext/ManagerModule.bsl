// Возвращает данные для оформления заголовков таблицы
// Параметры:
//  Контекст  - См. НовыйКонтекстФормированияОтчета
//
// Возвращаемое значение:
//  Структура:
//   Ключ - Строка - имя Таблицы в структуре настроек Схемы компоновки данных
//   Значение - См. НовыйШапкаТаблицы
//
Функция ОписаниеШапкиТаблиц(Контекст)

	ОписаниеШапкиТаблиц = Новый Структура;
	
	ШрифтРаздела    = Новый Шрифт(, 11, Истина);
	Отступ = 5;
	
	ТекстыЗаголовковКолонок = ТекстыЗаголовковКолонок(Контекст);
		
	ПараметрыОформления = Новый Структура;
	ПараметрыОформления.Вставить("Шрифт", ШрифтРаздела);
	ПараметрыОформления.Вставить("ОтступСверху", Отступ);
	ПараметрыОформления.Вставить("ОтступСнизу",  Отступ);
	
	// Дебиторская задолженность
	ЗаголовокРаздела = НовыйЗаголовокТаблицы();
	ЗаголовокРаздела.Текст = "Дебиторская задолженность";
	ЗаголовокРаздела.ПараметрыОформления = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыОформления);

	ШапкаТаблицы = НовыйШапкаТаблицы();
	ШапкаТаблицы.ГрафыСводно         = ГрафыДебиторскойЗадолженностиСводно();
	ШапкаТаблицы.ГрафыДетально       = ГрафыДебиторскойЗадолженностиДетально();
	ШапкаТаблицы.ЗаголовкиКолонок    = ЗаголовкиКолонокТаблицыДебиторскойЗадолженности(ТекстыЗаголовковКолонок, Контекст.ДетальныеЗаписи);
	ШапкаТаблицы.ЗаголовокРаздела    = ЗаголовокРаздела;
	ОписаниеШапкиТаблиц.Вставить("ДебиторскаяЗадолженность", ШапкаТаблицы);
	
	// Кредиторская задолженность
	ЗаголовокРаздела = НовыйЗаголовокТаблицы();
	ЗаголовокРаздела.Текст = "Кредиторская задолженность";
	ЗаголовокРаздела.ПараметрыОформления = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыОформления);

	ШапкаТаблицы = НовыйШапкаТаблицы();
	ШапкаТаблицы.ГрафыСводно         = ГрафыКредиторскойЗадолженностиСводно();
	ШапкаТаблицы.ГрафыДетально       = ГрафыКредиторскойЗадолженностиДетально();
	ШапкаТаблицы.ЗаголовкиКолонок    = ЗаголовкиКолонокТаблицыКредиторскойЗадолженности(ТекстыЗаголовковКолонок, Контекст.ДетальныеЗаписи);
	ШапкаТаблицы.ЗаголовокРаздела    = ЗаголовокРаздела;
	ОписаниеШапкиТаблиц.Вставить("КредиторскаяЗадолженность", ШапкаТаблицы);
	
	Возврат ОписаниеШапкиТаблиц;
	
КонецФункции

