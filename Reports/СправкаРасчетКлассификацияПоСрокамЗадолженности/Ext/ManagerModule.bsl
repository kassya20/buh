Функция ТекстыЗаголовковКолонок(Контекст)
 	
	ТекстыЗаголовков = Новый Структура;
	ТекстыЗаголовков.Вставить("СчетРасчетов", НСтр("ru = 'Счет'"));
	ТекстыЗаголовков.Вставить("БалансоваяСтоимость", НСтр("ru = 'Балансовая стоимость'"));
	
	Возврат ТекстыЗаголовков;
	
КонецФункции

Функция ЗаголовкиКолонокТаблицыДебиторскойЗадолженности(ТекстыЗаголовков, ДетальныеЗаписи)
	
	ЗаголовкиКолонок = НовыйЗаголовкиКолонок();
	
	// графы колонок - см. ГрафыТаблицыГрафикРуб
	Формулы = Новый Структура;
	Если ДетальныеЗаписи Тогда
		Формулы.Вставить("БалансоваяСтоимость", НСтр("ru = '(гр.6 - гр.7 - гр.8)'"));
	Иначе
		Формулы.Вставить("БалансоваяСтоимость", НСтр("ru = '(гр.2 - гр.3 - гр.4)'"));
	КонецЕсли;
	
	ТекстыСФормулами = ТекстыСФормулами(ТекстыЗаголовков, Формулы);
	
	// поля
	Поля = Новый Структура;
	Поля.Вставить("БалансоваяСтоимость", ТекстыСФормулами.БалансоваяСтоимость);

	ЗаголовкиКолонок.Поля = Поля;
	
	// группы
	Группы = Новый Массив;
	
	// Расчетное обязательство
	ОписаниеПоляГруппы = Новый Структура;
	ОписаниеПоляГруппы.Вставить("Заголовок", ТекстыСФормулами.СчетРасчетов);
	ОписаниеПоляГруппы.Вставить("ПолеГруппы", "СчетРасчетов");
	Группы.Добавить(ОписаниеПоляГруппы);
	
	ЗаголовкиКолонок.Группы = Группы;
	
	Возврат ЗаголовкиКолонок;

КонецФункции

