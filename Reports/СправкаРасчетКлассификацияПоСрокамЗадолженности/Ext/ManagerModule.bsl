#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Описывает свойства отчета (манифест), декларирующий поддержанные в нем возможности подсистемы,
// включая реализованный программный интерфейс.
//
Функция ПолучитьПараметрыИсполненияОтчета() Экспорт
	
	Манифест = Новый Структура;
	Манифест.Вставить("ИспользоватьПередКомпоновкойМакета", Истина);
	Манифест.Вставить("ИспользоватьПослеКомпоновкиМакета",  Истина);
	Манифест.Вставить("ИспользоватьПриВыводеЗаголовка",     Истина);
	Манифест.Вставить("ИспользоватьПослеВыводаРезультата",  Истина);
	Манифест.Вставить("ИспользоватьВременныеТаблицыЗапроса",  Истина);
	СправкиРасчеты.УстановитьОтчетНеИспользуетНаборыСуммовыхПоказателей(Манифест);

	Возврат Манифест;

КонецФункции

// Обработчик события подсистемы БухгалтерскиеОтчеты.
// Вызов определяется параметром ИспользоватьПередКомпоновкойМакета.
//
// Параметры:
//  Контекст  - См. НовыйКонтекстФормированияОтчета
//  Схема - СхемаКомпоновкиДанных - схема отчета.
//  КомпоновщикНастроек - КомпоновщикНастроекКомпоновкиДанных - описание связи настроек и схемы отчета.
//
Процедура ПередКомпоновкойМакета(Контекст, Схема, КомпоновщикНастроек) Экспорт
	
	// добавляем в контекст параметры для вывода группировок в табличный документ и оформления заголовков таблицы
	Контекст.ОписаниеШапкиТаблиц = ОписаниеШапкиТаблиц(Контекст);

	Если ЗначениеЗаполнено(Контекст.Организации) Тогда
		БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "Организации", Контекст.Организации);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Контекст.НачалоПериода) Тогда
		БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "НачалоПериода", НачалоДня(Контекст.НачалоПериода));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Контекст.КонецПериода) Тогда
		БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "КонецПериода",     Новый Граница(Контекст.КонецПериода, ВидГраницы.Включая));
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "КонецПериодаДата", КонецДня(Контекст.КонецПериодаДата));
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "НачалоПредыдущегоПериода", ДобавитьМесяц(НачалоГода(Контекст.КонецПериодаДата), -12));
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "ДатаНачалаДолгосрочногоПериода", КонецМесяца(ДобавитьМесяц(Контекст.КонецПериодаДата, 12)) + 1);
	КонецЕсли;
	
	СписокВидовСубконто = КлассификацияЗадолженности.СписокВидовСубконто();

	// Виды субконто
	Для Каждого ВидыСубконто Из СписокВидовСубконто Цикл
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, ВидыСубконто.Ключ, ВидыСубконто.Значение);
	КонецЦикла;

	СчетаКлассификацииДебиторская = КлассификацияЗадолженности.СчетаРасчетовДебиторскаяЗадолженность();
	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.Активный);
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	СчетаОтбораДебиторская = СчетаОтбора(КомпоновщикНастроек.Настройки.Отбор.Элементы, ВидыСчетов, СчетаКлассификацииДебиторская);
	
	СчетаКлассификацииКредиторская = КлассификацияЗадолженности.СчетаРасчетовКредиторскаяЗадолженность();
	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.Пассивный);
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	СчетаОтбораКредиторская = СчетаОтбора(КомпоновщикНастроек.Настройки.Отбор.Элементы, ВидыСчетов, СчетаКлассификацииКредиторская);
	
	ЕстьОтбор = СчетаОтбораДебиторская.ЕстьОтбор Или СчетаОтбораКредиторская.ЕстьОтбор;
	
	Если ЕстьОтбор Тогда
		СчетаКлассификацииДебиторская = ОбщегоНазначения.СкопироватьРекурсивно(СчетаОтбораДебиторская);
		СчетаКлассификацииКредиторская = ОбщегоНазначения.СкопироватьРекурсивно(СчетаОтбораКредиторская);
	КонецЕсли;
	
	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "СчетаРасчетовДебиторская", СчетаКлассификацииДебиторская.СчетаРасчетов);
	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "СчетаРасчетовПоАрендеДебиторская", СчетаКлассификацииДебиторская.СчетаРасчетовПоАренде);
	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "СчетаУчетаРБП", СчетаКлассификацииДебиторская.СчетаУчетаРБП);
	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "СчетаУчетаНМА", СчетаКлассификацииДебиторская.СчетаУчетаНМА);

	// ДЕБИТОРСКАЯ ЗАДОЛЖЕННОСТЬ
	ВидЗадолженностиДебиторская = Перечисления.ВидыЗадолженности.Дебиторская;
	
	КонтекстЗапросаДебиторская = КлассификацияЗадолженности.НовыйКонтекстЗапросаОстаткиЗадолженности();
	
	НаборыСчетовДебиторская = КлассификацияЗадолженности.НаборыСчетовРазвернуто(ВидЗадолженностиДебиторская, СписокВидовСубконто, Истина);
	КлассификацияЗадолженности.ЗаполнитьНаборыСчетами(НаборыСчетовДебиторская, СчетаКлассификацииДебиторская.СчетаРасчетов);
	
	Схема.НаборыДанных.Задолженность.Элементы.ДебиторскаяЗадолженность.Запрос = КлассификацияЗадолженности.ТекстЗапросаОстаткиДебиторскойЗадолженности(НаборыСчетовДебиторская, КонтекстЗапросаДебиторская, Контекст);
	
	// ВидЗадолженностиДебиторская
	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "ВидЗадолженностиДебиторская", ВидЗадолженностиДебиторская);

	// Наборы счетов
	Для Каждого Набор Из НаборыСчетовДебиторская Цикл
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, Набор.ИмяНабора, Набор.СписокСчетов);
	КонецЦикла;

	// КонтекстЗапроса
	Для Каждого Параметр Из КонтекстЗапросаДебиторская.ПараметрыЗапроса Цикл
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, Параметр.Ключ, Параметр.Значение);
	КонецЦикла;

	// КРЕДИТОРСКАЯ ЗАДОЛЖЕННОСТЬ
	СчетаРасчетовКредиторская = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаРасчетовКредиторская, СчетаКлассификацииКредиторская.СчетаРасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаРасчетовКредиторская, СчетаКлассификацииКредиторская.СчетаКредитовЗаймов);

	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "СчетаРасчетовКредиторская", СчетаРасчетовКредиторская);
	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "СчетаРасчетовПоАрендеКредиторская", СчетаКлассификацииКредиторская.СчетаРасчетовПоАренде);

	ВидЗадолженностиКредиторская = Перечисления.ВидыЗадолженности.Кредиторская;
	
	КонтекстЗапросаКредиторская = КлассификацияЗадолженности.НовыйКонтекстЗапросаОстаткиЗадолженности();

	НаборыСчетовКредиторская = КлассификацияЗадолженности.НаборыСчетовРазвернуто(ВидЗадолженностиКредиторская, СписокВидовСубконто, Истина);
	КлассификацияЗадолженности.ЗаполнитьНаборыСчетами(НаборыСчетовКредиторская, СчетаРасчетовКредиторская);
	
	Схема.НаборыДанных.Задолженность.Элементы.КредиторскаяЗадолженность.Запрос = КлассификацияЗадолженности.ТекстЗапросаОстаткиКредиторскойЗадолженности(НаборыСчетовКредиторская, КонтекстЗапросаКредиторская, Контекст);

	// ВидЗадолженностиКредиторская
	ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, "ВидЗадолженностиКредиторская", ВидЗадолженностиКредиторская);

	// Наборы счетов
	Для Каждого Набор Из НаборыСчетовКредиторская Цикл
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, Набор.ИмяНабора, Набор.СписокСчетов);
	КонецЦикла;

	// КонтекстЗапроса
	Для Каждого Параметр Из КонтекстЗапросаКредиторская.ПараметрыЗапроса Цикл
		ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	
	ИзменитьСтруктуруОтчета(КомпоновщикНастроек, Контекст);
КонецПроцедуры

// Обработчик события подсистемы БухгалтерскиеОтчеты.
// Вызов определяется параметром ИспользоватьПослеКомпоновкиМакета.
// Параметры:
//  Контекст - См. НовыйКонтекстФормированияОтчета
//  МакетКомпоновки - МакетКомпоновкиДанных - сформированный макет компоновки данных.
//
Процедура ПослеКомпоновкиМакета(Контекст, МакетКомпоновки) Экспорт
	
	ДобавитьМакетыТаблиц(Контекст.ОписаниеШапкиТаблиц, МакетКомпоновки, Контекст);
	
	Для Каждого ОписаниеШапки Из Контекст.ОписаниеШапкиТаблиц Цикл
		ОписаниеШапки = ОписаниеШапки.Значение;
		Если ОписаниеШапки.Макеты <> Неопределено Тогда
			
			РазмещениеМакетовШапкиТаблицы = Новый Соответствие;
			Для Каждого Макет Из ОписаниеШапки.Макеты Цикл
				Если Макет.Значение <> ИмяИтогиГруппировки() Тогда
					РазмещениеМакетовШапкиТаблицы.Вставить(Макет.Ключ, Макет.Значение);
				КонецЕсли;
			КонецЦикла;
			
			Графы = ОписаниеШапки.ГрафыСводно;
			Если Контекст.ДетальныеЗаписи Тогда
				Графы = ОписаниеШапки.ГрафыДетально;
			КонецЕсли;
			
			Если Графы <> Неопределено Тогда
				СправкиРасчеты.НастроитьГрафыОтчета(МакетКомпоновки, Графы, РазмещениеМакетовШапкиТаблицы);
			КонецЕсли;
			
			ОбработатьМакетыТаблиц(МакетКомпоновки, ОписаниеШапки);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Обработчик события подсистемы БухгалтерскиеОтчеты.
// Вызов определяется параметром ИспользоватьВнешниеНаборыДанных.
//
// Параметры:
//  Контекст - См. НовыйКонтекстФормированияОтчета
//  МакетКомпоновки - МакетКомпоновкиДанных - сформированный макет компоновки данных.
//
Функция ПолучитьВнешниеНаборыДанных(Контекст, МакетКомпоновки) Экспорт
	
	Возврат Контекст.ВнешниеНаборыДанных;
	
КонецФункции

// Обработчик события подсистемы БухгалтерскиеОтчеты.
// Вызов определяется параметром ИспользоватьПослеВыводаРезультата.
//
// Параметры:
//  Контекст - См. НовыйКонтекстФормированияОтчета
//  Результат - ТабличныйДокумент - табличный документ с сформированным отчетом.
//
Процедура ПослеВыводаРезультата(Контекст, Результат) Экспорт
	
	Результат.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	
	БухгалтерскиеОтчетыВызовСервера.ОбработкаРезультатаОтчета(Контекст.ИдентификаторОтчета, Результат);

КонецПроцедуры

// Обработчик события подсистемы БухгалтерскиеОтчеты.
// Вызов определяется параметром ИспользоватьПриВыводеЗаголовка.
//
// Параметры:
//  Контекст - См. НовыйКонтекстФормированияОтчета
//  КомпоновщикНастроек - КомпоновщикНастроекКомпоновкиДанных - описание связи настроек и схемы отчета.
//  Результат - ТабличныйДокумент - табличный документ с сформированным отчетом.
//
Процедура ПриВыводеЗаголовка(Контекст, КомпоновщикНастроек, Результат) Экспорт
	
	ВывестиШапкуОтчета(Результат, Контекст, КомпоновщикНастроек);
	
КонецПроцедуры 

// Обработчик события подсистемы БухгалтерскиеОтчеты.
// Вызов определяется параметром ИспользоватьВременныеТаблицыЗапроса.
// Параметры:
//  Контекст - См. НовыйКонтекстФормированияОтчета
//  МакетКомпоновки - МакетКомпоновкиДанных - сформированный макет компоновки данных.
//
// Возвращаемое значение:
//  МенеджерВременныхТаблиц
//
Функция МенеджерВременныхТаблицОтчета(Контекст, МакетКомпоновки) Экспорт

	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	КлассификацияЗадолженности.СоздатьВременныеТаблицыРасчетыПоАренде(МенеджерВременныхТаблиц, Контекст);
	РазделятьАвансыПоВидамАктивов = РегламентированнаяОтчетность.АвансыРазделеныПоВидамАктивов(Контекст.Организация.ГоловнаяОрганизация, Контекст.КонецПериодаДата);
	АвансыПоВидамАктивовСводно = ЗаполнениеБухгалтерскойОтчетности2025Основная.АвансыПоВидамАктивовСводно(Контекст.Организации, Контекст.КонецПериода, РазделятьАвансыПоВидамАктивов);
	КлассификацияЗадолженности.СоздатьВременныеТаблицыОбщийНДСАвансовВыданных(МенеджерВременныхТаблиц, Контекст, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивовСводно);
	КлассификацияЗадолженности.СоздатьВременныеТаблицыОбщийРезервПоСомнительнымДолгам(МенеджерВременныхТаблиц, Контекст, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивовСводно);
	Возврат МенеджерВременныхТаблиц;
	
КонецФункции

// Возвращает параметры расшифровки ячейки отчета.
//
// Параметры:
//  Адрес - Строка - Адрес временного хранилища с данными расшифровки отчета.
//  ИдентификаторРасшифровки - ИдентификаторРасшифровкиКомпоновкиДанных
//  ПараметрыОтчета - Структура
//
// Возвращаемое значение:
//  Структура - Содержит ключи (опционально):
//   * ОткрытьОбъект - Булево - Если Истина, то необходимо открыть указанный объект.
//   * ОткрытьФормуПечати - Булево - Если Истина, то необходимо открыть открыть печатную форму по параметрам.
//   * Значение - Произвольный - Значение расшифровывающего объекта.
//   * ПараметрыОткрытияФормы - Структура - параметры, необходимые для формирования печатной формы.
//
Функция ПараметрыРасшифровкиОтчета(Адрес, ИдентификаторРасшифровки, ПараметрыОтчета) Экспорт
	
	ПараметрыРасшифровки = Новый Структура;
	
	// Заполним соответствие полей которые мы хотим получить из данных расшифровки
	СоответствиеПолей = Новый Соответствие;
	ДанныеОтчета = ПолучитьИзВременногоХранилища(Адрес);
	
	ЗначениеРасшифровки = ДанныеОтчета.ДанныеРасшифровки.Элементы[ИдентификаторРасшифровки];
	Если ТипЗнч(ЗначениеРасшифровки) = Тип("ЭлементРасшифровкиКомпоновкиДанныхПоля") Тогда 
		ПолеРасшифровки = ЗначениеРасшифровки.ПолучитьПоля()[0];
		
		ПоляРасшифровки = Новый Массив;
		ПоляРасшифровки.Добавить("ОстатокДолга");
		ПоляРасшифровки.Добавить("РезервПоСомнительнымДолгам");
		ПоляРасшифровки.Добавить("НДСАвансов");
		ПоляРасшифровки.Добавить("ПроцентыПоРассрочке");
		ПоляРасшифровки.Добавить("БалансоваяСтоимость");
		
		// задан обратный порядок сортировки для корректного отображения данных расшифровки.
		СоответствиеПолей.Вставить("Субконто3Задолженности");
		СоответствиеПолей.Вставить("Субконто2Задолженности");
		СоответствиеПолей.Вставить("Субконто1Задолженности");
		СоответствиеПолей.Вставить("СчетРасчетов");
		
		// Получаем соответствие полей доступных в расшифровке
		ДанныеРасшифровки = БухгалтерскиеОтчеты.ПолучитьДанныеРасшифровки(ДанныеОтчета.ДанныеРасшифровки, СоответствиеПолей, ИдентификаторРасшифровки);
		
		Если ПолеРасшифровки.Поле = "ПроцентыПоРассрочке" И ПоляРасшифровки.Найти(ПолеРасшифровки.Поле) <> Неопределено Тогда
			
			Отборы = Новый Соответствие;
			Для Каждого ЭлементРасшифровки Из ДанныеРасшифровки Цикл
				ИмяПоляОтбора = ЭлементРасшифровки.Ключ;
				Если ИмяПоляОтбора = "СчетРасчетов" Тогда
					ИмяПоляОтбора = "Счет";
				ИначеЕсли ИмяПоляОтбора = "Субконто1Задолженности" Тогда
					ИмяПоляОтбора = "Контрагент";
				ИначеЕсли ИмяПоляОтбора = "Субконто2Задолженности" Тогда
					ИмяПоляОтбора = "ДоговорКонтрагента";
				Иначе
					Продолжить;
				КонецЕсли;
	
				Равно = Новый Структура("ВидСравненияКомпоновкиДанных, Значение",
				                         ВидСравненияКомпоновкиДанных.Равно,
				                         ЭлементРасшифровки.Значение);
				Отборы.Вставить(ИмяПоляОтбора, Равно);
			КонецЦикла;
			
			ИмяОтчета = "Отчет.СправкаРасчетКлассификацияПоСрокамРассрочки.ФормаОбъекта";
			ПараметрыРасшифровки = ЗаполнениеБухгалтерскойОтчетности.НастройкиРасшифровкиСправкиРасчетаКлассификацииЗадолженности(ПараметрыОтчета, ИмяОтчета, Отборы);
			
		ИначеЕсли ПоляРасшифровки.Найти(ПолеРасшифровки.Поле) <> Неопределено И ДанныеРасшифровки["СчетРасчетов"] <> Неопределено Тогда
			
			СчетаРБП = Новый Массив;
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаРБП, КлассификацияЗадолженности.СчетаУчетаРБП());
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаРБП, БухгалтерскийУчет.СчетаУчетаНазначенияИспользованияНМА());
			ЭтоСчетРБП = СчетаРБП.Найти(ДанныеРасшифровки["СчетРасчетов"])<> Неопределено;
			
			СчетаРасчетовПоАренде = ПланыСчетов.Хозрасчетный.СчетаРасчетовПоАренде();
			ЭтоСчетАренды = СчетаРасчетовПоАренде.Найти(ДанныеРасшифровки["СчетРасчетов"]) <> Неопределено;
			
			Если ЭтоСчетРБП Тогда
				
				Отборы = Новый Соответствие;
				Для Каждого ЭлементРасшифровки Из ДанныеРасшифровки Цикл
					ИмяПоляОтбора = ЭлементРасшифровки.Ключ;
					Если ИмяПоляОтбора = "СчетРасчетов" Тогда
						ИмяПоляОтбора = "Счет";
					ИначеЕсли ИмяПоляОтбора = "Субконто1Задолженности" Тогда
						ИмяПоляОтбора = "Субконто1";
					ИначеЕсли ИмяПоляОтбора = "Субконто2Задолженности" Тогда
						ИмяПоляОтбора = "Субконто2";
					ИначеЕсли ИмяПоляОтбора = "Субконто3Задолженности" Тогда
						ИмяПоляОтбора = "Субконто3";
					КонецЕсли;
					Равно = Новый Структура("ВидСравненияКомпоновкиДанных, Значение",
					                         ВидСравненияКомпоновкиДанных.Равно,
					                         ЭлементРасшифровки.Значение);
					Отборы.Вставить(ИмяПоляОтбора, Равно);
				КонецЦикла;
				
				ИмяОтчета = "Отчет.СправкаРасчетКлассификацияПоСрокамРасходовБудущихПериодов.ФормаОбъекта";
				ПараметрыРасшифровки = ЗаполнениеБухгалтерскойОтчетности.НастройкиРасшифровкиСправкиРасчетаКлассификацииЗадолженности(ПараметрыОтчета, ИмяОтчета, Отборы);
				
			ИначеЕсли ЭтоСчетАренды Тогда
				Отборы = Новый Соответствие;
				Для Каждого ЭлементРасшифровки Из ДанныеРасшифровки Цикл
					ИмяПоляОтбора = ЭлементРасшифровки.Ключ;
					Если ИмяПоляОтбора = "СчетРасчетов" Тогда
						Продолжить;
					ИначеЕсли ИмяПоляОтбора = "Субконто1Задолженности" Тогда
						ИмяПоляОтбора = "Контрагент";
					ИначеЕсли ИмяПоляОтбора = "Субконто2Задолженности" Тогда
						ИмяПоляОтбора = "ДоговорКонтрагента";
					Иначе
						Продолжить;
					КонецЕсли;
					
					Равно = Новый Структура("ВидСравненияКомпоновкиДанных, Значение",
					                         ВидСравненияКомпоновкиДанных.Равно,
					                         ЭлементРасшифровки.Значение);
					Отборы.Вставить(ИмяПоляОтбора, Равно);
				КонецЦикла;
					ИмяОтчета = "Отчет.СправкаРасчетКлассификацияПоСрокамАрендныхОбязательств.ФормаОбъекта";
					ПараметрыРасшифровки = ЗаполнениеБухгалтерскойОтчетности.НастройкиРасшифровкиСправкиРасчетаКлассификацииЗадолженности(ПараметрыОтчета, ИмяОтчета, Отборы);
				
			ИначеЕсли Не ПараметрыОтчета.ДетальныеЗаписи Тогда 
				
				Отборы = Новый Соответствие;
				Для Каждого ЭлементРасшифровки Из ДанныеРасшифровки Цикл
					Равно = Новый Структура("ВидСравненияКомпоновкиДанных, Значение",
					                         ВидСравненияКомпоновкиДанных.Равно,
					                         ЭлементРасшифровки.Значение);
					Отборы.Вставить(ЭлементРасшифровки.Ключ, Равно);
				КонецЦикла;
				
				ИмяОтчета = "Отчет.СправкаРасчетКлассификацияПоСрокамЗадолженности.ФормаОбъекта";
				ПараметрыРасшифровки = ЗаполнениеБухгалтерскойОтчетности.НастройкиРасшифровкиСправкиРасчетаКлассификацииЗадолженности(ПараметрыОтчета, ИмяОтчета, Отборы);
				ПараметрыРасшифровки.Отчет.ПараметрыФормы.ПользовательскиеНастройки.ДополнительныеСвойства.Вставить("ДетальныеЗаписи", Истина);
			КонецЕсли;
			
		ИначеЕсли ЗначениеЗаполнено(ПолеРасшифровки.Значение) И ОбщегоНазначения.ЭтоСсылка(ТипЗнч(ПолеРасшифровки.Значение)) Тогда
			ПараметрыРасшифровки.Вставить("ОткрытьОбъект", Истина);
			ПараметрыРасшифровки.Вставить("Значение",  ПолеРасшифровки.Значение);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПараметрыРасшифровки;
	
КонецФункции

// Конструктор коллекции, описывающий контекст и данные отчета
// При формировании отчета передается параметром согласно манифесту
//
// Возвращаемое значение:
//  Структура
//
Функция НовыйКонтекстФормированияОтчета() Экспорт 
	
	// Инициализация коллекции
	Контекст = Новый Структура;
	Контекст.Вставить("ИдентификаторОтчета");
	Контекст.Вставить("СинонимОтчета");
	
	Контекст.Вставить("СхемаКомпоновкиДанных");
	Контекст.Вставить("НастройкиКомпоновкиДанных");
	
	Контекст.Вставить("ДанныеРасшифровки");
	
	Контекст.Вставить("Организация");
	Контекст.Вставить("НачалоПериода");
	Контекст.Вставить("КонецПериода");
	Контекст.Вставить("КонецПериодаДата");
	Контекст.Вставить("ДетальныеЗаписи", Ложь);
	Контекст.Вставить("ВнешниеНаборыДанных", Новый Структура);
	
	Контекст.Вставить("ПредставлениеПериода");
	
	Контекст.Вставить("РежимРасшифровки",                  Ложь);
	Контекст.Вставить("ВключатьОбособленныеПодразделения", Ложь);
	Контекст.Вставить("ВыводитьЕдиницуИзмерения",          Ложь); // Соответствует флагу "Единица измерения" в форме справки-расчета на закладке "Оформление".
	Контекст.Вставить("ВыводитьЗаголовок",                 Ложь); // Соответствует флагу "Заголовок" в форме справки-расчета на закладке "Оформление".
	Контекст.Вставить("ВыводитьПодвал",                    Ложь); // Соответствует флагу "Подписи" в форме справки-расчета на закладке "Оформление".
	Контекст.Вставить("ОтветственноеЛицо");
	Контекст.Вставить("ОписаниеШапкиТаблиц");
	Контекст.Вставить("Организации", Новый Массив);

	Возврат Контекст;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ДобавитьПараметрВСхему(Схема, КомпоновщикНастроек, ИмяПараметра, ЗначениеПараметра)
	
	ПараметрКомпоновки = Схема.Параметры.Найти(ИмяПараметра);
	Если ПараметрКомпоновки = Неопределено Тогда
		ПараметрКомпоновки  = Схема.Параметры.Добавить();
		ПараметрКомпоновки.Имя      = ИмяПараметра;
		ПараметрКомпоновки.Значение = ЗначениеПараметра;
		ПараметрКомпоновки.Использование = ИспользованиеПараметраКомпоновкиДанных.Всегда;
	Иначе
		ПараметрКомпоновки.Значение = ЗначениеПараметра;
		БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, ПараметрКомпоновки.Имя, ЗначениеПараметра);
	КонецЕсли;
		
КонецПроцедуры

Функция СчетаОтбора(ЭлементыОтбора, Виды, СчетаРасчетов)
	
	СчетаРасчетовСОтбором = Новый Структура;
	Для Каждого ЭлементСчетов Из СчетаРасчетов Цикл
		СчетаРасчетовСОтбором.Вставить(ЭлементСчетов.Ключ, Новый Массив);
	КонецЦикла;
	СчетаРасчетовСОтбором.Вставить("ЕстьОтбор", Ложь);
		
	Счета = Новый Массив;
	Если ЗначениеЗаполнено(ЭлементыОтбора) Тогда
		ВидыСравнения = Новый Массив;
		ВидыСравнения.Добавить(ВидСравненияКомпоновкиДанных.ВСписке);
		ВидыСравнения.Добавить(ВидСравненияКомпоновкиДанных.ВСпискеПоИерархии);
		ВидыСравнения.Добавить(ВидСравненияКомпоновкиДанных.ВИерархии);
		ВидыСравнения.Добавить(ВидСравненияКомпоновкиДанных.Равно);
		
		Для Каждого ЭлементОтбора Из ЭлементыОтбора Цикл
			Если ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СчетРасчетов")
				И ВидыСравнения.Найти(ЭлементОтбора.ВидСравнения) <> Неопределено И ЭлементОтбора.Использование Тогда
				Если ТипЗнч(ЭлементОтбора.ПравоеЗначение) = Тип("СписокЗначений") Тогда
					Для Каждого СчетОтбора Из ЭлементОтбора.ПравоеЗначение Цикл
						Счета.Добавить(СчетОтбора.Значение);
					КонецЦикла;
				Иначе
					Счета.Добавить(ЭлементОтбора.ПравоеЗначение);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	СчетаОтбора = КлассификацияЗадолженности.СчетаВИерархии(Счета, Виды);
	
	Для Каждого ЭлементСчетов Из СчетаРасчетов Цикл
		Для Каждого Счет Из СчетаОтбора Цикл
			Если ЭлементСчетов.Значение.Найти(Счет) <> Неопределено Тогда
				СчетаРасчетовСОтбором[ЭлементСчетов.Ключ].Добавить(Счет);
				СчетаРасчетовСОтбором.ЕстьОтбор = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат СчетаРасчетовСОтбором;
	
КонецФункции

// Выводит шапку отчета.
//
// Параметры:
//  Результат - ТабличныйДокумент - табличный документ, в который выводится отчет
//  Контекст - см. НовыйКонтекстФормированияОтчета
//  КомпоновщикНастроек - КомпоновщикНастроекКомпоновкиДанных - описание связи настроек и схемы отчета
//
Процедура ВывестиШапкуОтчета(Результат, Контекст, КомпоновщикНастроек)
	
	Макет = ПолучитьОбщийМакет("ОбщиеОбластиСтандартногоОтчета");
	
	// Организация
	ОбластьВывода = Макет.ПолучитьОбласть("Организация");
	ОбластьВывода.Параметры.НазваниеОрганизации = БухгалтерскиеОтчетыВызовСервера.ПолучитьТекстОрганизация(
		Контекст.Организация,
		Контекст.ВключатьОбособленныеПодразделения,
		Контекст.КонецПериодаДата);
	Результат.Вывести(ОбластьВывода);
	
	// Название отчета
	ОбластьВывода = Макет.ПолучитьОбласть("ОбластьЗаголовок");
	ОбластьВывода.Параметры.ЗаголовокОтчета = ЗаголовокОтчета(Контекст);
	Результат.Вывести(ОбластьВывода);
	
	// Организация и название образуют заголовок
	ОбластьЗаголовка = Результат.Область(1, , Результат.ВысотаТаблицы);
	ОбластьЗаголовка.Имя = "Заголовок";
	
	// Единица измерения
	Если Контекст.Свойство("ВыводитьЕдиницуИзмерения")
		И Контекст.ВыводитьЕдиницуИзмерения Тогда
		// Единица измерения - рубль
		ОбластьВывода = Макет.ПолучитьОбласть("ОписаниеЕдиницыИзмерения");
		Результат.Вывести(ОбластьВывода);
	КонецЕсли; 
	
	// Отбор
	ТекстОтбор = Строка(КомпоновщикНастроек.Настройки.Отбор);
	
	Если Не ПустаяСтрока(ТекстОтбор) Тогда 
		ОбластьОписаниеНастроек = Макет.ПолучитьОбласть("ОписаниеНастроек");
		ОбластьОписаниеНастроек.Параметры.ИмяНастроекОтчета      = НСтр("ru = 'Отбор:'");
		ОбластьОписаниеНастроек.Параметры.ОписаниеНастроекОтчета = ТекстОтбор;
		
		Результат.Вывести(ОбластьОписаниеНастроек);
	КонецЕсли;
	
КонецПроцедуры

Функция ЗаголовокОтчета(Контекст)
	
	Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1 на %2", Контекст.СинонимОтчета, Контекст.ПредставлениеПериода);

КонецФункции

#Область МакетыЗаголовков

Процедура ДобавитьМакетыТаблиц(ОписаниеШапкиТаблиц, МакетКомпоновки, Контекст)
	
	Для Каждого ПервыйУровень Из МакетКомпоновки.Тело Цикл
		
		// Обходим элементы, выводимые на верхнем уровне.
		// Макеты каждой таблицы храним списком для дальнешей обработки заголовков и добавления граф
		Если ТипЗнч(ПервыйУровень) = Тип("ТаблицаМакетаКомпоновкиДанных") Тогда
			
			Макеты = Новый Соответствие;
			Если ЗначениеЗаполнено(ПервыйУровень.МакетШапки) Тогда
				Макеты.Вставить(ПервыйУровень.МакетШапки, ИмяГруппировка());
			КонецЕсли;

			ОписаниеШапки = ОписаниеШапкиТаблиц[ПервыйУровень.Имя];
			Если ОписаниеШапки <> Неопределено Тогда
				ОписаниеШапки.Макеты = Макеты;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбработатьМакетыТаблиц(МакетКомпоновки, ОписаниеШапки)
	
	Для Каждого ОписаниеМакетаОбласти Из ОписаниеШапки.Макеты Цикл
		
		ОписаниеМакета = МакетКомпоновки.Макеты.Найти(ОписаниеМакетаОбласти.Ключ);
		
		Если ОписаниеМакета = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЭталоннаяСтрока = ОписаниеМакета.Макет[0];
		
		Если ОписаниеМакетаОбласти.Значение <> ИмяИтогиГруппировки() Тогда
			// Добавляем новые строки с заголовками Таблиц для вывода в табличный документ
			ДобавитьСтрокуНадТаблицей(ОписаниеМакетаОбласти, ОписаниеМакета, ОписаниеШапки.ЗаголовокРаздела, ЭталоннаяСтрока);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьСтрокуНадТаблицей(ОписаниеМакетаОбласти, ОписаниеМакета, Заголовок, ЭталоннаяСтрока)
	
	Если Заголовок = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = ОписаниеМакета.Макет.Вставить(0,Тип("СтрокаТаблицыОбластиКомпоновкиДанных"));
	
	НоваяСтрока.ИдентификаторТаблицы = ЭталоннаяСтрока.ИдентификаторТаблицы;
	Если ОписаниеМакетаОбласти.Значение <> ИмяРесурсы() Тогда
		
		НоваяЯчейка = НоваяСтрока.Ячейки.Добавить();
		Поле = НоваяЯчейка.Элементы.Добавить(Тип("ПолеОбластиКомпоновкиДанных"));
		Поле.Значение = Заголовок.Текст;
		
		Для Каждого Параметр Из Заголовок.ПараметрыОформления Цикл
			НоваяЯчейка.Оформление.УстановитьЗначениеПараметра(
				Параметр.Ключ,
				Параметр.Значение);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

