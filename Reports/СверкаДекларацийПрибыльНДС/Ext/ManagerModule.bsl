#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ПрограммныйИнтерфейс

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("СформироватьОтчет", Истина);
	
КонецПроцедуры

#Область РасчетПоказатеей

// Параметры расчета показателей отчета
// 
// Возвращаемое значение:
//   - Структура - Параметры расчета
//
Функция ПараметрыРасчета() Экспорт
	
	ТекДата = ТекущаяДата();
	
	Результат = Новый Структура;
	Результат.Вставить("НачалоПериода", КонецГода(ТекДата));  
	Результат.Вставить("КонецПериода", КонецГода(ТекДата));  
	Результат.Вставить("Организация", Неопределено);
	
	Возврат Результат;
	
КонецФункции

// Функция - Рассчитать
// Рассчитывает показатели отчета
//
// Параметры:
//  ПараметрыРасчета - см. ПараметрыРасчета
// 
// Возвращаемое значение:
//  - см. НовыйТаблицаПоказателей
//
Функция Рассчитать(ПараметрыРасчета) Экспорт
	
	// Обработка расширенного периода
	ПараметрыРасчета = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыРасчета);
	ПараметрыРасчета.НачалоПериода = ?(
		Год(ПараметрыРасчета.НачалоПериода) <> Год(ПараметрыРасчета.КонецПериода),
		НачалоГода(ПараметрыРасчета.КонецПериода),
	   	ПараметрыРасчета.НачалоПериода
	);
	
	Возврат ПоказателиОтчета(ПараметрыРасчета);

КонецФункции

// Функция - Расшифровать показатель
//
// Параметры:
//  ПараметрыРасчета - см. ПараметрыРасчета
//  НомерПоказателя - Число
// 
// Возвращаемое значение:
//   - см. НовыйТаблицаПоказателей, Неопределено
//
Функция РасшифроватьПоказатель(ПараметрыРасчета, НомерПоказателя) Экспорт
	
	ОписаниеПоказателя = ОписаниеПоказателей(НомерПоказателя)[0];
	Если ЭтоПоказательДекларации(НомерПоказателя) Тогда
		Показатели = ?(НомерПоказателя < 2000, ПоказателиНП(ПараметрыРасчета), ПоказателиНДС(ПараметрыРасчета));
		Возврат Показатели.Скопировать(Показатели.НайтиСтроки(Новый Структура("Номер", НомерПоказателя)));
	ИначеЕсли ОписаниеПоказателя.Запрос <> Неопределено Тогда
		Запрос = ОписаниеПоказателей(НомерПоказателя)[0].Запрос;
		ДобавитьРасшифровку(Запрос);
		УстановитьПараметрыЗапроса(Запрос, ПараметрыРасчета);
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
		
КонецФункции

// Функция - Имеет расшифровку
//
// Параметры:
//  НомерПоказателя	 - Число
// 
// Возвращаемое значение:
//   - Булево
//
Функция ИмеетРасшифровку(НомерПоказателя) Экспорт
	
	ОписаниеПоказателя = ОписаниеПоказателей(НомерПоказателя)[0];
	Возврат ЭтоПоказательДекларации(НомерПоказателя) ИЛИ ОписаниеПоказателя.Запрос <> Неопределено;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ПоляРасшифровкиСКД(ЭлементРасшифровки, Результат = Неопределено) Экспорт
	
	Если Результат = Неопределено Тогда
		Результат = Новый Соответствие;
	КонецЕсли;
	
	Если ТипЗнч(ЭлементРасшифровки) <> Тип("ЭлементРасшифровкиКомпоновкиДанныхГруппировка") Тогда
		ПоляРасшифровки = ЭлементРасшифровки.ПолучитьПоля();
		Для Каждого ПолеРасшифровки Из ПоляРасшифровки Цикл
			Результат.Вставить(ПолеРасшифровки.Поле, ПолеРасшифровки.Значение);
		КонецЦикла;
	КонецЕсли; 
	
	Для Каждого ЭлементРодитель Из ЭлементРасшифровки.ПолучитьРодителей() Цикл
		ПоляРасшифровкиСКД(ЭлементРодитель, Результат);
	КонецЦикла;
	
	Возврат Новый ФиксированноеСоответствие(Результат);
	
КонецФункции

Функция ПолучитьТекстЗаголовка(ПараметрыОтчета) Экспорт 
	
	Заголовок = ?(
		ЗначениеЗаполнено(ПараметрыОтчета.ПоляРасшифровки),
		ПараметрыОтчета.ПоляРасшифровки["Представление"],
		Метаданные.Отчеты.СверкаДекларацийПрибыльНДС.Синоним
	);	
		
	Возврат СтрШаблон(
		НСтр("ru = '%1%2'"),
		Заголовок,
		БухгалтерскиеОтчетыКлиентСервер.ПолучитьПредставлениеПериода(
			ПараметрыОтчета.НачалоПериода, ПараметрыОтчета.КонецПериода)
	);
	
КонецФункции

Функция СформироватьОтчет(ПараметрыКомпоновки) Экспорт
	
	ДокументРезультат = Новый ТабличныйДокумент;
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	
	БухгалтерскиеОтчетыВызовСервера.ВывестиЗаголовокОтчета(
		ПараметрыКомпоновки.ПараметрыОтчета, КомпоновщикНастроек, ДокументРезультат);
	ДокументРезультат.Область("R1C1").Текст = СокрЛП(ДокументРезультат.Область("R1C1").Текст);
	ДокументРезультат.Область("R1C1:R1C11").Объединить();
	
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;	
	СкомпоноватьРезультатОтчета(ПараметрыКомпоновки, ДокументРезультат, ДанныеРасшифровки);
	
	ВывестиПримечания(ДокументРезультат, ДанныеРасшифровки);
	
	Возврат Новый Структура("Результат, ДанныеРасшифровки", ДокументРезультат, ДанныеРасшифровки);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ФормированиеОтчета

Процедура СкомпоноватьРезультатОтчета(ПараметрыКомпоновки, ДокументРезультат, ДанныеРасшифровки)
		
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		
	МакетКомпоновки = КомпоновщикМакета.Выполнить(
		ПараметрыКомпоновки.СКД, ПараметрыКомпоновки.Настройки, ДанныеРасшифровки);
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки,
		НаборыДанныхСКД(ПараметрыКомпоновки), ДанныеРасшифровки, Истина);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);

КонецПроцедуры 

// Выводит примечания из описания показателя, см. ОписаниеПоказателей
//
// Параметры:
//  ТабДок - ТабличныйДокумент - документ результат
//  ДанныеРасшифровки - ДанныеРасшифровкиКомпоновкиДанных - данные расшифровки СКД 
//
Процедура ВывестиПримечания(ТабДок, ДанныеРасшифровки)
	
	Для Строка = 1 По ТабДок.ВысотаТаблицы Цикл
		
		Для Колонка = 1 По ТабДок.ШиринаТаблицы Цикл
			
			Ячейка = ТабДок.Область(Строка, Колонка);
			Если ТипЗнч(Ячейка.Расшифровка) <> Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			ЭлементРасшифровки = ДанныеРасшифровки.Элементы[Ячейка.Расшифровка];
			ПоляРасшифровки = Отчеты.СверкаДекларацийПрибыльНДС.ПоляРасшифровкиСКД(ЭлементРасшифровки);

			ТекущееПоле = ЭлементРасшифровки.ПолучитьПоля();
			ТекущееПоле = ?(ТекущееПоле.Количество() = 0, "", ТекущееПоле[0].Поле);
			
			Если ТекущееПоле = "Показатель" И ЗначениеЗаполнено(ПоляРасшифровки["Примечание"]) Тогда
				Ячейка.Примечание.Текст = ПоляРасшифровки["Примечание"];
			КонецЕсли;
			
			Если СтрНайти(Ячейка.Формат,"НеАктуальный") > 0 Тогда
				Ячейка.Примечание.Текст = НСтр("ru='Показатель устарел, необходимо перезаполнить декларацию'");
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры

Функция НаборыДанныхСКД(ПараметрыКомпоновки)
	
	Если ПараметрыКомпоновки.Свойство("НаборыДанных") Тогда
		Возврат ПараметрыКомпоновки.НаборыДанных;
	КонецЕсли;
	
	ПараметрыОтчета = ПараметрыКомпоновки.ПараметрыОтчета;
	Если ЗначениеЗаполнено(ПараметрыОтчета.ПоляРасшифровки) Тогда	
		ПоляРасшифровки = ПараметрыОтчета.ПоляРасшифровки;
		Данные = РасшифроватьПоказатель(ПараметрыОтчета, ПоляРасшифровки["Номер"]);  					
		Если Данные.Колонки.Найти("Квартал") <> Неопределено Тогда
			Данные = Данные.Скопировать(
				Данные.НайтиСтроки(Новый Структура("Квартал", ПоляРасшифровки["Квартал"])));	
		КонецЕсли;  
	Иначе
	  	Данные = Рассчитать(ПараметрыОтчета);	
	КонецЕсли;
	
	Возврат Новый Структура("Данные", Данные);
	
КонецФункции

#КонецОбласти

#Область РасчетПоказателей

Функция ПоказателиОтчета(ПараметрыРасчета)

	Результат = НовыйТаблицаПоказателей();
	
	Источники = Новый Массив;
	Источники.Добавить(ПоказателиНП(ПараметрыРасчета));
	Источники.Добавить(ПоказателиНДС(ПараметрыРасчета));
	Источники.Добавить(ПоказателиРазниц(ПараметрыРасчета));
	
	Для Каждого Источник Из Источники Цикл
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Источник, Результат);
	КонецЦикла;
	
	ДобавитьИтогиРазниц(ПараметрыРасчета, Результат);
	
	Возврат Результат;
	
КонецФункции

Функция ПоказателиНП(ПараметрыРасчета)
	
	Параметры = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыРасчета);
	Параметры.НачалоПериода = НачалоГода(ПараметрыРасчета.НачалоПериода);
	Декларации = ПоследниеДекларации(Параметры, "Прибыль");
	
	Показатели = НовыйПоказателиДеклараций();
	ОписаниеПоказателей = ОписаниеПоказателей("1(?!0)...");
	
	Кварталы = КварталыПериода(ПараметрыРасчета);
	Для Каждого Квартал Из Кварталы Цикл  
	
		ДобавитьПоказателиНП(Показатели, ОписаниеПоказателей, ПараметрыРасчета, Квартал.Номер, Декларации);
	
		Если Кварталы.Количество() = 1 И Квартал.Номер > 1 Тогда 
	
			ДобавитьПоказателиНП(Показатели, ОписаниеПоказателей, ПараметрыРасчета, Квартал.Номер, Декларации, Ложь);
	
		КонецЕсли;
	
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		ИтогПоКварталам(ПараметрыРасчета, Показатели, ОписаниеПоказателей("1000")[0]), Показатели);
	
	Возврат Показатели;
	
КонецФункции

// Рассчитывает показатели НДС нарастающим итогом, с расшифровкой по декларациям
//
// Параметры:
//  ПараметрыРасчета - см. ПараметрыРасчета - параметры расчета показаталей 
// 
// Возвращаемое значение:
//   - см. НовыйТаблицаПоказателей - показатели декларации
//
Функция ПоказателиНДС(ПараметрыРасчета)
	
	Декларации = ПоследниеДекларации(ПараметрыРасчета, "НДС");
	Показатели = НовыйПоказателиДеклараций();
	
	ОписаниеПоказателей = ОписаниеПоказателей("2[1-9]00");
	
	Кварталы = КварталыПериода(ПараметрыРасчета);
	КешПоказателей = Новый Соответствие; 
	// КешПоказателей - Соответствие[(Квартал, Показатель), Структура("Значение, НеАктуальный")]
	// кешируем показатели по ранее рассчитанным периодам 
	
	Для Каждого Квартал Из Кварталы Цикл
		
		КварталНачало = ?(Кварталы.Количество()=1, Квартал.Номер, 1); 
		
		ГруппаОрганизаций = Новый СписокЗначений();
		ГруппаОрганизаций.ЗагрузитьЗначения(Новый Массив(Справочники.Организации.ВсяОрганизация(ПараметрыРасчета.Организация, Квартал.Период))); 
		
		Декларация = Декларации.Найти(Квартал.Номер,"Квартал");     
		ДатаПодписи = ?(ЗначениеЗаполнено(Декларация), Декларация.ДатаПодписи, Неопределено);
		
		ПоказателиИБ = УчетНДСФормированиеОтчетности.РассчитатьПоказатели(
			Квартал.Период, ПараметрыРасчета.Организация, ГруппаОрганизаций,,ДатаПодписи
		);
			
		Для Каждого ОписаниеПоказателя Из ОписаниеПоказателей Цикл
			
			ЗначениеПоказателя = ЗначениеПоказателяНДС(Декларации.Найти(Квартал.Номер, "Квартал"), ПоказателиИБ, ОписаниеПоказателя);
			КешПоказателей.Вставить(СтрШаблон("%1_%2", Квартал.Номер, ОписаниеПоказателя.Номер), ЗначениеПоказателя);
			
			Для КварталОтчета = КварталНачало По Квартал.Номер Цикл 
				
				ЗначениеПоказателя = КешПоказателей[СтрШаблон("%1_%2", КварталОтчета, ОписаниеПоказателя.Номер)];
				Если Не (ЗначениеЗаполнено(ЗначениеПоказателя.Значение) ИЛИ ЗначениеПоказателя.НеАктуальный) Тогда
					Продолжить;
				КонецЕсли;
	
				Декларация = Декларации.Найти(КварталОтчета,"Квартал");
				Показатель = Показатели.Добавить();
				ЗаполнитьЗначенияСвойств(Показатель, ОписаниеПоказателя); 
				Показатель.Квартал = Квартал.Номер;   
				Показатель.ДатаОкончания = КварталКонец(Квартал.Период, КварталОтчета);
				Показатель.ДатаНачала = НачалоКвартала(Показатель.ДатаОкончания);
				ЗаполнитьЗначенияСвойств(Показатель, ЗначениеПоказателя);	
				Показатель.Регистратор = ?(ЗначениеЗаполнено(Декларация), Декларация.Ссылка, Неопределено);
				
			КонецЦикла;
			
		КонецЦикла;
			
	КонецЦикла;
			
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		ИтогПоКварталам(ПараметрыРасчета, Показатели, ОписаниеПоказателей(2000)[0]), Показатели);
	
	Возврат Показатели;
	
КонецФункции

Функция ПоказателиРазниц(ПараметрыРасчета)
	
	Результат = НовыйТаблицаПоказателей();
	
	РазницыПрибыль = РазницыПоКварталам(ПараметрыРасчета, "31(?!00)..");
	РазницыНДС = РазницыПоКварталам(ПараметрыРасчета, "32(?!00)..");
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РазницыПрибыль, Результат);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РазницыНДС, Результат);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		ИтогПоКварталам(ПараметрыРасчета, РазницыПрибыль, ОписаниеПоказателей("3100")[0]),
		Результат);

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		ИтогПоКварталам(ПараметрыРасчета, РазницыНДС, ОписаниеПоказателей("3200")[0]),
		Результат);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

// Для расшифровки показателей разниц запрос должен выполнить следующие условия:
// 1. должен содержать следующие поля:
// - Номер - Число - номер показателя
// - Период - Дата - конец квартала
// - Значение - Число - сумма разницы
// 2. источник результирующего пакета должен иметь поле <Регистратор>, для расшифровки по документам
#Область Запросы

Функция ЗапросДекларации(ВидОтчета)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	
	"ВЫБРАТЬ
	|	РегламентированныйОтчет.Вид КАК Вид,
	|	РегламентированныйОтчет.ДатаНачала КАК ДатаНачала,
	|	РегламентированныйОтчет.ДатаОкончания КАК ДатаОкончания,
	|	РегламентированныйОтчет.Ссылка КАК Ссылка,
	|	РегламентированныйОтчет.Дата КАК Дата,
	|	РегламентированныйОтчет.ДанныеОтчета КАК ДанныеОтчета,
	|	КВАРТАЛ(РегламентированныйОтчет.ДатаОкончания) КАК Квартал,
	|	ВЫБОР
	|		КОГДА РегламентированныйОтчет.Вид = 0
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ РегламентированныйОтчет.ДатаПодписи
	|	КОНЕЦ КАК ДатаПодписи
	|ИЗ
	|	Документ.РегламентированныйОтчет КАК РегламентированныйОтчет
	|ГДЕ
	|	РегламентированныйОтчет.ПометкаУдаления = ЛОЖЬ
	|	И РегламентированныйОтчет.Организация = &Организация
	|	И РегламентированныйОтчет.ИсточникОтчета = &ИсточникОтчета
	|	И РегламентированныйОтчет.ДатаОкончания МЕЖДУ &НачалоПериода И &КонецПериода";

	Запрос.УстановитьПараметр("ИсточникОтчета", СтрШаблон("%1%2", "РегламентированныйОтчет", ВидОтчета)); 
	
	Возврат Запрос;
	
КонецФункции

