Функция ПоследниеДекларации(ПараметрыРасчета, ВидОтчета)
	
	Запрос = ЗапросДекларации(ВидОтчета);
	УстановитьПараметрыЗапроса(Запрос, ПараметрыРасчета);	
	Результат = Запрос.Выполнить().Выгрузить();  
	
	Типы = Новый Массив;
	Результат.Колонки.Добавить("Данные");  
	Результат.Колонки.Добавить("ДекларацияПодразделения");
	
	Для Каждого Декларация Из Результат Цикл
		Данные = Декларация.ДанныеОтчета.Получить();  
		Декларация.Данные = Данные; 
		Декларация.ДекларацияПодразделения = Отчеты.РегламентированныйОтчетПрибыль.ЭтоДекларацияПоНалогуНаПрибыльОбособленногоПодразделения(Декларация.Ссылка);
	КонецЦикла; 	
	Результат.Сортировать("ДекларацияПодразделения, Квартал, ДатаОкончания Убыв, Вид Убыв, ДатаПодписи");  
	
	Последние = Новый Массив;
	Для Каждого Квартал Из ОбщегоНазначенияКлиентСервер.СвернутьМассив(Результат.ВыгрузитьКолонку("Квартал")) Цикл 
		Последние.Добавить(НайтиСтроку(Результат,Новый Структура("Квартал", Квартал)));		
	КонецЦикла;
	
	Возврат Результат.Скопировать(Последние);
	
КонецФункции 

Функция НайтиСтроку(ТаблицаЗначений, Отбор) 
		
	Для Каждого Строка Из ТаблицаЗначений Цикл
		СоответствуетОтбору = Истина;	
		Для Каждого КлючЗначение Из Отбор Цикл
			Если КлючЗначение.Значение <> Строка[КлючЗначение.Ключ] Тогда
				СоответствуетОтбору = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла; 
		Если СоответствуетОтбору Тогда
			Возврат Строка;
		КонецЕсли;
	КонецЦикла;   
	
	Возврат Неопределено;
	
КонецФункции

