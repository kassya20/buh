Функция ЗначениеПоказателяНП(Декларация, ПоказателиИБ, ОписаниеПоказателя)
	
	// Получаем значение показателя налога на прибыль на основе данных декларации, 
	// текущих показателей базы и описания показателя
	
	Результат = Новый Структура("Значение, НеАктуальный", 0, Ложь); 
	Если ПоказателиИБ = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Значение = 0;
	ЗначениеИБ = ПоказателиИБ[ОписаниеПоказателя.Имя];
	
	Если ЗначениеЗаполнено(Декларация) Тогда
		ЗначениеРаздела = РегламентированныйОтчетПрибыль.ЗначениеМногоуровневогоРаздела(Декларация.Данные, "Лист02", ОписаниеПоказателя.КодМакета); 
		Если ЗначениеЗаполнено(ЗначениеРаздела) Тогда
			Значение = ЗначениеРаздела;	
		КонецЕсли;
	Иначе
		Значение = ЗначениеИБ;
	КонецЕсли; 
	
	Результат.Значение = Значение;  
	Разница = Значение - ЗначениеИБ; 
	Результат.НеАктуальный = Разница >= 1 ИЛИ Разница <=-1;  
		
	Возврат Результат;
	
КонецФункции

Функция ЗначениеПоказателяНДС(Декларация, ПоказателиИБ, ОписаниеПоказателя)
	
	// Получаем значение показателя НДС на основе данных декларации, 
	// текущих показателей базы и описания показателя
	
	Результат = Новый Структура("Значение, НеАктуальный", 0 , Ложь);	
	Раздел = ПоказателиИБ[ОписаниеПоказателя.Раздел];               
	Если Не Раздел.Свойство(ОписаниеПоказателя.КодМакета) Тогда
		Возврат Результат;	
	КонецЕсли;              
		
	Ставка = СтрРазделить(ОписаниеПоказателя.Имя,"_");
	ВТомЧислеНДС = Ставка.Количество() > 2;

	Значение = 0; 
	ЗначениеИБ = Раздел[ОписаниеПоказателя.КодМакета];

	Если ВТомЧислеНДС Тогда
		ЗначениеИБ = ЗначениеИБ - ЗначениеИБ / Число(Ставка[2]) * Число(Ставка[1]);		
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Декларация) Тогда 
		Попытка   
			ИмяРаздела = СтрШаблон("%1%2","ПолеТабличногоДокумента", ОписаниеПоказателя.Раздел);
			Значение = Декларация.Данные.ПоказателиОтчета[ИмяРаздела][ОписаниеПоказателя.КодМакета];  
			Если ВТомЧислеНДС Тогда
				КодНДС = Лев(ОписаниеПоказателя.КодМакета, СтрДлина(ОписаниеПоказателя.КодМакета) - 1) + "5";	
				ЗначениеНДС =  Декларация.Данные.ПоказателиОтчета[ИмяРаздела][КодНДС];
				Значение = Значение - ЗначениеНДС;
			КонецЕсли;
		Исключение   
			ЗаписьЖурналаРегистрации(
				"ЗначениеПоказателяНДС", 
				УровеньЖурналаРегистрации.Ошибка,
				Метаданные.Отчеты.СверкаДекларацийПрибыльНДС,,
				"Не удалось получить значение декларации");
		КонецПопытки;
	Иначе
		Значение = ЗначениеИБ;
	КонецЕсли;
	
	Результат.Значение = Значение;  
	Разница = Значение - ЗначениеИБ;	  
	Результат.НеАктуальный = Разница >= 1 ИЛИ Разница <=-1;
	
	Возврат Результат;
	
КонецФункции

