	Результат.Колонки.Добавить("Номер", ТипЧисло);
	Результат.Колонки.Добавить("Раздел", ТипСтрока);
	Результат.Колонки.Добавить("КодМакета", ТипСтрока);
	Результат.Колонки.Добавить("Примечание", ТипСтрока);

	Результат.Колонки.Добавить("НеАктуальный", ТипБулево);
	Результат.Колонки.Добавить("Значение", ТипЧисло);
