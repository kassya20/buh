	// НДС по расчетным ставкам извлекаем из значения, делаем это в отчете,
	// так как алгоритм заполнения контейнера не рассчитывает значение суммы НДС
	// см.ЗначениеПоказателяНДС
	
	Результат.Колонки.Добавить("Регистратор");
	Результат.Колонки.Добавить("ДатаНачала");
	Результат.Колонки.Добавить("ДатаОкончания");

