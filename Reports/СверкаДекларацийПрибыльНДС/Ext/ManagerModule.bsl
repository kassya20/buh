Функция ЗапросВнереализационныеДоходы()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ПрочиеДоходыИРасходы.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ СтатьиДоходовРеализации
	|ИЗ
	|	Справочник.ПрочиеДоходыИРасходы КАК ПрочиеДоходыИРасходы
	|ГДЕ
	|	ПрочиеДоходыИРасходы.ВидПрочихДоходовИРасходов В(&ВидыДоходовРеализации)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОбороты.СуммаНУОборотКт КАК Значение,
	|	ХозрасчетныйОбороты.Период КАК Период,
	|	3102 КАК Номер
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			Квартал,
	|			Счет В (&Счета),
	|			ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрочиеДоходыИРасходы),
	|			Организация В (&Организации)
	|				И НЕ Субконто1 В
	|						(ВЫБРАТЬ
	|							СтатьиДоходовРеализации.Ссылка КАК Ссылка
	|						ИЗ
	|							СтатьиДоходовРеализации КАК СтатьиДоходовРеализации),
	|			,
	|			) КАК ХозрасчетныйОбороты";
	
	
	// Исходим из того что внереализационные доходы (Кт 91.01) в целом не облагаются НДС за исключением реализации:
	// необлагаемые НДС реализации 91.01 получаем из регистра НДС продажи в соответствующем показателе отчета,
	// всю остальную реализацию облагаемую как НДС так и налогом на прибыль исключаем данным фильтром,
	// таким образом остаются внереализационные доходы необлагаемые НДС, и отдельно реализация без НДС
	
	ВидыДоходовРеализации = Новый Массив;
	ВидыДоходовРеализации.Добавить(Перечисления.ВидыПрочихДоходовИРасходов.РеализацияПрочегоИмущества);
	ВидыДоходовРеализации.Добавить(Перечисления.ВидыПрочихДоходовИРасходов.РеализацияОсновныхСредств);
	ВидыДоходовРеализации.Добавить(Перечисления.ВидыПрочихДоходовИРасходов.РеализацияНематериальныхАктивов);
	ВидыДоходовРеализации.Добавить(Перечисления.ВидыПрочихДоходовИРасходов.РеализацияОбъектовСтроительства);
	Запрос.УстановитьПараметр("ВидыДоходовРеализации", ВидыДоходовРеализации);
	
	Счета = Новый Массив;
	Счета.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеДоходы);
	Запрос.УстановитьПараметр("Счета", Счета);
	
	Возврат Запрос;
	
КонецФункции

