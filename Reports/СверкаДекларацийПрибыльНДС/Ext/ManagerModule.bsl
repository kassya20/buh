Функция РазницыПоКварталам(ПараметрыРасчета, ШаблонНомера) 

	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	1 КАК Номер
	|ПОМЕСТИТЬ Кварталы
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	3
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	4
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Разницы.Период КАК Период,
	|	Разницы.Значение КАК Значение,
	|	Разницы.Номер КАК Номер
	|ПОМЕСТИТЬ Разницы
	|ИЗ
	|	&Разницы КАК Разницы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Разницы.Значение) КАК Значение,
	|	Разницы.Номер КАК Номер,
	|	Кварталы.Номер КАК Квартал
	|ИЗ
	|	Разницы КАК Разницы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Кварталы КАК Кварталы
	|		ПО (Кварталы.Номер >= КВАРТАЛ(Разницы.Период))
	|ГДЕ
	|	Кварталы.Номер >= КВАРТАЛ(&НачалоПериода)
	|	И Кварталы.Номер <= КВАРТАЛ(&КонецПериода)
	|
	|СГРУППИРОВАТЬ ПО
	|	Разницы.Номер,
	|	Кварталы.Номер";      
	
	УстановитьПараметрыЗапроса(Запрос,ПараметрыРасчета);
	Запрос.УстановитьПараметр("Разницы", РазницыПоПериодам(ПараметрыРасчета, ШаблонНомера));
	Разницы = Запрос.Выполнить().Выгрузить();
	
	Показатели = НовыйТаблицаПоказателей();
	
	ОписаниеПоказателей = ОписаниеПоказателей();
	Для Каждого Разница Из Разницы Цикл
		Показатель = Показатели.Добавить();
		ЗаполнитьЗначенияСвойств(Показатель, ОписаниеПоказателей.Найти(Разница.Номер, "Номер"));
		ЗаполнитьЗначенияСвойств(Показатель, Разница);
	КонецЦикла;
	
	Возврат Показатели;
	
КонецФункции

Функция РазницыПоПериодам(ПараметрыРасчета, ШаблонНомера) 

	ОписаниеПоказателей = ОписаниеПоказателей(ШаблонНомера);
	
	Результат = Неопределено;
	Для Каждого ОписаниеПоказателя Из ОписаниеПоказателей Цикл 
		
		Запрос = ОписаниеПоказателя.Запрос;
		Если Запрос = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		УстановитьПараметрыЗапроса(Запрос, ПараметрыРасчета);
		
		Разницы = Запрос.Выполнить().Выгрузить();
		Если Результат = Неопределено Тогда
			Результат = Разницы;
			Продолжить;
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Разницы, Результат);	
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура УстановитьПараметрыЗапроса(Запрос, ПараметрыРасчета)

	Запрос.УстановитьПараметр("Организация", ПараметрыРасчета.Организация);
	Запрос.УстановитьПараметр("Организации", Справочники.Организации.ВсяОрганизация(ПараметрыРасчета.Организация, ПараметрыРасчета.КонецПериода));
	Запрос.УстановитьПараметр("НачалоПериода", ПараметрыРасчета.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ПараметрыРасчета.КонецПериода);

КонецПроцедуры

Функция КварталыПериода(ПараметрыРасчета)

	Результат = Новый Массив();
	КварталНачало = Месяц(КонецКвартала(ПараметрыРасчета.НачалоПериода)) / 3;
	КварталКонец = Месяц(КонецКвартала(ПараметрыРасчета.КонецПериода)) / 3;
	
	Для Квартал = КварталНачало По КварталКонец Цикл
		Результат.Добавить(Новый Структура("Номер, Период", Квартал, КварталКонец(ПараметрыРасчета.НачалоПериода,Квартал)));
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ИтогПоКварталам(ПараметрыРасчета, Показатели, ОписаниеПоказателя)
	
	Результат = НовыйТаблицаПоказателей();
	
	Для Каждого Квартал Из КварталыПериода(ПараметрыРасчета) Цикл
		НовыйПоказатель = Результат.Добавить();	 
		ЗаполнитьЗначенияСвойств(НовыйПоказатель, ОписаниеПоказателя);
		НовыйПоказатель.Квартал = Квартал.Номер;
		Для Каждого Показатель  Из Показатели Цикл 
			Если Показатель.Квартал = НовыйПоказатель.Квартал Тогда
				НовыйПоказатель.Значение = НовыйПоказатель.Значение + Показатель.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьИтогиРазниц(ПараметрыРасчета, Показатели)
	
	ПоказателиДеклараций = Показатели.Скопировать(Показатели.НайтиСтроки(Новый Структура("Уровень",1)));  
	
	СтрокиНДС = ПоказателиДеклараций.НайтиСтроки(Новый Структура("Номер",2000));
	Для Каждого Строка Из СтрокиНДС Цикл
		Строка.Значение = -Строка.Значение;
	КонецЦикла;		
	РазницыИтого = ИтогПоКварталам(ПараметрыРасчета, ПоказателиДеклараций, ОписаниеПоказателей(3000)[0]);		
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РазницыИтого,Показатели);
	
	ОшибкиПротиворечия = ОписаниеПоказателей(3300)[0];
	Для Каждого Разница Из РазницыИтого Цикл
		Показатель = Показатели.Добавить();	
		ЗаполнитьЗначенияСвойств(Показатель, ОшибкиПротиворечия);
		Показатель.Квартал = Разница.Квартал;    
		РазницаПрибыль = Показатели.НайтиСтроки(Новый Структура("Номер, Квартал", 3100, Разница.Квартал));
		РазницаНДС = Показатели.НайтиСтроки(Новый Структура("Номер, Квартал", 3200, Разница.Квартал));
		Показатель.Значение = Разница.Значение - РазницаПрибыль[0].Значение + РазницаНДС[0].Значение;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьРасшифровку(Запрос, ПараметрыИсточника = Неопределено, ВыбираемыеПоля = Неопределено)
	
	Если ПараметрыИсточника = Неопределено Тогда
		ПараметрыИсточника = Новый Соответствие;
		ПараметрыИсточника.Вставить("Квартал","Регистратор");
	КонецЕсли;
	
	Если ВыбираемыеПоля = Неопределено Тогда
		ВыбираемыеПоля = Новый Соответствие;
		ВыбираемыеПоля.Вставить("Регистратор", "Регистратор");
	КонецЕсли;
	
	ТочкаЗапроса = СхемыЗапросов.НайтиЗапросРезультата(Запрос.Текст);
	Источник = ТочкаЗапроса.Запрос.Операторы[0].Источники[0].Источник;
	
	Для Каждого ПараметрИсточника Из ПараметрыИсточника Цикл
		
		Если ТипЗнч(ПараметрИсточника.Ключ) = Тип("Число") Тогда 
			Параметр = Источник.Параметры[ПараметрИсточника.Ключ];
		Иначе
			Параметр = Источник.Параметры.Найти(ПараметрИсточника.Ключ);
		КонецЕсли;
		Если Параметр = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Параметр.Выражение = Новый ВыражениеСхемыЗапроса(ПараметрИсточника.Значение);
		
	КонецЦикла;  
	
	Оператор = ТочкаЗапроса.Запрос.Операторы[0];
	Источник = Оператор.Источники[0].Источник.Псевдоним;  
	
	Для Каждого ВыбираемоеПоле Из ВыбираемыеПоля Цикл
		
		ИмяПоля = СтрШаблон("%1.%2", Источник, ВыбираемоеПоле.Ключ); 
		Оператор.ВыбираемыеПоля.Добавить(ИмяПоля);
				
	КонецЦикла;
	
	Запрос.Текст = ТочкаЗапроса.Схема.ПолучитьТекстЗапроса();
	
КонецПроцедуры

Функция КварталКонец(Период, НомерКвартала) 
	
	Возврат КонецКвартала(ДобавитьМесяц(НачалоГода(Период), (НомерКвартала - 1) * 3));
	
КонецФункции

Процедура ДобавитьПоказателиНП(Показатели, ОписаниеПоказателей, ПараметрыРасчета, КварталПоказателя, Декларации, Текущий = Истина)

	КварталДекларации = ?(Текущий, КварталПоказателя, КварталПоказателя - 1);
	Декларация = Декларации.Найти(КварталДекларации, "Квартал"); 

	ПараметрыПоказателя = Новый Структура("ДатаНачала, Квартал, ДатаОкончания, Регистратор",
		НачалоГода(ПараметрыРасчета.НачалоПериода), КварталПоказателя);
	ПараметрыПоказателя.ДатаОкончания = КварталКонец(ПараметрыПоказателя.ДатаНачала, КварталДекларации);
	ПараметрыПоказателя.Регистратор = ?(ЗначениеЗаполнено(Декларация), Декларация.Ссылка, Неопределено);
	
	КонтекстРасчета = НалогНаПрибыльДекларация.НовыйКонтекстРасчета(ПараметрыРасчета.Организация, ПараметрыПоказателя.ДатаОкончания); 
	Если КонтекстРасчета = Неопределено Тогда
		ПоказателиИБ = Неопределено;
	Иначе
		ПоказателиИБ = НалогНаПрибыльДекларация.РассчитатьПоказатели(КонтекстРасчета, ОписаниеПоказателей.ВыгрузитьКолонку("Имя"));
	КонецЕсли;
	
	Для Каждого ОписаниеПоказателя Из ОписаниеПоказателей Цикл
	
		Показатель = Показатели.Добавить();  
		ЗаполнитьЗначенияСвойств(Показатель, ОписаниеПоказателя);
		ЗаполнитьЗначенияСвойств(Показатель, ПараметрыПоказателя);
		
		ЗаполнитьЗначенияСвойств(Показатель, ЗначениеПоказателяНП(Декларация, ПоказателиИБ, ОписаниеПоказателя));
		Если Не Текущий Тогда 
			Показатель.Значение = -Показатель.Значение;
		КонецЕсли;   
	
	КонецЦикла;
	
КонецПроцедуры

