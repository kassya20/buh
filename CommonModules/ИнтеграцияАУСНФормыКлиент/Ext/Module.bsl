
#Область ПрограммныйИнтерфейс

// Обработчик события "ОбработкаНавигационнойСсылки" подсказки получения кода заявки.
// Открывает личный кабинет банка для оформления заявки.
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения - форма, в которой происходит подключение банка
//   Элемент - ЭлементыФормы - элемент формы, в котором происходит обработка навигационной ссылки
//   НавигационнаяСсылкаФорматированнойСтроки - Строка - идентификатор ссылки
//   СтандартнаяОбработка - Булево - признак стандартной обработки открытия ссылки
//
Процедура ПодсказкаПолучениеКодаЗаявкиОбработкаНавигационнойСсылки(Форма, Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка) Экспорт

	Если НавигационнаяСсылкаФорматированнойСтроки = "ЛичныйКабинетБанка" Тогда
		СтандартнаяОбработка = Ложь;
		Если ЗначениеЗаполнено(Форма.ЛичныйКабинетБанка) Тогда
			ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(Форма.ЛичныйКабинетБанка);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

// Обрабатывает изменение кода заявки в форме, обновляя подсказку и статус проверки
//
// Параметры:
//   Форма - ФормаКлиентскогоПриложения - форма, в которой вводится код заявки
//   КодЗаявки - Строка - введенный код заявки
//
Процедура ОбработатьИзменениеКодаЗаявки(Форма, КодЗаявки) Экспорт
	
	Форма.КодЗаявкиПодсказка = ПодсказкаКодаЗаявки(КодЗаявки);
	
	Если СтрДлина(КодЗаявки) <> ДлинаКодаЗаявки() Тогда
		Форма.КодЗаявкиПроверен = Ложь;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает текст подсказки для введенного кода заявки
//
// Параметры:
//   КодЗаявки - Строка - код заявки
//   СтатусЗаявки - Строка - статус заявки см. ИнтеграцияАУСНКлиентСервер.СтатусыЗаявокПодключения
//   НаименованиеБанка - Строка - наименование банка
//
// Возвращаемое значение:
//   ФорматированнаяСтрока - сформированная подсказка
//
Функция ПодсказкаКодаЗаявки(КодЗаявки, СтатусЗаявки = Неопределено, НаименованиеБанка = "") Экспорт
	
	ДлинаВведенногоКодаЗаявки = СтрДлина(КодЗаявки);
	ДлинаКодаЗаявки = ДлинаКодаЗаявки(); 
	
	Если СтатусЗаявки <> Неопределено Тогда
		Если СтатусЗаявки = ИнтеграцияАУСНКлиентСервер.СтатусыЗаявокПодключения().Новая Тогда
			Если ЗначениеЗаполнено(НаименованиеБанка) Тогда
				СодержаниеПодсказки = СтрШаблон(НСтр("ru = 'Найдена новая заявка %1'"), НаименованиеБанка);
			Иначе
				СодержаниеПодсказки = НСтр("ru = 'Найдена новая заявка'");
			КонецЕсли; 
			ЦветПодсказки = ОбщегоНазначенияКлиент.ЦветСтиля("НоваяЗаявкаАУСНЦвет");
		ИначеЕсли СтатусЗаявки = ИнтеграцияАУСНКлиентСервер.СтатусыЗаявокПодключения().Принята Тогда
			Если ЗначениеЗаполнено(НаименованиеБанка) Тогда  
				СодержаниеПодсказки = СтрШаблон(НСтр("ru = 'Заявка %1 уже подтверждена'"), НаименованиеБанка);
			Иначе
				СодержаниеПодсказки = НСтр("ru = 'Заявка уже подтверждена'");
			КонецЕсли;
			ЦветПодсказки = ОбщегоНазначенияКлиент.ЦветСтиля("ПоясняющийТекст");
		ИначеЕсли СтатусЗаявки = ИнтеграцияАУСНКлиентСервер.СтатусыЗаявокПодключения().Отклонена Тогда
			Если ЗначениеЗаполнено(НаименованиеБанка) Тогда
				СодержаниеПодсказки = СтрШаблон(НСтр("ru = 'Заявка %1 отклонена'"), НаименованиеБанка);
			Иначе
				СодержаниеПодсказки = НСтр("ru = 'Заявка отклонена'");
			КонецЕсли;
			ЦветПодсказки = ОбщегоНазначенияКлиент.ЦветСтиля("НекорректнаяЗаявкаАУСНЦвет");
		Иначе
			СодержаниеПодсказки = "";
			ЦветПодсказки = Новый Цвет();
		КонецЕсли;
		
		ТекстПодсказки = Новый ФорматированнаяСтрока(СодержаниеПодсказки, , ЦветПодсказки);
	ИначеЕсли ДлинаВведенногоКодаЗаявки > 0 И ДлинаВведенногоКодаЗаявки < ДлинаКодаЗаявки Тогда
		ОсталосьВвести = ДлинаКодаЗаявки - ДлинаВведенногоКодаЗаявки;
		ТекстПодсказки = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
			НСтр("ru = ';Осталось ввести %1 символ;;Осталось ввести %1 символа;Осталось ввести %1 символов;Осталось ввести %1 символов'"),
			ОсталосьВвести);
		ТекстПодсказки = Новый ФорматированнаяСтрока(ТекстПодсказки, , ОбщегоНазначенияКлиент.ЦветСтиля("ПоясняющийТекст"));
	Иначе
		ТекстПодсказки = Новый ФорматированнаяСтрока("");
	КонецЕсли;
	
	Возврат ТекстПодсказки;
	
КонецФункции

// Возвращает текст подсказки о некорректном коде заявки
//
// Возвращаемое значение:
//   ФорматированнаяСтрока - сформированная подсказка
//
Функция ПодсказкаНекорректногоКодаЗаявки() Экспорт
	
	СодержаниеПодсказки = НСтр("ru = 'Заявка не найдена. Проверьте правильность заполнения.'");
	ЦветПодсказки = ОбщегоНазначенияКлиент.ЦветСтиля("НекорректнаяЗаявкаАУСНЦвет");
	Возврат Новый ФорматированнаяСтрока(СодержаниеПодсказки, , ЦветПодсказки);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ДлинаКодаЗаявки()
	
	Возврат 36;
	
КонецФункции

#КонецОбласти