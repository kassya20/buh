
#Область СлужебныйПрограммныйИнтерфейс

Процедура РеквизитыОрганизацииСсылкаОбработкаНавигационнойСсылки(Форма, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка) Экспорт
	
	Объект = Форма.Объект;
	Если НавигационнаяСсылкаФорматированнойСтроки = "РеквизитыОрганизацииСсылка" Тогда
		СтандартнаяОбработка = Ложь;
		ОткрытьФормуОрганизации(Объект.Организация, "Банк");
	ИначеЕсли НавигационнаяСсылкаФорматированнойСтроки = "ДатаПрисвоенияОГРНИП" Тогда
		СтандартнаяОбработка = Ложь;
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Форма", Форма);
		ДополнительныеПараметры.Вставить("НавигационнаяСсылка", НавигационнаяСсылкаФорматированнойСтроки);
		ОбработчикЗавершения = Новый ОписаниеОповещения("ОткрытьФормуОрганизацииЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		ОткрытьФормуОрганизации(Объект.Организация, "ДатаПрисвоенияОГРН", ОбработчикЗавершения);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОткрытьФормуОрганизации(Организация, ИмяТекущегоЭлемента, ОбработчикЗавершения = Неопределено)
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("Ключ", Организация);
	ПараметрыФормы.Вставить("УстановитьТекущийЭлемент", ИмяТекущегоЭлемента);
	Если ОбработчикЗавершения = Неопределено Тогда
		ФормаОрганизации = ОткрытьФорму("Справочник.Организации.ФормаОбъекта", ПараметрыФормы);
	Иначе
		ФормаОрганизации = ОткрытьФорму("Справочник.Организации.ФормаОбъекта", ПараметрыФормы,,,,, ОбработчикЗавершения);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОткрытьФормуОрганизацииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ДополнительныеПараметры.НавигационнаяСсылка = "ДатаПрисвоенияОГРНИП" Тогда
		ПроверкаРеквизитовОрганизацииКлиентСервер.УстановитьВидимостьПредупрежденияОДатеПрисвоенияОГРНИП(ДополнительныеПараметры.Форма);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти