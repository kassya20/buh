Функция ПлатежиСегодняПоБанку(Банк, Организация, АдресПлатежиСегодняПоБанкам) Экспорт
	
	СуммыПоБанку = Новый Структура;
	СуммыПоБанку.Вставить("Приход", 0);
	СуммыПоБанку.Вставить("Расход", 0);
	
	Если ЭтоАдресВременногоХранилища(АдресПлатежиСегодняПоБанкам) Тогда
		ПлатежиПоБанку = ПолучитьИзВременногоХранилища(АдресПлатежиСегодняПоБанкам);
	Иначе
		Возврат СуммыПоБанку;
	КонецЕсли;
	
	Если ПлатежиПоБанку <> Неопределено Тогда
		Отбор = Новый Структура("Банк, Организация", Банк, Организация);
		СтрокиБанка = ПлатежиПоБанку.НайтиСтроки(Отбор);
		Если СтрокиБанка.Количество() > 0 Тогда
			ЗаполнитьЗначенияСвойств(СуммыПоБанку, СтрокиБанка[0]);
		КонецЕсли;
	КонецЕсли;
	
	Возврат СуммыПоБанку;
	
КонецФункции

