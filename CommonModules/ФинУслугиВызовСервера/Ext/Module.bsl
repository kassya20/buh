Функция СтруктураГруппировокИСчетов(Раздел) Экспорт
	
	Группировки = Новый Массив;
	СписокВидовСубконто = Новый СписокЗначений;  

	Если Раздел = "Платежи" Тогда
		Группировки.Добавить(Новый Структура("Имя, Значение", "Субконто1", "БанковскиеСчета"));
		СписокВидовСубконто.Добавить(ПредопределенноеЗначение("ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.БанковскиеСчета"));
		СчетаРасчетов = УчетДенежныхСредствПовтИсп.ПолучитьСчетаССубконтоБанковскиеСчета()
	Иначе
		Группировки.Добавить(Новый Структура("Имя, Значение", "Субконто1", "Контрагенты"));
		Группировки.Добавить(Новый Структура("Имя, Значение", "Субконто2", "Договоры"));
		СписокВидовСубконто.Добавить(ПредопределенноеЗначение("ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты"));
		СписокВидовСубконто.Добавить(ПредопределенноеЗначение("ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры"));
		Если Раздел = "Кредиты" Тогда
			СчетаРасчетов = СчетаРасчетовКредиты();
		Иначе
			СчетаРасчетов = СчетаРасчетовЛизинг();
		КонецЕсли;
	КонецЕсли;
		
	Возврат Новый Структура("Группировки, СписокВидовСубконто, СчетаРасчетов", Группировки, СписокВидовСубконто, СчетаРасчетов);
	
КонецФункции

Функция СчетаРасчетовКредиты() Экспорт
	
	СчетаРасчетов = Новый Массив;
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоКраткосрочнымКредитамИЗаймам); // 66
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоДолгосрочнымКредитамИЗаймам);  // 67
	
	Возврат СчетаРасчетов;
	
КонецФункции

Функция СчетаРасчетовЛизинг() Экспорт
	
	СчетаРасчетов = Новый Массив;
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАренде);    // 76.07
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАрендеВал); // 76.27
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАрендеУЕ);  // 76.37
	
	Возврат СчетаРасчетов;
	
КонецФункции

