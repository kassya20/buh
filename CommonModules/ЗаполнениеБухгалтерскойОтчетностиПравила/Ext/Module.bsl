КонецФункции

Функция ПредставлениеСпискаЗначений(СписокЗначений, Маркированный, КодЯзыка, Лимит = 20)
	
	// Стандартное значение лимита установлено исходя из количества строк на экране,
	// так как интерактивная работа в табличном документе с текстом, не помещающимся по высоте экрана, затруднена
	
	Представления = Новый Массив;
	ОстатокЛимита = Лимит;
	Для Каждого ОписаниеЗначения Из СписокЗначений Цикл
		
		ПредставлениеЭлементаСписка = ОписаниеЗначения.Представление;
		
		ОстатокЛимита = ОстатокЛимита - 1;
		Если ОстатокЛимита = 0 Тогда
			СверхЛимита = СписокЗначений.Количество() - Лимит + 1; // последняя строка в пределах лимита - описание итога
			Если СверхЛимита > 1 Тогда
				ШаблонСверхЛимита = НСтр("ru = 'еще %1'", КодЯзыка);
				Если Маркированный Тогда
					ШаблонСверхЛимита = НСтр("ru = 'и др. (еще %1)'", КодЯзыка);
				КонецЕсли;
				ПредставлениеЭлементаСписка = СтрШаблон(ШаблонСверхЛимита, СверхЛимита);
			КонецЕсли;
		ИначеЕсли ОстатокЛимита < 0 Тогда
			Прервать;
		КонецЕсли;
		
		Если Маркированный Тогда
			ПредставлениеЗначения = СтрШаблон(" - %1", ПредставлениеЭлементаСписка);
		Иначе
			ПредставлениеЗначения = СтрШаблон("""%1""", ПредставлениеЭлементаСписка);
		КонецЕсли;
		Представления.Добавить(ПредставлениеЗначения);
		
	КонецЦикла;
	
	Если Маркированный Тогда
		Возврат СтрСоединить(Представления, Символы.ПС);
	Иначе
		Возврат ОбщегоНазначенияБПКлиентСервер.ПредставлениеСписка(Представления);
	КонецЕсли;
КонецФункции

Процедура УдалитьЗначенияИзСписка(СписокЗначений, Значение)
	
	Пока Истина Цикл
		ЭлементСписка = СписокЗначений.НайтиПоЗначению(Значение);
		Если ЭлементСписка = Неопределено Тогда
			Прервать;
		КонецЕсли;
		СписокЗначений.Удалить(ЭлементСписка);
	КонецЦикла;

