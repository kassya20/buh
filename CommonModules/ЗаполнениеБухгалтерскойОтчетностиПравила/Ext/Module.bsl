	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_СтатьиКурсовыеРазницы";

	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьКорректировкиДенежныхПотоков(Процессор)
	
	СоздатьДенежныеПотокиКонтрагентов(Процессор);
	СоздатьДенежныеПотокиОбменВалют(Процессор);
	СоздатьДенежныеПотокиКурсовыеРазницы(Процессор);
	
	КорректировочныеПоказатели = КорректировочныеПоказателиДенежныхПотоков(Процессор.ЗаполняемыеПоказатели);
	
	Процессор.ДанныеАлгоритма.Вставить("ПоказательЕдиныйНалоговыйПлатежБезРаспределения", -1);
	РаспределятьЕдиныйНалоговыйПлатеж = Ложь;
	
	ПоказательЕдиныйНалоговыйПлатеж = НайтиКорректировочныйПоказательДенежныхПотоков(
		КорректировочныеПоказатели,
		"ЕдиныйНалоговыйПлатеж",
		"РаспределениеИсточник");
	
	Если ПоказательЕдиныйНалоговыйПлатеж <> Неопределено Тогда
		РаспределятьЕдиныйНалоговыйПлатеж = Истина;
	Иначе
		ПоказательЕдиныйНалоговыйПлатеж = НайтиПоказательЕдиныйНалоговыйПлатеж(Процессор.ЗаполняемыеПоказатели);
		Процессор.ДанныеАлгоритма.ПоказательЕдиныйНалоговыйПлатежБезРаспределения = ПоказательЕдиныйНалоговыйПлатеж;
	КонецЕсли;
	
	ПоказательНДС = НайтиКорректировочныйПоказательДенежныхПотоков(
		КорректировочныеПоказатели,
		"НДС",
		"Сворачивание");
	
	СоздатьДенежныеПотокиЕдиныйНалоговыйПлатеж(Процессор, РаспределятьЕдиныйНалоговыйПлатеж, ПоказательНДС);
	
	Процессор.ДанныеАлгоритма.Вставить(
		"ПредставленияСсылокПоказателей",
		ПредставленияСсылокПоказателей(КорректировочныеПоказатели, Процессор.ЗаполняемыеПоказатели, Процессор.КодЯзыка));
	
	СворачиваемыеПоказатели = СворачиваемыеПоказатели(Процессор.ЗаполняемыеПоказатели);
	
	// Кроме корректировок денежных потоков внутри одного вида корректировки,
	// выполняется межвидовая корректировка - перенос НДС из ЕдиныйНалоговыйПлатеж в НДС.
	// Знак суммы должен быть со стороны корректируемого показателя - и для переноса НДС знак меняется,
	// так как выбираются данные из ЕдиныйНалоговыйПлатеж, а корректируется НДС.
	
	Запрос = НачатьЗапрос(Процессор);
	Запрос.УстановитьПараметр("КорректировочныеПоказатели", КорректировочныеПоказатели);
	Запрос.УстановитьПараметр("КорректировочныйПоказательЕдиныйНалоговыйПлатеж", ПоказательЕдиныйНалоговыйПлатеж);
	Запрос.УстановитьПараметр("КорректировочныйПоказательНДС", ПоказательНДС);
	Запрос.УстановитьПараметр("СворачиваемыеПоказатели", СворачиваемыеПоказатели);
	// По общему правилу основной показатель может идентифицироваться в запросе ДанныеУчета как Null,
	// но в условиях соединений с временными таблицами может быть удобнее избавиться от Null
	Запрос.УстановитьПараметр("ОсновнойПоказатель", Процессор.ОсновнойПоказатель);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КорректировочныеПоказатели.Вид КАК Вид,
	|	КорректировочныеПоказатели.Направление КАК Направление,
	|	КорректировочныеПоказатели.Показатель КАК Показатель
	|ПОМЕСТИТЬ ВТ_КорректировочныеПоказатели
	|ИЗ
	|	&КорректировочныеПоказатели КАК КорректировочныеПоказатели
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Вид,
	|	Направление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СворачиваемыеПоказатели.Вид КАК Вид,
	|	СворачиваемыеПоказатели.Показатель КАК Показатель
	|ПОМЕСТИТЬ ВТ_СворачиваемыеПоказатели
	|ИЗ
	|	&СворачиваемыеПоказатели КАК СворачиваемыеПоказатели
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Вид,
	|	Показатель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СчетаБезСтатей.Показатель, Статьи.Показатель) КАК ПоказательИсточник,
	|	ЕСТЬNULL(ЕСТЬNULL(СчетаБезСтатей.Показатель, Статьи.Показатель), &ОсновнойПоказатель) КАК ПоказательИсточникСворачиваемыеПоказатели,
	|	КорректировочныеПоказатели.Показатель КАК ПоказательПриемник,
	|	Корректировки.Вид КАК Вид,
	|	Корректировки.Организация КАК Организация,
	|	Корректировки.Счет КАК Счет,
	|	Корректировки.Статья КАК Статья,
	|	Корректировки.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВТ_КорректировкиДенежныхПотоковКонтрагентов
	|ИЗ
	|	ДенежныеПотокиКонтрагентов КАК Корректировки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Статьи КАК Статьи
	|		ПО Корректировки.Статья = Статьи.Статья
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаБезСтатей КАК СчетаБезСтатей
	|		ПО Корректировки.Счет = СчетаБезСтатей.Счет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КорректировочныеПоказатели КАК КорректировочныеПоказатели
	|		ПО Корректировки.Вид = КорректировочныеПоказатели.Вид
	|			И (КорректировочныеПоказатели.Направление = ""Сворачивание"")
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Вид,
	|	ПоказательИсточникСворачиваемыеПоказатели
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Корректировки.ПоказательИсточник КАК ПоказательИсточник,
	|	Корректировки.ПоказательПриемник КАК ПоказательПриемник,
	|	Корректировки.Вид КАК Вид,
	|	Корректировки.Организация КАК Организация,
	|	Корректировки.Счет КАК Счет,
	|	Корректировки.Статья КАК Статья,
	|	ЗНАЧЕНИЕ(Справочник.ВидыНалоговИПлатежейВБюджет.ПустаяСсылка) КАК Налог,
	|	"""" КАК ОперацияНалога,
	|	Корректировки.Сумма КАК Сумма
	|ПОМЕСТИТЬ КорректировкиДенежныхПотоков
	|ИЗ
	|	ВТ_КорректировкиДенежныхПотоковКонтрагентов КАК Корректировки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СворачиваемыеПоказатели КАК СворачиваемыеПоказатели
	|		ПО Корректировки.Вид = СворачиваемыеПоказатели.Вид
	|			И Корректировки.ПоказательИсточникСворачиваемыеПоказатели = СворачиваемыеПоказатели.Показатель
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&КорректировочныйПоказательЕдиныйНалоговыйПлатеж,
	|	&КорректировочныйПоказательНДС,
	|	""НДС"",
	|	ПлатежНДС.Организация,
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПустаяСсылка),
	|	ЗНАЧЕНИЕ(Справочник.СтатьиДвиженияДенежныхСредств.ПустаяСсылка),
	|	ПлатежНДС.Налог,
	|	ПлатежНДС.ОперацияНалога,
	|	ПлатежНДС.Сумма
	|ИЗ
	|	ДенежныеПотокиЕдиныйНалоговыйПлатеж КАК ПлатежНДС
	|ГДЕ
	|	НЕ ПлатежНДС.ВременныйУчет
	|	И ПлатежНДС.ВидНалога = ЗНАЧЕНИЕ(Перечисление.ВидыНалогов.НДС)
	|	И &КорректировочныйПоказательНДС <> НЕОПРЕДЕЛЕНО
	|	И &КорректировочныйПоказательЕдиныйНалоговыйПлатеж <> НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&КорректировочныйПоказательЕдиныйНалоговыйПлатеж,
	|	Корректировки.Показатель,
	|	КорректировочныеПоказатели.Вид,
	|	Корректировки.Организация,
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПустаяСсылка),
	|	ЗНАЧЕНИЕ(Справочник.СтатьиДвиженияДенежныхСредств.ПустаяСсылка),
	|	Корректировки.Налог,
	|	Корректировки.ОперацияНалога,
	|	Корректировки.Сумма
	|ИЗ
	|	ДенежныеПотокиЕдиныйНалоговыйПлатеж КАК Корректировки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КорректировочныеПоказатели КАК КорректировочныеПоказатели
	|		ПО (КорректировочныеПоказатели.Показатель = &КорректировочныйПоказательЕдиныйНалоговыйПлатеж)
	|ГДЕ
	|	НЕ Корректировки.ВременныйУчет
	|	И Корректировки.ВидНалога <> ЗНАЧЕНИЕ(Перечисление.ВидыНалогов.НДС)
	|	И &КорректировочныйПоказательЕдиныйНалоговыйПлатеж <> НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВременныйУчетЕдиногоНалоговогоПлатежа.Показатель,
	|	&КорректировочныйПоказательЕдиныйНалоговыйПлатеж,
	|	""ВременныйУчетЕдиногоНалоговогоПлатежа"",
	|	ВременныйУчетЕдиногоНалоговогоПлатежа.Организация,
	|	ВременныйУчетЕдиногоНалоговогоПлатежа.Счет,
	|	ВременныйУчетЕдиногоНалоговогоПлатежа.Статья,
	|	ЗНАЧЕНИЕ(Справочник.ВидыНалоговИПлатежейВБюджет.ПустаяСсылка),
	|	"""",
	|	ВременныйУчетЕдиногоНалоговогоПлатежа.Сумма
	|ИЗ
	|	ДенежныеПотокиЕдиныйНалоговыйПлатеж КАК ВременныйУчетЕдиногоНалоговогоПлатежа
	|ГДЕ
	|	ВременныйУчетЕдиногоНалоговогоПлатежа.ВременныйУчет
	|	И &КорректировочныйПоказательЕдиныйНалоговыйПлатеж <> НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СчетаБезСтатей.Показатель, Статьи.Показатель),
	|	КорректировочныеПоказатели.Показатель,
	|	КорректировочныеПоказатели.Вид,
	|	Корректировки.Организация,
	|	Корректировки.Счет,
	|	Корректировки.Статья,
	|	ЗНАЧЕНИЕ(Справочник.ВидыНалоговИПлатежейВБюджет.ПустаяСсылка),
	|	"""",
	|	Корректировки.Сумма
	|ИЗ
	|	ДенежныеПотокиОбменВалют КАК Корректировки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Статьи КАК Статьи
	|		ПО Корректировки.Статья = Статьи.Статья
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаБезСтатей КАК СчетаБезСтатей
	|		ПО Корректировки.Счет = СчетаБезСтатей.Счет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КорректировочныеПоказатели КАК КорректировочныеПоказатели
	|		ПО (КорректировочныеПоказатели.Вид = ""ОбменВалют"")
	|			И (КорректировочныеПоказатели.Направление = ""Сворачивание"")
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СчетаБезСтатей.Показатель, Статьи.Показатель),
	|	КорректировочныеПоказатели.Показатель,
	|	КорректировочныеПоказатели.Вид,
	|	Корректировки.Организация,
	|	Корректировки.Счет,
	|	Корректировки.Статья,
	|	ЗНАЧЕНИЕ(Справочник.ВидыНалоговИПлатежейВБюджет.ПустаяСсылка),
	|	"""",
	|	Корректировки.Сумма
	|ИЗ
	|	ДенежныеПотокиКурсовыеРазницы КАК Корректировки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Статьи КАК Статьи
	|		ПО Корректировки.Статья = Статьи.Статья
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаБезСтатей КАК СчетаБезСтатей
	|		ПО Корректировки.Счет = СчетаБезСтатей.Счет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_КорректировочныеПоказатели КАК КорректировочныеПоказатели
	|		ПО (КорректировочныеПоказатели.Вид = ""КурсовыеРазницы"")
	|			И (КорректировочныеПоказатели.Направление = ""Сворачивание"")
	|;
