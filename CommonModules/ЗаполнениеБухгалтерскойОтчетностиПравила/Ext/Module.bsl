Функция ОперацииНалогов()
	
	ОперацииНалогов = Новый СписокЗначений; // Представление - строка на разных языках
	
	ОперацииНалогов.Добавить("Списано", "ru = 'Списано в счет уплаты налога'");
	ОперацииНалогов.Добавить("ЗачетПереплаты", "ru = 'Зачет переплаты и возмещение налога'");
	
