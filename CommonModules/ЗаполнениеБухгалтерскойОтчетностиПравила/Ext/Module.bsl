Процедура СоздатьДенежныеПотокиЕдиныйНалоговыйПлатеж(Процессор, РаспределятьЕдиныйНалоговыйПлатеж, КорректировочныйПоказательНДС)

	Процессор.ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа = ДанныеВременногоУчетаЕдиногоНалоговогоПлатежа(Процессор);
	
	ЕдиныйНалоговыйПлатеж = Новый ТаблицаЗначений;
	ЕдиныйНалоговыйПлатеж.Колонки.Добавить("Показатель", Новый ОписаниеТипов("Число"));
	ЕдиныйНалоговыйПлатеж.Колонки.Добавить("Налог", Новый ОписаниеТипов("СправочникСсылка.ВидыНалоговИПлатежейВБюджет"));
	ЕдиныйНалоговыйПлатеж.Колонки.Добавить("ВидНалога", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалогов"));
	ЕдиныйНалоговыйПлатеж.Колонки.Добавить("ОперацияНалога", Новый ОписаниеТипов("Число")); // индекс в ОперацииНалогов, см. ИдентификаторыОперацийНалогов
	ЕдиныйНалоговыйПлатеж.Колонки.Добавить("Сумма", БухгалтерскийУчетКлиентСервер.ТипСумма());
	ЕдиныйНалоговыйПлатеж.Колонки.Добавить("ВременныйУчет", Новый ОписаниеТипов("Булево"));
	ДополнитьКолонкамиАналитикиПотоковВременногоУчетаЕдиногоНалоговогоПлатежа(ЕдиныйНалоговыйПлатеж);
	
	ПеренестиЕдиныйНалоговыйПлатежИзВременныхСтатей(ЕдиныйНалоговыйПлатеж, Процессор.ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа);
	
	Если РаспределятьЕдиныйНалоговыйПлатеж Тогда
		РаспределитьЕдиныйНалоговыйПлатеж(ЕдиныйНалоговыйПлатеж, КорректировочныйПоказательНДС, Процессор);
	КонецЕсли;
	
	Запрос = НачатьЗапрос(Процессор);
	Запрос.УстановитьПараметр("ДенежныеПотокиЕдиныйНалоговыйПлатеж", ЕдиныйНалоговыйПлатеж);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Данные.Показатель КАК Показатель,
	|	Данные.Налог КАК Налог,
	|	Данные.ВидНалога КАК ВидНалога,
	|	Данные.ОперацияНалога КАК ОперацияНалога,
	|	Данные.Сумма КАК Сумма,
	|	Данные.ВременныйУчет КАК ВременныйУчет,
	|	Данные.Организация КАК Организация,
	|	Данные.Статья КАК Статья,
	|	Данные.Счет КАК Счет
	|ПОМЕСТИТЬ ДенежныеПотокиЕдиныйНалоговыйПлатеж
	|ИЗ
	|	&ДенежныеПотокиЕдиныйНалоговыйПлатеж КАК Данные
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВременныйУчет,
	|	ВидНалога";
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура РаспределитьЕдиныйНалоговыйПлатеж(ЕдиныйНалоговыйПлатеж, КорректировочныйПоказательНДС, Процессор)
	
	// Потоки единого налогового платежа определяются по данным о принадлежности сумм ЕНС, общим для организации в целом.
	// Поэтому их нельзя определить для отчетности с показателями отдельного филиала.
	ОсновнаяОрганизация = Процессор.Контекст.Организации[0];
	Если ОбщегоНазначенияБПВызовСервераПовтИсп.ЭтоОбособленноеПодразделение(ОсновнаяОрганизация) Тогда
		Возврат;
	КонецЕсли;
	
	ОперацииНалогов = ИдентификаторыОперацийНалогов();
	
	СуммаЕНП = 0;
	Если Процессор.ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа <> Неопределено Тогда
		СуммаЕНП = Процессор.ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа.Сумма;
	Иначе
		СуммаЕНП = СуммаЕдиногоНалоговогоПлатежа(Процессор);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СуммаЕНП) Тогда
		Возврат;
	КонецЕсли;
	
	ПоказателиНалогов = ПоказателиНалоговЕдиныйНалоговыйПлатеж(Процессор.ЗаполняемыеПоказатели, КорректировочныйПоказательНДС);
	Если Не ЗначениеЗаполнено(ПоказателиНалогов) Тогда
		Возврат;
	КонецЕсли;
	
	Если СуммаЕНП > 0 Тогда
		// Возврат с ЕНС
		Возврат;
	КонецЕсли;
	
	// Интересны данные по видам налогов, включаемым в обособленные показатели, а также НДС, сворачиваемый с НДС в расчетах с контрагентами.
	// См. СоздатьКорректировкиДенежныхПотоков
	
	ПорядокЗачета = Новый ТаблицаЗначений;
	ПорядокЗачета.Колонки.Добавить("ВидНалога", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалогов"));
	Для Каждого ВидНалога Из ПорядокЗачетаПереплатыЕдиногоНалоговогоПлатежа() Цикл
		ПорядокЗачета.Добавить().ВидНалога = ВидНалога;
	КонецЦикла;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ЕдиныйНалоговыйСчет.СоздатьУплатаНалогов(
		МенеджерВременныхТаблиц,
		Процессор.Контекст.Период.Начало,
		Процессор.Контекст.Период.КонецДата,
		Процессор.Контекст.Организации[0]);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПоказателиНалогов", ПоказателиНалогов);
	Запрос.УстановитьПараметр("ПорядокВидовНалогов", ПорядокЗачета);
	Запрос.УстановитьПараметр("ПорядокВидаНалоговПоУмолчанию", ПорядокЗачета.Количество() + 1);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	АВТОНОМЕРЗАПИСИ() КАК Порядок,
	|	ПоказателиНалогов.Налог КАК Налог,
	|	ПоказателиНалогов.Показатель КАК Показатель
	|ПОМЕСТИТЬ ВТ_ПоказателиНалогов
	|ИЗ
	|	&ПоказателиНалогов КАК ПоказателиНалогов
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Налог
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АВТОНОМЕРЗАПИСИ() КАК Порядок,
	|	ПорядокВидовНалогов.ВидНалога КАК ВидНалога
	|ПОМЕСТИТЬ ВТ_ПорядокВидовНалогов
	|ИЗ
	|	&ПорядокВидовНалогов КАК ПорядокВидовНалогов
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидНалога
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыНалогов.Ссылка КАК ВидНалога,
	|	МАКСИМУМ(ПоказателиНалогов.Порядок) КАК Порядок,
	|	МАКСИМУМ(ПоказателиНалогов.Показатель) КАК Показатель
	|ПОМЕСТИТЬ ВТ_ПоказателиВидовНалогов
	|ИЗ
	|	ВТ_ПоказателиНалогов КАК ПоказателиНалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Перечисление.ВидыНалогов КАК ВидыНалогов
	|		ПО ПоказателиНалогов.Налог = ВидыНалогов.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВидыНалогов.Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидНалога
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПоказателиНалогов.Налог КАК Налог,
	|	МАКСИМУМ(Налоги.ВидНалога) КАК ВидНалога,
	|	МАКСИМУМ(ПоказателиНалогов.Порядок) КАК Порядок,
	|	МАКСИМУМ(ПоказателиНалогов.Показатель) КАК Показатель
	|ПОМЕСТИТЬ ВТ_ПоказателиНалоговУпорядоченные
	|ИЗ
	|	ВТ_ПоказателиНалогов КАК ПоказателиНалогов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНалоговИПлатежейВБюджет КАК Налоги
	|		ПО ПоказателиНалогов.Налог = Налоги.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоказателиНалогов.Налог
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПоказателиНалогов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УплатаНалогов.Налог КАК Налог,
	|	УплатаНалогов.Сумма КАК Сумма,
	|	ЕСТЬNULL(ПоказателиНалогов.ВидНалога, Налоги.ВидНалога) КАК ВидНалога,
	|	ЕСТЬNULL(ПоказателиНалогов.Показатель, ПоказателиВидовНалогов.Показатель) КАК Показатель,
	|	ЕСТЬNULL(ПоказателиНалогов.Порядок, ПоказателиВидовНалогов.Порядок) КАК Порядок
	|ПОМЕСТИТЬ ВТ_ПоказателиУплатыНалогов
	|ИЗ
	|	УплатаНалогов КАК УплатаНалогов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПоказателиНалоговУпорядоченные КАК ПоказателиНалогов
	|		ПО УплатаНалогов.Налог = ПоказателиНалогов.Налог
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПоказателиВидовНалогов КАК ПоказателиВидовНалогов
	|		ПО УплатаНалогов.Налог.ВидНалога = ПоказателиВидовНалогов.ВидНалога
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНалоговИПлатежейВБюджет КАК Налоги
	|		ПО УплатаНалогов.Налог = Налоги.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПоказателиНалоговУпорядоченные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПоказателиВидовНалогов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УплатаНалогов.Налог КАК Налог,
	|	УплатаНалогов.Сумма КАК Сумма,
	|	УплатаНалогов.ВидНалога КАК ВидНалога,
	|	УплатаНалогов.Показатель КАК Показатель,
	|	ВЫБОР
	|		КОГДА УплатаНалогов.Показатель ЕСТЬ NULL
	|			ТОГДА -1
	|		ИНАЧЕ ЕСТЬNULL(ПорядокВидовНалогов.Порядок, &ПорядокВидаНалоговПоУмолчанию)
	|	КОНЕЦ КАК ПорядокЗачетаВидовНалогов,
	|	УплатаНалогов.Порядок КАК ПорядокПоказателей,
	|	УплатаНалогов.ВидНалога.Порядок КАК ПорядокВидовНалогов,
	|	ВЫРАЗИТЬ(УплатаНалогов.Налог КАК Справочник.ВидыНалоговИПлатежейВБюджет).Наименование КАК ПорядокНалогов
	|ИЗ
	|	ВТ_ПоказателиУплатыНалогов КАК УплатаНалогов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПорядокВидовНалогов КАК ПорядокВидовНалогов
	|		ПО УплатаНалогов.ВидНалога = ПорядокВидовНалогов.ВидНалога
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокЗачетаВидовНалогов,
	|	ПорядокПоказателей,
	|	ПорядокВидовНалогов,
	|	ПорядокНалогов
	|ИТОГИ
	|	СУММА(Сумма)
	|ПО
	|	ОБЩИЕ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПорядокВидовНалогов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПоказателиУплатыНалогов";
	
	ВыборкаИтоги = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Если Не ВыборкаИтоги.Следующий() Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыборкаИтоги.Сумма <= 0 Тогда
		// Нет сведений о списании с ЕНС, вся сумма - переплата
		Возврат;
	КонецЕсли;
	
	ПереплатаПрошлыхЛет = Макс(0, СуммаЕНП + ВыборкаИтоги.Сумма); // ФНС списало больше, чем фактические платежи за год
	
	Выборка = ВыборкаИтоги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока Выборка.Следующий() Цикл
		
		Списано = - Выборка.Сумма; // Уплата налогов - это отрицательный денежный поток
		
		// Зачитываем переплату по всем списанным ФНС налогам - как выделяемым в отдельные показатели отчета, так и нет
		// (в первую очередь - по не выделяемым).
		ЗачетПереплаты = 0;
		Если ПереплатаПрошлыхЛет > 0 И Списано < 0 Тогда
			ЗачетПереплаты = Мин(ПереплатаПрошлыхЛет, - Списано);
			ПереплатаПрошлыхЛет = ПереплатаПрошлыхЛет - ЗачетПереплаты;
		КонецЕсли;
		
		Если Выборка.Показатель = Null Тогда
			Продолжить;
		КонецЕсли;
		
		Слагаемое = ЕдиныйНалоговыйПлатеж.Добавить();
		ЗаполнитьЗначенияСвойств(Слагаемое, Выборка);
		Слагаемое.Организация = ОсновнаяОрганизация;
		
		Слагаемое.Сумма = Списано;
		Слагаемое.ОперацияНалога = ОперацииНалогов.Списано;
		
		Если ЗачетПереплаты > 0 Тогда
			
			Слагаемое = ЕдиныйНалоговыйПлатеж.Добавить();
			ЗаполнитьЗначенияСвойств(Слагаемое, Выборка);
			Слагаемое.Организация = ОсновнаяОрганизация;
			
			Слагаемое.Сумма = ЗачетПереплаты;
			Слагаемое.ОперацияНалога = ОперацииНалогов.ЗачетПереплаты;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция СуммаЕдиногоНалоговогоПлатежа(Процессор)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Процессор.МенеджерВременныхТаблиц;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(Потоки.Сумма) КАК Сумма
	|ИЗ
	|	ДенежныеПотоки КАК Потоки
	|ГДЕ
	|	Потоки.Статья.ВидДвиженияДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ВидыДвиженийДенежныхСредств.ЕдиныйНалоговыйПлатеж)";
	
	Возврат Запрос.Выполнить().Выгрузить().Итог("Сумма");
	
КонецФункции

Функция ПоказателиНалоговЕдиныйНалоговыйПлатеж(ЗаполняемыеПоказатели, КорректировочныйПоказательНДС)
	
	ПоказателиНалогов = Новый ТаблицаЗначений;
	ПоказателиНалогов.Колонки.Добавить("Налог", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалогов,СправочникСсылка.ВидыНалоговИПлатежейВБюджет"));
	ПоказателиНалогов.Колонки.Добавить("Показатель", Новый ОписаниеТипов("Число"));
	
	ИмяПотока = ИмяРаспределенногоДенежногоПотока(Перечисления.ВидыДвиженийДенежныхСредств.ЕдиныйНалоговыйПлатеж);
	
	Для Каждого ОписаниеПоказателя Из ЗаполняемыеПоказатели.Показатели Цикл
		
		Если ОписаниеПоказателя.Заполнение.Идентификатор <> ИдентификаторАлгоритмаДенежныеПотоки() Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ОписаниеПоказателя.Заполнение.Отбор.Свойство("РаспределениеПриемник")
			Или ОписаниеПоказателя.Заполнение.Отбор.РаспределениеПриемник.Ключ <> ИмяПотока Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Налог Из ОписаниеПоказателя.Заполнение.Отбор.РаспределениеПриемник.Значение Цикл
			
			ОписаниеНалога = ПоказателиНалогов.Добавить();
			ОписаниеНалога.Налог = Налог;
			Если Налог = Перечисления.ВидыНалогов.НДС И КорректировочныйПоказательНДС <> Неопределено Тогда
				ОписаниеНалога.Показатель = КорректировочныйПоказательНДС;
			Иначе
				ОписаниеНалога.Показатель = БухгалтерскаяОтчетностьБРО.ИдентификаторПоказателя(ОписаниеПоказателя);
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;
	
	Если ПоказателиНалогов.Найти(Перечисления.ВидыНалогов.НДС, "Налог") = Неопределено
		И КорректировочныйПоказательНДС <> Неопределено Тогда
		ОписаниеНалога = ПоказателиНалогов.Добавить();
		ОписаниеНалога.Налог = Перечисления.ВидыНалогов.НДС;
		ОписаниеНалога.Показатель = КорректировочныйПоказательНДС;
	КонецЕсли;
	
	Возврат ПоказателиНалогов;
	
КонецФункции

Функция ПорядокЗачетаПереплатыЕдиногоНалоговогоПлатежа()
	
	// Переплатами здесь считаем только то, что не удалось зачесть без привлечения показателей, в которых части ЕНП отражаются обособленно.
	// См. также вызовы ДобавитьПоказательРаспределенныйЕдиныйНалоговыйПлатеж, в частности - НалоговыеПлатежиНДФЛ
	
	ПорядокВидовНалогов = Новый Массив;
	
	ПорядокВидовНалогов.Добавить(Перечисления.ВидыНалогов.НДФЛ);
	
	ПорядокПоказателей = Новый Массив; // Из Массив Из ПеречислениеСсылка.ВидыНалогов
	ПорядокПоказателей.Добавить(Перечисления.ВидыНалогов.НалоговыеПлатежиСтраховыеВзносыОплатыТруда());
	ПорядокПоказателей.Добавить(Перечисления.ВидыНалогов.НалоговыеПлатежиНалогНаПрибыль());
	ПорядокПоказателей.Добавить(Перечисления.ВидыНалогов.НалоговыеПлатежиНалогНаПрибыльДивидендов());
	
	Для Каждого НаборВидовНалоговПоказателя Из ПорядокПоказателей Цикл
		Для Каждого ВидНалога Из НаборВидовНалоговПоказателя Цикл
			ПорядокВидовНалогов.Добавить(ВидНалога);
		КонецЦикла;
	КонецЦикла;
	
	ПорядокВидовНалогов.Добавить(Перечисления.ВидыНалогов.НДС); // Последний, так как сальдируется с суммами в составе расчетов
	
	Возврат ПорядокВидовНалогов;
	
КонецФункции

#Область ВременныйУчетЕдиногоНалоговогоПлатежа

Функция НачалоОбязательногоПримененияСтатьиЕдиныйНалоговыйПлатеж()
	// Временный учет применяется до применения статьи
	Возврат '2026-01-01';
КонецФункции

Функция ДанныеВременногоУчетаЕдиногоНалоговогоПлатежа(Процессор)
	
	Если Процессор.Контекст.Период.КонецДата >= НачалоОбязательногоПримененияСтатьиЕдиныйНалоговыйПлатеж() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДанныеВременногоУчета = НовыйДанныеВременногоУчетаЕдиногоНалоговогоПлатежа();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Процессор.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ВидСтатьиЕдиныйНалоговыйПлатеж", ДанныеВременногоУчета.ВидСтатьиЕдиныйНалоговыйПлатеж);
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Потоки.Статья
	|ИЗ
	|	ДенежныеПотоки КАК Потоки
	|ГДЕ
	|	Потоки.Статья.ВидДвиженияДенежныхСредств = &ВидСтатьиЕдиныйНалоговыйПлатеж";
	ОпределитьСтатьиЕдиныйНалоговыйПлатежПоКорреспонденции = Запрос.Выполнить().Пустой();
	
	Если Не ОпределитьСтатьиЕдиныйНалоговыйПлатежПоКорреспонденции Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтатьиЕдиныйНалоговыйПлатеж = СтатьиЕдиныйНалоговыйПлатежПоКорреспонденции(Процессор, ДанныеВременногоУчета.СчетУчетаЕдиныйНалоговыйСчет);
	Если Не ЗначениеЗаполнено(СтатьиЕдиныйНалоговыйПлатеж) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("СтатьиЕдиныйНалоговыйПлатеж", СтатьиЕдиныйНалоговыйПлатеж);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Статьи.Показатель КАК Показатель,
	|	Потоки.Статья КАК Статья,
	|	Потоки.Статья.Наименование КАК СтатьяПорядок,
	|	Потоки.Счет КАК Счет,
	|	Потоки.Счет.Порядок КАК СчетПорядок,
	|	Потоки.Организация КАК Организация,
	|	Потоки.Организация.Наименование КАК ОрганизацияПорядок,
	|	Потоки.Сумма КАК Сумма
	|ИЗ
	|	ДенежныеПотоки КАК Потоки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Статьи КАК Статьи
	|		ПО Потоки.Статья = Статьи.Статья
	|			И (Потоки.Статья В (&СтатьиЕдиныйНалоговыйПлатеж))
	|
	|УПОРЯДОЧИТЬ ПО
	|	Показатель,
	|	ОрганизацияПорядок,
	|	Организация,
	|	СтатьяПорядок,
	|	Статья,
	|	СчетПорядок,
	|	Счет";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеВременногоУчета.Потоки.Добавить(), Выборка);
	КонецЦикла;
	
	ДанныеВременногоУчета.Сумма = ДанныеВременногоУчета.Потоки.Итог("Сумма");
	ДанныеВременногоУчета.Период = Процессор.Контекст.Период.КонецДата;
	
	Возврат ДанныеВременногоУчета;
	
КонецФункции

Функция НовыйДанныеВременногоУчетаЕдиногоНалоговогоПлатежа()
	
	ДанныеВременногоУчета = Новый Структура;
	
	ДанныеВременногоУчета.Вставить("Сумма", 0);
	ДанныеВременногоУчета.Вставить("СчетУчетаЕдиныйНалоговыйСчет", ПланыСчетов.Хозрасчетный.ЕдиныйНалоговыйСчет);
	ДанныеВременногоУчета.Вставить("ВидСтатьиЕдиныйНалоговыйПлатеж", Перечисления.ВидыДвиженийДенежныхСредств.ЕдиныйНалоговыйПлатеж);
	ДанныеВременногоУчета.Вставить("Период", '0001-01-01');
	ДанныеВременногоУчета.Вставить("Потоки", Новый ТаблицаЗначений);
	ДанныеВременногоУчета.Потоки.Колонки.Добавить("Показатель", Новый ОписаниеТипов("Число"));
	ДанныеВременногоУчета.Потоки.Колонки.Добавить("Сумма", БухгалтерскаяОтчетностьБРО.ТипСумма());
	ДополнитьКолонкамиАналитикиПотоковВременногоУчетаЕдиногоНалоговогоПлатежа(ДанныеВременногоУчета.Потоки);
	
	Возврат ДанныеВременногоУчета;
	
КонецФункции

Процедура ДополнитьКолонкамиАналитикиПотоковВременногоУчетаЕдиногоНалоговогоПлатежа(ТаблицаЗначений)
	ТаблицаЗначений.Колонки.Добавить("Статья", Новый ОписаниеТипов("СправочникСсылка.СтатьиДвиженияДенежныхСредств"));
	ТаблицаЗначений.Колонки.Добавить("Счет", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ТаблицаЗначений.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
КонецПроцедуры

Функция СтатьиЕдиныйНалоговыйПлатежПоКорреспонденции(Процессор, СчетУчетаЕдиныйНалоговыйСчет)
	
	Запрос = НачатьЗапрос(Процессор);
	Запрос.УстановитьПараметр("СчетаДенегДетально",  Процессор.ДанныеАлгоритма.Счета.ДеньгиДетально);
	Запрос.УстановитьПараметр("ЕдиныйНалоговыйСчет", БухгалтерскийУчетПовтИсп.СчетаВИерархии(СчетУчетаЕдиныйНалоговыйСчет));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Статьи.Ссылка КАК Статья,
	|	Статьи.Наименование КАК Порядок
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(&НачалоПериода, &КонецПериода, , Счет В (&СчетаДенегДетально), ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.СтатьиДвиженияДенежныхСредств), Организация В (&Организации), КорСчет В (&ЕдиныйНалоговыйСчет), ) КАК ДенежныеПотоки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтатьиДвиженияДенежныхСредств КАК Статьи
	|		ПО ДенежныеПотоки.Субконто1 = Статьи.Ссылка
	|ГДЕ
	|	Статьи.ВидДвиженияДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ВидыДвиженийДенежныхСредств.ПрочиеРасходыПоТекущейДеятельности)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок,
	|	Статья";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Статья");
	
КонецФункции

Процедура ПеренестиЕдиныйНалоговыйПлатежИзВременныхСтатей(ЕдиныйНалоговыйПлатеж, ДанныеВременногоУчета)
	
	Если ДанныеВременногоУчета = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Источник Из ДанныеВременногоУчета.Потоки Цикл
		
		Приемник = ЕдиныйНалоговыйПлатеж.Добавить();
		ЗаполнитьЗначенияСвойств(Приемник, Источник);
		Приемник.ВременныйУчет = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьОписаниеПорядкаВременногоУчетаЕдиногоНалоговогоПлатежа(Предложения, ДанныеАлгоритма, КодЯзыка)
	
	Если ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонТекста = НСтр(
		"ru = 'Дополнительно в %1 году учитывается оборот по счетам учета денежных средств с указанием статей, по которым в этом периоде были корреспонденции со счетом %2.
         |Такие обороты переносятся из других показателей отчета. Перечень статей и показателей приведен ниже.
         |Это дополнение применяется в переходном периоде до %3 года, если не используются статьи вида %4.'",
		КодЯзыка);
	
	Описание = СтрШаблон(
		ШаблонТекста,
		Формат(ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа.Период, "ДФ=yyyy"),
		ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа.СчетУчетаЕдиныйНалоговыйСчет,
		Формат(НачалоОбязательногоПримененияСтатьиЕдиныйНалоговыйПлатеж(), "ДФ=yyyy"),
		ДанныеАлгоритма.ВременныйУчетЕдиногоНалоговогоПлатежа.ВидСтатьиЕдиныйНалоговыйПлатеж);
	
	Предложения.Добавить(Описание);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#КонецОбласти

Процедура ОписатьПорядокЗаполненияПоказателяДенежныеПотоки(Описание, Показатель, ДанныеАлгоритма, КодЯзыка)
	
	ТекстОписания = Новый Массив;
	ТекстРазъяснения = Новый Массив;
	
	СодержитДвижениеДенежныхСредств = Не ЗначениеЗаполнено(Показатель.Заполнение.Отбор)
		Или Показатель.Заполнение.Отбор.Свойство("ВидСтатьи")
		Или Показатель.Заполнение.Отбор.Свойство("Счет");
		
	КомбинированныйПоказатель = СодержитДвижениеДенежныхСредств
		И (Показатель.Заполнение.Отбор.Свойство("Свернутый")
			Или Показатель.Заполнение.Отбор.Свойство("РаспределениеИсточник"));
			
	Если КомбинированныйПоказатель Тогда
		Описание.ШагиРасчета.Добавить(, "ЭтоДвижениеДенежныхСредств");
	КонецЕсли;
	
	Если СодержитДвижениеДенежныхСредств Тогда
		
		Сворачиваемые = Новый Массив;
		Для Каждого ОписаниеПотока Из ДанныеАлгоритма.ПредставленияСворачиваемыхДенежныхПотоков Цикл
			Если Не Показатель.Заполнение.НастройкиАлгоритма.Сворачиваемые.Свойство(ОписаниеПотока.Значение) Тогда
				Продолжить;
			КонецЕсли;
			Сворачиваемые.Добавить(ОписаниеПотока.Представление);
		КонецЦикла;
		
		Если Показатель.Заполнение.Отбор.Свойство("Счет") Тогда
			
			ОписаниеСчетовОтбора = Новый СписокЗначений;
			Для Каждого ОписаниеСчета Из ДанныеАлгоритма.Счета.Описание Цикл
				Если Показатель.Заполнение.Отбор.Счет.Найти(ОписаниеСчета.Значение) = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				ОписаниеСчетовОтбора.Добавить(ОписаниеСчета.Значение, ОписаниеСчета.Представление, Истина);
			КонецЦикла;
			
			Если КомбинированныйПоказатель Тогда
				Описание.ШагиРасчета.Добавить(, "Счет?");
			Иначе
				Описание.ШагиРасчета.Добавить(ОписаниеСчетовОтбора, "Счет");
			КонецЕсли;
			
			ПредставлениеСчетовОтбора = ПредставлениеСпискаСчетов(ОписаниеСчетовОтбора);
			Если ПредставлениеСчетовОтбора.Количество = 1 Тогда
				ШаблонТекста = НСтр("ru = 'Оборот по счету %1'", КодЯзыка);
			Иначе
				ШаблонТекста = НСтр("ru = 'Оборот по счетам %1'", КодЯзыка);
			КонецЕсли;
			
			ТекстОписания.Добавить(СтрШаблон(ШаблонТекста, ПредставлениеСчетовОтбора.Текст));
			ТекстРазъяснения.Добавить(НСтр(
				"ru = 'Учет по статьям денежных средств на этом счете не ведется, весь его оборот относится к одному показателю отчета'",
				КодЯзыка));
			
		Иначе
			
			ОписаниеСчетовОтбора = ДанныеАлгоритма.Счета.Описание;
			Если Показатель.Заполнение.Отбор.Свойство("ВидСтатьи") Тогда
				ОписаниеСчетовОтбора = ДанныеАлгоритма.Счета.ОписаниеСтатьи;
			Иначе
				ОписаниеСчетовОтбора = ДанныеАлгоритма.Счета.ОписаниеОсновной;
			КонецЕсли;
			
			ШаблонТекста = НСтр("ru = 'Оборот по счетам денежных средств и денежных эквивалентов %1.'", КодЯзыка);
			ОписаниеСтатей = "";
			ДопускаетсяПустаяСтатья = Ложь;
			Если Не Показатель.Заполнение.Отбор.Свойство("ВидСтатьи") Тогда
				ОписаниеСтатей = НСтр("ru = 'по статьям и счетам, не включенным в другие показатели'", КодЯзыка);
				ДопускаетсяПустаяСтатья = Истина;
			ИначеЕсли Показатель.Заполнение.Отбор.ВидСтатьи.Количество() = 1 Тогда
				ОписаниеСтатей = СтрШаблон(
					НСтр("ru = 'по статьям вида ""%1""'", КодЯзыка),
					Показатель.Заполнение.Отбор.ВидСтатьи[0]);
			Иначе
				ОписаниеСтатей = СтрШаблон(
					НСтр("ru = 'по статьям видов %1'", КодЯзыка),
					ОбщегоНазначенияБПКлиентСервер.ПредставлениеСписка(Показатель.Заполнение.Отбор.ВидСтатьи, "И", "; "));
			КонецЕсли;
			Если Не ДопускаетсяПустаяСтатья
				И Показатель.Заполнение.Отбор.ВидСтатьи.Найти(Перечисления.ВидыДвиженийДенежныхСредств.ПустаяСсылка()) <> Неопределено Тогда
				ДопускаетсяПустаяСтатья = Истина;
			КонецЕсли;
			ТекстОписания.Добавить(СтрШаблон(ШаблонТекста, ОписаниеСтатей));
			
			Если Не КомбинированныйПоказатель Тогда
				ТекстОписания.Добавить(НСтр("ru = 'Список счетов приведен ниже.'", КодЯзыка));
			КонецЕсли;
			
			Если КомбинированныйПоказатель Тогда
				Описание.ШагиРасчета.Добавить(, "Счет?");
				Описание.ШагиРасчета.Добавить(, "Статья?");
			Иначе
				Описание.ШагиРасчета.Добавить(ОписаниеСчетовОтбора, "Счет");
				Если ДопускаетсяПустаяСтатья И ЗначениеЗаполнено(Сворачиваемые) Тогда
					Описание.ШагиРасчета.Добавить(, "Статья?");
				Иначе
					Описание.ШагиРасчета.Добавить(, "Статья");
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Сворачиваемые) Тогда
			ТекстОписания.Добавить(НСтр("ru = 'Исключаются обороты между счетами денежных средств и денежных эквивалентов.'", КодЯзыка));
		Иначе
			
			Описание.ШагиРасчета.Добавить(, "ВидКорректировки");
			
			ТекстОписания.Добавить(НСтр("ru = 'Исключаются:
                                       |- обороты между счетами денежных средств и денежных эквивалентов
                                       |- денежные потоки, отображаемые в отчете свернуто.'", КодЯзыка));
			ШаблонТекста = НСтр("ru = 'Свернуто отражаются %1.'", КодЯзыка);
			Если Сворачиваемые.Количество() = 1 Тогда
				НСтр("ru = 'Свернуто отражается %1.'", КодЯзыка);
			КонецЕсли;
			Союз = НСтр("ru = ', а также '", КодЯзыка); // используем нестандартный союз, так как описания сворачиваемых потоков уже содержат союз "и"
			ТекстОписания.Добавить(СтрШаблон(ШаблонТекста, ОбщегоНазначенияБПКлиентСервер.ПредставлениеСписка(Сворачиваемые, Союз, "; ")));
		КонецЕсли;
		
		// Отчет
		Описание.Отчет.ВидОтчета  = "ОборотыСчета";
		
		Если Показатель.Заполнение.Отбор.Свойство("ВидСтатьи") Тогда
			Описание.Отчет.Субконто.Вставить("Статья", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СтатьиДвиженияДенежныхСредств);
			ОтборЧерезТочку = Новый Соответствие;
			ОтборЧерезТочку.Вставить("ВидДвиженияДенежныхСредств", Показатель.Заполнение.Отбор.ВидСтатьи);
			Описание.Отчет.ОтборыПоказателя.Вставить("Статья", ОтборЧерезТочку);
		КонецЕсли;
		
	КонецЕсли;
	
	Если Показатель.Заполнение.Отбор.Свойство("Свернутый") Тогда
		Если Показатель.Заполнение.Отбор.Свернутый = "АгентПродавца" Тогда
			ТекстРазъяснения.Добавить(НСтр(
				"ru = 'Условно считаем, что суммы, выплаченные комитентам, агент в полном объеме получил от покупателей'",
				КодЯзыка));
		ИначеЕсли Показатель.Заполнение.Отбор.Свернутый = "АгентПокупателя" Тогда
			ТекстРазъяснения.Добавить(НСтр(
				"ru = 'Условно считаем, что сумму, полученную от комитента для приобретения чего-либо, агент в полном объеме заплатил поставщикам.
                 |При этом предполагается, что суммы, полученные для платежей поставщикам отражаются на счетах прочих расчетов, а комиссионного вознаграждения - на счетах расчетов с покупателями.'",
				КодЯзыка));
		ИначеЕсли Показатель.Заполнение.Отбор.Свернутый = "НДС" Тогда
			Описание.ШагиРасчета.Добавить(, "СсылкаКорректировки");
			Описание.ШагиРасчета.Добавить(, "ВидКорректировкиДляОписанияСсылки");
			Если Не СодержитДвижениеДенежныхСредств Тогда
				ТекстОписания.Добавить(НСтр(
					"ru = 'Сальдирует денежные потоки по налогу на добавленную стоимость
                     |- исключенные из расчетов с контрагентами
                     |- перенесенные из состава единого налогового платежа.'", 
					КодЯзыка));
			Иначе
				ТекстОписания.Добавить(НСтр(
					"ru = 'Также сальдирует денежные потоки по налогу на добавленную стоимость, исключенные из расчетов с контрагентами.'",
					КодЯзыка));
			КонецЕсли;
		Иначе
			// Пока ограничиваемся наименованием
		КонецЕсли;
	ИначеЕсли Показатель.Заполнение.Отбор.Свойство("РаспределениеПриемник") Тогда
		Если Показатель.Заполнение.Отбор.РаспределениеПриемник.Ключ = "ЕдиныйНалоговыйПлатеж" Тогда
			Описание.ШагиРасчета.Добавить(, "СсылкаКорректировки?");
			Описание.ШагиРасчета.Добавить(, "Налог");
			ШаблонТекста = НСтр(
				"ru = 'Сведения о суммах, зачисленных на единый налоговый счет, и отнесенных налоговым органом к следующим видам обязательств: %1'",
				КодЯзыка);
			Если Показатель.Заполнение.Отбор.РаспределениеПриемник.Значение.Количество() = 1 Тогда
				ШаблонТекста = НСтр(
					"ru = 'Сведения о суммах, зачисленных на единый налоговый счет, и отнесенных налоговым органом к обязательству вида ""%1""'",
					КодЯзыка);
			КонецЕсли;
			ТекстОписания.Добавить(СтрШаблон(
				ШаблонТекста,
				ОбщегоНазначенияБПКлиентСервер.ПредставлениеСписка(Показатель.Заполнение.Отбор.РаспределениеПриемник.Значение, "И", "; ")));
			ТекстРазъяснения.Добавить(СтрШаблон(
					НСтр("ru = 'См. документы %1.'", КодЯзыка),
					Метаданные.Документы.СведенияОбУплатеНалогов.Представление()));
		КонецЕсли;
	ИначеЕсли Показатель.Заполнение.Отбор.Свойство("РаспределениеИсточник") Тогда
		Если Показатель.Заполнение.Отбор.РаспределениеИсточник = "ЕдиныйНалоговыйПлатеж" Тогда
			
			Описание.ШагиРасчета.Добавить(, "СсылкаКорректировки?");
			Описание.ШагиРасчета.Добавить(, "Налог");
			Описание.ШагиРасчета.Добавить(, "ОперацияНалога");
			
			ТекстОписания.Добавить(НСтр(
				"ru = 'Значение показателя корректируется с учетом сведений о суммах, отнесенных налоговым органом к видам обязательств, данные о выполнении которых отражаются в других показателях отчета.
                 |Для такой корректировки учитываются суммы:
                 |- списаний налоговым органом с единого налогового счета в счет уплаты налогов и иных обязательств
                 |- зачета переплаты прошлого отчетного периода
                 |- возмещений на единый налоговый счет, в частности, налога на добавленную стоимость.
                 |Суммы зачета переплаты и возмещений определяется расчетным путем, как превышение списаний с ЕНС над поступлениями, распределенное по видам обязательств.'",
				КодЯзыка));
			
			ТекстРазъяснения.Добавить(СтрШаблон(
					НСтр("ru = 'Сведения о суммах, отнесенных налоговым органом к отдельным видам обязательств, см. в документах %1.'", КодЯзыка),
					Метаданные.Документы.СведенияОбУплатеНалогов.Представление()));
					
			ДобавитьОписаниеПорядкаВременногоУчетаЕдиногоНалоговогоПлатежа(ТекстРазъяснения, ДанныеАлгоритма, КодЯзыка);
			
		КонецЕсли;
	КонецЕсли;
	
	Если БухгалтерскаяОтчетностьБРО.ИдентификаторПоказателя(Показатель) = ДанныеАлгоритма.ПоказательЕдиныйНалоговыйПлатежБезРаспределения Тогда
		ТекстРазъяснения.Добавить(НСтр(
			"ru = 'В учетной политике выбран вариант представления в отчете общей суммы единого налогового платежа
             |(п. 2 Рекомендации БМЦ Р-175/2025-КпР ""Единый налоговый счет"")'",
			КодЯзыка));
	КонецЕсли;
	
	Описание.Текст = СтрСоединить(ТекстОписания, Символы.ПС);
	Описание.Разъяснение = СтрСоединить(ТекстРазъяснения, Символы.ПС);
	
КонецПроцедуры

Процедура ОписатьЗаполняемоеЗначениеДенежныеПотоки(ЗаписьРасчет, СоставШагаРасчета, ДанныеАлгоритма, КодЯзыка)
	
	Если ЗаписьРасчет.ТипЗаписи = "ЭтоДвижениеДенежныхСредств" Тогда
		Если СоставШагаРасчета.ЭтоДвижениеДенежныхСредств Тогда
			ЗаписьРасчет.Описание = НСтр("ru = 'Оборот по счетам учета денежных средств'", КодЯзыка);
		Иначе
			ЗаписьРасчет.Описание = НСтр("ru = 'Корректировки других показателей отчета'", КодЯзыка);
		КонецЕсли;
	ИначеЕсли ЗаписьРасчет.ТипЗаписи = "ВидКорректировки" Тогда
		Если Не ЗначениеЗаполнено(СоставШагаРасчета.ВидКорректировки) Тогда
			ЗаписьРасчет.Описание = НСтр("ru = 'Всего'", КодЯзыка);
		Иначе
			ОписаниеКорректировки = ДанныеАлгоритма.ПредставленияСворачиваемыхДенежныхПотоков.НайтиПоЗначению(СоставШагаРасчета.ВидКорректировки);
			Если ОписаниеКорректировки <> Неопределено Тогда
				Если СоставШагаРасчета.Свойство("ЭтоДвижениеДенежныхСредств") Тогда
					// Слова про корректировку уже прозвучали
					ЗаписьРасчет.Описание = ОбщегоНазначенияБПКлиентСервер.КапитализироватьСтроку(ОписаниеКорректировки.Представление);
				Иначе
					ЗаписьРасчет.Описание = СтрШаблон(НСтр("ru = 'Исключены %1'", КодЯзыка), ОписаниеКорректировки.Представление);
				КонецЕсли;
			ИначеЕсли СоставШагаРасчета.ВидКорректировки = "ВременныйУчетЕдиногоНалоговогоПлатежа" Тогда
				ЗаписьРасчет.Описание = НСтр("ru = 'Суммы единого налогового платежа перенесены в одноименный показатель'", КодЯзыка);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ЗаписьРасчет.ТипЗаписи = "СсылкаКорректировки" Тогда
		ЗаписьРасчет.Описание = ПредставлениеСсылкиПоказателя(СоставШагаРасчета.СсылкаКорректировки, ЗаписьРасчет, ДанныеАлгоритма);
	ИначеЕсли ЗаписьРасчет.ТипЗаписи = "ВидКорректировкиДляОписанияСсылки" Тогда
		ПредставлениеПредметаКорректировки = ПредставлениеПредметаКорректировки(
			СоставШагаРасчета.ВидКорректировкиДляОписанияСсылки,
			ДанныеАлгоритма.ПредставленияСворачиваемыхДенежныхПотоков,
			КодЯзыка);
		ЗаписьРасчет.Описание = ОбщегоНазначенияБПКлиентСервер.КапитализироватьСтроку(ПредставлениеПредметаКорректировки);
	ИначеЕсли ЗаписьРасчет.ТипЗаписи = "ОперацияНалога" Тогда
		Если ТипЗнч(СоставШагаРасчета.ОперацияНалога) = Тип("Число") Тогда
			ЗаписьРасчет.Описание = НСтр(ДанныеАлгоритма.ОперацииНалогов[СоставШагаРасчета.ОперацияНалога].Представление, КодЯзыка);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ПредставленияСворачиваемыхДенежныхПотоков(КодЯзыка)
	
	Представления = Новый СписокЗначений;
	
	Представления.Добавить("НДС", НСтр("ru = 'суммы НДС'", КодЯзыка));
	
	Если ПолучитьФункциональнуюОпцию("ОсуществляетсяЗакупкаТоваровУслугДляКомитентов") Тогда
		Представления.Добавить("АгентПокупателя", НСтр("ru = 'поступления и платежи, относящиеся к деятельности агента при покупках в интересах комитента'", КодЯзыка));
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ОсуществляетсяРеализацияТоваровУслугКомитентов") Тогда
		Представления.Добавить("АгентПродавца", НСтр("ru = 'поступления и платежи, относящиеся к деятельности агента при продажах в интересах комитента'", КодЯзыка));
	КонецЕсли;
	
	Если БухгалтерскийУчетПереопределяемый.ИспользоватьВалютныйУчет() Тогда
		Представления.Добавить("ОбменВалют",      НСтр("ru = 'выгоды и потери от валютно-обменных операций'", КодЯзыка));
		Представления.Добавить("КурсовыеРазницы", НСтр("ru = 'последствия изменений курсов валют'", КодЯзыка));
	КонецЕсли;
	
	Возврат Представления;
	
КонецФункции

Функция ПредставлениеПредметаКорректировки(ВидКорректировки, ПредставленияСворачиваемыхДенежныхПотоков, КодЯзыка)
	
	Если ВидКорректировки = "ВременныйУчетЕдиногоНалоговогоПлатежа" Тогда
		Возврат НСтр("ru = 'единый налоговый платеж'", КодЯзыка);
	Иначе
		// См. ПредставленияСворачиваемыхДенежныхПотоков()
		ОписаниеКорректировки = ПредставленияСворачиваемыхДенежныхПотоков.НайтиПоЗначению(ВидКорректировки);
		Если ОписаниеКорректировки <> Неопределено Тогда
			Возврат ОписаниеКорректировки.Представление;
		КонецЕсли;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

#Область ПредставленияСсылокПоказателей

Функция ПредставленияСсылокПоказателей(КорректировочныеПоказатели, ЗаполняемыеПоказатели, КодЯзыка)
	
	ПредставленияПоказателей = Новый Структура;
	ПредставленияПоказателей.Вставить("ГруппыПоказателей", Новый Соответствие); // Ключ - идентификатор показателя; Значение - идентификатор группы
	ПредставленияПоказателей.Вставить("ПредставленияОдинаковойГруппы", Новый Соответствие); // Ключ - идентификатор показателя; Значение - представление
	ПредставленияПоказателей.Вставить("ПредставленияРазныхГрупп", Новый Соответствие); // Ключ - идентификатор показателя; Значение - представление
	
	КодыПоказателей = Новый Соответствие; // Ключ - идентификатор показателя, Значение - коды групп
	Для Каждого ГруппаПоказателей Из ЗаполняемыеПоказатели.ГруппыПоказателей Цикл
		ИдентификаторГруппы = БухгалтерскаяОтчетностьБРО.ИдентификаторПоказателя(ГруппаПоказателей);
		Если ГруппаПоказателей.Показатель <> Неопределено Тогда
			ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(КодыПоказателей, ГруппаПоказателей.Показатель, ГруппаПоказателей.КодСтроки);
			ПредставленияПоказателей.ГруппыПоказателей.Вставить(ГруппаПоказателей.Показатель, ИдентификаторГруппы);
		Иначе
			Для Каждого Показатель Из ГруппаПоказателей.Состав Цикл
				ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(КодыПоказателей, Показатель, ГруппаПоказателей.КодСтроки);
				ПредставленияПоказателей.ГруппыПоказателей.Вставить(Показатель, ИдентификаторГруппы);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Показатель Из ЗаполняемыеПоказатели.Показатели Цикл
		
		ИдентификаторПоказателя = БухгалтерскаяОтчетностьБРО.ИдентификаторПоказателя(Показатель);
		ПредставленияПоказателей.ПредставленияОдинаковойГруппы.Вставить(ИдентификаторПоказателя, Показатель.Наименование);
		ПредставленияПоказателей.ПредставленияРазныхГрупп.Вставить(
			ИдентификаторПоказателя,
			ПредставлениеПоказателяКодыСтрок(Показатель, КодыПоказателей[ИдентификаторПоказателя], КодЯзыка));
		
	КонецЦикла;
	
	Возврат ПредставленияПоказателей;
	
КонецФункции

Функция ПредставлениеПоказателяКодыСтрок(Показатель, КодыСтрок, КодЯзыка)
	
	ПредставлениеКодовСтрок = СтрСоединить(КодыСтрок, НСтр("ru = ', '", КодЯзыка));
	Возврат СтрШаблон(НСтр("ru = '%1 (см. %2)'", КодЯзыка), Показатель.Наименование, ПредставлениеКодовСтрок);
	
КонецФункции

Функция ПредставлениеСсылкиПоказателя(СсылкаПоказателя, ЗаписьРасчет, ДанныеАлгоритма)
	
	// Показатель в ЗаписьРасчет (ЭтотПоказатель) ссылается на какой-то другой показатель (СсылкаПоказателя).
	// Они могут входить в одну группу или в разные.
	// От этого зависит представление.
	ЭтотПоказатель = ИдентификаторПоказателяПоЗаписьРасчет(ЗаписьРасчет);
	ГруппаЭтогоПоказателя = ДанныеАлгоритма.ПредставленияСсылокПоказателей.ГруппыПоказателей[ЭтотПоказатель];
	ГруппаСсылкиПоказателя = ДанныеАлгоритма.ПредставленияСсылокПоказателей.ГруппыПоказателей[СсылкаПоказателя];
	НаборПредставлений = ДанныеАлгоритма.ПредставленияСсылокПоказателей.ПредставленияРазныхГрупп;
	Если ГруппаЭтогоПоказателя = ГруппаСсылкиПоказателя Тогда
		НаборПредставлений = ДанныеАлгоритма.ПредставленияСсылокПоказателей.ПредставленияОдинаковойГруппы;
	КонецЕсли;
	
	Возврат НаборПредставлений[СсылкаПоказателя];
	
КонецФункции

Функция ИдентификаторПоказателяПоЗаписьРасчет(ЗаписьРасчет)
	
	ЗаписьРасчетПоказателя = ЗаписьРасчет;
	Пока Истина Цикл
		Родитель = ЗаписьРасчетПоказателя.Родитель;
		Если Родитель = Неопределено Тогда
			Возврат ЗаписьРасчетПоказателя.Показатель;
		КонецЕсли;
		ЗаписьРасчетПоказателя = Родитель;
	КонецЦикла;
	
КонецФункции

