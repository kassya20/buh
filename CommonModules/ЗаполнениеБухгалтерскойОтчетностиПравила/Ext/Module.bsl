Функция ТипИмя()
	СтандартнаяДлинаИмени = 255;
	Возврат ОбщегоНазначения.ОписаниеТипаСтрока(СтандартнаяДлинаИмени);
КонецФункции

Функция НовыйКорректировочныеПоказатели()
	
	ТипИмя = ТипИмя();
	
	КорректировочныеПоказатели = Новый ТаблицаЗначений;
	КорректировочныеПоказатели.Колонки.Добавить("Вид", ТипИмя);
	КорректировочныеПоказатели.Колонки.Добавить("Направление", ТипИмя); // Сворачивание, РаспределениеПриемник, РаспределениеИсточник
	КорректировочныеПоказатели.Колонки.Добавить("Показатель", Новый ОписаниеТипов("Число"));
	
	Возврат КорректировочныеПоказатели;
	
КонецФункции

Функция КорректировочныеПоказателиДенежныхПотоков(ЗаполняемыеПоказатели)
	
	КорректировочныеПоказатели = НовыйКорректировочныеПоказатели();
	
	Для Каждого ОписаниеПоказателя Из ЗаполняемыеПоказатели.Показатели Цикл
		
		Если ОписаниеПоказателя.Заполнение.Идентификатор <> ИдентификаторАлгоритмаДенежныеПотоки() Тогда
			Продолжить;
		КонецЕсли;
		
		Вид         = Неопределено;
		Направление = Неопределено;
		
		Если ОписаниеПоказателя.Заполнение.Отбор.Свойство("Свернутый") Тогда
			
			Вид         = ОписаниеПоказателя.Заполнение.Отбор.Свернутый;
			Направление = "Сворачивание";
			
		ИначеЕсли ОписаниеПоказателя.Заполнение.Отбор.Свойство("РаспределениеПриемник") Тогда
			Вид         = ОписаниеПоказателя.Заполнение.Отбор.РаспределениеПриемник.Ключ;
			Направление = "РаспределениеПриемник";
		ИначеЕсли ОписаниеПоказателя.Заполнение.Отбор.Свойство("РаспределениеИсточник") Тогда
			Вид         = ОписаниеПоказателя.Заполнение.Отбор.РаспределениеИсточник;
			Направление = "РаспределениеИсточник";
		КонецЕсли;
		
		Если Вид <> Неопределено Тогда
			
			Корректировка = КорректировочныеПоказатели.Добавить();
			Корректировка.Вид         = Вид;
			Корректировка.Направление = Направление;
			Корректировка.Показатель  = БухгалтерскаяОтчетностьБРО.ИдентификаторПоказателя(ОписаниеПоказателя);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат КорректировочныеПоказатели;
	
КонецФункции

Функция НовыйСворачиваемыеПоказатели()
	
	СворачиваемыеПоказатели = Новый ТаблицаЗначений;
	СворачиваемыеПоказатели.Колонки.Добавить("Вид", ТипИмя());
	СворачиваемыеПоказатели.Колонки.Добавить("Показатель", Новый ОписаниеТипов("Число"));
	
	Возврат СворачиваемыеПоказатели;
	
КонецФункции

Функция СворачиваемыеПоказатели(ЗаполняемыеПоказатели)
	
	СворачиваемыеПоказатели = НовыйСворачиваемыеПоказатели();
	
	Для Каждого ОписаниеПоказателя Из ЗаполняемыеПоказатели.Показатели Цикл
		
		Если ОписаниеПоказателя.Заполнение.Идентификатор <> ИдентификаторАлгоритмаДенежныеПотоки() Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СворачиваемыйПоток Из ОписаниеПоказателя.Заполнение.НастройкиАлгоритма.Сворачиваемые Цикл
			
			ИмяСворачиваемогоПотока = СворачиваемыйПоток.Ключ;
			
			ОписаниеСворачиваемогоПоказателя = СворачиваемыеПоказатели.Добавить();
			ОписаниеСворачиваемогоПоказателя.Показатель = БухгалтерскаяОтчетностьБРО.ИдентификаторПоказателя(ОписаниеПоказателя);;
			ОписаниеСворачиваемогоПоказателя.Вид = ИмяСворачиваемогоПотока;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат СворачиваемыеПоказатели;
	
КонецФункции

Функция НайтиКорректировочныйПоказательДенежныхПотоков(КорректировочныеПоказатели, ВидКорректировки, НаправлениеКорректировки)
	
	Отбор = Новый Структура;
	Отбор.Вставить("Вид", ВидКорректировки);
	Отбор.Вставить("Направление", НаправлениеКорректировки);
	
	Поиск = КорректировочныеПоказатели.НайтиСтроки(Отбор);
	Если Не ЗначениеЗаполнено(Поиск) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Поиск[0].Показатель;
	
КонецФункции

Функция НайтиПоказательДенежныхПотоковПоВидуСтатьи(ВидСтатьи, ЗаполняемыеПоказатели)
	
	Для Каждого Показатель Из ЗаполняемыеПоказатели.Показатели Цикл
		
		Если Показатель.Заполнение.Идентификатор <> ИдентификаторАлгоритмаДенежныеПотоки() Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не Показатель.Заполнение.Отбор.Свойство("ВидСтатьи") Тогда
			Продолжить;
		КонецЕсли;
		
		Если Показатель.Заполнение.Отбор.ВидСтатьи.Найти(ВидСтатьи) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Возврат БухгалтерскаяОтчетностьБРО.ИдентификаторПоказателя(Показатель);
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

#Область ПотокиЕдиногоНалоговогоСчета

// Реализует Рекомендацию БМЦ Р-175.
// Поток в виде единого налогового платежа может отражаться
// - общей суммой (п. 2 Рекомендации)
// - раздельно по видам налогов - распределяться между показателями на основе данных из ФНС (п. 3 Рекомендации).

Функция РаспределятьЕдиныйНалоговыйПлатеж(Контекст)
	
	Если Не ЗначениеЗаполнено(Контекст.Организация) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат УчетнаяПолитика.РаспределятьЕдиныйНалоговыйПлатеж(Контекст.Период, Контекст.Организация);
	
КонецФункции

Процедура ДобавитьГруппуОтрицательныхЗначенийЕдиныйНалоговыйПлатеж(Процессор, КодСтроки, НаименованиеГруппы, ПоказательЕдиныйНалоговыйПлатеж)
	
	// В соответствии с п. 2 Рекомендации БМЦ Р-175 в ОДДС отражается общая сумма единого налогового платежа отдельным показателем.
	// В частном случае чистое значение такого потока может оказаться положительным - и тогда его следует отразить как поступление.
	// Как правило, показатели, отражаемые в ОДДС в поступлениях или в платежах в зависимости от знака,
	// входят в группы Прочие поступления/Прочие платежи.
	// Показатель ЕНП - исключение, он должен входить в обособленную группу, поэтому группу отрицательных значений определяем отдельно от других.
	
	ДобавитьГруппу(Процессор, КодСтроки, НаименованиеГруппы);
	ДобавитьПоказательОтрицательногоЗначения(Процессор, ПоказательЕдиныйНалоговыйПлатеж);
	
КонецПроцедуры

Процедура ДобавитьПоказательРаспределенныйЕдиныйНалоговыйПлатеж(Процессор, ОтборНалогов, Наименование)
	
	ДобавитьПоказательРаспределенногоДенежногоПотока(
		Процессор,
		Перечисления.ВидыДвиженийДенежныхСредств.ЕдиныйНалоговыйПлатеж,
		ОтборНалогов,
		Наименование);
	
КонецПроцедуры

Функция НайтиПоказательЕдиныйНалоговыйПлатеж(ЗаполняемыеПоказатели)
	
	Возврат НайтиПоказательДенежныхПотоковПоВидуСтатьи(
		Перечисления.ВидыДвиженийДенежныхСредств.ЕдиныйНалоговыйПлатеж,
		ЗаполняемыеПоказатели);
	
КонецФункции

Функция НалоговыеПлатежиНДФЛ(КодыВидовДохода)
	
	Налоги = Новый Массив;
	Для Каждого Код Из КодыВидовДохода Цикл
		
		Налог = Справочники.ВидыНалоговИПлатежейВБюджет.НалогПоВиду(Перечисления.ВидыНалогов.НДФЛ, Ложь, , Код, Ложь);
		Если ЗначениеЗаполнено(Налог) Тогда
			Налоги.Добавить(Налог);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ОбщегоНазначенияКлиентСервер.СвернутьМассив(Налоги);
	
КонецФункции

Функция НалоговыеПлатежиНДФЛОплатыТруда()
	
	// Одинаковый элемент Перечисления.ВидыНалогов.НДФЛ для удобства используется для всего агентского НДФЛ -
	// как связанного с выплатами сотрудникам, так и нет (см. дивиденды).
	// Поэтому здесь не получится опираться на него, нужно опираться на коды бюджетной классификации.
	
	Возврат НалоговыеПлатежиНДФЛ(Справочники.ВидыНалоговИПлатежейВБюджет.КодыВидовДоходаНДФЛ_ОплатаТруда());
	
КонецФункции

