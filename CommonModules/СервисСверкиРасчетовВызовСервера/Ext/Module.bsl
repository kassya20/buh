#Область СлужебныйПрограммныйИнтерфейс

Функция МожноПодключитьОбсуждения() Экспорт
	
	Возврат ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.Обсуждения");
	
КонецФункции

Функция ОбсужденияПодключены() Экспорт
	
	Если МожноПодключитьОбсуждения() Тогда
		МодульОбсуждения = ОбщегоНазначения.ОбщийМодуль("Обсуждения");
		Возврат МодульОбсуждения.ОбсужденияДоступны();
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ДатаНачалаСверкиРасчетов() Экспорт
	
	Возврат СервисСверкиРасчетов.ДатаНачалаСверкиРасчетов();
	
КонецФункции

// Формирует отчет по переданным параметрам.
//
// Параметры:
// ПараметрыОтчета - Структура - см. Отчеты.СверкаРасчетовСКонтрагентами.ПустыеПараметрыКомпоновкиОтчета() 
//
// Возвращаемое значение:
//   Структура   - содержит ключи:
//      * Результат - ТабличныйДокумент - сформированный отчет.
//      * ИтогиСверки - Структура - см. СервисСверкиРасчетов.ИтогиСверки()
//      * ДанныеРасшифровки - Строка - адрес во временном хранилище, куда помещены данные расшифровок.
//
Функция ПодготовитьОтчет(ПараметрыОтчета) Экспорт
	
	Перем ДанныеРасшифровкиОбъект;
	
	Результат = Новый ТабличныйДокумент;
	ИтогиСверки = СервисСверкиРасчетов.ИтогиСверки(
		ПараметрыОтчета.Организация,
		ПараметрыОтчета.Контрагент, 
		ПараметрыОтчета.НачалоПериода,
		ПараметрыОтчета.КонецПериода,
		ПараметрыОтчета.ИдентификаторыРасхождений,
		ПараметрыОтчета.ВключатьОбособленныеПодразделения);
	
	РезультатФормированияОтчета = Новый Структура;
	РезультатФормированияОтчета.Вставить("Результат",         Результат);
	РезультатФормированияОтчета.Вставить("ИтогиСверки",       ИтогиСверки);
	РезультатФормированияОтчета.Вставить("ДанныеРасшифровки", ПараметрыОтчета.ДанныеРасшифровки);
	РезультатФормированияОтчета.Вставить("Выполнено",         Истина);
	РезультатФормированияОтчета.Вставить("КраткоеПредставлениеОшибки",   "");
	РезультатФормированияОтчета.Вставить("ПодробноеПредставлениеОшибки", "");
	
	МенеджерОтчета = Отчеты.СверкаРасчетовСКонтрагентами;
	
	СхемаКомпоновкиДанных = ПараметрыОтчета.СхемаКомпоновкиДанных;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.ЗагрузитьНастройки(ПараметрыОтчета.НастройкиКомпоновкиДанных);
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	
	Макет = Отчеты.СверкаРасчетовСКонтрагентами.ПолучитьМакет("МакетЗаголовковОтчета");
	
	ОбластьЗаголовок    = Макет.ПолучитьОбласть("Заголовок");
	ОбластьСтатистика   = Макет.ПолучитьОбласть("Статистика");
	ОбластьОтбор        = Макет.ПолучитьОбласть("Отбор");
	ОбластьАктуальность = Макет.ПолучитьОбласть("Актуальность");
	
	// Заголовок
	ОбластьЗаголовок.Параметры.ЗаголовокОтчета = МенеджерОтчета.ПолучитьТекстЗаголовка(ПараметрыОтчета);
	Результат.Вывести(ОбластьЗаголовок);
	
	// Актуальность
	Если ЗначениеЗаполнено(ПараметрыОтчета.ДатаАктуальности) Тогда
		ОбластьАктуальность.Параметры.ДатаАктуальности = ПараметрыОтчета.ДатаАктуальности;
		Результат.Вывести(ОбластьАктуальность);
	КонецЕсли;
	
	// Статистика
	Если Не ПараметрыОтчета.ОтборНеСверено Тогда
		ОбластьСтатистика.Параметры.Сверено        = ИтогиСверки.Сверено;
		ОбластьСтатистика.Параметры.Критичные      = ИтогиСверки.Критичные;
		ОбластьСтатистика.Параметры.Незначительные = ИтогиСверки.Незначительные;
		ОбластьСтатистика.Параметры.БезРасхождений = ИтогиСверки.БезРасхождений;
		Результат.Вывести(ОбластьСтатистика);
	КонецЕсли;
	
	// Отбор
	ВыводитьОтбор = ПараметрыОтчета.ОтборОтличаетсяСумма
		ИЛИ ПараметрыОтчета.ОтборОтличаетсяСФ
		ИЛИ ПараметрыОтчета.ОтборОтсутствуетДокумент
		ИЛИ ПараметрыОтчета.ОтборКонтрагентНеУчитываетНДС
		ИЛИ ПараметрыОтчета.ОтборОтличаетсяПервичныйДокумент 
		ИЛИ ПараметрыОтчета.ОтборБезРасхождений;
	
	Если ВыводитьОтбор Тогда
		СтрокаОтбор = "";
		
		Если ПараметрыОтчета.ПоказатьВсе Тогда
			СтрокаОтбор = НСтр("ru = 'все сверенные документы'");
		Иначе
			// Критичные
			Если ПараметрыОтчета.ОтборОтличаетсяСумма
				ИЛИ ПараметрыОтчета.ОтборОтличаетсяСФ
				ИЛИ ПараметрыОтчета.ОтборОтсутствуетДокумент Тогда 
				СтрокаОтбор = НСтр("ru = 'критичные расхождения'");
				Если НЕ ПараметрыОтчета.ОтборОтличаетсяСумма
					ИЛИ НЕ ПараметрыОтчета.ОтборОтличаетсяСФ
					ИЛИ НЕ ПараметрыОтчета.ОтборОтсутствуетДокумент Тогда
					УточнениеОтбора = "";
					Если ПараметрыОтчета.ОтборОтличаетсяСумма Тогда
						УточнениеОтбора = НСтр("ru = 'сумма и НДС'");
					КонецЕсли;
					Если ПараметрыОтчета.ОтборОтличаетсяСФ Тогда
						УточнениеОтбора = УточнениеОтбора + ?(ЗначениеЗаполнено(УточнениеОтбора), ", ", "") + НСтр("ru = 'реквизиты счета-фактуры'");
					КонецЕсли;
					Если ПараметрыОтчета.ОтборОтсутствуетДокумент Тогда
						УточнениеОтбора = УточнениеОтбора + ?(ЗначениеЗаполнено(УточнениеОтбора), ", ", "") + НСтр("ru = 'отсутствует документ'");
					КонецЕсли;
					СтрокаОтбор = СтрокаОтбор + " (" + УточнениеОтбора + ")";
				КонецЕсли;
			КонецЕсли;
			
			// Незначительные
			Если ПараметрыОтчета.ОтборКонтрагентНеУчитываетНДС
				ИЛИ ПараметрыОтчета.ОтборОтличаетсяПервичныйДокумент Тогда 
				СтрокаОтбор = СтрокаОтбор + ?(ЗначениеЗаполнено(СтрокаОтбор), "; ", "") + НСтр("ru = 'незначительные расхождения'");  
				Если НЕ ПараметрыОтчета.ОтборКонтрагентНеУчитываетНДС
					ИЛИ НЕ ПараметрыОтчета.ОтборОтличаетсяПервичныйДокумент Тогда
					УточнениеОтбора = "";
					Если ПараметрыОтчета.ОтборКонтрагентНеУчитываетНДС Тогда
						УточнениеОтбора = НСтр("ru = 'контрагент не учитывает НДС'");
					КонецЕсли;
					Если ПараметрыОтчета.ОтборОтличаетсяПервичныйДокумент Тогда
						УточнениеОтбора = УточнениеОтбора + ?(ЗначениеЗаполнено(УточнениеОтбора), ", ", "") + НСтр("ru = 'реквизиты первичного документа'");
					КонецЕсли;
					СтрокаОтбор = СтрокаОтбор + " (" + УточнениеОтбора + ")";
				КонецЕсли;
			КонецЕсли;
			
			// Без расхождений
			Если ПараметрыОтчета.ОтборБезРасхождений Тогда 
				СтрокаОтбор = СтрокаОтбор + ?(ЗначениеЗаполнено(СтрокаОтбор), "; ", "") + НСтр("ru = 'без расхождений'");  
			КонецЕсли;
		КонецЕсли;
		ОбластьОтбор.Параметры.Отбор = СтрокаОтбор;
		Результат.Вывести(ОбластьОтбор);
		
	КонецЕсли;
	
	МенеджерОтчета.ПередКомпоновкойМакета(ПараметрыОтчета, СхемаКомпоновкиДанных, КомпоновщикНастроек);
	КомпоновщикНастроек.Восстановить();
	
	НастройкиДляКомпоновкиМакета = КомпоновщикНастроек.ПолучитьНастройки();
	
	// Сгенерируем макет компоновки данных при помощи компоновщика макета
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;

	Попытка
		
		МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиДляКомпоновкиМакета, ДанныеРасшифровкиОбъект);
		МенеджерВременныхТаблицЗапроса = Неопределено;
		ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , ДанныеРасшифровкиОбъект, Истина, , МенеджерВременныхТаблицЗапроса);
		
		// Создадим и инициализируем процессор вывода результата
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
		ПроцессорВывода.УстановитьДокумент(Результат);
		
		ПроцессорВывода.Вывести(ПроцессорКомпоновки, Истина);

		ДанныеДляРасшифровки = Новый Структура("Объект, ДанныеРасшифровки", ПараметрыОтчета, ДанныеРасшифровкиОбъект);
		РезультатФормированияОтчета.ДанныеРасшифровки = ПоместитьВоВременноеХранилище(
			ДанныеДляРасшифровки, РезультатФормированияОтчета.ДанныеРасшифровки);
		
	Исключение

		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
			
		// Записываем в журнал регистрации
		Событие = НСтр("ru = 'Ошибка формирования отчета'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗаписьЖурналаРегистрации(
			Событие,
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.Отчеты[ПараметрыОтчета.ИдентификаторОтчета],
			, // Данных нет
			ПодробноеПредставлениеОшибки);
		
		// Информируем пользователя файловой версии
		Пока ИнформацияОбОшибке.Причина <> Неопределено Цикл
			ИнформацияОбОшибке = ИнформацияОбОшибке.Причина;
		КонецЦикла;
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Отчет не сформирован! %1'"), ИнформацияОбОшибке.Описание);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		РезультатФормированияОтчета.Выполнено                    = Ложь;
		РезультатФормированияОтчета.КраткоеПредставлениеОшибки   = ТекстСообщения;
		РезультатФормированияОтчета.ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки;
		
		Возврат РезультатФормированияОтчета;
		
	КонецПопытки;
	
	МенеджерОтчета.ПослеВыводаРезультата(ПараметрыОтчета, Результат);
	
	Возврат РезультатФормированияОтчета;
	
КонецФункции

// Возвращает признак подключена сверка для организации или нет
//
// Входящие параметры:
// 		- Организация - СправочникСсылка.Организации
// 		- Дата - Дата
// Возвращаемое значение:
// 		- Истина - для организации подключена сверка
// 		- Ложь   - для организации не подключена сверка
//
Функция ОрганизацияПодключена(Организация, Дата) Экспорт
	
	Возврат ПолучитьФункциональнуюОпцию("ИспользуетсяСервисСверкиРасчетов")
		И БизнесСеть.ОрганизацияПодключена(Организация);
		
КонецФункции

