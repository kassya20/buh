	МобильныйКлиентБП.ПроверитьИЗарегистроватьСобытиеДляОценки(ИдентификаторОперации, ПоказыватьФормуОценки);
	
КонецПроцедуры

#Область СозданиеПлатежаПоQR

Функция НовоеПлатежноеПоручениеПоРеквизитамQRКода(СтрокаQR, ТекстСообщенияОбОшибке) Экспорт
	
	СтрокаУФЭБС = "";
	Если СтрНачинаетсяС(СтрокаQR, "ST0001") Тогда
		СтрокаУФЭБС = СтрокаQR;
	ИначеЕсли ОнлайнЗаказыКлиентСервер.ЭтоURLСервиса(СтрокаQR)
		И ОнлайнЗаказы.ОнлайнЗаказыДоступны() Тогда
		ДанныеЗаказа = ОнлайнЗаказы.ПубличныеДанныеЗаказа(СтрокаQR);
		СтрокаУФЭБС = ДанныеЗаказа.ПараметрыОплат.ПоРеквизитам.ДанныеQR;
	КонецЕсли;
	
	Если Не ПустаяСтрока(СтрокаУФЭБС) Тогда
		Возврат Документы.ПлатежноеПоручение.НовоеПлатежноеПоручениеПоРеквизитамУФЭБС(СтрокаУФЭБС, ТекстСообщенияОбОшибке);
	Иначе
		ТекстСообщенияОбОшибке = НСтр("ru = 'Данный вид QR кода не поддерживается'");
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

#КонецОбласти
// Преобразует табличный документ в двоичные данные и возвращает адрес временного хранилища, куда они помещены.
//
// Параметры:
//  СохраняемыйДокумент - ТабличныйДокумент - преобразуемый в двоичные данные.
//  ТипФайла - ТипФайлаТабличногоДокумента - позволяет переопределить формат файла
//
// Возвращаемое значение:
//   Структура
//    АдресДвоичныхДанных - адрес временного хранилища, содержащего объект типа ДвоичныеДанные.
//    РасширениеФайла - Строка - расширение типа файла
//
Функция ДвоичныеДанныеИзТабличногоДокумента(СохраняемыйДокумент, ТипФайла = Неопределено) Экспорт
	
	Если ТипФайла = Неопределено Тогда
		ТипФайла = ТипФайлаТабличногоДокумента.XLSX;
	КонецЕсли;
	ДвоичныеДанныеФайла = БухгалтерскиеОтчеты.ДвоичныеДанныеИзТабличногоДокумента(СохраняемыйДокумент, ТипФайла);
	
	ТаблицаФорматов = УправлениеПечатью.НастройкиФорматовСохраненияТабличногоДокумента();
	СтрокиНастроекФормата = ТаблицаФорматов.НайтиСтроки(Новый Структура("ТипФайлаТабличногоДокумента", ТипФайла));
	Если СтрокиНастроекФормата.Количество() = 0 Тогда
		ВызватьИсключение "Необнаружено настроек формата для типа файла" + ТипФайла;
	КонецЕсли;
	
	НастройкиФормата = СтрокиНастроекФормата[0];
	
	Результат = Новый Структура();
	Результат.Вставить("АдресДвоичныхДанных", ПоместитьВоВременноеХранилище(ДвоичныеДанныеФайла));
	Результат.Вставить("РасширениеФайла", НастройкиФормата.Расширение);
	Возврат Результат;
	
КонецФункции

Функция ПараметрыПисьмаРазработчикам() Экспорт
	Параметры  = Новый Структура;
	Параметры.Вставить("ТекстТехническойИнформации",
		МобильныйКлиентБПФормаОбъекта.ТекстТехническойИнформации());
	Параметры.Вставить("ЕстьДоступныеУчетныеЗаписиДляОтправки",
		РаботаСПочтовымиСообщениямиВызовСервера.ЕстьДоступныеУчетныеЗаписиДляОтправки());
	Параметры.Вставить("ЭтоБизнесСтарт",
		ОбщегоНазначенияБП.ЭтоБизнесСтарт());
	
	Возврат Параметры;
КонецФункции

#КонецОбласти
