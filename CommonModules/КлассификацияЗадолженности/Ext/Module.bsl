	Запрос.Выполнить();
		
КонецПроцедуры

// Предназначена для корректировки остатков по активно-пассивным счетам с учетом детализации в балансе.
// В акте инвентаризации есть возможность указать полную аналитику по счету, по ней дату погашения и фактический остаток.
// При этом в балансе отражены расчеты до определенной детализации.
// Например, по счету 76.05 в акте инвентаризации указана дата погашения по конкретному поступлению товаров.
// При классификации по срокам учитывается данный документ. Но в баланс уже должны попасть свернутые данные по договору.
// Поэтому корректируем остатки в случае расхождений свернутых остатков с учетом документов расчетов и свернутых остатков с учетом договоров.
Процедура СкорректироватьОстаткиСУчетомДетализацииБаланса(МенеджерВременныхТаблиц, ВидЗадолженности)

	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	
	РасчетыСДебиторамиИКредиторами = СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыСРазнымиДебиторамиИКредиторами, ВидыСчетов);
	КорректировочныеСчетаДетализацияДоДоговоров = ЗаполнениеБухгалтерскойОтчетностиТабличное.СчетаПоСубконто(
													РасчетыСДебиторамиИКредиторами,
													ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами); 
	КорректировочныеСчетаДетализацияДоДоговоров = ЗаполнениеБухгалтерскойОтчетностиТабличное.СчетаПоСубконто(
													КорректировочныеСчетаДетализацияДоДоговоров,
													ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КорректировочныеСчетаДетализацияДоДоговоров", КорректировочныеСчетаДетализацияДоДоговоров);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АПРасчетыПоДокументамРасчетов.Организация КАК Организация,
	|	АПРасчетыПоДокументамРасчетов.Счет КАК Счет,
	|	АПРасчетыПоДокументамРасчетов.Субконто1 КАК Субконто1,
	|	АПРасчетыПоДокументамРасчетов.Субконто2 КАК Субконто2,
	|	НЕОПРЕДЕЛЕНО КАК Субконто3,
	|	ВЫБОР
	|		КОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт) > СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт)
	|			ТОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт) - СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОстатокДт,
	|	ВЫБОР
	|		КОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт) < СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт)
	|			ТОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт) - СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОстатокКт,
	|	СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт) <> ВЫБОР
	|			КОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт) > СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт)
	|				ТОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт) - СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт)
	|			ИНАЧЕ 0
	|		КОНЕЦ
	|		ИЛИ СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт) <> ВЫБОР
	|			КОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт) < СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт)
	|				ТОГДА СУММА(АПРасчетыПоДокументамРасчетов.ОстатокКт) - СУММА(АПРасчетыПоДокументамРасчетов.ОстатокДт)
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК НеобходимоСкорректировать
	|ПОМЕСТИТЬ СгруппированныеРасчетыПоДоговорам
	|ИЗ
	|	АПРасчетыПоДокументамРасчетов КАК АПРасчетыПоДокументамРасчетов
	|ГДЕ
	|	АПРасчетыПоДокументамРасчетов.Счет В(&КорректировочныеСчетаДетализацияДоДоговоров)
	|
	|СГРУППИРОВАТЬ ПО
	|	АПРасчетыПоДокументамРасчетов.Организация,
	|	АПРасчетыПоДокументамРасчетов.Счет,
	|	АПРасчетыПоДокументамРасчетов.Субконто1,
	|	АПРасчетыПоДокументамРасчетов.Субконто2
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АПРасчетыПоДокументамРасчетов.Организация КАК Организация,
	|	АПРасчетыПоДокументамРасчетов.Счет КАК Счет,
	|	АПРасчетыПоДокументамРасчетов.Субконто1 КАК Субконто1,
	|	АПРасчетыПоДокументамРасчетов.Субконто2 КАК Субконто2,
	|	АПРасчетыПоДокументамРасчетов.Субконто3 КАК Субконто3,
	|	АПРасчетыПоДокументамРасчетов.ОстатокДт КАК ОстатокДт,
	|	АПРасчетыПоДокументамРасчетов.ОстатокКт КАК ОстатокКт,
	|	ЕСТЬNULL(СгруппированныеРасчетыПоДоговорам.НеобходимоСкорректировать, ЛОЖЬ) КАК НеобходимоСкорректировать
	|ПОМЕСТИТЬ РасчетыСПолнойДетализацией
	|ИЗ
	|	АПРасчетыПоДокументамРасчетов КАК АПРасчетыПоДокументамРасчетов
	|		ЛЕВОЕ СОЕДИНЕНИЕ СгруппированныеРасчетыПоДоговорам КАК СгруппированныеРасчетыПоДоговорам
	|		ПО АПРасчетыПоДокументамРасчетов.Организация = СгруппированныеРасчетыПоДоговорам.Организация
	|			И АПРасчетыПоДокументамРасчетов.Счет = СгруппированныеРасчетыПоДоговорам.Счет
	|			И АПРасчетыПоДокументамРасчетов.Субконто1 = СгруппированныеРасчетыПоДоговорам.Субконто1
	|			И АПРасчетыПоДокументамРасчетов.Субконто2 = СгруппированныеРасчетыПоДоговорам.Субконто2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыСПолнойДетализацией.Организация КАК Организация,
	|	РасчетыСПолнойДетализацией.Счет КАК Счет,
	|	РасчетыСПолнойДетализацией.Субконто1 КАК Субконто1,
	|	РасчетыСПолнойДетализацией.Субконто2 КАК Субконто2,
	|	РасчетыСПолнойДетализацией.Субконто3 КАК Субконто3,
	|	РасчетыСПолнойДетализацией.ОстатокДт КАК ОстатокДт,
	|	РасчетыСПолнойДетализацией.ОстатокКт КАК ОстатокКт,
	|	ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаРегистратора
	|ИЗ
	|	РасчетыСПолнойДетализацией КАК РасчетыСПолнойДетализацией
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
	|		ПО РасчетыСПолнойДетализацией.Организация = ДанныеПервичныхДокументов.Организация
	|			И РасчетыСПолнойДетализацией.Субконто3 = ДанныеПервичныхДокументов.Документ
	|ГДЕ
	|	РасчетыСПолнойДетализацией.НеобходимоСкорректировать
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	ДатаРегистратора УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СгруппированныеРасчетыПоДоговорам.Организация КАК Организация,
	|	СгруппированныеРасчетыПоДоговорам.Счет КАК Счет,
	|	СгруппированныеРасчетыПоДоговорам.Субконто1 КАК Субконто1,
	|	СгруппированныеРасчетыПоДоговорам.Субконто2 КАК Субконто2,
	|	СгруппированныеРасчетыПоДоговорам.ОстатокДт КАК ОстатокДт,
	|	СгруппированныеРасчетыПоДоговорам.ОстатокКт КАК ОстатокКт
	|ИЗ
	|	СгруппированныеРасчетыПоДоговорам КАК СгруппированныеРасчетыПоДоговорам
	|ГДЕ
	|	СгруппированныеРасчетыПоДоговорам.НеобходимоСкорректировать
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2";
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	ПоследнийИндекс = ПакетЗапросов.ВГраница();
	
	ДанныеСгруппированные = ПакетЗапросов[ПоследнийИндекс].Выгрузить();
	ДанныеРаспределения = ПакетЗапросов[ПоследнийИндекс - 1].Выгрузить();

	ТаблицаРасчетная = Новый ТаблицаЗначений;
	ТаблицаРасчетная.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ТаблицаРасчетная.Колонки.Добавить("Счет", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ТаблицаРасчетная.Колонки.Добавить("Субконто1", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ТаблицаРасчетная.Колонки.Добавить("Субконто2", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	ТаблицаРасчетная.Колонки.Добавить("Субконто3", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами.ТипЗначения);
	ТаблицаРасчетная.Колонки.Добавить("ОстатокДт", БухгалтерскийУчетКлиентСервер.ТипСумма());
	ТаблицаРасчетная.Колонки.Добавить("ОстатокКт", БухгалтерскийУчетКлиентСервер.ТипСумма());
	
	ПересчитатьОстаткиСгруппированнойАналитики(ТаблицаРасчетная, ДанныеСгруппированные, ДанныеРаспределения);
	
	Запрос.УстановитьПараметр("ТаблицаРасчетная", ТаблицаРасчетная);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаРасчетная.Организация КАК Организация,
	|	ТаблицаРасчетная.Счет КАК Счет,
	|	ТаблицаРасчетная.Субконто1 КАК Субконто1,
	|	ТаблицаРасчетная.Субконто2 КАК Субконто2,
	|	ТаблицаРасчетная.Субконто3 КАК Субконто3,
	|	ТаблицаРасчетная.ОстатокДт КАК ОстатокДт,
	|	ТаблицаРасчетная.ОстатокКт КАК ОстатокКт
	|ПОМЕСТИТЬ РаспределенныеДанные
	|ИЗ
	|	&ТаблицаРасчетная КАК ТаблицаРасчетная
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыСПолнойДетализацией.Организация КАК Организация,
	|	РасчетыСПолнойДетализацией.Счет КАК Счет,
	|	РасчетыСПолнойДетализацией.Субконто1 КАК Субконто1,
	|	РасчетыСПолнойДетализацией.Субконто2 КАК Субконто2,
	|	РасчетыСПолнойДетализацией.Субконто3 КАК Субконто3,
	|	РасчетыСПолнойДетализацией.ОстатокДт КАК ОстатокДт,
	|	РасчетыСПолнойДетализацией.ОстатокКт КАК ОстатокКт
	|ПОМЕСТИТЬ СкорректированныеРасчетыСКонтрагентами
	|ИЗ
	|	РасчетыСПолнойДетализацией КАК РасчетыСПолнойДетализацией
	|ГДЕ
	|	НЕ РасчетыСПолнойДетализацией.НеобходимоСкорректировать
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РаспределенныеДанные.Организация,
	|	РаспределенныеДанные.Счет,
	|	РаспределенныеДанные.Субконто1,
	|	РаспределенныеДанные.Субконто2,
	|	РаспределенныеДанные.Субконто3,
	|	РаспределенныеДанные.ОстатокДт,
	|	РаспределенныеДанные.ОстатокКт
	|ИЗ
	|	РаспределенныеДанные КАК РаспределенныеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СгруппированныеРасчетыПоДоговорам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РасчетыСПолнойДетализацией
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РаспределенныеДанные";
	
	Запрос.Выполнить();
	
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкорректированныеРасчетыСКонтрагентами.Организация КАК Организация,
		|	СкорректированныеРасчетыСКонтрагентами.Счет КАК Счет,
		|	СкорректированныеРасчетыСКонтрагентами.Субконто1 КАК Субконто1,
		|	СкорректированныеРасчетыСКонтрагентами.Субконто2 КАК Субконто2,
		|	СкорректированныеРасчетыСКонтрагентами.Субконто3 КАК Субконто3,
		|	СкорректированныеРасчетыСКонтрагентами.ОстатокДт КАК ОстатокДт,
		|	0 КАК ОстатокКт
		|ДОБАВИТЬ РасчетыСКонтрагентамиПоДоговорам
		|ИЗ
		|	СкорректированныеРасчетыСКонтрагентами КАК СкорректированныеРасчетыСКонтрагентами
		|ГДЕ
		|	СкорректированныеРасчетыСКонтрагентами.ОстатокДт <> 0";
		Запрос.Выполнить();
	ИначеЕсли ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкорректированныеРасчетыСКонтрагентами.Организация КАК Организация,
		|	СкорректированныеРасчетыСКонтрагентами.Счет КАК Счет,
		|	СкорректированныеРасчетыСКонтрагентами.Субконто1 КАК Субконто1,
		|	СкорректированныеРасчетыСКонтрагентами.Субконто2 КАК Субконто2,
		|	СкорректированныеРасчетыСКонтрагентами.Субконто3 КАК Субконто3,
		|	0 КАК ОстатокДт,
		|	СкорректированныеРасчетыСКонтрагентами.ОстатокКт КАК ОстатокКт
		|ДОБАВИТЬ РасчетыСКонтрагентамиПоДоговорам
		|ИЗ
		|	СкорректированныеРасчетыСКонтрагентами КАК СкорректированныеРасчетыСКонтрагентами
		|ГДЕ
		|	СкорректированныеРасчетыСКонтрагентами.ОстатокКт <> 0";
		Запрос.Выполнить();
	КонецЕсли;
		
КонецПроцедуры

Процедура ПересчитатьОстаткиСгруппированнойАналитики(ТаблицаРасчетная, ДанныеСгруппированные, ДанныеРаспределения)
	
	Если Не ЗначениеЗаполнено(ДанныеРаспределения) Тогда
		Возврат;
	КонецЕсли;
	
	КолонкиГруппировки = "Организация, Счет, Субконто1, Субконто2";
	
	Для Каждого СтрокаГруппировки Из ДанныеСгруппированные Цикл
		Отбор = Новый Структура(КолонкиГруппировки);
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаГруппировки);
		
		ОстатокДт = СтрокаГруппировки.ОстатокДт;
		ОстатокКт = СтрокаГруппировки.ОстатокКт;
		
		СтрокиТаблицы = ДанныеРаспределения.НайтиСтроки(Отбор);

		Для Каждого СтрокаТаблицы Из СтрокиТаблицы Цикл
			
			СуммаРасчетнаяДт = Мин(СтрокаТаблицы.ОстатокДт, ОстатокДт);
			СуммаРасчетнаяКт = Мин(СтрокаТаблицы.ОстатокКт, ОстатокКт);
			
			СтрокаРасчетная = ТаблицаРасчетная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРасчетная, СтрокаТаблицы, "Организация, Счет, Субконто1, Субконто2, Субконто3");
			СтрокаРасчетная.ОстатокДт = СуммаРасчетнаяДт;
			СтрокаРасчетная.ОстатокКт = СуммаРасчетнаяКт;
			
			ОстатокДт = ОстатокДт - СуммаРасчетнаяДт;
			ОстатокКт = ОстатокКт - СуммаРасчетнаяКт;
			
			Если ОстатокДт = 0 И ОстатокКт = 0 Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

#Область РезервыПоСомнительнымДолгам

Процедура СоздатьВременныеТаблицыРезервыПоСомнительнымДолгам(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты) КАК Субконто1,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК Субконто2,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ХозрасчетныйОстатки.Субконто3
	|	КОНЕЦ КАК Субконто3,
	|	СУММА(-1 * ХозрасчетныйОстатки.СуммаОстаток) КАК ОстатокРезерва,
	|	(ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) КАК Субконто1ПустаяСсылка,
	|	(ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов)) = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка) КАК Субконто2ПустаяСсылка,
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) = &ПустойУникальныйИдентификатор КАК Субконто3ПустаяСсылка
	|ПОМЕСТИТЬ ВсеРезервы
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаРезервов), &СубконтоКонтрагентыДоговорыДокументы, Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ХозрасчетныйОстатки.Организация,
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты),
	|	ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов),
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ХозрасчетныйОстатки.Субконто3
	|	КОНЕЦ,
	|	(ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто1 КАК Справочник.Контрагенты)) = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка),
	|	(ВЫРАЗИТЬ(ХозрасчетныйОстатки.Субконто2 КАК Справочник.ДоговорыКонтрагентов)) = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка),
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) = &ПустойУникальныйИдентификатор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыРезервов.Организация КАК Организация,
	|	ОбъектыРезервов.Счет КАК Счет,
	|	ОбъектыРезервов.Субконто1 КАК Субконто1,
	|	ОбъектыРезервов.Субконто2 КАК Субконто2,
	|	ОбъектыРезервов.Субконто3 КАК Субконто3,
	|	ВЫБОР
	|		КОГДА ОбъектыРезервов.ОстатокДолга - ЕСТЬNULL(НДСАвансов.ОстатокНДС, 0) > 0
	|			ТОГДА ОбъектыРезервов.ОстатокДолга - ЕСТЬNULL(НДСАвансов.ОстатокНДС, 0)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОстатокДолга,
	|	ОбъектыРезервов.ДатаВозникновения КАК ДатаВозникновения,
	|	ОбъектыРезервов.ДатаПогашения КАК ДатаПогашения
	|ПОМЕСТИТЬ ОбъектыРезервовБезНДСАвансов
	|ИЗ
	|	ОбъектыРезервов КАК ОбъектыРезервов
	|		ЛЕВОЕ СОЕДИНЕНИЕ НДСАвансов КАК НДСАвансов
	|		ПО ОбъектыРезервов.Организация = НДСАвансов.Организация
	|			И ОбъектыРезервов.Счет = НДСАвансов.СчетРасчетов
	|			И ОбъектыРезервов.Субконто1 = НДСАвансов.Субконто1
	|			И ОбъектыРезервов.Субконто2 = НДСАвансов.Субконто2
	|			И ОбъектыРезервов.Субконто3 = НДСАвансов.Субконто3
	|			И ОбъектыРезервов.ДатаВозникновения = НДСАвансов.ДатаВозникновения
	|			И ОбъектыРезервов.ДатаПогашения = НДСАвансов.ДатаПогашения
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаВозникновения,
	|	ДатаПогашения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеРезервы.Организация КАК Организация,
	|	ВсеРезервы.Субконто1 КАК Субконто1,
	|	ВсеРезервы.Субконто2 КАК Субконто2,
	|	ВсеРезервы.Субконто3 КАК Субконто3,
	|	ВсеРезервы.ОстатокРезерва КАК ОстатокРезерва,
	|	ОбъектыРезервов.Счет КАК СчетРасчетов,
	|	ОбъектыРезервов.Субконто1 КАК Субконто1Задолженность,
	|	ОбъектыРезервов.Субконто2 КАК Субконто2Задолженность,
	|	ОбъектыРезервов.Субконто3 КАК Субконто3Задолженность,
	|	ОбъектыРезервов.ДатаВозникновения КАК ДатаВозникновения,
	|	ОбъектыРезервов.ДатаПогашения КАК ДатаПогашения,
	|	ОбъектыРезервов.ОстатокДолга КАК ОстатокДолга,
	|	ВЫБОР
	|		КОГДА ВсеРезервы.Субконто1ПустаяСсылка
	|				И ВсеРезервы.Субконто2ПустаяСсылка
	|				И ВсеРезервы.Субконто3ПустаяСсылка
	|			ТОГДА 0
	|		КОГДА ВсеРезервы.Субконто2ПустаяСсылка
	|				И ВсеРезервы.Субконто3ПустаяСсылка
	|			ТОГДА 1
	|		КОГДА ВсеРезервы.Субконто3ПустаяСсылка
	|			ТОГДА 2
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК УровеньДетализации,
	|	НЕ ОбъектыРезервов.Организация ЕСТЬ NULL КАК НайденОбъектРасчетов
	|ПОМЕСТИТЬ РезервыВсеУровниРаспределения
	|ИЗ
	|	ВсеРезервы КАК ВсеРезервы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОбъектыРезервовБезНДСАвансов КАК ОбъектыРезервов
	|		ПО ВсеРезервы.Организация = ОбъектыРезервов.Организация
	|			И ВсеРезервы.Субконто1 = ОбъектыРезервов.Субконто1
	|			И (НЕ ВсеРезервы.Субконто1ПустаяСсылка)
	|			И (ВсеРезервы.Субконто2 = ОбъектыРезервов.Субконто2
	|				ИЛИ ВсеРезервы.Субконто2ПустаяСсылка)
	|			И (ВсеРезервы.Субконто3 = ОбъектыРезервов.Субконто3
	|				ИЛИ ВсеРезервы.Субконто3ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РезервыВсеУровниРаспределения.Организация КАК Организация,
	|	РезервыВсеУровниРаспределения.СчетРасчетов КАК СчетРасчетов,
	|	РезервыВсеУровниРаспределения.Субконто1Задолженность КАК Субконто1Задолженность,
