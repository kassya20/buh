КонецФункции

Функция СчетаНалогов()
	
	СчетаРасчетов = Новый Структура;

	СчетаПоВидамПлатежей = БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ПрочиеНалогиИСборы); // 68.10
	СчетаРасчетов.Вставить("СчетаПоВидамПлатежей", СчетаПоВидамПлатежей);

	СчетаИсключения = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетНалогаНаПрибыль)); // 68.04.2
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.НДСпоЭкспортуКВозмещению)); // 68.22
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, СчетаПоВидамПлатежей);
	
	СчетаБезДетализации = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаБезДетализации, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.НДСНалоговогоАгента)); // 68.32
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаБезДетализации, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.НДСТаможенныйСоюзКУплате)); // 68.42
	СчетаРасчетов.Вставить("СчетаБезДетализации", СчетаБезДетализации);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, СчетаБезДетализации);

	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	СчетаАПБезДетализации = СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоНалогам, ВидыСчетов, СчетаИсключения);
	СчетаРасчетов.Вставить("СчетаАПБезДетализации", СчетаАПБезДетализации);

	Возврат СчетаРасчетов;
	
КонецФункции

Функция СчетаСоциальногоСтрахования()
	
	СчетаРасчетов = Новый Структура;

	СчетаПоВидамПлатежей = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаПоВидамПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ПФР_доп)); // 69.02.3
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаПоВидамПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ПФР_доп_шахтеры)); // 69.02.4
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаПоВидамПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ПФР_ДОБР_орг)); // 69.05.1
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаПоВидамПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ПФР_ДОБР_сотр)); // 69.05.2
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаПоВидамПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ФСС_СтраховойГод)); // 69.06.4
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаПоВидамПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.ФСС_НСиПЗ)); // 69.11
	СчетаРасчетов.Вставить("СчетаПоВидамПлатежей", СчетаПоВидамПлатежей);

	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	СчетаАПБезДетализации = СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоСоциальномуСтрахованию, ВидыСчетов, СчетаПоВидамПлатежей);
	СчетаРасчетов.Вставить("СчетаАПБезДетализации", СчетаАПБезДетализации);

	Возврат СчетаРасчетов;
		
КонецФункции

#Область ДебиторскаяЗадолженность

Функция КонтекстРасчетаДебиторская()
	
	КонтекстРасчета = Новый Структура;
	КонтекстРасчета.Вставить("ВидЗадолженности", Перечисления.ВидыЗадолженности.Дебиторская);
	
	СчетаНДСАвансов = Новый Массив;
	СчетаНДСАвансов.Добавить(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным);

	СчетаИнвентаризацииРасчетов = СчетаИнвентаризацииРасчетовДебиторская();
	СчетаСрокиОплаты = СчетаРасчетовСрокиОплатыПокупателей();
	СчетаУчетаАвансов = СчетаУчетаАвансовВыданных();
	СчетаОбъектовРезервов = СчетаОбъектовРезервов();
	
	СчетаКлассификации = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаИнвентаризацииРасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаСрокиОплаты);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаУчетаАвансов);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаОбъектовРезервов);

	// Список счетов, у которых дата погашения может быть получена только из инвентаризации расчетов и нет корректирующих величин
	СчетаСоСроками = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаСоСроками, СчетаСрокиОплаты);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаСоСроками, СчетаУчетаАвансов);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаСоСроками, СчетаОбъектовРезервов);
	СчетаИсключитьБезДатыПогашения = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключитьБезДатыПогашения, СчетаКлассификации);
	Для Каждого Счет Из СчетаСоСроками Цикл
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(СчетаИсключитьБезДатыПогашения, Счет);
	КонецЦикла;
	
	КонтекстРасчета.Вставить("ВидЗадолженности", Перечисления.ВидыЗадолженности.Дебиторская);
	КонтекстРасчета.Вставить("СчетаРезервов",    БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам));
	КонтекстРасчета.Вставить("СчетаИнвентаризацииРасчетов", СчетаИнвентаризацииРасчетов);
	КонтекстРасчета.Вставить("СчетаНДСАвансов", СчетаНДСАвансов);
	КонтекстРасчета.Вставить("СчетаСрокиОплаты", СчетаСрокиОплаты);
	КонтекстРасчета.Вставить("СчетаУчетаАвансов", СчетаУчетаАвансов);
	КонтекстРасчета.Вставить("СчетаОбъектовРезервов", СчетаОбъектовРезервов);
	КонтекстРасчета.Вставить("СчетаКлассификации", СчетаКлассификации);
	КонтекстРасчета.Вставить("СчетаИсключитьБезДатыПогашения", СчетаИсключитьБезДатыПогашения);
	КонтекстРасчета.Вставить("СчетНДСАвансов", ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным);
	
	СубконтоКонтрагентыСФ = Новый Массив;
	СубконтоКонтрагентыСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СФПолученные);
	КонтекстРасчета.Вставить("СубконтоКонтрагентыСФ", СубконтоКонтрагентыСФ);

	Возврат КонтекстРасчета;

КонецФункции

Функция ДебиторскаяЗадолженностьПоСрокам(КонтекстОперации, РасчетныеДанные)

	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	СоздатьВременныеТаблицыАвансыПоАренде(МенеджерВременныхТаблиц, РасчетныеДанные.РасчетыПоАренде.АрендныеОбязательства);
	
	КонтекстРасчета = КонтекстРасчетаДебиторская();
	
	СоздатьВременныеТаблицыРаспределеннаяЗадолженностьПоСрокам(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета);
	
	// Объекты авансов
	СоздатьВременныеТаблицыОбъектыАвансовДебиторская(МенеджерВременныхТаблиц, КонтекстРасчета);
	
	// НДС с авансов, распределенный по объектам авансов
	СоздатьВременныеТаблицыНДСАвансов(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета, -1);
		
	// Объекты резервов по сомнительным долгам
	СоздатьВременныеТаблицыОбъектыРезервовПоСомнительнымДолгам(МенеджерВременныхТаблиц, КонтекстРасчета);
	
	// Резервы по сомнительным долгам, распределенные по объектам резервов
	СоздатьВременныеТаблицыРезервыПоСомнительнымДолгам(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДатаНачалаДолгосрочногоПериода", КонтекстОперации.ДатаНачалаДолгосрочногоПериода);
	Запрос.Текст = ТекстЗапросаОбъединитьВсеРасчетыДебиторская();

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ТекстЗапросаДебиторскаяЗадолженностьПоСрокам(КонтекстЗапроса, ИмяПоместить, ОбщиеПараметры)
	
	// Для остатков расчетов получаем дату погашения по срокам оплаты, указанных в договорах или документах расчетах
	ТекстыЗапросов = Новый Массив;
	ТекстЗапроса = ШаблонТекстаЗапросаРасчеты();
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИмяТаблицыРасчеты", ИмяПоместить);
	ТекстыЗапросов.Добавить(ТекстЗапроса);
		
	ВременныеТаблицы = КонтекстЗапроса.ВременныеТаблицы;
	Если ВременныеТаблицы.Найти("РасчетыСКонтрагентамиПоДоговорам") <> Неопределено Тогда
		
		Если КонтекстЗапроса.ОпределитьСроки Тогда
			ТекстЗапроса = 
			"ВЫБРАТЬ
			|	Расчеты.Организация КАК Организация,
			|	Расчеты.Счет КАК Счет,
			|	Расчеты.Субконто1 КАК Субконто1,
			|	Расчеты.Субконто2 КАК Субконто2,
			|	Расчеты.Субконто3 КАК Субконто3,
			|	Расчеты.ОстатокДт КАК ОстатокБУ
			|ИЗ
			|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
			|ГДЕ
			|	Расчеты.Счет В(&СчетаРасчетовСрокиОплатыПокупателей)
			|	И Расчеты.ОстатокДт <> 0";
			
			ПараметрыСвязи = НовыйПараметрыСвязиВременнойТаблицыРасчеты();
			ПараметрыСвязи.ИмяТаблицы =         "Расчеты";
			ПараметрыСвязи.ИмяПоляСчет =        "Счет";
			ПараметрыСвязи.ИмяПоляОрганизация = "Организация";
			ПараметрыСвязи.ИмяПоляДоговор =     "Субконто2";
			ПараметрыСвязи.ИмяПоляДокумент =    "Субконто3";
			
			ДополнитьЗапросДаннымиПоСрокамОплаты(ТекстЗапроса, ПараметрыСвязи, КонтекстЗапроса.ПараметрыЗапроса);
			ТекстыЗапросов.Добавить(ТекстЗапроса);
			
			ТекстЗапроса =
			"ВЫБРАТЬ
			|	Расчеты.Организация КАК Организация,
			|	Расчеты.Счет КАК Счет,
			|	Расчеты.Субконто1 КАК Субконто1,
			|	Расчеты.Субконто2 КАК Субконто2,
			|	Расчеты.Субконто3 КАК Субконто3,
			|	Расчеты.ОстатокДт КАК ОстатокБУ,
			|	ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаРегистратора,
			|	НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL КАК ЕстьДокументРасчетов,
			|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
			|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
			|ИЗ
			|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
			|		ПО Расчеты.Организация = ДанныеПервичныхДокументов.Организация
			|			И Расчеты.Субконто3 = ДанныеПервичныхДокументов.Документ
			|ГДЕ
			|	НЕ Расчеты.Счет В (&СчетаРасчетовСрокиОплатыПокупателей)
			|	И Расчеты.ОстатокДт <> 0";
			ТекстыЗапросов.Добавить(ТекстЗапроса);
			КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаРасчетовСрокиОплатыПокупателей", СчетаРасчетовСрокиОплатыПокупателей());
		Иначе
			ТекстЗапроса =
			"ВЫБРАТЬ
			|	Расчеты.Организация КАК Организация,
			|	Расчеты.Счет КАК Счет,
			|	Расчеты.Субконто1 КАК Субконто1,
			|	Расчеты.Субконто2 КАК Субконто2,
			|	Расчеты.Субконто3 КАК Субконто3,
			|	Расчеты.ОстатокДт КАК ОстатокБУ,
			|	ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаРегистратора,
			|	НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL КАК ЕстьДокументРасчетов,
			|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
			|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
			|ИЗ
			|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
			|		ПО Расчеты.Организация = ДанныеПервичныхДокументов.Организация
			|			И Расчеты.Субконто3 = ДанныеПервичныхДокументов.Документ
			|ГДЕ
			|	Расчеты.ОстатокДт <> 0";
			ТекстыЗапросов.Добавить(ТекстЗапроса);
		КонецЕсли;
		
	КонецЕсли;

	Если ВременныеТаблицы.Найти("Авансы") <> Неопределено Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Авансы.Организация КАК Организация,
		|	Авансы.Счет КАК Счет,
		|	Авансы.Субконто1 КАК Субконто1,
		|	ВЫРАЗИТЬ(Авансы.Субконто2 КАК Справочник.ДоговорыКонтрагентов) КАК Субконто2,
		|	Авансы.Субконто3 КАК Субконто3,
		|	Авансы.ОстатокДт КАК ОстатокБУ,
		|	ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаРегистратора,
		|	НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL КАК ЕстьДокументРасчетов,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
		|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
		|ИЗ
		|	Авансы КАК Авансы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
		|		ПО Авансы.Организация = ДанныеПервичныхДокументов.Организация
		|			И Авансы.Субконто3 = ДанныеПервичныхДокументов.Документ
		|ГДЕ
		|	Авансы.ОстатокДт <> 0
		|	И &РазделятьАвансыПоВидамАктивов";
		
		РазделятьАвансыПоВидамАктивов = РегламентированнаяОтчетность.АвансыРазделеныПоВидамАктивов(ОбщиеПараметры.Организация, ОбщиеПараметры.КонецПериодаДата);
		Если РазделятьАвансыПоВидамАктивов Тогда
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&РазделятьАвансыПоВидамАктивов", "НЕ Авансы.Субконто2.ВидАктива В (&ИсключаемыеВидыАктиваАвансов)");
		Иначе
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&РазделятьАвансыПоВидамАктивов", "ИСТИНА");
		КонецЕсли;
		
		ИсключаемыеВидыАктиваАвансов = Новый Массив;
		Если РазделятьАвансыПоВидамАктивов Тогда
			ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.Запасы);
			ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ИнвестиционнаяНедвижимость);
			ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.НематериальныеАктивы);
			ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ПрочиеВнеоборотные);
			ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ОсновныеСредства);
			ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ПрочиеОборотные);
		КонецЕсли;
		
		КонтекстЗапроса.ПараметрыЗапроса.Вставить("ИсключаемыеВидыАктиваАвансов", ИсключаемыеВидыАктиваАвансов);

		ТекстыЗапросов.Добавить(ТекстЗапроса);
	КонецЕсли;

	Если ВременныеТаблицы.Найти("РасчетыПрочие") <> Неопределено Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Расчеты.Организация КАК Организация,
		|	Расчеты.Счет КАК Счет,
		|	Расчеты.Субконто1 КАК Субконто1,
		|	Расчеты.Субконто2 КАК Субконто2,
		|	Расчеты.Субконто3 КАК Субконто3,
		|	Расчеты.ОстатокДт КАК ОстатокБУ,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаРегистратора,
		|	ЛОЖЬ КАК ЕстьДокументРасчетов,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
		|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
		|ИЗ
		|	РасчетыПрочие КАК Расчеты
		|ГДЕ
		|	Расчеты.ОстатокДт <> 0";
		
		ТекстыЗапросов.Добавить(ТекстЗапроса);
	КонецЕсли;
	
	Возврат СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.ТекстОбъединитьВсе());
	
КонецФункции

Процедура СоздатьВременныеТаблицыОбъектыАвансовДебиторская(МенеджерВременныхТаблиц, КонтекстРасчета)

	// Из объектов авансов исключаются объекты аренды, так как НДС с авансов уже участвует в расчете арендного обязательства
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасчетыПоСрокамПогашения.Организация КАК Организация,
	|	РасчетыПоСрокамПогашения.Счет КАК Счет,
	|	РасчетыПоСрокамПогашения.Субконто1 КАК Субконто1,
	|	РасчетыПоСрокамПогашения.Субконто2 КАК Субконто2,
	|	РасчетыПоСрокамПогашения.Субконто3 КАК Субконто3,
	|	РасчетыПоСрокамПогашения.ОстатокДолга КАК ОстатокДолга,
	|	РасчетыПоСрокамПогашения.ДатаВозникновения КАК ДатаВозникновения,
	|	РасчетыПоСрокамПогашения.ДатаПогашения КАК ДатаПогашения
	|ПОМЕСТИТЬ ОбъектыАвансов
	|ИЗ
	|	РасчетыПоСрокамПогашения КАК РасчетыПоСрокамПогашения
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОбъектыАвансовАренды КАК ОбъектыАвансовАренды
	|		ПО РасчетыПоСрокамПогашения.Организация = ОбъектыАвансовАренды.Организация
	|			И РасчетыПоСрокамПогашения.Субконто1 = ОбъектыАвансовАренды.Контрагент
	|			И РасчетыПоСрокамПогашения.Субконто2 = ОбъектыАвансовАренды.ДоговорКонтрагента
	|ГДЕ
	|	РасчетыПоСрокамПогашения.Счет В(&СчетаУчетаАвансов)
	|	И ОбъектыАвансовАренды.Контрагент ЕСТЬ NULL
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаВозникновения,
	|	ДатаПогашения";

	Запрос.УстановитьПараметр("СчетаУчетаАвансов", КонтекстРасчета.СчетаУчетаАвансов);
	Запрос.Выполнить();
		
КонецПроцедуры

Функция ТекстЗапросаОбъединитьВсеРасчетыДебиторская()

	Возврат
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.ВидыЗадолженности.Дебиторская) КАК ВидЗадолженности,
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	Расчеты.Субконто1 КАК Субконто1,
	|	Расчеты.Субконто2 КАК Субконто2,
	|	Расчеты.Субконто3 КАК Субконто3,
	|	Расчеты.ДатаВозникновения КАК ДатаВозникновения,
	|	Расчеты.ДатаПогашения КАК ДатаПогашения,
	|	МАКСИМУМ(Расчеты.ИсточникСрокаПогашения) КАК ИсточникСрокаПогашения,
	|	МАКСИМУМ(Расчеты.ЗаписыватьВРегистр) КАК ЗаписыватьВРегистр,
	|	МАКСИМУМ(Расчеты.УровеньДетализации) КАК УровеньДетализации,
	|	СУММА(Расчеты.ОстатокДолга) КАК ОстатокДолга,
	|	СУММА(Расчеты.ОстатокРезерва) КАК РезервПоСомнительнымДолгам,
	|	СУММА(Расчеты.ОстатокНДС) КАК НДСАвансов
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасчетыПоСрокамПогашения.Организация КАК Организация,
	|		РасчетыПоСрокамПогашения.Счет КАК Счет,
	|		РасчетыПоСрокамПогашения.Субконто1 КАК Субконто1,
	|		РасчетыПоСрокамПогашения.Субконто2 КАК Субконто2,
	|		РасчетыПоСрокамПогашения.Субконто3 КАК Субконто3,
	|		РасчетыПоСрокамПогашения.ДатаВозникновения КАК ДатаВозникновения,
	|		РасчетыПоСрокамПогашения.ДатаПогашения КАК ДатаПогашения,
	|		РасчетыПоСрокамПогашения.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|		РасчетыПоСрокамПогашения.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|		0 КАК УровеньДетализации,
	|		РасчетыПоСрокамПогашения.ОстатокДолга КАК ОстатокДолга,
	|		0 КАК ОстатокРезерва,
	|		0 КАК ОстатокНДС
	|	ИЗ
	|		РасчетыПоСрокамПогашения КАК РасчетыПоСрокамПогашения
	|	ГДЕ
	|		НЕ РасчетыПоСрокамПогашения.НайтиДатуВозникновения
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РасчетыДатаВозникновенияПоРегистратору.Организация,
	|		РасчетыДатаВозникновенияПоРегистратору.Счет,
	|		РасчетыДатаВозникновенияПоРегистратору.Субконто1,
	|		РасчетыДатаВозникновенияПоРегистратору.Субконто2,
	|		РасчетыДатаВозникновенияПоРегистратору.Субконто3,
	|		РасчетыДатаВозникновенияПоРегистратору.ДатаВозникновения,
	|		РасчетыДатаВозникновенияПоРегистратору.ДатаПогашения,
	|		РасчетыДатаВозникновенияПоРегистратору.ИсточникСрокаПогашения,
	|		РасчетыДатаВозникновенияПоРегистратору.ЗаписыватьВРегистр,
	|		0,
	|		РасчетыДатаВозникновенияПоРегистратору.ОстатокДолга,
	|		0,
	|		0
	|	ИЗ
	|		РасчетыДатаВозникновенияПоРегистратору КАК РасчетыДатаВозникновенияПоРегистратору
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РезервыПоСомнительнымДолгам.Организация,
	|		РезервыПоСомнительнымДолгам.СчетРасчетов,
	|		РезервыПоСомнительнымДолгам.Субконто1Задолженность,
	|		РезервыПоСомнительнымДолгам.Субконто2Задолженность,
	|		РезервыПоСомнительнымДолгам.Субконто3Задолженность,
	|		РезервыПоСомнительнымДолгам.ДатаВозникновения,
	|		РезервыПоСомнительнымДолгам.ДатаПогашения,
	|		НЕОПРЕДЕЛЕНО,
	|		ИСТИНА,
	|		РезервыПоСомнительнымДолгам.УровеньДетализации,
	|		0,
	|		РезервыПоСомнительнымДолгам.ОстатокРезерва,
	|		0
	|	ИЗ
	|		РезервыПоСомнительнымДолгам КАК РезервыПоСомнительнымДолгам
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		НДСАвансов.Организация,
	|		НДСАвансов.СчетРасчетов,
	|		НДСАвансов.Субконто1,
	|		НДСАвансов.Субконто2,
	|		НДСАвансов.Субконто3,
	|		НДСАвансов.ДатаВозникновения,
	|		НДСАвансов.ДатаПогашения,
	|		НЕОПРЕДЕЛЕНО,
	|		ИСТИНА,
	|		0,
	|		0,
	|		0,
	|		НДСАвансов.ОстатокНДС
	|	ИЗ
	|		НДСАвансов КАК НДСАвансов
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		АвансыАренды.Организация,
	|		АвансыАренды.Счет,
	|		АвансыАренды.Контрагент,
	|		АвансыАренды.ДоговорКонтрагента,
	|		НЕОПРЕДЕЛЕНО,
	|		АвансыАренды.ДатаВозникновения,
	|		АвансыАренды.ДатаПогашения,
	|		НЕОПРЕДЕЛЕНО,
	|		ИСТИНА,
	|		0,
	|		АвансыАренды.АвансыПоАренде,
	|		0,
	|		АвансыАренды.НДСсПлатежей
	|	ИЗ
	|		АвансыАренды КАК АвансыАренды) КАК Расчеты
	|
	|СГРУППИРОВАТЬ ПО
	|	Расчеты.Организация,
	|	Расчеты.Счет,
	|	Расчеты.Субконто1,
	|	Расчеты.Субконто2,
	|	Расчеты.Субконто3,
	|	Расчеты.ДатаПогашения,
	|	Расчеты.ДатаВозникновения
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(Расчеты.ЗаписыватьВРегистр) = ИСТИНА
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаВозникновения,
	|	ДатаПогашения";
		
КонецФункции

#КонецОбласти

#Область КредиторскаяЗадолженность

Функция КонтекстРасчетаКредиторская()
	
	КонтекстРасчета = Новый Структура;
	КонтекстРасчета.Вставить("ВидЗадолженности", Перечисления.ВидыЗадолженности.Кредиторская);
	
	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	ВидыСчетов.Добавить(ВидСчета.Пассивный);
	КонтекстРасчета.Вставить("ВидыСчетов", ВидыСчетов);
	
	СчетаНДСАвансов = Новый Массив;
	СчетаНДСАвансов.Добавить(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам);
	
	СчетаИнвентаризацииРасчетов = СчетаИнвентаризацииРасчетовКредиторская();
	СчетаСрокиОплаты = СчетаРасчетовСрокиОплатыПоставщикам();
	СчетаУчетаАвансов = СчетаУчетаАвансовПолученных();
	СчетаКредитовЗаймов = СчетаДолгосрочныхКредитовЗаймов();
	
	СчетаКлассификации = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаИнвентаризацииРасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаСрокиОплаты);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаУчетаАвансов);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаКлассификации, СчетаКредитовЗаймов);

	// Список счетов, у которых дата погашения может быть получена только из инвентаризации расчетов и нет корректирующих величин
	СчетаСоСроками = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаСоСроками, СчетаСрокиОплаты);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаСоСроками, СчетаУчетаАвансов);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаСоСроками, СчетаКредитовЗаймов);
	СчетаИсключитьБезДатыПогашения = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключитьБезДатыПогашения, СчетаКлассификации);
	Для Каждого Счет Из СчетаСоСроками Цикл
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(СчетаИсключитьБезДатыПогашения, Счет);
	КонецЦикла;
	
	КонтекстРасчета.Вставить("СчетаИнвентаризацииРасчетов", СчетаИнвентаризацииРасчетов);
	КонтекстРасчета.Вставить("СчетаНДСАвансов", СчетаНДСАвансов);
	КонтекстРасчета.Вставить("СчетаСрокиОплаты", СчетаСрокиОплаты);
	КонтекстРасчета.Вставить("СчетаУчетаАвансов", СчетаУчетаАвансов);
	КонтекстРасчета.Вставить("СчетаКредитовЗаймов", СчетаКредитовЗаймов);
	КонтекстРасчета.Вставить("СчетаКлассификации", СчетаКлассификации);
	КонтекстРасчета.Вставить("СчетаИсключитьБезДатыПогашения", СчетаИсключитьБезДатыПогашения);
	КонтекстРасчета.Вставить("СчетНДСАвансов", ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам);

	СубконтоКонтрагентыСФ = Новый Массив;
	СубконтоКонтрагентыСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СФВыданные);
	КонтекстРасчета.Вставить("СубконтоКонтрагентыСФ", СубконтоКонтрагентыСФ);

	Возврат КонтекстРасчета;
	
КонецФункции

Функция КредиторскаяЗадолженностьПоСрокам(КонтекстОперации, РасчетныеДанные)

	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	СоздатьВременныеТаблицыАрендныеОбязательства(МенеджерВременныхТаблиц, РасчетныеДанные.РасчетыПоАренде.АрендныеОбязательства, КонтекстОперации);
	СоздатьВременныеТаблицыЗадолженностьВРассрочку(МенеджерВременныхТаблиц, РасчетныеДанные.РасчетыПоРассрочке.ЗадолженностьВРассрочку, КонтекстОперации);
	
	КонтекстРасчета= КонтекстРасчетаКредиторская();

	СоздатьВременныеТаблицыРаспределеннаяЗадолженностьПоСрокам(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета);
	
	// Объекты авансов
	СоздатьВременныеТаблицыОбъектыАвансовКредиторская(МенеджерВременныхТаблиц, КонтекстРасчета);
	
	// НДС с авансов, распределенный по объектам авансов
	СоздатьВременныеТаблицыНДСАвансов(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДатаНачалаДолгосрочногоПериода", КонтекстОперации.ДатаНачалаДолгосрочногоПериода);
	Запрос.Текст = ТекстЗапросаОбъединитьВсеРасчетыКредиторская();

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Функция ТекстЗапросаКредиторскаяЗадолженностьПоСрокам(КонтекстЗапроса, ИмяПоместить, МенеджерВременныхТаблиц = Неопределено)
	
	// Для остатков расчетов получаем дату погашения по срокам оплаты, указанных в договорах или документах расчетов
	ТекстыЗапросов = Новый Массив;
	ТекстЗапроса = ШаблонТекстаЗапросаРасчеты();
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИмяТаблицыРасчеты", ИмяПоместить);
	ТекстыЗапросов.Добавить(ТекстЗапроса);
		
	ВременныеТаблицы = КонтекстЗапроса.ВременныеТаблицы;
	Если ВременныеТаблицы.Найти("РасчетыСКонтрагентамиПоДоговорам") <> Неопределено Тогда
		
		Если КонтекстЗапроса.ОпределитьСроки Тогда
			ТекстЗапроса = 
			"ВЫБРАТЬ
			|	Расчеты.Организация КАК Организация,
			|	Расчеты.Счет КАК Счет,
			|	Расчеты.Субконто1 КАК Субконто1,
			|	Расчеты.Субконто2 КАК Субконто2,
			|	Расчеты.Субконто3 КАК Субконто3,
			|	Расчеты.ОстатокКт КАК ОстатокБУ
			|ИЗ
			|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
			|ГДЕ
			|	Расчеты.Счет В(&СчетаРасчетовСрокиОплатыПоставщикам)
			|	И Расчеты.ОстатокКт <> 0";
			
			Если МенеджерВременныхТаблиц <> Неопределено И МенеджерВременныхТаблиц.Таблицы.Найти("ЗадолженностьВРассрочку") <> Неопределено Тогда
				ТекстЗапроса = 
				"ВЫБРАТЬ
				|	Расчеты.Организация КАК Организация,
				|	Расчеты.Счет КАК Счет,
				|	Расчеты.Субконто1 КАК Субконто1,
				|	Расчеты.Субконто2 КАК Субконто2,
				|	Расчеты.Субконто3 КАК Субконто3,
				|	Расчеты.ОстатокКт КАК ОстатокБУ
				|ИЗ
				|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
				|		ЛЕВОЕ СОЕДИНЕНИЕ АналитикаРассрочки КАК АналитикаРассрочки
				|		ПО Расчеты.Организация = АналитикаРассрочки.Организация
				|			И Расчеты.Счет = АналитикаРассрочки.Счет
				|			И Расчеты.Субконто1 = АналитикаРассрочки.Контрагент
				|			И Расчеты.Субконто2 = АналитикаРассрочки.ДоговорКонтрагента
				|ГДЕ
				|	Расчеты.Счет В(&СчетаРасчетовСрокиОплатыПоставщикам)
				|	И Расчеты.ОстатокКт <> 0
				|	И АналитикаРассрочки.Организация ЕСТЬ NULL";
			КонецЕсли;
			ПараметрыСвязи = НовыйПараметрыСвязиВременнойТаблицыРасчеты();
			ПараметрыСвязи.ИмяТаблицы =         "Расчеты";
			ПараметрыСвязи.ИмяПоляСчет =        "Счет";
			ПараметрыСвязи.ИмяПоляОрганизация = "Организация";
			ПараметрыСвязи.ИмяПоляДоговор =     "Субконто2";
			ПараметрыСвязи.ИмяПоляДокумент =    "Субконто3";
			
			ДополнитьЗапросДаннымиПоСрокамОплаты(ТекстЗапроса, ПараметрыСвязи, КонтекстЗапроса.ПараметрыЗапроса);
		Иначе
			ТекстЗапроса = 
			"ВЫБРАТЬ
			|	Расчеты.Организация КАК Организация,
			|	Расчеты.Счет КАК Счет,
			|	Расчеты.Субконто1 КАК Субконто1,
			|	Расчеты.Субконто2 КАК Субконто2,
			|	Расчеты.Субконто3 КАК Субконто3,
			|	Расчеты.ОстатокКт КАК ОстатокБУ,
			|	ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаРегистратора,
			|	НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL КАК ЕстьДокументРасчетов,
			|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
			|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
			|ИЗ
			|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
			|		ПО Расчеты.Организация = ДанныеПервичныхДокументов.Организация
			|			И Расчеты.Субконто3 = ДанныеПервичныхДокументов.Документ
			|ГДЕ
			|	Расчеты.Счет В(&СчетаРасчетовСрокиОплатыПоставщикам)
			|	И Расчеты.ОстатокКт <> 0";
		КонецЕсли;
		
		ТекстыЗапросов.Добавить(ТекстЗапроса);

		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Расчеты.Организация КАК Организация,
		|	Расчеты.Счет КАК Счет,
		|	Расчеты.Субконто1 КАК Субконто1,
		|	Расчеты.Субконто2 КАК Субконто2,
		|	Расчеты.Субконто3 КАК Субконто3,
		|	Расчеты.ОстатокКт КАК ОстатокБУ,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаРегистратора,
		|	ЛОЖЬ КАК ЕстьДокументРасчетов,
		|	ВЫБОР
		|		КОГДА &ОпределитьСроки
		|			ТОГДА ЕСТЬNULL(ДоговорыКонтрагентов.СрокДействия, ДАТАВРЕМЯ(1, 1, 1))
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ КАК ДатаПогашенияБУ,
		|	ВЫБОР
		|		КОГДА &ОпределитьСроки
		|				И ДоговорыКонтрагентов.Ссылка ЕСТЬ НЕ NULL 
		|				И ДоговорыКонтрагентов.СрокДействия <> ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА ДоговорыКонтрагентов.Ссылка
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ КАК ИсточникСрокаПогашения
		|ИЗ
		|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|		ПО Расчеты.Субконто2 = ДоговорыКонтрагентов.Ссылка
		|ГДЕ
		|	Расчеты.Счет В(&СчетаКредитовЗаймов)
		|	И Расчеты.ОстатокКт <> 0";
		ТекстыЗапросов.Добавить(ТекстЗапроса);

		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Расчеты.Организация КАК Организация,
		|	Расчеты.Счет КАК Счет,
		|	Расчеты.Субконто1 КАК Субконто1,
		|	Расчеты.Субконто2 КАК Субконто2,
		|	Расчеты.Субконто3 КАК Субконто3,
		|	Расчеты.ОстатокКт КАК ОстатокБУ,
		|	ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаРегистратора,
		|	НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL КАК ЕстьДокументРасчетов,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
		|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
		|ИЗ
		|	РасчетыСКонтрагентамиПоДоговорам КАК Расчеты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
		|		ПО Расчеты.Организация = ДанныеПервичныхДокументов.Организация
		|			И Расчеты.Субконто3 = ДанныеПервичныхДокументов.Документ
		|ГДЕ
		|	НЕ Расчеты.Счет В (&СчетаРасчетовСрокиОплатыПоставщикам, &СчетаКредитовЗаймов)
		|	И Расчеты.ОстатокКт <> 0";
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		
		//ПараметрыЗапроса формируются в зависимости от объединяемых текстов запросов. Параметр "СчетаКредитовЗаймов" может принимать различные значения.
		//Например, при классификации задолженности учитываются только долгосрочные кредиты и займы.
		//Поэтому данный параметр задается в контексте вызова. Если параметр не задан, он считается необязательным.
		Если Не КонтекстЗапроса.ПараметрыЗапроса.Свойство("СчетаКредитовЗаймов") Тогда
			КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаКредитовЗаймов", Новый Массив);
		КонецЕсли;
		КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаРасчетовСрокиОплатыПоставщикам", СчетаРасчетовСрокиОплатыПоставщикам());
		КонтекстЗапроса.ПараметрыЗапроса.Вставить("ОпределитьСроки", КонтекстЗапроса.ОпределитьСроки);
		
	КонецЕсли;

	Если ВременныеТаблицы.Найти("РасчетыПрочие") <> Неопределено Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Расчеты.Организация КАК Организация,
		|	Расчеты.Счет КАК Счет,
		|	Расчеты.Субконто1 КАК Субконто1,
		|	Расчеты.Субконто2 КАК Субконто2,
		|	Расчеты.Субконто3 КАК Субконто3,
		|	Расчеты.ОстатокКт КАК ОстатокБУ,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаРегистратора,
		|	ЛОЖЬ КАК ЕстьДокументРасчетов,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
		|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
		|ИЗ
		|	РасчетыПрочие КАК Расчеты
		|ГДЕ
		|	Расчеты.ОстатокКт <> 0";
		ТекстыЗапросов.Добавить(ТекстЗапроса);
		
	КонецЕсли;
	
	Возврат СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.ТекстОбъединитьВсе());

КонецФункции

Процедура СоздатьВременныеТаблицыОбъектыАвансовКредиторская(МенеджерВременныхТаблиц, КонтекстРасчета)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасчетыПоСрокамПогашения.Организация КАК Организация,
	|	РасчетыПоСрокамПогашения.Счет КАК Счет,
	|	РасчетыПоСрокамПогашения.Субконто1 КАК Субконто1,
	|	РасчетыПоСрокамПогашения.Субконто2 КАК Субконто2,
	|	РасчетыПоСрокамПогашения.Субконто3 КАК Субконто3,
	|	РасчетыПоСрокамПогашения.ОстатокДолга КАК ОстатокДолга,
	|	РасчетыПоСрокамПогашения.ДатаВозникновения КАК ДатаВозникновения,
	|	РасчетыПоСрокамПогашения.ДатаПогашения КАК ДатаПогашения
	|ПОМЕСТИТЬ ОбъектыАвансов
	|ИЗ
	|	РасчетыПоСрокамПогашения КАК РасчетыПоСрокамПогашения
	|ГДЕ
	|	РасчетыПоСрокамПогашения.Счет В (&СчетаУчетаАвансов)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаВозникновения,
	|	ДатаПогашения";
	
	Запрос.УстановитьПараметр("СчетаУчетаАвансов", КонтекстРасчета.СчетаУчетаАвансов);
	Запрос.Выполнить();
		
КонецПроцедуры

Функция ТекстЗапросаОбъединитьВсеРасчетыКредиторская()

	Возврат 
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.ВидыЗадолженности.Кредиторская) КАК ВидЗадолженности,
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	Расчеты.Субконто1 КАК Субконто1,
	|	Расчеты.Субконто2 КАК Субконто2,
	|	Расчеты.Субконто3 КАК Субконто3,
	|	Расчеты.ДатаВозникновения КАК ДатаВозникновения,
	|	Расчеты.ДатаПогашения КАК ДатаПогашения,
	|	МАКСИМУМ(Расчеты.ИсточникСрокаПогашения) КАК ИсточникСрокаПогашения,
	|	МАКСИМУМ(Расчеты.ЗаписыватьВРегистр) КАК ЗаписыватьВРегистр,
	|	СУММА(Расчеты.ОстатокДолга) КАК ОстатокДолга,
	|	СУММА(Расчеты.ОстатокНДС) КАК НДСАвансов,
	|	СУММА(Расчеты.ПроцентыПоРассрочке) КАК ПроцентыПоРассрочке
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасчетыПоСрокамПогашения.Организация КАК Организация,
	|		РасчетыПоСрокамПогашения.Счет КАК Счет,
	|		РасчетыПоСрокамПогашения.Субконто1 КАК Субконто1,
	|		РасчетыПоСрокамПогашения.Субконто2 КАК Субконто2,
	|		РасчетыПоСрокамПогашения.Субконто3 КАК Субконто3,
	|		РасчетыПоСрокамПогашения.ДатаВозникновения КАК ДатаВозникновения,
	|		РасчетыПоСрокамПогашения.ДатаПогашения КАК ДатаПогашения,
	|		РасчетыПоСрокамПогашения.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|		РасчетыПоСрокамПогашения.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|		РасчетыПоСрокамПогашения.ОстатокДолга КАК ОстатокДолга,
	|		0 КАК ОстатокНДС,
	|		0 КАК ПроцентыПоРассрочке
	|	ИЗ
	|		РасчетыПоСрокамПогашения КАК РасчетыПоСрокамПогашения
	|	ГДЕ
	|		НЕ РасчетыПоСрокамПогашения.НайтиДатуВозникновения
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		РасчетыДатаВозникновенияПоРегистратору.Организация,
	|		РасчетыДатаВозникновенияПоРегистратору.Счет,
	|		РасчетыДатаВозникновенияПоРегистратору.Субконто1,
	|		РасчетыДатаВозникновенияПоРегистратору.Субконто2,
	|		РасчетыДатаВозникновенияПоРегистратору.Субконто3,
	|		РасчетыДатаВозникновенияПоРегистратору.ДатаВозникновения,
	|		РасчетыДатаВозникновенияПоРегистратору.ДатаПогашения,
	|		РасчетыДатаВозникновенияПоРегистратору.ИсточникСрокаПогашения,
	|		РасчетыДатаВозникновенияПоРегистратору.ЗаписыватьВРегистр,
	|		РасчетыДатаВозникновенияПоРегистратору.ОстатокДолга,
	|		0,
	|		0
	|	ИЗ
	|		РасчетыДатаВозникновенияПоРегистратору КАК РасчетыДатаВозникновенияПоРегистратору
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		НДСАвансов.Организация,
	|		НДСАвансов.СчетРасчетов,
	|		НДСАвансов.Субконто1,
	|		НДСАвансов.Субконто2,
	|		НДСАвансов.Субконто3,
	|		НДСАвансов.ДатаВозникновения,
	|		НДСАвансов.ДатаПогашения,
	|		НЕОПРЕДЕЛЕНО,
	|		ИСТИНА,
	|		0,
	|		НДСАвансов.ОстатокНДС,
	|		0
	|	ИЗ
	|		НДСАвансов КАК НДСАвансов
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		АрендныеОбязательства.Организация,
	|		АрендныеОбязательства.Счет,
	|		АрендныеОбязательства.Контрагент,
	|		АрендныеОбязательства.ДоговорКонтрагента,
	|		НЕОПРЕДЕЛЕНО,
	|		АрендныеОбязательства.ДатаВозникновения,
	|		АрендныеОбязательства.ДатаПогашения,
	|		НЕОПРЕДЕЛЕНО,
	|		ИСТИНА,
	|		АрендныеОбязательства.Обязательство,
	|		0,
	|		0
	|	ИЗ
	|		АрендныеОбязательства КАК АрендныеОбязательства
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ЗадолженностьВРассрочку.Организация,
	|		ЗадолженностьВРассрочку.Счет,
	|		ЗадолженностьВРассрочку.Контрагент,
	|		ЗадолженностьВРассрочку.ДоговорКонтрагента,
	|		НЕОПРЕДЕЛЕНО,
	|		ЗадолженностьВРассрочку.ДатаВозникновения,
	|		ЗадолженностьВРассрочку.ДатаПогашения,
	|		НЕОПРЕДЕЛЕНО,
	|		ИСТИНА,
	|		ЗадолженностьВРассрочку.НоминальнаяВеличина,
	|		0,
	|		ЗадолженностьВРассрочку.ПроцентыПоРассрочке
	|	ИЗ
	|		ЗадолженностьВРассрочку КАК ЗадолженностьВРассрочку) КАК Расчеты
	|
	|СГРУППИРОВАТЬ ПО
	|	Расчеты.Организация,
	|	Расчеты.Счет,
	|	Расчеты.Субконто1,
	|	Расчеты.Субконто2,
	|	Расчеты.Субконто3,
	|	Расчеты.ДатаПогашения,
	|	Расчеты.ДатаВозникновения
	|
	|ИМЕЮЩИЕ
	|	МАКСИМУМ(Расчеты.ЗаписыватьВРегистр) = ИСТИНА
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаВозникновения,
	|	ДатаПогашения";

КонецФункции

#КонецОбласти

Процедура СоздатьВременныеТаблицыРаспределеннаяЗадолженностьПоСрокам(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организации",      КонтекстОперации.Организации);
	Запрос.УстановитьПараметр("КонецПериода",     КонтекстОперации.КонецПериода);
	Запрос.УстановитьПараметр("КонецПериодаДата", КонтекстОперации.КонецПериодаДата);
	Запрос.УстановитьПараметр("НачалоПредыдущегоПериода", ДобавитьМесяц(НачалоГода(КонтекстОперации.КонецПериодаДата), -12));
	Запрос.УстановитьПараметр("ДатаНачалаДолгосрочногоПериода", КонтекстОперации.ДатаНачалаДолгосрочногоПериода);
	Запрос.УстановитьПараметр("ВидЗадолженности", КонтекстРасчета.ВидЗадолженности);
	Запрос.УстановитьПараметр("СчетаИнвентаризацииРасчетов", КонтекстРасчета.СчетаИнвентаризацииРасчетов);
	Запрос.УстановитьПараметр("СчетаИсключитьБезДатыПогашения", КонтекстРасчета.СчетаИсключитьБезДатыПогашения);
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор", ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	Запрос.УстановитьПараметр("ТипыДокументовРасчетов", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами.ТипЗначения.Типы());
	
	// Счета, по которым есть детализированные записи в документах Инвентаризации расчетов с контрагентами за заданный период
	СчетаИнвентаризацииРасчетовДетализация = СчетаИнвентаризацииРасчетовДетализация(Запрос);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(КонтекстРасчета.СчетаКлассификации, СчетаИнвентаризацииРасчетовДетализация);

	СписокВидовСубконто = СписокВидовСубконто();
	ТаблицаСчетов = НовыйТаблицаСчетов();
	НаборыСчетов = НаборыСчетовКлассификацииЗадолженности(КонтекстРасчета.ВидЗадолженности, СписокВидовСубконто);
	ЗаполнитьНаборыСчетами(НаборыСчетов, КонтекстРасчета.СчетаКлассификации, ТаблицаСчетов, Истина, Истина);
	
	КонтекстРасчета.СчетаКлассификации = Новый Массив;
	// Обход по наборам для заполнения счетами параметров запроса
	Для Каждого Набор Из НаборыСчетов Цикл
		Запрос.УстановитьПараметр(Набор.ИмяНабора, Набор.СписокСчетов);
		// переопределение списка счетов классификации после определения наборов
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(КонтекстРасчета.СчетаКлассификации, Набор.СписокСчетов);
	КонецЦикла;
	Запрос.УстановитьПараметр("СчетаКлассификации", КонтекстРасчета.СчетаКлассификации);
	
	Для Каждого ВидыСубконто Из СписокВидовСубконто Цикл
		Запрос.УстановитьПараметр(ВидыСубконто.Ключ, ВидыСубконто.Значение);
	КонецЦикла;
	
	// Остатки задолженности по счетам, которые участвуют в классификации задолженности по срокам погашения
	КонтекстЗапроса = НовыйКонтекстЗапросаОстаткиЗадолженности();
	КонтекстЗапроса.ОпределитьСроки = Истина;
	Запрос.Текст = ТекстЗапросаОстаткиЗадолженности(НаборыСчетов, КонтекстЗапроса, КонтекстРасчета.ВидЗадолженности);
	Запрос.Выполнить();
	СкорректироватьОстаткиСУчетомДетализацииБаланса(МенеджерВременныхТаблиц, КонтекстРасчета.ВидЗадолженности);
	
	ИмяВременнойТаблицы = "Расчеты";
	Если КонтекстРасчета.ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		Запрос.Текст = ТекстЗапросаДебиторскаяЗадолженностьПоСрокам(КонтекстЗапроса, ИмяВременнойТаблицы, КонтекстОперации);
	ИначеЕсли КонтекстРасчета.ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаКредитовЗаймов", КонтекстРасчета.СчетаКредитовЗаймов); // в классификации задолженности участвуют только долгосрочные кредиты и займы
		Запрос.Текст = ТекстЗапросаКредиторскаяЗадолженностьПоСрокам(КонтекстЗапроса, ИмяВременнойТаблицы, МенеджерВременныхТаблиц);
	КонецЕсли;
	
	Для Каждого Параметр Из КонтекстЗапроса.ПараметрыЗапроса Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	Запрос.Выполнить();
	
	// Необходима для отбора детальных записей в инвентаризации расчетов
	СоздатьВременнуюТаблицуАналитика(Запрос, ИмяВременнойТаблицы);
	
	// По инвентаризации расчетов с контрагентами определяются даты погашения
	СоздатьВременныеТаблицыРаспределенныеДанныеПоИнвентаризацииРасчетов(Запрос, ТаблицаСчетов);

	// Определяется дата возникновения по тем объектам, у которых она не определена ранее
	СоздатьВременныеТаблицыРаспределенныеДанныеПоДатамВозникновения(Запрос);
	
КонецПроцедуры

Процедура СоздатьВременнуюТаблицуАналитика(Запрос, ИмяВременнойТаблицы)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВременнаяТаблица.Организация КАК Организация,
	|	ВременнаяТаблица.Счет КАК Счет,
	|	ВременнаяТаблица.Субконто1 КАК Субконто1,
	|	ВременнаяТаблица.Субконто2 КАК Субконто2,
	|	ВременнаяТаблица.Субконто3 КАК Субконто3
	|ПОМЕСТИТЬ Аналитика
	|ИЗ
	|	&ВременнаяТаблица КАК ВременнаяТаблица";
	
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "&ВременнаяТаблица", ИмяВременнойТаблицы);
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьВременныеТаблицыИнвентаризацияРасчетовДетализация(Запрос, ТаблицаСчетов)
	
	Если ТаблицаСчетов = Неопределено Тогда
		ТаблицаСчетов = НовыйТаблицаСчетов();
	КонецЕсли;
	Запрос.УстановитьПараметр("ТаблицаСчетов", ТаблицаСчетов);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаСчетов.Счет КАК Счет,
	|	ТаблицаСчетов.Код КАК Код,
	|	ТаблицаСчетов.КодГруппы КАК КодГруппы,
	|	ТаблицаСчетов.Порядок КАК Порядок,
	|	ТаблицаСчетов.ВидСчета КАК ВидСчета,
	|	ТаблицаСчетов.ВидСубконто1 КАК ВидСубконто1,
	|	ТаблицаСчетов.ВидСубконто2 КАК ВидСубконто2,
	|	ТаблицаСчетов.ВидСубконто3 КАК ВидСубконто3
	|ПОМЕСТИТЬ СчетаНаборов
	|ИЗ
	|	&ТаблицаСчетов КАК ТаблицаСчетов
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИнвентаризацияРасчетов.Ссылка КАК Ссылка,
	|	ИнвентаризацияРасчетов.Дата КАК Дата,
	|	ИнвентаризацияРасчетов.Организация КАК Организация,
	|	ИнвентаризацияРасчетовДетальныеЗаписи.СчетРасчетов КАК СчетРасчетов,
	|	ВЫБОР
	|		КОГДА СчетаНаборов.ВидСубконто1 = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПустаяСсылка)
	|				ИЛИ УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ИнвентаризацияРасчетовДетальныеЗаписи.Субконто1) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ИнвентаризацияРасчетовДетальныеЗаписи.Субконто1
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА СчетаНаборов.ВидСубконто2 = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПустаяСсылка)
	|				ИЛИ УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ИнвентаризацияРасчетовДетальныеЗаписи.Субконто2) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ИнвентаризацияРасчетовДетальныеЗаписи.Субконто2
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА СчетаНаборов.ВидСубконто3 = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПустаяСсылка)
	|				ИЛИ УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ИнвентаризацияРасчетовДетальныеЗаписи.Субконто3) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ИнвентаризацияРасчетовДетальныеЗаписи.Субконто3
	|	КОНЕЦ КАК Субконто3,
	|	ИнвентаризацияРасчетовДетальныеЗаписи.Подтверждено КАК Подтверждено,
	|	ИнвентаризацияРасчетовДетальныеЗаписи.ДатаВозникновения КАК ДатаВозникновения,
	|	ИнвентаризацияРасчетовДетальныеЗаписи.ДатаПогашения КАК ДатаПогашения
	|ПОМЕСТИТЬ ВсеДетальныеЗаписи
	|ИЗ
	|	Документ.ИнвентаризацияРасчетовСКонтрагентами.ДетальныеЗаписи КАК ИнвентаризацияРасчетовДетальныеЗаписи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИнвентаризацияРасчетовСКонтрагентами КАК ИнвентаризацияРасчетов
	|		ПО ИнвентаризацияРасчетовДетальныеЗаписи.Ссылка = ИнвентаризацияРасчетов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаНаборов КАК СчетаНаборов
	|		ПО ИнвентаризацияРасчетовДетальныеЗаписи.СчетРасчетов = СчетаНаборов.Счет
	|ГДЕ
	|	ИнвентаризацияРасчетов.Проведен
	|	И ИнвентаризацияРасчетов.Дата МЕЖДУ &НачалоПредыдущегоПериода И &КонецПериодаДата
	|	И ИнвентаризацияРасчетов.Организация В(&Организации)
	|	И ИнвентаризацияРасчетов.ДетализироватьЗадолженность
	|	И ИнвентаризацияРасчетовДетальныеЗаписи.ВидЗадолженности = &ВидЗадолженности
	|	И ИнвентаризацияРасчетовДетальныеЗаписи.СчетРасчетов В(&СчетаИнвентаризацииРасчетов)
	|	И ИнвентаризацияРасчетовДетальныеЗаписи.ДатаПогашения <> ДАТАВРЕМЯ(1, 1, 1)
	|	И (ИнвентаризацияРасчетов.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&КонецПериодаДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&КонецПериодаДата, ДЕНЬ)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ИнвентаризацияРасчетовДетальныеЗаписи.Субконто3) В (&ТипыДокументовРасчетов)
	|			ИЛИ ИнвентаризацияРасчетовДетальныеЗаписи.ДатаПогашения >= &КонецПериодаДата)
	|	И ИнвентаризацияРасчетовДетальныеЗаписи.Подтверждено > 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетРасчетов,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеДетальныеЗаписи.Ссылка КАК Ссылка,
	|	ВсеДетальныеЗаписи.Ссылка.Дата КАК Дата,
	|	ВсеДетальныеЗаписи.Ссылка.Организация КАК Организация,
	|	ВсеДетальныеЗаписи.СчетРасчетов КАК СчетРасчетов,
	|	ВсеДетальныеЗаписи.Субконто1 КАК Субконто1,
	|	ВсеДетальныеЗаписи.Субконто2 КАК Субконто2,
	|	ВсеДетальныеЗаписи.Субконто3 КАК Субконто3,
	|	ВсеДетальныеЗаписи.Подтверждено КАК Подтверждено,
	|	ВсеДетальныеЗаписи.ДатаВозникновения КАК ДатаВозникновения,
	|	ВсеДетальныеЗаписи.ДатаПогашения КАК ДатаПогашения
	|ПОМЕСТИТЬ ДетальныеЗаписи
	|ИЗ
	|	Аналитика КАК Аналитика
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВсеДетальныеЗаписи КАК ВсеДетальныеЗаписи
	|		ПО Аналитика.Организация = ВсеДетальныеЗаписи.Организация
	|			И Аналитика.Счет = ВсеДетальныеЗаписи.СчетРасчетов
	|			И Аналитика.Субконто1 = ВсеДетальныеЗаписи.Субконто1
	|			И Аналитика.Субконто2 = ВсеДетальныеЗаписи.Субконто2
	|			И Аналитика.Субконто3 = ВсеДетальныеЗаписи.Субконто3
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетРасчетов,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ДетальныеЗаписи.Дата) КАК Дата,
	|	ДетальныеЗаписи.Организация КАК Организация,
	|	ДетальныеЗаписи.СчетРасчетов КАК СчетРасчетов,
	|	ДетальныеЗаписи.Субконто1 КАК Субконто1,
	|	ДетальныеЗаписи.Субконто2 КАК Субконто2,
	|	ДетальныеЗаписи.Субконто3 КАК Субконто3
	|ПОМЕСТИТЬ МаксимальныеДаты
	|ИЗ
	|	ДетальныеЗаписи КАК ДетальныеЗаписи
	|
	|СГРУППИРОВАТЬ ПО
	|	ДетальныеЗаписи.Организация,
	|	ДетальныеЗаписи.Субконто1,
	|	ДетальныеЗаписи.Субконто2,
	|	ДетальныеЗаписи.Субконто3,
	|	ДетальныеЗаписи.СчетРасчетов
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетРасчетов,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ДетальныеЗаписи.Ссылка) КАК Ссылка,
	|	ДетальныеЗаписи.Дата КАК Дата,
	|	ДетальныеЗаписи.Организация КАК Организация,
	|	ДетальныеЗаписи.СчетРасчетов КАК СчетРасчетов,
	|	ДетальныеЗаписи.Субконто1 КАК Субконто1,
	|	ДетальныеЗаписи.Субконто2 КАК Субконто2,
	|	ДетальныеЗаписи.Субконто3 КАК Субконто3
	|ПОМЕСТИТЬ ПоследниеДокументы
	|ИЗ
	|	МаксимальныеДаты КАК МаксимальныеДаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДетальныеЗаписи КАК ДетальныеЗаписи
	|		ПО МаксимальныеДаты.Организация = ДетальныеЗаписи.Организация
	|			И МаксимальныеДаты.СчетРасчетов = ДетальныеЗаписи.СчетРасчетов
	|			И МаксимальныеДаты.Субконто1 = ДетальныеЗаписи.Субконто1
	|			И МаксимальныеДаты.Субконто2 = ДетальныеЗаписи.Субконто2
	|			И МаксимальныеДаты.Субконто3 = ДетальныеЗаписи.Субконто3
	|			И МаксимальныеДаты.Дата = ДетальныеЗаписи.Дата
	|
	|СГРУППИРОВАТЬ ПО
	|	ДетальныеЗаписи.Дата,
	|	ДетальныеЗаписи.Организация,
	|	ДетальныеЗаписи.СчетРасчетов,
	|	ДетальныеЗаписи.Субконто1,
	|	ДетальныеЗаписи.Субконто2,
	|	ДетальныеЗаписи.Субконто3
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетРасчетов,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДетальныеЗаписи.Ссылка КАК Ссылка,
	|	ДетальныеЗаписи.Дата КАК Дата,
	|	ДетальныеЗаписи.Организация КАК Организация,
	|	ДетальныеЗаписи.СчетРасчетов КАК СчетРасчетов,
	|	ДетальныеЗаписи.Субконто1 КАК Субконто1,
	|	ДетальныеЗаписи.Субконто2 КАК Субконто2,
	|	ДетальныеЗаписи.Субконто3 КАК Субконто3,
	|	ДетальныеЗаписи.Подтверждено КАК Подтверждено,
	|	ДетальныеЗаписи.ДатаВозникновения КАК ДатаВозникновения,
	|	ДетальныеЗаписи.ДатаПогашения КАК ДатаПогашения
	|ПОМЕСТИТЬ ИнвентаризацияРасчетов
	|ИЗ
	|	ПоследниеДокументы КАК ПоследниеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДетальныеЗаписи КАК ДетальныеЗаписи
	|		ПО ПоследниеДокументы.Организация = ДетальныеЗаписи.Организация
	|			И ПоследниеДокументы.СчетРасчетов = ДетальныеЗаписи.СчетРасчетов
	|			И ПоследниеДокументы.Субконто1 = ДетальныеЗаписи.Субконто1
	|			И ПоследниеДокументы.Субконто2 = ДетальныеЗаписи.Субконто2
	|			И ПоследниеДокументы.Субконто3 = ДетальныеЗаписи.Субконто3
	|			И ПоследниеДокументы.Ссылка = ДетальныеЗаписи.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВсеДетальныеЗаписи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МаксимальныеДаты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ПоследниеДокументы";
	
	Запрос.Выполнить();
	
КонецПроцедуры

Функция СчетаИнвентаризацииРасчетовДетализация(Запрос)
	
	Счета = Новый Массив;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИнвентаризацияРасчетовДетальныеЗаписи.СчетРасчетов КАК СчетРасчетов
	|ИЗ
	|	Документ.ИнвентаризацияРасчетовСКонтрагентами КАК ИнвентаризацияРасчетовСКонтрагентами
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИнвентаризацияРасчетовСКонтрагентами.ДетальныеЗаписи КАК ИнвентаризацияРасчетовДетальныеЗаписи
	|		ПО ИнвентаризацияРасчетовСКонтрагентами.Ссылка = ИнвентаризацияРасчетовДетальныеЗаписи.Ссылка
	|ГДЕ
	|	ИнвентаризацияРасчетовСКонтрагентами.Проведен
	|	И ИнвентаризацияРасчетовСКонтрагентами.Дата МЕЖДУ &НачалоПредыдущегоПериода И &КонецПериодаДата
	|	И ИнвентаризацияРасчетовСКонтрагентами.Организация В(&Организации)
	|	И ИнвентаризацияРасчетовСКонтрагентами.ДетализироватьЗадолженность
	|	И ИнвентаризацияРасчетовДетальныеЗаписи.ВидЗадолженности = &ВидЗадолженности
	|	И ИнвентаризацияРасчетовДетальныеЗаписи.СчетРасчетов В(&СчетаИнвентаризацииРасчетов)
	|	И ВЫБОР
	|			КОГДА ИнвентаризацияРасчетовСКонтрагентами.Дата МЕЖДУ НАЧАЛОПЕРИОДА(&КонецПериодаДата, ДЕНЬ) И КОНЕЦПЕРИОДА(&КонецПериодаДата, ДЕНЬ)
	|				ТОГДА ИСТИНА
	|			КОГДА ТИПЗНАЧЕНИЯ(ИнвентаризацияРасчетовДетальныеЗаписи.Субконто3) В (&ТипыДокументовРасчетов)
	|					И ИнвентаризацияРасчетовДетальныеЗаписи.ДатаПогашения <> ДАТАВРЕМЯ(1, 1, 1)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ИнвентаризацияРасчетовДетальныеЗаписи.ДатаПогашения >= &КонецПериодаДата
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ИнвентаризацияРасчетовДетальныеЗаписи.СчетРасчетов";

	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Счета.Добавить(Выборка.СчетРасчетов);
	КонецЦикла;
	
	Возврат Счета;
КонецФункции

Процедура ПересчитатьОстаткиСовпадающейАналитикиВИнвентаризацииРасчетов(ТаблицаРасчетная, ДанныеРаспределения)
	
	Если Не ЗначениеЗаполнено(ДанныеРаспределения) Тогда
		Возврат;
	КонецЕсли;
	
	КолонкиГруппировки = "Организация, Счет, Субконто1, Субконто2, Субконто3, ДатаРегистратора, ДатаПогашенияБУ, ИсточникСрокаПогашения";
	
	// Данные по остаткам бухгалтерского учета
	КолонкиТаблицы = СтрШаблон("%1, %2", КолонкиГруппировки, "ОстатокБУ");

	ДанныеРасчетаБУ = ДанныеРаспределения.Скопировать(,КолонкиТаблицы);
	ДанныеРасчетаБУ.Свернуть(КолонкиТаблицы);
	
	Для Каждого СтрокаГруппировки Из ДанныеРасчетаБУ Цикл
		Отбор = Новый Структура(КолонкиГруппировки);
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаГруппировки);
		
		ОстатокБУ = СтрокаГруппировки.ОстатокБУ;
		
		СтрокиТаблицы = ДанныеРаспределения.НайтиСтроки(Отбор);

		Для Каждого СтрокаТаблицы Из СтрокиТаблицы Цикл
			
			СуммаРасчетная = Мин(СтрокаТаблицы.Подтверждено, ОстатокБУ);
			
			СтрокаРасчетная = ТаблицаРасчетная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРасчетная, СтрокаТаблицы, "Организация, Счет, Субконто1, Субконто2, Субконто3");
			СтрокаРасчетная.ДатаВозникновения = ?(ЗначениеЗаполнено(СтрокаТаблицы.ДатаРегистратора), СтрокаТаблицы.ДатаРегистратора, СтрокаТаблицы.ДатаВозникновенияИнвентаризация);
			СтрокаРасчетная.ДатаПогашения = СтрокаТаблицы.ДатаПогашенияИнвентаризация;
			СтрокаРасчетная.ИсточникСрокаПогашения = СтрокаТаблицы.ДокументИнвентаризации;
			СтрокаРасчетная.ЗаписыватьВРегистр = Истина;
			СтрокаРасчетная.СуммаРасчетная = СуммаРасчетная;
			ОстатокБУ = ОстатокБУ - СуммаРасчетная;
			
			Если ОстатокБУ = 0 Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		// В Инвентаризации расчетов могут быть указаны суммы меньше, чем фактические остатки,
		// поэтому добавляем остаток за вычетом подтвержденных сумм по инвентаризации.
		Если ОстатокБУ > 0 Тогда
			СтрокаРасчетная = ТаблицаРасчетная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРасчетная, СтрокаГруппировки, "Организация, Счет, Субконто1, Субконто2, Субконто3,ИсточникСрокаПогашения");
			СтрокаРасчетная.ДатаВозникновения = СтрокаГруппировки.ДатаРегистратора;
			СтрокаРасчетная.ДатаПогашения = СтрокаГруппировки.ДатаПогашенияБУ;
			СтрокаРасчетная.ЗаписыватьВРегистр = Истина;
			СтрокаРасчетная.СуммаРасчетная = ОстатокБУ;
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьВременныеТаблицыРаспределенныеДанныеПоДатамВозникновения(Запрос)
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасчетыПоСрокамПогашения.Организация КАК Организация,
	|	РасчетыПоСрокамПогашения.Счет КАК Счет,
	|	РасчетыПоСрокамПогашения.Субконто1 КАК Субконто1,
	|	РасчетыПоСрокамПогашения.Субконто2 КАК Субконто2,
	|	РасчетыПоСрокамПогашения.Субконто3 КАК Субконто3,
	|	РасчетыПоСрокамПогашения.ДатаВозникновения КАК ДатаВозникновения,
	|	РасчетыПоСрокамПогашения.ДатаПогашения КАК ДатаПогашения,
	|	РасчетыПоСрокамПогашения.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	РасчетыПоСрокамПогашения.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	РасчетыПоСрокамПогашения.ОстатокДолга КАК ОстатокДолга
	|ПОМЕСТИТЬ ОбъектыРасчетовБезДатыВозникновения
	|ИЗ
	|	РасчетыПоСрокамПогашения КАК РасчетыПоСрокамПогашения
	|ГДЕ
	|	РасчетыПоСрокамПогашения.НайтиДатуВозникновения
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаВозникновения,
	|	ДатаПогашения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОбороты.Период КАК ДатаРегистратора,
	|	ХозрасчетныйОбороты.Организация КАК Организация,
	|	ХозрасчетныйОбороты.Счет КАК Счет,
	|	ВЫБОР
	|		КОГДА СчетаНаборов.ВидСубконто1 = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПустаяСсылка)
	|				ИЛИ УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОбороты.Субконто1) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ХозрасчетныйОбороты.Субконто1
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА СчетаНаборов.ВидСубконто2 = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПустаяСсылка)
	|				ИЛИ УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОбороты.Субконто2) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ХозрасчетныйОбороты.Субконто2
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА СчетаНаборов.ВидСубконто3 = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.ПустаяСсылка)
	|				ИЛИ УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОбороты.Субконто3) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ХозрасчетныйОбороты.Субконто3
	|	КОНЕЦ КАК Субконто3,
	|	ВЫБОР
	|		КОГДА &ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.ВидыЗадолженности.Кредиторская)
	|			ТОГДА -1 * ХозрасчетныйОбороты.СуммаОборот
	|		ИНАЧЕ ХозрасчетныйОбороты.СуммаОборот
	|	КОНЕЦ КАК СуммаОборот
	|ПОМЕСТИТЬ ПериодыДвижений
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоПредыдущегоПериода,
	|			&КонецПериода,
	|			День,
	|			Счет В
	|				(ВЫБРАТЬ
	|					ОбъектыРасчетовБезДатыВозникновения.Счет
	|				ИЗ
	|					ОбъектыРасчетовБезДатыВозникновения КАК ОбъектыРасчетовБезДатыВозникновения),
	|			,
	|			Организация В (&Организации),
	|			,
	|			) КАК ХозрасчетныйОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаНаборов КАК СчетаНаборов
	|		ПО ХозрасчетныйОбороты.Счет = СчетаНаборов.Счет
	|ГДЕ
	|	ВЫБОР
	|		КОГДА &ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.ВидыЗадолженности.Кредиторская)
	|			ТОГДА -1 * ХозрасчетныйОбороты.СуммаОборот
	|		ИНАЧЕ ХозрасчетныйОбороты.СуммаОборот
	|	КОНЕЦ > 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОбъектыРасчетов.Организация КАК Организация,
	|	ОбъектыРасчетов.Счет КАК Счет,
	|	ОбъектыРасчетов.Субконто1 КАК Субконто1,
	|	ОбъектыРасчетов.Субконто2 КАК Субконто2,
	|	ОбъектыРасчетов.Субконто3 КАК Субконто3
	|ПОМЕСТИТЬ ОбъектыРасчетовНайденыДвижения
	|ИЗ
	|	ОбъектыРасчетовБезДатыВозникновения КАК ОбъектыРасчетов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПериодыДвижений КАК ПериодыДвижений
	|		ПО ОбъектыРасчетов.Организация = ПериодыДвижений.Организация
	|			И ОбъектыРасчетов.Счет = ПериодыДвижений.Счет
	|			И ОбъектыРасчетов.Субконто1 = ПериодыДвижений.Субконто1
	|			И ОбъектыРасчетов.Субконто2 = ПериодыДвижений.Субконто2
	|			И ОбъектыРасчетов.Субконто3 = ПериодыДвижений.Субконто3
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыРасчетов.Организация КАК Организация,
	|	ОбъектыРасчетов.Счет КАК Счет,
	|	ОбъектыРасчетов.Субконто1 КАК Субконто1,
	|	ОбъектыРасчетов.Субконто2 КАК Субконто2,
	|	ОбъектыРасчетов.Субконто3 КАК Субконто3,
	|	ОбъектыРасчетов.ДатаВозникновения КАК ДатаВозникновения,
	|	ОбъектыРасчетов.ДатаПогашения КАК ДатаПогашения,
	|	ОбъектыРасчетов.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	ОбъектыРасчетов.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	ОбъектыРасчетов.ОстатокДолга КАК ОстатокДолга,
	|	НЕ ОбъектыРасчетовНайденыДвижения.Организация ЕСТЬ NULL КАК ЕстьОбороты
	|ПОМЕСТИТЬ ОбъектыРасчетовДвижения
	|ИЗ
	|	ОбъектыРасчетовБезДатыВозникновения КАК ОбъектыРасчетов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОбъектыРасчетовНайденыДвижения КАК ОбъектыРасчетовНайденыДвижения
	|		ПО ОбъектыРасчетов.Организация = ОбъектыРасчетовНайденыДвижения.Организация
	|			И ОбъектыРасчетов.Счет = ОбъектыРасчетовНайденыДвижения.Счет
	|			И ОбъектыРасчетов.Субконто1 = ОбъектыРасчетовНайденыДвижения.Субконто1
	|			И ОбъектыРасчетов.Субконто2 = ОбъектыРасчетовНайденыДвижения.Субконто2
	|			И ОбъектыРасчетов.Субконто3 = ОбъектыРасчетовНайденыДвижения.Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПериодыДвижений.Организация КАК Организация,
	|	ПериодыДвижений.Счет КАК Счет,
	|	ПериодыДвижений.Субконто1 КАК Субконто1,
	|	ПериодыДвижений.Субконто2 КАК Субконто2,
	|	ПериодыДвижений.Субконто3 КАК Субконто3,
	|	ПериодыДвижений.ДатаРегистратора КАК ДатаРегистратора,
	|	ПериодыДвижений.СуммаОборот КАК СуммаОборот
	|ИЗ
	|	ПериодыДвижений КАК ПериодыДвижений
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОбъектыРасчетовНайденыДвижения КАК ОбъектыРасчетовНайденыДвижения
	|		ПО ПериодыДвижений.Организация = ОбъектыРасчетовНайденыДвижения.Организация
	|			И ПериодыДвижений.Счет = ОбъектыРасчетовНайденыДвижения.Счет
	|			И ПериодыДвижений.Субконто1 = ОбъектыРасчетовНайденыДвижения.Субконто1
	|			И ПериодыДвижений.Субконто2 = ОбъектыРасчетовНайденыДвижения.Субконто2
	|			И ПериодыДвижений.Субконто3 = ОбъектыРасчетовНайденыДвижения.Субконто3
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаРегистратора
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыРасчетовДвижения.Организация КАК Организация,
	|	ОбъектыРасчетовДвижения.Счет КАК Счет,
	|	ОбъектыРасчетовДвижения.Субконто1 КАК Субконто1,
	|	ОбъектыРасчетовДвижения.Субконто2 КАК Субконто2,
	|	ОбъектыРасчетовДвижения.Субконто3 КАК Субконто3,
	|	ОбъектыРасчетовДвижения.ДатаВозникновения КАК ДатаВозникновения,
	|	ОбъектыРасчетовДвижения.ДатаПогашения КАК ДатаПогашения,
	|	ОбъектыРасчетовДвижения.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	ОбъектыРасчетовДвижения.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	ОбъектыРасчетовДвижения.ОстатокДолга КАК ОстатокДолга
	|ИЗ
	|	ОбъектыРасчетовДвижения КАК ОбъектыРасчетовДвижения
	|ГДЕ
	|	ОбъектыРасчетовДвижения.ЕстьОбороты
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаПогашения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыРасчетовНайденыДвижения.Организация КАК Организация,
	|	ОбъектыРасчетовНайденыДвижения.Счет КАК Счет,
	|	ОбъектыРасчетовНайденыДвижения.Субконто1 КАК Субконто1,
	|	ОбъектыРасчетовНайденыДвижения.Субконто2 КАК Субконто2,
	|	ОбъектыРасчетовНайденыДвижения.Субконто3 КАК Субконто3
	|ИЗ
	|	ОбъектыРасчетовНайденыДвижения КАК ОбъектыРасчетовНайденыДвижения
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3";
	
	Результат = Запрос.ВыполнитьПакет();
	ПоследнийИндекс = Результат.ВГраница();

	ВыборкаГруппировки = Результат[ПоследнийИндекс].Выбрать();
	
	ТаблицаЗадолженность = Результат[ПоследнийИндекс - 1].Выгрузить();
	ТаблицаЗадолженность.Индексы.Добавить("Организация, Счет, Субконто1, Субконто2, Субконто3");
	
	ВыборкаДвижения = Результат[ПоследнийИндекс - 2].Выбрать();
	
	ТаблицаРаспределения = ТаблицаЗадолженность.СкопироватьКолонки();
	
	КолонкиГруппировок = "Организация, Счет, Субконто1, Субконто2, Субконто3";
	
	Пока ВыборкаГруппировки.Следующий() Цикл
		
		Отбор = Новый Структура(КолонкиГруппировок);
		ЗаполнитьЗначенияСвойств(Отбор, ВыборкаГруппировки);
		СтрокиЗадолженности = ТаблицаЗадолженность.НайтиСтроки(Отбор);
		
		ВыборкаДвижения.Сбросить();
		
		ОстатокОборота = 0;
		ДатаВозникновения = Дата(1,1,1);
		
		Для Каждого СтрокаЗадолженность Из СтрокиЗадолженности Цикл
			
			ОстатокДолга = СтрокаЗадолженность.ОстатокДолга;
			
			Если ОстатокОборота > 0 Тогда
				СтрокаТаблицы = ТаблицаРаспределения.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаЗадолженность);
				СтрокаТаблицы.ОстатокДолга = Мин(ОстатокДолга, ОстатокОборота);
				СтрокаТаблицы.ДатаВозникновения = ДатаВозникновения;
				ОстатокДолга = ОстатокДолга - СтрокаТаблицы.ОстатокДолга;
				ОстатокОборота = ОстатокОборота - СтрокаТаблицы.ОстатокДолга;
			КонецЕсли;
			
			Если ОстатокДолга > 0 Тогда
				Пока ВыборкаДвижения.НайтиСледующий(Отбор) Цикл
					СтрокаТаблицы = ТаблицаРаспределения.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаЗадолженность);
					СтрокаТаблицы.ОстатокДолга = Мин(ОстатокДолга, ВыборкаДвижения.СуммаОборот);
					СтрокаТаблицы.ДатаВозникновения = ВыборкаДвижения.ДатаРегистратора;
					ДатаВозникновения = ВыборкаДвижения.ДатаРегистратора;
					ОстатокДолга = ОстатокДолга - СтрокаТаблицы.ОстатокДолга;
					ОстатокОборота = ВыборкаДвижения.СуммаОборот - СтрокаТаблицы.ОстатокДолга;
					Если ОстатокДолга = 0 Тогда
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			Если ОстатокДолга > 0 Тогда
				СтрокаТаблицы = ТаблицаРаспределения.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаЗадолженность);
				СтрокаТаблицы.ОстатокДолга = ОстатокДолга;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаРаспределения.Организация КАК Организация,
	|	ТаблицаРаспределения.Счет КАК Счет,
	|	ТаблицаРаспределения.Субконто1 КАК Субконто1,
	|	ТаблицаРаспределения.Субконто2 КАК Субконто2,
	|	ТаблицаРаспределения.Субконто3 КАК Субконто3,
	|	ТаблицаРаспределения.ДатаВозникновения КАК ДатаВозникновения,
	|	ТаблицаРаспределения.ДатаПогашения КАК ДатаПогашения,
	|	ТаблицаРаспределения.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	ТаблицаРаспределения.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	ТаблицаРаспределения.ОстатокДолга КАК ОстатокДолга
	|ПОМЕСТИТЬ ЗадолженностьРаспределенная
	|ИЗ
	|	&ТаблицаРаспределения КАК ТаблицаРаспределения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбъектыРасчетовДвижения.Организация КАК Организация,
	|	ОбъектыРасчетовДвижения.Счет КАК Счет,
	|	ОбъектыРасчетовДвижения.Субконто1 КАК Субконто1,
	|	ОбъектыРасчетовДвижения.Субконто2 КАК Субконто2,
	|	ОбъектыРасчетовДвижения.Субконто3 КАК Субконто3,
	|	ОбъектыРасчетовДвижения.ДатаВозникновения КАК ДатаВозникновения,
	|	ОбъектыРасчетовДвижения.ДатаПогашения КАК ДатаПогашения,
	|	ОбъектыРасчетовДвижения.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	ОбъектыРасчетовДвижения.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	ОбъектыРасчетовДвижения.ОстатокДолга КАК ОстатокДолга
	|ПОМЕСТИТЬ РасчетыДатаВозникновенияПоРегистратору
	|ИЗ
	|	ОбъектыРасчетовДвижения КАК ОбъектыРасчетовДвижения
	|ГДЕ
	|	НЕ ОбъектыРасчетовДвижения.ЕстьОбороты
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗадолженностьРаспределенная.Организация,
	|	ЗадолженностьРаспределенная.Счет,
	|	ЗадолженностьРаспределенная.Субконто1,
	|	ЗадолженностьРаспределенная.Субконто2,
	|	ЗадолженностьРаспределенная.Субконто3,
	|	ЗадолженностьРаспределенная.ДатаВозникновения,
	|	ЗадолженностьРаспределенная.ДатаПогашения,
	|	ЗадолженностьРаспределенная.ИсточникСрокаПогашения,
	|	ЗадолженностьРаспределенная.ЗаписыватьВРегистр,
	|	ЗадолженностьРаспределенная.ОстатокДолга
	|ИЗ
	|	ЗадолженностьРаспределенная КАК ЗадолженностьРаспределенная";
	
	Запрос.УстановитьПараметр("ТаблицаРаспределения", ТаблицаРаспределения);
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьВременныеТаблицыОбъектыРезервовПоСомнительнымДолгам(МенеджерВременныхТаблиц, КонтекстРасчета)
	
	Запрос = Новый Запрос;
