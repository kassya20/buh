//
Функция СчетаИнвентаризацииРасчетовДебиторская() Экспорт
	
	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	ВидыСчетов.Добавить(ВидСчета.Активный);
	
	СчетаРасчетов = Новый Массив;
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.ВыполненныеЭтапыПоНезавершеннымРаботам);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПоставщикамиИПодрядчиками);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПокупателямиИЗаказчиками);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоОплатеТруда);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПодотчетнымиЛицами_);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоПрочимОперациям);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСУчредителями);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСРазнымиДебиторамиИКредиторами);

	СчетаИсключения = Новый Массив;
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСРозничнымиПокупателями); // 62.Р
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам); // 76.АВ
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.КорректировкаРасчетовПрошлогоПериода); // 76.К
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.РасчетыНДСНалоговогоАгента); // 76.НА
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.НДСНачисленныйПоОтгрузке); // 76.ОТ
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоИсполнительнымДокументамРаботников); // 76.41 отнесен к кредиторской задолженности
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, ПланыСчетов.Хозрасчетный.СчетаРасчетовПоАренде()); // 76.07, 76.27, 76.37
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, ПланыСчетов.Хозрасчетный.СчетаПроцентовПоРассрочке()); // 76.08, 76.28, 76.38
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, БухгалтерскийУчет.СчетаУчетаНазначенияИспользованияНМА()); // 76.18
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, СчетаУчетаРБП()); // 76.01.2, 76.01.9, 97

	Возврат СчетаВИерархии(СчетаРасчетов, ВидыСчетов, СчетаИсключения);
	
КонецФункции

