	|		ПО КлассификацияДебиторскойЗадолженностиПоСрочности.Организация = ДолгБУ.Организация
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Счет = ДолгБУ.Счет
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто1 = ДолгБУ.Субконто1
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто2 = ДолгБУ.Субконто2
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто3 = ДолгБУ.Субконто3
	|
	|СГРУППИРОВАТЬ ПО
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Организация,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Счет,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто1,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто2,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто3
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Организация КАК Организация,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Счет КАК Счет,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто1 КАК Субконто1,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто2 КАК Субконто2,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто3 КАК Субконто3,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.ДатаВозникновения КАК ДатаВозникновения,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.ДатаПогашения КАК ДатаПогашения,
	|	ВЫБОР
	|		КОГДА НЕ ЕСТЬNULL(ИсключитьРасчетныеДанные.ИсключитьОстатокДолга, ЛОЖЬ)
	|			ТОГДА КлассификацияДебиторскойЗадолженностиПоСрочности.ОстатокДолга
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ОстатокДолга,
	|	ВЫБОР
	|		КОГДА НЕ ЕСТЬNULL(ИсключитьРасчетныеДанные.ИсключитьОстатокДолга, ЛОЖЬ)
	|				ИЛИ КлассификацияДебиторскойЗадолженностиПоСрочности.ЭтоСчетРезерва
	|			ТОГДА КлассификацияДебиторскойЗадолженностиПоСрочности.РезервПоСомнительнымДолгам
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК РезервПоСомнительнымДолгам,
	|	ВЫБОР
	|		КОГДА НЕ ЕСТЬNULL(ИсключитьРасчетныеДанные.ИсключитьОстатокДолга, ЛОЖЬ)
	|				ИЛИ КлассификацияДебиторскойЗадолженностиПоСрочности.ЭтоСчетНДС
	|			ТОГДА КлассификацияДебиторскойЗадолженностиПоСрочности.НДСАвансов
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК НДСАвансов,
	|	КлассификацияДебиторскойЗадолженностиПоСрочности.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения
	|ПОМЕСТИТЬ КорректировкаКлассификации
	|ИЗ
	|	КлассификацияДебиторскойЗадолженностиПоСрочности КАК КлассификацияДебиторскойЗадолженностиПоСрочности
	|		ЛЕВОЕ СОЕДИНЕНИЕ ИсключитьРасчетныеДанные КАК ИсключитьРасчетныеДанные
	|		ПО КлассификацияДебиторскойЗадолженностиПоСрочности.Организация = ИсключитьРасчетныеДанные.Организация
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Счет = ИсключитьРасчетныеДанные.Счет
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто1 = ИсключитьРасчетныеДанные.Субконто1
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто2 = ИсключитьРасчетныеДанные.Субконто2
	|			И КлассификацияДебиторскойЗадолженностиПоСрочности.Субконто3 = ИсключитьРасчетныеДанные.Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.ВидыЗадолженности.Дебиторская) КАК ВидЗадолженности,
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК СчетРасчетов,
	|	Хозрасчетный.Наименование КАК СчетНаименование,
	|	Расчеты.Субконто1 КАК Субконто1Задолженности,
	|	Расчеты.Субконто2 КАК Субконто2Задолженности,
	|	Расчеты.Субконто3 КАК Субконто3Задолженности,
	|	МАКСИМУМ(НАЧАЛОПЕРИОДА(Расчеты.ДатаВозникновения, ДЕНЬ)) КАК ДатаВозникновенияЗадолженности,
	|	МАКСИМУМ(Расчеты.ДатаПогашения) КАК ДатаПогашенияЗадолженности,
	|	МАКСИМУМ(Расчеты.ДатаПогашения) >= &ДатаНачалаДолгосрочногоПериода КАК Долгосрочный,
	|	СУММА(Расчеты.ОстатокДолга) КАК ОстатокДолга,
	|	СУММА(Расчеты.РезервПоСомнительнымДолгам) КАК РезервПоСомнительнымДолгам,
	|	СУММА(Расчеты.НДСАвансов) КАК НДСАвансов,
	|	МАКСИМУМ(Расчеты.ИсточникСрокаПогашения) КАК ИсточникСрокаПогашения
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДолгБУ.Организация КАК Организация,
	|		ДолгБУ.Счет КАК Счет,
	|		ДолгБУ.Субконто1 КАК Субконто1,
	|		ДолгБУ.Субконто2 КАК Субконто2,
	|		ДолгБУ.Субконто3 КАК Субконто3,
	|		ДолгБУ.ДатаВозникновения КАК ДатаВозникновения,
	|		ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашения,
	|		ДолгБУ.ОстатокБУ КАК ОстатокДолга,
	|		0 КАК РезервПоСомнительнымДолгам,
	|		0 КАК НДСАвансов,
	|		НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
	|	ИЗ
	|		ДолгБУ КАК ДолгБУ
	|	ГДЕ
	|		ДолгБУ.ЕстьРасхождениеОстаткаДолга
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КорректировкаКлассификации.Организация,
	|		КорректировкаКлассификации.Счет,
	|		КорректировкаКлассификации.Субконто1,
	|		КорректировкаКлассификации.Субконто2,
	|		КорректировкаКлассификации.Субконто3,
	|		КорректировкаКлассификации.ДатаВозникновения,
	|		КорректировкаКлассификации.ДатаПогашения,
	|		КорректировкаКлассификации.ОстатокДолга,
	|		КорректировкаКлассификации.РезервПоСомнительнымДолгам,
	|		КорректировкаКлассификации.НДСАвансов,
	|		КорректировкаКлассификации.ИсточникСрокаПогашения
	|	ИЗ
	|		КорректировкаКлассификации КАК КорректировкаКлассификации
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ОбщийРезервПоСомнительнымДолгам.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		ОбщийРезервПоСомнительнымДолгам.РезервБУ,
	|		0,
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		ОбщийРезервПоСомнительнымДолгам КАК ОбщийРезервПоСомнительнымДолгам
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КорректировкаКлассификации.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		-СУММА(КорректировкаКлассификации.РезервПоСомнительнымДолгам),
	|		0,
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		КорректировкаКлассификации КАК КорректировкаКлассификации
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КорректировкаКлассификации.Организация
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ОбщийНДС.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		0,
	|		СУММА(ОбщийНДС.НДСАвансовБУ),
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		ОбщийНДСВыданный КАК ОбщийНДС
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ОбщийНДС.Организация
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КорректировкаКлассификации.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		0,
	|		-СУММА(КорректировкаКлассификации.НДСАвансов),
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		КорректировкаКлассификации КАК КорректировкаКлассификации
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КорректировкаКлассификации.Организация) КАК Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|		ПО Расчеты.Счет = Хозрасчетный.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Расчеты.Организация,
	|	Расчеты.Счет,
	|	Хозрасчетный.Наименование,
	|	Расчеты.Субконто1,
	|	Расчеты.Субконто2,
	|	Расчеты.Субконто3,
	|	Расчеты.ДатаВозникновения,
	|	Расчеты.ДатаПогашения,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Расчеты.ДатаПогашения < &ДатаНачалаДолгосрочногоПериода, ЛОЖЬ)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ
	|
	|ИМЕЮЩИЕ
	|	(СУММА(Расчеты.ОстатокДолга) <> 0
	|		ИЛИ СУММА(Расчеты.НДСАвансов) <> 0
	|		ИЛИ СУММА(Расчеты.РезервПоСомнительнымДолгам) <> 0)");
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("ПустойУникальныйИдентификатор", ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("ВидАктиваДебиторскаяЗадолженность", Перечисления.ВидыАктивовДляРБП.ДебиторскаяЗадолженность);
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаРезервов",   БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам));
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаНДСАвансовВыданных", БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным));
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаУчетаАвансовВыданных", СчетаУчетаАвансовВыданных());
	
	РазделятьАвансыПоВидамАктивов = РегламентированнаяОтчетность.АвансыРазделеныПоВидамАктивов(ОбщиеПараметры.Организация.ГоловнаяОрганизация, ОбщиеПараметры.КонецПериодаДата);
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("РазделятьАвансыПоВидамАктивов", РазделятьАвансыПоВидамАктивов);
	
	ИсключаемыеВидыАктиваАвансов = Новый Массив;
	Если РазделятьАвансыПоВидамАктивов Тогда
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.Запасы);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ИнвестиционнаяНедвижимость);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.НематериальныеАктивы);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ПрочиеВнеоборотные);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ОсновныеСредства);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ПрочиеОборотные);
	КонецЕсли;
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("ИсключаемыеВидыАктиваАвансов", ИсключаемыеВидыАктиваАвансов);

	КонтекстЗапроса.ПараметрыЗапроса.Вставить("ТипыДокументовРасчетов", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами.ТипЗначения.Типы());

	Возврат ТекстЗапроса;
	
КонецФункции

// Формирует текст запроса по остаткам по счетам кредиторской задолженности с учетом сроков
//
// Параметры:
//  НаборыСчетов - см. НовыйНаборыСчетов
//  КонтекстЗапроса - см.НовыйКонтекстЗапросаОстаткиЗадолженности
//  ОбщиеПараметры - Структура - основные параметры
//
// Возвращаемое значение:
//  Строка - текст запроса
//
Функция ТекстЗапросаОстаткиКредиторскойЗадолженности(НаборыСчетов, КонтекстЗапроса, ОбщиеПараметры) Экспорт

	ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская;
	
	ТекстыЗапросов = Новый Массив;
	
	// Остатки задолженности по счетам, которые участвуют в классификации задолженности по срокам погашения
	ТекстЗапросаОстатки = ТекстЗапросаОстаткиЗадолженности(НаборыСчетов, КонтекстЗапроса, ВидЗадолженности);
	Если ЗначениеЗаполнено(ТекстЗапросаОстатки) Тогда
		ТекстыЗапросов.Добавить(ТекстЗапросаОстатки);
	КонецЕсли;
	
	// Дополнить остатки задолженности сроками по первичным данным
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаКредитовЗаймов", СчетаКредитовЗаймов());
	ТекстЗапросаОстаткиПоСрокам = ТекстЗапросаКредиторскаяЗадолженностьПоСрокам(КонтекстЗапроса, "РасчетыКредиторская");

	ТекстыЗапросов.Добавить(ТекстЗапросаОстаткиПоСрокам);
	
	ТекстыЗапросов.Добавить( 
	"ВЫБРАТЬ
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация КАК Организация,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет КАК Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто1) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто1
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто2) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
