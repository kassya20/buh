	|	РезервыРаспределенныеПоОбъектам.Субконто2,
	|	РезервыРаспределенныеПоОбъектам.Субконто3,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	0,
	|	РезервыРаспределенныеПоОбъектам.ОстатокРезерва
	|ИЗ
	|	РезервыРаспределенныеПоОбъектам КАК РезервыРаспределенныеПоОбъектам
	|ГДЕ
	|	НЕ РезервыРаспределенныеПоОбъектам.НайденОбъектРасчетов
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НераспределенныеРезервы.Организация,
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам),
	|	НераспределенныеРезервы.Субконто1,
	|	НераспределенныеРезервы.Субконто2,
	|	НераспределенныеРезервы.Субконто3,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	0,
	|	НераспределенныеРезервы.Остаток
	|ИЗ
	|	НераспределенныеРезервы КАК НераспределенныеРезервы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВсеРезервы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ОбъектыРезервовБезНДСАвансов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РезервыВсеУровниРаспределения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ОбъектыРезервовМаксимальныеУровни
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РезервыРаспределенныеПоОбъектам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СовпадающаяАналитикаРезервы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РезервыПоОбъектам";

	Запрос.УстановитьПараметр("ТаблицаРаспределения", ТаблицаРаспределения);
	Запрос.УстановитьПараметр("ТаблицаРезервы", НераспределенныеРезервы);
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура РаспределитьПоФИФО(ТаблицаГруппировки, ТаблицаРаспределения, ТаблицаОстаточная, КолонкаРасчета, КолонкаСравнения)
	
	КолонкиГруппировок = "Организация, Субконто1, Субконто2, Субконто3";

	Для Каждого СтрокаГруппировки Из ТаблицаГруппировки Цикл
		
		Отбор = Новый Структура(КолонкиГруппировок);
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаГруппировки);
		
		СтрокиТаблицы = ТаблицаРаспределения.НайтиСтроки(Отбор);
		
		СуммаРаспределения = СтрокаГруппировки[КолонкаРасчета];
		
		Для Каждого СтрокаТаблица Из СтрокиТаблицы Цикл
			
			СтрокаТаблица[КолонкаРасчета] = Мин(СтрокаТаблица[КолонкаСравнения], СуммаРаспределения);
			
			СуммаРаспределения = СуммаРаспределения - СтрокаТаблица[КолонкаРасчета];
		КонецЦикла;
		
		Если СуммаРаспределения > 0 Тогда
			СтрокаРезерва = ТаблицаОстаточная.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРезерва, СтрокаГруппировки, "Организация, Субконто1, Субконто2, Субконто3");
			СтрокаРезерва.Остаток = СуммаРаспределения;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область НДСАвансов

Процедура СоздатьВременныеТаблицыНДСАвансов(МенеджерВременныхТаблиц, КонтекстОперации, КонтекстРасчета, ЗнакЧисла = 1)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организации", КонтекстОперации.Организации);
	Запрос.УстановитьПараметр("НачалоПериода", КонтекстОперации.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонтекстОперации.КонецПериода);
	Запрос.УстановитьПараметр("СчетаНДСАвансов", КонтекстРасчета.СчетаНДСАвансов);
	Запрос.УстановитьПараметр("СубконтоКонтрагентыСФ", КонтекстРасчета.СубконтоКонтрагентыСФ);
	Запрос.УстановитьПараметр("СчетНДСАвансов", КонтекстРасчета.СчетНДСАвансов);

	Запрос.УстановитьПараметр("ЗнакЧисла", ЗнакЧисла);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	ТекстыЗапросов = Новый Массив;
	
	ТекстыЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ХозрасчетныйОстатки.Субконто1 КАК Контрагент,
	|	ХозрасчетныйОстатки.Субконто2 КАК СчетФактура,
	|	&ЗнакЧисла * ХозрасчетныйОстатки.СуммаОстаток КАК ОстатокНДС
	|ПОМЕСТИТЬ ОстаткиНДСАвансов
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаНДСАвансов), &СубконтоКонтрагентыСФ, Организация В (&Организации)) КАК ХозрасчетныйОстатки");
	
	Если МенеджерВременныхТаблиц.Таблицы.Найти("ОбъектыАвансовАренды") = Неопределено Тогда
		ТекстыЗапросов.Добавить(
		"ВЫБРАТЬ
		|	ОстаткиНДСАвансов.Организация КАК Организация,
		|	ОстаткиНДСАвансов.Контрагент КАК Субконто1,
		|	ЕСТЬNULL(КонтрагентыДоговорыСФ.Договор, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК Субконто2,
		|	ОстаткиНДСАвансов.СчетФактура КАК Субконто3,
		|	ОстаткиНДСАвансов.ОстатокНДС КАК ОстатокНДС
		|ПОМЕСТИТЬ НДСАвансов
		|ИЗ
		|	ОстаткиНДСАвансов КАК ОстаткиНДСАвансов
		|		ЛЕВОЕ СОЕДИНЕНИЕ КонтрагентыДоговорыСФ КАК КонтрагентыДоговорыСФ
		|		ПО ОстаткиНДСАвансов.СчетФактура = КонтрагентыДоговорыСФ.Ссылка");
	Иначе
		ТекстыЗапросов.Добавить(
		"ВЫБРАТЬ
		|	ОстаткиНДСАвансов.Организация КАК Организация,
		|	ОстаткиНДСАвансов.Контрагент КАК Субконто1,
		|	ЕСТЬNULL(КонтрагентыДоговорыСФ.Договор, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК Субконто2,
		|	ОстаткиНДСАвансов.СчетФактура КАК Субконто3,
		|	ОстаткиНДСАвансов.ОстатокНДС КАК ОстатокНДС
		|ПОМЕСТИТЬ НДСАвансов
		|ИЗ
		|	ОстаткиНДСАвансов КАК ОстаткиНДСАвансов
		|		ЛЕВОЕ СОЕДИНЕНИЕ КонтрагентыДоговорыСФ КАК КонтрагентыДоговорыСФ
		|			ЛЕВОЕ СОЕДИНЕНИЕ ОбъектыАвансовАренды КАК ОбъектыАвансовАренды
		|			ПО КонтрагентыДоговорыСФ.Организация = ОбъектыАвансовАренды.Организация
		|				И КонтрагентыДоговорыСФ.Контрагент = ОбъектыАвансовАренды.Контрагент
		|				И КонтрагентыДоговорыСФ.Договор = ОбъектыАвансовАренды.ДоговорКонтрагента
		|		ПО ОстаткиНДСАвансов.СчетФактура = КонтрагентыДоговорыСФ.Ссылка
		|ГДЕ
		|	ОбъектыАвансовАренды.Контрагент ЕСТЬ NULL");
	КонецЕсли;

	ТекстыЗапросов.Добавить(
	"ВЫБРАТЬ
	|	ОбъектыАвансов.Организация КАК Организация,
	|	ОбъектыАвансов.Субконто1 КАК Субконто1,
	|	ОбъектыАвансов.Субконто2 КАК Субконто2,
	|	ОбъектыАвансов.Субконто3 КАК Субконто3,
	|	СУММА(ОбъектыАвансов.ОстатокДолга) КАК ИтогоОстатокДолга
	|ПОМЕСТИТЬ СовпадающаяАналитика
	|ИЗ
	|	ОбъектыАвансов КАК ОбъектыАвансов
	|
	|СГРУППИРОВАТЬ ПО
	|	ОбъектыАвансов.Организация,
	|	ОбъектыАвансов.Субконто1,
	|	ОбъектыАвансов.Субконто2,
	|	ОбъектыАвансов.Субконто3
	|
	|ИМЕЮЩИЕ
	|	(КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ОбъектыАвансов.Счет) > 1
	|		ИЛИ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ОбъектыАвансов.ДатаВозникновения) > 1
	|		ИЛИ КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ОбъектыАвансов.ДатаПогашения) > 1)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НДСАвансов.Организация КАК Организация,
	|	ЕСТЬNULL(ОбъектыАвансов.Счет, &СчетНДСАвансов) КАК СчетРасчетов,
	|	НДСАвансов.Субконто1 КАК Субконто1,
	|	НДСАвансов.Субконто2 КАК Субконто2,
	|	НДСАвансов.Субконто3 КАК Субконто3,
	|	ЕСТЬNULL(ОбъектыАвансов.ДатаВозникновения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаВозникновения,
	|	ЕСТЬNULL(ОбъектыАвансов.ДатаПогашения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПогашения,
	|	ЕСТЬNULL(ОбъектыАвансов.ОстатокДолга, 0) КАК ОстатокДолга,
	|	НДСАвансов.ОстатокНДС КАК ОстатокНДС,
	|	НЕ СовпадающаяАналитика.Организация ЕСТЬ NULL КАК СовпадающиеЗаписи,
	|	ЕСТЬNULL(СовпадающаяАналитика.ИтогоОстатокДолга, 0) КАК ИтогоОстатокДолга,
	|	НЕ ОбъектыАвансов.Организация ЕСТЬ NULL КАК НайденОбъектРасчетов
	|ПОМЕСТИТЬ НДСАвансовПоОбъектам
	|ИЗ
	|	НДСАвансов КАК НДСАвансов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОбъектыАвансов КАК ОбъектыАвансов
	|			ЛЕВОЕ СОЕДИНЕНИЕ СовпадающаяАналитика КАК СовпадающаяАналитика
	|			ПО ОбъектыАвансов.Организация = СовпадающаяАналитика.Организация
	|				И ОбъектыАвансов.Субконто1 = СовпадающаяАналитика.Субконто1
	|				И ОбъектыАвансов.Субконто2 = СовпадающаяАналитика.Субконто2
	|				И ОбъектыАвансов.Субконто3 = СовпадающаяАналитика.Субконто3
	|		ПО НДСАвансов.Организация = ОбъектыАвансов.Организация
	|			И НДСАвансов.Субконто1 = ОбъектыАвансов.Субконто1
	|			И НДСАвансов.Субконто2 = ОбъектыАвансов.Субконто2
	|			И НДСАвансов.Субконто3 = ОбъектыАвансов.Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ НДСАвансов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НДСАвансовПоОбъектам.Организация КАК Организация,
	|	НДСАвансовПоОбъектам.СчетРасчетов КАК СчетРасчетов,
	|	НДСАвансовПоОбъектам.Субконто1 КАК Субконто1,
	|	НДСАвансовПоОбъектам.Субконто2 КАК Субконто2,
	|	НДСАвансовПоОбъектам.Субконто3 КАК Субконто3,
	|	НДСАвансовПоОбъектам.ДатаВозникновения КАК ДатаВозникновения,
	|	НДСАвансовПоОбъектам.ДатаПогашения КАК ДатаПогашения,
	|	НДСАвансовПоОбъектам.ОстатокДолга КАК ОстатокДолга,
	|	НДСАвансовПоОбъектам.ИтогоОстатокДолга КАК ИтогоОстатокДолга,
	|	0 КАК ОстатокНДС
	|ИЗ
	|	НДСАвансовПоОбъектам КАК НДСАвансовПоОбъектам
	|ГДЕ
	|	НДСАвансовПоОбъектам.СовпадающиеЗаписи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НДСАвансовПоОбъектам.Организация КАК Организация,
	|	НДСАвансовПоОбъектам.Субконто1 КАК Субконто1,
	|	НДСАвансовПоОбъектам.Субконто2 КАК Субконто2,
	|	НДСАвансовПоОбъектам.Субконто3 КАК Субконто3,
	|	НДСАвансовПоОбъектам.ОстатокНДС КАК ОстатокНДС
	|ИЗ
	|	НДСАвансовПоОбъектам КАК НДСАвансовПоОбъектам
	|ГДЕ
	|	НДСАвансовПоОбъектам.СовпадающиеЗаписи");
	
	Запрос.Текст = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	ДополнитьТекстЗапросаПоДоговорамСчетовФактур(Запрос, Запрос.Параметры);

	Результат = Запрос.ВыполнитьПакет();
	КоличествоПакетов = Результат.ВГраница();

	ТаблицаГруппировки = Результат[КоличествоПакетов].Выгрузить();
	ТаблицаРаспределения = Результат[КоличествоПакетов-1].Выгрузить();

	РаспределитьПропорционально(ТаблицаГруппировки, ТаблицаРаспределения, "ОстатокНДС", "ОстатокДолга","ИтогоОстатокДолга");
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаРаспределения.Организация КАК Организация,
	|	ТаблицаРаспределения.СчетРасчетов КАК СчетРасчетов,
	|	ТаблицаРаспределения.Субконто1 КАК Субконто1,
	|	ТаблицаРаспределения.Субконто2 КАК Субконто2,
	|	ТаблицаРаспределения.Субконто3 КАК Субконто3,
	|	ТаблицаРаспределения.ДатаВозникновения КАК ДатаВозникновения,
	|	ТаблицаРаспределения.ДатаПогашения КАК ДатаПогашения,
	|	ТаблицаРаспределения.ОстатокНДС КАК ОстатокНДС
	|ПОМЕСТИТЬ НДСРаспределенный
	|ИЗ
	|	&ТаблицаРаспределения КАК ТаблицаРаспределения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НДСАвансовПоОбъектам.Организация КАК Организация,
	|	НДСАвансовПоОбъектам.СчетРасчетов КАК СчетРасчетов,
	|	НДСАвансовПоОбъектам.Субконто1 КАК Субконто1,
	|	НДСАвансовПоОбъектам.Субконто2 КАК Субконто2,
	|	НДСАвансовПоОбъектам.Субконто3 КАК Субконто3,
	|	НДСАвансовПоОбъектам.ДатаВозникновения КАК ДатаВозникновения,
	|	НДСАвансовПоОбъектам.ДатаПогашения КАК ДатаПогашения,
	|	НДСАвансовПоОбъектам.ОстатокНДС КАК ОстатокНДС
	|ПОМЕСТИТЬ НДСАвансов
	|ИЗ
	|	НДСАвансовПоОбъектам КАК НДСАвансовПоОбъектам
	|ГДЕ
	|	НЕ НДСАвансовПоОбъектам.СовпадающиеЗаписи
	|	И НДСАвансовПоОбъектам.НайденОбъектРасчетов
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НДСАвансовПоОбъектам.Организация,
	|	&СчетНДСАвансов,
	|	НДСАвансовПоОбъектам.Субконто1,
	|	НДСАвансовПоОбъектам.Субконто3,
	|	НЕОПРЕДЕЛЕНО,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	НДСАвансовПоОбъектам.ОстатокНДС
	|ИЗ
	|	НДСАвансовПоОбъектам КАК НДСАвансовПоОбъектам
	|ГДЕ
	|	НЕ НДСАвансовПоОбъектам.НайденОбъектРасчетов
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НДСРаспределенный.Организация,
	|	НДСРаспределенный.СчетРасчетов,
	|	НДСРаспределенный.Субконто1,
	|	НДСРаспределенный.Субконто2,
	|	НДСРаспределенный.Субконто3,
	|	НДСРаспределенный.ДатаВозникновения,
	|	НДСРаспределенный.ДатаПогашения,
	|	НДСРаспределенный.ОстатокНДС
	|ИЗ
	|	НДСРаспределенный КАК НДСРаспределенный
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетРасчетов,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	ДатаВозникновения,
	|	ДатаПогашения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ОстаткиНДСАвансов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СовпадающаяАналитика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ НДСАвансовПоОбъектам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ КонтрагентыДоговорыСФ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ НДСРаспределенный";

	Запрос.УстановитьПараметр("ТаблицаРаспределения", ТаблицаРаспределения);

	Запрос.Выполнить();
	
КонецПроцедуры

Процедура ДополнитьТекстЗапросаПоДоговорамСчетовФактур(ИсходныйЗапрос, ПараметрыЗапроса)
	
	ЗапросПоВидамСчетовФактур = Новый Запрос;
	ЗапросПоВидамСчетовФактур.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТИПЗНАЧЕНИЯ(ХозрасчетныйОстаткиИОбороты.Субконто2) КАК ТипДокумента
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
		|			&НачалоПериода,
		|			&КонецПериода,
		|			Период,
		|			,
		|			Счет В (&СчетаСоСчетамиФактурами),
		|			&СубконтоКонтрагентыСФ,
		|			Организация В (&Организации)) КАК ХозрасчетныйОстаткиИОбороты";
		
	ЗапросПоВидамСчетовФактур.УстановитьПараметр("Организации", ПараметрыЗапроса.Организации);
	ЗапросПоВидамСчетовФактур.УстановитьПараметр("НачалоПериода", ПараметрыЗапроса.НачалоПериода);
	ЗапросПоВидамСчетовФактур.УстановитьПараметр("КонецПериода", ПараметрыЗапроса.КонецПериода);
	ЗапросПоВидамСчетовФактур.УстановитьПараметр("СчетаСоСчетамиФактурами", ПараметрыЗапроса.СчетаНДСАвансов);
	ЗапросПоВидамСчетовФактур.УстановитьПараметр("СубконтоКонтрагентыСФ", ПараметрыЗапроса.СубконтоКонтрагентыСФ);
	
	СоздательВременнойТаблицы =
		"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка) КАК Организация,
		|	ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка) КАК Ссылка,
		|	ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка) КАК Контрагент,
		|	ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка) КАК Договор
		|ПОМЕСТИТЬ КонтрагентыДоговорыСФ
		|ГДЕ
		|	ЛОЖЬ";
	
	ШаблонДополнения =
		"ВЫБРАТЬ
		|	ВидДокумента.Организация,
		|	ВидДокумента.Ссылка,
		|	ВидДокумента.Контрагент,
		|	ВидДокумента.ДоговорКонтрагента
		|ИЗ
		|	&ПолноеИмяДокумента КАК ВидДокумента
		|";
	
	ШаблонОбъединение =
		"
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|";

	ШаблонИндексирование = 
		"
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка
		|;
		|
		|";
	
	ТекстыПодзапросов = Новый Массив;
	ТекстыПодзапросов.Добавить(СоздательВременнойТаблицы);
	ВыборкаПоТипамДокументов = ЗапросПоВидамСчетовФактур.Выполнить().Выбрать();
	
	Пока ВыборкаПоТипамДокументов.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаПоТипамДокументов.ТипДокумента) Тогда
			МетаданныеДокумента = Метаданные.НайтиПоТипу(ВыборкаПоТипамДокументов.ТипДокумента);
			Если МетаданныеДокумента <> Неопределено Тогда
				Если ДокументСодержитНужныеРеквизиты(МетаданныеДокумента) Тогда
					ТекстыПодзапросов.Добавить(СтрЗаменить(ШаблонДополнения, "&ПолноеИмяДокумента", МетаданныеДокумента.ПолноеИмя()));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ТекстЗапроса = СтрШаблон("%1 %2", СтрСоединить(ТекстыПодзапросов, ШаблонОбъединение), ШаблонИндексирование);
	
	ИсходныйЗапрос.Текст = ТекстЗапроса + ИсходныйЗапрос.Текст;
	
КонецПроцедуры

Функция ДокументСодержитНужныеРеквизиты(МетаданныеДокумента)

	Возврат МетаданныеДокумента.Реквизиты.Найти("Организация") <> Неопределено
			И МетаданныеДокумента.Реквизиты.Найти("Контрагент") <> Неопределено
			И МетаданныеДокумента.Реквизиты.Найти("ДоговорКонтрагента") <> Неопределено;
	
КонецФункции

Процедура РаспределитьПропорционально(ТаблицаГруппировки, ТаблицаРаспределения, КолонкаРасчета, КолонкаЧислитель, КолонкаЗнаменатель)
	
	КолонкиГруппировок = "Организация, Субконто1, Субконто2, Субконто3";

	Для Каждого СтрокаГруппировки Из ТаблицаГруппировки Цикл
		
		Отбор = Новый Структура(КолонкиГруппировок);
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаГруппировки);
		
		СтрокиТаблицы = ТаблицаРаспределения.НайтиСтроки(Отбор);
		
		СуммаРаспределения = СтрокаГруппировки[КолонкаРасчета];
		
		Для Каждого СтрокаТаблица Из СтрокиТаблицы Цикл
			
			СтрокаТаблица[КолонкаРасчета] = Окр(СтрокаГруппировки[КолонкаРасчета] * (СтрокаТаблица[КолонкаЧислитель] / СтрокаТаблица[КолонкаЗнаменатель]), 2);

			СуммаРаспределения = СуммаРаспределения - СтрокаТаблица[КолонкаРасчета];
		КонецЦикла;
		
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область РасчетыПоАрендеИРассрочке

Функция КонтекстРасчетаДисконтированногоОбязательства(КонтекстОперации)

	КонтекстРасчета = РасчетПоказателейБалансаПоОбязательствам.НовыйКонтекстРасчета();
	КонтекстРасчета.КонецПериода = КонтекстОперации.КонецПериодаДата;
	КонтекстРасчета.КонецПериодаДата = КонтекстОперации.КонецПериодаДата;
	КонтекстРасчета.Организации = КонтекстОперации.Организации;
	КонтекстРасчета.ИспользуетсяВалютныйУчет = БухгалтерскийУчетПереопределяемый.ИспользоватьВалютныйУчет();
	КонтекстРасчета.ЕстьДисконтирование = УчетнаяПолитика.ПоддерживаетсяДисконтированиеОбязательств();
	Возврат КонтекстРасчета;
	
КонецФункции

Процедура СоздатьВременныеТаблицыАвансыПоАренде(МенеджерВременныхТаблиц, АрендныеОбязательства)
	
	// Арендное обязательство очищено от НДС. Поэтому при уменьшении обязательства на сумму аванса, аванс также должен быть очищен от НДС.
	// В регистр "Классификация по срокам отдельных видов задолженности" делается запись суммы арендного обязательства, уменьшенного на сумму аванса без НДС.
	// Сумма НДС должна быть отражена также в регистре. Поэтому для его хранения используем счет 76.07.2
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.Организация КАК Организация,
	|	Таблица.Счет КАК Счет,
	|	Таблица.Контрагент КАК Контрагент,
	|	Таблица.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Таблица.ДатаПогашения КАК ДатаПогашения,
	|	Таблица.ОстатокПоАрендеДт КАК АвансыПоАренде,
	|	Таблица.НДСсПлатежей КАК НДСсПлатежей,
	|	Таблица.ДолгосрочноеОбязательство КАК ДолгосрочноеОбязательство,
	|	Таблица.КраткосрочноеОбязательство КАК КраткосрочноеОбязательство,
	|	Таблица.ЭтоАванс КАК ЭтоАванс
	|ПОМЕСТИТЬ АрендныеОбязательства
	|ИЗ
	|	&ТаблицаАрендныеОбязательства КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АрендныеОбязательства.Организация КАК Организация,
	|	АрендныеОбязательства.Контрагент КАК Контрагент,
	|	АрендныеОбязательства.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ ОбъектыАвансовАренды
	|ИЗ
	|	АрендныеОбязательства КАК АрендныеОбязательства
	|ГДЕ
	|	АрендныеОбязательства.НДСсПлатежей <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АрендныеОбязательства.Организация КАК Организация,
	|	АрендныеОбязательства.Счет КАК Счет,
	|	АрендныеОбязательства.Контрагент КАК Контрагент,
	|	АрендныеОбязательства.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаВозникновения,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашения,
	|	АрендныеОбязательства.АвансыПоАренде КАК АвансыПоАренде,
	|	АрендныеОбязательства.НДСсПлатежей КАК НДСсПлатежей
	|ПОМЕСТИТЬ АвансыАренды
	|ИЗ
	|	АрендныеОбязательства КАК АрендныеОбязательства
	|ГДЕ
	|	АрендныеОбязательства.ЭтоАванс
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	АрендныеОбязательства.Организация,
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.АрендныеПлатежи),
	|	АрендныеОбязательства.Контрагент,
	|	АрендныеОбязательства.ДоговорКонтрагента,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	0,
	|	АрендныеОбязательства.НДСсПлатежей
	|ИЗ
	|	АрендныеОбязательства КАК АрендныеОбязательства
	|ГДЕ
	|	НЕ АрендныеОбязательства.ЭтоАванс
	|	И АрендныеОбязательства.НДСсПлатежей <> 0";
	
	Запрос.УстановитьПараметр("ТаблицаАрендныеОбязательства", АрендныеОбязательства);
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьВременныеТаблицыАрендныеОбязательства(МенеджерВременныхТаблиц, АрендныеОбязательства, КонтекстОперации)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.Организация КАК Организация,
	|	Таблица.Счет КАК Счет,
	|	Таблица.Контрагент КАК Контрагент,
	|	Таблица.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Таблица.ДатаПогашения КАК ДатаПогашения,
	|	Таблица.ДолгосрочноеОбязательство КАК ДолгосрочноеОбязательство,
	|	Таблица.КраткосрочноеОбязательство КАК КраткосрочноеОбязательство
	|ПОМЕСТИТЬ ВТАрендныеОбязательства
	|ИЗ
	|	&ТаблицаАрендныеОбязательства КАК Таблица
	|ГДЕ
	|	НЕ Таблица.ЭтоАванс
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТАрендныеОбязательства.Организация КАК Организация,
	|	ВТАрендныеОбязательства.Счет КАК Счет,
	|	ВТАрендныеОбязательства.Контрагент КАК Контрагент,
	|	ВТАрендныеОбязательства.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаВозникновения,
	|	ВЫБОР
	|		КОГДА ВТАрендныеОбязательства.ДатаПогашения > &ДатаОкончанияКраткосрочногоПериода
	|			ТОГДА &ДатаОкончанияКраткосрочногоПериода
	|		ИНАЧЕ ВТАрендныеОбязательства.ДатаПогашения
	|	КОНЕЦ КАК ДатаПогашения,
	|	ВТАрендныеОбязательства.КраткосрочноеОбязательство КАК Обязательство
	|ПОМЕСТИТЬ АрендныеОбязательства
	|ИЗ
	|	ВТАрендныеОбязательства КАК ВТАрендныеОбязательства
	|ГДЕ
	|	ВТАрендныеОбязательства.КраткосрочноеОбязательство <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТАрендныеОбязательства.Организация,
	|	ВТАрендныеОбязательства.Счет,
	|	ВТАрендныеОбязательства.Контрагент,
	|	ВТАрендныеОбязательства.ДоговорКонтрагента,
	|	ДАТАВРЕМЯ(1, 1, 1),
	|	ВТАрендныеОбязательства.ДатаПогашения,
	|	ВТАрендныеОбязательства.ДолгосрочноеОбязательство
	|ИЗ
	|	ВТАрендныеОбязательства КАК ВТАрендныеОбязательства
	|ГДЕ
	|	ВТАрендныеОбязательства.ДолгосрочноеОбязательство <> 0";

	Запрос.УстановитьПараметр("ДатаОкончанияКраткосрочногоПериода", КонтекстОперации.ДатаОкончанияКраткосрочногоПериода);
	Запрос.УстановитьПараметр("ТаблицаАрендныеОбязательства", АрендныеОбязательства);
	
	Запрос.Выполнить();
	
