//   * СчетаРасчетов - Массив из ПланСчетовСсылка.Хозрасчетный
//   * СчетаРасчетовПоАренде - Массив из ПланСчетовСсылка.Хозрасчетный
//   * СчетаКредитовЗаймов - Массив из ПланСчетовСсылка.Хозрасчетный
//
Функция СчетаРасчетовКредиторскаяЗадолженность() Экспорт
	
	Счета = Новый Структура;

	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	ВидыСчетов.Добавить(ВидСчета.Пассивный);
	
	СчетаРасчетов = Новый Массив;
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПоставщикамиИПодрядчиками);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПокупателямиИЗаказчиками);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоНалогам);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоСоциальномуСтрахованию);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоОплатеТруда);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПодотчетнымиЛицами_);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоПрочимОперациям);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСУчредителями);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСРазнымиДебиторамиИКредиторами);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.ЦелевоеФинансирование);
	СчетаРасчетов.Добавить(ПланыСчетов.Хозрасчетный.ДоходыПолученныеВСчетБудущихПериодов);
	
	СчетаИсключения = Новый Массив;
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.РасчетНалогаНаПрибыль);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаИсключения, ПланыСчетов.Хозрасчетный.СчетаРасчетовПоАренде());
	СчетаИсключения.Добавить(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным);


	Счета.Вставить("СчетаРасчетов", СчетаВИерархии(СчетаРасчетов, ВидыСчетов, СчетаИсключения));
	Счета.Вставить("СчетаРасчетовПоАренде",   ПланыСчетов.Хозрасчетный.СчетаРасчетовПоАренде());
