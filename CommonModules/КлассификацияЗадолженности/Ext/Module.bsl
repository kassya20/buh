	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто2) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто3,
	|	СУММА(ХозрасчетныйОстатки.СуммаОстаток) КАК Сумма,
	|	ВЫБОР
	|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		КОГДА ХозрасчетныйОстатки.Субконто3 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РасходыБудущихПериодов.ПустаяСсылка)
	|	КОНЕЦ КАК СтатьяРБП
	|ПОМЕСТИТЬ ОстаткиРБП
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаУчетаРБП), , Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ХозрасчетныйОстатки.Организация,
	|	ХозрасчетныйОстатки.Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто1) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто2) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		КОГДА ХозрасчетныйОстатки.Субконто3 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РасходыБудущихПериодов.ПустаяСсылка)
	|	КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СтатьяРБП
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ХозрасчетныйОстатки.Счет КАК Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто1) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто2) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто3,
	|	СУММА(ХозрасчетныйОстатки.СуммаОстаток) КАК Сумма,
	|	ВЫБОР
	|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.НазначенияИспользованияНМА
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.НазначенияИспользованияНМА
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		КОГДА ХозрасчетныйОстатки.Субконто3 ССЫЛКА Справочник.НазначенияИспользованияНМА
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.НазначенияИспользованияНМА.ПустаяСсылка)
	|	КОНЕЦ КАК НазначениеИспользования
	|ПОМЕСТИТЬ ОстаткиНМА
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаУчетаНМА), , Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ХозрасчетныйОстатки.Организация,
	|	ХозрасчетныйОстатки.Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто1) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто2) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.НазначенияИспользованияНМА
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.НазначенияИспользованияНМА
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		КОГДА ХозрасчетныйОстатки.Субконто3 ССЫЛКА Справочник.НазначенияИспользованияНМА
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.НазначенияИспользованияНМА.ПустаяСсылка)
	|	КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	НазначениеИспользования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОстаткиРБП.Организация КАК Организация,
	|	ОстаткиРБП.Счет КАК Счет,
	|	ОстаткиРБП.Субконто1 КАК Субконто1,
	|	ОстаткиРБП.Субконто2 КАК Субконто2,
	|	ОстаткиРБП.Субконто3 КАК Субконто3,
	|	ОстаткиРБП.Сумма КАК Сумма,
	|	ОстаткиРБП.СтатьяРБП КАК СтатьяРБП,
	|	СтатьиРБП.СпособПризнанияРасходов КАК СпособПризнанияРасходов,
	|	СтатьиРБП.ДатаНачалаСписания КАК ДатаНачалаСписания,
	|	СтатьиРБП.ДатаОкончанияСписания КАК ДатаОкончанияСписания
	|ИЗ
	|	ОстаткиРБП КАК ОстаткиРБП
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РасходыБудущихПериодов КАК СтатьиРБП
	|		ПО ОстаткиРБП.СтатьяРБП = СтатьиРБП.Ссылка
	|ГДЕ
	|	СтатьиРБП.ВидРБП В(&ВидыРБП)
	|	И СтатьиРБП.ВидАктива = ЗНАЧЕНИЕ(Перечисление.ВидыАктивовДляРБП.ДебиторскаяЗадолженность)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОстаткиНМА.Организация,
	|	ОстаткиНМА.Счет,
	|	ОстаткиНМА.Субконто1,
	|	ОстаткиНМА.Субконто2,
	|	ОстаткиНМА.Субконто3,
	|	ОстаткиНМА.Сумма,
	|	ОстаткиНМА.НазначениеИспользования,
	|	ЗНАЧЕНИЕ(Перечисление.СпособыПризнанияРасходов.ПоКалендарнымДням),
	|	НазначенияИспользования.ДатаНачалаСписания,
	|	НазначенияИспользования.ДатаОкончанияСписания
	|ИЗ
	|	ОстаткиНМА КАК ОстаткиНМА
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.НазначенияИспользованияНМА КАК НазначенияИспользования
	|		ПО ОстаткиНМА.НазначениеИспользования = НазначенияИспользования.Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		
		СтрокаТаблицы = ТаблицаРБП.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Выборка);
		
		ДатаОчередногоСписания = КонтекстОперации.ДатаНачалаКраткосрочногоПериода;
		Если КонтекстОперации.ДатаНачалаКраткосрочногоПериода < Выборка.ДатаНачалаСписания Тогда
			ДатаОчередногоСписания = Выборка.ДатаНачалаСписания;
		КонецЕсли;
		
		Если Выборка.СпособПризнанияРасходов = Перечисления.СпособыПризнанияРасходов.ПоКалендарнымДням
			Или Выборка.СпособПризнанияРасходов = Перечисления.СпособыПризнанияРасходов.ПоМесяцам Тогда
			ДоляДолгосрочногоПериода = ДоляВОстаткеАктива(
					Выборка.Сумма,
					Выборка.СпособПризнанияРасходов,
					КонтекстОперации.ДатаНачалаДолгосрочногоПериода,
					ДатаОчередногоСписания,
					Выборка.ДатаОкончанияСписания);
					
			СтрокаТаблицы.КоличествоМесяцевДней = Окр(ДоляДолгосрочногоПериода.Знаменатель, 5);
			СтрокаТаблицы.КоличествоМесяцевДнейДолгосрочногоПериода = Окр(ДоляДолгосрочногоПериода.Числитель, 5);
			СтрокаТаблицы.СуммаДолгосрочная = ДоляДолгосрочногоПериода.Сумма;
			СтрокаТаблицы.СуммаКраткосрочная = Выборка.Сумма - ДоляДолгосрочногоПериода.Сумма;
		Иначе
			Если Выборка.ДатаОкончанияСписания >= КонтекстОперации.ДатаНачалаДолгосрочногоПериода Тогда
				СтрокаТаблицы.СуммаДолгосрочная = Выборка.Сумма;
			Иначе
				СтрокаТаблицы.СуммаКраткосрочная = Выборка.Сумма;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаРБП;

КонецФункции

Функция НовыйТаблицаРасходыБудущихПериодов()
	
	КвалификаторыДаты = Новый КвалификаторыДаты(ЧастиДаты.Дата);
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	Таблица.Колонки.Добавить("Счет", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	Таблица.Колонки.Добавить("Субконто1");
	Таблица.Колонки.Добавить("Субконто2");
	Таблица.Колонки.Добавить("Субконто3");
	Таблица.Колонки.Добавить("ДатаНачалаСписания", Новый ОписаниеТипов("Дата",,,КвалификаторыДаты));
	Таблица.Колонки.Добавить("ДатаОкончанияСписания", Новый ОписаниеТипов("Дата",,,КвалификаторыДаты));
