Функция НовыйРасчетЗадолженности()
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	Таблица.Колонки.Добавить("Счет", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	Таблица.Колонки.Добавить("Субконто1");
	Таблица.Колонки.Добавить("Субконто2");
	Таблица.Колонки.Добавить("Субконто3");
	Таблица.Колонки.Добавить("ВидЗадолженности", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыЗадолженности"));
	Таблица.Колонки.Добавить("ДатаВозникновения", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	Таблица.Колонки.Добавить("ДатаПогашения", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
