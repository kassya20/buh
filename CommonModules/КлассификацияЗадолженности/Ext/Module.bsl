/////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// КлассификацияЗадолженности: По дебиторской и кредиторской задолженности рассчитываются остатки с учетом сроков.
// Результаты расчётов фиксируются в регистрах классификации по срокам.
//
#Область ПрограммныйИнтерфейс

// Возвращает рассчитанные данные задолженности по срокам
//
// Параметры:
//  КонтекстОперации - Структура:
//   * Организации - Массив из СправочникСсылка.Организации
//   * НачалоПериода - Дата
//   * КонецПериода - Граница
//   * КонецПериодаДата - Дата
//   * ДатаНачалаКраткосрочногоПериода - Дата
//   * ДатаОкончанияКраткосрочногоПериода - Дата
//   * ДатаНачалаДолгосрочногоПериода - Дата
//
// Возвращаемое значение:
//  см. НовыйДанныеЗадолженности
//
Функция ДанныеЗадолженностиПоСрокам(КонтекстОперации) Экспорт
	
	РасчетныеДанные = Новый Структура;
	КонтекстРасчетаОбязательств = КонтекстРасчетаДисконтированногоОбязательства(КонтекстОперации);
	РасчетныеДанные.Вставить("РасчетыПоАренде",    РасчетПоказателейБалансаПоОбязательствам.ИсходныеДанныеПоАренднымОбязательствам(КонтекстРасчетаОбязательств));
	РасчетныеДанные.Вставить("РасчетыПоРассрочке", РасчетПоказателейБалансаПоОбязательствам.ИсходныеДанныеЗадолженностиСРассрочкой(КонтекстРасчетаОбязательств));
	
	ДанныеЗадолженности = НовыйДанныеЗадолженности();
	ДанныеЗадолженности.РасходыБудущихПериодов            = РасходыБудущихПериодовПоСрокам(КонтекстОперации);
	ДанныеЗадолженности.ДебиторскаяЗадолженностьПоСрокам  = ДебиторскаяЗадолженностьПоСрокам(КонтекстОперации, РасчетныеДанные);
	ДанныеЗадолженности.КредиторскаяЗадолженностьПоСрокам = КредиторскаяЗадолженностьПоСрокам(КонтекстОперации, РасчетныеДанные);
	
	Возврат ДанныеЗадолженности;
	
КонецФункции

// Конструктор параметра "ПараметрыСвязиВременнойТаблицыРасчеты" функции "ДополнитьЗапросДаннымиПоСрокамОплаты"
// Содержит имя временной таблицы и ключевые поля, которые используются для соединения с другой таблицей
//
// Возвращаемое значение:
//  Структура
//   * ИмяТаблицы - Строка - имя временной таблицы
//   * ИмяПоляСчет - Строка
//   * ИмяПоляОрганизация - Строка
//   * ИмяПоляДоговор - Строка
//   * ИмяПоляДокумент - Строка
//
Функция НовыйПараметрыСвязиВременнойТаблицыРасчеты() Экспорт
	
	ПараметрыСвязи = Новый Структура;
	ПараметрыСвязи.Вставить("ИмяТаблицы",         "");
	ПараметрыСвязи.Вставить("ИмяПоляСчет",        "");
	ПараметрыСвязи.Вставить("ИмяПоляОрганизация", "");
	ПараметрыСвязи.Вставить("ИмяПоляДоговор",     "");
	ПараметрыСвязи.Вставить("ИмяПоляДокумент",    "");
	
	Возврат ПараметрыСвязи;
	
КонецФункции

// Конструктор коллекции, описывающий контекст запроса
//
// Возвращаемое значение:
//  Структура:
//   * ПараметрыЗапроса - Структура
//   * ОпределитьСроки - Булево
//   * ВременныеТаблицы - Массив из Строка - имена временных таблиц
//
Функция НовыйКонтекстЗапросаОстаткиЗадолженности() Экспорт
	
	Контекст = Новый Структура;
	Контекст.Вставить("ПараметрыЗапроса", Новый Структура); // набираются параметры запроса
	Контекст.Вставить("ОпределитьСроки",  Ложь);
	Контекст.Вставить("ВременныеТаблицы", Новый Массив);
	Возврат Контекст;
	
КонецФункции

// Дополняет текст запроса сведениями о сроках оплаты
//
// Параметры:
//  ТекстЗапроса - Строка - текст запроса
//  ПараметрыСвязи - см.НовыйПараметрыСвязиВременнойТаблицыРасчеты - указаны имя временной таблицы и поля соединения
//  ПараметрыЗапроса - см. ПараметрыЗапроса из НовыйКонтекстЗапросаОстаткиЗадолженности
//
Процедура ДополнитьЗапросДаннымиПоСрокамОплаты(ТекстЗапроса, ПараметрыСвязи, ПараметрыЗапроса) Экспорт
	
	СхемаЗапроса = Новый СхемаЗапроса;

	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	ОписаниеЗапроса = СхемаЗапроса.ПакетЗапросов[0];
	Оператор = ОписаниеЗапроса.Операторы[0];
	
	ИсточникРасчеты = Оператор.Источники[0];
	
	ИсточникДанныеПервичныхДокументов = Оператор.Источники.Добавить("РегистрСведений.ДанныеПервичныхДокументов", "ДанныеПервичныхДокументов");
	УсловиеДанныеПервичныхДокументов = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(
	                                   "[ИмяТаблицы].[ИмяПоляОрганизация] = ДанныеПервичныхДокументов.Организация И [ИмяТаблицы].[ИмяПоляДокумент] = ДанныеПервичныхДокументов.Документ",
	                                   ПараметрыСвязи);
	ИсточникРасчеты.Соединения.Добавить(ИсточникДанныеПервичныхДокументов, УсловиеДанныеПервичныхДокументов);
	
	ИсточникДоговоры = Оператор.Источники.Добавить("Справочник.ДоговорыКонтрагентов", "ДоговорыКонтрагентов");
	УсловиеДоговоры = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(
	                                   "[ИмяТаблицы].[ИмяПоляДоговор] = ДоговорыКонтрагентов.Ссылка",
	                                   ПараметрыСвязи);
	ИсточникРасчеты.Соединения.Добавить(ИсточникДоговоры,УсловиеДоговоры);
	
	ИсточникСрокиОплатыДокументов = Оператор.Источники.Добавить("РегистрСведений.СрокиОплатыДокументов", "СрокиОплатыДокументов");
	УсловиеСрокиОплатыДокументов = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(
	                                   "[ИмяТаблицы].[ИмяПоляОрганизация] = СрокиОплатыДокументов.Организация И [ИмяТаблицы].[ИмяПоляДокумент] = СрокиОплатыДокументов.Документ",
	                                   ПараметрыСвязи);
	ИсточникРасчеты.Соединения.Добавить(ИсточникСрокиОплатыДокументов,УсловиеСрокиОплатыДокументов);
	
	ДобавитьПолеЗапроса(ОписаниеЗапроса,
	                    Оператор,
	                    "ДатаРегистратора",
	                    "ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1))");
	
	ДобавитьПолеЗапроса(ОписаниеЗапроса,
	                    Оператор,
	                    "ЕстьДокументРасчетов",
	                    "НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL");
	
	ДобавитьПолеЗапроса(ОписаниеЗапроса,
	                    Оператор,
	                    "СрокОплаты",
	                    "ВЫБОР
	                    |	КОГДА (ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПоставщиков)
	                    |				И &ИспользуютсяСрокиОплатыПоставщикам
	                    |			ИЛИ ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПокупателей)
	                    |				И &ИспользуютсяСрокиОплатыПокупателей)
	                    |			И СрокиОплатыДокументов.СрокОплаты <> ДАТАВРЕМЯ(1, 1, 1)
	                    |		ТОГДА СрокиОплатыДокументов.СрокОплаты
	                    |	КОГДА ДоговорыКонтрагентов.УстановленСрокОплаты
	                    |			И ДоговорыКонтрагентов.ДатаОплаты <> ДАТАВРЕМЯ(1, 1, 1)
	                    |		ТОГДА ДоговорыКонтрагентов.ДатаОплаты
	                    |	КОГДА НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL
	                    |			И ВЫБОР
	                    |				КОГДА ДоговорыКонтрагентов.УстановленСрокОплаты
	                    |					ТОГДА ДоговорыКонтрагентов.СрокОплаты
	                    |				КОГДА ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПокупателей)
	                    |					ТОГДА &СрокОплатыПокупателей
	                    |				КОГДА ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПоставщиков)
	                    |					ТОГДА &СрокОплатыПоставщикам
	                    |				ИНАЧЕ 0
	                    |			КОНЕЦ <> 0
	                    |		ТОГДА ДОБАВИТЬКДАТЕ(ДанныеПервичныхДокументов.ДатаРегистратора, ДЕНЬ, ВЫБОР
	                    |					КОГДА ДоговорыКонтрагентов.УстановленСрокОплаты
	                    |						ТОГДА ДоговорыКонтрагентов.СрокОплаты
	                    |					КОГДА ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПокупателей)
	                    |						ТОГДА &СрокОплатыПокупателей
	                    |					КОГДА ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПоставщиков)
	                    |						ТОГДА &СрокОплатыПоставщикам
	                    |					ИНАЧЕ 0
	                    |				КОНЕЦ)
	                    |	ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	                    |КОНЕЦ");

	ДобавитьПолеЗапроса(ОписаниеЗапроса,
	                    Оператор,
	                    "ИсточникСрокаОплаты",
	                    "ВЫБОР
	                    |	КОГДА (ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПоставщиков)
	                    |				И &ИспользуютсяСрокиОплатыПоставщикам
	                    |			ИЛИ ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПокупателей)
	                    |				И &ИспользуютсяСрокиОплатыПокупателей)
	                    |			И СрокиОплатыДокументов.СрокОплаты <> ДАТАВРЕМЯ(1, 1, 1)
	                    |		ТОГДА СрокиОплатыДокументов.Документ
	                    |	КОГДА ДоговорыКонтрагентов.УстановленСрокОплаты
	                    |			И ДоговорыКонтрагентов.ДатаОплаты <> ДАТАВРЕМЯ(1, 1, 1)
	                    |		ТОГДА ДоговорыКонтрагентов.Ссылка
	                    |	КОГДА НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL
	                    |			И ВЫБОР
	                    |				КОГДА ДоговорыКонтрагентов.УстановленСрокОплаты
	                    |					ТОГДА ДоговорыКонтрагентов.СрокОплаты
	                    |				ИНАЧЕ 0
	                    |			КОНЕЦ <> 0
	                    |		ТОГДА ДоговорыКонтрагентов.Ссылка
	                    |	КОГДА НЕ ДанныеПервичныхДокументов.ДатаРегистратора ЕСТЬ NULL
	                    |			И ВЫБОР
	                    |				КОГДА ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПокупателей)
	                    |					ТОГДА &СрокОплатыПокупателей
	                    |				КОГДА ДоговорыКонтрагентов.ВидДоговора В (&ВидыДоговоровПоставщиков)
	                    |					ТОГДА &СрокОплатыПоставщикам
	                    |				ИНАЧЕ 0
	                    |			КОНЕЦ <> 0
	                    |		ТОГДА ""Настройка сроков оплаты""
	                    |	ИНАЧЕ НЕОПРЕДЕЛЕНО
	                    |КОНЕЦ");
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();

	ПараметрыЗапроса.Вставить("ИспользуютсяСрокиОплатыПокупателей", ПолучитьФункциональнуюОпцию("ИспользоватьПланированиеПлатежейОтПокупателей"));
	ПараметрыЗапроса.Вставить("ВидыДоговоровПокупателей",  БухгалтерскиеОтчеты.ВидыДоговоровПокупателей());
	ПараметрыЗапроса.Вставить("СрокОплатыПокупателей", Константы.СрокОплатыПокупателей.Получить());
	ПараметрыЗапроса.Вставить("ИспользуютсяСрокиОплатыПоставщикам", ПолучитьФункциональнуюОпцию("ИспользоватьПланированиеПлатежейПоставщикам"));
	ПараметрыЗапроса.Вставить("ВидыДоговоровПоставщиков", БухгалтерскиеОтчеты.ВидыДоговоровПоставщиков());
	ПараметрыЗапроса.Вставить("СрокОплатыПоставщикам", Константы.СрокОплатыПоставщикам.Получить());
	
КонецПроцедуры

// Устанавливает последовательность полей в запросе
//
// Возвращаемое значение:
//  Строка
//
Функция ШаблонТекстаЗапросаРасчеты() Экспорт
	
	Возврат
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка) КАК Организация,
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПустаяСсылка) КАК Счет,
	|	НЕОПРЕДЕЛЕНО КАК Субконто1,
	|	НЕОПРЕДЕЛЕНО КАК Субконто2,
	|	НЕОПРЕДЕЛЕНО КАК Субконто3,
	|	0 КАК ОстатокБУ,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаРегистратора,
	|	ЛОЖЬ КАК ЕстьДокументРасчетов,
	|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПогашенияБУ,
	|	НЕОПРЕДЕЛЕНО КАК ИсточникСрокаПогашения
	|ПОМЕСТИТЬ ИмяТаблицыРасчеты
	|ГДЕ
	|	ЛОЖЬ";
	
КонецФункции

// Определяет наборы параметров счетов, которые участвуют в динамическом формировании запроса, используемый для классификации задолженности
//
// Параметры:
//  ВидЗадолженности - ПеречислениеСсылка.ВидыЗадолженности
//  СписокВидовСубконто - см.СписокВидовСубконто
//
// Возвращаемое значение:
//  см. НовыйНаборыСчетов
//
Функция НаборыСчетовКлассификацииЗадолженности(ВидЗадолженности, СписокВидовСубконто) Экспорт
	
	НаборыСчетов = НовыйНаборыСчетов();
	
	СчетаНалогов = СчетаНалогов();
	СчетаСоциальногоСтрахования = СчетаСоциальногоСтрахования();
	
	ВидСчетаЗадолженности = ВидСчета.Активный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ВидСчетаЗадолженности = ВидСчета.Пассивный;
	КонецЕсли;

	ИмяВТ = "РасчетыСКонтрагентамиПоДоговорам";
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаКонтрагентыДоговорыДокументы", СписокВидовСубконто, "СубконтоКонтрагентыДоговорыДокументы");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаКонтрагентыДоговоры", СписокВидовСубконто, "СубконтоКонтрагентыДоговоры");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		СтрокаНабора.СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ВекселяПолученные); // 62.03
	КонецЕсли;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		СтрокаНабора.СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ВекселяВыданные); // 60.03
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаКонтрагентыДоговоры", СписокВидовСубконто, "СубконтоКонтрагентыДоговоры");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыНДСНалоговогоАгента)); // 76.НА
	КонецЕсли;
	
	ИмяВТ = "АПРасчетыПоДокументамРасчетов";
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаКонтрагентыДоговорыДокументы", СписокВидовСубконто, "СубконтоКонтрагентыДоговорыДокументы");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;

	ИмяВТ = "РасчетыПрочие";
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаКонтрагенты", СписокВидовСубконто, "СубконтоКонтрагенты");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаКонтрагентыЦенныеБумаги", СписокВидовСубконто, "СубконтоКонтрагентыЦенныеБумаги");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаКонтрагентыДоговорыЦенныеБумаги", СписокВидовСубконто, "СубконтоКонтрагентыДоговорыЦенныеБумаги");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаКонтрагенты", СписокВидовСубконто, "СубконтоКонтрагенты");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаУчредители", СписокВидовСубконто, "СубконтоУчредители");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаРаботники", СписокВидовСубконто, "СубконтоРаботники");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаРаботники", СписокВидовСубконто, "СубконтоРаботники");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаБезУчетаАналитики", СписокВидовСубконто);
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаБезДетализации); // 68 пассивный
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаБезУчетаАналитики", СписокВидовСубконто);
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ЗаполнениеБухгалтерскойОтчетности.УчетНа70ВедетсяСводно() Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоОплатеТруда)); // 70
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаАПБезДетализации); // 68 без учета субконто
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаСоциальногоСтрахования.СчетаАПБезДетализации); // 69 без учета субконто
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаСвернутоеСальдо", СписокВидовСубконто);
	СтрокаНабора.ДополнитьСчетами = Ложь;
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоИсполнительнымДокументамРаботников)); // 76.41
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаВидыПлатежей", СписокВидовСубконто, "СубконтоВидыПлатежей");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	СтрокаНабора.ДополнитьСчетами = Ложь;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаПоВидамПлатежей); // 68 по видам платежей
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаСоциальногоСтрахования.СчетаПоВидамПлатежей); // 69 по видам платежей
	
	Возврат НаборыСчетов;
	
КонецФункции

// Определяет наборы параметров счетов, которые участвуют в динамическом формировании запроса, используемый для расшифровки классификации задолженности.
// Счет может быть отнесен только к одному набору. В случае, если счет соответствует критериям нескольких наборов, ему присваивается тот, который содержит наибольшее количество субконто.
//
// Параметры:
//  ВидЗадолженности - ПеречислениеСсылка.ВидыЗадолженности
//  СписокВидовСубконто - см.СписокВидовСубконто
//  УчитыватьДокументыРасчетов - Булево - Истина, когда необходимо рассчитать остатки с детализацией до документов расчетов
//
// Возвращаемое значение:
//  см. НовыйНаборыСчетов
//
Функция НаборыСчетовРазвернуто(ВидЗадолженности, СписокВидовСубконто, УчитыватьДокументыРасчетов = Ложь) Экспорт
	
	НаборыСчетов = НовыйНаборыСчетов();
	
	СчетаНалогов = СчетаНалогов();
	СчетаСоциальногоСтрахования = СчетаСоциальногоСтрахования();
	
	Префикс = "";
	ВидСчетаЗадолженности = ВидСчета.Активный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		Префикс = "ДЗ";
		ВидСчетаЗадолженности = ВидСчета.Активный;
	ИначеЕсли ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		Префикс = "КЗ";
		ВидСчетаЗадолженности = ВидСчета.Пассивный;
	КонецЕсли;
	
	ИмяВТ = "РасчетыСКонтрагентамиПоДоговорам";
	Если УчитыватьДокументыРасчетов Тогда
		СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаКонтрагентыДоговорыДокументы%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагентыДоговорыДокументы");
		СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаКонтрагентыДоговоры%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагентыДоговоры");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		СтрокаНабора.СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ВекселяПолученные); // 62.03
	КонецЕсли;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		СтрокаНабора.СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.ВекселяВыданные); // 60.03
	КонецЕсли;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("АПСчетаКонтрагентыДоговоры%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагентыДоговоры");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыНДСНалоговогоАгента)); // 76.НА
	КонецЕсли;
	
	// Авансы выданные
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		ИмяВТ = "Авансы";
		СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаКонтрагентыДоговорыДокументыПоВидамАктива%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагентыДоговорыДокументы");
		СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
		СтрокаНабора.ДополнитьСчетами = Ложь;
		СтрокаНабора.ВидСчета = ВидСчета.Активный;
		СтрокаНабора.СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданным); // 60.02
		СтрокаНабора.СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданнымВал); // 60.22
		СтрокаНабора.СписокСчетов.Добавить(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданнымУЕ);    // 60.32
	КонецЕсли;
	
	ИмяВТ = "РасчетыПрочие";
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаКонтрагенты%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагенты");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаКонтрагентыЦенныеБумаги%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагентыЦенныеБумаги");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ,  СтрШаблон("СчетаКонтрагентыДоговорыЦенныеБумаги%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагентыДоговорыЦенныеБумаги");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("АПСчетаКонтрагенты%1", Префикс), СписокВидовСубконто, "СубконтоКонтрагенты");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаУчредители%1", Префикс), СписокВидовСубконто, "СубконтоУчредители");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаРаботники%1", Префикс), СписокВидовСубконто, "СубконтоРаботники");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("АПСчетаРаботники%1", Префикс), СписокВидовСубконто, "СубконтоРаботники");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаНазначениеЦСДоговоры%1", Префикс), СписокВидовСубконто, "СубконтоНазначениеЦСДоговоры");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаДоходыБПКонтрагентыДоговоры%1", Префикс), СписокВидовСубконто, "СубконтоДоходыБПКонтрагентыДоговоры");
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("СчетаБезУчетаАналитики%1", Префикс), СписокВидовСубконто);
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаБезДетализации); // 68 пассивный
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("АПСчетаБезУчетаАналитики%1", Префикс), СписокВидовСубконто);
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ЗаполнениеБухгалтерскойОтчетности.УчетНа70ВедетсяСводно() Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоОплатеТруда)); // 70
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаАПБезДетализации); // 68 без учета субконто
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаСоциальногоСтрахования.СчетаАПБезДетализации); // 69 без учета субконто
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("АПСчетаСвернутоеСальдо%1", Префикс), СписокВидовСубконто);
	СтрокаНабора.ДополнитьСчетами = Ложь;
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоИсполнительнымДокументамРаботников)); // 76.41
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, СтрШаблон("АПСчетаВидыПлатежей%1", Префикс), СписокВидовСубконто, "СубконтоВидыПлатежей");
	СтрокаНабора.ДополнитьСчетами = Ложь;
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаПоВидамПлатежей); // 68 по видам платежей
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаСоциальногоСтрахования.СчетаПоВидамПлатежей); // 69 по видам платежей
	
	Возврат НаборыСчетов;
КонецФункции

// Определяет наборы параметров счетов, которые участвуют в динамическом формировании запроса, используемый для заполнения баланса.
// Счет может быть отнесен только к одному набору. В случае, если счет соответствует критериям нескольких наборов, ему присваивается тот, который содержит наибольшее количество субконто.
//
// Параметры:
//  ВидЗадолженности - ПеречислениеСсылка.ВидыЗадолженности
//  СписокВидовСубконто - см.СписокВидовСубконто
//
// Возвращаемое значение:
//  см. НовыйНаборыСчетов
//
Функция НаборыСчетовБаланса(ВидЗадолженности, СписокВидовСубконто) Экспорт
	
	НаборыСчетов = НовыйНаборыСчетов();
	
	СчетаНалогов = СчетаНалогов();
	СчетаСоциальногоСтрахования = СчетаСоциальногоСтрахования();
	
	ВидСчетаЗадолженности = ВидСчета.Активный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		ВидСчетаЗадолженности = ВидСчета.Активный;
	ИначеЕсли ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ВидСчетаЗадолженности = ВидСчета.Пассивный;
	КонецЕсли;
	
	ИмяВТ = "Расчеты";

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаКонтрагентыДоговоры", СписокВидовСубконто, "СубконтоКонтрагентыДоговоры");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыНДСНалоговогоАгента)); // 76.НА
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ,"АПСчетаКонтрагенты", СписокВидовСубконто, "СубконтоКонтрагенты");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаРаботники", СписокВидовСубконто, "СубконтоРаботники");
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;

	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаБезУчетаАналитики", СписокВидовСубконто);
	СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаБезДетализации); // 68 пассивный
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаБезУчетаАналитики", СписокВидовСубконто);
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ЗаполнениеБухгалтерскойОтчетности.УчетНа70ВедетсяСводно() Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоОплатеТруда)); // 70
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаАПБезДетализации); // 68 без учета субконто
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаСоциальногоСтрахования.СчетаАПБезДетализации); // 69 без учета субконто
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаСвернутоеСальдо", СписокВидовСубконто);
	СтрокаНабора.ДополнитьСчетами = Ложь;
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоИсполнительнымДокументамРаботников)); // 76.41
	КонецЕсли;
	
	СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "АПСчетаВидыПлатежей", СписокВидовСубконто, "СубконтоВидыПлатежей");
	СтрокаНабора.ДополнитьСчетами = Ложь;
	СтрокаНабора.ВидСчета = ВидСчета.АктивноПассивный;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаНалогов.СчетаПоВидамПлатежей); // 68 по видам платежей
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, СчетаСоциальногоСтрахования.СчетаПоВидамПлатежей); // 69 по видам платежей

	// Авансы выданные
	Если ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская Тогда
		ИмяВТ = "Авансы";
		СтрокаНабора = ДобавитьСтрокуНабораСчетов(НаборыСчетов, ИмяВТ, "СчетаКонтрагентыДоговорыПоВидамАктива", СписокВидовСубконто, "СубконтоКонтрагентыДоговоры");
		СтрокаНабора.ВидСчета = ВидСчетаЗадолженности;
		СтрокаНабора.ДополнитьСчетами = Ложь;
		СтрокаНабора.ВидСчета = ВидСчета.Активный;
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданным)); // 60.02
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданнымВал)); // 60.22
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокаНабора.СписокСчетов, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоАвансамВыданнымУЕ));    // 60.32
	КонецЕсли;

	Возврат НаборыСчетов;
КонецФункции

// Заполняет наборы счетами и формирует таблицу счетов
//
// Параметры:
//  НаборыСчетов - см. НовыйНаборыСчетов
//  СписокСчетов - Массив из ПланСчетовСсылка.Хозрасчетный
//  ТаблицаСчетов - см.НовыйТаблицаСчетов
//  ИсключитьВалютные -Булево
//  УчитыватьПорядокСубконто -Булево
//
Процедура ЗаполнитьНаборыСчетами(НаборыСчетов, СписокСчетов, ТаблицаСчетов = Неопределено, ИсключитьВалютные = Ложь, УчитыватьПорядокСубконто = Ложь) Экспорт
	
	ИспользуетсяВалютныйУчет = БухгалтерскийУчетПереопределяемый.ИспользоватьВалютныйУчет();
	
	СчетаСУказаннымНабором = Новый ТаблицаЗначений;
	СчетаСУказаннымНабором.Колонки.Добавить("ИмяНабора", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	СчетаСУказаннымНабором.Колонки.Добавить("Счет", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	
	// Список счетов из таблицы НаборыСчетов перенесем в таблицу СчетаСУказаннымНабором,
	// из набора очистим список счетов.
	// Это необходимо, чтобы в наборе были только те счета, которые необходимы для дальнейшей обработки.
	// Например, если счет 70 не указан в детализации инвентаризации расчетов 
	// и для него нет необходимости получать дату возникновения, тогда его совсем не обрабатываем
	Для Каждого Набор Из НаборыСчетов Цикл
		Для Каждого Счет Из Набор.СписокСчетов Цикл
			СтрокаТаблицы = СчетаСУказаннымНабором.Добавить();
			СтрокаТаблицы.ИмяНабора = Набор.ИмяНабора;
			СтрокаТаблицы.Счет = Счет;
		КонецЦикла;
		Набор.СписокСчетов.Очистить();
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТаблицаНаборыСчетов", НаборыСчетов);
	Запрос.УстановитьПараметр("СчетаСУказаннымНабором", СчетаСУказаннымНабором);
	Запрос.УстановитьПараметр("СписокСчетов", СписокСчетов);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТаблицаНаборыСчетов.ВидСчета КАК ВидСчета,
	|	ТаблицаНаборыСчетов.ИмяНабора КАК ИмяНабора,
	|	ТаблицаНаборыСчетов.ВидСубконто1 КАК ВидСубконто1,
	|	ТаблицаНаборыСчетов.ВидСубконто2 КАК ВидСубконто2,
	|	ТаблицаНаборыСчетов.ВидСубконто3 КАК ВидСубконто3,
	|	ТаблицаНаборыСчетов.КоличествоСубконто КАК КоличествоСубконто,
	|	ТаблицаНаборыСчетов.ДополнитьСчетами КАК ДополнитьСчетами
	|ПОМЕСТИТЬ НаборыСчетов
	|ИЗ
	|	&ТаблицаНаборыСчетов КАК ТаблицаНаборыСчетов
	|ГДЕ
	|	ТаблицаНаборыСчетов.ДополнитьСчетами
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидСчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетаСУказаннымНабором.ИмяНабора КАК ИмяНабора,
	|	СчетаСУказаннымНабором.Счет КАК Счет
	|ПОМЕСТИТЬ ПрисвоенныеКНаборам
	|ИЗ
	|	&СчетаСУказаннымНабором КАК СчетаСУказаннымНабором
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПланСчетовХозрасчетный.Ссылка КАК Счет,
	|	ПланСчетовХозрасчетный.Код КАК Код,
	|	ПланСчетовХозрасчетный.Вид КАК ВидСчета,
	|	ПланСчетовХозрасчетный.Порядок КАК Порядок,
	|	ПланСчетовХозрасчетный.Валютный КАК Валютный
	|ПОМЕСТИТЬ Счета
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК ПланСчетовХозрасчетный
	|ГДЕ
	|	ПланСчетовХозрасчетный.Ссылка В(&СписокСчетов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПланСчетовХозрасчетный.Ссылка,
	|	ПланСчетовХозрасчетный.Вид,
	|	ПланСчетовХозрасчетный.Код,
	|	ПланСчетовХозрасчетный.Порядок,
	|	ПланСчетовХозрасчетный.Валютный
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Счета.Счет КАК Счет,
	|	Счета.ВидСчета КАК ВидСчета,
	|	ХозрасчетныйВидыСубконто.ВидСубконто КАК ВидСубконто,
	|	ХозрасчетныйВидыСубконто.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ СчетаСубконто
	|ИЗ
	|	Счета КАК Счета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто
	|		ПО Счета.Счет = ХозрасчетныйВидыСубконто.Ссылка
	|ГДЕ
	|	НЕ ХозрасчетныйВидыСубконто.ТолькоОбороты
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВидСчета,
	|	ВидСубконто
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СчетаСубконто.Счет КАК Счет
	|ПОМЕСТИТЬ СчетаЕстьВидыСубконто
	|ИЗ
	|	СчетаСубконто КАК СчетаСубконто
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НаборыСчетов.ИмяНабора КАК ИмяНабора,
	|	СчетаСубконто.Счет КАК Счет,
	|	СУММА(1) КАК КоличествоСовпадающихСубконто
	|ПОМЕСТИТЬ СчетаВсеНаборы
	|ИЗ
	|	СчетаСубконто КАК СчетаСубконто
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НаборыСчетов КАК НаборыСчетов
	|		ПО СчетаСубконто.ВидСчета = НаборыСчетов.ВидСчета
	|			И (СчетаСубконто.ВидСубконто = НаборыСчетов.ВидСубконто1
	|					И &УчитыватьПорядок1
	|				ИЛИ СчетаСубконто.ВидСубконто = НаборыСчетов.ВидСубконто2
	|					И &УчитыватьПорядок2
	|				ИЛИ СчетаСубконто.ВидСубконто = НаборыСчетов.ВидСубконто3
	|					И &УчитыватьПорядок3)
	|
	|СГРУППИРОВАТЬ ПО
	|	НаборыСчетов.ИмяНабора,
	|	СчетаСубконто.Счет
	|
	|ИМЕЮЩИЕ
	|	СУММА(1) = МАКСИМУМ(НаборыСчетов.КоличествоСубконто)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетаВсеНаборы.Счет КАК Счет,
	|	СчетаВсеНаборы.КоличествоСовпадающихСубконто КАК КоличествоСовпадающихСубконто,
	|	МАКСИМУМ(СчетаВсеНаборы.ИмяНабора) КАК ИмяНабора
	|ПОМЕСТИТЬ СчетаНаборы
	|ИЗ
	|	СчетаВсеНаборы КАК СчетаВсеНаборы
	|
	|СГРУППИРОВАТЬ ПО
	|	СчетаВсеНаборы.Счет,
	|	СчетаВсеНаборы.КоличествоСовпадающихСубконто
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетаНаборы.Счет КАК Счет,
	|	МАКСИМУМ(СчетаНаборы.КоличествоСовпадающихСубконто) КАК КоличествоСубконто
	|ПОМЕСТИТЬ МаксимальноеКоличествоСубконто
	|ИЗ
	|	СчетаНаборы КАК СчетаНаборы
	|
	|СГРУППИРОВАТЬ ПО
	|	СчетаНаборы.Счет
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СчетаНаборы.ИмяНабора КАК ИмяНабора,
	|	СчетаНаборы.Счет КАК Счет,
	|	ИСТИНА КАК СчетСДетализацией
	|ПОМЕСТИТЬ НайденныеНаборы
	|ИЗ
	|	СчетаНаборы КАК СчетаНаборы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МаксимальноеКоличествоСубконто КАК МаксимальноеКоличествоСубконто
	|		ПО СчетаНаборы.Счет = МаксимальноеКоличествоСубконто.Счет
	|			И СчетаНаборы.КоличествоСовпадающихСубконто = МаксимальноеКоличествоСубконто.КоличествоСубконто
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	НаборыСчетов.ИмяНабора,
	|	Счета.Счет,
	|	СчетаЕстьВидыСубконто.Счет ЕСТЬ NULL
	|ИЗ
	|	Счета КАК Счета
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НаборыСчетов КАК НаборыСчетов
	|		ПО Счета.ВидСчета = НаборыСчетов.ВидСчета
	|			И (НаборыСчетов.КоличествоСубконто = 0)
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаНаборы КАК СчетаНаборы
	|		ПО Счета.Счет = СчетаНаборы.Счет
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаЕстьВидыСубконто КАК СчетаЕстьВидыСубконто
	|		ПО Счета.Счет = СчетаЕстьВидыСубконто.Счет
	|ГДЕ
	|	СчетаНаборы.Счет ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ ПрисвоенныеКНаборам.Счет ЕСТЬ NULL
	|			ТОГДА ПрисвоенныеКНаборам.ИмяНабора
	|		ИНАЧЕ НайденныеНаборы.ИмяНабора
	|	КОНЕЦ КАК ИмяНабора,
	|	НЕ НайденныеНаборы.СчетСДетализацией
	|		И ПрисвоенныеКНаборам.Счет ЕСТЬ NULL КАК ИсключитьИзНабора,
	|	НайденныеНаборы.Счет КАК Счет,
	|	Счета.Код КАК Код,
	|	Счета.Порядок КАК Порядок,
	|	Счета.Валютный КАК Валютный
	|ИЗ
	|	НайденныеНаборы КАК НайденныеНаборы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПрисвоенныеКНаборам КАК ПрисвоенныеКНаборам
	|		ПО НайденныеНаборы.Счет = ПрисвоенныеКНаборам.Счет
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Счета КАК Счета
	|		ПО НайденныеНаборы.Счет = Счета.Счет
	|ИТОГИ ПО
	|	ИмяНабора
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ НаборыСчетов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СчетаСубконто
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СчетаНаборы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ МаксимальноеКоличествоСубконто";
	
	Если УчитыватьПорядокСубконто Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УчитыватьПорядок1", "СчетаСубконто.НомерСтроки = 1");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УчитыватьПорядок2", "СчетаСубконто.НомерСтроки = 2");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УчитыватьПорядок3", "СчетаСубконто.НомерСтроки = 3");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УчитыватьПорядок1", "ИСТИНА");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УчитыватьПорядок2", "ИСТИНА");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УчитыватьПорядок3", "ИСТИНА");
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	
	ВыборкаНабор = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ЗаполнитьТаблицуСчетов = ТаблицаСчетов <> Неопределено;
	
	Пока ВыборкаНабор.Следующий() Цикл
		
		// по отбору должна быть найдена одна строка
		СтрокаНаборы = НаборыСчетов.Найти(ВыборкаНабор.ИмяНабора, "ИмяНабора");
		// теоретически, не должно быть случая, когда СтрокаНаборы = Неопределено,
		// но для предотвращения потенциальных ошибок добавим соответствующую проверку.
		Если СтрокаНаборы = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ВыборкаСчет = ВыборкаНабор.Выбрать();
		Пока ВыборкаСчет.Следующий() Цикл
			Если ИсключитьВалютные И Не ИспользуетсяВалютныйУчет И ВыборкаСчет.Валютный Тогда
				Продолжить;
			КонецЕсли;
			
			// при классификации задолженности в закрытии месяца исключаются счета, которые не определены по видам субконто или не предопределены заранее
			Если УчитыватьПорядокСубконто И ВыборкаСчет.ИсключитьИзНабора Тогда
				Продолжить;
			КонецЕсли;

			СтрокаНаборы.СписокСчетов.Добавить(ВыборкаСчет.Счет);
			Если ЗаполнитьТаблицуСчетов Тогда
				СтрокаСчет = ТаблицаСчетов.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаСчет, ВыборкаСчет, "Счет, Код, Порядок");
				ЗаполнитьЗначенияСвойств(СтрокаСчет, СтрокаНаборы, "ВидСчета, ВидСубконто1, ВидСубконто2, ВидСубконто3, ИмяНабора");
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// Конструктор таблицы счетов
//
// Возвращаемое значение:
//  ТаблицаЗначений
//
Функция НовыйТаблицаСчетов() Экспорт

	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Счет",             Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	Таблица.Колонки.Добавить("ВидСчета",         Новый ОписаниеТипов("ВидСчета"));
	Таблица.Колонки.Добавить("Код",              ОбщегоНазначения.ОписаниеТипаСтрока(Метаданные.ПланыСчетов.Хозрасчетный.ДлинаКода));
	Таблица.Колонки.Добавить("Порядок",          ОбщегоНазначения.ОписаниеТипаСтрока(Метаданные.ПланыСчетов.Хозрасчетный.ДлинаПорядка));
	Таблица.Колонки.Добавить("ИмяНабора",        ОбщегоНазначения.ОписаниеТипаСтрока(100));
	Таблица.Колонки.Добавить("ВидСубконто1",     Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные"));
	Таблица.Колонки.Добавить("ВидСубконто2",     Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные"));
	Таблица.Колонки.Добавить("ВидСубконто3",     Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ВидыСубконтоХозрасчетные"));
	Таблица.Колонки.Добавить("КодГруппы",        ОбщегоНазначения.ОписаниеТипаСтрока(10));
	
	Возврат Таблица;
		
КонецФункции

// Возвращает текст запроса по остаткам бухгалтерского учета по переданным наборам счетов
//
// Параметры:
//  НаборыСчетов - см. НовыйНаборыСчетов
//  КонтекстЗапроса - см.НовыйКонтекстЗапросаОстаткиЗадолженности
//  ВидЗадолженности - ПеречислениеСсылка.ВидыЗадолженности
//
// Возвращаемое значение:
//  Строка
//
Функция ТекстЗапросаОстаткиЗадолженности(НаборыСчетов, КонтекстЗапроса, ВидЗадолженности) Экспорт
	
	СхемаЗапроса = Новый СхемаЗапроса;
	
	ШаблонТекстаЗапроса =
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ХозрасчетныйОстатки.Счет КАК Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто1) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто2) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ХозрасчетныйОстатки.Субконто3) <> &ПустойУникальныйИдентификатор
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Субконто3,
	|	ХозрасчетныйОстатки.СуммаОстатокДт КАК ОстатокДт,
	|	ХозрасчетныйОстатки.СуммаОстатокКт КАК ОстатокКт
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СписокСчетов), &ВидыСубконто, Организация В (&Организации)) КАК ХозрасчетныйОстатки";
	
	ЗапросЭталон = СхемаЗапроса.ПакетЗапросов[0];
	ЗапросЭталон.УстановитьТекстЗапроса(ШаблонТекстаЗапроса);

	Для Каждого Набор Из НаборыСчетов Цикл
		
		Если Не ЗначениеЗаполнено(Набор.СписокСчетов) Тогда
			Продолжить;
		КонецЕсли;
		
		ТочкаЗапроса = СхемыЗапросов.НайтиЗапросСозданияТаблицы(СхемаЗапроса, Набор.ИмяВТ);
		Если ТочкаЗапроса = Неопределено Тогда
			
			ОписаниеЗапроса = СхемаЗапроса.ПакетЗапросов.Добавить();
			
			ОписаниеЗапроса.УстановитьТекстЗапроса(ШаблонТекстаЗапроса);
			ОписаниеЗапроса.ТаблицаДляПомещения = Набор.ИмяВТ;
			Оператор = ОписаниеЗапроса.Операторы.Добавить(ЗапросЭталон.Операторы[0]);
			Источник = Оператор.Источники[0];
			
			ТочкаЗапроса = СхемыЗапросов.НовыйТочкаЗапроса(СхемаЗапроса, ОписаниеЗапроса, Оператор, Источник);
			
			КонтекстЗапроса.ВременныеТаблицы.Добавить(Набор.ИмяВТ);
			
		Иначе
			ТочкаЗапроса.Вставить("Оператор", ТочкаЗапроса.Запрос.Операторы.Добавить(ЗапросЭталон.Операторы[0]));
			ТочкаЗапроса.Вставить("Источник", ТочкаЗапроса.Оператор.Источники[0]);
		КонецЕсли;
		
		УстановитьПараметрыИПоляОстатки(Набор, ТочкаЗапроса, ВидЗадолженности);
	КонецЦикла;
	
	// Удалим первый (эталонный) пакет запросов
	СхемаЗапроса.ПакетЗапросов.Удалить(0);
	// Удалим первый оператор
	Для Каждого ПакетЗапроса Из СхемаЗапроса.ПакетЗапросов Цикл
		ПакетЗапроса.Операторы.Удалить(0);
	КонецЦикла;
		
	Возврат СхемаЗапроса.ПолучитьТекстЗапроса();
	
КонецФункции

// Создает временные таблицы расчетов, распределенные по срокам, указанным в документе "ИнвентаризацияРасчетовСКонтрагентами"
//
// Параметры:
//  Запрос - Запрос
//  ТаблицаСчетов - см. НовыйТаблицаСчетов
//                - Неопределено
//
Процедура СоздатьВременныеТаблицыРаспределенныеДанныеПоИнвентаризацииРасчетов(Запрос, ТаблицаСчетов = Неопределено) Экспорт
	
	// Данные инвентаризации за последние два года сопоставляются с остатками БУ.
	// Находится жесткая связь по аналитике, то есть аналитика задолженности БУ с заданной детализацией должна полностью совпадать с аналитикой инвентаризации.
	// Отбираются все данные, которые сопоставлены с инвентаризацией. Остаток БУ распределяется согласно подтвержденным суммам и срокам(от самого дальнего срока к самому раннему).
	// Признак "ЗаписыватьВРегистр" устанавливается:
	// - для всех счетов, у которых указан источник срока погашения.
	// - для активно-пассивных счетов, если есть документ расчетов и заполнена дата погашения.
	
	СоздатьВременныеТаблицыИнвентаризацияРасчетовДетализация(Запрос, ТаблицаСчетов);
		
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ИнвентаризацияРасчетов.Организация КАК Организация,
	|	ИнвентаризацияРасчетов.СчетРасчетов КАК СчетРасчетов,
	|	ИнвентаризацияРасчетов.Субконто1 КАК Субконто1,
	|	ИнвентаризацияРасчетов.Субконто2 КАК Субконто2,
	|	ИнвентаризацияРасчетов.Субконто3 КАК Субконто3
	|ПОМЕСТИТЬ СовпадающаяАналитика
	|ИЗ
	|	ИнвентаризацияРасчетов КАК ИнвентаризацияРасчетов
	|
	|СГРУППИРОВАТЬ ПО
	|	ИнвентаризацияРасчетов.Организация,
	|	ИнвентаризацияРасчетов.СчетРасчетов,
	|	ИнвентаризацияРасчетов.Субконто1,
	|	ИнвентаризацияРасчетов.Субконто2,
	|	ИнвентаризацияРасчетов.Субконто3
	|
	|ИМЕЮЩИЕ
	|	СУММА(1) > 1
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СчетРасчетов,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	Расчеты.Субконто1 КАК Субконто1,
	|	Расчеты.Субконто2 КАК Субконто2,
	|	Расчеты.Субконто3 КАК Субконто3,
	|	Расчеты.ДатаРегистратора КАК ДатаРегистратора,
	|	Расчеты.ДатаПогашенияБУ КАК ДатаПогашенияБУ,
	|	Расчеты.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	Расчеты.ЕстьДокументРасчетов
	|			И СчетаНаборов.ВидСчета = ЗНАЧЕНИЕ(ВидСчета.АктивноПассивный)
	|			И Расчеты.ДатаПогашенияБУ <> ДАТАВРЕМЯ(1, 1, 1)
	|		ИЛИ Расчеты.ИсточникСрокаПогашения <> НЕОПРЕДЕЛЕНО
	|		ИЛИ Расчеты.ДатаПогашенияБУ >= &ДатаНачалаДолгосрочногоПериода
	|		ИЛИ ИнвентаризацияРасчетов.Организация ЕСТЬ НЕ NULL  КАК ЗаписыватьВРегистр,
	|	Расчеты.ЕстьДокументРасчетов КАК ЕстьДокументРасчетов,
	|	Расчеты.ОстатокБУ КАК ОстатокБУ,
	|	ЕСТЬNULL(ИнвентаризацияРасчетов.Подтверждено, 0) КАК Подтверждено,
	|	ВЫБОР
	|		КОГДА ИнвентаризацияРасчетов.Организация ЕСТЬ НЕ NULL 
	|				И СовпадающаяАналитика.Организация ЕСТЬ NULL
	|			ТОГДА ВЫБОР
	|					КОГДА Расчеты.ОстатокБУ < ЕСТЬNULL(ИнвентаризацияРасчетов.Подтверждено, 0)
	|						ТОГДА Расчеты.ОстатокБУ
	|					ИНАЧЕ ИнвентаризацияРасчетов.Подтверждено
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПодтвержденоОстатокБУ,
	|	ВЫБОР
	|		КОГДА Расчеты.ОстатокБУ < ЕСТЬNULL(ИнвентаризацияРасчетов.Подтверждено, 0)
	|			ТОГДА 0
	|		ИНАЧЕ Расчеты.ОстатокБУ - ЕСТЬNULL(ИнвентаризацияРасчетов.Подтверждено, 0)
	|	КОНЕЦ КАК НеПодтвержденоОстатокБУ,
	|	ЕСТЬNULL(ИнвентаризацияРасчетов.Субконто1, НЕОПРЕДЕЛЕНО) КАК Субконто1Инвентаризация,
	|	ЕСТЬNULL(ИнвентаризацияРасчетов.Субконто2, НЕОПРЕДЕЛЕНО) КАК Субконто2Инвентаризация,
	|	ЕСТЬNULL(ИнвентаризацияРасчетов.Субконто3, НЕОПРЕДЕЛЕНО) КАК Субконто3Инвентаризация,
	|	ЕСТЬNULL(ИнвентаризацияРасчетов.ДатаВозникновения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаВозникновенияИнвентаризация,
	|	ЕСТЬNULL(ИнвентаризацияРасчетов.ДатаПогашения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПогашенияИнвентаризация,
	|	ЕСТЬNULL(ИнвентаризацияРасчетов.Ссылка, ЗНАЧЕНИЕ(Документ.ИнвентаризацияРасчетовСКонтрагентами.ПустаяСсылка)) КАК ДокументИнвентаризации,
	|	ИнвентаризацияРасчетов.Организация ЕСТЬ НЕ NULL  КАК ПоИнвентаризацииРасчетов,
	|	СовпадающаяАналитика.Организация ЕСТЬ НЕ NULL  КАК СовпадающиеЗаписи
	|ПОМЕСТИТЬ РасчетыСУчетомИнвентаризации
	|ИЗ
	|	Расчеты КАК Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ИнвентаризацияРасчетов КАК ИнвентаризацияРасчетов
	|			ЛЕВОЕ СОЕДИНЕНИЕ СовпадающаяАналитика КАК СовпадающаяАналитика
	|			ПО ИнвентаризацияРасчетов.Организация = СовпадающаяАналитика.Организация
	|				И ИнвентаризацияРасчетов.СчетРасчетов = СовпадающаяАналитика.СчетРасчетов
	|				И ИнвентаризацияРасчетов.Субконто1 = СовпадающаяАналитика.Субконто1
	|				И ИнвентаризацияРасчетов.Субконто2 = СовпадающаяАналитика.Субконто2
	|				И ИнвентаризацияРасчетов.Субконто3 = СовпадающаяАналитика.Субконто3
	|		ПО Расчеты.Организация = ИнвентаризацияРасчетов.Организация
	|			И Расчеты.Счет = ИнвентаризацияРасчетов.СчетРасчетов
	|			И Расчеты.Субконто1 = ИнвентаризацияРасчетов.Субконто1
	|			И Расчеты.Субконто2 = ИнвентаризацияРасчетов.Субконто2
	|			И Расчеты.Субконто3 = ИнвентаризацияРасчетов.Субконто3
	|		ЛЕВОЕ СОЕДИНЕНИЕ СчетаНаборов КАК СчетаНаборов
	|		ПО Расчеты.Счет = СчетаНаборов.Счет
	|ГДЕ
	|	(НЕ Расчеты.Счет В (&СчетаИсключитьБезДатыПогашения)
	|			ИЛИ ИнвентаризацияРасчетов.ДатаПогашения <> ДАТАВРЕМЯ(1, 1, 1))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыСУчетомИнвентаризации.Организация КАК Организация,
	|	РасчетыСУчетомИнвентаризации.Счет КАК Счет,
	|	РасчетыСУчетомИнвентаризации.Субконто1 КАК Субконто1,
	|	РасчетыСУчетомИнвентаризации.Субконто2 КАК Субконто2,
	|	РасчетыСУчетомИнвентаризации.Субконто3 КАК Субконто3,
	|	РасчетыСУчетомИнвентаризации.ДатаРегистратора КАК ДатаРегистратора,
	|	РасчетыСУчетомИнвентаризации.ДатаПогашенияБУ КАК ДатаПогашенияБУ,
	|	РасчетыСУчетомИнвентаризации.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	РасчетыСУчетомИнвентаризации.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	РасчетыСУчетомИнвентаризации.ОстатокБУ КАК ОстатокБУ,
	|	РасчетыСУчетомИнвентаризации.Подтверждено КАК Подтверждено,
	|	РасчетыСУчетомИнвентаризации.ДатаВозникновенияИнвентаризация КАК ДатаВозникновенияИнвентаризация,
	|	РасчетыСУчетомИнвентаризации.ДатаПогашенияИнвентаризация КАК ДатаПогашенияИнвентаризация,
	|	РасчетыСУчетомИнвентаризации.ДокументИнвентаризации КАК ДокументИнвентаризации
	|ИЗ
	|	РасчетыСУчетомИнвентаризации КАК РасчетыСУчетомИнвентаризации
	|ГДЕ
	|	РасчетыСУчетомИнвентаризации.СовпадающиеЗаписи
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасчетыСУчетомИнвентаризации.Организация,
	|	РасчетыСУчетомИнвентаризации.Счет,
	|	РасчетыСУчетомИнвентаризации.Субконто1,
	|	РасчетыСУчетомИнвентаризации.Субконто2,
	|	РасчетыСУчетомИнвентаризации.Субконто3,
	|	РасчетыСУчетомИнвентаризации.ДатаРегистратора,
	|	РасчетыСУчетомИнвентаризации.ДатаПогашенияБУ,
	|	РасчетыСУчетомИнвентаризации.ИсточникСрокаПогашения,
	|	РасчетыСУчетомИнвентаризации.ЗаписыватьВРегистр,
	|	РасчетыСУчетомИнвентаризации.ОстатокБУ,
	|	РасчетыСУчетомИнвентаризации.Подтверждено,
	|	РасчетыСУчетомИнвентаризации.ДатаВозникновенияИнвентаризация,
	|	РасчетыСУчетомИнвентаризации.ДатаПогашенияИнвентаризация,
	|	РасчетыСУчетомИнвентаризации.ДокументИнвентаризации
	|ИЗ
	|	РасчетыСУчетомИнвентаризации КАК РасчетыСУчетомИнвентаризации
	|ГДЕ
	|	РасчетыСУчетомИнвентаризации.ПоИнвентаризацииРасчетов
	|	И РасчетыСУчетомИнвентаризации.НеПодтвержденоОстатокБУ <> 0
	|	И НЕ РасчетыСУчетомИнвентаризации.СовпадающиеЗаписи
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3,
	|	РасчетыСУчетомИнвентаризации.ДатаВозникновенияИнвентаризация УБЫВ,
	|	РасчетыСУчетомИнвентаризации.ДатаПогашенияИнвентаризация УБЫВ";
	
	ДанныеРаспределения = Запрос.Выполнить().Выгрузить();
	
	// Таблица, в которую будут добавлены строки с расcчитанными величинами
	ТаблицаРасчетная = ДанныеРаспределения.СкопироватьКолонки("Организация, Счет, Субконто1, Субконто2, Субконто3");
	ТаблицаРасчетная.Колонки.Добавить("ДатаВозникновения", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	ТаблицаРасчетная.Колонки.Добавить("ДатаПогашения",     ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	ТаблицаРасчетная.Колонки.Добавить("ИсточникСрокаПогашения", Новый ОписаниеТипов(ТипыИсточниковСроковПогашения()));
	ТаблицаРасчетная.Колонки.Добавить("ЗаписыватьВРегистр", Новый ОписаниеТипов("Булево"));
	ТаблицаРасчетная.Колонки.Добавить("СуммаРасчетная",    БухгалтерскийУчетКлиентСервер.ТипСумма());
	
	ПересчитатьОстаткиСовпадающейАналитикиВИнвентаризацииРасчетов(ТаблицаРасчетная, ДанныеРаспределения);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаРасчетная.Организация КАК Организация,
	|	ТаблицаРасчетная.Счет КАК Счет,
	|	ТаблицаРасчетная.Субконто1 КАК Субконто1,
	|	ТаблицаРасчетная.Субконто2 КАК Субконто2,
	|	ТаблицаРасчетная.Субконто3 КАК Субконто3,
	|	ТаблицаРасчетная.ДатаВозникновения КАК ДатаВозникновения,
	|	ТаблицаРасчетная.ДатаПогашения КАК ДатаПогашения,
	|	ТаблицаРасчетная.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	ТаблицаРасчетная.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	ТаблицаРасчетная.СуммаРасчетная КАК СуммаРасчетная
	|ПОМЕСТИТЬ РаспределенныеДанные
	|ИЗ
	|	&ТаблицаРасчетная КАК ТаблицаРасчетная
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыСУчетомИнвентаризации.Организация КАК Организация,
	|	РасчетыСУчетомИнвентаризации.Счет КАК Счет,
	|	РасчетыСУчетомИнвентаризации.Субконто1 КАК Субконто1,
	|	РасчетыСУчетомИнвентаризации.Субконто2 КАК Субконто2,
	|	РасчетыСУчетомИнвентаризации.Субконто3 КАК Субконто3,
	|	РасчетыСУчетомИнвентаризации.ДатаРегистратора КАК ДатаВозникновения,
	|	РасчетыСУчетомИнвентаризации.ДатаПогашенияБУ КАК ДатаПогашения,
	|	РасчетыСУчетомИнвентаризации.ДатаРегистратора = ДАТАВРЕМЯ(1, 1, 1)
	|		И РасчетыСУчетомИнвентаризации.ДатаПогашенияБУ <> ДАТАВРЕМЯ(1, 1, 1) КАК НайтиДатуВозникновения,
	|	РасчетыСУчетомИнвентаризации.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	РасчетыСУчетомИнвентаризации.ЗаписыватьВРегистр КАК ЗаписыватьВРегистр,
	|	РасчетыСУчетомИнвентаризации.ОстатокБУ КАК ОстатокДолга
	|ПОМЕСТИТЬ РасчетыПоСрокамПогашения
	|ИЗ
	|	РасчетыСУчетомИнвентаризации КАК РасчетыСУчетомИнвентаризации
	|ГДЕ
	|	НЕ РасчетыСУчетомИнвентаризации.ПоИнвентаризацииРасчетов
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасчетыСУчетомИнвентаризации.Организация,
	|	РасчетыСУчетомИнвентаризации.Счет,
	|	РасчетыСУчетомИнвентаризации.Субконто1,
	|	РасчетыСУчетомИнвентаризации.Субконто2,
	|	РасчетыСУчетомИнвентаризации.Субконто3,
	|	РасчетыСУчетомИнвентаризации.ДатаВозникновенияИнвентаризация,
	|	РасчетыСУчетомИнвентаризации.ДатаПогашенияИнвентаризация,
	|	РасчетыСУчетомИнвентаризации.ДатаВозникновенияИнвентаризация = ДАТАВРЕМЯ(1, 1, 1)
	|		И РасчетыСУчетомИнвентаризации.ДатаПогашенияИнвентаризация <> ДАТАВРЕМЯ(1, 1, 1),
	|	ВЫБОР
	|		КОГДА РасчетыСУчетомИнвентаризации.ПоИнвентаризацииРасчетов
	|			ТОГДА РасчетыСУчетомИнвентаризации.ДокументИнвентаризации
	|		ИНАЧЕ РасчетыСУчетомИнвентаризации.ИсточникСрокаПогашения
	|	КОНЕЦ,
	|	РасчетыСУчетомИнвентаризации.ЗаписыватьВРегистр,
	|	РасчетыСУчетомИнвентаризации.ОстатокБУ
	|ИЗ
	|	РасчетыСУчетомИнвентаризации КАК РасчетыСУчетомИнвентаризации
	|ГДЕ
	|	РасчетыСУчетомИнвентаризации.ПодтвержденоОстатокБУ <> 0
	|	И РасчетыСУчетомИнвентаризации.НеПодтвержденоОстатокБУ = 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РаспределенныеДанные.Организация,
	|	РаспределенныеДанные.Счет,
	|	РаспределенныеДанные.Субконто1,
	|	РаспределенныеДанные.Субконто2,
	|	РаспределенныеДанные.Субконто3,
	|	РаспределенныеДанные.ДатаВозникновения,
	|	РаспределенныеДанные.ДатаПогашения,
	|	РаспределенныеДанные.ДатаВозникновения = ДАТАВРЕМЯ(1, 1, 1),
	|	РаспределенныеДанные.ИсточникСрокаПогашения,
	|	РаспределенныеДанные.ЗаписыватьВРегистр,
	|	РаспределенныеДанные.СуммаРасчетная
	|ИЗ
	|	РаспределенныеДанные КАК РаспределенныеДанные
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ СовпадающаяАналитика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РаспределенныеДанные";
	
	Запрос.УстановитьПараметр("ТаблицаРасчетная", ТаблицаРасчетная);
	
	Запрос.Выполнить();
	
КонецПроцедуры

// Формирует текст запроса по остаткам по счетам дебиторской задолженности с учетом сроков
//
// Параметры:
//  НаборыСчетов - см. НовыйНаборыСчетов
//  КонтекстЗапроса - см.НовыйКонтекстЗапросаОстаткиЗадолженности
//  ОбщиеПараметры - Структура - основные параметры
//
// Возвращаемое значение:
//  Строка - текст запроса
//
Функция ТекстЗапросаОстаткиДебиторскойЗадолженности(НаборыСчетов, КонтекстЗапроса, ОбщиеПараметры) Экспорт
	
	ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская;

	ТекстыЗапросов = Новый Массив;
	
	// Остатки задолженности по счетам, которые участвуют в классификации задолженности по срокам погашения
	ТекстЗапросаОстатки = ТекстЗапросаОстаткиЗадолженности(НаборыСчетов, КонтекстЗапроса, ВидЗадолженности);
	Если ЗначениеЗаполнено(ТекстЗапросаОстатки) Тогда
		ТекстыЗапросов.Добавить(ТекстЗапросаОстатки);
	КонецЕсли;
	
	// Дополнить остатки задолженности сроками по первичным данным
	ТекстЗапросаОстаткиПоСрокам = ТекстЗапросаДебиторскаяЗадолженностьПоСрокам(КонтекстЗапроса, "РасчетыДебиторская", ОбщиеПараметры);
	
	ТекстыЗапросов.Добавить(ТекстЗапросаОстаткиПоСрокам);

	ТекстыЗапросов.Добавить(
	"ВЫБРАТЬ
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Организация КАК Организация,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Счет КАК Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамРасходовБудущихПериодов.Субконто1) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамРасходовБудущихПериодов.Субконто1
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамРасходовБудущихПериодов.Субконто2) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамРасходовБудущихПериодов.Субконто2
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамРасходовБудущихПериодов.Субконто3) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамРасходовБудущихПериодов.Субконто3
	|	КОНЕЦ КАК Субконто3,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.ДатаНачалаСписания КАК ДатаНачалаСписания,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.ДатаОкончанияСписания КАК ДатаОкончанияСписания,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.СуммаКраткосрочная КАК СуммаКраткосрочная,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.СуммаДолгосрочная КАК СуммаДолгосрочная
	|ПОМЕСТИТЬ КлассификацияРасходовБудущихПериодовПоСрочности
	|ИЗ
	|	РегистрСведений.КлассификацияПоСрокамРасходовБудущихПериодов КАК КлассификацияПоСрокамРасходовБудущихПериодов
	|ГДЕ
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Активность
	|	И КлассификацияПоСрокамРасходовБудущихПериодов.Организация В(&Организации)
	|	И КлассификацияПоСрокамРасходовБудущихПериодов.ПериодРасчета МЕЖДУ &НачалоПериода И &КонецПериодаДата
	|	И КлассификацияПоСрокамРасходовБудущихПериодов.Счет В(&СчетаУчетаРБП)
	|	И (ВЫБОР
	|			КОГДА КлассификацияПоСрокамРасходовБудущихПериодов.Субконто1 ССЫЛКА Справочник.РасходыБудущихПериодов
	|				ТОГДА КлассификацияПоСрокамРасходовБудущихПериодов.Субконто1
	|			КОГДА КлассификацияПоСрокамРасходовБудущихПериодов.Субконто2 ССЫЛКА Справочник.РасходыБудущихПериодов
	|				ТОГДА КлассификацияПоСрокамРасходовБудущихПериодов.Субконто2
	|			КОГДА КлассификацияПоСрокамРасходовБудущихПериодов.Субконто3 ССЫЛКА Справочник.РасходыБудущихПериодов
	|				ТОГДА КлассификацияПоСрокамРасходовБудущихПериодов.Субконто3
	|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РасходыБудущихПериодов.ПустаяСсылка)
	|		КОНЕЦ).ВидАктива = &ВидАктиваДебиторскаяЗадолженность
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Организация,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамРасходовБудущихПериодов.Субконто1) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамРасходовБудущихПериодов.Субконто1
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамРасходовБудущихПериодов.Субконто2) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамРасходовБудущихПериодов.Субконто2
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамРасходовБудущихПериодов.Субконто3) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамРасходовБудущихПериодов.Субконто3
	|	КОНЕЦ,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.ДатаНачалаСписания,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.ДатаОкончанияСписания,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.СуммаКраткосрочная,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.СуммаДолгосрочная
	|ИЗ
	|	РегистрСведений.КлассификацияПоСрокамРасходовБудущихПериодов КАК КлассификацияПоСрокамРасходовБудущихПериодов
	|ГДЕ
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Активность
	|	И КлассификацияПоСрокамРасходовБудущихПериодов.Организация В(&Организации)
	|	И КлассификацияПоСрокамРасходовБудущихПериодов.ПериодРасчета МЕЖДУ &НачалоПериода И &КонецПериодаДата
	|	И КлассификацияПоСрокамРасходовБудущихПериодов.Счет В(&СчетаУчетаНМА)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация КАК Организация,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет КАК Счет,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто1) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто1
	|	КОНЕЦ КАК Субконто1,
	|	ВЫБОР
	|		КОГДА УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто2) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто2
	|	КОНЕЦ КАК Субконто2,
	|	ВЫБОР
	|		КОГДА КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет.Вид = ЗНАЧЕНИЕ(ВидСчета.АктивноПассивный)
	|					И ТИПЗНАЧЕНИЯ(КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто3) В (&ТипыДокументовРасчетов)
	|				ИЛИ УНИКАЛЬНЫЙИДЕНТИФИКАТОР(КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто3) = &ПустойУникальныйИдентификатор
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ КлассификацияПоСрокамОтдельныхВидовЗадолженности.Субконто3
	|	КОНЕЦ КАК Субконто3,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ДатаВозникновения КАК ДатаВозникновения,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ДатаПогашения КАК ДатаПогашения,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ОстатокДолга КАК ОстатокДолга,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.РезервПоСомнительнымДолгам КАК РезервПоСомнительнымДолгам,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.НДСАвансов КАК НДСАвансов,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.УровеньДетализации КАК УровеньДетализации,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
