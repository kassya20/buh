	|		КорректировкаКлассификации.ДатаВозникновения,
	|		КорректировкаКлассификации.ДатаПогашения,
	|		КорректировкаКлассификации.ОстатокДолга,
	|		КорректировкаКлассификации.НДСАвансов,
	|		КорректировкаКлассификации.ПроцентыПоРассрочке,
	|		КорректировкаКлассификации.ИсточникСрокаПогашения
	|	ИЗ
	|		КорректировкаКлассификации КАК КорректировкаКлассификации
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ХозрасчетныйОстатки.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		ХозрасчетныйОстатки.СуммаОстаток,
	|		0,
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаНДСАвансовПолученных), &СубконтоКонтрагентыСФВыданные, Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КорректировкаКлассификации.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		-СУММА(КорректировкаКлассификации.НДСАвансов),
	|		0,
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		КорректировкаКлассификации КАК КорректировкаКлассификации
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КорректировкаКлассификации.Организация
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ХозрасчетныйОстатки.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПроцентыПоРассрочке),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		0,
	|		ХозрасчетныйОстатки.СуммаОстаток,
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаПроцентовПоРассрочке), &СубконтоКонтрагентыДоговоры, Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КорректировкаКлассификации.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПроцентыПоРассрочке),
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		НЕОПРЕДЕЛЕНО,
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		0,
	|		0,
	|		-СУММА(КорректировкаКлассификации.ПроцентыПоРассрочке),
	|		НЕОПРЕДЕЛЕНО
	|	ИЗ
	|		КорректировкаКлассификации КАК КорректировкаКлассификации
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КорректировкаКлассификации.Организация) КАК Расчеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|		ПО Расчеты.Счет = Хозрасчетный.Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	Расчеты.Организация,
	|	Расчеты.Счет,
	|	Хозрасчетный.Наименование,
	|	Расчеты.Субконто1,
	|	Расчеты.Субконто2,
	|	Расчеты.Субконто3,
	|	Расчеты.ДатаВозникновения,
	|	Расчеты.ДатаПогашения,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(Расчеты.ДатаПогашения < &ДатаНачалаДолгосрочногоПериода, ЛОЖЬ)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ
	|
	|ИМЕЮЩИЕ
	|	(СУММА(Расчеты.ОстатокДолга) <> 0
	|		ИЛИ СУММА(Расчеты.НДСАвансов) <> 0
	|		ИЛИ СУММА(Расчеты.ПроцентыПоРассрочке) <> 0)");
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("ПустойУникальныйИдентификатор", ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаНДСАвансовПолученных", БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам));
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаДолгосрочныхКредитовЗаймов", СчетаДолгосрочныхКредитовЗаймов());

	СубконтоКонтрагентыСФВыданные = Новый Массив;
	СубконтоКонтрагентыСФВыданные.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыСФВыданные.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СФВыданные);
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СубконтоКонтрагентыСФВыданные", СубконтоКонтрагентыСФВыданные);

	КонтекстЗапроса.ПараметрыЗапроса.Вставить("СчетаПроцентовПоРассрочке", ПланыСчетов.Хозрасчетный.СчетаПроцентовПоРассрочке());
	
	КонтекстЗапроса.ПараметрыЗапроса.Вставить("ТипыДокументовРасчетов", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами.ТипЗначения.Типы());

	Возврат ТекстЗапроса;

КонецФункции

// Создает временную таблицу общего остатка НДС авансов
//
// Параметры:
//  МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
//  КонтексРасчета - Структура:
//   * Организации - Массив из СправочникСсылка.Организации
//   * КонецПериода - Дата, МоментВремениСУточнениемПериода
//  РазделятьАвансыПоВидамАктивов - Булево - см. РегламентированнаяОтчетность.АвансыРазделеныПоВидамАктивов
//  АвансыПоВидамАктивовСводно - см. ЗаполнениеБухгалтерскойОтчетности2025Основная.НовыйАвансыПоВидамАктивовСводно
//
Процедура СоздатьВременныеТаблицыОбщийНДСАвансовВыданных(МенеджерВременныхТаблиц, КонтексРасчета, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивовСводно) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организации",     КонтексРасчета.Организации);
	Запрос.УстановитьПараметр("КонецПериода",    Новый Граница(КонтексРасчета.КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("СчетаНДСАвансов", БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным));

	СубконтоКонтрагентыСФ = Новый Массив;
	СубконтоКонтрагентыСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СФПолученные);
	Запрос.УстановитьПараметр("СубконтоКонтрагентыСФ", СубконтоКонтрагентыСФ);
	
	Если Не РазделятьАвансыПоВидамАктивов Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеНДС.Организация КАК Организация,
		|	СУММА(ДанныеНДС.НДСАвансовБУ) КАК НДСАвансовБУ
		|ПОМЕСТИТЬ ОбщийНДСВыданный
		|ИЗ
		|	(ВЫБРАТЬ
		|		ХозрасчетныйОстатки.Организация КАК Организация,
		|		-1 * ХозрасчетныйОстатки.СуммаОстаток КАК НДСАвансовБУ
		|	ИЗ
		|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаНДСАвансов), &СубконтоКонтрагентыСФ, Организация В (&Организации)) КАК ХозрасчетныйОстатки
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		НДСАвансовРасчетыПоАренде.Организация,
		|		-1 * НДСАвансовРасчетыПоАренде.НДСАвансов
		|	ИЗ
		|		НДСАвансовРасчетыПоАренде КАК НДСАвансовРасчетыПоАренде) КАК ДанныеНДС
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеНДС.Организация";
	Иначе
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Авансы.Организация КАК Организация,
		|	Авансы.ВидАктива КАК ВидАктива,
		|	Авансы.ОстатокНДС КАК ОстатокНДС
		|ПОМЕСТИТЬ АвансыПоВидамАктивов
		|ИЗ
		|	&АвансыПоВидамАктивовСводно КАК Авансы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеНДС.Организация КАК Организация,
		|	СУММА(ДанныеНДС.НДСАвансовБУ) КАК НДСАвансовБУ
		|ПОМЕСТИТЬ ОбщийНДСВыданный
		|ИЗ
		|	(ВЫБРАТЬ
		|		ХозрасчетныйОстатки.Организация КАК Организация,
		|		-1 * ХозрасчетныйОстатки.СуммаОстаток КАК НДСАвансовБУ
		|	ИЗ
		|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаНДСАвансов), &СубконтоКонтрагентыСФ, Организация В (&Организации)) КАК ХозрасчетныйОстатки
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		АвансыПоВидамАктивов.Организация,
		|		-1 * АвансыПоВидамАктивов.ОстатокНДС
		|	ИЗ
		|		АвансыПоВидамАктивов КАК АвансыПоВидамАктивов
		|	ГДЕ
		|		АвансыПоВидамАктивов.ВидАктива <> ЗНАЧЕНИЕ(Перечисление.ВидыАктивовДляАвансов.ПустаяСсылка)
		|		И АвансыПоВидамАктивов.ОстатокНДС <> 0
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		НДСАвансовРасчетыПоАренде.Организация,
		|		-1 * НДСАвансовРасчетыПоАренде.НДСАвансов
		|	ИЗ
		|		НДСАвансовРасчетыПоАренде КАК НДСАвансовРасчетыПоАренде) КАК ДанныеНДС
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеНДС.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ АвансыПоВидамАктивов";
		
		Запрос.УстановитьПараметр("АвансыПоВидамАктивовСводно", АвансыПоВидамАктивовСводно);
	КонецЕсли;
	
	Запрос.Выполнить();
	
КонецПроцедуры

// Создает временную таблицу общего остатка резерва по сомнительным долгам
//
// Параметры:
//  МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
//  КонтексРасчета - Структура:
//   * Организации - Массив из СправочникСсылка.Организации
//   * КонецПериода - Дата, МоментВремениСУточнениемПериода
//  РазделятьАвансыПоВидамАктивов - Булево - см. РегламентированнаяОтчетность.АвансыРазделеныПоВидамАктивов
//  АвансыПоВидамАктивовСводно - см. ЗаполнениеБухгалтерскойОтчетности2025Основная.НовыйАвансыПоВидамАктивовСводно
//
Процедура СоздатьВременныеТаблицыОбщийРезервПоСомнительнымДолгам(МенеджерВременныхТаблиц, КонтексРасчета, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивовСводно) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организации",     КонтексРасчета.Организации);
	Запрос.УстановитьПараметр("КонецПериода",    Новый Граница(КонтексРасчета.КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("СчетаРезервов", БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам));
	
	СубконтоКонтрагентыДоговорыДокументы = Новый Массив;
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами);

	Запрос.УстановитьПараметр("СубконтоКонтрагентыДоговорыДокументы", СубконтоКонтрагентыДоговорыДокументы);
	
	Если Не РазделятьАвансыПоВидамАктивов Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйОстатки.Организация КАК Организация,
		|	СУММА(-1 * ХозрасчетныйОстатки.СуммаОстаток) КАК РезервБУ
		|ПОМЕСТИТЬ ОбщийРезервПоСомнительнымДолгам
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаРезервов), &СубконтоКонтрагентыДоговорыДокументы, Организация В (&Организации)) КАК ХозрасчетныйОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ХозрасчетныйОстатки.Организация";
	Иначе
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Авансы.Организация КАК Организация,
		|	Авансы.ВидАктива КАК ВидАктива,
		|	Авансы.ОстатокРезерва КАК ОстатокРезерва
		|ПОМЕСТИТЬ АвансыПоВидамАктивов
		|ИЗ
		|	&АвансыПоВидамАктивовСводно КАК Авансы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеРезервов.Организация КАК Организация,
		|	СУММА(ДанныеРезервов.РезервБУ) КАК РезервБУ
		|ПОМЕСТИТЬ ОбщийРезервПоСомнительнымДолгам
		|ИЗ
		|	(ВЫБРАТЬ
		|		ХозрасчетныйОстатки.Организация КАК Организация,
		|		-1 * ХозрасчетныйОстатки.СуммаОстаток КАК РезервБУ
		|	ИЗ
		|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаРезервов), &СубконтоКонтрагентыДоговорыДокументы, Организация В (&Организации)) КАК ХозрасчетныйОстатки
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		АвансыПоВидамАктивов.Организация,
		|		-1 * АвансыПоВидамАктивов.ОстатокРезерва
		|	ИЗ
		|		АвансыПоВидамАктивов КАК АвансыПоВидамАктивов
		|	ГДЕ
		|		АвансыПоВидамАктивов.ВидАктива <> ЗНАЧЕНИЕ(Перечисление.ВидыАктивовДляАвансов.ПустаяСсылка)
		|		И АвансыПоВидамАктивов.ОстатокРезерва <> 0) КАК ДанныеРезервов
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеРезервов.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ АвансыПоВидамАктивов";
		
		Запрос.УстановитьПараметр("АвансыПоВидамАктивовСводно", АвансыПоВидамАктивовСводно);
	КонецЕсли;
	
	Запрос.Выполнить();
		
КонецПроцедуры

// Создает временные таблицы расчетов по аренде
//
// Параметры:
//  МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
//  КонтексРасчета - См. Отчеты.СправкаРасчетКлассификацияЗадолженностиПоСрокам.НовыйКонтекстФормированияОтчета
//
Процедура СоздатьВременныеТаблицыРасчетыПоАренде(МенеджерВременныхТаблиц, КонтексРасчета) Экспорт
	
	СчетаРасчетовПоАренде = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаРасчетовПоАренде, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоАренде));
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаРасчетовПоАренде, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоАрендеВал));
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаРасчетовПоАренде, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РасчетыПоАрендеУЕ));

	СчетаАрендныхПлатежей = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаАрендныхПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.АрендныеПлатежи));
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаАрендныхПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.АрендныеПлатежиВал));
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СчетаАрендныхПлатежей, БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.АрендныеПлатежиУЕ));
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организации",     КонтексРасчета.Организации);
	Запрос.УстановитьПараметр("НачалоПериода",   КонтексРасчета.НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериодаДата",   КонтексРасчета.КонецПериодаДата);
	Запрос.УстановитьПараметр("КонецПериода",    Новый Граница(КонтексРасчета.КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("СчетаРасчетовПоАрендеБезПодчиненных", ПланыСчетов.Хозрасчетный.СчетаРасчетовПоАренде());
	Запрос.УстановитьПараметр("СчетаРасчетовПоАренде", СчетаРасчетовПоАренде);
	Запрос.УстановитьПараметр("СчетаАрендныхПлатежей", СчетаАрендныхПлатежей);
	
	СубконтоКонтрагентыДоговоры = Новый Массив;
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	Запрос.УстановитьПараметр("СубконтоКонтрагентыДоговоры", СубконтоКонтрагентыДоговоры);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОстаткиБУ.Организация КАК Организация,
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РасчетыПоАренде) КАК Счет,
	|	ЕСТЬNULL(ВЫРАЗИТЬ(ОстаткиБУ.Субконто1 КАК Справочник.Контрагенты), ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Субконто1,
	|	ЕСТЬNULL(ВЫРАЗИТЬ(ОстаткиБУ.Субконто2 КАК Справочник.ДоговорыКонтрагентов), ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК Субконто2,
	|	СУММА(ОстаткиБУ.СуммаОстаток) КАК ОстатокБУ
	|ПОМЕСТИТЬ РасчетыПоАренде
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаРасчетовПоАренде), &СубконтоКонтрагентыДоговоры, Организация В (&Организации)) КАК ОстаткиБУ
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиБУ.Организация,
	|	ЕСТЬNULL(ВЫРАЗИТЬ(ОстаткиБУ.Субконто1 КАК Справочник.Контрагенты), ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)),
	|	ЕСТЬNULL(ВЫРАЗИТЬ(ОстаткиБУ.Субконто2 КАК Справочник.ДоговорыКонтрагентов), ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КлассификацияЗадолженности.Организация КАК Организация,
	|	КлассификацияЗадолженности.Субконто1 КАК Субконто1,
	|	КлассификацияЗадолженности.Субконто2 КАК Субконто2,
	|	СУММА(КлассификацияЗадолженности.НДСАвансов) КАК НДСАвансов
	|ПОМЕСТИТЬ НДСАвансовАренды
	|ИЗ
	|	РегистрСведений.КлассификацияПоСрокамОтдельныхВидовЗадолженности КАК КлассификацияЗадолженности
	|ГДЕ
	|	КлассификацияЗадолженности.Активность
	|	И КлассификацияЗадолженности.Организация В(&Организации)
	|	И КлассификацияЗадолженности.Счет В(&СчетаАрендныхПлатежей)
	|	И КлассификацияЗадолженности.ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.ВидыЗадолженности.Дебиторская)
	|	И КлассификацияЗадолженности.ПериодРасчета МЕЖДУ &НачалоПериода И &КонецПериодаДата
	|
	|СГРУППИРОВАТЬ ПО
	|	КлассификацияЗадолженности.Организация,
	|	КлассификацияЗадолженности.Счет,
	|	КлассификацияЗадолженности.Субконто1,
	|	КлассификацияЗадолженности.Субконто2,
	|	КлассификацияЗадолженности.Субконто3
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Субконто1,
	|	Субконто2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РазницаВеличин.Организация КАК Организация,
	|	РазницаВеличин.Счет КАК Счет,
	|	РазницаВеличин.Субконто1 КАК Субконто1,
	|	РазницаВеличин.Субконто2 КАК Субконто2,
	|	РазницаВеличин.Субконто3 КАК Субконто3,
	|	СУММА(РазницаВеличин.ОстатокБУ) КАК ОстатокБУ,
	|	СУММА(РазницаВеличин.ОстатокРаспределенный) КАК ОстатокРаспределенный,
	|	СУММА(РазницаВеличин.НДСАвансов) КАК НДСАвансов,
	|	СУММА(РазницаВеличин.ОстатокБУ) <> СУММА(РазницаВеличин.ОстатокРаспределенный) - СУММА(РазницаВеличин.НДСАвансов) КАК ЕстьРасхождениеОстаткаДолга
	|ПОМЕСТИТЬ ОбязательстваПоАренде
	|ИЗ
	|	(ВЫБРАТЬ
	|		РасчетыПоАренде.Организация КАК Организация,
	|		РасчетыПоАренде.Счет КАК Счет,
	|		РасчетыПоАренде.Субконто1 КАК Субконто1,
	|		РасчетыПоАренде.Субконто2 КАК Субконто2,
	|		НЕОПРЕДЕЛЕНО КАК Субконто3,
	|		-1 * РасчетыПоАренде.ОстатокБУ КАК ОстатокБУ,
	|		0 КАК ОстатокРаспределенный,
	|		0 КАК НДСАвансов
	|	ИЗ
	|		РасчетыПоАренде КАК РасчетыПоАренде
	|	ГДЕ
	|		РасчетыПоАренде.ОстатокБУ < 0
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КлассификацияЗадолженности.Организация,
	|		КлассификацияЗадолженности.Счет,
	|		КлассификацияЗадолженности.Субконто1,
	|		КлассификацияЗадолженности.Субконто2,
	|		НЕОПРЕДЕЛЕНО,
	|		0,
	|		СУММА(КлассификацияЗадолженности.ОстатокДолга),
	|		ЕСТЬNULL(НДСАвансовАренды.НДСАвансов, 0)
	|	ИЗ
	|		РегистрСведений.КлассификацияПоСрокамОтдельныхВидовЗадолженности КАК КлассификацияЗадолженности
	|			ЛЕВОЕ СОЕДИНЕНИЕ НДСАвансовАренды КАК НДСАвансовАренды
	|			ПО КлассификацияЗадолженности.Организация = НДСАвансовАренды.Организация
	|				И КлассификацияЗадолженности.Субконто1 = НДСАвансовАренды.Субконто1
	|				И КлассификацияЗадолженности.Субконто2 = НДСАвансовАренды.Субконто2
	|	ГДЕ
	|		КлассификацияЗадолженности.Активность
	|		И КлассификацияЗадолженности.Организация В(&Организации)
	|		И КлассификацияЗадолженности.Счет В(&СчетаРасчетовПоАрендеБезПодчиненных)
	|		И КлассификацияЗадолженности.ВидЗадолженности = ЗНАЧЕНИЕ(Перечисление.ВидыЗадолженности.Кредиторская)
	|		И КлассификацияЗадолженности.ПериодРасчета МЕЖДУ &НачалоПериода И &КонецПериодаДата
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КлассификацияЗадолженности.Организация,
	|		КлассификацияЗадолженности.Счет,
	|		КлассификацияЗадолженности.Субконто1,
	|		КлассификацияЗадолженности.Субконто2,
	|		КлассификацияЗадолженности.Субконто3,
	|		НДСАвансовАренды.НДСАвансов) КАК РазницаВеличин
	|
	|СГРУППИРОВАТЬ ПО
	|	РазницаВеличин.Организация,
	|	РазницаВеличин.Счет,
	|	РазницаВеличин.Субконто1,
	|	РазницаВеличин.Субконто2,
	|	РазницаВеличин.Субконто3
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыПоАренде.Организация КАК Организация,
	|	РасчетыПоАренде.Счет КАК Счет,
	|	РасчетыПоАренде.Субконто1 КАК Субконто1,
	|	РасчетыПоАренде.Субконто2 КАК Субконто2,
	|	НЕОПРЕДЕЛЕНО КАК Субконто3,
	|	РасчетыПоАренде.ОстатокБУ КАК ОстатокБУ
	|ПОМЕСТИТЬ АвансыПоАренде
	|ИЗ
	|	РасчетыПоАренде КАК РасчетыПоАренде
	|ГДЕ
	|	РасчетыПоАренде.ОстатокБУ > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОбязательстваПоАренде.Организация КАК Организация,
	|	ОбязательстваПоАренде.НДСАвансов КАК НДСАвансов
	|ПОМЕСТИТЬ НДСАвансовРасчетыПоАренде
	|ИЗ
	|	ОбязательстваПоАренде КАК ОбязательстваПоАренде
	|ГДЕ
	|	НЕ ОбязательстваПоАренде.ЕстьРасхождениеОстаткаДолга
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ РасчетыПоАренде";
	
	Запрос.Выполнить();

КонецПроцедуры

// Возвращает типы объектов, которые являются источниками для нахождения срока погашения
//
// Возвращаемое значение:
//  Массив из Тип
//
Функция ТипыИсточниковСроковПогашения() Экспорт
	
	Типы = Новый Массив;
	Типы.Добавить(Тип("СправочникСсылка.ДоговорыКонтрагентов"));
	Типы.Добавить(Тип("ДокументСсылка.АктОбОказанииПроизводственныхУслуг"));
	Типы.Добавить(Тип("ДокументСсылка.ПередачаНМА"));
	Типы.Добавить(Тип("ДокументСсылка.ПередачаОС"));
	Типы.Добавить(Тип("ДокументСсылка.ПоступлениеДопРасходов"));
	Типы.Добавить(Тип("ДокументСсылка.ПоступлениеНМА"));
	Типы.Добавить(Тип("ДокументСсылка.ПоступлениеТоваровУслуг"));
	Типы.Добавить(Тип("ДокументСсылка.РеализацияТоваровУслуг"));
	Типы.Добавить(Тип("ДокументСсылка.ИнвентаризацияРасчетовСКонтрагентами"));
	
	Возврат Типы;
	
КонецФункции

Функция СписокВидовСубконто() Экспорт
	
	ВидыСубконто = Новый Структура;
	
	СубконтоКонтрагенты = Новый Массив;
	СубконтоКонтрагенты.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	ВидыСубконто.Вставить("СубконтоКонтрагенты", СубконтоКонтрагенты);
	
	СубконтоКонтрагентыДоговоры = Новый Массив;
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	ВидыСубконто.Вставить("СубконтоКонтрагентыДоговоры", СубконтоКонтрагентыДоговоры);
	
	СубконтоКонтрагентыЦенныеБумаги = Новый Массив;
	СубконтоКонтрагентыЦенныеБумаги.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыЦенныеБумаги.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ЦенныеБумаги);
	ВидыСубконто.Вставить("СубконтоКонтрагентыЦенныеБумаги", СубконтоКонтрагентыЦенныеБумаги);
	
	СубконтоКонтрагентыДоговорыДокументы = Новый Массив;
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами);
	ВидыСубконто.Вставить("СубконтоКонтрагентыДоговорыДокументы", СубконтоКонтрагентыДоговорыДокументы);
	
	СубконтоКонтрагентыДоговорыЦенныеБумаги = Новый Массив;
	СубконтоКонтрагентыДоговорыЦенныеБумаги.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговорыЦенныеБумаги.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	СубконтоКонтрагентыДоговорыЦенныеБумаги.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ЦенныеБумаги);
	ВидыСубконто.Вставить("СубконтоКонтрагентыДоговорыЦенныеБумаги", СубконтоКонтрагентыДоговорыЦенныеБумаги);
	
	СубконтоКонтрагентыРБП = Новый Массив;
	СубконтоКонтрагентыРБП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыРБП.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.РасходыБудущихПериодов);
	ВидыСубконто.Вставить("СубконтоКонтрагентыРБП", СубконтоКонтрагентыРБП);
	
	СубконтоРасходыБудущихПериодов = Новый Массив;
	СубконтоРасходыБудущихПериодов.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.РасходыБудущихПериодов);
	ВидыСубконто.Вставить("СубконтоРасходыБудущихПериодов", СубконтоРасходыБудущихПериодов);

	СубконтоВидыПлатежей = Новый Массив;
	СубконтоВидыПлатежей.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ВидыПлатежейВГосБюджет);
	ВидыСубконто.Вставить("СубконтоВидыПлатежей", СубконтоВидыПлатежей);

	СубконтоРаботники = Новый Массив;
	СубконтоРаботники.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.РаботникиОрганизаций);
	ВидыСубконто.Вставить("СубконтоРаботники", СубконтоРаботники);

