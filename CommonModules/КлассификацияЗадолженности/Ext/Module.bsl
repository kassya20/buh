	Таблица.Колонки.Добавить("ОстатокДолга", БухгалтерскийУчетКлиентСервер.ТипСумма());
	Таблица.Колонки.Добавить("РезервПоСомнительнымДолгам", БухгалтерскийУчетКлиентСервер.ТипСумма());
