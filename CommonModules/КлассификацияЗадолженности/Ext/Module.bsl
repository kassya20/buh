Процедура СоздатьВременныеТаблицыЗадолженностьВРассрочку(МенеджерВременныхТаблиц, ЗадолженностьВРассрочку, КонтекстОперации)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.Организация КАК Организация,
	|	Таблица.Счет КАК Счет,
	|	Таблица.Контрагент КАК Контрагент,
	|	Таблица.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Таблица.ЕстьГрафикПлатежей КАК ЕстьГрафикПлатежей,
	|	Таблица.ДатаВозникновения КАК ДатаВозникновения,
	|	Таблица.ДатаПогашения КАК ДатаПогашения,
	|	Таблица.НоминальнаяДолгосрочнаяВеличина КАК НоминальнаяДолгосрочнаяВеличина,
	|	Таблица.НоминальнаяКраткосрочнаяВеличина КАК НоминальнаяКраткосрочнаяВеличина,
	|	Таблица.КраткосрочноеОбязательство КАК КраткосрочноеОбязательство,
	|	Таблица.ДолгосрочноеОбязательство КАК ДолгосрочноеОбязательство,
	|	Таблица.ПроцентыПоРассрочке КАК ПроцентыПоРассрочке
	|ПОМЕСТИТЬ ВТЗадолженностьВРассрочку
	|ИЗ
	|	&ТаблицаЗадолженностьВРассрочку КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТЗадолженностьВРассрочку.Организация КАК Организация,
	|	ВТЗадолженностьВРассрочку.Счет КАК Счет,
	|	ВТЗадолженностьВРассрочку.Контрагент КАК Контрагент,
	|	ВТЗадолженностьВРассрочку.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ АналитикаРассрочки
	|ИЗ
	|	ВТЗадолженностьВРассрочку КАК ВТЗадолженностьВРассрочку
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТЗадолженностьВРассрочку.Организация КАК Организация,
	|	ВТЗадолженностьВРассрочку.Счет КАК Счет,
	|	ВТЗадолженностьВРассрочку.Контрагент КАК Контрагент,
	|	ВТЗадолженностьВРассрочку.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ВТЗадолженностьВРассрочку.ДатаВозникновения КАК ДатаВозникновения,
	|	ВЫБОР
	|		КОГДА ВТЗадолженностьВРассрочку.ДатаПогашения > &ДатаОкончанияКраткосрочногоПериода
	|			ТОГДА &ДатаОкончанияКраткосрочногоПериода
	|		ИНАЧЕ ВТЗадолженностьВРассрочку.ДатаПогашения
	|	КОНЕЦ КАК ДатаПогашения,
	|	ВЫБОР
	|		КОГДА ВТЗадолженностьВРассрочку.ЕстьГрафикПлатежей
	|			ТОГДА ВТЗадолженностьВРассрочку.ПроцентыПоРассрочке
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВТЗадолженностьВРассрочку.НоминальнаяДолгосрочнаяВеличина < ВТЗадолженностьВРассрочку.ПроцентыПоРассрочке
	|					ТОГДА ВТЗадолженностьВРассрочку.ПроцентыПоРассрочке - ВТЗадолженностьВРассрочку.НоминальнаяДолгосрочнаяВеличина
	|				ИНАЧЕ 0
	|			КОНЕЦ
	|	КОНЕЦ КАК ПроцентыПоРассрочке,
	|	ВТЗадолженностьВРассрочку.НоминальнаяКраткосрочнаяВеличина КАК НоминальнаяВеличина
	|ПОМЕСТИТЬ ЗадолженностьВРассрочку
	|ИЗ
	|	ВТЗадолженностьВРассрочку КАК ВТЗадолженностьВРассрочку
	|ГДЕ
	|	(ВТЗадолженностьВРассрочку.НоминальнаяКраткосрочнаяВеличина <> 0
	|			ИЛИ ВТЗадолженностьВРассрочку.КраткосрочноеОбязательство <> 0)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТЗадолженностьВРассрочку.Организация,
	|	ВТЗадолженностьВРассрочку.Счет,
	|	ВТЗадолженностьВРассрочку.Контрагент,
	|	ВТЗадолженностьВРассрочку.ДоговорКонтрагента,
	|	ВТЗадолженностьВРассрочку.ДатаВозникновения,
	|	ВТЗадолженностьВРассрочку.ДатаПогашения,
	|	ВЫБОР
	|		КОГДА ВТЗадолженностьВРассрочку.ЕстьГрафикПлатежей
	|			ТОГДА 0
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВТЗадолженностьВРассрочку.НоминальнаяДолгосрочнаяВеличина < ВТЗадолженностьВРассрочку.ПроцентыПоРассрочке
	|					ТОГДА ВТЗадолженностьВРассрочку.НоминальнаяДолгосрочнаяВеличина
	|				ИНАЧЕ ВТЗадолженностьВРассрочку.ПроцентыПоРассрочке
	|			КОНЕЦ
	|	КОНЕЦ,
	|	ВТЗадолженностьВРассрочку.НоминальнаяДолгосрочнаяВеличина
	|ИЗ
	|	ВТЗадолженностьВРассрочку КАК ВТЗадолженностьВРассрочку
	|ГДЕ
	|	(ВТЗадолженностьВРассрочку.НоминальнаяДолгосрочнаяВеличина <> 0
	|			ИЛИ ВТЗадолженностьВРассрочку.ДолгосрочноеОбязательство <> 0)";

	Запрос.УстановитьПараметр("ДатаОкончанияКраткосрочногоПериода", КонтекстОперации.ДатаОкончанияКраткосрочногоПериода);
	Запрос.УстановитьПараметр("ТаблицаЗадолженностьВРассрочку", ЗадолженностьВРассрочку);
	
	Запрос.Выполнить();
	
КонецПроцедуры

