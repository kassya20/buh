Функция НовыйПротоколРасчета()
	
	ПротоколРасчета = Новый Структура;
	ПротоколРасчета.Вставить("Числитель",   0);
	ПротоколРасчета.Вставить("Знаменатель", 0);
	ПротоколРасчета.Вставить("Доля", 0);
	ПротоколРасчета.Вставить("Сумма", 0);
	
	Возврат ПротоколРасчета;
	
КонецФункции

Функция ДоляВОстаткеАктива(Остаток, Способ, Знач ДатаРасчета, Знач НачалоПериода, Знач КонецПериода)
	
	ПротоколРасчета = НовыйПротоколРасчета();
	
	НачалоПериода = НачалоДня(НачалоПериода);
	КонецПериода  = НачалоДня(КонецПериода);
	ДатаРасчета = НачалоДня(ДатаРасчета);
	
	Если НачалоПериода > КонецПериода
		Или Не ЗначениеЗаполнено(НачалоПериода) Или Не ЗначениеЗаполнено(КонецПериода) Тогда
		Возврат ПротоколРасчета;
	КонецЕсли;
	
	Если Способ = Перечисления.СпособыПризнанияРасходов.ПоКалендарнымДням Тогда
		
		ПротоколРасчета.Знаменатель = ОбщегоНазначенияБПКлиентСервер.РазностьДат(НачалоПериода, КонецДня(КонецПериода) + 1, Перечисления.Периодичность.День);
		
		Если ДатаРасчета <= КонецПериода Тогда
			ПротоколРасчета.Числитель = ОбщегоНазначенияБПКлиентСервер.РазностьДат(ДатаРасчета, КонецДня(КонецПериода) + 1, Перечисления.Периодичность.День);
		КонецЕсли;
		
	ИначеЕсли Способ = Перечисления.СпособыПризнанияРасходов.ПоМесяцам Тогда
		
		ПорядокПризнанияРасходов = РасходыБудущихПериодов.ПорядокПризнанияРасходовПоМесяцам(НачалоПериода, КонецПериода);
		ПротоколРасчета.Знаменатель = ПорядокПризнанияРасходов.ВсегоКоличествоМесяцев;
		
		// Часть срока, которая может быть выражена в календарных месяцах (целом числе месяцев)
		Если ДатаРасчета < ПорядокПризнанияРасходов.КонецПериодаЦелыхМесяцев Тогда
			ПротоколРасчета.Числитель = (Год(ПорядокПризнанияРасходов.КонецПериодаЦелыхМесяцев) - Год(ДатаРасчета)) * 12 
			+ Месяц(ПорядокПризнанияРасходов.КонецПериодаЦелыхМесяцев) - Месяц(ДатаРасчета) + 1;
		КонецЕсли;
		
		НецелыйМесяц = ПорядокПризнанияРасходов.НецелыеМесяцы.Найти(НачалоМесяца(КонецПериода), "Месяц");
		
		Если НецелыйМесяц <> Неопределено И ДатаРасчета <= КонецПериода Тогда
			ПротоколРасчета.Числитель = ПротоколРасчета.Числитель + НецелыйМесяц.Вес;
		КонецЕсли;
		
	КонецЕсли;
	
	ПротоколРасчета.Доля = ?(ПротоколРасчета.Знаменатель = 0, 0, Окр(ПротоколРасчета.Числитель / ПротоколРасчета.Знаменатель, 5));
	ПротоколРасчета.Сумма = КоллекцииСумм.ДоляСуммы(Остаток, ПротоколРасчета.Числитель, ПротоколРасчета.Знаменатель);
	
	Возврат ПротоколРасчета;
	
КонецФункции

// Определяет список видов расходов будущих периодов, которые участвуют в классификации дебиторской задолженности
//
// Возвращаемое значение:
//  Массив из ПеречислениеСсылка.ВидыРБП
//
Функция ВидыРБП()
	
	Виды = Новый Массив;
	Виды.Добавить(Перечисления.ВидыРБП.Прочие);
	Виды.Добавить(Перечисления.ВидыРБП.ОсвоениеПриродныхРесурсов);
	Виды.Добавить(Перечисления.ВидыРБП.УбыткиОтРеализацииАмортизируемогоИмущества);
	Виды.Добавить(Перечисления.ВидыРБП.ДолгосрочноеСтрахованиеЖизни);
	Виды.Добавить(Перечисления.ВидыРБП.СтрахованиеНаОплатуМедицинскихРасходов);
	Виды.Добавить(Перечисления.ВидыРБП.СтрахованиеНаСлучайСмертиИУтратыРаботоспособности);
	Виды.Добавить(Перечисления.ВидыРБП.ПрочиеВидыСтрахования);
	
	Возврат Виды;
	
КонецФункции

