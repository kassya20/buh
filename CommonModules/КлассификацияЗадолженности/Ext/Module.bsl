// Возвращает счета с подчиненными по переданному списку
//
// Параметры:
//  Счета - Массив из ПланСчетовСсылка.Хозрасчетный
//  ВидыСчетов - Массив из ВидСчета
//  СчетаИсключения - Массив из ПланСчетовСсылка.Хозрасчетный
//
// Возвращаемое значение:
//  Массив из ПланСчетовСсылка.Хозрасчетный
//
Функция СчетаВИерархии(Счета, ВидыСчетов, СчетаИсключения = Неопределено) Экспорт
	
	Если СчетаИсключения = Неопределено Тогда
		СчетаИсключения = Новый Массив;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Счета", Счета);
	Запрос.УстановитьПараметр("ВидыСчетов", ВидыСчетов);
	Запрос.УстановитьПараметр("СчетаИсключения", СчетаИсключения);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Счет
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В ИЕРАРХИИ(&Счета)
	|	И Хозрасчетный.Вид В(&ВидыСчетов)
	|	И НЕ Хозрасчетный.Ссылка В ИЕРАРХИИ (&СчетаИсключения)
	|	И НЕ Хозрасчетный.ЗапретитьИспользоватьВПроводках
	|
	|УПОРЯДОЧИТЬ ПО
	|	Хозрасчетный.Код";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Счет");
	
КонецФункции

