Процедура ПовторитьЗапросЕслиСервисНедоступен(ОтветСервиса, ДанныеЗапроса, Подключение, ИмяРесурса)

	// Если на сервисе произошел сбой и если метод выполняется в фоновом задании,
	// пытаемся несколько раз получить хороший ответ, делая между попытками паузу: с каждой попыткой пауза увеличивается.
	
	Если ПолучитьТекущийСеансИнформационнойБазы().ПолучитьФоновоеЗадание() = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МасимальноеКоличествоНовыхПопыток = 3;
	КоличествоНовыхПопыток = 1;
	ГенераторСлучайныхЧисел = Новый ГенераторСлучайныхЧисел();
	// Расчетное время на получение максимальной порции запроса - 5 секунд.
	СтандартнаяПауза = 5000;

	Пока КоличествоНовыхПопыток <= МасимальноеКоличествоНовыхПопыток
		И ОтветСервиса.КодСостояния = ЗапросыREST.КодСостоянияВнутренняяОшибкаСервера() Цикл
		
		ДлинаПаузы = ГенераторСлучайныхЧисел.СлучайноеЧисло(
			КоличествоНовыхПопыток * СтандартнаяПауза,
			КоличествоНовыхПопыток * СтандартнаяПауза + СтандартнаяПауза);
		
		Попытка
			ВызватьПаузу(ДлинаПаузы);
		Исключение
			СобытиеЖурналаРегистрации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = '%1.%2'", ОбщегоНазначения.КодОсновногоЯзыка()),
				ПодсказкаКодовОКВЭД.ИмяОбщегоСобытияЖурналаРегистрации(),
				ПодсказкаКодовОКВЭД.ИмяСобытияПолучениеДанных());
				
			ЗаписьЖурналаРегистрации(
				СобытиеЖурналаРегистрации,
				УровеньЖурналаРегистрации.Ошибка,
				,
				,
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				
			Возврат;
			
		КонецПопытки;

		ОтветСервиса = ЗапросыREST.ВыполнитьМетодСервиса(Подключение, "POST", ИмяРесурса, ДанныеЗапроса);
		КоличествоНовыхПопыток = КоличествоНовыхПопыток + 1;
		
	КонецЦикла;

КонецПроцедуры

