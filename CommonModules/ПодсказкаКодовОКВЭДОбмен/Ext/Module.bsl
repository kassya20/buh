Функция Токен()
	
	УстановитьПривилегированныйРежим(Истина);
	Токен = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(
		"ПодсказкаКодовОКВЭД",
		"Токен");
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Токен <> Неопределено И Не ПустаяСтрока(Токен) Тогда
		Возврат Токен;
	КонецЕсли;
	
	Токен = ТокенИзСервиса();
	
	Если ПустаяСтрока(Токен) Тогда
		Возврат "";
	КонецЕсли;
	
	СохранитьТокенВБезопасноеХранилище(Токен);
	
	Возврат Токен;
	
КонецФункции

Функция ТокенИзСервиса()
	
	Подключение = НовыйПодключениеКСервису();
	Подключение.ПрочитатьОтветВСоответствие = Истина;
	
	Подключение.ИсточникЗапроса = СтрШаблон("%1.%2",
		ПодсказкаКодовОКВЭД.ИмяОбщегоСобытияЖурналаРегистрации(),
		НСтр("ru = 'Получение токена'", ОбщегоНазначения.КодОсновногоЯзыка()));
	
	ДанныеЗапроса = НовыйДанныеЗапросаПолученияТокена();
	Подключение.ЗаголовкиАутентификации.Вставить("X-Origin", "fresh_its");
	
	ПодготовитьДанныеПолученияТокена(ДанныеЗапроса);
	
	ОтветСервиса = ЗапросыREST.ВыполнитьМетодСервиса(Подключение, "POST", ИмяРесурсаПолучениеТокена(), ДанныеЗапроса);
	
	Если ОтветСервиса = Неопределено Или ОтветСервиса.КодСостояния <> ЗапросыREST.КодСтандартногоСостояния() Тогда
		Возврат "";
	КонецЕсли;
	
	Токен = ОтветСервиса.Содержимое.Получить("X-Auth-Token");
	Если Токен = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Токен;
	
КонецФункции

Процедура СохранитьТокенВБезопасноеХранилище(Знач Токен)
	
