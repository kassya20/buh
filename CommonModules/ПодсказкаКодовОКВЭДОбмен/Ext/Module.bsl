// См. РаботаВБезопасномРежимеПереопределяемый.ПриЗаполненииРазрешенийНаДоступКВнешнимРесурсам
//
Процедура ПриЗаполненииРазрешенийНаДоступКВнешнимРесурсам(ЗапросыРазрешений) Экспорт
	
	НовыеРазрешения = Новый Массив;
	
	СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресСервисаКлассификации());
	Разрешение = РаботаВБезопасномРежиме.РазрешениеНаИспользованиеИнтернетРесурса(
		ВРег(СтруктураURI.Схема),
		СтруктураURI.Хост,
		СтруктураURI.Порт,
		НСтр("ru = 'Сервис классификации номенклатуры'"));
	НовыеРазрешения.Добавить(Разрешение);
	
	ЗапросыРазрешений.Добавить(РаботаВБезопасномРежиме.ЗапросНаИспользованиеВнешнихРесурсов(НовыеРазрешения));
	
КонецПроцедуры

// Возвращает "раскодированные" признаки выручки из данных обратной связи в виде соответствия с ключами Истина и Ложь.
//
// Параметры:
//  ЭлементСтруктурыВыручкиОбратнойСвязи - Массив из Число - последовательность нулей и единиц
//                                       - Строка - последовательность нулей и единиц через запятую, заключенных в квадратные скобки - фрагмент Json
//                                                  обратной связи, соответствующий одному элементу структуры выручки.
//  ИменаКолонокВыручки - Массив из Строка
// 
// Возвращаемое значение:
//  Соответствие из КлючиИЗначение:
//   * Ключ - Булево
//   * Значение - Массив из Строка - имена полей запроса, соответствующих признакам выручки, из см. ПодсказкаКодовОКВЭД.СтруктураВыручки.
//
Функция ПризнакиВыручкиОбратнойСвязиПоИменам(Знач ЭлементСтруктурыВыручкиОбратнойСвязи, ИменаКолонокВыручки = Неопределено) Экспорт

	СоответствиеПризнаков = Новый Соответствие;
	
	Если ТипЗнч(ЭлементСтруктурыВыручкиОбратнойСвязи) = Тип("Строка") Тогда
		ЭлементСтруктурыВыручкиОбратнойСвязи = ОбщегоНазначения.JSONВЗначение(ЭлементСтруктурыВыручкиОбратнойСвязи);
	КонецЕсли;
	
	Если ИменаКолонокВыручки = Неопределено Тогда
		ОписаниеСтруктурыВыручки = ПодсказкаКодовОКВЭД.НовыйСтруктураВыручки();
		ИменаКолонокВыручки = ПодсказкаКодовОКВЭД.КолонкиПоказателиСтруктурыВыручки(ОписаниеСтруктурыВыручки);
	КонецЕсли;
	
	Если ЭлементСтруктурыВыручкиОбратнойСвязи.Количество() <> ИменаКолонокВыручки.Количество() Тогда
		// Вероятно, версия обратной связи не соответствует текущей версии конфигурации.
		Возврат СоответствиеПризнаков;
	КонецЕсли;

	Для ИндексЭлемента = 0 По ЭлементСтруктурыВыручкиОбратнойСвязи.ВГраница() Цикл
		Признак = ЭлементСтруктурыВыручкиОбратнойСвязи[ИндексЭлемента]; // 0 или 1
		ЛогическоеЗначениеПризнака = Ложь;
		Если Признак = 1 Тогда
			ЛогическоеЗначениеПризнака = Истина;
		КонецЕсли;
		ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(
			СоответствиеПризнаков,
			ЛогическоеЗначениеПризнака,
			ИменаКолонокВыручки[ИндексЭлемента]);
	КонецЦикла;
	
	Возврат СоответствиеПризнаков;
	
КонецФункции

#КонецОбласти

