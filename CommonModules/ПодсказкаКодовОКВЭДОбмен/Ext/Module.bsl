#Область ПрограммныйИнтерфейс

// Результат сопоставления.
// 
// Параметры:
//  ИменаДляПоискаВСервисе - Массив из Строка
//                         - Соответствие из КлючИЗначение:
//                             * Ключ - Строка - наименование, по которому выполняется поиск в сервисе
//                             * Значение - Произвольный
//  КодыПоИдентификаторам - см. НовыйСопоставленияИдентификаторовКодов.КодыПоИдентификаторам
//  ТребуетсяКороткийТаймаут - Булево - Истина, если требуется меньшая длительность ответа сервиса, например, при интерактивном вызове.
//  
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//    * Ключ - Строка
//    * Значение - Массив из см. НовыйЭлементСопоставления
Функция РезультатСопоставления(Знач ИменаДляПоискаВСервисе, КодыПоИдентификаторам, ТребуетсяКороткийТаймаут = Ложь) Экспорт
	
	Если ТипЗнч(ИменаДляПоискаВСервисе) = Тип("Соответствие") Тогда
		ИменаДляПоискаВСервисе = ОбщегоНазначенияБПКлиентСервер.КлючиКоллекции(ИменаДляПоискаВСервисе);
	КонецЕсли;
	
	Токен = Токен();
	
	Если ПустаяСтрока(Токен) Тогда
		Возврат Новый Соответствие;
	КонецЕсли;
	
	Подключение = НовыйПодключениеКСервису();
	ДобавитьТокенВЗаголовок(Подключение, Токен);
	
	Подключение.ИсточникЗапроса = СтрШаблон(
		"%1.%2",
		ПодсказкаКодовОКВЭД.ИмяОбщегоСобытияЖурналаРегистрации(),
		ПодсказкаКодовОКВЭД.ИмяСобытияПолучениеДанных());
		
	Если ТребуетсяКороткийТаймаут Тогда
		Подключение.Таймаут = КороткийТаймаут();
	КонецЕсли;
	
	ИмяРесурса = ИмяРесурсаКлассификация();

	РезультатСопоставления = Новый Соответствие;

	ДанныеЗапроса = Новый Структура;
	ДанныеЗапроса.Вставить("uuid_classificator", ВерсияКлассификатора());

	ДанныеЗапроса.Вставить("k", РазмерВектора());
	
	Прогресс = 0;
	КоличествоВсего = ИменаДляПоискаВСервисе.Количество();
	
	НачалоПорции = 0;
	
	Пока НачалоПорции <= ИменаДляПоискаВСервисе.ВГраница() Цикл
		Если Константы.ИспользоватьПодсказкуКодовОКВЭД.Получить() = Ложь Тогда
			// Константа могла быть выключена в процессе получения подсказки
			Возврат РезультатСопоставления;
		КонецЕсли;

		ПрогрессНовоеЗначение = Цел((НачалоПорции + 1) / КоличествоВсего * 100);
		Если Прогресс < ПрогрессНовоеЗначение Тогда
			Прогресс = ПрогрессНовоеЗначение;
			ДлительныеОперации.СообщитьПрогресс(Прогресс);
		КонецЕсли;
				
		РазмерПорции = Мин(МаксимальныйРазмерПорцииЗапроса(), КоличествоВсего - НачалоПорции);
		ПорцияЗапроса = Новый Массив;
		Для к = 0 По РазмерПорции - 1 Цикл
			ПорцияЗапроса.Добавить(ИменаДляПоискаВСервисе[НачалоПорции + к]);
		КонецЦикла;
		
		ДанныеЗапроса.Вставить("queries", ПорцияЗапроса);
		ОтветСервиса = ЗапросыREST.ВыполнитьМетодСервиса(Подключение, "POST", ИмяРесурса, ДанныеЗапроса);
		
		Если ОтветСервиса = Неопределено Тогда
			Возврат РезультатСопоставления;
		КонецЕсли;
		
		НачалоПорции = НачалоПорции + РазмерПорции;
		
		Если ОтветСервиса.КодСостояния = ЗапросыREST.КодСостоянияНеподдерживаемыйКонтент() Тогда
			// Сервер не может обработать конкретную порцию запроса. Пропускаем ее.
			Продолжить;
		КонецЕсли;
		
		ПовторитьЗапросЕслиСервисНедоступен(ОтветСервиса, ДанныеЗапроса, Подключение, ИмяРесурса);
		
		Если ОтветСервиса.КодСостояния = ЗапросыREST.КодСостоянияВнутренняяОшибкаСервера() Тогда
			// Пропускаем эту порцию и будем пытаться получить следующую.
			Продолжить;
		КонецЕсли;
		
		Если ОтветСервиса.КодСостояния <> ЗапросыREST.КодСтандартногоСостояния() Тогда
			Возврат РезультатСопоставления;
		КонецЕсли;
		
		ПорцияКодов = ОтветСервиса.Содержимое;

		Если ПорцияКодов.Количество() <> ПорцияЗапроса.Количество() Тогда
			Продолжить;
		КонецЕсли;
		
		Для Индекс = 0 По ПорцияЗапроса.ВГраница() Цикл
			
			КодыСервиса = ПорцияКодов[Индекс];
			
			СтрокаЗапроса = ПорцияЗапроса[Индекс];
			
			Для Каждого КодСервиса Из КодыСервиса Цикл
				
				КодОКВЭД = КодыПоИдентификаторам[КодСервиса.category_id];
				
				Если КодОКВЭД = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				ЭлементСопоставления = НовыйЭлементСопоставления();
				ЭлементСопоставления.КодОКВЭД = КодОКВЭД;
				ЭлементСопоставления.Вероятность = КодСервиса.prob;
				
				ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(
					РезультатСопоставления,
					СтрокаЗапроса,
					ЭлементСопоставления);
			КонецЦикла;
				
		КонецЦикла;

	КонецЦикла;
	
	Возврат РезультатСопоставления;

КонецФункции

// Передает обратную связь в сервис.
// 
// Параметры:
//  ОбратнаяСвязь - Соответствие из КлючИЗначение:
//    * Ключ - Строка
//    * Значение - см. ПодсказкаКодовОКВЭД.НовыйСоставОбратнойСвязи
//  КолонкиПоказателиСтруктурыВыручки - Массив из Строка - список имен колонок показателей выручки, отсортированных по имени.
//                                                         Например, "Перепродажа", "Опт", "Розница".
Процедура ОтправитьОбратнуюСвязь(ОбратнаяСвязь, КолонкиПоказателиСтруктурыВыручки) Экспорт
	
	Токен = Токен();
	
	Если ПустаяСтрока(Токен) Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбратнаяСвязь.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВерсияКлассификатора = ВерсияКлассификатора();
	ИмяРесурса = ИмяРесурсаОбратнаяСвязь();

	ИдентификаторыПоКодам = СопоставленияИдентификаторовКодов().ИдентификаторыПоКодам;
	
	ПорцияОбратнойСвязи = Новый Массив;
	ВерсияОбратнойСвязи = ВерсияОбратнойСвязи();

	Для Каждого ЭлементОбратнойСвязи Из ОбратнаяСвязь Цикл
		
		ЗначениеЭлементаОбратнойСвязи = ЭлементОбратнойСвязи.Значение; // см. ПодсказкаКодовОКВЭД.НовыйСоставОбратнойСвязи
		
		ОбратнаяСвязьЗапроса = НовыйОбратнаяСвязьЗапроса();
		
		ПорцияОбратнойСвязи.Добавить(ОбратнаяСвязьЗапроса);
		
		ОбратнаяСвязьЗапроса.uuid_classificator = ВерсияКлассификатора;
		ОбратнаяСвязьЗапроса.query = ЭлементОбратнойСвязи.Ключ;
		
		ОбратнаяСвязьЗапроса.candidate_ids = ИдентификаторыКодов(ЗначениеЭлементаОбратнойСвязи.КодыСервиса, ИдентификаторыПоКодам);
		ОбратнаяСвязьЗапроса.selected_ids = ИдентификаторыКодов(ЗначениеЭлементаОбратнойСвязи.ВыбранныеКоды, ИдентификаторыПоКодам);
		
		// Нет выбранных кодов, обратная связь смысла не имеет.
		Если ОбратнаяСвязьЗапроса.selected_ids.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		additional_data = ОбратнаяСвязьЗапроса.additional_data;
		additional_data.version = ВерсияОбратнойСвязи;
		
		Для Каждого ЭлементКонтекста Из ЗначениеЭлементаОбратнойСвязи.Контекст Цикл
			
			ЭлементКонтекстаОбратнаяСвязь = НовыйЭлементКонтекстаОбратнаяСвязь();
			
			ВыручкаОбратнаяСвязь = СоставВыручкиВФорматеСервиса(ЭлементКонтекста.СоставВыручки, КолонкиПоказателиСтруктурыВыручки);
			
			ЭлементКонтекстаОбратнаяСвязь.type = ЭлементКонтекста.Тип;
			ЭлементКонтекстаОбратнаяСвязь.revenue = ВыручкаОбратнаяСвязь;
			ЭлементКонтекстаОбратнаяСвязь.added_ids = ИдентификаторыКодов(ЭлементКонтекста.ДобавленныеКоды, ИдентификаторыПоКодам);
			ЭлементКонтекстаОбратнаяСвязь.selected_ids = ИдентификаторыКодов(ЭлементКонтекста.ВыбранныеКоды, ИдентификаторыПоКодам);
			ЭлементКонтекстаОбратнаяСвязь.deleted_ids = ИдентификаторыКодов(ЭлементКонтекста.УдаленныеКоды, ИдентификаторыПоКодам);
			
			// Контекст без выбранного кода нет смысла анализировать.
			Если ЭлементКонтекстаОбратнаяСвязь.selected_ids.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			additional_data.context.Добавить(ЭлементКонтекстаОбратнаяСвязь);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Подключение = НовыйПодключениеКСервису();
	ДобавитьТокенВЗаголовок(Подключение, Токен);
	
	Подключение.ИсточникЗапроса = СтрШаблон(
		"%1.%2",
		ПодсказкаКодовОКВЭД.ИмяОбщегоСобытияЖурналаРегистрации(),
		НСтр("ru = 'Передача обратной связи'", ОбщегоНазначения.КодОсновногоЯзыка()));
		
	ОтветСервиса = ЗапросыREST.ВыполнитьМетодСервиса(Подключение, "POST", ИмяРесурса, ПорцияОбратнойСвязи);
	
	Если ОтветСервиса <> Неопределено И ОтветСервиса.КодСостояния <> ЗапросыREST.КодСтандартногоСостояния() Тогда
		
		ШаблонСобытия = НСтр("ru = '%1.Ошибка отправки обратной связи'", ОбщегоНазначения.КодОсновногоЯзыка());
		
		ЗаписьЖурналаРегистрации(
			СтрШаблон(ШаблонСобытия, ПодсказкаКодовОКВЭД.ИмяОбщегоСобытияЖурналаРегистрации()),
			УровеньЖурналаРегистрации.Предупреждение,
			Метаданные.Обработки.КлассификацияВыручкиПоОКВЭД,
			,
			ОтветСервиса.Текст);
			
	КонецЕсли;

КонецПроцедуры

// Конструктор элемента сопоставления кодов.
// 
// Возвращаемое значение:
//  Структура:
// * КодОКВЭД - Строка
// * Вероятность - Число
Функция НовыйЭлементСопоставления() Экспорт

	ЭлементСопоставления = Новый Структура;
	ЭлементСопоставления.Вставить("КодОКВЭД", "");
	ЭлементСопоставления.Вставить("Вероятность", 0);
	
	Возврат ЭлементСопоставления;

КонецФункции

// Возвращает коллекцию сопоставлений кодов классификатора и идентификаторов сервиса.
// Эта информация кешируется на форме классификации выручки в коллекции см. ПодсказкаКодовОКВЭД.НовыйДанныеПодсказкиКодов,
// которая хранится во временном хранилище по адресу АдресПодсказкаКодов.
//
// Возвращаемое значение:
//  см. РезультатЗапросаСопоставленияИдентификаторовКодов
Функция СопоставленияИдентификаторовКодов() Экспорт
	
	Токен = Токен();
	
	Если ПустаяСтрока(Токен) Тогда
		Возврат НовыйСопоставленияИдентификаторовКодов();
	КонецЕсли;
	
	Подключение = НовыйПодключениеКСервису();
	ДобавитьТокенВЗаголовок(Подключение, Токен);
	
	ИмяРесурса = ИмяРесурсаСтруктураКлассификатора();
	Подключение.ИсточникЗапроса = СтрШаблон("%1.%2",
		ПодсказкаКодовОКВЭД.ИмяОбщегоСобытияЖурналаРегистрации(),
		НСтр("ru = 'Получение структуры классификатора'", ОбщегоНазначения.КодОсновногоЯзыка()));
	
	ОтветСервиса = ЗапросыREST.ВыполнитьМетодСервиса(Подключение, "GET", ИмяРесурса);
	
	Если ОтветСервиса = Неопределено Тогда
		Возврат НовыйСопоставленияИдентификаторовКодов();
	КонецЕсли;
	
	Если ОтветСервиса.КодСостояния = ЗапросыREST.КодСостоянияНеАутентифицирован() Тогда
		// Возможно, сохранен неверный токен. Один раз попробуем получить новый.
		Токен = ТокенИзСервиса();
		Если ПустаяСтрока(Токен) Тогда
			Возврат НовыйСопоставленияИдентификаторовКодов();
		КонецЕсли;
		СохранитьТокенВБезопасноеХранилище(Токен);
		ДобавитьТокенВЗаголовок(Подключение, Токен);
		ОтветСервиса = ЗапросыREST.ВыполнитьМетодСервиса(Подключение, "GET", ИмяРесурса);
	КонецЕсли;
	
	Если ОтветСервиса = Неопределено Или ОтветСервиса.КодСостояния <> ЗапросыREST.КодСтандартногоСостояния() Тогда
		Возврат НовыйСопоставленияИдентификаторовКодов();
	КонецЕсли;
		
	СодержимоеОтвета = ОтветСервиса.Содержимое;

	СопоставленияИдентификаторовКодов = РезультатЗапросаСопоставленияИдентификаторовКодов(СодержимоеОтвета);
	
	Возврат СопоставленияИдентификаторовКодов;
	
КонецФункции

// Преобразует структуру классификатора, полученную из сервиса, в набор из двух коллекций - ИдентификаторыПоКодам и КодыПоИдентификаторам,
// описывающие какому идентификатору классификатора сервиса (порядковому номер группы классификатора, которым оперирует сервис
// классификации) соотвествует данный код ОКВЭД, и наоборот.
// 
// Параметры:
//  СодержимоеОтвета - Структура:
//    * category_tree - Массив из Структура:
//      ** name - Строка - наименование категории классификатора ОКВЭД в формате "Код_пробел_наименование", например,
//                         "25.72 Производство замков, петель"
//      ** category_id - Число - числовой идентификатор категории классификатора в сервисе
//
// Возвращаемое значение:
//  Структура - Сопоставления идентификаторов кодов:
//    * ИдентификаторыПоКодам - Соответствие из КлючИЗначение:
//      ** Ключ - Строка - код из классификатора ОКВЭД
//      ** Значение- Число - числовой идентификатор категории классификатора в сервисе
//    * КодыПоИдентификаторам - Соответствие из КлючИЗначение:
//      ** Ключ - Число - числовой идентификатор категории классификатора в сервисе
//      ** Значение - Строка - код из классификатора ОКВЭД
Функция РезультатЗапросаСопоставленияИдентификаторовКодов(СодержимоеОтвета) Экспорт

	СопоставленияИдентификаторовКодов = НовыйСопоставленияИдентификаторовКодов();
	ИдентификаторыПоКодам = СопоставленияИдентификаторовКодов.ИдентификаторыПоКодам;
	КодыПоИдентификаторам = СопоставленияИдентификаторовКодов.КодыПоИдентификаторам;
	
	Для Каждого ПозицияКлассификатора Из СодержимоеОтвета.category_tree Цикл
		КодНаименование = ПозицияКлассификатора.name;
		ЧастиКодНаименование = СтрРазделить(КодНаименование, " ");
		Если ЧастиКодНаименование.Количество() < 2 Тогда
			Продолжить;
		КонецЕсли;
		Код = ЧастиКодНаименование[0];
		КодыПоИдентификаторам.Вставить(ПозицияКлассификатора.category_id, Код);
		ИдентификаторыПоКодам.Вставить(Код, ПозицияКлассификатора.category_id);
	КонецЦикла;
	
	Возврат СопоставленияИдентификаторовКодов;
	
КонецФункции

// Конструктор соответствия классификатора ОКВЭД идентификаторам классификатора в сервисе.
// 
// Возвращаемое значение:
//  Структура - Новый сопоставления идентификаторов кодов:
// * ИдентификаторыПоКодам - Соответствие из КлючИЗначение:
//   ** Ключ - Строка
//   ** Значение - Число
// * КодыПоИдентификаторам - Соответствие из КлючИЗначение:
//   ** Ключ - Число
//   ** Значение - Строка
Функция НовыйСопоставленияИдентификаторовКодов() Экспорт
	
	СопоставленияИдентификаторовКодов = Новый Структура;
	СопоставленияИдентификаторовКодов.Вставить("ИдентификаторыПоКодам", Новый Соответствие());
	СопоставленияИдентификаторовКодов.Вставить("КодыПоИдентификаторам", Новый Соответствие());
	
	Возврат СопоставленияИдентификаторовКодов;
	
КонецФункции

// Проверка доступности сервиса.
// 
// Возвращаемое значение:
//  Булево
//
Функция СервисДоступен() Экспорт
	
	Подключение = НовыйПодключениеКСервису();
	Подключение.Таймаут = КороткийТаймаут();
	
	Подключение.ИсточникЗапроса = СтрШаблон("%1.%2",
		ПодсказкаКодовОКВЭД.ИмяОбщегоСобытияЖурналаРегистрации(),
		НСтр("ru = 'Проверка доступности сервиса классификации номенклатуры'", ОбщегоНазначения.КодОсновногоЯзыка()));
	
	ОтветСервиса = ЗапросыREST.ВыполнитьМетодСервиса(Подключение, "GET", ИмяРесурсаПроверкиДоступностиСервиса());
	
	Если ОтветСервиса = Неопределено Или ОтветСервиса.КодСостояния <> ЗапросыREST.КодСтандартногоСостояния() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

