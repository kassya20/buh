#Область ПрограммныйИнтерфейс

Процедура ПоказатьСообщение(Текст, Обработчик = Неопределено) Экспорт
	
	ПоказатьПредупреждение(
		Обработчик,
		Текст,
		,
		НСтр("ru='1С:Сканер Документов';
		     |en='1C:Document Scanner'")
	);
	
КонецПроцедуры

Асинх Процедура СканироватьДокументы(Обработчик) Экспорт
	
#Если МобильныйКлиент Тогда
	
	Фильтры = Новый Массив;
	Фильтры.Добавить(ФильтрОбработкиСканированияДокументов.Нет);
	
	ПараметрыСканирования = Новый ПараметрыСканированияДокументов;
	ПараметрыСканирования.РазрешитьАвтоЗахват = Истина;
	ПараметрыСканирования.ПрямоугольныйДокумент = Истина;
	ПараметрыСканирования.БелыйФонДокумента = Истина;
	ПараметрыСканирования.СканированиеСериями = Истина;
	ПараметрыСканирования.ПроверкаКачества = 
		ПроверкаКачестваСканированияДокументов.ТребоватьСреднееПредупреждатьНижеВысокого;
	ПараметрыСканирования.ФильтрыОбработки = Фильтры;
	ПараметрыСканирования.РежимОпределенияОриентации = 
		РежимОпределенияОриентацииСканированияДокументов.ПоГоризонтальнымСтрокамТекста;
	
	ОтсканированныеСтраницы = Ждать СредстваМультимедиа.СканироватьДокументыАсинх(, ПараметрыСканирования);
	
	Если ОтсканированныеСтраницы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Результат = Новый Массив;
	НомерКадра = 0;
	
	Для Каждого Страница Из ОтсканированныеСтраницы Цикл
		
		НомерКадра = НомерКадра + 1;
		
		НомерКадраСтрока = XMLСтрока(НомерКадра);
		ТекущаяДатаСтрока = Формат(ТекущаяДата(), "ДФ=yyyyMMdd_HHmmss");
		ИмяФайла = "scan_" + НомерКадраСтрока + "_" + ТекущаяДатаСтрока + "." + Страница.ДанныеИзображения.РасширениеФайла;
		
		РезультатФайл = Новый Структура;
		РезультатФайл.Вставить("ИмяФайла", ИмяФайла);
		РезультатФайл.Вставить("ДвоичныеДанные", Страница.ДанныеИзображения.ПолучитьДвоичныеДанные());
		
		Результат.Добавить(РезультатФайл);
		
	КонецЦикла;
	
	Если Результат.Количество() > 0 Тогда
		ВыполнитьОбработкуОповещения(Обработчик, Результат);
	КонецЕсли;
	
#КонецЕсли
	
КонецПроцедуры

Процедура ВыбратьФайлы(Обработчик) Экспорт
	
	Контекст = Новый Структура("Обработчик", Обработчик);
	ОбработчикВыбора = Новый ОписаниеОповещения("ПослеВыбораИзФайла", ЭтотОбъект, Контекст);
	
	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.МножественныйВыбор = Истина;
	
#Если МобильныйКлиент Тогда
	
	Разделы = Новый Массив;
	
	СисИнфо = Новый СистемнаяИнформация;
	Если СисИнфо.ТипПлатформы = ТипПлатформы.iOS_ARM
	 Или СисИнфо.ТипПлатформы = ТипПлатформы.iOS_ARM_64 Тогда
		
		Разделы.Добавить(РазделДиалогаВыбораФайла.Галерея);
	КонецЕсли;
	
	Разделы.Добавить(РазделДиалогаВыбораФайла.Файлы);
	
	ДиалогВыбора.Разделы = Разделы;
	
#КонецЕсли
	
	ДиалогВыбора.Показать(ОбработчикВыбора);
	
КонецПроцедуры

Асинх Процедура ОткрытьФайлДляПросмотра(РасположениеФайла, ИмяФайла) Экспорт
	
	ПутьКФайлу = Ждать ПутьКФайлу(РасположениеФайла, ИмяФайла);
	
	УдалосьЗапустить = Ложь;
#Если МобильныйКлиент Тогда
	Интент = Новый ЗапускПриложенияМобильногоУстройства;
	Интент.Действие = "android.intent.action.VIEW";
	Интент.Данные = "file://" + ПутьКФайлу;
	Интент.Тип = ПоРасширениюФайла(ПутьКФайлу);
	
	Если Интент.ПоддерживаетсяЗапуск() Тогда
		УдалосьЗапустить = Интент.ЗапуститьБезОжидания();
	КонецЕсли;
#КонецЕсли
	
	Если Не УдалосьЗапустить Тогда
		КодВозврата = Ждать ЗапуститьПриложениеАсинх(ПутьКФайлу, , Истина);
		УдалосьЗапустить = (КодВозврата <> Неопределено);
	КонецЕсли;
	
	Если Не УдалосьЗапустить Тогда
		ТекстПредупреждения =
			НСтр("ru='Отсутствует приложение, которым можно открыть данный файл';
			     |en='No app found to open the file'");
		ТекстЗаголовка =
			НСтр("ru='Открытие файла';
			     |en='Open file'");
		ПоказатьПредупреждение(,ТекстПредупреждения, , ТекстЗаголовка);
	КонецЕсли;
	
КонецПроцедуры

// Проверяет, является ли переданная строка внутренней навигационной ссылкой.
//  
// Параметры:
//  Строка - Строка - навигационная ссылка.
//
// Возвращаемое значение:
//  Булево - результат проверки.
//
Функция ЭтоНавигационнаяСсылка(Строка) Экспорт
	
	Возврат СтрНачинаетсяС(Строка, "e1c:")
		Или СтрНачинаетсяС(Строка, "e1cib/")
		Или СтрНачинаетсяС(Строка, "e1ccs/");
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Асинх Функция ПутьКФайлу(РасположениеФайла, ИмяФайла)
	
	ПутьКФайлу = ОбъединитьПути(КаталогДокументов(), ИмяФайла);
	
	Если ТипЗнч(РасположениеФайла) = Тип("ДанныеМультимедиа") Тогда
		Ждать РасположениеФайла.ПолучитьДвоичныеДанные().ЗаписатьАсинх(ПутьКФайлу);
	Иначе
		Если ЭтоАдресВременногоХранилища(РасположениеФайла)
		Или ЭтоНавигационнаяСсылка(РасположениеФайла) Тогда
			Ждать ПолучитьФайлССервераАсинх(РасположениеФайла, ПутьКФайлу);
		Иначе
			Ждать КопироватьФайлАсинх(РасположениеФайла, ПутьКФайлу);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПутьКФайлу;
	
КонецФункции

Функция ОбъединитьПути(Путь1, Путь2)
	
	Если СтрЗаканчиваетсяНа(Путь1, ПолучитьРазделительПути()) Тогда
		Возврат Путь1 + Путь2;
	Иначе
		Возврат Путь1 + ПолучитьРазделительПути() + Путь2;
	КонецЕсли;
	
КонецФункции

Процедура ПослеВыбораИзФайла(ВыбранныеФайлы, Контекст) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Результат = Новый Массив;
	
	Для Каждого ВыбранныйФайл Из ВыбранныеФайлы Цикл
		
		ФайлИнфо = Новый Файл(ВыбранныйФайл);
		
		ИмяФайла = "";
		
#Если МобильныйКлиент Тогда
		ИмяФайла = ФайлИнфо.ПолучитьПредставлениеФайлаБиблиотекиМобильногоУстройства();
#КонецЕсли
		
		Если ПустаяСтрока(ИмяФайла) Тогда
			ИмяФайла = ФайлИнфо.Имя;
		КонецЕсли;
		
		РезультатФайл = Новый Структура;
		РезультатФайл.Вставить("ИмяФайла", ИмяФайла);
		РезультатФайл.Вставить("ДвоичныеДанные", Новый ДвоичныеДанные(ВыбранныйФайл));
		
		Результат.Добавить(РезультатФайл);
	КонецЦикла;
	
	ВыполнитьОбработкуОповещения(Контекст.Обработчик, Результат);
	
КонецПроцедуры

Функция ПоРасширениюФайла(ПутьКФайлу) Экспорт
	
	ФайлИнфо = Новый Файл(ПутьКФайлу);
	Расширение = НРег(ФайлИнфо.Расширение);
	
	// https://developer.mozilla.org/en-US/docs/Web/HTTP/Basics_of_HTTP/MIME_types/Common_types
	
	Если Расширение = ".heic" Или Расширение = ".heif"Тогда
		Возврат "image/heic";
	ИначеЕсли Расширение = ".bmp" Тогда
		Возврат "image/bmp";
	ИначеЕсли Расширение = ".bz" Тогда
		Возврат "application/x-bzip";
	ИначеЕсли Расширение = ".bz2" Тогда
		Возврат "application/x-bzip2";
	ИначеЕсли Расширение = ".doc" Тогда
		Возврат "application/msword";
	ИначеЕсли Расширение = ".docx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
	ИначеЕсли Расширение = ".gz" Тогда
		Возврат "application/gzip";
	ИначеЕсли Расширение = ".gif" Тогда
		Возврат "image/gif";
	ИначеЕсли Расширение = ".jpeg" Или Расширение = ".jpg" Тогда
		Возврат "image/jpeg";
	ИначеЕсли Расширение = ".odp" Тогда
		Возврат "application/vnd.oasis.opendocument.presentation";
	ИначеЕсли Расширение = ".ods" Тогда
		Возврат "application/vnd.oasis.opendocument.spreadsheet";
	ИначеЕсли Расширение = ".odt" Тогда
		Возврат "application/vnd.oasis.opendocument.text";
	ИначеЕсли Расширение = ".png" Тогда
		Возврат "image/png";
	ИначеЕсли Расширение = ".pdf" Тогда
		Возврат "application/pdf";
	ИначеЕсли Расширение = ".ppt" Тогда
		Возврат "application/vnd.ms-powerpoint";
	ИначеЕсли Расширение = ".pptx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.presentationml.presentation";
	ИначеЕсли Расширение = ".rar" Тогда
		Возврат "application/vnd.rar";
	ИначеЕсли Расширение = ".rtf" Тогда
		Возврат "application/rtf";
	ИначеЕсли Расширение = ".svg" Тогда
		Возврат "image/svg+xml";
	ИначеЕсли Расширение = ".tar" Тогда
		Возврат "application/x-tar";
	ИначеЕсли Расширение = ".tif" Или Расширение = ".tiff" Тогда
		Возврат "image/tiff";
	ИначеЕсли Расширение = ".webp" Тогда
		Возврат "image/webp";
	ИначеЕсли Расширение = ".xls" Тогда
		Возврат "application/vnd.ms-excel";
	ИначеЕсли Расширение = ".xlsx" Тогда
		Возврат "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
	ИначеЕсли Расширение = ".zip" Тогда
		Возврат "application/zip";
	ИначеЕсли Расширение = ".7z" Тогда
		Возврат "application/x-7z-compressed";
	Иначе
		Возврат "*/*";
	КонецЕсли;
	
КонецФункции

#КонецОбласти