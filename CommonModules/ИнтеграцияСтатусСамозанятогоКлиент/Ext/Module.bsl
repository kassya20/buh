Функция ИменаСобытий() Экспорт
	
	ИменаСобытий = Новый Структура;
	ИменаСобытий.Вставить("СтатусСамозанятогоПолучен", "СтатусСамозанятогоПолучен");
	ИменаСобытий.Вставить("СтатусСамозанятогоОшибка", "СтатусСамозанятогоОшибка");
	ИменаСобытий.Вставить("СписокОпцийПолучен", "СписокОпцийПолучен");
	ИменаСобытий.Вставить("СписокОпцийОшибка", "СписокОпцийОшибка");
	ИменаСобытий.Вставить("ОбслуживающаяОрганизацияПолучена", "ОбслуживающаяОрганизацияПолучена");
	ИменаСобытий.Вставить("ОбслуживающаяОрганизацияОшибка", "ОбслуживающаяОрганизацияОшибка");
	ИменаСобытий.Вставить("ИспользоватьСтатусСамозанятогоИзменено", "ИспользоватьСтатусСамозанятогоИзменено");
	Возврат ИменаСобытий;
	
КонецФункции

// Открывает журнал регистрации с отбором по имени события
//
// Параметры:
//   Владелец - ФормаКлиентскогоПриложения
//   Уровни - Массив из Строка, Неопределено - отбор по уровням
//
Процедура ОткрытьЖурналРегистрации(Владелец, Уровни = Неопределено) Экспорт
	
	Если Не ИнтеграцияСтатусСамозанятогоВызовСервера.ЕстьПравоПросмотраЖурналаРегистрации() Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Для просмотра Журнала регистрации обратитесь к администратору'"));
		Возврат;
	КонецЕсли;
	
	ОтборЖурнала = Новый Структура;
	ОтборЖурнала.Вставить("СобытиеЖурналаРегистрации",
		ИнтеграцияСтатусСамозанятогоКлиентСервер.ИмяСобытияЖурналаРегистрации());
	
	Если Уровни <> Неопределено Тогда
		ОтборЖурнала.Вставить("Уровень", Уровни);
	КонецЕсли;
	
	ЖурналРегистрацииКлиент.ОткрытьЖурналРегистрации(ОтборЖурнала, Владелец);
	
КонецПроцедуры

Процедура ПолучитьСтатусСамозанятогоЗавершение(ДлительнаяОперация, ДополнительныеПараметры) Экспорт
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Источник = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "Источник");
	Если ДлительнаяОперация.Статус <> "Ошибка" Тогда
		Оповестить(
			ИменаСобытий().СтатусСамозанятогоПолучен,
			ИзвлечьСтатусСамозанятого(ДлительнаяОперация.АдресРезультата),
			Источник);
	Иначе
		ПолучитьСтатусСамозанятогоОшибка(
			ДлительнаяОперация.КраткоеПредставлениеОшибки,
			ДлительнаяОперация.ПодробноеПредставлениеОшибки,
			Источник);
	КонецЕсли;
	
КонецПроцедуры

