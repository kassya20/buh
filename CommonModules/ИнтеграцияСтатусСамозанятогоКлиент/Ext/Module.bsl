#Область ПрограммныйИнтерфейс

// Запускает получение статуса самозанятого из сервиса в фоне.
// 
// Параметры:
//  Источник - Произвольный - используется в обработке оповещения при завершении длительной операции
//  ФормаВладелец - ФормаКлиентскогоПриложения
//  ИНН - Строка - ИНН физического лица
//  НаДату - Дата - дата в часовом поясе "Europe/Moscow", на которую нужно получить статус
//  
//  Возвращаемое значение:
//   Булево - Истина, если длительная операция запущена
//
Функция НачатьПолучениеСтатусаСамозанятого(Источник, ФормаВладелец, ИНН, НаДату) Экспорт
	
	Если Не ЗначениеЗаполнено(ИНН) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	МетодВзаимодействия = ИнтеграцияСтатусСамозанятогоКлиентСервер.ИменаМетодовВзаимодействия().СоздатьЗадание;
	ПараметрыМетода = ИнтеграцияСтатусСамозанятогоКлиентСервер.НовыеПараметрыМетодаВзаимодействия(МетодВзаимодействия);
	
	СтрокаСодержанияЗадания = ИнтеграцияСтатусСамозанятогоКлиентСервер.НоваяСтрокаСодержанияЗадания(ИНН, НаДату);
	ПараметрыМетода.СодержаниеЗадания.Добавить(СтрокаСодержанияЗадания);
	
	ДлительнаяОперация = ИнтеграцияСтатусСамозанятогоВызовСервера.ВыполнитьВФоне(
		ПараметрыМетода, ФормаВладелец.УникальныйИдентификатор);
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПолучитьСтатусСамозанятогоОшибка(
			ДлительнаяОперация.КраткоеПредставлениеОшибки,
			ДлительнаяОперация.ПодробноеПредставлениеОшибки,
			ФормаВладелец);
		Возврат Ложь;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("Источник", Источник);
	Обработчик = Новый ОписаниеОповещения("ПолучитьСтатусСамозанятогоЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	НастройкиОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ФормаВладелец);
	НастройкиОжидания.ВыводитьОкноОжидания = Ложь;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, НастройкиОжидания);
	
	Возврат (ДлительнаяОперация.Статус = "Выполняется");
	
КонецФункции

// Запускает задание получения списка опций тарифов пользователя
// 
// Параметры:
//  ФормаВладелец - ФормаКлиентскогоПриложения
// 
// Возвращаемое значение:
//  Булево - Истина, если длительная операция запущена
//
Функция ПолучитьСписокОпций(ФормаВладелец) Экспорт
	
	МетодВзаимодействия = ИнтеграцияСтатусСамозанятогоКлиентСервер.ИменаМетодовВзаимодействия().СоздатьЗапросСпискаОпций;
	ПараметрыМетода = ИнтеграцияСтатусСамозанятогоКлиентСервер.НовыеПараметрыМетодаВзаимодействия(МетодВзаимодействия);
	
	ДлительнаяОперация = ИнтеграцияСтатусСамозанятогоВызовСервера.ВыполнитьВФоне(
		ПараметрыМетода, ФормаВладелец.УникальныйИдентификатор);
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПолучитьСписокОпцийОшибка(
			ДлительнаяОперация.КраткоеПредставлениеОшибки,
			ДлительнаяОперация.ПодробноеПредставлениеОшибки,
			ФормаВладелец);
		Возврат Ложь;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("Источник", ФормаВладелец);
	Обработчик = Новый ОписаниеОповещения("ПолучитьСписокОпцийЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	НастройкиОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ФормаВладелец);
	НастройкиОжидания.ВыводитьОкноОжидания = Ложь;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, НастройкиОжидания);
	
	Возврат (ДлительнаяОперация.Статус = "Выполняется");
	
КонецФункции

// Запускает задание получения реквизитов обслуживающей организации
// 
// Параметры:
//  ФормаВладелец - ФормаКлиентскогоПриложения
// 
// Возвращаемое значение:
//  Булево - Истина, если длительная операция запущена
//
Функция ПолучитьРеквизитыОбслуживающейОрганизации(ФормаВладелец) Экспорт
	
	ДлительнаяОперация = ИнтеграцияСтатусСамозанятогоВызовСервера.ПолучитьОбслуживающуюОрганизациюВФоне(
		ФормаВладелец.УникальныйИдентификатор);
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("Источник", ФормаВладелец);
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПолучитьРеквизитыОбслуживающейОшибка(
			ДлительнаяОперация.КраткоеПредставлениеОшибки,
			ДлительнаяОперация.ПодробноеПредставлениеОшибки,
			ФормаВладелец);
		Возврат Ложь;
	КонецЕсли;
	
	Обработчик = Новый ОписаниеОповещения(
		"ПолучитьРеквизитыОбслуживающейЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	НастройкиОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ФормаВладелец);
	НастройкиОжидания.ВыводитьОкноОжидания = Ложь;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, НастройкиОжидания);
	
	Возврат (ДлительнаяОперация.Статус = "Выполняется");
	
КонецФункции

#КонецОбласти

