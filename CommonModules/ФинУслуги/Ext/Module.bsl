Функция ПараметрыПолученияПредложенийПоВидуФормы(Форма)
	
	Результат = Новый Структура;
	Результат.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
	Результат.Вставить("Банк", Справочники.Банки.ПустаяСсылка());
    Результат.Вставить("ДатаПолучения", Дата(1, 1, 1));
    Результат.Вставить("ИмяФормы", Форма.ИмяФормы);
    Результат.Вставить("КоличествоБаннеров", 0);

	Если ФинУслугиКлиентСервер.ЭтоФормаФинансыОрганизации(Форма.ИмяФормы) Тогда
		Результат.Организация = Форма.Организация;
		Результат.Банк = Форма.Банк;
		Результат.ДатаПолучения = Форма.ДатаАктуальности;
		// В Финансы организации нет реквизита "КоличествоБаннеров".
	ИначеЕсли ФинУслугиКлиентСервер.ЭтоФормаБанковскогоСчета(Форма.ИмяФормы) Тогда 
		Результат.Организация = Форма.Объект.Владелец;
		Результат.Банк = Форма.Объект.Банк;
		Результат.ДатаПолучения = ТекущаяДата();
		Результат.КоличествоБаннеров = Форма.КоличествоБаннеров;
	Иначе
		// В ИнфоПанели необходимые параметы хранятся
		// в ДанныеПлатежейСегодня
		Результат.Организация = Форма.ДанныеПлатежейСегодня.Организация;
		Результат.Банк = Форма.ДанныеПлатежейСегодня.Банк;
		Результат.ДатаПолучения = Форма.ДанныеПлатежейСегодня.ДатаАктуальности;
		Результат.КоличествоБаннеров = Форма.КоличествоБаннеров;

	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

