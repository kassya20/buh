#Область СведенияДляПредложенийБанков

Функция СведенияОбОрганизациях(ДатаАктуальности, Организация) Экспорт
	
	ДатаФактическогоНачала = УниверсальныйОбменСБанкамиФормы.ДатаФактическогоНачалаВеденияБизнеса(Организация, ДатаАктуальности);

	Результат = Новый Массив;
	
	МассивОрганизаций = Обработки.ФинансыОрганизации.МассивОрганизаций(Организация);
	РеквизитыОрганизаций = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(МассивОрганизаций, 
			"ЮридическоеФизическоеЛицо, ИндивидуальныйПредприниматель, ИностраннаяОрганизация, ДатаРегистрации, КодОКВЭД2, КодОКОПФ, ИНН");
	
	КонтактнаяИнформацияОбъектов = УправлениеКонтактнойИнформациейБП.КонтактнаяИнформацияОбъектовНаДату(
			МассивОрганизаций, Неопределено,
			ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации),
			ДатаАктуальности);

	Для Каждого ЭлементМассива Из МассивОрганизаций Цикл
		
		РеквизитыОрганизации = РеквизитыОрганизаций.Получить(ЭлементМассива);
		Если РеквизитыОрганизации = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		// Заполним сведения о клиенте для подбора банков по текущим условиям.
		Сведения = Обработки.ФинансыОрганизации.НовыеСведенияОбОрганизации();
		Сведения.Организация               = ЭлементМассива;    
		Сведения.ИНН               = РеквизитыОрганизации.ИНН;
		Сведения.ЮридическоеФизическоеЛицо = РеквизитыОрганизации.ЮридическоеФизическоеЛицо;
		Сведения.ДатаАктуальности = ДатаАктуальности;

		Если РеквизитыОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
			ФизическоеЛицо = РеквизитыОрганизации.ИндивидуальныйПредприниматель;
			Гражданство = ГражданствоФизическогоЛица(ФизическоеЛицо);
			Сведения.Нерезидент = Гражданство <> Справочники.СтраныМира.Россия;
			Сведения.ДатаРождения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФизическоеЛицо, "ДатаРождения");
			Сведения.ВозрастИП = ОбщегоНазначенияБПКлиентСервер.КоличествоЦелыхЛет(Сведения.ДатаРождения, ДатаАктуальности);
		Иначе
			Сведения.Нерезидент  = РеквизитыОрганизации.ИностраннаяОрганизация;
		КонецЕсли;

		Сведения.ДатаРегистрации   = РеквизитыОрганизации.ДатаРегистрации;
		Сведения.СрокОтДатыРегистрации = ОбщегоНазначенияБПКлиентСервер.КоличествоЦелыхМесяцев(
			Сведения.ДатаРегистрации, ДатаАктуальности);
		Сведения.КодОКВЭД2         = СокрЛП(РеквизитыОрганизации.КодОКВЭД2);
		Сведения.КодОКОПФ          = СокрЛП(РеквизитыОрганизации.КодОКОПФ);
		
		КонтактнаяИнформацияОбъекта = КонтактнаяИнформацияОбъектов.Найти(ЭлементМассива, "Объект");
		Если ЗначениеЗаполнено(КонтактнаяИнформацияОбъекта) Тогда
			Сведения.ЮрАдресОрганизации = КонтактнаяИнформацияОбъекта.Значение;
		КонецЕсли;
		
		Сведения.ДатаФактическогоНачалаВеденияБизнеса = ДатаФактическогоНачала;
		Сведения.СрокФактическогоВеденияБизнеса = 
			ОбщегоНазначенияБПКлиентСервер.КоличествоЦелыхМесяцев(ДатаФактическогоНачала, ДатаАктуальности);

		КодРегиона = "";
		Если ЗначениеЗаполнено(Сведения.ЮрАдресОрганизации) Тогда
			СведенияОбАдресе = РаботаСАдресами.СведенияОбАдресе(Сведения.ЮрАдресОрганизации);
			КодРегиона = СведенияОбАдресе.КодРегиона;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(КодРегиона) Тогда
			// Если из адреса определить код региона не получилось, то ищем через регистрацию в налоговом органе.
			ОсновнаяРегистрацияВНалоговомОргане = Справочники.Организации.РегистрацияВНалоговомОрганеНаДату(
				ЭлементМассива, ДатаАктуальности);
			Если ЗначениеЗаполнено(ОсновнаяРегистрацияВНалоговомОргане) Тогда
				РеквизитыРегистрации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ОсновнаяРегистрацияВНалоговомОргане, "КодРегиона");
				Если ЗначениеЗаполнено(РеквизитыРегистрации.КодРегиона) Тогда
					// В настройках сервиса код региона задан в виде строки с лидирующем нулем.
					КодРегиона = Формат(РеквизитыРегистрации.КодРегиона, "ЧЦ=2;ЧВН=");
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Сведения.КодРегиона = СокрЛП(КодРегиона);
		Сведения.ДополнительныеСвойства.Вставить("ХешСуммаИНН", ХешСуммаСтроки(Сведения.ИНН));
		
		Результат.Добавить(Сведения);
		
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

Процедура ОтправитьСтатистику(Форма, УникальныйИдентификатор) Экспорт
	
	Если ОбщегоНазначения.РежимОтладки() 
		Или БлокировкаРаботыСВнешнимиРесурсами.РаботаСВнешнимиРесурсамиЗаблокирована() Тогда
		Форма.ТаблицаСтатистики.Очистить();
	КонецЕсли;
	
	МассивСтатистики = МассивСтатистики(Форма.ТаблицаСтатистики);
	Если МассивСтатистики.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	СтруктураДанныхСтатистики = Новый Структура;
	СтруктураДанныхСтатистики.Вставить("ПоказыИПереходы", МассивСтатистики);
	
	СервисОбменаСБанками = Перечисления.СервисыОбменаСБанками.ФинУслуги; 
	// В хранилище храним результат отправки статистики. 
	// Если результат отправки неуспешный, статистика накапливается,
	// в противном случае - очищается
	Форма.АдресХранилищаОтправкаСтатистики = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);

	НачатьОтправкуСтатистикиВСервис(СервисОбменаСБанками, Форма, СтруктураДанныхСтатистики);
		
КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьИсполненныеПлатежиСегодня(ДанныеПлатежей) Экспорт
		
	Запрос = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВЫРАЗИТЬ(ХозрасчетныйОбороты.Субконто1 КАК Справочник.БанковскиеСчета).Банк КАК Банк,
	|	ХозрасчетныйОбороты.СуммаОборотДт КАК Приход,
	|	ХозрасчетныйОбороты.СуммаОборотКт КАК Расход,
	|	ХозрасчетныйОбороты.Организация КАК Организация
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоДня,
	|			&КонецДня,
	|			Авто,
	|			Счет В (&СчетаУчета),
	|			,
	|			&ОтборПоОрганизации
	|				И &ОтборПоБанковскомуСчету,
	|			,
	|			) КАК ХозрасчетныйОбороты");
	
	Запрос.УстановитьПараметр("НачалоДня", НачалоДня(ДанныеПлатежей.ДатаАктуальности));
	Запрос.УстановитьПараметр("КонецДня", КонецДня(ДанныеПлатежей.ДатаАктуальности));
		 
	ИзменитьТекстЗапросаПоОрганизации(Запрос, ДанныеПлатежей.Организация);
	ИзменитьТекстЗапросаПоБанковскомуСчету(Запрос, ДанныеПлатежей.БанковскийСчет);
	
	МассивСчетов = УчетДенежныхСредствПовтИсп.ПолучитьСчетаССубконтоБанковскиеСчета();
	
	Запрос.УстановитьПараметр("СчетаУчета", МассивСчетов);
		
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);

	ДанныеПлатежей.ПлатежиСегодняПриход = 0;
	ДанныеПлатежей.ПлатежиСегодняРасход = 0;

	ТаблицаОбороты = Результат.Выгрузить();
	ПоместитьВоВременноеХранилище(ТаблицаОбороты, ДанныеПлатежей.АдресПлатежиСегодняПоБанкам);
	ДанныеПлатежей.ПлатежиСегодняПриход = ТаблицаОбороты.Итог("Приход");
	ДанныеПлатежей.ПлатежиСегодняРасход = ТаблицаОбороты.Итог("Расход");
		
КонецПроцедуры

Процедура ИзменитьТекстЗапросаПоОрганизации(Запрос, Организация) Экспорт
	
	МассивДоступныхОрганизаций = ОбщегоНазначенияБПВызовСервераПовтИсп.ВсеОрганизацииДанныеКоторыхДоступныПоRLS(Ложь);

	Если ЗначениеЗаполнено(Организация) И МассивДоступныхОрганизаций.Найти(Организация) <> Неопределено Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоОрганизации", "Организация = &Организация"); 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборБанковскогоСчетаПоОрганизации", "БанковскиеСчета.Владелец = &Организация");
		Запрос.УстановитьПараметр("Организация", Организация);
		
	ИначеЕсли Не ЗначениеЗаполнено(Организация) Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоОрганизации", "Организация В (&Организации)");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборБанковскогоСчетаПоОрганизации", "БанковскиеСчета.Владелец В (&Организации)");
        Запрос.УстановитьПараметр("Организации", МассивДоступныхОрганизаций); 
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоОрганизации", "Ложь");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборБанковскогоСчетаПоОрганизации", "Ложь");

	КонецЕсли;
	
КонецПроцедуры

Процедура ИзменитьТекстЗапросаПоБанковскомуСчету(Запрос, БанковскийСчет) Экспорт
	
	Если ЗначениеЗаполнено(БанковскийСчет) Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоБанковскомуСчету", "Субконто1 = &БанковскийСчет"); 
		Запрос.УстановитьПараметр("БанковскийСчет", БанковскийСчет);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоБанковскомуСчету", "Истина");
	
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьТаблицыПлатежей(ДанныеПлатежейСегодня, АдресХранилища) Экспорт
	
		
	ПлатежиПоДатам = ПлатежиПоДатам(АдресХранилища);
	
	Если ПлатежиПоДатам = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ДатаПлатежаСегодня = НачалоДня(ДанныеПлатежейСегодня.ДатаАктуальности);
    ПлатежиКалендаряСегодня = ПлатежиКалендаряСегодня(ПлатежиПоДатам, ДатаПлатежаСегодня);

	Запрос = Новый Запрос;
	Запрос.Текст = ЗапросТаблицыВнеплановыхПлатежей();
	
	Запрос.УстановитьПараметр("ДатаПлатежаНачало", ДатаПлатежаСегодня - 86400 * 9);
	Запрос.УстановитьПараметр("ДатаПлатежаКонец", КонецДня(ДанныеПлатежейСегодня.ДатаАктуальности));
	Запрос.УстановитьПараметр("ПлатежиКалендаряСегодня", ПлатежиКалендаряСегодня);
	Запрос.УстановитьПараметр("Состояние", ФинУслугиКлиентСервер.СостоянияПлатежныхПоручений());
			
	Если ЗначениеЗаполнено(ДанныеПлатежейСегодня.Организация) Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоОрганизации", "ПлатежноеПоручение.Организация = &Организация");
		Запрос.УстановитьПараметр("Организация", ДанныеПлатежейСегодня.Организация);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОтборПоОрганизации", "Истина");
	
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	ВнеплановыеПлатежи = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
		
	ТаблицаПлатежныхПоручений = ВнеплановыеПлатежи.Скопировать();
	ВнеплановыеПлатежи.Свернуть("БанковскийСчет, Банк", "Сумма");

    ПоместитьВоВременноеХранилище(ВнеплановыеПлатежи, ДанныеПлатежейСегодня.АдресВнеплановыеПлатежиСегодня);
    ПоместитьВоВременноеХранилище(ТаблицаПлатежныхПоручений, ДанныеПлатежейСегодня.АдресПлатежныеПоручения);
	
	ДанныеПлатежейСегодня.ПланируемыеПлатежиСегодняПриход = ПлатежиКалендаряСегодня.Итог("Приход");
	ДанныеПлатежейСегодня.ПланируемыеПлатежиСегодняРасход =  ПлатежиКалендаряСегодня.Итог("Расход"); 
			
	// Для формы Финансы организации заполняется таблица платежей по дням, 
	Если ЗначениеЗаполнено(ДанныеПлатежейСегодня.АдресПланируемыеПлатежиПоДням) Тогда
		ПлатежиПоДатам.Свернуть("ДатаПлатежа", "Приход, Расход");
		ПлатежиПоДатам.Сортировать("ДатаПлатежа");
		ПланируемыеПлатежи = ПланируемыеПлатежиПятьДней(ПлатежиПоДатам, ДатаПлатежаСегодня);
		ДополнитьТаблицуДатами(ПланируемыеПлатежи, ДанныеПлатежейСегодня.ДатаАктуальности); 
		ПоместитьВоВременноеХранилище(ПланируемыеПлатежи, ДанныеПлатежейСегодня.АдресПланируемыеПлатежиПоДням);
	КонецЕсли;
	
КонецПроцедуры

Функция ИспользоватьПланированиеПлатежей() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ОтПокупателей", ПолучитьФункциональнуюОпцию("ИспользоватьПланированиеПлатежейОтПокупателей"));
	Результат.Вставить("Поставщикам", ПолучитьФункциональнуюОпцию("ИспользоватьПланированиеПлатежейПоставщикам"));

	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьДанныеПлатежиСегодня(Форма, РеквизитыБанковскогоСчета, ПолучитьДанныеПлатежногоКалендаря) Экспорт
	
	ТекущаяДата = ТекущаяДатаСеанса();
	ДатаАктуальности = 
		?(ЗначениеЗаполнено(Форма.ОтборДатаОтбора) И Форма.ОтборДатаОтбораИспользование, Форма.ОтборДатаОтбора, ТекущаяДата);
	Организация = 
			?(ЗначениеЗаполнено(Форма.ОтборОрганизация) И Форма.ОтборОрганизацияИспользование, Форма.ОтборОрганизация, Неопределено);
			
	ГоризонтПланирования = ФинУслугиКлиентСервер.ДнейПланированияКалендаряДляИнфопанели(ДатаАктуальности, ТекущаяДата);
	
	Если ПолучитьДанныеПлатежногоКалендаря Тогда
			
		Форма.ДлительнаяОперацияПлатежныйКалендарь = Новый Структура();
		Форма.ДлительнаяОперацияПлатежныйКалендарь.Вставить("Имя", "");
		Форма.ДлительнаяОперацияПлатежныйКалендарь.Вставить("ДлительнаяОперация");

		НачатьЗаполнениеКалендаряНаСервере(Форма.ДлительнаяОперацияПлатежныйКалендарь, 
				Форма.ОтборОрганизация, Форма.УникальныйИдентификатор, ГоризонтПланирования);
	КонецЕсли;
			
	Если Форма.ДанныеПлатежейСегодня = Неопределено Тогда
		
		Форма.ДанныеПлатежейСегодня = НовыйДанныеПлатежейСегодня();
		Форма.ДанныеПлатежейСегодня.АдресПлатежныеПоручения = 
			ПоместитьВоВременноеХранилище(Неопределено, Форма.УникальныйИдентификатор);
		Форма.ДанныеПлатежейСегодня.АдресВнеплановыеПлатежиСегодня = 
			ПоместитьВоВременноеХранилище(Неопределено, Форма.УникальныйИдентификатор);
        Форма.ДанныеПлатежейСегодня.АдресПлатежиСегодняПоБанкам = 
			ПоместитьВоВременноеХранилище(Неопределено, Форма.УникальныйИдентификатор);
			
	КонецЕсли;
	
	Форма.ДанныеПлатежейСегодня.Организация = Организация;
	Форма.ДанныеПлатежейСегодня.Банк = РеквизитыБанковскогоСчета.Банк; 
	Форма.ДанныеПлатежейСегодня.БанковскийСчет = РеквизитыБанковскогоСчета.БанковскийСчет;
	Форма.ДанныеПлатежейСегодня.ДатаАктуальности = ДатаАктуальности;
    Форма.ДанныеПлатежейСегодня.ИнфоПанель = Истина;
	
	Форма.Элементы.ДатаПлатежиСегодня.Заголовок = Формат(ДатаАктуальности, "ДФ='дддд, дд ММММ ЧЧ:мм'");
	
	ЗаполнитьИсполненныеПлатежиСегодня(Форма.ДанныеПлатежейСегодня);
		
КонецПроцедуры

Функция ИмяНастройкиИнфоПанель()
	
	Возврат "ИнфоПанель";
	
КонецФункции

Функция ИмяКлючНастройкиЗакрытиеИнфоПанель()
	
	Возврат "ИнфоПанельЗакрытие";
	
КонецФункции

Функция ПоказыватьИнфоПанель(ИмяПользователя) Экспорт
	
	Результат = Истина;
	ПараметрыЗакрытия = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
		ИмяНастройкиИнфоПанель(),
		ИмяКлючНастройкиЗакрытиеИнфоПанель(), , , ИмяПользователя);
		
	Если Не ПараметрыЗакрытия = Неопределено Тогда
			
		ДатаЗакрытия = ПараметрыЗакрытия.ДатаЗакрытия;
		ПериодЗакрытия = 86400 * 30;
		
		Если ТекущаяДатаСеанса() - ДатаЗакрытия >= ПериодЗакрытия Тогда
			ОбщегоНазначения.ХранилищеОбщихНастроекУдалить(ИмяНастройкиИнфоПанель(), 
				ИмяКлючНастройкиЗакрытиеИнфоПанель(), ИмяПользователя);
		Иначе
			Результат = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Сохраняет решение пользователя закрыть инфопанель в хранилище
// общих настроек.
// 
// Параметры:
//  ИмяПользователя - Строка - см. ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить.
//
Процедура СохранитьЗакрытиеИнфоПанели(ИмяПользователя) Экспорт
	
	ПоказыватьИнфоПанель = ПоказыватьИнфоПанель(ИмяПользователя);
	
	Если ПоказыватьИнфоПанель Тогда
		
		ПараметрыЗакрытия = ПараметрыЗакрытияИнфоПанель();
		ПараметрыЗакрытия.ДатаЗакрытия = ТекущаяДатаСеанса();
		
		ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(
			ИмяНастройкиИнфоПанель(),
			ИмяКлючНастройкиЗакрытиеИнфоПанель(),
			ПараметрыЗакрытия, , ИмяПользователя);
		
	КонецЕсли;
		
КонецПроцедуры

// Проверяет наличие данных о решении пользователя закрыть инфопанель и удаляет их.
// 
// Параметры:
//  ИмяПользователя - Строка - см. ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить.
//
Процедура ПроверитьИУдалитьДанныеОЗакрытииИнфоПанели(ИмяПользователя) Экспорт
	
	Если ПоказыватьИнфоПанель(ИмяПользователя) Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначения.ХранилищеОбщихНастроекУдалить(ИмяНастройкиИнфоПанель(), 
		ИмяКлючНастройкиЗакрытиеИнфоПанель(), ИмяПользователя);
	
КонецПроцедуры

Процедура ПриСозданииНаСервереИнфоПанель(Форма) Экспорт
	
	Если ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
    	Форма.Элементы.ГруппаПанельИнформации.Видимость = Ложь; 
		Форма.Элементы.ПоказатьПанельИнформации.Видимость = Ложь; 
		Возврат;
	КонецЕсли;
				
	ДополнительныеПараметрыДепозитов = 
		ОбменСБанкамиДепозитыСлужебныйКлиентСервер.ДополнительныеПараметрыДепозитов(Форма); 
	ДоступенФункционалДепозиты = ДополнительныеПараметрыДепозитов <> Неопределено;
	
	Если ДоступенФункционалДепозиты Тогда
		ТекущаяОрганизация = ОбщегоНазначенияКлиентСервер.ПолучитьРеквизитФормыПоПути(Форма, 
			ДополнительныеПараметрыДепозитов.ПутьКРеквизитуОрганизация);
	КонецЕсли;
		
	НастройкаПоказыватьИнфоПанель = НастройкаПоказыватьИнфоПанель();
	Форма.Элементы.ГруппаПанельИнформации.Видимость = НастройкаПоказыватьИнфоПанель;
	
	Если НастройкаПоказыватьИнфоПанель Тогда
		ОбновитьСведенияОСервисеФинУслуги(Форма);
	КонецЕсли;
	
	ПоказыватьДепозиты = ОбменСБанкамиДепозитыВызовСервера.ПоказыватьПанельРасчетаДепозитов()	
		И ДоступенФункционалДепозиты 
		И ЗначениеЗаполнено(ТекущаяОрганизация);
		
	Если ПоказыватьДепозиты Тогда
		Форма.ВариантПанели = "ДепозитныйКалькулятор";	
	Иначе
		Форма.ВариантПанели = "Платежи"; 
	КонецЕсли;
	
	Форма.Элементы.ГруппаПлатежиИРасчеты.Видимость = Не ПоказыватьДепозиты;
	Форма.Элементы.ВариантПанели.Видимость = ДоступенФункционалДепозиты; 
    Форма.Элементы.ЗаголовокПлатежи.Видимость = Не ДоступенФункционалДепозиты; 

КонецПроцедуры

Процедура ОбновитьСведенияОСервисеФинУслуги(Форма) Экспорт
	
	СервисОбменаСБанками = Перечисления.СервисыОбменаСБанками.ФинУслуги;
	Форма.СведенияОДлительнойОперации = Новый Структура();
	Форма.СведенияОДлительнойОперации.Вставить("Имя", "");
	Форма.СведенияОДлительнойОперации.Вставить("ДлительнаяОперация");
	Форма.СведенияОДлительнойОперацииСтатистика = Новый Структура();
	Форма.СведенияОДлительнойОперацииСтатистика.Вставить("Имя", "");
	Форма.СведенияОДлительнойОперацииСтатистика.Вставить("ДлительнаяОперация");
	Форма.СведенияОСервисе = УниверсальныйОбменСБанками.СведенияОСервисе(СервисОбменаСБанками);
	ЭтоВебКлиент = ОбщегоНазначения.ЭтоВебКлиент();
	Форма.КоличествоБаннеров = ФинУслугиКлиентСервер.МаксимальноеКоличествоБаннеров(Форма.ИмяФормы, ВысотаЭкрана(), ЭтоВебКлиент);
	
	Если Форма.КоличествоБаннеров > 0 Тогда
		НачатьОбновлениеДанныхСервиса(СервисОбменаСБанками, Форма);
	КонецЕсли;
	
КонецПроцедуры

