	Результат.Вставить("Банк", Справочники.Банки.ПустаяСсылка()); 
	Результат.Вставить("БанковскийСчет", Справочники.БанковскиеСчета.ПустаяСсылка());
	Результат.Вставить("ДатаАктуальности", Дата(1, 1, 1));
	Результат.Вставить("МассивПлатежныхПоручений", Новый Массив);
    Результат.Вставить("ПланируемыеПлатежиСегодняПриход", 0);   
	Результат.Вставить("ПланируемыеПлатежиСегодняРасход", 0);
	Результат.Вставить("ПлатежиСегодняПриход", 0);   
	Результат.Вставить("ПлатежиСегодняРасход", 0);
   	Результат.Вставить("ВнеплановыеПлатежиСегодняРасход", 0); 
	Результат.Вставить("АдресПлатежныеПоручения", "");
	Результат.Вставить("АдресПланируемыеПлатежиПоДням", "");
	Результат.Вставить("АдресВнеплановыеПлатежиСегодня", "");
	Результат.Вставить("АдресПлатежиСегодняПоБанкам", "");  
    Результат.Вставить("Инфопанель", Ложь);

    Возврат Результат;
	
