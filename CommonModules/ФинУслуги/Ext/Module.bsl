Процедура ВывестиПлатежиСегодня(Форма) Экспорт
	
	ОпцияПлатежи = Ложь;
	ЗаполнитьДанныеВнеплановыхПлатежей(Форма.ДанныеПлатежейСегодня, ОпцияПлатежи);  

	ФинУслугиКлиентСервер.УстановитьВидимостьДанныхПлатежи(Форма, Истина, ОпцияПлатежи);
	
	ФорматСумм = "ЧДЦ=2; ЧН=0,00";
	ДанныеПлатежейСегодня = Форма.ДанныеПлатежейСегодня;
	Элементы = Форма.Элементы;
	
	СуммаПолучено = ДанныеПлатежейСегодня.ПлатежиСегодняПриход;
	СуммаОсталосьПолучить = ДанныеПлатежейСегодня.ПланируемыеПлатежиСегодняПриход;
	СуммаКПоступлению = СуммаПолучено + СуммаОсталосьПолучить;
	СуммаИсполнено = ДанныеПлатежейСегодня.ПлатежиСегодняРасход;
	СуммаКОплате = СуммаИсполнено + ДанныеПлатежейСегодня.ПланируемыеПлатежиСегодняРасход 
		+ ДанныеПлатежейСегодня.ВнеплановыеПлатежиСегодняРасход;
			
	Элементы.СуммаПолучено.Заголовок = Формат(СуммаПолучено, ФорматСумм);
	Гиперссылка = СуммаПолучено <> 0;
	Элементы.СуммаПолучено.Гиперссылка = Гиперссылка;
	
	Элементы.СуммаОсталосьПолучить.Заголовок = Формат(СуммаОсталосьПолучить, ФорматСумм);
	Гиперссылка = СуммаОсталосьПолучить <> 0;
	Элементы.СуммаОсталосьПолучить.Гиперссылка = Гиперссылка;

	Элементы.СуммаКПоступлению.Заголовок = Формат(СуммаКПоступлению, ФорматСумм);
	
	Элементы.СуммаИсполнено.Заголовок = Формат(СуммаИсполнено, ФорматСумм);
	Гиперссылка = СуммаИсполнено <> 0;
	Элементы.СуммаИсполнено.Гиперссылка = Гиперссылка;

	Элементы.СуммаКОплате.Заголовок = Формат(СуммаКОплате, ФорматСумм);

	Элементы.СуммаПланируемыеПлатежи.Заголовок = Формат(ДанныеПлатежейСегодня.ПланируемыеПлатежиСегодняРасход, ФорматСумм);
	Гиперссылка = ДанныеПлатежейСегодня.ПланируемыеПлатежиСегодняРасход <> 0;
	Элементы.СуммаПланируемыеПлатежи.Гиперссылка = Гиперссылка;

	Элементы.СуммаВнеплановыеПлатежи.Заголовок = Формат(ДанныеПлатежейСегодня.ВнеплановыеПлатежиСегодняРасход, ФорматСумм);
	Гиперссылка = ДанныеПлатежейСегодня.ВнеплановыеПлатежиСегодняРасход <> 0;
	Элементы.СуммаВнеплановыеПлатежи.Гиперссылка = Гиперссылка;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеВнеплановыхПлатежей(ДанныеПлатежейСегодня, ОпцияПлатежи) Экспорт
	
	ОпцияПлатежи = ИспользоватьПланированиеПлатежей();
	
	ОтборБанковскийСчет = Новый Структура("БанковскийСчет", ДанныеПлатежейСегодня.БанковскийСчет);
    ОтборБанк = Новый Структура("Банк", ДанныеПлатежейСегодня.Банк);
	
	ДанныеПлатежейСегодня.МассивПлатежныхПоручений = Новый Массив;
	ДанныеПлатежейСегодня.ВнеплановыеПлатежиСегодняРасход = 0;
	
	Если ЭтоАдресВременногоХранилища(ДанныеПлатежейСегодня.АдресВнеплановыеПлатежиСегодня) Тогда
		ВнеплановыеПлатежи = ПолучитьИзВременногоХранилища(ДанныеПлатежейСегодня.АдресВнеплановыеПлатежиСегодня);
	Иначе
		Возврат;
	КонецЕсли;
	
	Если ЭтоАдресВременногоХранилища(ДанныеПлатежейСегодня.АдресПлатежныеПоручения) Тогда
		ТаблицаПлатежныхПоручений = ПолучитьИзВременногоХранилища(ДанныеПлатежейСегодня.АдресПлатежныеПоручения); 
	Иначе
		Возврат;
	КонецЕсли;
	
	Если ТаблицаПлатежныхПоручений = Неопределено Тогда
		Возврат;
	Конецесли;
	
	Если ЗначениеЗаполнено(ДанныеПлатежейСегодня.БанковскийСчет) Тогда
		ВнеплановыеПлатежи = ВнеплановыеПлатежи.Скопировать(ОтборБанковскийСчет);
		ДанныеПлатежейСегодня.МассивПлатежныхПоручений = 
			ТаблицаПлатежныхПоручений.Скопировать(ОтборБанковскийСчет).ВыгрузитьКолонку("ПлатежноеПоручение")
	ИначеЕсли ЗначениеЗаполнено(ДанныеПлатежейСегодня.Банк) Тогда
		ВнеплановыеПлатежи = ВнеплановыеПлатежи.Скопировать(ОтборБанк); 
		ДанныеПлатежейСегодня.МассивПлатежныхПоручений = 
			ТаблицаПлатежныхПоручений.Скопировать(ОтборБанк).ВыгрузитьКолонку("ПлатежноеПоручение");
	Иначе
		ДанныеПлатежейСегодня.МассивПлатежныхПоручений = 
			ТаблицаПлатежныхПоручений.ВыгрузитьКолонку("ПлатежноеПоручение");	
	КонецЕсли;
	
	ДанныеПлатежейСегодня.ВнеплановыеПлатежиСегодняРасход = ВнеплановыеПлатежи.Итог("Сумма");

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет наличие данных о закрытии пользователем панели Платежи.
// см. ФинУслуги.ПоказыватьИнфоПанель.
//
// Возвращаемое значение:
//  Булево - Ложь - если медленный режим работы, Истина - если с момента закрытия прошло 30 дней
//  или пользователь не закрывал панель.
//
Функция НастройкаПоказыватьИнфоПанель()
	
	ЭтоМедленныйРежимРаботы = ОбщегоНазначенияБП.ЭтоМедленныйРежимРаботы();
	
	Если ЭтоМедленныйРежимРаботы Тогда
		Возврат Ложь;
	КонецЕсли;

	ИмяПользователя = ИмяПользователя();
	Возврат ПоказыватьИнфоПанель(ИмяПользователя);
	
КонецФункции

Функция ПланируемыеПлатежиПятьДней(ПлатежиПоДатам, ДатаПлатежаСегодня) 
		
	ПодходящиеСтроки = Новый Массив;
		
	Для Каждого СтрокаПлатежей Из ПлатежиПоДатам Цикл 
		Если СтрокаПлатежей.ДатаПлатежа <> ДатаПлатежаСегодня Тогда
			ПодходящиеСтроки.Добавить(СтрокаПлатежей);
			Если ПодходящиеСтроки.Количество() = 5 Тогда
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Возврат ПлатежиПоДатам.Скопировать(ПодходящиеСтроки);
		
КонецФункции

Функция ПлатежиПоДатам(АдресХранилища)
	
	РезультатВыполнения = ПолучитьИзВременногоХранилища(АдресХранилища);
	
	Если ТипЗнч(РезультатВыполнения) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ПлатежиПоДатам = РезультатВыполнения.Платежи;
	ПлатежиПоДатам.Свернуть("НомерРаздела, Документ, ДатаПлатежа", "Сумма"); 
	ТипизироватьТаблицуПлатежей(ПлатежиПоДатам);
	
	НоваяТаблица = ПлатежиПоДатам.СкопироватьКолонки();
	НоваяТаблица.Колонки.Добавить("Приход", ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	НоваяТаблица.Колонки.Добавить("Расход", ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	
    НомераРазделовПоступлений = Обработки.ПлатежныйКалендарь.НомераРазделовДляГруппировкиПлатежей(Истина, Истина);
	НомераРазделовСписаний = Обработки.ПлатежныйКалендарь.НомераРазделовДляГруппировкиПлатежей(Истина);

	Для Каждого Строка Из ПлатежиПоДатам Цикл
		
		Если Строка.Сумма = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТаблицы = НоваяТаблица.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Строка); 
		Если НомераРазделовПоступлений.Найти(СтрокаТаблицы.НомерРаздела) <> Неопределено Тогда
			СтрокаТаблицы.Приход = СтрокаТаблицы.Сумма;
		КонецЕсли; 
		Если НомераРазделовСписаний.Найти(СтрокаТаблицы.НомерРаздела) <> Неопределено Тогда
			Если СтрокаТаблицы.Сумма < 0 Тогда
				СтрокаТаблицы.Расход = -СтрокаТаблицы.Сумма; 
			Иначе
				СтрокаТаблицы.Расход = СтрокаТаблицы.Сумма; 
			КонецЕсли;
		КонецЕсли;
					
	КонецЦикла;
	
	Возврат НоваяТаблица;
	
КонецФункции

Функция ПлатежиКалендаряСегодня(ПлатежиПоДатам, ДатаПлатежа)
	
	ПлатежиПоДатам.Индексы.Добавить("ДатаПлатежа");
	
	Отбор = Новый Структура("ДатаПлатежа", ДатаПлатежа); 
	ПлатежиКалендаряСегодня = ПлатежиПоДатам.Скопировать(Отбор);
	
	Возврат ПлатежиКалендаряСегодня;
	
КонецФункции

Функция ЗапросТаблицыВнеплановыхПлатежей()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ПлатежиКалендаряСегодня.ДатаПлатежа КАК ДатаПлатежа,
		|	ПлатежиКалендаряСегодня.Сумма КАК Сумма,
		|	ПлатежиКалендаряСегодня.Документ КАК Документ,
		|	ПлатежиКалендаряСегодня.НомерРаздела КАК НомерРаздела
		|ПОМЕСТИТЬ ВТ_ПлатежиКалендаряСегодня
		|ИЗ
		|	&ПлатежиКалендаряСегодня КАК ПлатежиКалендаряСегодня
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Документ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПлатежноеПоручение.ДокументОснование КАК ДокументОснование,
		|	ПлатежноеПоручение.Ссылка КАК ПлатежноеПоручение,
		|	ПлатежноеПоручение.СуммаДокумента КАК Сумма,
		|	ПлатежноеПоручение.СчетОрганизации КАК БанковскийСчет,
		|	Банки.Ссылка КАК Банк
		|ПОМЕСТИТЬ ПодготовленныеПлатежи
		|ИЗ
		|	Документ.ПлатежноеПоручение КАК ПлатежноеПоручение
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Банки КАК Банки
		|		ПО ПлатежноеПоручение.СчетОрганизации.Банк = Банки.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияБанковскихДокументов КАК СостоянияБанковскихДокументов
		|		ПО (СостоянияБанковскихДокументов.СсылкаНаОбъект = ПлатежноеПоручение.Ссылка)
		|			И (СостоянияБанковскихДокументов.Организация = ПлатежноеПоручение.Организация)
		|			И (СостоянияБанковскихДокументов.Состояние В (&Состояние))
		|ГДЕ
		|	ПлатежноеПоручение.Дата МЕЖДУ &ДатаПлатежаНачало И &ДатаПлатежаКонец
		|	И ПлатежноеПоручение.ПометкаУдаления = ЛОЖЬ
		|	И &ОтборПоОрганизации
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ДокументОснование
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПодготовленныеПлатежи.ПлатежноеПоручение КАК ПлатежноеПоручение,
		|	ПодготовленныеПлатежи.БанковскийСчет КАК БанковскийСчет,
		|	ПодготовленныеПлатежи.Банк КАК Банк,
		|	СУММА(ПодготовленныеПлатежи.Сумма) КАК Сумма
		|ИЗ
		|	ПодготовленныеПлатежи КАК ПодготовленныеПлатежи
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПлатежиКалендаряСегодня КАК ВТ_ПлатежиКалендаряСегодня
		|		ПО (ВТ_ПлатежиКалендаряСегодня.Документ = ПодготовленныеПлатежи.ДокументОснование)
		|ГДЕ
		|	ВТ_ПлатежиКалендаряСегодня.Документ ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	ПодготовленныеПлатежи.ПлатежноеПоручение,
		|	ПодготовленныеПлатежи.БанковскийСчет,
		|	ПодготовленныеПлатежи.Банк";
	
		
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПараметрыЗакрытияИнфоПанель()
	
	Результат = Новый Структура();
	Результат.Вставить("ДатаЗакрытия", Дата(1, 1, 1));
	
	Возврат Результат;
	
КонецФункции

Процедура ДополнитьТаблицуДатами(ПланируемыеПлатежи, ДатаАктуальности)
	
	ДлинаСуток = 86400;
	КоличествоЗаполненныхДней = ПланируемыеПлатежи.Количество();
	Если КоличествоЗаполненныхДней = 0 Тогда
		ПоследнийЗаполненныйДень = ДатаАктуальности;
	Иначе
		ПоследнийЗаполненныйДень = ПланируемыеПлатежи[КоличествоЗаполненныхДней - 1].ДатаПлатежа;
	КонецЕсли;
	
	МаксимальноеКоличествоДней = 5; 
	ДобавитьДней = МаксимальноеКоличествоДней - КоличествоЗаполненныхДней;
		
	Для НомерДня = 1 По ДобавитьДней Цикл
		
		СтрокаПлатежиПоДням = ПланируемыеПлатежи.Добавить();
		ДатаПлатежа = ПоследнийЗаполненныйДень + ДлинаСуток * НомерДня;
		СтрокаПлатежиПоДням.ДатаПлатежа = ДатаПлатежа;

	КонецЦикла;

КонецПроцедуры

Процедура ТипизироватьТаблицуПлатежей(ПлатежиПоДатам)
	
	ПлатежиПоДатам.Колонки.Добавить("ТипизированныйДокумент", Документы.ТипВсеСсылки());
	МассивДокументов = ПлатежиПоДатам.ВыгрузитьКолонку("Документ");
	ПлатежиПоДатам.ЗагрузитьКолонку(МассивДокументов, "ТипизированныйДокумент");
	ПлатежиПоДатам.Колонки.Удалить("Документ");
	ПлатежиПоДатам.Колонки.ТипизированныйДокумент.Имя = "Документ"; // Переименовываем колонку
	
КонецПроцедуры

Функция МассивСтатистики(ТаблицаСтатистики)
	
	Статистика = ТаблицаСтатистики.Выгрузить();
	Если ТаблицаСтатистики.Итог("Показы") = 0 Тогда
		Статистика.Свернуть("Банк, ИДУслуги, ИДРекламы, ИмяФормы", "Переходы");
	ИначеЕсли ТаблицаСтатистики.Итог("Переходы") = 0 Тогда
		Статистика.Свернуть("Банк, ИДУслуги, ИДРекламы, ИмяФормы", "Показы"); 
	Иначе
		Статистика.Свернуть("Банк, ИДУслуги, ИДРекламы, ИмяФормы", "Показы, Переходы"); 
	КонецЕсли;
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(Статистика);
	
КонецФункции

Процедура ОбработатьХарактеристику(Характеристика, УслугаБанка)
	
	Если Характеристика.Характеристика <> Перечисления.ХарактеристикиСервисаФинУслуги.ГруппыКонтрагентов
		И Характеристика.Характеристика <> Перечисления.ХарактеристикиСервисаФинУслуги.ГруппыКомпанийБанков Тогда
		Возврат;
	КонецЕсли;
				
	ЗначениеХарактеристики = Характеристика.Значение.Получить();
	Если Не ЗначениеЗаполнено(ЗначениеХарактеристики) Тогда
		Возврат;
	КонецЕсли;
	
	СервисХарактеристики = Перечисления.СервисыОбменаСБанками.ФинУслуги;
	
	ОбъектXDTOХарактеристики = ОбъектXDTOХарактеристики(СервисХарактеристики, ЗначениеХарактеристики);
	
	Банк = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(УслугаБанка, "Банк");
	
	Если Характеристика.Характеристика = Перечисления.ХарактеристикиСервисаФинУслуги.ГруппыКонтрагентов Тогда
		РегистрыСведений.ГруппыКонтрагентовЗаявкиВБанки.ЗаписатьГруппыКонтрагентов(СервисХарактеристики, 
			ОбъектXDTOХарактеристики, Банк); 
	Иначе
		РегистрыСведений.ГруппыКомпанийБанков.ЗаписатьГруппыКомпанийБанков(СервисХарактеристики, 
			ОбъектXDTOХарактеристики, Банк);
	КонецЕсли;
	
КонецПроцедуры

Функция ГражданствоФизическогоЛица(ФизическоеЛицо) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ГражданствоФизическихЛицСрезПоследних.Страна КАК Страна
		|ИЗ
		|	РегистрСведений.ГражданствоФизическихЛиц.СрезПоследних(, ФизическоеЛицо = &ФизическоеЛицо) КАК ГражданствоФизическихЛицСрезПоследних";
	
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Страна;
	КонецЕсли;
	
	Возврат Справочники.СтраныМира.ПустаяСсылка();
	
КонецФункции

