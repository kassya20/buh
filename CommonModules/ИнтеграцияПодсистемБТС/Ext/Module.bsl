// См. ИнтеграцияПодсистемБСП.ПриПолученииПриоритетаОбновления.
Процедура ПриПолученииПриоритетаОбновления(Приоритет) Экспорт
	
	ПриоритетОбработкаДанных = "ОбработкаДанных";
	
	Если Приоритет = ПриоритетОбработкаДанных Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьОтключениеБезопасногоРежима(Истина);
	УстановитьПривилегированныйРежим(Истина);
	
	Если Не Константы.УстанавливатьПриоритетОбработкиДанныхВУказанномИнтервалеВремени.Получить() Тогда
		Возврат;
	КонецЕсли;
	
	ОписаниеТиповВремя = ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Время);
	ТекущееУниверсальноеВремя = ОписаниеТиповВремя.ПривестиЗначение(ТекущаяУниверсальнаяДата());
	
	НачалоИнтервалаВремениПриоритетаОбработкиДанных = Константы.НачалоИнтервалаВремениПриоритетаОбработкиДанных.Получить();
	ОкончаниеИнтервалаВремениПриоритетаОбработкиДанных = Константы.ОкончаниеИнтервалаВремениПриоритетаОбработкиДанных.Получить();
	
	Если ОкончаниеИнтервалаВремениПриоритетаОбработкиДанных > НачалоИнтервалаВремениПриоритетаОбработкиДанных Тогда
		Если ТекущееУниверсальноеВремя >= НачалоИнтервалаВремениПриоритетаОбработкиДанных 
			И ТекущееУниверсальноеВремя <= ОкончаниеИнтервалаВремениПриоритетаОбработкиДанных Тогда
			Приоритет = ПриоритетОбработкаДанных;
		КонецЕсли;
	Иначе
		Если ТекущееУниверсальноеВремя <= ОкончаниеИнтервалаВремениПриоритетаОбработкиДанных 
			Или ТекущееУниверсальноеВремя >= НачалоИнтервалаВремениПриоритетаОбработкиДанных Тогда
			Приоритет = ПриоритетОбработкаДанных;
		КонецЕсли;	 
	КонецЕсли;
		
КонецПроцедуры

