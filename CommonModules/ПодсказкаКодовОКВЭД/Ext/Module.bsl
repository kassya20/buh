// Добавляет в таблицу ПравилаКорректировкиКодов группу правил на основании значения, указанного в параметре Код.
// В этом параметре могут быть указаны:
// - Набор кодов, перечисленных через запятую. В качестве кода могут быть указаны не только коды групп, например, "47.54" (именно в разрезе
// групп представлен классификатор сервиса), но и более общие группировки классификатора - например, подклассы, классы или даже первые
// цифры кодов классификатора. В этом случае соответствующее правило будет добавлено для всех кодов, входящих в иерархию этого кода.
// Например, если указать код "47.5", то будут добавлены правила для кодов "47.51", "47.52", "47.54", "47.59".
// - Диапазон кодов, в котором начало и конец диапазона разделены дефисом. При составлении диапазона следует учесть, что
// коды, описывающие начало и конец диапазона должны быть сопоставимы, то есть должны иметь одинаковую длину строки.
// Если при составлении дипазона не получается выполнить это правило, следует разбить такой один диапазон не несколько более мелких.
// Например, вместо "47.3-47.63" следует указать два диапазона, разделенных запятой: "47.3-47.5,47.61-47.63".
// - Различные комбинации и сочетания единичных кодов и диапазонов, перечисленных через запятую.
// 
// Параметры:
//  ДанныеКлассификатора - см. ДанныеКлассификатораСИерархией
//  ПравилаКорректировкиКодов - см. НовыйПравилаКорректировкиКодов
//  Код - Строка
//  Действие - Строка - см. ДействияПравила
//  ПризнакВыручки - Строка - описано в НовыйПравилаКорректировкиКодов.ПризнакВыручки
//  ДобавляемыеКоды - Строка - описано в НовыйПравилаКорректировкиКодов.ДобавляемыеКоды
Процедура ДобавитьПравило(ДанныеКлассификатора, ПравилаКорректировкиКодов, Код, Действие, ПризнакВыручки = "", ДобавляемыеКоды = "")
	
	КодБезТочек = СтрЗаменить(Код, ".", "");

	Для Каждого ГруппаКодов Из СтрРазделить(КодБезТочек, ",") Цикл

		ДиапазонКодов = СтрРазделить(ГруппаКодов, "-");

		НачалоДиапазона = ДиапазонКодов[0];
		КонецДиапазона = ДиапазонКодов[ДиапазонКодов.ВГраница()]; // Может совпадать с началом

		Для КодПравила = Число(НачалоДиапазона) По Число(КонецДиапазона) Цикл
			ДлинаКода = СтрДлина(НачалоДиапазона);
			КодПравилаСтрокой = СтроковыеФункцииКлиентСервер.ДополнитьСтроку(XMLСтрока(КодПравила), ДлинаКода);
			Поиск = Новый Структура;
			Поиск.Вставить(СтрШаблон("ЧастьКода%1", XMLСтрока(ДлинаКода)), КодПравилаСтрокой);
			СтрокиКлассификатораВИерархии = ДанныеКлассификатора.НайтиСтроки(Поиск);

			Для Каждого СтрокаКлассификатора Из СтрокиКлассификатораВИерархии Цикл
				Правило = ПравилаКорректировкиКодов.Добавить();
				Правило.Код = СтрокаКлассификатора.Код;
				Правило.Действие = Действие;
				Правило.ПризнакВыручки = ПризнакВыручки;
				Правило.ДобавляемыеКоды = ДобавляемыеКоды;
			КонецЦикла;
			
		КонецЦикла;

	КонецЦикла;
	
КонецПроцедуры

Процедура ПрименитьПравилаДляКодаСервиса(ДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом, КодСервиса, Правила, Выручка, ДействияПравила)
	
	Код = КодСервиса.КодОКВЭД;
	
	Если ДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом.Найти(Код, "Код") <> Неопределено Тогда
		Возврат;
	КонецЕсли;

	НоваяСтрока = ДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом.Добавить();
	НоваяСтрока.Код = Код;
	НоваяСтрока.Приоритет = КодСервиса.Вероятность;
	
	ПоискПравилаПоКоду = Новый Структура("Код", Код);
	СтрокиПравила = Правила.НайтиСтроки(ПоискПравилаПоКоду);
	
	Для Каждого СтрокаПравила Из СтрокиПравила Цикл
		
		ВыполняетсяУсловиеПравила = ВыполняетсяУсловиеПравила(
			СтрокаПравила.ПризнакВыручки,
			Выручка, 
			СтрокаПравила.Действие = ДействияПравила.Дополнить);

		Если Не ВыполняетсяУсловиеПравила Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаПравила.Действие = ДействияПравила.Дополнить Тогда
			
			Для Каждого Дополнение Из СтрРазделить(СтрокаПравила.ДобавляемыеКоды, ",") Цикл
				СтрокиДополнения = ДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом.Добавить();
				СтрокиДополнения.Код = Дополнение;
				СтрокиДополнения.Приоритет = КодСервиса.Вероятность;
			КонецЦикла;
			
		ИначеЕсли СтрокаПравила.Действие = ДействияПравила.Удалить Тогда
			// Добавленной строке устанавливаем признак удаления.
			// Так, чтобы если в других правилах строка с таким же кодом будет добавлена,
			// он не попал в итоговый результат.
			НоваяСтрока.Удалить = Истина;
		
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Проверяет, соответствует ли набор данных о выручке заданному правилу.
// Правило определяется набором признаков и типом (добавление/исключение).
// Для правил добавления достаточно одного совпадения, для исключения - все строки должны подходить.
//
// Параметры:
//  ПризнакВыручки - Строка - Признак для фильтрации. Если не задан, условие выполнено.
//  Выручка - Массив из СтрокаТаблицыЗначений - Набор данных для проверки.
//  ЭтоПравилоДобавления - Булево - Истина для правила добавления, Ложь - для исключения.
//
// Возвращаемое значение:
//  Булево - Истина, если условие выполняется, иначе Ложь.
Функция ВыполняетсяУсловиеПравила(ПризнакВыручки, Выручка, ЭтоПравилоДобавления = Истина)

	// Если признак выручки не задан, считаем, что правило всегда выполняется.
	Если Не ЗначениеЗаполнено(ПризнакВыручки) Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Получаем все возможные наборы признаков для проверки в виде массива структур.
	НаборыИменПризнаков = ИменаПризнаковВыручки(ПризнакВыручки);
	
	ПравилоВыполненоДляВсехСтрок = Истина;
	Для Каждого СтрокаВыручки Из Выручка Цикл
		
		ПравилоВыполняетсяДляТекущейСтроки = Ложь;
		Для Каждого ПризнакиВыручки Из НаборыИменПризнаков Цикл
			
			// Если на одном из шагов переменная ПравилоВыполняетсяДляТекущейСтроки = Истина, вторая часть выражения не вычисляется.
			// Ветку с прерыванием цикла для правил удаления не делаем, чтобы не запутывать код.
			ПравилоВыполняетсяДляТекущейСтроки =
				ПравилоВыполняетсяДляТекущейСтроки Или ВыручкаСоответствуетПризнаку(ПризнакиВыручки, СтрокаВыручки);
			
			// Для правил добавления достаточно совпадения одного из набора признаков (например, "Товар,Розница") хотя бы по одной из строк
			// выручки.
			Если ПравилоВыполняетсяДляТекущейСтроки И ЭтоПравилоДобавления Тогда
				Возврат Истина;
			КонецЕсли;
			
		КонецЦикла;
		
		ПравилоВыполненоДляВсехСтрок = ПравилоВыполненоДляВсехСтрок И ПравилоВыполняетсяДляТекущейСтроки;

	КонецЦикла;
	
	Возврат ПравилоВыполненоДляВсехСтрок;
	
КонецФункции

Функция ВыручкаСоответствуетПризнаку(ПризнакиВыручки, СтрокаВыручки)
	
	ЗаполнитьЗначенияСвойств(ПризнакиВыручки, СтрокаВыручки);
	ЗначенияПризнаков = ОбщегоНазначенияБПКлиентСервер.ЗначенияКоллекции(ПризнакиВыручки, Истина);
	
	Возврат ЗначенияПризнаков.Количество() = 1 И ЗначенияПризнаков[0] = Истина;

КонецФункции

#КонецОбласти

Функция ИменаПризнаковВыручки(ПризнакиВыручки)
	
	ИменаПризнаковВыручки = Новый Массив;
	Если Не ЗначениеЗаполнено(ПризнакиВыручки) Тогда
		Возврат ИменаПризнаковВыручки;
	КонецЕсли;
	
	НаборыИмен =  СтрРазделить(ПризнакиВыручки, ";");
	
	Для Каждого НаборИмен Из НаборыИмен Цикл
		ИменаПризнаковВыручки.Добавить(Новый Структура(НаборИмен));
	КонецЦикла;
	
	Возврат ИменаПризнаковВыручки;
	
КонецФункции

Функция ИменаКолонокТаблицы(СтруктураВыручкиПоПолямГруппировки)

	КолонкиСтруктурыВыручки = Новый Массив;
	Для Каждого Колонка Из СтруктураВыручкиПоПолямГруппировки.Колонки Цикл
		КолонкиСтруктурыВыручки.Добавить(Колонка.Имя);
	КонецЦикла;
	Возврат КолонкиСтруктурыВыручки
КонецФункции

Функция ПоляГруппировкиВыручки(СписокПолей)

	ПоляГруппировкиВыручки = СписокПолей.ВыгрузитьЗначения();
	
	ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(ПоляГруппировкиВыручки, "ОКВЭД");
	
	ПоляГруппировкиВыручки.Добавить("Номенклатура");
	
	Возврат ПоляГруппировкиВыручки;
	
КонецФункции

Функция СписокИменДляСопоставления(СтруктураВыручки, ПоляГруппировок, КодыПодобранныеСервисомРанее)
	
	СписокИменДляСопоставления = Новый Соответствие;
	
	// Значения в некоторых разрезах могут иметь наименования, которые плохо соотносятся с классификатором.
	// Например, предполагаем, что таким разрезом должен быть ВидНоменклатуры: предполагается, что у него
	// максимально обобщенное название - Товары, Услуги, Материалы и тому подобное.
	ПоляНеПоказыватьПодсказку = ПодсказкаКодовОКВЭДКлиентСервер.ПоляНеПоказыватьПодсказку();
	
	Для Каждого ПолеСопоставления Из ПоляГруппировок Цикл
		
		Если ПоляНеПоказыватьПодсказку.Найти(ПолеСопоставления) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ЗначенияПолейДляСопоставления = СтруктураВыручки.ВыгрузитьКолонку(ПолеСопоставления);
		ЗначенияПолейДляСопоставления = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ЗначенияПолейДляСопоставления);
		
		ЗаполнитьСписокИменПоЗначениям(
			СписокИменДляСопоставления,
			ПолеСопоставления,
			ЗначенияПолейДляСопоставления,
			КодыПодобранныеСервисомРанее);

	КонецЦикла;
			
	Возврат СписокИменДляСопоставления;
	
КонецФункции

Процедура ЗаполнитьСписокИменПоЗначениям(СписокИменДляСопоставления, ПолеСопоставления, ЗначенияПолейДляСопоставления, КодыПодобранныеСервисомРанее)
	
	Если ПолеСопоставления = "Номенклатура" Тогда
			
		// Для поля "Номенклатура" особый поиск, потому что в первую очередь для сопоставления используем реквизит "НаименованиеПолное"
		// и только если он не заполнен, используем "Наименование". У других полей реквизита "НаименованиеПолное" нет.
		ЗаполнитьПоискНоменклатура(СписокИменДляСопоставления, ЗначенияПолейДляСопоставления, КодыПодобранныеСервисомРанее);
	Иначе
		ЗаполнитьПоискПрочиеПоля(СписокИменДляСопоставления, ЗначенияПолейДляСопоставления, КодыПодобранныеСервисомРанее);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПоискПрочиеПоля(СписокИменДляСопоставления, ЗначенияПолейДляСопоставления, КодыПодобранныеСервисомРанее)
	
	ЗначенияДляКлассификации = Новый Массив;
	Для Каждого ЗначениеПоля Из ЗначенияПолейДляСопоставления Цикл
		Если Не ЗначениеЗаполнено(ЗначениеПоля) Тогда
			Продолжить;
		КонецЕсли;
		Если КодыПодобранныеСервисомРанее[ЗначениеПоля] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗначенияДляКлассификации.Добавить(ЗначениеПоля);
	КонецЦикла;
	
	ИменаДляКлассификации = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ЗначенияДляКлассификации, "Наименование");

	Для Каждого ИмяДляКлассификации Из ИменаДляКлассификации Цикл

		Если Не ЗначениеЗаполнено(ИмяДляКлассификации.Значение) Тогда
			Продолжить;
		КонецЕсли;

		ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(
			СписокИменДляСопоставления,
			ИмяДляКлассификации.Значение,
			ИмяДляКлассификации.Ключ);

	КонецЦикла;

КонецПроцедуры
	
Процедура ЗаполнитьПоискНоменклатура(СписокИменДляСопоставления, ЗначенияПолейДляСопоставления, КодыПодобранныеСервисомРанее)
	
	ЗначенияДляКлассификации = Новый Массив;
	Для Каждого ЗначениеПоля Из ЗначенияПолейДляСопоставления Цикл
		Если Не ЗначениеЗаполнено(ЗначениеПоля) Тогда
			Продолжить;
		КонецЕсли;
		Если КодыПодобранныеСервисомРанее[ЗначениеПоля] <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗначенияДляКлассификации.Добавить(ЗначениеПоля);
	КонецЦикла;
	
	ИменаДляКлассификации = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
		ЗначенияДляКлассификации,
		"Наименование, НаименованиеПолное");
		
	Для Каждого НаименованияНоменклатуры Из ИменаДляКлассификации Цикл
		
		Наименование = НаименованияНоменклатуры.Значение.Наименование;
		НаименованиеПолное = НаименованияНоменклатуры.Значение.НаименованиеПолное;
		
		ИмяДляПоиска = "";
		Если ЗначениеЗаполнено(НаименованиеПолное) Тогда
			ИмяДляПоиска = НаименованиеПолное;
		ИначеЕсли ЗначениеЗаполнено(Наименование) Тогда
			ИмяДляПоиска = Наименование;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ИмяДляПоиска) Тогда
			Продолжить;
		КонецЕсли;
		
		ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(
			СписокИменДляСопоставления,
			ИмяДляПоиска,
			НаименованияНоменклатуры.Ключ);
			
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСоставВыручки(СоставВыручки, СтруктураВыручки, ЗначениеПолейТекущейГруппировки, ИменаТекущихПолей, КолонкиПоказателиСтруктурыВыручки)

	ПоискСтруктурыВыручки = Новый Структура(ИменаТекущихПолей);
	ЗаполнитьЗначенияСвойств(ПоискСтруктурыВыручки, ЗначениеПолейТекущейГруппировки);
	
	КолонкиПоказателейВыручкиСтрокой = СтрСоединить(КолонкиПоказателиСтруктурыВыручки, ",");
	СтруктураВыручкиПоЗначению = СтруктураВыручки.Скопировать(
		ПоискСтруктурыВыручки,
		КолонкиПоказателейВыручкиСтрокой);
	СтруктураВыручкиПоЗначению.Свернуть(КолонкиПоказателейВыручкиСтрокой);
	
	Для Каждого СтрокаСтруктурыВыручки Из СтруктураВыручкиПоЗначению Цикл
		ЗаписьСоставаВыручки = СоставВыручки.Добавить();
		ЗаполнитьЗначенияСвойств(ЗаписьСоставаВыручки, СтрокаСтруктурыВыручки);
	КонецЦикла;
	
	СоставВыручки.Свернуть(КолонкиПоказателейВыручкиСтрокой);
	
КонецПроцедуры

Процедура ОпределитьВыбранныеКоды(СоставВыбранныхКодов, ДанныеСопоставленнойНоменклатуры, ЗначениеПолейТекущейГруппировки, ИменаТекущихПолей)
	
	ПоискВыбранныхКодов = Новый Структура(ИменаТекущихПолей);
	ЗаполнитьЗначенияСвойств(ПоискВыбранныхКодов, ЗначениеПолейТекущейГруппировки);
	ВыбранныеКоды = ДанныеСопоставленнойНоменклатуры.НайтиСтроки(ПоискВыбранныхКодов);
	
	Для Каждого ВыбранныйКод Из ВыбранныеКоды Цикл
		
		КодПриведенныйКДлинеКодаСервиса = Лев(ВыбранныйКод.ОКВЭДКод, МаксимальнаяДлинаКодаСервиса());
		
		Если СоставВыбранныхКодов.Найти(КодПриведенныйКДлинеКодаСервиса) = Неопределено Тогда
			СоставВыбранныхКодов.Добавить(КодПриведенныйКДлинеКодаСервиса);
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

Процедура ОпределитьДобавленныеУдаленныеКоды(КонтекстВыбранногоКода, СоставОбратнойСвязи, Правила, КодыСервисаСВероятностями)
	
	ДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом = НовыйДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом();
	
	ПрименитьПравила(
		ДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом,
		КодыСервисаСВероятностями,
		Правила,
		КонтекстВыбранногоКода.СоставВыручки);

	УдаляемыеКоды = Новый Массив;
	ОстающиесяКоды = Новый Массив;

	Для Каждого КодПоПравилам Из ДействияПравилСУчетомВыручкиДляКодовПодобранныхСервисом Цикл

		Код = Лев(КодПоПравилам.Код, 5);

		Если КодПоПравилам.Удалить Тогда

			УдаляемыеКоды.Добавить(Код);

		Иначе

			ОстающиесяКоды.Добавить(Код);

		КонецЕсли;

	КонецЦикла;

	КонтекстВыбранногоКода.УдаленныеКоды = ОбщегоНазначенияКлиентСервер.СвернутьМассив(УдаляемыеКоды);

	ОстающиесяКоды = ОбщегоНазначенияКлиентСервер.РазностьМассивов(ОстающиесяКоды, УдаляемыеКоды);
	
	КонтекстВыбранногоКода.ДобавленныеКоды = ОбщегоНазначенияКлиентСервер.РазностьМассивов(ОстающиесяКоды, СоставОбратнойСвязи.КодыСервиса);
	КонтекстВыбранногоКода.ДобавленныеКоды = ОбщегоНазначенияКлиентСервер.СвернутьМассив(КонтекстВыбранногоКода.ДобавленныеКоды);
	
КонецПроцедуры


#КонецОбласти