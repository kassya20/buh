
#Область ПрограммныйИнтерфейс

#Область ФормированиеДвижений

Процедура СформироватьДвиженияБюджетПлан(ТаблицаРасходы, ТаблицаДоходы, ТаблицаРеквизиты, Движения, Отказ) Экспорт
	
	Параметры = ПодготовитьПараметрыБюджетПлан(ТаблицаРасходы, ТаблицаДоходы, ТаблицаРеквизиты);
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Параметры.Реквизиты[0]);
	
	Для Каждого СтрокаТаблицы Из Параметры.ТаблицаРасходы Цикл
		НовоеДвижение = Движения.БюджетРасходы.Добавить();
		НовоеДвижение.Регистратор = Реквизиты.Регистратор;
		НовоеДвижение.Организация = Реквизиты.Организация;
		НовоеДвижение.СуммаПлан   = СтрокаТаблицы.Сумма;
		ЗаполнитьЗначенияСвойств(НовоеДвижение, СтрокаТаблицы);
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из Параметры.ТаблицаДоходы Цикл
		НовоеДвижение = Движения.БюджетДоходы.Добавить();
		НовоеДвижение.Регистратор = Реквизиты.Регистратор;
		НовоеДвижение.Организация = Реквизиты.Организация;
		НовоеДвижение.СуммаПлан   = СтрокаТаблицы.Сумма;
		ЗаполнитьЗначенияСвойств(НовоеДвижение, СтрокаТаблицы);
	КонецЦикла;
	
	Движения.БюджетРасходы.Записывать = Истина;
	Движения.БюджетДоходы.Записывать = Истина;
	
КонецПроцедуры

Процедура СформироватьСтруктуруБюджета(ТаблицаСтруктураДоходов, ТаблицаСтруктураРасходов, ТаблицаРеквизиты, Движения, Отказ) Экспорт
	
	Параметры = ПодготовитьПараметрыСтруктураБюджета(ТаблицаСтруктураДоходов, ТаблицаСтруктураРасходов, ТаблицаРеквизиты);
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Параметры.Реквизиты[0]);
	
	Для Каждого СтрокаТаблицы Из Параметры.ТаблицаСтруктураДоходов Цикл
		Запись = Движения.СтруктураБюджетаДоходы.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Реквизиты);
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из Параметры.ТаблицаСтруктураРасходов Цикл
		Запись = Движения.СтруктураБюджетаРасходы.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Реквизиты);
		ЗаполнитьЗначенияСвойств(Запись, СтрокаТаблицы);
	КонецЦикла;
	
	Движения.СтруктураБюджетаДоходы.Записывать = Истина;
	Движения.СтруктураБюджетаРасходы.Записывать = Истина;
	
КонецПроцедуры

Процедура СформироватьДвиженияДоходыФактБюджет(ТаблицаБюджетДоходы, ТаблицаРеквизиты, Движения, Отказ) Экспорт
	
	Параметры = ПодготовитьПараметрыДоходыФактБюджет(ТаблицаБюджетДоходы, ТаблицаРеквизиты);
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Параметры.Реквизиты[0]);
	
	Для Каждого СтрокаТаблицы Из Параметры.ТаблицаБюджетДоходы Цикл
		НовоеДвижение = Движения.БюджетДоходы.Добавить();
		НовоеДвижение.Регистратор  = Реквизиты.Регистратор;
		НовоеДвижение.Организация  = Реквизиты.Организация;
		НовоеДвижение.Период       = Реквизиты.Период;
		НовоеДвижение.СуммаФакт    = СтрокаТаблицы.Сумма;
		НовоеДвижение.СтатьяДохода = СтрокаТаблицы.СтатьяДохода;
	КонецЦикла;
	
	Движения.БюджетДоходы.Записывать = Истина;
	
КонецПроцедуры

Процедура СформироватьДвиженияРасходыФактБюджет(ТаблицаБюджетРасходы, ТаблицаРеквизиты, Движения, Отказ) Экспорт
	
	Параметры = ПодготовитьПараметрыРасходыФактБюджет(ТаблицаБюджетРасходы, ТаблицаРеквизиты);
	
	Реквизиты = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Параметры.Реквизиты[0]);
	
	Для Каждого СтрокаТаблицы Из Параметры.ТаблицаБюджетРасходы Цикл
		НовоеДвижение = Движения.БюджетРасходы.Добавить();
		НовоеДвижение.Регистратор             = Реквизиты.Регистратор;
		НовоеДвижение.Организация             = Реквизиты.Организация;
		НовоеДвижение.Период                  = Реквизиты.Период;
		НовоеДвижение.НаправлениеДеятельности = Реквизиты.НаправлениеДеятельности;
		НовоеДвижение.СуммаФакт               = СтрокаТаблицы.СуммаФакт;
		НовоеДвижение.СтатьяРасхода           = СтрокаТаблицы.СтатьяРасхода;
	КонецЦикла;
	
	Движения.БюджетРасходы.Записывать = Истина;
	
КонецПроцедуры

