// Функция-конструктор для колонок с периодами детализации бюджета для вывода на форму и на печать.
//
// Возвращаемое значение:
//    ТаблицаЗначений - см. тело функции
//
Функция НовыйКолонкиДетализации() Экспорт
	
	КолонкиДетализации = Новый ТаблицаЗначений;
	КолонкиДетализации.Колонки.Добавить("ИмяКолонки", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	КолонкиДетализации.Колонки.Добавить("Заголовок", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	КолонкиДетализации.Колонки.Добавить("Дата", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	
	Возврат КолонкиДетализации;
	
КонецФункции

// Процедура заполняет дополнительные колонки с периодами в зависимости от выбранной детализации.
//
// Параметры:
//    КолонкиДетализации - ТаблицаЗначений - Таблица значений с описанием колонок.
//    ДанныеДокумента - Структура, ДокументОбъект.Бюджет - Коллекция с обязательными полями "Детализация" и "Период"
//
Процедура ЗаполнитьКолонкиДетализации(КолонкиДетализации, ДанныеДокумента) Экспорт
	
	КолонкиДетализации.Очистить();
	
	Если ДанныеДокумента.Детализация = Перечисления.Периодичность.Квартал Тогда
		НомерКвартала = 1;
		Пока НомерКвартала <= 4 Цикл
			Строка = КолонкиДетализации.Добавить();
			Строка.ИмяКолонки = "Квартал" + НомерКвартала;
			Строка.Заголовок = СтрШаблон(НСтр("ru='%1 квартал'"), НомерКвартала);
			Строка.Дата = Дата(Год(ДанныеДокумента.Период), НомерКвартала * 3 , 1);
			НомерКвартала = НомерКвартала + 1;
		КонецЦикла;
	ИначеЕсли ДанныеДокумента.Детализация = Перечисления.Периодичность.Месяц Тогда
		НомерМесяца = 1;
		ГодДокумента = НачалоГода(ДанныеДокумента.Период);
		Пока НомерМесяца <= 12 Цикл
			Строка = КолонкиДетализации.Добавить();
			Месяц = Формат(ДобавитьМесяц(ГодДокумента, НомерМесяца - 1), "ДФ=MMMM");
			Строка.ИмяКолонки = Месяц;
			Строка.Заголовок = Месяц;
			Строка.Дата = Дата(Год(ДанныеДокумента.Период), НомерМесяца, 1);
			НомерМесяца = НомерМесяца + 1;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Функция-конструктор для данных бюджета для их вывода на форму и на печать.
//
// Возвращаемое значение:
//    Структура - Описание:
// * Реквизиты - ТаблицаЗначений - Реквизиты документа, см. НовыйРеквизитыБюджета
// * Доходы - ТаблицаЗначений - таблица с доходами бюджета, см. НовыйДоходыБюджета
// * Расходы - ТаблицаЗначений - таблица с расходами бюджета, см. НовыйРасходыБюджета
// * РасходыПоНаправлениямДеятельности - ТаблицаЗначений - таблица с расходами бюджета по направлениям деятельности, см. НовыйРасходыПоНаправлениямДеятельности
// * СтруктураДоходов - ТаблицаЗначений - структура доходов бюджета, см. НовыйСтруктураДоходовБюджета
// * СтруктураРасходов - ТаблицаЗначений - структура расходов бюджета, см. НовыйСтруктураРасходовБюджета
//
Функция НовыйДанныеБюджета() Экспорт
	
	МетаданныеБюджета = Метаданные.Документы.Бюджет;
	
	ДанныеБюджета = Новый Структура;
	ДанныеБюджета.Вставить("Реквизиты", НовыйРеквизитыБюджета(МетаданныеБюджета));
	ДанныеБюджета.Вставить("Доходы", НовыйДоходыБюджета(МетаданныеБюджета));
	ДанныеБюджета.Вставить("Расходы", НовыйРасходыБюджета(МетаданныеБюджета));
	ДанныеБюджета.Вставить("РасходыПоНаправлениямДеятельности", НовыйРасходыПоНаправлениямДеятельности(МетаданныеБюджета));
	ДанныеБюджета.Вставить("СтруктураДоходов", НовыйСтруктураДоходовБюджета(МетаданныеБюджета));
	ДанныеБюджета.Вставить("СтруктураРасходов", НовыйСтруктураРасходовБюджета(МетаданныеБюджета));
	
	Возврат ДанныеБюджета;
	
КонецФункции

// Функция-конструктор для данных корректировки бюджета для их вывода на форму и на печать.
//
// Возвращаемое значение:
//    Структура - аналогично НовыйДанныеБюджета, с дополнительными колонками СуммаКорректировки, СуммаДоКорректировки - Поля:
// * Реквизиты - ТаблицаЗначений - Реквизиты документа, см. НовыйРеквизитыБюджета
// * Доходы - ТаблицаЗначений - таблица с доходами бюджета, см. НовыйДоходыБюджета
// * Расходы - ТаблицаЗначений - таблица с расходами бюджета, см. НовыйРасходыБюджета
// * РасходыПоНаправлениямДеятельности - ТаблицаЗначений - таблица с расходами бюджета по направлениям деятельности, см. НовыйРасходыПоНаправлениямДеятельности
// * СтруктураДоходов - ТаблицаЗначений - структура доходов бюджета, см. НовыйСтруктураДоходовБюджета
// * СтруктураРасходов - ТаблицаЗначений - структура расходов бюджета, см. НовыйСтруктураРасходовБюджета
//
Функция НовыйДанныеКорректировки() Экспорт
	
	ДанныеКорректировки = НовыйДанныеБюджета();
	МетаданныеКорректировки = Метаданные.Документы.КорректировкаБюджета;
	
	ДанныеКорректировки.Реквизиты.Колонки.Добавить("Бюджет", МетаданныеКорректировки.Реквизиты.Бюджет.Тип);
	ДанныеКорректировки.Реквизиты.Колонки.Добавить("ОстатокНаНачалоДоКорректировки", 
		МетаданныеКорректировки.Реквизиты.ОстатокНаНачалоДоКорректировки.Тип);
	ДанныеКорректировки.Реквизиты.Колонки.Добавить("ОстатокНаНачалоКорректировка", 
		МетаданныеКорректировки.Реквизиты.ОстатокНаНачалоКорректировка.Тип);
		
	ДополнитьКолонкамиКорректировки(ДанныеКорректировки.Доходы, "Доходы", МетаданныеКорректировки);
	ДополнитьКолонкамиКорректировки(ДанныеКорректировки.Расходы, "Расходы", МетаданныеКорректировки);
	ДополнитьКолонкамиКорректировки(
		ДанныеКорректировки.РасходыПоНаправлениямДеятельности, "РасходыПоНаправлениямДеятельности", МетаданныеКорректировки);
	
	Возврат ДанныеКорректировки;
	
КонецФункции

// Процедура устанавливает текущую строку в дереве бюджета при открытии формы из отчета "План-фактный анализ"
//
// Параметры:
//    Форма - ФормаКлиентскогоПриложения - Открываемая форма бюджета или корректировки
//
Процедура УстановитьТекущуюСтрокуИзПланФактногоАнализа(Форма) Экспорт
	
	ПараметрыПоискаСтроки = Неопределено;
	Если Не Форма.Параметры.Свойство("ПараметрыПоискаСтроки", ПараметрыПоискаСтроки) Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторСтроки = Неопределено;
	Если ПараметрыПоискаСтроки.ТипЗаписи = Отчеты.ПланФактныйАнализБюджета.ТипЗаписиОстатокНаНачало() Тогда
		ИдентификаторСтроки = Форма.ИдентификаторОстатокНачало;
	ИначеЕсли ПараметрыПоискаСтроки.ТипЗаписи = Отчеты.ПланФактныйАнализБюджета.ТипЗаписиОстатокНаКонец() Тогда
		ИдентификаторСтроки = Форма.ИдентификаторОстатокКонец;
	ИначеЕсли ПараметрыПоискаСтроки.ТипЗаписи = Отчеты.ПланФактныйАнализБюджета.ТипЗаписиДоход() Тогда
		ИдентификаторСтроки = Форма.ИдентификаторДоходы;
		СтрокаРазделДоходы = Форма.ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторСтроки);
		ИскомаяСтрока = СтрокаПоСтатьеДДСРекурсивно(СтрокаРазделДоходы, ПараметрыПоискаСтроки);
		Если ИскомаяСтрока <> Неопределено Тогда
			ИдентификаторСтроки = ИскомаяСтрока.ПолучитьИдентификатор();
		КонецЕсли;
	ИначеЕсли ПараметрыПоискаСтроки.ТипЗаписи = Отчеты.ПланФактныйАнализБюджета.ТипЗаписиРасход() Тогда
		ИдентификаторСтроки = Форма.ИдентификаторРасходы;
		СтрокаРазделРасходы = Форма.ДеревоБюджета.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если ЗначениеЗаполнено(ПараметрыПоискаСтроки.НаправлениеДеятельности) Тогда
			ИскомаяСтрока = СтрокаРасходыРекурсивно(СтрокаРазделРасходы, ПараметрыПоискаСтроки);
			Если ИскомаяСтрока <> Неопределено Тогда
				ИдентификаторСтроки = ИскомаяСтрока.ПолучитьИдентификатор();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ИдентификаторСтроки <> Неопределено Тогда
		Форма.Элементы.ДеревоБюджета.ТекущаяСтрока = ИдентификаторСтроки;
		Форма.Элементы.ДеревоБюджета.ТекущийЭлемент = Форма.Элементы.ДеревоБюджетаСуммаГод;
		Для Каждого КолонкаДетализации Из Форма.КолонкиДетализации Цикл
			Если КолонкаДетализации.Дата = ПараметрыПоискаСтроки.ПериодДетализации Тогда
				Форма.Элементы.ДеревоБюджета.ТекущийЭлемент = Форма.Элементы["ДеревоБюджета" + КолонкаДетализации.ИмяКолонки];
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ФормированиеДвижений

Функция ПодготовитьПараметрыБюджетПлан(ТаблицаРасходы, ТаблицаДоходы, ТаблицаРеквизиты)
	
	Параметры = Новый Структура;
	
	// Подготовка таблицы шапки документа.
	СписокОбязательныхКолонок = ""
	+ "Период,"      // <Дата> - дата докумета, записывающего движения
	+ "Регистратор," // <Регистратор> - документ, записывающий движения в регистры
	+ "Организация"  // <СправочникСсылка.Организации> - организация документа
	;
	Параметры.Вставить("Реквизиты", ОбщегоНазначенияБПВызовСервера.ПолучитьТаблицуПараметровПроведения(
		ТаблицаРеквизиты, СписокОбязательныхКолонок));
	
	// Подготовка таблицы расходов по бюджету
	СписокОбязательныхКолонок = ""
	+ "Период,"                  // <Дата> - Дата, на которую запланирован бюджет
	+ "НаправлениеДеятельности," // <СправочникСсылка.НаправлениеДеятельности> - Направление деятельности
	+ "СтатьяРасхода,"           // <СправочникСсылка.СтатьяДвиженияДенежныхСредств> - Статья ДДС по расходам
	+ "Сумма"                    // <Число(15,2)> - сумма
	;
	
	Параметры.Вставить("ТаблицаРасходы", ОбщегоНазначенияБПВызовСервера.ПолучитьТаблицуПараметровПроведения(
		ТаблицаРасходы, СписокОбязательныхКолонок));
		
		
	// Подготовка таблицы доходов по бюджету
	СписокОбязательныхКолонок = ""
	+ "Период,"       // <Дата> - Дата, на которую запланирован бюджет
