				Если ЗначениеЗаполнено(ДанныеДокумента) Тогда
					
					ВидДокументаВСтатформе = ВидДокументаФизическогоЛицаВСтатформе(ДанныеДокумента.ВидДокумента, "RU");
					
					РеквизитыШапка.ОтвЛицоФинУрПасВидДок        = ВидДокументаВСтатформе.Код;
					РеквизитыШапка.ОтвЛицоФинУрПасДатаДок       = ДанныеДокумента.ДатаВыдачи;
					РеквизитыШапка.ОтвЛицоФинУрПасДатаДокумента = ДанныеДокумента.ДатаВыдачи;
					РеквизитыШапка.ОтвЛицоФинУрПасНаименование  = ВидДокументаВСтатформе.Наименование;
					РеквизитыШапка.ОтвЛицоФинУрПасНомерДок      = ДанныеДокумента.Номер;
					РеквизитыШапка.ОтвЛицоФинУрПасСерДок        = ДанныеДокумента.Серия;
					РеквизитыШапка.ОтвЛицоФинУрПасОрг           = ДанныеДокумента.КемВыдан;
					ДанныеДокументаПредставление                = ДанныеДокумента.Представление;
					
				КонецЕсли;
				
				ФИО = Строка(РеквизитыШапка.ИндивидуальныйПредприниматель);
				РеквизитыШапка.ОтвЛицоФинУрНаименование = ФИО;
				
				Если НаправлениеПеремещения = "ЭК" Тогда
					РеквизитыШапка.ОтправительНаименование = ФИО;
				Иначе
					РеквизитыШапка.ПолучательНаименование = ФИО;
				КонецЕсли;
				
			КонецЕсли;
			
			// Для физического лица, зарегистрированного на территории Российской Федерации в качестве индивидуального предпринимателя,
			// либо самозанятого
			// - фамилия, имя, отчество, место жительства, а также сведения о документе, удостоверяющем его личность
			РеквизитыШапка.ОтвЛицоФинУрРеквизиты = СтрШаблон("%1, %2", РеквизитыШапка.ОтправительРеквизиты, ДанныеДокументаПредставление);
		
		ИначеЕсли РеквизитыШапка.ОбособленноеПодразделение Тогда
			
			// Заявитель статформы обособленное подразделение
			
			РеквизитыШапка.ОтвЛицоФинУрПодРФ_ИНН = РеквизитыШапка.ОтвЛицоФинУрРФ_ИНН;
			РеквизитыШапка.ОтвЛицоФинУрПодРФ_КПП = РеквизитыШапка.ОтвЛицоФинУрРФ_КПП;
			РеквизитыШапка.ОтвЛицоФинУрПодРФ_ОГРН = РеквизитыШапка.ОтвЛицоФинУрРФ_ОГРН;
			
			РеквизитыШапка.ОтвЛицоФинУрПодСтранаКод = РеквизитыШапка.ОтвЛицоФинУрСтранаКод;
			РеквизитыШапка.ОтвЛицоФинУрПодСтранаНаименование = РеквизитыШапка.ОтвЛицоФинУрСтранаНаименование;
			РеквизитыШапка.ОтвЛицоФинУрПодНаименование = РеквизитыШапка.ОтвЛицоФинУрНаименование;
			РеквизитыШапка.ОтвЛицоФинУрПодИндекс = РеквизитыШапка.ОтвЛицоФинУрИндекс;
			РеквизитыШапка.ОтвЛицоФинУрПодОбласть = РеквизитыШапка.ОтвЛицоФинУрОбласть;
			РеквизитыШапка.ОтвЛицоФинУрПодНаселенныйПункт = РеквизитыШапка.ОтвЛицоФинУрНаселенныйПункт;
			РеквизитыШапка.ОтвЛицоФинУрПодУлицаНомерДома = РеквизитыШапка.ОтвЛицоФинУрУлицаНомерДома;
			
		Иначе
			
			// Заявитель статформы юридическое лицо
			
			РеквизитыШапка.ОтвЛицоФинУр = РеквизитыШапка.ОтвЛицоФинУрНаименование;
			
		КонецЕсли;
		
		РеквизитыШапка.Вставить("ОргСтранаКод",          РеквизитыШапка.ОтвЛицоФинУрСтранаКод);
		РеквизитыШапка.Вставить("ОргСтранаНаименование", РеквизитыШапка.ОтвЛицоФинУрСтранаНаименование);
		РеквизитыШапка.Вставить("ОргИндекс",             РеквизитыШапка.ОтвЛицоФинУрИндекс);
		РеквизитыШапка.Вставить("ОргОбласть",            РеквизитыШапка.ОтвЛицоФинУрОбласть);
		РеквизитыШапка.Вставить("ОргНаселенныйПункт",    РеквизитыШапка.ОтвЛицоФинУрНаселенныйПункт);
		РеквизитыШапка.Вставить("ОргУлицаНомерДома",     РеквизитыШапка.ОтвЛицоФинУрУлицаНомерДома);
		
	КонецЕсли;
	
	ВидТранспорта = СписокВидовТранспорта.НайтиПоЗначению(РеквизитыШапка.ВидТранспортаКод);
	Если ВидТранспорта <> Неопределено Тогда
		РеквизитыШапка.ВидТранспортаНаименование = Сред(ВидТранспорта, 6);
	КонецЕсли;
	
	// Графа 7 - общая стоимость
	РеквизитыШапка.Вставить("ОбщаяЦенаТоваров", ТаблицаТоварыДляВыгрузки.Итог("ЦенаТовараВыбВал"));
	
	// Реквизиты подписи - ИНН/КПП/ОГРН заявителя статформы.
	// В форме БРО собирается по отдельным значениям ИНН, КПП, ОГРН
	РеквизитыШапка.Вставить("ИннКппОгрн", ИННКППОГРН);
	
	Для каждого СтрокаТовары Из ТаблицаТоварыДляВыгрузки Цикл
		
		// КодТО - Код таможенного органа
		// ДатаРегистрацииСтр - Дата таможенной декларации
		// НомерДок - Номер таможенной декларации
		// ДекларацияНом - Порядковый номер строки в декларации
		// НомерДекларацииНаТовары - Номер декларации на товары (без порядкового номера товара) для печатной формы
		ЗаполнитьРеквизитыТаможеннойДекларации(СтрокаТовары, СтрокаТовары);
		
		СтрокаТовары.ЕдИзмТовараКратко = ВРег(СтрокаТовары.ЕдИзмТовараКратко);
		
		Если НаправлениеПеремещения = "ИМ" Тогда
			// Экспорт
			// Товаросопроводительные документы не хранятся в реализации в структурированном виде
			
			// Импорт
			// Товаросопроводительные документы отображаются в статформе как "Счет-проформа (проформа-инвойс)"
			Если ЗначениеЗаполнено(СтрокаТовары.СерияНомерТСД) Тогда
				
				НоваяСтрокаВыгрузки = ТаблицаДокументы.Добавить();
				НоваяСтрокаВыгрузки.НаименованиеДокумента = "Счет-проформа (проформа-инвойс)";
				НоваяСтрокаВыгрузки.НомерДокумента = СтрокаТовары.СерияНомерТСД;
				НоваяСтрокаВыгрузки.ДатаДокумента = СтрокаТовары.ДатаТСД;
				
			КонецЕсли;
				
			// Вычисляются реквизиты счетов фактур
			Если ЗначениеЗаполнено(СтрокаТовары.НомерСчетаФактуры) Тогда
				
				НоваяСтрокаВыгрузки = ТаблицаДокументы.Добавить();
				НоваяСтрокаВыгрузки.НаименованиеДокумента = "Счет-фактура (инвойс)";
				НоваяСтрокаВыгрузки.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(СтрокаТовары.НомерСчетаФактуры, Истина, Ложь);
				НоваяСтрокаВыгрузки.ДатаДокумента = СтрокаТовары.ДатаСчетаФактуры;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если НаправлениеПеремещения = "ЭК" Тогда
			
			Если СтрокаТовары.ПроизводительСтранаРегистрацииКод = "RU" И Не ЗначениеЗаполнено(СтрокаТовары.ПроизводительОКАТО) Тогда
				Если ЗначениеЗаполнено(СтрокаТовары.ПроизводительКПП) Тогда
					КодРегиона = Лев(СтрокаТовары.ПроизводительКПП, 2);
				ИначеЕсли ЗначениеЗаполнено(СтрокаТовары.ПроизводительИНН) Тогда
					КодРегиона = Лев(СтрокаТовары.ПроизводительИНН, 2);
				Иначе
					КодРегиона = "";
				КонецЕсли;
				Если КодРегиона = "" Тогда
					ПроизводительОКАТО = "";
				Иначе
					ОтбСтроки = ТаблицаОКАТО.НайтиСтроки(Новый Структура("КодРегиона", КодРегиона));
					ПроизводительОКАТО = ?(ЗначениеЗаполнено(ОтбСтроки), ОтбСтроки[0].Код, "");
				КонецЕсли;
				СтрокаТовары.ПроизводительОКАТО = ПроизводительОКАТО;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Если РеквизитыШапка.ВалютаТовараКод <> "RUB" Тогда
		
		ДанныеВалютногоКонтроля = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(РеквизитыШапка.Договор,
			"УникальныйНомерВалютногоКонтроля,ДатаПостановкиНаВалютныйКонтроль");
		
		Если ЗначениеЗаполнено(ДанныеВалютногоКонтроля.УникальныйНомерВалютногоКонтроля) Тогда
			
			НоваяСтрокаВыгрузки = ТаблицаДокументы.Добавить();
			НоваяСтрокаВыгрузки.НаименованиеДокумента = "Уникальный номер договора (паспорт сделки)";
			НоваяСтрокаВыгрузки.НомерДокумента = ДанныеВалютногоКонтроля.УникальныйНомерВалютногоКонтроля;
			НоваяСтрокаВыгрузки.ДатаДокумента = ДанныеВалютногоКонтроля.ДатаПостановкиНаВалютныйКонтроль;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ТаблицаДокументы.Свернуть("НаименованиеДокумента,НомерДокумента,ДатаДокумента");
	
	Если ТаблицаТоварыДляВыгрузки <> Неопределено
		И НаправлениеПеремещения = "ИМ" Тогда
		
		ТаблицаТоварыДляВыгрузки.Колонки.Удалить("ДатаСчетаФактуры");
		ТаблицаТоварыДляВыгрузки.Колонки.Удалить("НомерСчетаФактуры");
		ТаблицаТоварыДляВыгрузки.Колонки.Удалить("ДатаТСД");
		ТаблицаТоварыДляВыгрузки.Колонки.Удалить("СерияНомерТСД");
		
	КонецЕсли;
	
	Результат.РеквизитыШапка = РеквизитыШапка;
	Результат.ТаблицаДокументы = ТаблицаДокументы;
	Результат.ТаблицаТоварыДляВыгрузки = ТаблицаТоварыДляВыгрузки;
	Результат.ТаблицаДопСведения = ТаблицаДопСведения;
	Результат.ШтрихкодыУпаковок = ШтрихкодыУпаковок;
	Результат.КурсыВалютыНаДатыДокументовОтгрузки = КурсыВалютыНаДатыДокументовОтгрузки;
	
	Возврат Результат;
	
КонецФункции

// Устанавливает список выбора типов документов, используемых в отчете "Статистическая форма учета перемещения товаров"
// Параметры
// СписокЗначений - СписокЗначений - список значений для выбора типов документов, используемых для
//                                   заполнения отчета "Статистическая форма учета перемещения товаров"
Процедура СписокДокументовСтатистическойФормыУчетаПеремещенияТоваров(СписокЗначений) Экспорт
	
	МакетПоказателей = Отчеты.РегламентированныйОтчетСтатистикаФормаУчетаПеремещенияТоваровТС.ПолучитьМакет("СпискиАналогЛК");
	СписокДокументов = МакетПоказателей.ПолучитьОбласть("СписокДокументов");
	
	СписокЗначений.Очистить();
	
	Для Ном = 2 По СписокДокументов.ВысотаТаблицы Цикл
		
		СписокЗначений.Добавить(СписокДокументов.Область(Ном,2).Текст, СписокДокументов.Область(Ном,2).Текст);
		
	КонецЦикла;
	
	СписокЗначений.СортироватьПоПредставлению();
	
КонецПроцедуры

Функция КурсыВалютыНаДатыДокументовОтгрузки(Знач МассивДокументов, Валюта, ИмяДокумента)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РеализацияТоваровУслуг.Дата КАК Дата,
		|	РеализацияТоваровУслуг.Ссылка КАК ДокументОтгрузки,
		|	&Валюта КАК Валюта
		|ПОМЕСТИТЬ ДатыОтгрузок
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Ссылка В(&МассивДокументов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КурсыВалют.Валюта КАК Валюта,
		|	ДатыОтгрузок.Дата КАК Дата,
		|	МАКСИМУМ(КурсыВалют.Период) КАК Период,
		|	ДатыОтгрузок.ДокументОтгрузки КАК ДокументОтгрузки
		|ПОМЕСТИТЬ ДатаКурса
		|ИЗ
		|	РегистрСведений.КурсыВалют КАК КурсыВалют
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыОтгрузок КАК ДатыОтгрузок
		|		ПО КурсыВалют.Валюта = ДатыОтгрузок.Валюта
		|			И КурсыВалют.Период <= ДатыОтгрузок.Дата
		|
		|СГРУППИРОВАТЬ ПО
		|	КурсыВалют.Валюта,
		|	ДатыОтгрузок.Дата,
		|	ДатыОтгрузок.ДокументОтгрузки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДатаКурса.Дата КАК Дата,
		|	КурсыВалют.Валюта КАК Валюта,
		|	КурсыВалют.Курс КАК Курс,
		|	КурсыВалют.Кратность КАК Кратность,
		|	ДатаКурса.ДокументОтгрузки КАК ДокументОтгрузки
		|ИЗ
		|	РегистрСведений.КурсыВалют КАК КурсыВалют
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатаКурса КАК ДатаКурса
		|		ПО КурсыВалют.Валюта = ДатаКурса.Валюта
		|			И КурсыВалют.Период = ДатаКурса.Период";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	Запрос.УстановитьПараметр("Валюта", Валюта);
	
	Если ИмяДокумента <> "РеализацияТоваровУслуг" Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "РеализацияТоваровУслуг", ИмяДокумента);
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура СведенияОСчетеФактуреВыданномЭкспорт(Знач МассивДокументов, ТаблицаДокументы)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СчетФактураВыданный.Номер КАК Номер,
	|	СчетФактураВыданный.Дата КАК Дата
	|ИЗ
	|	Документ.СчетФактураВыданный КАК СчетФактураВыданный
	|ГДЕ
	|	СчетФактураВыданный.ДокументОснование В(&МассивДокументов)
	|	И НЕ СчетФактураВыданный.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Строка = ТаблицаДокументы.Добавить();
		Строка.НаименованиеДокумента = "Счет-фактура (инвойс)";
		Строка.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Выборка.Номер, Истина, Ложь);
		Строка.ДатаДокумента = Выборка.Дата;
		
	КонецЦикла;

КонецПроцедуры

Функция ТекстЗапросаШапкаСтатформаЭкспорт()
	Возврат
	"ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка КАК ДокументСсылка,
	|	РеализацияТоваровУслуг.Номер КАК СистемныйНомер,
	|	РеализацияТоваровУслуг.Дата КАК Дата,
	|	РеализацияТоваровУслуг.Организация.ИНН КАК ОтправительКоды,
	|	НЕОПРЕДЕЛЕНО КАК ОтправительРеквизиты,
	|	РеализацияТоваровУслуг.Организация.НаименованиеПолное КАК ОтправительНаименование,
	|	РеализацияТоваровУслуг.Контрагент КАК Контрагент,
	|	РеализацияТоваровУслуг.ДоговорКонтрагента.Номер КАК НомерДоговора,
	|	РеализацияТоваровУслуг.ДоговорКонтрагента.Дата КАК ДатаДоговора,
	|	РеализацияТоваровУслуг.ДоговорКонтрагента КАК Договор,
	|	РеализацияТоваровУслуг.Контрагент.ИНН КАК ПокупательИНН,
	|	РеализацияТоваровУслуг.Контрагент.КПП КАК ПокупательКПП,
	|	НЕОПРЕДЕЛЕНО КАК ПолучательКоды,
	|	НЕОПРЕДЕЛЕНО КАК ПолучательРеквизиты,
	|	РеализацияТоваровУслуг.ВалютаДокумента КАК ВалютаДокумента,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.ВалютаДокумента = &ВалютаРеглУчета
	|			ТОГДА ""RUB""
	|		ИНАЧЕ РеализацияТоваровУслуг.ВалютаДокумента.Наименование
	|	КОНЕЦ КАК ВалютаТовараКод,
	|	РеализацияТоваровУслуг.Организация КАК Организация,
	|	РеализацияТоваровУслуг.Организация.ОбособленноеПодразделение КАК ОбособленноеПодразделение,
	|	РеализацияТоваровУслуг.Контрагент.ЮридическоеФизическоеЛицо КАК ПолучательЮридическоеФизическоеЛицо,
	|	РеализацияТоваровУслуг.Контрагент.НалоговыйНомер КАК НалоговыйНомер,
	|	РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.КодАльфа2 КАК ТоргующаяСтранаКод,
	|	РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.Наименование КАК ТоргующаяСтранаНаименование,
	|	""RU"" КАК СтранаОтправленияКод,
	|	""РОССИЯ"" КАК СтранаОтправленияНаименование,
	|	РеализацияТоваровУслуг.ВидТранспортаНаГранице КАК ВидТранспортаКод,
	|	НЕОПРЕДЕЛЕНО КАК ВидТранспортаНаименование,
	|	НЕОПРЕДЕЛЕНО КАК ОтвЛицоФинУрКоды,
	|	НЕОПРЕДЕЛЕНО КАК ОтвЛицоФинУрРеквизиты,
	|	""ЭК"" КАК НаправлениеПеремещения,
	|	""ЭК"" КАК НапрПеремещения,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(РеализацияТоваровУслуг.СтранаРеализации, ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)
	|			ТОГДА РеализацияТоваровУслуг.СтранаРеализации.Наименование
	|		ИНАЧЕ РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.Наименование
	|	КОНЕЦ КАК СтранаНазначенияНаименование,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(РеализацияТоваровУслуг.СтранаРеализации, ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)
	|			ТОГДА РеализацияТоваровУслуг.СтранаРеализации.КодАльфа2
	|		ИНАЧЕ РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.КодАльфа2
	|	КОНЕЦ КАК СтранаНазначенияКод,
	|	НЕОПРЕДЕЛЕНО КАК ОргПочтовыйАдресСоответствие,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.ВалютаДокумента = &ВалютаРеглУчета
	|			ТОГДА ""RUB""
	|		ИНАЧЕ РеализацияТоваровУслуг.ВалютаДокумента.Наименование
	|	КОНЕЦ КАК КодВалютыЦеныТовара,
	|	""РФ"" КАК СтранаОтправления,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(РеализацияТоваровУслуг.СтранаРеализации, ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)
	|			ТОГДА ВЫБОР
	|					КОГДА РеализацияТоваровУслуг.СтранаРеализации.КодАльфа2 = ""KZ""
	|						ТОГДА ""РК""
	|					КОГДА РеализацияТоваровУслуг.СтранаРеализации.КодАльфа2 = ""BY""
	|						ТОГДА ""РБ""
	|					КОГДА РеализацияТоваровУслуг.СтранаРеализации.КодАльфа2 = ""AM""
	|						ТОГДА ""АМ""
	|					КОГДА РеализацияТоваровУслуг.СтранаРеализации.КодАльфа2 = ""KG""
	|						ТОГДА ""КГ""
	|					ИНАЧЕ """"
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.КодАльфа2 = ""KZ""
	|					ТОГДА ""РК""
	|				КОГДА РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.КодАльфа2 = ""BY""
	|					ТОГДА ""РБ""
	|				КОГДА РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.КодАльфа2 = ""AM""
	|					ТОГДА ""АМ""
	|				КОГДА РеализацияТоваровУслуг.Контрагент.СтранаРегистрации.КодАльфа2 = ""KG""
	|					ТОГДА ""КГ""
	|				ИНАЧЕ """"
	|			КОНЕЦ
	|	КОНЕЦ КАК СтранаНазначения,
	|	РеализацияТоваровУслуг.Организация.ЮридическоеФизическоеЛицо КАК ОтправительЮридическоеФизическоеЛицо,
	|	РеализацияТоваровУслуг.Организация.ИндивидуальныйПредприниматель КАК ИндивидуальныйПредприниматель,
	|	РеализацияТоваровУслуг.Организация.СтатусФизическогоЛица КАК СтатусФизическогоЛица,
	|	РеализацияТоваровУслуг.Организация.ИмяИП КАК ИмяИП,
	|	РеализацияТоваровУслуг.Организация.ОтчествоИП КАК ОтчествоИП,
	|	РеализацияТоваровУслуг.Организация.ФамилияИП КАК ФамилияИП,
	|	РеализацияТоваровУслуг.Организация.НаименованиеОКОПФ КАК Отправитель_ФормаСобственности,
	|	РеализацияТоваровУслуг.Организация.ИНН КАК ОтправительРФ_ИНН,
	|	РеализацияТоваровУслуг.Организация.КПП КАК ОтправительРФ_КПП,
	|	РеализацияТоваровУслуг.Организация.ОГРН КАК ОтправительРФ_ОГРН,
	|	"""" КАК Получатель_ФормаСобственности,
	|	РеализацияТоваровУслуг.ЭлектроннаяТорговаяПлощадка КАК ПродажаФизлицуЧерезЭлектроннуюТорговуюПлощадку,
	|	РеализацияТоваровУслуг.Организация.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка В(&МассивДокументов)";
КонецФункции

