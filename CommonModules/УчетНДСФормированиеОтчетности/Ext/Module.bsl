Процедура ЗаполнитьСтатистическуюФормуУчетаПеремещенияТоваров(ПараметрыОтчета, Контейнер)
	
	Контейнер = ТаблицыСтатистическойФормыУчетаПеремещенияТоваров(ПараметрыОтчета.МассивДокументов, ПараметрыОтчета.НаправлениеПеремещения);
	
КонецПроцедуры

// Определяет Структуру таблиц значений для заполнения отчета "Статистическая форма учета перемещения товаров"
// Параметры
// МассивДокументов       - массив документов отгрузки (РеализацияТоваровУслуг.Ссылка)
//......................... или массив структур со значениением Ссылка (ОтчетКомиссионераОПродажах.Ссылка)
//                                при экспорте товаров в страны ЕАЭС,
//                          либо массив заявлений о ввозе товаров (ЗаявлениеОВвозеТоваров.Ссылка)
//                                при импорте товаров из стран ЕАЭС
// НаправлениеПеремещения - Строка - "ЭК" - экспорт товаров в страны ЕАЭС, "ИМ" - импорт товаров из стран ЕАЭС
//
// Возвращаемое значение:
// Структура - поля структуры:
//    РеквизитыШапка                      - Структура
//    ТаблицаДокументы                    - ТаблицаЗначений
//    ТаблицаТоварыДляВыгрузки            - ТаблицаЗначений
//    ШтрихкодыУпаковок                   - ТаблицаЗначений
//    КурсыВалютыНаДатыДокументовОтгрузки - ТаблицаЗначений
Функция ТаблицыСтатистическойФормыУчетаПеремещенияТоваров(МассивДокументов, НаправлениеПеремещения) Экспорт
	
	//Инициализация структуры результата для возврата значения функции
	
	РеквизитыШапка = Новый Структура;
	ТаблицаТоварыДляВыгрузки = Новый ТаблицаЗначений;
	ШтрихкодыУпаковок = Неопределено;
	КурсыВалютыНаДатыДокументовОтгрузки = Новый ТаблицаЗначений;
	
	ТаблицаДокументы = Новый ТаблицаЗначений; // Таблица для выгрузки
	ТаблицаДокументы.Колонки.Добавить("НаименованиеДокумента", ОбщегоНазначения.ОписаниеТипаСтрока(1000));
	ТаблицаДокументы.Колонки.Добавить("НомерДокумента", ОбщегоНазначения.ОписаниеТипаСтрока(1000));
	ТаблицаДокументы.Колонки.Добавить("ДатаДокумента", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	
	// Дополнительная информация о товарах
	ТаблицаДопСведения = Новый ТаблицаЗначений;
	ТаблицаДопСведения.Колонки.Добавить("ДокументСсылка");
	ТаблицаДопСведения.Колонки.Добавить("Номенклатура");
	ТаблицаДопСведения.Колонки.Добавить("Код");
	ТаблицаДопСведения.Колонки.Добавить("ДополнительнаяИнформация");
	
	Результат = Новый Структура(
		"РеквизитыШапка, ТаблицаДокументы, ТаблицаТоварыДляВыгрузки,
		|ТаблицаДопСведения, ШтрихкодыУпаковок, КурсыВалютыНаДатыДокументовОтгрузки",
		РеквизитыШапка, ТаблицаДокументы, ТаблицаТоварыДляВыгрузки,
		ТаблицаДопСведения, ШтрихкодыУпаковок, КурсыВалютыНаДатыДокументовОтгрузки);
		
	Если МассивДокументов.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	МакетПоказателей = Отчеты.РегламентированныйОтчетСтатистикаФормаУчетаПеремещенияТоваровТС.ПолучитьМакет("СпискиАналогЛК");
	СписокЗначенийГрафы19 = МакетПоказателей.ПолучитьОбласть("Гр19");
	ДопСведенияПрослеживаемыеТовары = "";
	ДопСведенияТоварыФизЛицамЭлектронныеТорговыеПлощадки = "";
	
	// Нумерация начинается со 2-й строки, т.к. 1-я строка в макете содержит пустое значение
	Для Ном = 2 По СписокЗначенийГрафы19.ВысотаТаблицы Цикл
		
		Если СокрЛП(СписокЗначенийГрафы19.Область(Ном,1).Текст) = "07" Тогда
			ДопСведенияТоварыФизЛицамЭлектронныеТорговыеПлощадки = СокрЛП(СписокЗначенийГрафы19.Область(Ном,2).Текст);
		КонецЕсли;
		
		Если СокрЛП(СписокЗначенийГрафы19.Область(Ном,1).Текст) = "08" Тогда
			ДопСведенияПрослеживаемыеТовары = СокрЛП(СписокЗначенийГрафы19.Область(Ном,2).Текст);
		КонецЕсли;
		
	КонецЦикла;
	
	ИмяДокумента = "РеализацияТоваровУслуг";
	ДокументОтгрузки = МассивДокументов[0];
	
	Если ТипЗнч(ДокументОтгрузки) = Тип("Структура") Тогда
		ИмяДокумента = "ОтчетКомиссионераОПродажах";
		ДокументСсылка = ДокументОтгрузки.ДокументСсылка;
		МассивДокументов.Очистить();
		МассивДокументов.Добавить(ДокументСсылка);
	КонецЕсли;
	
	ВалютаРеглУчета = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	ДолларСША = Справочники.Валюты.НайтиПоНаименованию("USD",Истина);
	
	КурсыВалютыНаДатыДокументовОтгрузки = КурсыВалютыНаДатыДокументовОтгрузки(МассивДокументов, ДолларСША, ИмяДокумента);
	
	Шапка = Неопределено;
	ЗапросШапка = Новый Запрос;
	ЗапросШапка.УстановитьПараметр("МассивДокументов", МассивДокументов);
	ЗапросШапка.УстановитьПараметр("ВалютаРеглУчета", ВалютаРеглУчета);
	
	ЗапросТовары = Новый Запрос;
	ЗапросТовары.УстановитьПараметр("МассивДокументов", МассивДокументов);
	ЗапросТовары.УстановитьПараметр("ВалютаРеглУчета", ВалютаРеглУчета);
	ЗапросТовары.УстановитьПараметр("ДолларСША", ДолларСША);
	ЗапросТовары.УстановитьПараметр("ДопСведенияПрослеживаемыеТовары", ДопСведенияПрослеживаемыеТовары);
	ЗапросТовары.УстановитьПараметр("КурсыВалютыНаДатыДокументовОтгрузки", КурсыВалютыНаДатыДокументовОтгрузки);
	
	// Информация о товарах, подлежащих обязательной маркировке
	ЗапросШтрихкодыУпаковок = Новый Запрос;
	ЗапросШтрихкодыУпаковок.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	// Статформа подается ежемесячно всегда по одной организации
	Если НаправлениеПеремещения = "ЭК" Тогда
		
		Если ИмяДокумента = "РеализацияТоваровУслуг" Тогда
			
			ЗапросШапка.Текст = ТекстЗапросаШапкаСтатформаЭкспорт();
			
			ЗапросТовары.Текст = ТекстЗапросаТоварыСтатформаЭкспорт(ИмяДокумента);
			ЗапросТовары.УстановитьПараметр("КлючСтроки", Истина);
			
			ЗапросШтрихкодыУпаковок.Текст = ТекстЗапросаМаркировкаШтрихкодыУпаковокСтатформаЭкспорт();
			
			Шапка = ЗапросШапка.Выполнить().Выгрузить();
			ШтрихкодыУпаковок = ЗапросШтрихкодыУпаковок.Выполнить().Выгрузить();
			СведенияОСчетеФактуреВыданномЭкспорт(МассивДокументов, ТаблицаДокументы);
			
		Иначе
			РеквизитыШапка = ДокументОтгрузки;
			РеквизитыШапкаСтатформаЭкспортПоОтчетуКомиссионера(РеквизитыШапка, ВалютаРеглУчета);
			
			ЗапросТовары.Текст = ТекстЗапросаТоварыСтатформаЭкспорт(ИмяДокумента);
			ЗапросТовары.УстановитьПараметр("КлючСтроки", РеквизитыШапка.КлючСтроки);
			
			НоваяСтрока = ТаблицаДокументы.Добавить();
			НоваяСтрока.НаименованиеДокумента = "Договор";
			НоваяСтрока.НомерДокумента = ДокументОтгрузки.НомерДоговора;
			НоваяСтрока.ДатаДокумента = ДокументОтгрузки.ДатаДоговора;
			
			НоваяСтрока = ТаблицаДокументы.Добавить();
			НоваяСтрока.НаименованиеДокумента = "Счет-фактура (инвойс)";
			НоваяСтрока.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(
				ДокументОтгрузки.НомерСчетаФактурыОтКомиссионера, Истина, Ложь);
			НоваяСтрока.ДатаДокумента = ДокументОтгрузки.ДатаСчетаФактурыОтКомиссионера;
			
			НоваяСтрока = ТаблицаДокументы.Добавить();
			НоваяСтрока.НаименованиеДокумента = "Счет-фактура (инвойс)";
			НоваяСтрока.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(
				ДокументОтгрузки.НомерСчетаФактурыВыданного, Истина, Ложь);
			НоваяСтрока.ДатаДокумента = ДокументОтгрузки.ДатаСчетаФактурыВыданного;
			
		КонецЕсли;
		
	Иначе
		
		ЗапросШапка.Текст = ТекстЗапросаШапкаСтатформаИмпорт();
		ЗапросТовары.Текст = ТекстЗапросаТоварыСтатформаИмпорт();
		ЗапросШтрихкодыУпаковок.Текст = ТекстЗапросаМаркировкаШтрихкодыУпаковокСтатформаИмпорт();
		
		Шапка = ЗапросШапка.Выполнить().Выгрузить();
		ШтрихкодыУпаковок = ЗапросШтрихкодыУпаковок.Выполнить().Выгрузить();
		СведенияОДокументахСтатформаИмпорт(МассивДокументов, ТаблицаДокументы);
		
	КонецЕсли;
	
	ТаблицаТоварыДляВыгрузки = ЗапросТовары.Выполнить().Выгрузить();
	
	Для каждого Документ Из МассивДокументов Цикл
		
		Если НаправлениеПеремещения = "ЭК"
			И ИмяДокумента = "РеализацияТоваровУслуг" Тогда
			
			Отбор = Новый Структура;
			Отбор.Вставить("ДокументСсылка", Документ);
			Отбор.Вставить("ПродажаФизлицуЧерезЭлектроннуюТорговуюПлощадку", Истина);
			РезультатПоиска = Шапка.НайтиСтроки(Отбор);
			
			Если РезультатПоиска.Количество() > 0 Тогда
				
				Отбор = Новый Структура;
				Отбор.Вставить("ДокументСсылка", Документ);
				ТоварыФизлицуЧерезЭлектроннуюТорговуюПлощадку = ТаблицаТоварыДляВыгрузки.НайтиСтроки(Отбор);
				
				Для каждого Товар Из ТоварыФизлицуЧерезЭлектроннуюТорговуюПлощадку Цикл
					ДопСведения = ТаблицаДопСведения.Добавить();
					ДопСведения.ДокументСсылка = Товар.ДокументСсылка;
					ДопСведения.Номенклатура = Товар.Номенклатура;
					ДопСведения.Код = "07";
					ДопСведения.ДополнительнаяИнформация = ДопСведенияТоварыФизЛицамЭлектронныеТорговыеПлощадки;
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Отбор = Новый Структура;
		Отбор.Вставить("ДокументСсылка", Документ);
		Отбор.Вставить("ПрослеживаемыйТовар", Истина);
		ПрослеживаемыеТовары = ТаблицаТоварыДляВыгрузки.НайтиСтроки(Отбор);
		
		Для каждого Товар Из ПрослеживаемыеТовары Цикл
			ДопСведения = ТаблицаДопСведения.Добавить();
			ДопСведения.ДокументСсылка = Товар.ДокументСсылка;
			ДопСведения.Номенклатура = Товар.Номенклатура;
			ДопСведения.Код = "08";
			ДопСведения.ДополнительнаяИнформация = ДопСведенияПрослеживаемыеТовары;
		КонецЦикла;
		
	КонецЦикла;

	ПараметрыРазбораКодаМаркировки = РазборКодаМаркировкиИССлужебныйКлиентСервер.ИнициализироватьПараметрыРазбораКодаМаркировки();
	ПараметрыРазбораКодаМаркировки.НачинаетсяСоСкобки = Ложь;
	
	// Табличная часть документов ШтрихкодыУпаковок содержит информацию только о штрихкодах упаковок товаров,
	// подлежащих обязательной маркировке
	// Для правильного определения единичного кода в табличной части ШтрихкодыУпаковок колонка ЕдиничныйКод
	// должна иметь тип НЕОПРЕДЕЛЕНО или строгую типизацию
	Если ШтрихкодыУпаковок <> Неопределено Тогда
		
		Для каждого СтрокаШтрихкодыУпаковок Из ШтрихкодыУпаковок Цикл
			
			РезультатРазбора = РазборКодаМаркировкиИССлужебный.РазобратьКодМаркировки(СтрокаШтрихкодыУпаковок.ШтрихкодУпаковки);
			ШтрихкодыEAN = Новый Массив;
			ШтрихкодыEAN.Добавить(РезультатРазбора.СоставКодаМаркировки.EAN);
			ДанныеПоШтрихкодамEAN = ШтрихкодированиеОбщегоНазначенияИС.ДанныеПоШтрихкодамEAN(ШтрихкодыEAN);
			
			СтрокаШтрихкодыУпаковок.ЕдиничныйКод = РазборКодаМаркировкиИССлужебныйКлиентСервер.НормализоватьКодМаркировки(
													РезультатРазбора, ,ПараметрыРазбораКодаМаркировки);
													
			// Значения КодУровняМаркировки и КодВидаСтредстваИдентификации взяты из макета СпискиАналогЛК
			// отчета РегламентированныйОтчетСтатистикаФормаУчетаПеремещенияТоваровТС
			
			Если ДанныеПоШтрихкодамEAN.Количество() > 0 Тогда
				
				ВидУпаковки = ДанныеПоШтрихкодамEAN[0].ВидУпаковкиИС;
				
				Если ВидУпаковки = Перечисления.ВидыУпаковокИС.Потребительская Тогда
					
					СтрокаШтрихкодыУпаковок.КодУровняМаркировки = "0 - Товарная упаковка (КМ, КИ, sGTIN)";
					
				ИначеЕсли ВидУпаковки = Перечисления.ВидыУпаковокИС.Групповая
					ИЛИ ВидУпаковки = Перечисления.ВидыУпаковокИС.Набор Тогда
					
					СтрокаШтрихкодыУпаковок.КодУровняМаркировки = "1 - Групповая упаковка (КИГУ)";
					
				ИначеЕсли ВидУпаковки = Перечисления.ВидыУпаковокИС.Логистическая Тогда
					
					СтрокаШтрихкодыУпаковок.КодУровняМаркировки = "2 - Транспортная упаковка (КИТУ, 35СС)";
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	СписокВидовТранспорта = Новый СписокЗначений;
	УчетНДСКлиентСервер.ЗаполнитьСписокВыбораВидовТранспорта(СписокВидовТранспорта);
	
	Если Шапка <> Неопределено
		И Шапка.Количество() > 0 Тогда
		
		Для каждого СтрокаШапки Из Шапка Цикл
		
			НоваяСтрокаВыгрузки = ТаблицаДокументы.Добавить();
			НоваяСтрокаВыгрузки.НаименованиеДокумента = "Договор";
			НоваяСтрокаВыгрузки.НомерДокумента = СтрокаШапки.НомерДоговора;
			НоваяСтрокаВыгрузки.ДатаДокумента = СтрокаШапки.ДатаДоговора;
			
			Если НаправлениеПеремещения = "ЭК" Тогда
				НоваяСтрокаВыгрузки = ТаблицаДокументы.Добавить();
				НоваяСтрокаВыгрузки.НаименованиеДокумента = "Товарная накладная";
				НоваяСтрокаВыгрузки.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(СтрокаШапки.СистемныйНомер, Истина, Ложь);
				НоваяСтрокаВыгрузки.ДатаДокумента = СтрокаШапки.Дата;
			КонецЕсли;
		
		КонецЦикла;
		
		СтрокаШапки = Шапка[0];
		
		РеквизитыШапка = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаШапки); // Структура для выгрузки
		РеквизитыШапкаСтатформа(
			РеквизитыШапка,
			РеквизитыШапка.СистемныйНомер,
			РеквизитыШапка.Дата,
			РеквизитыШапка.ДокументСсылка);
			
	КонецЕсли;
	
	// Для графы 3 сведения о лице, ответственное за финансовое урегулирование:
	// 1. в случае экспорта заполняются из организации,
	// 2. в случае импорта тоже из организации
	// Ограничение из БРО:
	// Считается заявитель и лицо ответственное за финансовое урегулирование - это одно и тоже лицо.
	// При экспорте получателем является всегда иностранное государство, а отправителем является РФ.
	// При импорте получателем является всегда РФ, а отправителем является иностранное государство.
	
	ТаблицаОКАТО = ЗаполнитьТаблицуОКАТО();
	Если ЗначениеЗаполнено(РеквизитыШапка.Организация) Тогда
		ОКАТООрганизации = Справочники.РегистрацииВНалоговомОргане.КодТерритории(РеквизитыШапка.РегистрацияВНалоговомОргане, "ОКАТО");
		Если ОКАТООрганизации = "" Тогда
			ОКТМООрганизации = Справочники.РегистрацииВНалоговомОргане.КодТерритории(РеквизитыШапка.РегистрацияВНалоговомОргане, "ОКТМО");
			Если ОКТМООрганизации = "" Тогда
				РегионОКАТО = "";
			Иначе
				Регион = СтрШаблон("%1%2", Лев(ОКТМООрганизации, 4), "0");
				
				ОтбСтроки = ТаблицаОКАТО.НайтиСтроки(Новый Структура("Код", Регион));
				РегионОКАТО = ?(ЗначениеЗаполнено(ОтбСтроки), ОтбСтроки[0].Код, "");
				Если РегионОКАТО = "" Тогда
					Регион = СтрШаблон("%1%2", Лев(ОКТМООрганизации, 2), "000");
					
					ОтбСтроки = ТаблицаОКАТО.НайтиСтроки(Новый Структура("Код", Регион));
					РегионОКАТО = ?(ЗначениеЗаполнено(ОтбСтроки), ОтбСтроки[0].Код, "");
				КонецЕсли;
			КонецЕсли;
			
		Иначе
			Регион = СтрШаблон("%1%2", Лев(ОКАТООрганизации, 4), "0");
			
			ОтбСтроки = ТаблицаОКАТО.НайтиСтроки(Новый Структура("Код", Регион));
			РегионОКАТО = ?(ЗначениеЗаполнено(ОтбСтроки), ОтбСтроки[0].Код, "");
			Если РегионОКАТО = "" Тогда
				Регион = СтрШаблон("%1%2", Лев(ОКАТООрганизации, 2), "000");
				
				ОтбСтроки = ТаблицаОКАТО.НайтиСтроки(Новый Структура("Код", Регион));
				РегионОКАТО = ?(ЗначениеЗаполнено(ОтбСтроки), ОтбСтроки[0].Код, "");
			КонецЕсли;
		КонецЕсли;
	Иначе
		РегионОКАТО = "";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РеквизитыШапка.Организация) И ЗначениеЗаполнено(РеквизитыШапка.Контрагент) Тогда
		
		Если НаправлениеПеремещения = "ЭК" Тогда
			
			СведенияОПродавце = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
				РеквизитыШапка.Организация, РеквизитыШапка.Дата);
			СведенияОПродавце.Телефоны = СтрЗаменить(СведенияОПродавце.Телефоны, "+7", "8");
			
			ПравоваяФормаВСтатистическойФормеУчетаПеремещенияТоваров(РеквизитыШапка.Отправитель_ФормаСобственности,
				РеквизитыШапка.СтатусФизическогоЛица);
			
			СведенияОПокупателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
				РеквизитыШапка.Контрагент, РеквизитыШапка.Дата);
			СведенияОПокупателе.Телефоны = СтрЗаменить(СведенияОПокупателе.Телефоны, "+7", "8");
			
			ОтправительАдрес = УчетНДСВызовСервера.ПолучитьАдресВВидеСоответствия(
				РеквизитыШапка.Организация,
				Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации,
				РеквизитыШапка.Дата);
			
			ПолучательАдрес = УчетНДСВызовСервера.ПолучитьАдресВВидеСоответствия(
				РеквизитыШапка.Контрагент,
				Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента,
				РеквизитыШапка.Дата);
			
			РеквизитыШапка.ПолучательКоды = РеквизитыШапка.НалоговыйНомер;
			
			// Реквизиты подписи - сокращенное наименование заявителя статформы
			РеквизитыШапка.Вставить("ПолнСокрНаим", СведенияОПродавце.СокращенноеНаименование);
			
			Если ЗначениеЗаполнено(РеквизитыШапка.ОтправительРФ_КПП) Тогда
				ИННКППОГРН = РеквизитыШапка.ОтправительРФ_ИНН+ "/" + РеквизитыШапка.ОтправительРФ_КПП + "/"
							+ РеквизитыШапка.ОтправительРФ_ОГРН;
			Иначе
				ИННКППОГРН = РеквизитыШапка.ОтправительРФ_ИНН+ "/" + РеквизитыШапка.ОтправительРФ_ОГРН;
			КонецЕсли;
			
			ЗаявительЮридическоеФизическоеЛицо = РеквизитыШапка.ОтправительЮридическоеФизическоеЛицо;
			
			РеквизитыШапка.Вставить("ОтправительОКАТО", РегионОКАТО);
			
		Иначе
			
			СведенияОПродавце = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
				РеквизитыШапка.Контрагент, РеквизитыШапка.Дата);
			
			СведенияОПокупателе = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(
				РеквизитыШапка.Организация, РеквизитыШапка.Дата);
				
			ПравоваяФормаВСтатистическойФормеУчетаПеремещенияТоваров(РеквизитыШапка.Получатель_ФормаСобственности, 
				РеквизитыШапка.СтатусФизическогоЛица);
			
			ОтправительАдрес = УчетНДСВызовСервера.ПолучитьАдресВВидеСоответствия(
				РеквизитыШапка.Контрагент,
				Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента,
				РеквизитыШапка.Дата);
			
			ПолучательАдрес = УчетНДСВызовСервера.ПолучитьАдресВВидеСоответствия(
				РеквизитыШапка.Организация,
				Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации,
				РеквизитыШапка.Дата);
			
			Если ЗначениеЗаполнено(РеквизитыШапка.ПокупательКПП) Тогда
				РеквизитыШапка.ПолучательКоды = РеквизитыШапка.ПокупательИНН + "/" + РеквизитыШапка.ПокупательКПП;
			Иначе
				РеквизитыШапка.ПолучательКоды = РеквизитыШапка.ПокупательИНН;
			КонецЕсли;
			
			// Реквизиты подписи - сокращенное наименование заявителя статформы
			РеквизитыШапка.Вставить("ПолнСокрНаим", СведенияОПокупателе.СокращенноеНаименование);
			
			Если ЗначениеЗаполнено(РеквизитыШапка.ПокупательКПП) Тогда
				ИННКППОГРН = РеквизитыШапка.ПокупательИНН + "/" + РеквизитыШапка.ПокупательКПП + "/"
							+ РеквизитыШапка.ОГРН;
			Иначе
				ИННКППОГРН = РеквизитыШапка.ПокупательИНН + "/" + РеквизитыШапка.ОГРН;
			КонецЕсли;
			
			ЗаявительЮридическоеФизическоеЛицо = РеквизитыШапка.ПолучательЮридическоеФизическоеЛицо;
			
			// Заполняем код вида транспорта на границе
