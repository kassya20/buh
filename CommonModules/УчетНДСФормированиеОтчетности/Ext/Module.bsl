Функция ПравилаЗаполнения(Период = '20250101') 
	
	Если Период < '20201001' Тогда    
		Возврат "2019Кв1";     
	ИначеЕсли Период < '20210701' Тогда 
		Возврат "2020Кв4";
	ИначеЕсли Период < '20230101' Тогда 
		Возврат "2021Кв3";
	ИначеЕсли Период < '20250101' Тогда
		Возврат "2023Кв1";
	ИначеЕсли Период < '20260101' Тогда
		Возврат "2025Кв1"; 
	Иначе
		Возврат "2026Кв1";
	КонецЕсли;
	
