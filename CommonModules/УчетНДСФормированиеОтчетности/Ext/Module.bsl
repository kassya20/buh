				КомпоновщикXML_ЗакрытьУзел(КомпоновщикXML);
			КонецЕсли;
			
			КомпоновщикXML_ЗакрытьУзел(КомпоновщикXML);
		КонецЕсли;
		
		Для Каждого ДокументПодтверждения Из СтрокаСведений.СвДокПдтвОпл Цикл
