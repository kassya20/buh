Процедура ДобавитьСтраницуРаздел5(Контейнер, НомерСтраницы, ДанныеЗаполнения, МакетыРасшифровкиПолей, ТаблицаРасшифровки, ПараметрыРасшифровки)
	
	Страница = Контейнер.Раздел5.Добавить();
	Страница.АктивнаяСтраница=Ложь;
	Страница.Данные = Новый Структура;
	Страница.Данные.Вставить("П000500001003", Формат(ДанныеЗаполнения.НачалоКвартала, "ДФ=yyyy"));
	
	Если Месяц(ДанныеЗаполнения.НачалоКвартала) = 1 Тогда
		
		Страница.Данные.Вставить("П000500002003", "21");

	ИначеЕсли Месяц(ДанныеЗаполнения.НачалоКвартала) = 4 Тогда
		
		Страница.Данные.Вставить("П000500002003", "22");

	ИначеЕсли Месяц(ДанныеЗаполнения.НачалоКвартала) = 7 Тогда
		
		Страница.Данные.Вставить("П000500002003", "23");
		
	ИначеЕсли Месяц(ДанныеЗаполнения.НачалоКвартала) = 10 Тогда
		
		Страница.Данные.Вставить("П000500002003", "24");
		
	Иначе
		// Сообщить об ошибке неизвестный месяц
		ОписаниеОшибки = НСтр("ru = 'Неизвестное начало квартала.'", ОбщегоНазначения.КодОсновногоЯзыка());
		ВызватьИсключение ОписаниеОшибки;
		Возврат;
		
	КонецЕсли;
	
	// Итоговые показатели
	Страница.Данные.Вставить("П000500008003", 0);
	Страница.Данные.Вставить("П000500009003", 0);

	Страница.Представление = "Лист N " + НомерСтраницы;
	
	// Определяем таблицу значений ДанныеДопСтрок
	ТЗДанныеДопСтрок = Новый ТаблицаЗначений;
	ТЗДанныеДопСтрок.Колонки.Добавить("П000500003003");
	ТЗДанныеДопСтрок.Колонки.Добавить("П000500004003");
	ТЗДанныеДопСтрок.Колонки.Добавить("П000500005003");
	ТЗДанныеДопСтрок.Колонки.Добавить("П000500006003");
	ТЗДанныеДопСтрок.Колонки.Добавить("П000500007003");
	
	Страница.ДанныеДопСтрок = ТЗДанныеДопСтрок;
	СтраницаДанныеДопСтрок = Контейнер.Раздел5_ДанныеДопСтрок.Добавить();
	
	//Добавляем строки на страницу
	
	НомерСтроки = 0;
	
	Выборка = ДанныеЗаполнения.Выбрать();
	
	ПараметрыРасшифровки.Вставить("ДатаНачала", ДанныеЗаполнения.НачалоКвартала);
	
