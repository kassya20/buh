// Функция-конструктор параметров рассылки, которые специфичны для рассылки запросов на сверку.
//
// Возвращаемое значение:
//   Структура - параметры рассылки запросов на сверку:
//   * Организация - СправочникСсылка.Организации - организация.
//   * ДатаНачала - Дата - начало периода сверки.
//   * ДатаОкончания - Дата - окончание периода сверки.
//   * НаименованиеОрганизации - Строка - наименование организации.
//   * СчетаУчетаРасчетов - Массив из ПланСчетовСсылка.Хозрасчетный - счета учета расчетов.
//   * НастройкаРассылки - СправочникСсылка.НастройкиРассылкиЗапросовНаСверку - настройка рассылки.
//
Функция НовыйПараметрыРассылки() Экспорт
	
	ПараметрыРассылки = Новый Структура;
	ПараметрыРассылки.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
	ПараметрыРассылки.Вставить("ДатаНачала", '0001-01-01');
	ПараметрыРассылки.Вставить("ДатаОкончания", '0001-01-01');
	ПараметрыРассылки.Вставить("НаименованиеОрганизации", "");
	ПараметрыРассылки.Вставить("СчетаУчетаРасчетов", Новый Массив);
	ПараметрыРассылки.Вставить("НастройкаРассылки", Справочники.НастройкиРассылкиЗапросовНаСверку.ПустаяСсылка());
	Возврат ПараметрыРассылки;
	
КонецФункции

// Определяет, нужно ли отправить акт сверки в виде приложения к электронному письму
//
// Параметры:
//  СтрокаПолучателя - СтрокаТаблицыЗначений, ДанныеФормыКоллекция - 
//  СоставНастройки - Структура - см. реквизиты справочника НастройкиРассылкиЗапросовНаСверку
//  НастроенЭДО - Булево - Истина, если с получателем настроен ЭДО
// 
// Возвращаемое значение:
//  Булево - Истина, если нужно отправить е-mail и приложить акт сверки
//
Функция ТребуетсяАктСверкиПисьмом(СтрокаПолучателя, СоставНастройки, НастроенЭДО = Неопределено) Экспорт
	
	Если НастроенЭДО = Неопределено Тогда
		НастроенЭДО = Обработки.МониторСверкиСКонтрагентами.НастроенЭДО(СтрокаПолучателя.ЭДО);
	КонецЕсли;
	
	Возврат (СоставНастройки.ПорядокСверки = Перечисления.ПорядокСверкиРасчетовСКонтрагентами.ОтправитьНашАктСверки
		И (Не НастроенЭДО Или СоставНастройки.СпособЗапросаПоЭДО = Перечисления.СпособыЗапросаСверкиЭДО.ОтправитьПисьмо));
	
КонецФункции

// Создает акты сверки для получателей рассылки (если нужно) и возвращает их в виде массива.
//
// Параметры:
//  Получатели - ТаблицаЗначений, ДанныеФормыКоллекция - получатели рассылки.
//  ПараметрыСверки - Структура - параметры сверки.
//  Настройка - Структура - структура реквизитов справочника НастройкиРассылкиЗапросовНаСверку.
// Возвращаемое значение:
//  Массив из ДокументСсылка.АктСверкиВзаиморасчетов - акты сверки.
//
Функция АктыСверкиДляРассылки(Получатели, ПараметрыСверки, Настройка) Экспорт
	
	АктыСверки = Новый Массив;
	
	Для Каждого СтрокаПолучателя Из Получатели Цикл
		
		Если СтрокаПолучателя.ТребуетсяАктСверки Или Не ЗначениеЗаполнено(СтрокаПолучателя.АктСверки) Тогда
			
			ДанныеЗаполнения = Новый Структура;
			ДанныеЗаполнения.Вставить("Организация",   ПараметрыСверки.Организация);
			ДанныеЗаполнения.Вставить("ДатаНачала",    ПараметрыСверки.ДатаНачала);
			ДанныеЗаполнения.Вставить("ДатаОкончания", ПараметрыСверки.ДатаОкончания);
			ДанныеЗаполнения.Вставить("Контрагент"   , СтрокаПолучателя.Получатель);
			ДанныеЗаполнения.Вставить("ЗаполнитьПоДаннымОрганизации", Истина);
			
			Если Обработки.МониторСверкиСКонтрагентами.НастроенЭДО(СтрокаПолучателя.ЭДО) Тогда
				ДанныеЗаполнения.Вставить("ЭтоЭлектронныйДокумент", Истина);
			КонецЕсли;
			
			ДанныеЗаполнения.Вставить("СчетаУчетаРасчетов", ПараметрыСверки.СчетаУчетаРасчетов);
			
			ДанныеЗаполнения.Вставить("РазбитьПоДоговорам", Настройка.РазбитьПоДоговорам);
			ДанныеЗаполнения.Вставить("ВыводитьПолныеНазванияДокументов", Настройка.ВыводитьПолныеНазванияДокументов);
			ДанныеЗаполнения.Вставить("ВыводитьСчетаФактуры", Настройка.ВыводитьСчетаФактуры);
			
			АктСверки = Документы.АктСверкиВзаиморасчетов.СоздатьДокумент();
			АктСверки.Заполнить(ДанныеЗаполнения);
			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(АктСверки,,, РежимЗаписиДокумента.Проведение);
			
			СтрокаПолучателя.АктСверки = АктСверки.Ссылка;
	
		КонецЕсли;
		
		АктыСверки.Добавить(СтрокаПолучателя.АктСверки);
		
	КонецЦикла;
	
	Возврат АктыСверки;
	
КонецФункции

// Обработчик фонового задания для выборки (и создания при необходимости) актов сверки для получателей рассылки.
//
// Параметры:
//  ПараметрыЗадания - Структура - параметры задания.
//  АдресХранилища - Строка - адрес хранилища.
//
Процедура СоздатьАктыСверкиПоПолучателямРассылкиВФоне(ПараметрыЗадания, АдресХранилища) Экспорт
	
	АктыСверки = АктыСверкиДляРассылки(
		ПараметрыЗадания.Получатели,
		ПараметрыЗадания.ПараметрыСверки,
		ПараметрыЗадания.Настройка);
	
	Результат = Новый Структура;
	Результат.Вставить("АктыСверки", АктыСверки);
	Результат.Вставить("Контрагенты", ПараметрыЗадания.Получатели.ВыгрузитьКолонку("Получатель"));
	
	ПоместитьВоВременноеХранилище(Результат, АдресХранилища);

КонецПроцедуры

// Формирует вложения для письма. Если нужно, формирует печатные формы для вложений.
//
// Параметры:
//  СтрокаПолучателя - СтрокаТаблицыЗначений, ДанныеФормыЭлементКоллекции - данные формы элемента коллекции получателя рассылки.
//  СоставНастройки - Структура - структура реквизитов справочника НастройкиРассылкиЗапросовНаСверку.
//  ПараметрыСверки - Структура - параметры сверки.
//  АктыСверкиКВложению - ТаблицаЗначений - см. АктыСверкиКВложению() - закэшированные табличные документы в двоичных данных.
//  НастроенЭДО - Булево - Истина, если с получателем настроен ЭДО.
//  ФорматыОтсутствуютОригиналы - Массив из ТипФайлаТабличногоДокумента - форматы файлов, которые будут добавлены в вложения.
//  ТаблицаФорматов - ТаблицаЗначений - см. УправлениеПечатью.НастройкиФорматовСохраненияТабличногоДокумента() - настройки форматов сохранения табличных документов.
// Возвращаемое значение:
//  Массив из Структура - свойства:
//  * ДвоичныеДанные - ДвоичныеДанные - двоичные данные вложения.
//  * Представление - Строка - представление вложения.
//  * ТипФайла - ТипФайлаТабличногоДокумента - тип файла вложения.
//
Функция СформироватьВложенияПисьма(СтрокаПолучателя, СоставНастройки, ПараметрыСверки, Знач АктыСверкиКВложению = Неопределено,
	НастроенЭДО = Неопределено, ФорматыОтсутствуютОригиналы = Неопределено, ТаблицаФорматов = Неопределено) Экспорт
	
	Вложения = Новый Массив;
	
	// Акт сверки
	Если ТребуетсяАктСверкиПисьмом(СтрокаПолучателя, СоставНастройки, НастроенЭДО)
		 И ЗначениеЗаполнено(СтрокаПолучателя.АктСверки) Тогда
		
		Если АктыСверкиКВложению = Неопределено Тогда
			
			ФорматыАктаСверки = СоставНастройки.ФорматыВложенийАктаСверки.Получить();
			Если Не ЗначениеЗаполнено(ФорматыАктаСверки) Тогда
				ФорматыАктаСверки = Новый Массив;
			КонецЕсли;
			
			АктыСверкиКВложению = АктыСверкиКВложению(
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(СтрокаПолучателя.АктСверки),
				ФорматыАктаСверки,
				ПараметрыСверки);
			
			ВложенияПоАктуСверки = АктыСверкиКВложению;
			
		Иначе
			ВложенияПоАктуСверки = АктыСверкиКВложению.НайтиСтроки(Новый Структура("АктСверки", СтрокаПолучателя.АктСверки));
		КонецЕсли;
		
		Для Каждого Вложение Из ВложенияПоАктуСверки Цикл
			ОписаниеВложения = НовыйОписаниеВложенияДляОчереди();
			ОписаниеВложения.ДвоичныеДанные = Вложение.ДвоичныеДанные;
			ОписаниеВложения.Представление = Вложение.Представление;
			ОписаниеВложения.ТипФайла = Вложение.ТипФайла;
			Вложения.Добавить(ОписаниеВложения);
		КонецЦикла;
		
	КонецЕсли;
	
	ИмяВременнойПапки = ПолучитьИмяВременногоФайла("");
	СоздатьКаталог(ИмяВременнойПапки);
	
	// Список неполученных оригиналов
	Если ТребуетсяСписокНеполученныхОригиналовПисьмом(СтрокаПолучателя, СоставНастройки, НастроенЭДО) Тогда
		
		ПараметрыРасшифровки = Новый Структура;
		ПараметрыРасшифровки.Вставить("ИдентификаторРасшифровки", "РасшифровкаНетОригиналов");
		ПараметрыРасшифровки.Вставить("Контрагент", СтрокаПолучателя.Получатель);
		ПараметрыРасшифровки.Вставить("Организация", ПараметрыСверки.Организация);
		ПараметрыРасшифровки.Вставить("ВключатьОбособленныеПодразделения", Ложь);
		ПараметрыРасшифровки.Вставить("НачалоПериода", НачалоДня(ПараметрыСверки.ДатаНачала));
		ПараметрыРасшифровки.Вставить("КонецПериода", КонецДня(ПараметрыСверки.ДатаОкончания));
		ПараметрыРасшифровки.Вставить("УникальныйИдентификатор", Новый УникальныйИдентификатор());
		
		Расшифровка = Обработки.МониторСверкиСКонтрагентами.СформироватьРасшифровку(ПараметрыРасшифровки);
		ТабличныйДокумент = Расшифровка.Результат;
		
		ИмяФайла = СтрШаблон(НСтр("ru='Запрос оригиналов для %1 от %2 за период с %3 по %4'"),
			ПараметрыСверки.НаименованиеОрганизации,
			СтрокаПолучателя.НаименованиеКонтрагента,
			Формат(ПараметрыСверки.ДатаНачала, "ДФ=dd.MM.yy"),
			Формат(ПараметрыСверки.ДатаОкончания, "ДФ=dd.MM.yy"));
		
		ИмяФайла = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(ИмяФайла);
		
		Если ФорматыОтсутствуютОригиналы = Неопределено Тогда
			ФорматыОтсутствуютОригиналы = СоставНастройки.ФорматыВложенийНеПолученыОригиналы.Получить();
			Если Не ЗначениеЗаполнено(ФорматыОтсутствуютОригиналы) Тогда
				ФорматыОтсутствуютОригиналы = Новый Массив;
			КонецЕсли;
		КонецЕсли;
		
		Если ТаблицаФорматов = Неопределено Тогда
			ТаблицаФорматов = УправлениеПечатью.НастройкиФорматовСохраненияТабличногоДокумента();
		КонецЕсли;
		
		Для Каждого ТипФайла Из ФорматыОтсутствуютОригиналы Цикл
			
			НастройкиФормата = ТаблицаФорматов.НайтиСтроки(Новый Структура("ТипФайлаТабличногоДокумента", ТипФайла))[0];
			
			ИмяФайлаСРаширением = СтрШаблон("%1.%2", ИмяФайла, НастройкиФормата.Расширение);
			
			ПолноеИмяФайла = ФайловаяСистема.УникальноеИмяФайла(
				ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(ИмяВременнойПапки) + ИмяФайлаСРаширением);
			ОбщегоНазначения.СократитьИмяФайла(ПолноеИмяФайла);
			ТабличныйДокумент.Записать(ПолноеИмяФайла, ТипФайла);
			
			Если ТипФайла = ТипФайлаТабличногоДокумента.HTML Тогда
				УправлениеПечатью.ВставитьКартинкиВHTML(ПолноеИмяФайла);
			КонецЕсли;
			
			ДвоичныеДанные = Новый ДвоичныеДанные(ПолноеИмяФайла);
			
			ОписаниеВложения = НовыйОписаниеВложенияДляОчереди();
			ОписаниеВложения.ДвоичныеДанные = ДвоичныеДанные;
			ОписаниеВложения.Представление = ИмяФайлаСРаширением;
			ОписаниеВложения.ТипФайла = ТипФайла;
			Вложения.Добавить(ОписаниеВложения);
			
		КонецЦикла;
		
	КонецЕсли;

	УдалитьФайлы(ИмяВременнойПапки);
	
	Возврат Вложения;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Переопределяет данные заполнения нового элемента справочника
//
// Параметры:
//  ДанныеЗаполнения - Структура - см. Справочники.РассылкиСообщений.НовыйДанныеЗаполнения()
//  ПараметрыРассылки - Структура - см. РассылкаСообщений.НовыйПараметрыРассылки()
//  СпециальныеПараметрыРассылки - Структура - любые данные, специфичные для конкретного вида рассылки
//
Процедура ПередДобавлениемРассылки(ДанныеЗаполнения, ПараметрыРассылки, СпециальныеПараметрыРассылки = Неопределено) Экспорт
	
	ДанныеЗаполнения.Наименование = СтрШаблон(НСтр("ru = 'Рассылка запросов на сверку от %1'"), ТекущаяДатаСеанса());
	
КонецПроцедуры

// Регистрирует очередь рассылки в регистре сведений
//
// Параметры:
//  ОчередьРассылки - РегистрСведенийНаборЗаписей.РассылкаСообщений - набор записей очереди рассылки
//  ПараметрыРассылки - Структура - см. РассылкаСообщений.НовыйПараметрыРассылки()
//  СпециальныеПараметрыРассылки - Структура - любые данные, специфичные для конкретного вида рассылки
//
Процедура РегистрацияОчередиРассылки(ОчередьРассылки, ПараметрыРассылки, СпециальныеПараметрыРассылки) Экспорт
	
	СоставНастройки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			СпециальныеПараметрыРассылки.НастройкаРассылки,
			СтрЗаменить(
				"ПорядокСверки, ЗапрашиватьОригиналы, СпособЗапросаПоЭДО, ФорматыВложенийАктаСверки,
				|ФорматыВложенийНеПолученыОригиналы, РазбитьПоДоговорам, ВыводитьПолныеНазванияДокументов,
				|ВыводитьСчетаФактуры, ВложенияТекстаШаблона",
				Символы.ПС, " "));
	
	// Создадим акты сверки, если требуются
	ОбъектыОтправки = Новый Массив;
	Если СоставНастройки.ПорядокСверки = Перечисления.ПорядокСверкиРасчетовСКонтрагентами.ОтправитьНашАктСверки Тогда
		ОбъектыОтправки = АктыСверкиДляРассылки(
			ПараметрыРассылки.Получатели, СпециальныеПараметрыРассылки, СоставНастройки);
	КонецЕсли;

	ФорматыАктаСверки = СоставНастройки.ФорматыВложенийАктаСверки.Получить();
	Если Не ЗначениеЗаполнено(ФорматыАктаСверки) Тогда
		ФорматыАктаСверки = Новый Массив;
	КонецЕсли;
	
	АктыСверкиКВложению = АктыСверкиКВложению(ОбъектыОтправки, ФорматыАктаСверки, СпециальныеПараметрыРассылки);
	
	ФорматыОтсутствуютОригиналы = СоставНастройки.ФорматыВложенийНеПолученыОригиналы.Получить();
	Если Не ЗначениеЗаполнено(ФорматыОтсутствуютОригиналы) Тогда
		ФорматыОтсутствуютОригиналы = Новый Массив;
	КонецЕсли;
	
	ТаблицаФорматов = УправлениеПечатью.НастройкиФорматовСохраненияТабличногоДокумента();
	
	Для Каждого СтрокаПолучателя Из ПараметрыРассылки.Получатели Цикл
		
		НастроенЭДО = Обработки.МониторСверкиСКонтрагентами.НастроенЭДО(СтрокаПолучателя.ЭДО);
		
		Если Не ТребуетсяОтправкаПисьма(СтрокаПолучателя, СоставНастройки, НастроенЭДО) Тогда
			Продолжить;
		КонецЕсли;
		
		Запись = ОчередьРассылки.Добавить();
		Запись.РассылкаСообщений = ПараметрыРассылки.РассылкаСообщений;
		Запись.Получатель = СтрокаПолучателя.Получатель;
		Запись.Организация = СпециальныеПараметрыРассылки.Организация;
		Запись.ОтчетныйПериодСообщения = СпециальныеПараметрыРассылки.ДатаОкончания;
		Запись.СпособОтправки = Перечисления.СпособыОтправкиСообщений.ЭлектроннаяПочта;
		
		Запись.ПолучательАдрес = СтрокаПолучателя.АдресЭлектроннойПочты;
		
		ИмяПолучателя = СтрокаПолучателя.НаименованиеКонтрагента;
		Если СтрокаПолучателя.ИсточникАдреса = "КонтактноеЛицоДляСверки"
			 Или СтрокаПолучателя.ИсточникАдреса = "ОсновноеКонтактноеЛицо" Тогда
			ИмяПолучателя = СтрокаПолучателя.ИмяКонтактногоЛица;
		КонецЕсли;
		
		Запись.ПолучательПредставление = ИмяПолучателя;
		
		Запись.Состояние = Перечисления.СтатусыРассылки.Ожидание;
		Запись.ДатаПостановкиВОчередь = ТекущаяУниверсальнаяДата();
		
		Запись.Тема = СтрокаПолучателя.ТемаПисьма;
		Запись.Текст = СтрокаПолучателя.ТекстПисьма;
		
		Вложения = СформироватьВложенияПисьма(СтрокаПолучателя, СоставНастройки,
			СпециальныеПараметрыРассылки, АктыСверкиКВложению, НастроенЭДО, ФорматыОтсутствуютОригиналы, ТаблицаФорматов);
		
		// Добавим картинки текста письма во вложения, а в самом тексте письма заменим ссылки на файлы
		// на идентификаторы вложений
		ВложенияТекстаПисьма = СоставНастройки.ВложенияТекстаШаблона.Получить();
		
		Если ВложенияТекстаПисьма <> Неопределено Тогда
			
			ТаблицаСоответствийИменВложенийИдентификаторам = Новый ТаблицаЗначений;
			ТаблицаСоответствийИменВложенийИдентификаторам.Колонки.Добавить("ИмяФайла", Новый ОписаниеТипов("Строка"));
			ТаблицаСоответствийИменВложенийИдентификаторам.Колонки.Добавить("ИдентификаторФайлаДляHTML", Новый ОписаниеТипов("Строка"));
			ТаблицаСоответствийИменВложенийИдентификаторам.Колонки.Добавить("Картинка", Новый ОписаниеТипов("Картинка"));
			
			Для каждого Вложение Из ВложенияТекстаПисьма Цикл
				
				НоваяСтрока = ТаблицаСоответствийИменВложенийИдентификаторам.Добавить();
				НоваяСтрока.ИмяФайла = Вложение.Ключ;
				НоваяСтрока.ИдентификаторФайлаДляHTML = Новый УникальныйИдентификатор;
				НоваяСтрока.Картинка = Вложение.Значение;
				
			КонецЦикла;
			
			Если ТаблицаСоответствийИменВложенийИдентификаторам.Количество() > 0 Тогда
				
				ДокументHTML = Взаимодействия.ПолучитьОбъектДокументHTMLИзТекстаHTML(СтрокаПолучателя.ТекстПисьма);
				Взаимодействия.ЗаменитьИменаКартинокНаИдентификаторыПочтовыхВложенийВHTML(
					ДокументHTML, ТаблицаСоответствийИменВложенийИдентификаторам);
				
				Запись.Текст = Взаимодействия.ПолучитьТекстHTMLИзОбъектаДокументHTML(ДокументHTML);
				
				Для Каждого Вложение Из ТаблицаСоответствийИменВложенийИдентификаторам Цикл
					
					ОписаниеВложения = НовыйОписаниеВложенияДляОчереди();
					ОписаниеВложения.ДвоичныеДанные = Вложение.Картинка.ПолучитьДвоичныеДанные();
					ОписаниеВложения.Представление = Вложение.ИмяФайла;
					ОписаниеВложения.Идентификатор = Вложение.ИдентификаторФайлаДляHTML;
					Вложения.Добавить(ОписаниеВложения);
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Запись.Вложения = Новый ХранилищеЗначения(Вложения);

	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОбщиеСведения(СоставНастройки, ОбщиеПараметрыСверки, ТребуемыеПоказатели)
	
	ОбщиеПоказатели = Новый Структура;
	
	Для Каждого ИмяПоказателя Из ТребуемыеПоказатели Цикл
		ОбщиеПоказатели.Вставить(ИмяПоказателя);
	КонецЦикла;
	
	// Формируем текст запроса к ИБ: выбираем все возможные показатели
	// (наименования соответствуют значениям структур ДоступныеПараметры и ДоступныеУсловия)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Организации.Ссылка КАК Организация,
	|	Организации.НаименованиеСокращенное КАК НаименованиеОрганизацииСокращенное,
	|	Организации.НаименованиеПолное КАК НаименованиеОрганизацииПолное,
	|	Организации.ИНН КАК ИННОрганизации,
	|	Организации.КПП КАК КППОрганизации
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.Ссылка = &Организация";
	
	Запрос.УстановитьПараметр("Организация", ОбщиеПараметрыСверки.Организация);
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(Запрос.Текст);
	КолонкиЗапроса = СхемаЗапроса.ПакетЗапросов[0].Колонки;
	
	// Одновременно добавляем необходимые показатели в результат и удаляем лишние колонки запроса.
	// Колонку Организация не трогаем.
	Для Индекс = КолонкиЗапроса.Количество() - 1 По 1 Цикл
		Если ТребуемыеПоказатели.Найти(КолонкиЗапроса[Индекс].Псевдоним) = Неопределено Тогда
			КолонкиЗапроса.Удалить(Индекс);
		Иначе
			ОбщиеПоказатели.Вставить(КолонкиЗапроса[Индекс].Псевдоним);
		КонецЕсли;
	КонецЦикла;
	
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	ЗаполнитьЗначенияСвойств(ОбщиеПоказатели, Запрос.Выполнить().Выгрузить()[0]);
	
	Если ТребуемыеПоказатели.Найти("ДатаНачала") <> Неопределено Тогда
		ОбщиеПоказатели.Вставить("ДатаНачала", Формат(ОбщиеПараметрыСверки.ДатаНачала, "ДФ=dd.MM.yy"));
	КонецЕсли;
	
	Если ТребуемыеПоказатели.Найти("ДатаОкончания") <> Неопределено Тогда
		ОбщиеПоказатели.Вставить("ДатаОкончания", Формат(ОбщиеПараметрыСверки.ДатаОкончания, "ДФ=dd.MM.yy"));
	КонецЕсли;
	
	// Некоторые показатели не требуется для подстановки в шаблон, но используется для вычисления условий
	ОбщиеПоказатели.Вставить("ПодключенЭДО", НастройкиЭДО.ИспользуетсяОбменЭлектроннымиДокументами());
	ОбщиеПоказатели.Вставить("ЗапрашиватьОригиналы", СоставНастройки.ЗапрашиватьОригиналы);
	
	Если ТребуемыеПоказатели.Найти("ИдентификаторЭДООрганизации") <> Неопределено Тогда
		СписокИдентификаторов = УчетныеЗаписиЭДО.СписокИдентификаторовУчетныхЗаписейОрганизацииСервисаЭДО(
			ОбщиеПараметрыСверки.Организация);
		Если СписокИдентификаторов.Количество() = 1 Тогда
			ОбщиеПоказатели.Вставить("ИдентификаторЭДООрганизации", СписокИдентификаторов[0].Значение);
		КонецЕсли;
	КонецЕсли;
	
	Если ТребуемыеПоказатели.Найти("ОператорЭДООрганизации") <> Неопределено Тогда
		ИдентификаторЭДО = "";
		Если ОбщиеПоказатели.Свойство("ИдентификаторЭДООрганизации") Тогда
			ИдентификаторЭДО = ОбщиеПоказатели.ИдентификаторЭДООрганизации;
		Иначе
			СписокИдентификаторов = УчетныеЗаписиЭДО.СписокИдентификаторовУчетныхЗаписейОрганизацииСервисаЭДО(
				ОбщиеПараметрыСверки.Организация);
			Если СписокИдентификаторов.Количество() = 1 Тогда
				ИдентификаторЭДО = СписокИдентификаторов[0].Значение;
			КонецЕсли;
		КонецЕсли;
		ДанныеУчетнойЗаписи = УчетныеЗаписиЭДО.ДанныеУчетнойЗаписи(ИдентификаторЭДО);
		Если ЗначениеЗаполнено(ДанныеУчетнойЗаписи) Тогда
			ОбщиеПоказатели.Вставить("ОператорЭДООрганизации",
				СервисНастроекЭДО.ПредставлениеОператораЭлектронногоДокументооборота(ДанныеУчетнойЗаписи.ОператорЭДО));
		КонецЕсли;
	КонецЕсли;
	
	Если ТребуемыеПоказатели.Найти("ОрганизацияПодключенаКСверке20") <> Неопределено Тогда
		ПодключенаСверка20 = СервисСверкиРасчетов.ИспользуетсяСервисСверкиРасчетов();
		ОрганизацияПодключенаКСверке20 = Ложь;
		Если ПодключенаСверка20 Тогда
			ОрганизацияПодключенаКСверке20 =
				СервисСверкиРасчетов.ПодключенныеОрганизации().Найти(ОбщиеПараметрыСверки.Организация, "Организация") <> Неопределено;
		КонецЕсли;
		ОбщиеПоказатели.Вставить("ОрганизацияПодключенаКСверке20", ОрганизацияПодключенаКСверке20);
	КонецЕсли;
	
	Если ТребуемыеПоказатели.Найти("Подпись") <> Неопределено Тогда
		ОбщиеПоказатели.Вставить("Подпись", БухгалтерскийУчетПереопределяемый.ПолучитьЗначениеПоУмолчанию("Подпись"));
	КонецЕсли;
	
	Возврат ОбщиеПоказатели;
	
КонецФункции

Функция РезультатЗапросаСведенийОПолучателяхРассылки(Контрагенты, КонтекстРассылки, ТребуемыеПоказатели)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент,
	|	Контрагенты.НаименованиеПолное КАК НаименованиеПолное,
	|	Контрагенты.ИНН КАК ИНН,
	|	Контрагенты.КПП КАК КПП,
	|	Контрагенты.ОсновноеКонтактноеЛицо КАК ОсновноеКонтактноеЛицо
	|ПОМЕСТИТЬ ПолучателиРассылки
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.Ссылка В (&Контрагенты)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Контрагент,
	|	ОсновноеКонтактноеЛицо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтрагентыКонтактнаяИнформация.Ссылка КАК Контрагент,
	|	КонтрагентыКонтактнаяИнформация.Вид КАК ВидКонтактнойИнформации,
	|	МАКСИМУМ(КонтрагентыКонтактнаяИнформация.Представление) КАК Представление
	|ПОМЕСТИТЬ КонтактнаяИнформацияКонтрагентов
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка В
	|		(ВЫБРАТЬ
	|			Контрагенты.Контрагент
	|		ИЗ
	|			ПолучателиРассылки КАК Контрагенты)
	|	И КонтрагентыКонтактнаяИнформация.Вид В (&ВидыКонтактнойИнформацииКонтрагента)
	|	И КонтрагентыКонтактнаяИнформация.Представление <> """"
	|СГРУППИРОВАТЬ ПО
	|	КонтрагентыКонтактнаяИнформация.Ссылка,
	|	КонтрагентыКонтактнаяИнформация.Вид
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Контрагент,
	|	ВидКонтактнойИнформации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.ОбъектВладелец КАК Контрагент,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка КАК КонтактноеЛицо,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.Наименование КАК ИмяКонтактногоЛица,
	|	КонтактныеЛицаКонтактнаяИнформация.Вид КАК ВидКонтактнойИнформации,
	|	МАКСИМУМ(КонтактныеЛицаКонтактнаяИнформация.Представление) КАК Представление
	|ПОМЕСТИТЬ КонтактнаяИнформацияОсновныхКонтактныхЛиц
	|ИЗ
	|	Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КонтактныеЛицаКонтактнаяИнформация
	|ГДЕ
	|	(КонтактныеЛицаКонтактнаяИнформация.Ссылка.ОбъектВладелец, КонтактныеЛицаКонтактнаяИнформация.Ссылка) В
	|		(ВЫБРАТЬ
	|			Контрагенты.Контрагент,
	|			Контрагенты.ОсновноеКонтактноеЛицо
	|		ИЗ
	|			ПолучателиРассылки КАК Контрагенты)
	|	И КонтактныеЛицаКонтактнаяИнформация.Вид В (&ВидыКонтактнойИнформацииКонтактныхЛиц)
	|	И КонтактныеЛицаКонтактнаяИнформация.Представление <> """"
	|СГРУППИРОВАТЬ ПО
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.ОбъектВладелец,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.Наименование,
	|	КонтактныеЛицаКонтактнаяИнформация.Вид
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Контрагент,
	|	ВидКонтактнойИнформации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.ОбъектВладелец КАК Контрагент,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка КАК КонтактноеЛицо,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.Наименование КАК ИмяКонтактногоЛица,
	|	КонтактныеЛицаКонтактнаяИнформация.Вид КАК ВидКонтактнойИнформации,
	|	МАКСИМУМ(КонтактныеЛицаКонтактнаяИнформация.Представление) КАК Представление
	|ПОМЕСТИТЬ КонтактнаяИнформацияКонтактныхЛицДляСверки
	|ИЗ
	|	Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КонтактныеЛицаКонтактнаяИнформация
	|ГДЕ
	|	&ИспользуетсяРольДляСверки
	|	И КонтактныеЛицаКонтактнаяИнформация.Ссылка.ОбъектВладелец В
	|		(ВЫБРАТЬ
	|			Контрагенты.Контрагент
	|		ИЗ
	|			ПолучателиРассылки КАК Контрагенты)
	|	И КонтактныеЛицаКонтактнаяИнформация.Ссылка.Роль = &РольДляСверки
	|	И КонтактныеЛицаКонтактнаяИнформация.Вид В (&ВидыКонтактнойИнформацииКонтактныхЛиц)
	|	И КонтактныеЛицаКонтактнаяИнформация.Представление <> """"
	|СГРУППИРОВАТЬ ПО
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.ОбъектВладелец,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка,
	|	КонтактныеЛицаКонтактнаяИнформация.Ссылка.Наименование,
	|	КонтактныеЛицаКонтактнаяИнформация.Вид
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Контрагент,
	|	ВидКонтактнойИнформации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПолучателиРассылки.Контрагент КАК Контрагент,
	|	ПолучателиРассылки.НаименованиеПолное КАК НаименованиеКонтрагентаПолное,
	|	ПолучателиРассылки.ИНН КАК ИННКонтрагента,
	|	ПолучателиРассылки.КПП КАК КППКонтрагента,
	|	ВЫБОР
	|		КОГДА НЕ EmailКонтактныхЛицДляСверки.Представление ЕСТЬ NULL
	|			ТОГДА EmailКонтактныхЛицДляСверки.Представление
	|		КОГДА НЕ EmailОсновныхКонтактныхЛиц.Представление ЕСТЬ NULL
	|			ТОГДА EmailОсновныхКонтактныхЛиц.Представление
	|		ИНАЧЕ ЕСТЬNULL(EmailКонтрагентов.Представление, """")
	|	КОНЕЦ КАК АдресЭлектроннойПочты,
	|	ВЫБОР
	|		КОГДА НЕ EmailКонтактныхЛицДляСверки.ВидКонтактнойИнформации ЕСТЬ NULL
	|			ТОГДА ""КонтактноеЛицоДляСверки""
	|		КОГДА НЕ EmailОсновныхКонтактныхЛиц.ВидКонтактнойИнформации ЕСТЬ NULL
	|			ТОГДА ""ОсновноеКонтактноеЛицо""
	|		ИНАЧЕ ""Контрагент""
	|	КОНЕЦ КАК ИсточникАдреса,
	|	ВЫБОР
	|		КОГДА НЕ EmailКонтактныхЛицДляСверки.КонтактноеЛицо ЕСТЬ NULL
	|			ТОГДА EmailКонтактныхЛицДляСверки.КонтактноеЛицо
	|		КОГДА НЕ EmailОсновныхКонтактныхЛиц.КонтактноеЛицо ЕСТЬ NULL
	|			ТОГДА EmailОсновныхКонтактныхЛиц.КонтактноеЛицо
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.КонтактныеЛица.ПустаяСсылка)
	|	КОНЕЦ КАК КонтактноеЛицо,
	|	ВЫБОР
	|		КОГДА НЕ EmailКонтактныхЛицДляСверки.ИмяКонтактногоЛица ЕСТЬ NULL
	|			ТОГДА EmailКонтактныхЛицДляСверки.ИмяКонтактногоЛица
	|		КОГДА НЕ EmailОсновныхКонтактныхЛиц.ИмяКонтактногоЛица ЕСТЬ NULL
	|			ТОГДА EmailОсновныхКонтактныхЛиц.ИмяКонтактногоЛица
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ИмяКонтактногоЛица,
	|	ВЫБОР
	|		КОГДА НЕ ТелефоныМобильныеКонтактныхЛицДляСверки.Представление ЕСТЬ NULL
	|			ТОГДА ТелефоныМобильныеКонтактныхЛицДляСверки.Представление
	|		КОГДА НЕ ТелефоныРабочиеКонтактныхЛицДляСверки.Представление ЕСТЬ NULL
	|			ТОГДА ТелефоныРабочиеКонтактныхЛицДляСверки.Представление
	|		КОГДА НЕ ТелефоныМобильныеОсновныхКонтактныхЛиц.Представление ЕСТЬ NULL
	|			ТОГДА ТелефоныМобильныеОсновныхКонтактныхЛиц.Представление
	|		КОГДА НЕ ТелефоныРабочиеОсновныхКонтактныхЛиц.Представление ЕСТЬ NULL
	|			ТОГДА ТелефоныРабочиеОсновныхКонтактныхЛиц.Представление
	|		ИНАЧЕ ЕСТЬNULL(ТелефоныКонтрагентов.Представление, """")
	|	КОНЕЦ КАК НомерТелефона,
	|	ЕСТЬNULL(EmailКонтрагентов.Представление, """") КАК АдресЭлектроннойПочтыКонтрагента,
	|	ЕСТЬNULL(EmailОсновныхКонтактныхЛиц.Представление, """") КАК АдресЭлектроннойПочтыОсновногоКонтактногоЛица,
	|	ЕСТЬNULL(EmailОсновныхКонтактныхЛиц.КонтактноеЛицо, ЗНАЧЕНИЕ(Справочник.КонтактныеЛица.ПустаяСсылка)) КАК
	|		ОсновноеКонтактноеЛицо,
	|	ЕСТЬNULL(EmailОсновныхКонтактныхЛиц.ИмяКонтактногоЛица, """") КАК ИмяОсновногоКонтактногоЛица,
	|	ЕСТЬNULL(EmailКонтактныхЛицДляСверки.Представление, """") КАК АдресЭлектроннойПочтыКонтактногоЛицаДляСверки,
	|	ЕСТЬNULL(EmailКонтактныхЛицДляСверки.КонтактноеЛицо, ЗНАЧЕНИЕ(Справочник.КонтактныеЛица.ПустаяСсылка)) КАК
	|		КонтактноеЛицоДляСверки,
	|	ЕСТЬNULL(EmailКонтактныхЛицДляСверки.ИмяКонтактногоЛица, """") КАК ИмяКонтактногоЛицаДляСверки
	|ИЗ
	|	ПолучателиРассылки КАК ПолучателиРассылки
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияКонтрагентов КАК EmailКонтрагентов
	|		ПО ПолучателиРассылки.Контрагент = EmailКонтрагентов.Контрагент
	|		И EmailКонтрагентов.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагенты)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияОсновныхКонтактныхЛиц КАК EmailОсновныхКонтактныхЛиц
	|		ПО ПолучателиРассылки.Контрагент = EmailОсновныхКонтактныхЛиц.Контрагент
	|		И
	|			EmailОсновныхКонтактныхЛиц.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтактныеЛица)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияКонтактныхЛицДляСверки КАК EmailКонтактныхЛицДляСверки
	|		ПО ПолучателиРассылки.Контрагент = EmailКонтактныхЛицДляСверки.Контрагент
	|		И
	|			EmailКонтактныхЛицДляСверки.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтактныеЛица)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияКонтрагентов КАК ТелефоныКонтрагентов
	|		ПО &ВыбиратьНомераТелефонов
	|		И ПолучателиРассылки.Контрагент = ТелефоныКонтрагентов.Контрагент
	|		И ТелефоныКонтрагентов.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонКонтрагента)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияОсновныхКонтактныхЛиц КАК ТелефоныМобильныеОсновныхКонтактныхЛиц
	|		ПО &ВыбиратьНомераТелефонов
	|		И ПолучателиРассылки.Контрагент = ТелефоныМобильныеОсновныхКонтактныхЛиц.Контрагент
	|		И
	|			ТелефоныМобильныеОсновныхКонтактныхЛиц.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонМобильныйКонтактныеЛица)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияОсновныхКонтактныхЛиц КАК ТелефоныРабочиеОсновныхКонтактныхЛиц
	|		ПО &ВыбиратьНомераТелефонов
	|		И ПолучателиРассылки.Контрагент = ТелефоныРабочиеОсновныхКонтактныхЛиц.Контрагент
	|		И
	|			ТелефоныРабочиеОсновныхКонтактныхЛиц.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонРабочийКонтактныеЛица)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияКонтактныхЛицДляСверки КАК ТелефоныМобильныеКонтактныхЛицДляСверки
	|		ПО &ВыбиратьНомераТелефонов
	|		И ПолучателиРассылки.Контрагент = ТелефоныМобильныеКонтактныхЛицДляСверки.Контрагент
	|		И
	|			ТелефоныМобильныеКонтактныхЛицДляСверки.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонМобильныйКонтактныеЛица)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КонтактнаяИнформацияКонтактныхЛицДляСверки КАК ТелефоныРабочиеКонтактныхЛицДляСверки
	|		ПО &ВыбиратьНомераТелефонов
	|		И ПолучателиРассылки.Контрагент = ТелефоныРабочиеКонтактныхЛицДляСверки.Контрагент
	|		И
	|			ТелефоныРабочиеКонтактныхЛицДляСверки.ВидКонтактнойИнформации = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонРабочийКонтактныеЛица)";
	
	Запрос.УстановитьПараметр("Контрагенты", Контрагенты);
	Запрос.УстановитьПараметр("ИспользуетсяРольДляСверки",
		КонтекстРассылки.ВариантПолучателя = Перечисления.ВариантыПолучателяЗапросаСверки.КонтактноеЛицоСРолью
		И ЗначениеЗаполнено(КонтекстРассылки.РольКонтактногоЛица));
	Запрос.УстановитьПараметр("РольДляСверки", КонтекстРассылки.РольКонтактногоЛица);
	
	ВыбиратьНомераТелефонов = (ТребуемыеПоказатели.Найти("НомерТелефона") <> Неопределено);
	Запрос.УстановитьПараметр("ВыбиратьНомераТелефонов", ВыбиратьНомераТелефонов);
	
	ВидыКонтактнойИнформацииКонтрагента = Новый Массив;
	ВидыКонтактнойИнформацииКонтрагента.Добавить(Справочники.ВидыКонтактнойИнформации.EmailКонтрагенты);
	
	ВидыКонтактнойИнформацииКонтактныхЛиц = Новый Массив;
	ВидыКонтактнойИнформацииКонтактныхЛиц.Добавить(Справочники.ВидыКонтактнойИнформации.EmailКонтактныеЛица);
	
	Если ВыбиратьНомераТелефонов Тогда
		
		ВидыКонтактнойИнформацииКонтрагента.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента);
	
		ВидыКонтактнойИнформацииКонтактныхЛиц.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйКонтактныеЛица);
		ВидыКонтактнойИнформацииКонтактныхЛиц.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонРабочийКонтактныеЛица);
	
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВидыКонтактнойИнформацииКонтрагента", ВидыКонтактнойИнформацииКонтрагента);
	Запрос.УстановитьПараметр("ВидыКонтактнойИнформацииКонтактныхЛиц", ВидыКонтактнойИнформацииКонтактныхЛиц);
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(Запрос.Текст);
	КолонкиЗапроса = СхемаЗапроса.ПакетЗапросов[СхемаЗапроса.ПакетЗапросов.Количество() - 1].Колонки;
	
	// Удаляем лишние колонки запроса. Колонку Контрагент не трогаем.
	Для Индекс = КолонкиЗапроса.Количество() - 1 По 1 Цикл
		Если ТребуемыеПоказатели.Найти(КолонкиЗапроса[Индекс].Псевдоним) = Неопределено Тогда
			КолонкиЗапроса.Удалить(Индекс);
		КонецЕсли;
	КонецЦикла;
	
	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Возврат Запрос.Выполнить();
	
КонецФункции

// Возвращает все фактически используемые параметры в тексте шаблона письма и темы.
//
// Параметры:
//  Шаблоны - Структура - содержит шаблоны текста темы и письма.
//
// Возвращаемое значение:
//   Массив из Строка - массив с именами параметров, которые используются в тексте шаблона письма и темы.
//
Функция ПараметрыПисьмаИзНастройки(Шаблоны)
	
	ПараметрыПисьма = Новый Массив;
	
	ТекстПисьма = Шаблоны.ШаблонПисьма;
	ТемаПисьма = Шаблоны.ШаблонТемы;
	
	// Ищем все вхождения [ИмяПараметра] в теме письма
	Позиция = 1;
	ДлинаСтроки = СтрДлина(ТемаПисьма);
	Пока Позиция > 0 И Позиция < ДлинаСтроки Цикл
		Начало = СтрНайти(ТемаПисьма, "[", , Позиция);
		Если Начало = 0 Тогда
			Прервать;
		КонецЕсли;
		КонецПарам = СтрНайти(ТемаПисьма, "]", , Начало);
		Если КонецПарам = 0 Тогда
			Прервать;
		КонецЕсли;
		ИмяПараметра = Сред(ТемаПисьма, Начало + 1, КонецПарам - Начало - 1);
		Если ИмяПараметра <> "" И ПараметрыПисьма.Найти(ИмяПараметра) = Неопределено Тогда
			ПараметрыПисьма.Добавить(ИмяПараметра);
		КонецЕсли;
		Позиция = КонецПарам + 1;
	КонецЦикла;
	
	// Ищем все вхождения [ИмяПараметра] в тексте письма
	Позиция = 1;
	ДлинаСтроки = СтрДлина(ТекстПисьма);
	Пока Позиция > 0 И Позиция < ДлинаСтроки Цикл
		Начало = СтрНайти(ТекстПисьма, "[", , Позиция);
		Если Начало = 0 Тогда
			Прервать;
		КонецЕсли;
		КонецПарам = СтрНайти(ТекстПисьма, "]", , Начало);
		Если КонецПарам = 0 Тогда
			Прервать;
		КонецЕсли;
		ИмяПараметра = Сред(ТекстПисьма, Начало + 1, КонецПарам - Начало - 1);
		Если ИмяПараметра <> "" И ПараметрыПисьма.Найти(ИмяПараметра) = Неопределено Тогда
			ПараметрыПисьма.Добавить(ИмяПараметра);
		КонецЕсли;
		Позиция = КонецПарам + 1;
	КонецЦикла;
	
	Возврат ПараметрыПисьма;
	
КонецФункции

// Возвращает все фактически используемые условия в тексте шаблона письма и темы.
//
// Параметры:
//  Шаблоны - Структура - содержит шаблоны текста темы и письма.
//
// Возвращаемое значение:
//   Массив из Строка - Массив с именами условий, которые используются в тексте шаблона письма и темы.
//
Функция УсловияПисьмаИзНастройки(Шаблоны)
	
	УсловияПисьма = Новый Массив;
	
	ТекстПисьма = Шаблоны.ШаблонПисьма;
	ТемаПисьма = Шаблоны.ШаблонТемы;
	
	// Ищем все условия в теме письма
	ТегНачалоУсловия = РассылкаЗапросовНаСверкуКлиентСервер.ТегНачалоУсловия("*"); // символ, по которому ниже разделим тег на части
	ЧастиТега = СтрРазделить(ТегНачалоУсловия, "*");
	НачалоТегаУсловия = ЧастиТега[0];
	ОкончаниеТегаУсловия = ЧастиТега[1];
	
	Позиция = 1;
	ДлинаСтроки = СтрДлина(ТемаПисьма);
	ДлинаТега = СтрДлина(НачалоТегаУсловия);
	Пока Позиция > 0 И Позиция < ДлинаСтроки Цикл
		Начало = СтрНайти(ТемаПисьма, НачалоТегаУсловия, , Позиция);
		Если Начало = 0 Тогда
			Прервать;
		КонецЕсли;
		Конец = СтрНайти(ТемаПисьма, ОкончаниеТегаУсловия, , Начало + ДлинаТега);
		Если Конец = 0 Тогда
			Прервать;
		КонецЕсли;
		ИмяУсловия = СокрЛП(Сред(ТемаПисьма, Начало + ДлинаТега, Конец - Начало - ДлинаТега));
		// Убираем "Не " если есть
		Если СтрНачинаетсяС(ИмяУсловия, "Не ") Тогда
			ИмяУсловия = СокрЛП(Сред(ИмяУсловия, 4));
		КонецЕсли;
		Если ИмяУсловия <> "" И УсловияПисьма.Найти(ИмяУсловия) = Неопределено Тогда
			УсловияПисьма.Добавить(ИмяУсловия);
		КонецЕсли;
		Позиция = Конец + 1;
	КонецЦикла;
	
	// Ищем все условия в тексте письма
	Позиция = 1;
	ДлинаСтроки = СтрДлина(ТекстПисьма);
	Пока Позиция > 0 И Позиция < ДлинаСтроки Цикл
		Начало = СтрНайти(ТекстПисьма, НачалоТегаУсловия, , Позиция);
		Если Начало = 0 Тогда
			Прервать;
		КонецЕсли;
		Конец = СтрНайти(ТекстПисьма, ОкончаниеТегаУсловия, , Начало + ДлинаТега);
		Если Конец = 0 Тогда
			Прервать;
		КонецЕсли;
		ИмяУсловия = СокрЛП(Сред(ТекстПисьма, Начало + ДлинаТега, Конец - Начало - ДлинаТега));
		// Убираем "Не " если есть
		Если СтрНачинаетсяС(ИмяУсловия, "Не ") Тогда
			ИмяУсловия = СокрЛП(Сред(ИмяУсловия, 4));
		КонецЕсли;
		Если ИмяУсловия <> "" И УсловияПисьма.Найти(ИмяУсловия) = Неопределено Тогда
			УсловияПисьма.Добавить(ИмяУсловия);
		КонецЕсли;
		Позиция = Конец + 1;
	КонецЦикла;
	
	Возврат УсловияПисьма;
	
КонецФункции

// Поиск и обработка условий в виде блоков, ограниченных специальными тегами.
// НачалоБлока используется как курсор: символ, до которого обработана строка шаблока. На первом вызове опеределяется,
// как начало первого тега условия. В случае ошибки в шаблоне НачалоБлока устанавливается в Неопределено.
Функция ОбработатьУсловныеБлоки(ТекстШаблона, ДанныеДляПроверки, НачалоБлока = 0)
	
	Если НачалоБлока = Неопределено Тогда
		// Ошибка шаблона
		Возврат ТекстШаблона;
	КонецЕсли;
	
	ТегНачалоУсловия = РассылкаЗапросовНаСверкуКлиентСервер.ТегНачалоУсловия("*"); // символ, по которому ниже разделим тег на части
	ЧастиТега = СтрРазделить(ТегНачалоУсловия, "*");
	НачалоТегаУсловия = ЧастиТега[0];
	ОкончаниеТегаУсловия = ЧастиТега[1];
	ТегОкончаниеУсловия = РассылкаЗапросовНаСверкуКлиентСервер.ТегОкончаниеУсловия();

	НачалоБлока = ?(НачалоБлока = 0, СтрНайти(ТекстШаблона, НачалоТегаУсловия), НачалоБлока);
	
	Пока НачалоБлока > 0 Цикл
		// Проверим, есть ли вложенные условные блоки. Для этого найдем следующее начало блока и следующий конец блока.
		// Если есть начало нового блока до конца блока, то это вложенный блок.
		СледующееНачалоБлока = СтрНайти(ТекстШаблона, НачалоТегаУсловия, , НачалоБлока + СтрДлина(НачалоТегаУсловия));
		СледующийКонецБлока = СтрНайти(ТекстШаблона, ТегОкончаниеУсловия, , НачалоБлока);
		Если СледующееНачалоБлока > 0 Тогда
			// Есть еще условный блок, но не обязательно вложенный.
			Если СледующийКонецБлока > СледующееНачалоБлока Тогда
				// Есть начало нового блока до конца текущего, т.е. вложенный блок - обрабатываем рекурсивно.
				ТекстШаблона = ОбработатьУсловныеБлоки(ТекстШаблона, ДанныеДляПроверки, СледующееНачалоБлока);
				Если СледующееНачалоБлока = Неопределено Тогда
					// Ошибка шаблона
					НачалоБлока = Неопределено;
					Возврат ТекстШаблона;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		КонецНачалаБлока = СтрНайти(ТекстШаблона, ОкончаниеТегаУсловия, , НачалоБлока);
		Если КонецНачалаБлока = 0 Тогда
			// Ошибка шаблона
			НачалоБлока = Неопределено;
			Возврат ТекстШаблона;
		КонецЕсли;
		
		// После обработки вложенных блоков конец текущего блока может сместиться - найдем заново.
		КонецБлока = СтрНайти(ТекстШаблона, ТегОкончаниеУсловия, , КонецНачалаБлока);
		Если КонецБлока = 0 Тогда
			// Ошибка шаблона
			НачалоБлока = Неопределено;
			Возврат ТекстШаблона;
		КонецЕсли;
		
		// Извлекаем объявление условия, например: "Условие Не ПодключенЭДО", где "Не" - опционально
		ОбъявлениеУсловия = Сред(ТекстШаблона, НачалоБлока + 1, КонецНачалаБлока - НачалоБлока - 1);
		
		// Извлекаем имя условия и флаг инверсии
		ЧастиОбъявления = СтрРазделить(ОбъявлениеУсловия, " ", Ложь);
		
		Если ЧастиОбъявления.Количество() < 2 Тогда
			// Ошибка шаблона
			НачалоБлока = Неопределено;
			Возврат ТекстШаблона;
		КонецЕсли;
		
		Инверсия = СтрНайти("не", НРег(ЧастиОбъявления[1])) > 0;
		
		Если Инверсия И ЧастиОбъявления.Количество() < 3 Тогда
			// Ошибка шаблона
			НачалоБлока = Неопределено;
			Возврат ТекстШаблона;
		КонецЕсли;
		
		ИмяУсловия = ?(Инверсия, ЧастиОбъявления[2], ЧастиОбъявления[1]);
		
		// Проверяем, выполняется ли условие.
		УсловиеВыполнено = УсловиеВыполнено(ДанныеДляПроверки, ИмяУсловия);
		Если Инверсия Тогда
			УсловиеВыполнено = Не УсловиеВыполнено;
		КонецЕсли;
		
		ПолныйБлок = Сред(ТекстШаблона, НачалоБлока, КонецБлока + СтрДлина(ТегОкончаниеУсловия) - НачалоБлока);
		
		Если УсловиеВыполнено Тогда
			// Условие выполнено - вырезаем только теги, оставляем текст.
			ВнутреннийТекст = Сред(ТекстШаблона, КонецНачалаБлока + 1, КонецБлока - КонецНачалаБлока - 1);
			ТекстШаблона = СтрЗаменить(ТекстШаблона, ПолныйБлок, ВнутреннийТекст);
		Иначе
			// Условие не выполнено - вырезаем весь блок целиком.
			ТекстШаблона = СтрЗаменить(ТекстШаблона, ПолныйБлок, "");
		КонецЕсли;
		
		НачалоБлока = СтрНайти(ТекстШаблона, НачалоТегаУсловия);
		
	КонецЦикла;
	
	Возврат ТекстШаблона;
	
КонецФункции

Функция УсловиеВыполнено(ДанныеДляПроверки, ИмяУсловия)
	
	// Обрабатываем условия, требующие вычисления.
	Если ИмяУсловия = "НастроенЭДОСКонтрагентом" Тогда
		Возврат ДанныеДляПроверки.ПодключенЭДО И Обработки.МониторСверкиСКонтрагентами.НастроенЭДО(ДанныеДляПроверки.ЭДО);
	ИначеЕсли ИмяУсловия = "ЕстьНеполученныеОригиналы" Тогда
		Возврат ДанныеДляПроверки.ЗапрашиватьОригиналы И ДанныеДляПроверки.НетОригиналовКоличество > 0;
	КонецЕсли;
	
	// Все остальные условия обрабатываются как булево из источника, указанного в перечне доступных условий
	ОписаниеУсловия = ДоступныеУсловияШаблона().Найти(ИмяУсловия, "Имя");
	Если ОписаниеУсловия <> Неопределено Тогда
		Возврат ДанныеДляПроверки[ОписаниеУсловия.ПолеИсточника];
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция АктыСверкиКВложению(АктыСверки, ФорматыСохранения, ПараметрыСверки)
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("АктСверки", Новый ОписаниеТипов("ДокументСсылка.АктСверкиВзаиморасчетов"));
	Результат.Колонки.Добавить("Представление", ОбщегоНазначения.ОписаниеТипаСтрока(150));
	Результат.Колонки.Добавить("ДвоичныеДанные", Новый ОписаниеТипов("ДвоичныеДанные"));
	Результат.Колонки.Добавить("ТипФайла", Новый ОписаниеТипов("ТипФайлаТабличногоДокумента"));
	
	Результат.Индексы.Добавить("АктСверки");
	
	Если АктыСверки.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	КомандыОтправки = ОтправкаПочтовыхСообщений.КомандыОтправки();
	КомандыОтправки.Колонки.Добавить("ОбъектыОтправки");
	
	Документы.АктСверкиВзаиморасчетов.ДобавитьКомандыОтправки(КомандыОтправки);
	ОписаниеКоманды = КомандыОтправки.Найти("АктСверки", "Идентификатор");
	ОписаниеКоманды.ОбъектыОтправки = АктыСверки;
	
	Если ПустаяСтрока(ОписаниеКоманды.МенеджерПечати) Тогда
		ОписаниеКоманды.МенеджерПечати = "Документ.АктСверкиВзаиморасчетов";
	КонецЕсли;
	
	РезультатПечати = ОтправкаПочтовыхСообщений.ПечатныеФормы(ОписаниеКоманды);
	
	Если РезультатПечати.ТабличныеДокументы.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаФорматов = УправлениеПечатью.НастройкиФорматовСохраненияТабличногоДокумента();
	
	ИмяВременнойПапки = ПолучитьИмяВременногоФайла("");
	СоздатьКаталог(ИмяВременнойПапки);
	
	ПечатныеФормыПоОбъектам = Новый ТаблицаЗначений;
	ПечатныеФормыПоОбъектам.Колонки.Добавить("Объект");
	ПечатныеФормыПоОбъектам.Колонки.Добавить("ПечатныеФормы");
	ПечатныеФормыПоОбъектам.Индексы.Добавить("Объект");
	
	// Подготовлена одна печатная форма, но в ней сразу весь массив актов. Разделим на отдельные табличные документы по
	// каждому акту и запишем в результат.
	ПечатныеФормыПоОбъектам = УправлениеПечатью.ПечатныеФормыПоОбъектам(
		РезультатПечати.ТабличныеДокументы[0].Значение, РезультатПечати.ОбъектыПечати);
	
	Для Каждого СоответствиеОбъектаПечатнойФорме Из ПечатныеФормыПоОбъектам Цикл
		
		АктСверки = СоответствиеОбъектаПечатнойФорме.Ключ;
		ПечатнаяФорма = СоответствиеОбъектаПечатнойФорме.Значение;
		
		Если ПечатнаяФорма.Вывод = ИспользованиеВывода.Запретить Тогда
			Продолжить;
		КонецЕсли;
		
		РеквизитыАкта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			АктСверки, "ДатаНачала, ДатаОкончания, Контрагент.НаименованиеПолное");
		ИмяФайла = СтрШаблон(НСтр("ru='Акт сверки расчетов между %1 и %2 за период с %3 по %4'"),
			ПараметрыСверки.НаименованиеОрганизации,
			РеквизитыАкта.КонтрагентНаименованиеПолное,
			Формат(РеквизитыАкта.ДатаНачала, "ДФ=dd.MM.yy"),
			Формат(РеквизитыАкта.ДатаОкончания, "ДФ=dd.MM.yy"));
		
		ИмяФайла = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(ИмяФайла);
		
		Для Каждого ТипФайла Из ФорматыСохранения Цикл
			
			НастройкиФормата = ТаблицаФорматов.НайтиСтроки(Новый Структура("ТипФайлаТабличногоДокумента", ТипФайла))[0];
			
			ИмяФайлаСРаширением = СтрШаблон("%1.%2", ИмяФайла, НастройкиФормата.Расширение);
			
			ПолноеИмяФайла = ФайловаяСистема.УникальноеИмяФайла(
				ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(ИмяВременнойПапки) + ИмяФайлаСРаширением);
			ОбщегоНазначения.СократитьИмяФайла(ПолноеИмяФайла);
			ПечатнаяФорма.Записать(ПолноеИмяФайла, ТипФайла);
			
			Если ТипФайла = ТипФайлаТабличногоДокумента.HTML Тогда
				УправлениеПечатью.ВставитьКартинкиВHTML(ПолноеИмяФайла);
			КонецЕсли;
			
			ДвоичныеДанные = Новый ДвоичныеДанные(ПолноеИмяФайла);
			
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.АктСверки      = АктСверки;
			НоваяСтрока.Представление  = ИмяФайлаСРаширением;
			НоваяСтрока.ДвоичныеДанные = ДвоичныеДанные;
			НоваяСтрока.ТипФайла       = ТипФайла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	УдалитьФайлы(ИмяВременнойПапки);
	
	Возврат Результат;
	
КонецФункции

Функция ТребуетсяОтправкаПисьма(СтрокаПолучателя, СоставНастройки, НастроенЭДО)
	
	ОтправлятьЗапрос = Не НастроенЭДО Или СоставНастройки.СпособЗапросаПоЭДО <> Перечисления.СпособыЗапросаСверкиЭДО.НеОтправлять;
	
	АктСверкиПоЭДО = НастроенЭДО
		И (СоставНастройки.ПорядокСверки = Перечисления.ПорядокСверкиРасчетовСКонтрагентами.ОтправитьНашАктСверки
			 И СоставНастройки.СпособЗапросаПоЭДО = Перечисления.СпособыЗапросаСверкиЭДО.ОтправитьАктСверки);
		
	Возврат ОтправлятьЗапрос И Не АктСверкиПоЭДО;
	
КонецФункции

Функция ТребуетсяСписокНеполученныхОригиналовПисьмом(СтрокаПолучателя, СоставНастройки, НастроенЭДО = Неопределено)
	
	Если НастроенЭДО = Неопределено Тогда
		НастроенЭДО = Обработки.МониторСверкиСКонтрагентами.НастроенЭДО(СтрокаПолучателя.ЭДО);
	КонецЕсли;
	
	ПрилагатьСписокНеПолученныхОригиналовКПисьму = (СоставНастройки.ЗапрашиватьОригиналы
		И (Не НастроенЭДО Или СоставНастройки.СпособЗапросаПоЭДО = Перечисления.СпособыЗапросаСверкиЭДО.ОтправитьПисьмо));
	
	ЕстьНеполученныеОригиналы = СтрокаПолучателя.НетОригиналовКоличество > 0;
	
	Возврат ПрилагатьСписокНеПолученныхОригиналовКПисьму И ЕстьНеполученныеОригиналы;
	
КонецФункции

Функция НовыйОписаниеВложенияДляОчереди()
	
	ОписаниеВложения = Новый Структура;
	
	ОписаниеВложения.Вставить("ДвоичныеДанные", Неопределено);
	ОписаниеВложения.Вставить("Представление", "");
	ОписаниеВложения.Вставить("ТипФайла", ТипФайлаТабличногоДокумента.PDF);
	ОписаниеВложения.Вставить("Идентификатор", "");
	
	Возврат ОписаниеВложения;
	
КонецФункции

#КонецОбласти