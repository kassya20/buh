#Область ПрограммныйИнтерфейс

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("СоздатьАктыСверкиПоПолучателямРассылкиВФоне", Истина);
	
КонецПроцедуры

// Создает таблицу получателей для рассылки с необходимым набором колонок.
// Если передана таблица контрагентов в качестве параметра, то она копируется и дополняется недостающими колонками.
// Если параметр не передан, то создается новая пустая таблица со всеми необходимыми колонками.
//
// Параметры:
//  Контрагенты - ТаблицаЗначений - (необязательный) - если передана, то таблица получателей будет создана на ее основе,
//                                                     но дополнена недостающими колонками.
//
// Возвращаемое значение:
//  ТаблицаЗначений - подготовленная таблица получателей. Колонки:
// * Контрагент - СправочникСсылка.Контрагенты - контрагент.
// * НаименованиеКонтрагентаПолное - Строка - полное наименование контрагента.
// * ИНН - Строка - ИНН контрагента.
// * КПП - Строка - КПП контрагента.
// * НомерСчета - Строка - номер счета контрагента.
// * НетОригиналовКоличество - Число - количество неполученных оригиналов.
// * ЭДО - Число - 2, если ЭДО настроен с контрагентом.
// * АдресЭлектроннойПочты - Строка - адрес электронной почты получателя.
// * ИсточникАдреса - Строка - откуда взят адрес электронной почты.
// * КонтактноеЛицо - СправочникСсылка.КонтактныеЛица - контактное лицо - получатель рассылки.
// * ИмяКонтактногоЛица - Строка - имя контактного лица.
// * ТемаПисьма - Строка - тема письма.
// * ТекстПисьма - Строка - текст письма.
// * НомерТелефона - Строка - номер телефона получателя.
//
Функция ПолучателиРассылки(Контрагенты = Неопределено) Экспорт
	
	Если Контрагенты = Неопределено Тогда
		Получатели = Новый ТаблицаЗначений;
	Иначе
		Получатели = Контрагенты.Скопировать();
	КонецЕсли;
	
	// Описание всех возможных колонок таблицы получателей
	ОписаниеКолонок = Новый Структура;
	ОписаниеКолонок.Вставить("Контрагент", Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ОписаниеКолонок.Вставить("НаименованиеКонтрагентаПолное", ОбщегоНазначения.ОписаниеТипаСтрока(1000));
	ОписаниеКолонок.Вставить("ИННКонтрагента", ОбщегоНазначения.ОписаниеТипаСтрока(12));
	ОписаниеКолонок.Вставить("КППКонтрагента", ОбщегоНазначения.ОписаниеТипаСтрока(9));
	ОписаниеКолонок.Вставить("НетОригиналовКоличество", Новый ОписаниеТипов("Число"));
	ОписаниеКолонок.Вставить("ЭДО", Новый ОписаниеТипов("Число"));
	ОписаниеКолонок.Вставить("СервисСверкиИспользуется", Новый ОписаниеТипов("Булево"));
	ОписаниеКолонок.Вставить("АдресЭлектроннойПочты", ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ОписаниеКолонок.Вставить("ИсточникАдреса", ОбщегоНазначения.ОписаниеТипаСтрока(50));
	ОписаниеКолонок.Вставить("КонтактноеЛицо", Новый ОписаниеТипов("СправочникСсылка.КонтактныеЛица"));
	ОписаниеКолонок.Вставить("ИмяКонтактногоЛица", ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ОписаниеКолонок.Вставить("НомерТелефона", ОбщегоНазначения.ОписаниеТипаСтрока(20));
	ОписаниеКолонок.Вставить("ТемаПисьма", ОбщегоНазначения.ОписаниеТипаСтрока(0));
	ОписаниеКолонок.Вставить("ТекстПисьма", ОбщегоНазначения.ОписаниеТипаСтрока(0));

	// Добавляем отсутствующие колонки в таблицу получателей
	Для Каждого ОписаниеКолонки Из ОписаниеКолонок Цикл
		Если Получатели.Колонки.Найти(ОписаниеКолонки.Ключ) = Неопределено Тогда
			Получатели.Колонки.Добавить(ОписаниеКолонки.Ключ, ОписаниеКолонки.Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Получатели;
	
КонецФункции

// Подготавливает таблицу с контрагентами-полчателями рассылки, их адресами, темой и текстом писем запросов на сверку.
//
// Параметры:
//  Получатели - ТаблицаЗначений - см. ПолучателиРассылки()
//  КонтекстРассылки - Структура - см. НовыйКонтекстРассылки()
//  ОбщиеПараметрыСверки - Структура - См. НовыйОбщиеПараметрыСверки()
//  Ошибки - Массив из Строка - массив ошибок, которые будут выданы в случае невозможности подготовить текст писем
//
Процедура ЗаполнитьСообщенияПолучателямРассылки(Получатели, КонтекстРассылки, ОбщиеПараметрыСверки, Ошибки) Экспорт
	
	НастройкаРассылки = КонтекстРассылки.НастройкаРассылки;
	Если ТипЗнч(НастройкаРассылки) = Тип("СправочникСсылка.НастройкиРассылкиЗапросовНаСверку") И НастройкаРассылки.Пустая() Тогда
		Ошибки.Добавить(НСтр("ru='Не выбрана настройка рассылки.'"));
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(НастройкаРассылки) = Тип("СправочникСсылка.НастройкиРассылкиЗапросовНаСверку") Тогда
		СоставНастройки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
			НастройкаРассылки, "ЗапрашиватьОригиналы, ШаблонТемы, ШаблонПисьма");
	Иначе
		СоставНастройки = Новый Структура("ЗапрашиватьОригиналы, ШаблонТемы, ШаблонПисьма");
		ЗаполнитьЗначенияСвойств(СоставНастройки, НастройкаРассылки);
	КонецЕсли;
	
	// Инициализируем необходимые параметры для подстановки в шаблон - это структура, где ключ - имя свойства из шаблона,
	// значение - это имена свойств источника данных.
	// Ниже при обходе таблицы получателей заполним значения параметров из полученных данных ИБ.
	ПараметрыДляПодстановки = Новый Структура;
	
	// Определяем, какие показатели нужны из ИБ
	ТребуемыеПоказатели = Новый Массив;
	
	// Некоторые данные нужны всегда
	ТребуемыеПоказатели.Добавить("АдресЭлектроннойПочты");
	ТребуемыеПоказатели.Добавить("ИсточникАдреса");
	ТребуемыеПоказатели.Добавить("КонтактноеЛицо");
	ТребуемыеПоказатели.Добавить("ИмяКонтактногоЛица");
	
	// Все прочие сведения определяются из текста шаблонов (фактически необходимые сведения)
	ИспользуемыеПараметры = ПараметрыПисьмаИзНастройки(СоставНастройки);
	
	ДоступныеПараметры = ДоступныеПараметрыШаблона();
	НенайденныеПараметры = Новый Массив;
	Для Каждого ИмяПараметра Из ИспользуемыеПараметры Цикл
		ДоступныйПараметр = ДоступныеПараметры.Найти(ИмяПараметра, "Имя");
		Если ДоступныйПараметр = Неопределено Тогда
			НенайденныеПараметры.Добавить(ИмяПараметра);
		Иначе
			Если ТребуемыеПоказатели.Найти(ДоступныйПараметр.ПолеИсточника) = Неопределено Тогда
				ТребуемыеПоказатели.Добавить(ДоступныйПараметр.ПолеИсточника);
			КонецЕсли;
			ПараметрыДляПодстановки.Вставить(ИмяПараметра, ДоступныйПараметр.ПолеИсточника);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ИмяПараметра Из НенайденныеПараметры Цикл
		Ошибки.Добавить(СтрШаблон(
			НСтр("ru='Параметр ""%1"" не найден в доступных параметрах шаблонов. Проверьте настройку рассылки.'"),
				ИмяПараметра));
	КонецЦикла;
	
	ИспользуемыеУсловия = УсловияПисьмаИзНастройки(СоставНастройки);
	
	ДоступныеУсловия = ДоступныеУсловияШаблона();
	НенайденныеУсловия = Новый Массив;
	Для Каждого ИмяУсловия Из ИспользуемыеУсловия Цикл
		ДоступноеУсловие = ДоступныеУсловия.Найти(ИмяУсловия, "Имя");
		Если ДоступноеУсловие = Неопределено Тогда
			НенайденныеУсловия.Добавить(ИмяУсловия);
		Иначе
			Если ТребуемыеПоказатели.Найти(ДоступноеУсловие.ПолеИсточника) = Неопределено Тогда
				ТребуемыеПоказатели.Добавить(ДоступноеУсловие.ПолеИсточника);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ИмяУсловия Из НенайденныеУсловия Цикл
		Ошибки.Добавить(СтрШаблон(
			НСтр("ru='Условие ""%1"" не найдено в доступных условиях шаблонов. Проверьте настройку рассылки.'"),
				ИмяУсловия));
	КонецЦикла;
	
	Если Ошибки.Количество() Тогда
		Возврат;
	КонецЕсли;
	
	// Получим общие для всех получателей сведения
	ОбщиеДанныеДляПодстановки = ОбщиеСведения(СоставНастройки, ОбщиеПараметрыСверки, ТребуемыеПоказатели);
	
	// Получим сведения, специфичные для каждого получателя
	РезультатЗапроса = РезультатЗапросаСведенийОПолучателяхРассылки(
		Получатели.ВыгрузитьКолонку("Контрагент"), КонтекстРассылки, ТребуемыеПоказатели);
	
	СведенийОПолучателяхРассылки = РезультатЗапроса.Выгрузить();
	СведенийОПолучателяхРассылки.Индексы.Добавить("Контрагент");
	
	Для Каждого СтрокаКонтрагента Из Получатели Цикл
		
		ДанныеИБ = ОбщегоНазначения.СкопироватьРекурсивно(ОбщиеДанныеДляПодстановки);
		
		// Сначала дополним строку получателя выбранными сведениями
		СтрокаСведений = СведенийОПолучателяхРассылки.Найти(СтрокаКонтрагента.Контрагент, "Контрагент");
		Если СтрокаСведений <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(СтрокаКонтрагента, СтрокаСведений);
			// Если в строке сразу несколько адресов, то берем первый
			АдресаЭлектроннойПочты = СтрРазделить(СтрокаСведений.АдресЭлектроннойПочты, ";, ", Ложь);
			Если АдресаЭлектроннойПочты.Количество() > 1 Тогда
				СтрокаКонтрагента.АдресЭлектроннойПочты = СокрЛП(АдресаЭлектроннойПочты[0]);
			КонецЕсли;
		КонецЕсли;
		
		// И далее дополним общую структуру для заполнения шаблонов (общие сведения и индивидуальные по получателю)
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(
			ДанныеИБ,
			ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаКонтрагента),
			Истина);
		
		// Обрабатываем условные блоки.
		ТекстТемы = ОбработатьУсловныеБлоки(СоставНастройки.ШаблонТемы, ДанныеИБ);
		ТекстПисьма = ОбработатьУсловныеБлоки(СоставНастройки.ШаблонПисьма, ДанныеИБ);
		
		// Подготовим значения необходимых параметров для подстановки
		ЗначенияПараметров = Новый Структура;
		Для Каждого ОписаниеПараметра Из ПараметрыДляПодстановки Цикл
			ЗначенияПараметров.Вставить(ОписаниеПараметра.Ключ, ДанныеИБ[ОписаниеПараметра.Значение]);
		КонецЦикла;
		
		// Подставляем простые параметры.
		СтрокаКонтрагента.ТемаПисьма = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ТекстТемы, ЗначенияПараметров);
		СтрокаКонтрагента.ТекстПисьма = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ТекстПисьма, ЗначенияПараметров);
		
	КонецЦикла;
	
КонецПроцедуры

// Заполняет контактную информацию по таблице получателей рассылки.
// Параметры:
//  Получатели - ТаблицаЗначений - см. ПолучателиРассылки()
//  КонтекстРассылки - Структура - см. НовыйКонтекстРассылки()
//
Процедура ЗаполнитьКонтактнуюИнформациюПолучателейРассылки(Получатели, КонтекстРассылки) Экспорт

	// Определяем, какие показатели нужны из ИБ
	ТребуемыеПоказатели = Новый Массив;

	ТребуемыеПоказатели.Добавить("АдресЭлектроннойПочты");
	ТребуемыеПоказатели.Добавить("ИсточникАдреса");
	ТребуемыеПоказатели.Добавить("КонтактноеЛицо");
	ТребуемыеПоказатели.Добавить("ИмяКонтактногоЛица");
	ТребуемыеПоказатели.Добавить("НомерТелефона");
	
	РезультатЗапроса = РезультатЗапросаСведенийОПолучателяхРассылки(
		Получатели.ВыгрузитьКолонку("Контрагент"), КонтекстРассылки, ТребуемыеПоказатели);
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Получатели.Индексы.Добавить("Контрагент");
	
	// Заполняем данные получателей по полученной выборке
	Пока Выборка.Следующий() Цикл
		
		СтрокаТаблицы = Получатели.Найти(Выборка.Контрагент, "Контрагент");
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Выборка, , "Контрагент");
		
		// Если в строке сразу несколько адресов, то берем первый
		АдресаЭлектроннойПочты = СтрРазделить(СтрокаТаблицы.АдресЭлектроннойПочты, ";, ", Ложь);
		Если АдресаЭлектроннойПочты.Количество() > 1 Тогда
			СтрокаТаблицы.АдресЭлектроннойПочты = СокрЛП(АдресаЭлектроннойПочты[0]);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает расширенную контактную информацию контрагента - сразу для всех вариантов получателя рассылки.
//
// Параметры:
//  Контрагент - СправочникСсылка.Контрагенты - контрагент.
//  РольКонтактногоЛицаДляСверки - СправочникСсылка.РолиКонтактныхЛиц  - роль контактного лица для сверки.
// Возвращаемое значение:
//  Структура - свойства:
//  * Контрагент - СправочникСсылка.Контрагенты - контрагент.
//  * ОсновноеКонтактноеЛицо - СправочникСсылка.КонтактныеЛица - основное контактное лицо.
//  * АдресЭлектроннойПочтыКонтрагента - Строка - адрес электронной почты контрагента.
//  * ИмяОсновногоКонтактногоЛица - Строка - имя основного контактного лица.
//  * АдресЭлектроннойПочтыОсновногоКонтактногоЛица - Строка - адрес электронной почты основного контактного лица.
//  * АдресЭлектроннойПочтыКонтактногоЛицаДляСверки - Строка - адрес электронной почты контактного лица для сверки.
//  * ИмяКонтактногоЛицаДляСверки - Строка - имя контактного лица для сверки.
//
Функция РасширеннаяКонтактнаяИнформацияКонтрагента(Контрагент, РольКонтактногоЛицаДляСверки) Экспорт
	
	// Если указана роль контакта для сверки, то будет выбрана контактная информация такого контакта
	КонтекстРассылки = НовыйКонтекстРассылки();
	КонтекстРассылки.ВариантПолучателя = Перечисления.ВариантыПолучателяЗапросаСверки.КонтактноеЛицоСРолью;
	КонтекстРассылки.РольКонтактногоЛица = РольКонтактногоЛицаДляСверки;
	
	// Выбираем информацию для разных вариантов получателя
	ТребуемыеПоказатели = Новый Массив;
	ТребуемыеПоказатели.Добавить("АдресЭлектроннойПочтыКонтрагента");
	ТребуемыеПоказатели.Добавить("АдресЭлектроннойПочтыОсновногоКонтактногоЛица");
	ТребуемыеПоказатели.Добавить("ОсновноеКонтактноеЛицо");
	ТребуемыеПоказатели.Добавить("ИмяОсновногоКонтактногоЛица");
	ТребуемыеПоказатели.Добавить("АдресЭлектроннойПочтыКонтактногоЛицаДляСверки");
	ТребуемыеПоказатели.Добавить("КонтактноеЛицоДляСверки");
	ТребуемыеПоказатели.Добавить("ИмяКонтактногоЛицаДляСверки");
	
	РезультатЗапроса = РезультатЗапросаСведенийОПолучателяхРассылки(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Контрагент),
		КонтекстРассылки,
		ТребуемыеПоказатели);
	
	ТаблицаРезультат = РезультатЗапроса.Выгрузить(); // 1 строка в таблице
	Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ТаблицаРезультат[0]);
	
КонецФункции

// Конструктор коллекции, описывающей контекст рассылки.
//
// Возвращаемое значение:
//   Структура - Контекст рассылки:
//   * НастройкаРассылки - СправочникСсылка.НастройкиРассылкиЗапросовНаСверку, ДанныеФормыСтруктура.
//   * УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиЭлектроннойПочты - учетная запись, с котороый выполняется рассылка.
//   * ВариантПолучателя - ПеречислениеСсылка.ВариантыПолучателяЗапросаСверки - вариант получателя запроса сверки.
//   * РольКонтактногоЛица - СправочникСсылка.РолиКонтактныхЛиц - роль контактного лица, если выбран вараинт рассылки контактному лицу по сверке.
//
Функция НовыйКонтекстРассылки() Экспорт
	
	Контекст = Новый Структура;
	Контекст.Вставить("НастройкаРассылки",   Справочники.НастройкиРассылкиЗапросовНаСверку.ПустаяСсылка());
	Контекст.Вставить("УчетнаяЗапись",       Справочники.УчетныеЗаписиЭлектроннойПочты.ПустаяСсылка());
	Контекст.Вставить("ВариантПолучателя",   Перечисления.ВариантыПолучателяЗапросаСверки.ПустаяСсылка());
	Контекст.Вставить("РольКонтактногоЛица", Справочники.РолиКонтактныхЛиц.ПустаяСсылка());
	
	Возврат Контекст;
	
КонецФункции

