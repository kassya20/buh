//   * ЕстьРасчетыВВалюте - Булево
//
Функция НовыйИсходныеДанныеЗадолженностьВРассрочку()
	
	ИсходныеДанные = Новый Структура;
	ИсходныеДанные.Вставить("ЗадолженностьВРассрочку", НовыйЗадолженностьВРассрочку());
	ИсходныеДанные.Вставить("ИсточникиСроков", НовыйИсточникиСроков());
	ИсходныеДанные.Вставить("ГрафикиПлатежей");
	ИсходныеДанные.Вставить("ЕстьРасчетыВВалюте", Ложь);
		
	Возврат ИсходныеДанные;
	
