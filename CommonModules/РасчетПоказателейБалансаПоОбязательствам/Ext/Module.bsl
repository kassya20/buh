Процедура РаспределитьЗадолженностьВРассрочкуПоСрокамПогашения(ИсходныеДанные, МенеджерВременныхТаблиц, КонтекстРасчета, АналитикаБезГрафика)
	
	Если Не ЗначениеЗаполнено(АналитикаБезГрафика) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АналитикаБезГрафика.Организация КАК Организация,
	|	АналитикаБезГрафика.Счет КАК Счет,
	|	АналитикаБезГрафика.Контрагент КАК Контрагент,
	|	АналитикаБезГрафика.ДоговорКонтрагента КАК ДоговорКонтрагента
	|ПОМЕСТИТЬ АналитикаБезГрафика
	|ИЗ
	|	&АналитикаБезГрафика КАК АналитикаБезГрафика
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Счет,
	|	Контрагент,
	|	ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыПоДокументам.Организация КАК Организация,
	|	РасчетыПоДокументам.Счет КАК Счет,
	|	РасчетыПоДокументам.Субконто1 КАК Субконто1,
	|	РасчетыПоДокументам.Субконто2 КАК Субконто2,
	|	РасчетыПоДокументам.Субконто3 КАК Субконто3,
	|	РасчетыПоДокументам.ОстатокДолга КАК ОстатокДолга
	|ПОМЕСТИТЬ РасчетыБезГрафика
	|ИЗ
	|	РасчетыПоДокументам КАК РасчетыПоДокументам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ АналитикаБезГрафика КАК Аналитика
	|		ПО РасчетыПоДокументам.Организация = Аналитика.Организация
	|			И РасчетыПоДокументам.Счет = Аналитика.Счет
	|			И РасчетыПоДокументам.Субконто1 = Аналитика.Контрагент
	|			И РасчетыПоДокументам.Субконто2 = Аналитика.ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыБезГрафика.Организация КАК Организация,
	|	РасчетыБезГрафика.Счет КАК Счет,
	|	РасчетыБезГрафика.Субконто1 КАК Субконто1,
	|	РасчетыБезГрафика.Субконто2 КАК Субконто2,
	|	РасчетыБезГрафика.Субконто3 КАК Субконто3
	|ПОМЕСТИТЬ Аналитика
	|ИЗ
	|	РасчетыБезГрафика КАК РасчетыБезГрафика
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2,
	|	Субконто3";
	
	Запрос.УстановитьПараметр("АналитикаБезГрафика", АналитикаБезГрафика);
	
	Запрос.Выполнить();
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	РасчетыБезГрафика.Организация КАК Организация,
	|	РасчетыБезГрафика.Счет КАК Счет,
	|	РасчетыБезГрафика.Субконто1 КАК Субконто1,
	|	РасчетыБезГрафика.Субконто2 КАК Субконто2,
	|	РасчетыБезГрафика.Субконто3 КАК Субконто3,
	|	РасчетыБезГрафика.ОстатокДолга КАК ОстатокДолга
	|ИЗ
	|	РасчетыБезГрафика КАК РасчетыБезГрафика";

	ПараметрыСвязи = КлассификацияЗадолженности.НовыйПараметрыСвязиВременнойТаблицыРасчеты();
	ПараметрыСвязи.ИмяТаблицы =         "РасчетыБезГрафика";
	ПараметрыСвязи.ИмяПоляСчет =        "Счет";
	ПараметрыСвязи.ИмяПоляОрганизация = "Организация";
	ПараметрыСвязи.ИмяПоляДоговор =     "Субконто2";
	ПараметрыСвязи.ИмяПоляДокумент =    "Субконто3";
	
	ПараметрыЗапроса = Новый Структура; // набираются значения параметров
	КлассификацияЗадолженности.ДополнитьЗапросДаннымиПоСрокамОплаты(ТекстЗапроса, ПараметрыСвязи, ПараметрыЗапроса);
	
	Для Каждого Параметр Из ПараметрыЗапроса Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
		
	ТекстыЗапросов = Новый Массив;
	ТекстыЗапросов.Добавить(КлассификацияЗадолженности.ШаблонТекстаЗапросаРасчеты());
	ТекстыЗапросов.Добавить(ТекстЗапроса);
	
	ТекстЗапроса = СтрСоединить(ТекстыЗапросов, " ОБЪЕДИНИТЬ ВСЕ ");
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "ИмяТаблицыРасчеты", "Расчеты");
	
	Запрос.Выполнить();
		
	Запрос.УстановитьПараметр("Организации",                    КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("КонецПериодаДата",               КонтекстРасчета.КонецПериодаДата);
	Запрос.УстановитьПараметр("НачалоПредыдущегоПериода",       ДобавитьМесяц(НачалоГода(КонтекстРасчета.КонецПериодаДата), -12));
	Запрос.УстановитьПараметр("ДатаНачалаДолгосрочногоПериода", НачалоДня(КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)) + 1));
	Запрос.УстановитьПараметр("КраткосрочныйПериод",            КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)));
	Запрос.УстановитьПараметр("ВидЗадолженности",               Перечисления.ВидыЗадолженности.Кредиторская);
	Запрос.УстановитьПараметр("СчетаИнвентаризацииРасчетов",    СчетаЗадолженностиСРассрочкой());
	Запрос.УстановитьПараметр("СчетаИсключитьБезДатыПогашения", Новый Массив);
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор",  ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	Запрос.УстановитьПараметр("ТипыДокументовРасчетов",         ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами.ТипЗначения.Типы());

	КлассификацияЗадолженности.СоздатьВременныеТаблицыРаспределенныеДанныеПоИнвентаризацииРасчетов(Запрос);
	
	ОбщегоНазначенияБП.УничтожитьВременныеТаблицы(Запрос.МенеджерВременныхТаблиц,,"РасчетыПоСрокамПогашения,Проценты");

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасчетыПоСрокамПогашения.Организация КАК Организация,
	|	РасчетыПоСрокамПогашения.Счет КАК Счет,
	|	РасчетыПоСрокамПогашения.Субконто1 КАК Контрагент,
	|	РасчетыПоСрокамПогашения.Субконто2 КАК ДоговорКонтрагента,
	|	КОЛИЧЕСТВО(РасчетыПоСрокамПогашения.ИсточникСрокаПогашения) > 1 КАК НесколькоИсточниковСроков,
	|	МАКСИМУМ(РасчетыПоСрокамПогашения.ДатаВозникновения) КАК ДатаВозникновения,
	|	МАКСИМУМ(РасчетыПоСрокамПогашения.ДатаПогашения) КАК ДатаПогашения,
	|	СУММА(РасчетыПоСрокамПогашения.ОстатокДолга) КАК НоминальнаяВеличина,
	|	СУММА(ВЫБОР
	|			КОГДА РасчетыПоСрокамПогашения.ДатаПогашения > &КраткосрочныйПериод
	|				ТОГДА 0
	|			ИНАЧЕ РасчетыПоСрокамПогашения.ОстатокДолга
	|		КОНЕЦ) КАК НоминальнаяКраткосрочнаяВеличина,
	|	СУММА(ВЫБОР
	|			КОГДА РасчетыПоСрокамПогашения.ДатаПогашения > &КраткосрочныйПериод
	|				ТОГДА РасчетыПоСрокамПогашения.ОстатокДолга
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК НоминальнаяДолгосрочнаяВеличина
	|ПОМЕСТИТЬ Расчеты
	|ИЗ
	|	РасчетыПоСрокамПогашения КАК РасчетыПоСрокамПогашения
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыПоСрокамПогашения.Организация,
	|	РасчетыПоСрокамПогашения.Счет,
	|	РасчетыПоСрокамПогашения.Субконто1,
	|	РасчетыПоСрокамПогашения.Субконто2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыПоСрокамПогашения.Организация КАК Организация,
	|	РасчетыПоСрокамПогашения.Счет КАК Счет,
	|	РасчетыПоСрокамПогашения.Субконто1 КАК Контрагент,
	|	РасчетыПоСрокамПогашения.Субконто2 КАК ДоговорКонтрагента,
	|	РасчетыПоСрокамПогашения.ДатаВозникновения КАК ДатаВозникновения,
	|	РасчетыПоСрокамПогашения.ДатаПогашения КАК ДатаПогашения,
	|	РасчетыПоСрокамПогашения.ИсточникСрокаПогашения КАК ИсточникСрокаПогашения,
	|	ТИПЗНАЧЕНИЯ(РасчетыПоСрокамПогашения.ИсточникСрокаПогашения) = ТИП(Документ.ИнвентаризацияРасчетовСКонтрагентами) КАК ЭтоДокумент,
	|	РасчетыПоСрокамПогашения.ОстатокДолга КАК НоминальнаяВеличина,
	|	ВЫБОР
	|		КОГДА РасчетыПоСрокамПогашения.ДатаПогашения > &КраткосрочныйПериод
	|			ТОГДА 0
	|		ИНАЧЕ РасчетыПоСрокамПогашения.ОстатокДолга
	|	КОНЕЦ КАК НоминальнаяКраткосрочнаяВеличина,
	|	ВЫБОР
	|		КОГДА РасчетыПоСрокамПогашения.ДатаПогашения > &КраткосрочныйПериод
	|			ТОГДА РасчетыПоСрокамПогашения.ОстатокДолга
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК НоминальнаяДолгосрочнаяВеличина,
	|	ЕСТЬNULL(ИнвентаризацияРасчетовСКонтрагентами.Дата, ДАТАВРЕМЯ(1, 1, 1)) КАК ДокументИсточникаСрокаДата,
	|	ЕСТЬNULL(ИнвентаризацияРасчетовСКонтрагентами.Номер, """") КАК ДокументИсточникаСрокаНомер
	|ИЗ
	|	РасчетыПоСрокамПогашения КАК РасчетыПоСрокамПогашения
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИнвентаризацияРасчетовСКонтрагентами КАК ИнвентаризацияРасчетовСКонтрагентами
	|		ПО РасчетыПоСрокамПогашения.ИсточникСрокаПогашения = ИнвентаризацияРасчетовСКонтрагентами.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	Расчеты.Контрагент КАК Контрагент,
	|	Расчеты.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Расчеты.НесколькоИсточниковСроков КАК НесколькоИсточниковСроков,
	|	Расчеты.ДатаВозникновения КАК ДатаВозникновения,
	|	Расчеты.ДатаПогашения КАК ДатаПогашения,
	|	Расчеты.НоминальнаяВеличина КАК НоминальнаяВеличина,
	|	Расчеты.НоминальнаяКраткосрочнаяВеличина КАК НоминальнаяКраткосрочнаяВеличина,
	|	Расчеты.НоминальнаяДолгосрочнаяВеличина КАК НоминальнаяДолгосрочнаяВеличина,
	|	Проценты.ПроцентыПоРассрочке КАК ПроцентыПоРассрочке
	|ИЗ
	|	Расчеты КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Проценты КАК Проценты
	|		ПО Расчеты.Организация = Проценты.Организация
	|			И Расчеты.Контрагент = Проценты.Контрагент
	|			И Расчеты.ДоговорКонтрагента = Проценты.ДоговорКонтрагента";
	
	Результат = Запрос.ВыполнитьПакет();
	ПоследнийИндекс = Результат.ВГраница();
	
	ВыборкаДокументы = Результат[ПоследнийИндекс - 1].Выбрать();
	
	Пока ВыборкаДокументы.Следующий() Цикл 
		
		СтрокаТаблицы = ИсходныеДанные.ИсточникиСроков.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыборкаДокументы);
		
		Если ВыборкаДокументы.ЭтоДокумент Тогда
			СтрокаТаблицы.ДокументИсточникаСрокаПредставление = ПредставлениеДокумента(
						ВыборкаДокументы.ИсточникСрокаПогашения,
						ВыборкаДокументы.ДокументИсточникаСрокаНомер,
						ВыборкаДокументы.ДокументИсточникаСрокаДата);
		КонецЕсли;
					
	КонецЦикла;
	
	ВыборкаДоговоры = Результат[ПоследнийИндекс].Выбрать();
	
	Пока ВыборкаДоговоры.Следующий() Цикл
		СтрокаТаблицы = ИсходныеДанные.ЗадолженностьВРассрочку.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыборкаДоговоры);
		
		СтрокаТаблицы.Обязательство = ВыборкаДоговоры.НоминальнаяВеличина - ВыборкаДоговоры.ПроцентыПоРассрочке;
		СтрокаТаблицы.ДолгосрочноеОбязательство = Макс(ВыборкаДоговоры.НоминальнаяДолгосрочнаяВеличина - ВыборкаДоговоры.ПроцентыПоРассрочке, 0);
		СтрокаТаблицы.КраткосрочноеОбязательство = СтрокаТаблицы.Обязательство - СтрокаТаблицы.ДолгосрочноеОбязательство;
		
		Если Не ВыборкаДоговоры.НесколькоИсточниковСроков Тогда
			Отбор = Новый Структура;
			Отбор.Вставить("Организация",        ВыборкаДоговоры.Организация);
			Отбор.Вставить("Счет",               ВыборкаДоговоры.Счет);
			Отбор.Вставить("Контрагент",         ВыборкаДоговоры.Контрагент);
			Отбор.Вставить("ДоговорКонтрагента", ВыборкаДоговоры.ДоговорКонтрагента);
			
			СтрокиИсточников = ИсходныеДанные.ИсточникиСроков.НайтиСтроки(Отбор);
			Если ЗначениеЗаполнено(СтрокиИсточников) Тогда
				СтрокаИсточника = СтрокиИсточников[0];
				СтрокаТаблицы.ИсточникСрокаПогашения = СтрокаИсточника.ИсточникСрокаПогашения;
				Если СтрокаИсточника.ЭтоДокумент Тогда
					СтрокаТаблицы.ЭтоДокумент = СтрокаИсточника.ЭтоДокумент;
					СтрокаТаблицы.ДокументИсточникаСрокаПредставление = СтрокаИсточника.ДокументИсточникаСрокаПредставление;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
		
КонецПроцедуры

Функция СчетаЗадолженностиСРассрочкой()
	
	Счета = Новый Массив;
	Счета.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПоставщиками);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПоставщикамиВал);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПоставщикамиУЕ);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПоставщикамиИПодрядчиками);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПоставщикамиИПодрядчикамиВал);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.РасчетыСПрочимиПоставщикамиИПодрядчикамиУЕ);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторами);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторамиВал);
	Счета.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеРасчетыСРазнымиДебиторамиИКредиторамиУЕ);
	
	Возврат Счета;
	
КонецФункции

#КонецОбласти

#КонецОбласти
