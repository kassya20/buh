#Область СлужебныйПрограммныйИнтерфейс

// Конструктор параметра "КонтекстРасчета"
// 
// Возвращаемое значение:
//  Структура:
//   * КонецПериода - Дата, МоментВремениСУточнениемПериода
//   * КонецПериодаДата - Дата
//   * Организации - Массив из СправочникСсылка.Организации
//   * ИспользуетсяВалютныйУчет - см. БухгалтерскийУчетПереопределяемый.ИспользоватьВалютныйУчет
//   * ЕстьДисконтирование - см. УчетнаяПолитика.ПоддерживаетсяДисконтированиеОбязательств
//
Функция НовыйКонтекстРасчета() Экспорт
	
	Контекст = Новый Структура;
	
	Контекст.Вставить("КонецПериода", '0001-01-01');
	Контекст.Вставить("КонецПериодаДата", '0001-01-01');
	Контекст.Вставить("Организации",   Новый Массив);
	Контекст.Вставить("ИспользуетсяВалютныйУчет", Ложь);
	Контекст.Вставить("ЕстьДисконтирование",      Ложь);
	
	Возврат Контекст;

КонецФункции

// Возвращает исходные данные по арендным обязательствам
//
// Параметры:
//  КонтекстРасчета - см. НовыйКонтекстРасчета
//
// Возвращаемое значение:
//  см.НовыйИсходныеДанныеПоАренде
//
Функция ИсходныеДанныеПоАренднымОбязательствам(КонтекстРасчета) Экспорт
	
	ИсходныеДанные = НовыйИсходныеДанныеПоАренде();
	
	// Остатки по счетам 76.07, 76.27, 76.37
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	РасчетыПоАренде = РасчетыПоАренде(МенеджерВременныхТаблиц, КонтекстРасчета);
	
	// НДС с авансовых арендных платежей
	НДСсАвансовыхПлатежей = НДСсАвансовыхПлатежейПоАренде(МенеджерВременныхТаблиц, КонтекстРасчета);
	
	// Арендные обязательства по графикам платежей
	РасчетПоказателейБалансаПоОбязательствамГрафики.ДобавитьТаблицуГрафикиПлатежей(ИсходныеДанные.ГрафикиПлатежей, КонтекстРасчета, МенеджерВременныхТаблиц);
	
	Для Каждого СтрокаРасчета Из РасчетыПоАренде Цикл
		
		СтрокаТаблицы = ИсходныеДанные.АрендныеОбязательства.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, СтрокаРасчета);
		
		// заполняем НДС с выданного авансового платежа, если платеж отражен на счетах 76.07.2, 76.27.2, 76.37.2
		Если СтрокаТаблицы.ОстатокПлатежей > 0 Тогда
			ДополнитьСтрокуДаннымиНДСсПлатежейПоАренде(СтрокаТаблицы, НДСсАвансовыхПлатежей);
		КонецЕсли;
		
		// Сумма платежа всегда содержит НДС, поэтому при платежах авансом величина на счетах 76.07, 76.27, 76.37 получается искаженной
		// Для устранения искажения необходимо исключить НДС с выданного авансового платежа
		ОстатокБезНДС = СтрокаРасчета.ОстатокПоАренде - СтрокаТаблицы.НДСсПлатежей;
		
		СтрокаТаблицы.ОстатокПоАрендеДт = Макс(СтрокаРасчета.ОстатокПоАренде,  0);
		СтрокаТаблицы.ОстатокПоАрендеКт = Макс(-СтрокаРасчета.ОстатокПоАренде, 0);
		СтрокаТаблицы.Обязательство  = Макс(-ОстатокБезНДС, 0);
		СтрокаТаблицы.АвансыПоАренде = Макс(ОстатокБезНДС,  0);

		Если СтрокаТаблицы.АвансыПоАренде <> 0 Тогда
			СтрокаТаблицы.ЭтоАванс = Истина;
		КонецЕсли;
		
		РасчетПоказателейБалансаПоОбязательствамГрафики.ДополнитьСтрокуДаннымиИзГрафикаПоАренде(СтрокаТаблицы, ИсходныеДанные.ГрафикиПлатежей);
		
		Если СтрокаТаблицы.ЕстьГрафикПлатежей Тогда
			// Если график предусматривает годовой платеж меньше суммы процентных расходов за год или часть обязательства погашена авансом,
			// тогда величина на счетах 76.07, 76.27, 76.37 может быть меньше, чем величина по графику через 12 месяцев от отчетной даты
			СтрокаТаблицы.ДолгосрочноеОбязательство = Мин(СтрокаТаблицы.ОбязательствоРуб12, СтрокаТаблицы.Обязательство);
		Иначе
			// для договоров без графика платежей дата погашения равна сроку договору
			СтрокаТаблицы.ДатаПогашения = СтрокаРасчета.СрокДоговора;
			Если СтрокаТаблицы.Долгосрочный Тогда
				СтрокаТаблицы.ДолгосрочноеОбязательство = СтрокаТаблицы.Обязательство;
			КонецЕсли;
		КонецЕсли;
		СтрокаТаблицы.КраткосрочноеОбязательство = СтрокаТаблицы.Обязательство - СтрокаТаблицы.ДолгосрочноеОбязательство;
		
		// если есть договоры по арендным обязательствам в валюте
		Если СтрокаТаблицы.РасчетыВВалюте Тогда
			ИсходныеДанные.ЕстьРасчетыВВалюте = Истина;
		КонецЕсли;
			
	КонецЦикла;
	
	Возврат ИсходныеДанные;
	
КонецФункции

// Возвращает исходные данные задолженности с рассрочкой по срокам погашения
//
// Параметры:
//  КонтекстРасчета - см. НовыйКонтекстРасчета
//
// Возвращаемое значение:
//  см.НовыйИсходныеДанныеЗадолженностьВРассрочку
//
Функция ИсходныеДанныеЗадолженностиСРассрочкой(КонтекстРасчета) Экспорт

	ИсходныеДанные = НовыйИсходныеДанныеЗадолженностьВРассрочку();

	// Признаком, что по договору есть рассрочка оплаты, являются остатки процентов по рассрочке по счетам 76.08, 76.28, 76.38
	Запрос = Новый Запрос;
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Период",                        Новый Граница(КонтекстРасчета.КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Период12",                      КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)));
	Запрос.УстановитьПараметр("Организации",                   КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("ИспользуетсяВалютныйУчет",      КонтекстРасчета.ИспользуетсяВалютныйУчет);
	Запрос.УстановитьПараметр("СчетаЗадолженностиСРассрочкой", СчетаЗадолженностиСРассрочкой());
	Запрос.УстановитьПараметр("СчетаПроцентовПоРассрочке",     ПланыСчетов.Хозрасчетный.СчетаПроцентовПоРассрочке());
	
	СубконтоКонтрагентыДоговоры = Новый Массив;
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	Запрос.УстановитьПараметр("СубконтоКонтрагентыДоговоры", СубконтоКонтрагентыДоговоры);
	
	СубконтоКонтрагентыДоговорыДокументы = Новый Массив;
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	СубконтоКонтрагентыДоговорыДокументы.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ДокументыРасчетовСКонтрагентами);
	Запрос.УстановитьПараметр("СубконтоКонтрагентыДоговорыДокументы", СубконтоКонтрагентыДоговорыДокументы);

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ХозрасчетныйОстатки.Счет КАК Счет,
	|	ХозрасчетныйОстатки.Субконто1 КАК Контрагент,
	|	ХозрасчетныйОстатки.Субконто2 КАК ДоговорКонтрагента,
	|	ХозрасчетныйОстатки.СуммаОстаток КАК ПроцентыПоРассрочке
	|ПОМЕСТИТЬ Проценты
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&Период, Счет В (&СчетаПроцентовПоРассрочке), &СубконтоКонтрагентыДоговоры, Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент,
	|	ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Остатки.Организация КАК Организация,
	|	Остатки.Счет КАК Счет,
	|	Остатки.Субконто1 КАК Субконто1,
	|	Остатки.Субконто2 КАК Субконто2,
	|	Остатки.Субконто3 КАК Субконто3,
	|	-1 * Остатки.СуммаОстаток КАК ОстатокДолга
	|ПОМЕСТИТЬ РасчетыПоДокументам
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&Период,
	|			Счет В (&СчетаЗадолженностиСРассрочкой),
	|			&СубконтоКонтрагентыДоговорыДокументы,
	|			(Организация, Субконто1, Субконто2) В
	|				(ВЫБРАТЬ
	|					Проценты.Организация,
	|					Проценты.Контрагент,
	|					Проценты.ДоговорКонтрагента
	|				ИЗ
	|					Проценты)) КАК Остатки
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Счет,
	|	Субконто1,
	|	Субконто2
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыПоДокументам.Организация КАК Организация,
	|	РасчетыПоДокументам.Счет КАК Счет,
	|	РасчетыПоДокументам.Субконто1 КАК Контрагент,
	|	РасчетыПоДокументам.Субконто2 КАК ДоговорКонтрагента,
	|	СУММА(РасчетыПоДокументам.ОстатокДолга) КАК НоминальнаяВеличина,
	|	МАКСИМУМ(ЕСТЬNULL(ДанныеПервичныхДокументов.ДатаРегистратора, ДАТАВРЕМЯ(1, 1, 1))) КАК ДатаВозникновения
	|ПОМЕСТИТЬ РасчетыПоДоговорам
	|ИЗ
	|	РасчетыПоДокументам КАК РасчетыПоДокументам
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПервичныхДокументов КАК ДанныеПервичныхДокументов
	|		ПО РасчетыПоДокументам.Организация = ДанныеПервичныхДокументов.Организация
	|			И РасчетыПоДокументам.Субконто3 = ДанныеПервичныхДокументов.Документ
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыПоДокументам.Организация,
	|	РасчетыПоДокументам.Счет,
	|	РасчетыПоДокументам.Субконто1,
	|	РасчетыПоДокументам.Субконто2
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент,
	|	ДоговорКонтрагента
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	Расчеты.Контрагент КАК Контрагент,
	|	Расчеты.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	Расчеты.ДатаВозникновения КАК ДатаВозникновения,
	|	Расчеты.НоминальнаяВеличина КАК НоминальнаяВеличина,
	|	Проценты.ПроцентыПоРассрочке КАК ПроцентыПоРассрочке,
	|	Расчеты.НоминальнаяВеличина - Проценты.ПроцентыПоРассрочке КАК Обязательство,
	|	&ИспользуетсяВалютныйУчет
	|		И ДоговорыКонтрагентов.Валютный КАК РасчетыВВалюте
	|ИЗ
	|	РасчетыПоДоговорам КАК Расчеты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Проценты КАК Проценты
	|		ПО Расчеты.Организация = Проценты.Организация
	|			И Расчеты.Контрагент = Проценты.Контрагент
	|			И Расчеты.ДоговорКонтрагента = Проценты.ДоговорКонтрагента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО Расчеты.ДоговорКонтрагента = ДоговорыКонтрагентов.Ссылка";
	
	Результат = Запрос.Выполнить();
		
	Если Результат.Пустой() Тогда
		Возврат ИсходныеДанные;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();

	// Обязательства по графикам платежей
	РасчетПоказателейБалансаПоОбязательствамГрафики.ДобавитьТаблицуГрафикиПлатежей(ИсходныеДанные.ГрафикиПлатежей, КонтекстРасчета, МенеджерВременныхТаблиц);
	
	АналитикаБезГрафика = Новый ТаблицаЗначений;
	АналитикаБезГрафика.Колонки.Добавить("Организация",        Новый ОписаниеТипов("СправочникСсылка.Организации"));
	АналитикаБезГрафика.Колонки.Добавить("Счет",               Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	АналитикаБезГрафика.Колонки.Добавить("Контрагент",         Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	АналитикаБезГрафика.Колонки.Добавить("ДоговорКонтрагента", Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));

	Пока Выборка.Следующий() Цикл
		
		СтрокиГрафиков = Неопределено;
		
		Отбор = Новый Структура("Организация, Контрагент, ДоговорКонтрагента");
		ЗаполнитьЗначенияСвойств(Отбор, Выборка);
		
		РасчетПоказателейБалансаПоОбязательствамГрафики.ПроверитьНаличиеГрафикаПлатежей(ИсходныеДанные.ГрафикиПлатежей, Отбор, СтрокиГрафиков);
		
		Если Не ЗначениеЗаполнено(СтрокиГрафиков) Тогда
			СтрокаБезГрафика = АналитикаБезГрафика.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаБезГрафика, Выборка);
			Продолжить;
		КонецЕсли;
		
		СтрокаТаблицы = ИсходныеДанные.ЗадолженностьВРассрочку.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Выборка);
		РасчетПоказателейБалансаПоОбязательствамГрафики.ДополнитьСтрокуДаннымиИзГрафикаПоРассрочке(СтрокаТаблицы, СтрокиГрафиков);
		
		// Если график предусматривает годовой платеж меньше суммы процентных расходов за год,
		// тогда долгосрочное обязательство может быть меньше, чем величина по графику через 12 месяцев от отчетной даты
		СтрокаТаблицы.ДолгосрочноеОбязательство = Мин(СтрокаТаблицы.ОбязательствоРуб12, СтрокаТаблицы.НоминальнаяВеличина);
		СтрокаТаблицы.КраткосрочноеОбязательство = СтрокаТаблицы.Обязательство - СтрокаТаблицы.ДолгосрочноеОбязательство;
		
		СтрокаТаблицы.НоминальнаяДолгосрочнаяВеличина = СтрокаТаблицы.ДолгосрочноеОбязательство;
		// включает в себя Краткосрочное обязательство и проценты по рассрочке
		СтрокаТаблицы.НоминальнаяКраткосрочнаяВеличина = СтрокаТаблицы.НоминальнаяВеличина - СтрокаТаблицы.ДолгосрочноеОбязательство;

		// если есть договоры в валюте
		Если СтрокаТаблицы.РасчетыВВалюте Тогда
			ИсходныеДанные.ЕстьРасчетыВВалюте = Истина;
		КонецЕсли;
	КонецЦикла;

	ОбщегоНазначенияБП.УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц,,"РасчетыПоДоговорам,РасчетыПоДокументам,Проценты");
	
	// Для договоров без графика платежей дату погашения получаем из документа "Акт инвентаризации расчетов"
	РаспределитьЗадолженностьВРассрочкуПоСрокамПогашения(ИсходныеДанные, МенеджерВременныхТаблиц, КонтекстРасчета, АналитикаБезГрафика);
	
	Возврат ИсходныеДанные;
	
КонецФункции

// Возвращает типы документов, которые содержат график платежей
// Возвращаемое значение:
//  Массив - типы документов
//
Функция ТипыДокументовГрафикиПлатежей() Экспорт
	
	Типы = Новый Массив;
	РасчетПоказателейБалансаПоОбязательствамГрафики.ДобавитьТипыДокументовГрафикиПлатежей(Типы);
	
	Возврат Типы;
	
КонецФункции

// Возвращает представление документа
//
// Параметры:
//  ДокументСсылка - ДокументСсылка
//  Номер - Строка - номер документа
//  Дата - Дата - дата документа
//
// Возвращаемое значение:
//  Строка - представление документа
//
Функция ПредставлениеДокумента(ДокументСсылка, Номер, Дата) Экспорт
	
	МетаданныеДокумента = ДокументСсылка.Метаданные();
	Представление = СтрШаблон(НСтр("ru = '%1 %2 от %3'"),
					МетаданныеДокумента.Синоним,
					Номер,
					Формат(Дата, "ДЛФ=D"));
		
	Возврат Представление;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РасчетыПоАренде

// Конструктор исходных данных по арендным обязательствам
//
// Возвращаемое значение:
//  Структура:
//   * АрендныеОбязательства - см. РасчетПоказателейБалансаПоОбязательствам.НовыйАрендныеОбязательства
//   * ГрафикиПлатежей - см. РасчетПоказателейБалансаПоОбязательствамГрафики.НовыйГрафикиПлатежей
//                     - Неопределено - если Не ЕстьДисконтирование
//   * ЕстьРасчетыВВалюте - Булево
//
Функция НовыйИсходныеДанныеПоАренде()
	
	ИсходныеДанные = Новый Структура;
	ИсходныеДанные.Вставить("АрендныеОбязательства", НовыйАрендныеОбязательства());
	ИсходныеДанные.Вставить("ГрафикиПлатежей");
	ИсходныеДанные.Вставить("ЕстьРасчетыВВалюте", Ложь);
	
	Возврат ИсходныеДанные;
	
КонецФункции

Функция НовыйАрендныеОбязательства()
	
	ТипБулево = Новый ОписаниеТипов("Булево");
	ТипДата = Новый ОписаниеТипов("Дата");
	ТипСумма = БухгалтерскийУчетКлиентСервер.ТипСумма();
	
	Таблица = Новый ТаблицаЗначений; 
	Таблица.Колонки.Добавить("Период",                      ТипДата);
	Таблица.Колонки.Добавить("Организация",                 Новый ОписаниеТипов("СправочникСсылка.Организации"));
	Таблица.Колонки.Добавить("Счет",                        Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
