// Возвращает признак того, что нотариус обязан заверить и отправить документы в налоговую
// при назначении нового руководителя организации
//
// Параметры:
//   Период - Дата - Дата составления заявления
//
// Возвращаемое значение:
//   Булево
//
Функция РешениеОНовомРуководителеЗаверяетсяУНотариуса(Период) Экспорт
	
	// Федеральный закон от 08.08.2024 № 287-ФЗ
	Возврат Период >= '20240901';
	
КонецФункции

// Возвращает признак неудачи процесса формирования пакета документов для отправки в налоговую
//
// Параметры:
//   Результат                - Структура - см. Обработки.РегистрацияОрганизации.НовыйРезультатФормированияЗаявления()
//   ДатаСоставления          - Дата - Дата составления заявление для регистрации
//   СпособПодачиДокументов   - Строка - См. РегистрацияОрганизацииКлиентСервер.СпособыПодачиДокументов()
//   ФорматОтправкиДокументов - Строка - XML, TIF
//
// Возвращаемое значение:
//   Булево
//
Функция НеУдалосьСформироватьПакетДокументов(Результат, ДатаСоставления, СпособПодачиДокументов, ФорматОтправкиДокументов) Экспорт
	
	Если Не ЭтоЭлектронныйСпособПодачиДокументов(СпособПодачиДокументов) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ОтправлятьЗаявлениеВXMLФормате = ОтправлятьЗаявлениеВXMLФормате(
		ДатаСоставления,
		СпособПодачиДокументов,
		ФорматОтправкиДокументов);
	
	Если Не ОтправлятьЗаявлениеВXMLФормате Тогда
		Возврат Ложь;
	КонецЕсли;
	
	XMLПроверен = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Результат, "XMLПроверен", Истина);
	PDFПолучен = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Результат, "PDFПолучен", Истина);
	
	Возврат Не XMLПроверен Или Не PDFПолучен;
	
КонецФункции

// Возвращает описание имен прикрепленных файлов к регламентированным отчетам Р11001, Р13014, Р21001, Р24001, Р26001
//
// Возвращаемое значение:
//   Структура:
//     * Устав - Строка - имя файла с уставом
//     * РешениеЕдинственногоУчредителя - Строка - имя файла с решением единственного учредителя
//     * ПротоколСобранияУчредителейЕдинственногоУчредителя - Строка - имя файла с образцом протокола единственного учредителя
//     * ПротоколСобранияУчредителей - Строка - имя файла протокола собрания учредителей
//     * КвитанцияНаОплатуГоспошлины - Строка - имя файла квитанции на оплату госпошлины
//     * ИнструкцияПоВнесениюИзмененийВЕГРИП - Строка - имя файла по внесению изменений в ЕГРИП
//     * ИнструкцияПоВнесениюИзмененийВЕГРЮЛ - Строка - имя файла по внесению изменений в ЕГРЮЛ
//     * ИнструкцияПоПрекращениюДеятельностиИП - Строка - имя файла инструкции по прекращению деятельности ИП
//     * ЗаявлениеИП - Строка - имя файла заявления на регистрацию ИП
//     * ЗаявлениеООО - Строка - имя файла заявления на регистрацию ООО
//     * ЗаявлениеНаИзменениеИП - Строка - имя файла заявления на внесение изменений в ЕГРИП
//     * ЗаявлениеНаИзменениеООО - Строка - имя файла заявления на внесение изменений в ЕГРЮЛ
//     * ЗаявлениеСнятиеИП - Строка - имя файла заявления на снятие с учета ИП
//
Функция ИменаПрикрепляемыхФайлов() Экспорт
	
	ИменаФайлов = Новый Структура;
	ИменаФайлов.Вставить("Устав", НСтр("ru = 'Устав'"));
	ИменаФайлов.Вставить("РешениеЕдинственногоУчредителя", НСтр("ru = 'Решение единственного учредителя'"));
	ИменаФайлов.Вставить("ПротоколСобранияУчредителейЕдинственногоУчредителя", НСтр("ru = 'Образец протокола собрания учредителей'"));
	ИменаФайлов.Вставить("ПротоколСобранияУчредителей", НСтр("ru = 'Протокол собрания учредителей'"));
	ИменаФайлов.Вставить("КвитанцияНаОплатуГоспошлины", НСтр("ru = 'Квитанция на оплату госпошлины'"));
	ИменаФайлов.Вставить("ИнструкцияПоВнесениюИзмененийВЕГРИП", НСтр("ru = 'Инструкция по внесению изменений в ЕГРИП'"));
	ИменаФайлов.Вставить("ИнструкцияПоВнесениюИзмененийВЕГРЮЛ", НСтр("ru = 'Инструкция по внесению изменений в ЕГРЮЛ'"));
	ИменаФайлов.Вставить("ИнструкцияПоПрекращениюДеятельностиИП", НСтр("ru = 'Инструкция по прекращению деятельности ИП'"));
	ИменаФайлов.Вставить("ЗаявлениеИП", НСтр("ru = 'Заявление на регистрацию ИП'"));
	ИменаФайлов.Вставить("ЗаявлениеООО", НСтр("ru = 'Заявление на регистрацию ООО'"));
	ИменаФайлов.Вставить("ЗаявлениеНаИзменениеИП", НСтр("ru = 'Заявление на изменение в ЕГРИП'"));
	ИменаФайлов.Вставить("ЗаявлениеНаИзменениеООО", НСтр("ru = 'Заявление на изменение в ЕГРЮЛ'"));
	ИменаФайлов.Вставить("ЗаявлениеСнятиеИП", НСтр("ru = 'Заявление о прекращении деятельности ИП'"));
	
	Возврат ИменаФайлов;
	
КонецФункции

