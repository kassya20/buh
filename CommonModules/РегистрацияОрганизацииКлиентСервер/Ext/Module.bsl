// Определяет, поддерживается ли отправка заявлений на регистрацию XML-формате в налоговом органе
//
// Параметры:
//   ДатаСоставления - Дата - Дата составления регламентированного уведомления
//   ВидДокумента    - Строка - Вид прикрепляемого документа, см. ВидыПрикрепленныхДокументов()
//
// Возвращаемое значение:
//   Булево
//
Функция ПоддерживаетсяXMLФорматЗаявления(ДатаСоставления, ВидДокумента = Неопределено)
	
	Если ПрикрепленныйДокументПринимаетсяСканом(ВидДокумента) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Приказ Федеральной налоговой службы от 28.12.2022 № ЕД-7-14/1267@
	Возврат ДатаСоставления >= '20230221';
	
КонецФункции

Функция ПрикрепленныйДокументПринимаетсяСканом(ВидДокумента)
	
	// Некоторые виды документов налоговая принимает только в формате .tif 
	Если Не ЗначениеЗаполнено(ВидДокумента) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ВидыДокументов = ВидыПрикрепленныхДокументов();
	
	СписокДокументов = Новый Массив;
	СписокДокументов.Добавить(ВидыДокументов.УведомлениеОПереходеНаУСН);
	СписокДокументов.Добавить(ВидыДокументов.Патент);
	СписокДокументов.Добавить(ВидыДокументов.Протокол);
	СписокДокументов.Добавить(ВидыДокументов.Договор);
	СписокДокументов.Добавить(ВидыДокументов.Решение);
	
	Возврат СписокДокументов.Найти(ВидДокумента) <> Неопределено;
	
КонецФункции

Функция ПоказыватьЛистЗаписиЕГР(АдресДанныхПомощника, ИзмененияДобавленыВРеестр)
	
	Если ЭтоАдресВременногоХранилища(АдресДанныхПомощника) Тогда
		
		ДанныеПомощника = ПолучитьИзВременногоХранилища(АдресДанныхПомощника);
		
		Если ТипЗнч(ДанныеПомощника) = Тип("Структура") Тогда
			СпособПодачиДокументов = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеПомощника, "СпособПодачиДокументов");
			Если ЗаявлениеОтправляетсяОнлайн(СпособПодачиДокументов) Тогда
				Возврат ИзмененияДобавленыВРеестр;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

