// Возвращает признак того, что ранее отправленное заявление поддерживало отправку в XML-формате для заявлений:
// - Уведомление о переходе на упрощенную систему налогообложения (форма N 26.2-1)// - Заявление на получение патента (форма N 26.5-1)
//
// Параметры:
//   ДатаСоставления    - Дата - Дата составления заявления
//   ДокументыПодписаны - Булево - Признак того, что заявление подписано и сформирован транспортный контейнер
//
// Возвращаемое значение:
//   Булево
//
Функция ПоддерживаласьОтправкаВXMLФормате(ДатаСоставления, ДокументыПодписаны) Экспорт
	
	Если Не ДокументыПодписаны Тогда
		// Если транспортный контейнере не был отправлен, отправка в любом случае в форме сканов
		Возврат Ложь;
	КонецЕсли;
	
	Возврат ДатаСоставления < '20250416';
	
КонецФункции

// Возвращает представление заголовка поля ИНН заявителя для формирования документов регистрации через помощник
//
