//
Функция ИмяФормыВыбораВидовДеятельности() Экспорт
	
	Возврат "Обработка.РегистрацияОрганизации.Форма.ФормаВыбораВидовДеятельности";
	
КонецФункции

// Возвращает описание блока регистрации в ЕГРЮЛ/ЕГРИП
//
// Параметры:
//  Параметры - Структура - См. НовыеПараметрыОписанияБлокаРегистрацииВЕГР()
//
// Возвращаемое значение:
//  Структура: см. НовоеОписаниеБлокаРегистрацииВЕГР()
//
Функция ОписаниеБлокаРегистрацииВЕГР(Параметры) Экспорт
	
	Результат = НовоеОписаниеБлокаРегистрацииВЕГР();
	
	Если Параметры.СтатусФизЛица = ПредопределенноеЗначение("Перечисление.СтатусыФизическихЛиц.ИндивидуальныйПредприниматель") Тогда
		ЭтоИП = Истина;
		ЭтоСамозанятый = Ложь;
	Иначе
		ЭтоИП = Ложь;
		ЭтоСамозанятый = Параметры.ЭтоФизЛицо;
	КонецЕсли;
	
	Если Параметры.ВнесениеИзмененийНеЗавершено Тогда
		Результат.Команда = НСтр("ru = 'Продолжить подготовку документов'");
	ИначеЕсли Параметры.ОбновитьРеквизитыОрганизации Или Параметры.ЗаявлениеЗаполнено Тогда
		Результат.Команда = НСтр("ru = 'Показать пакет документов'");
	ИначеЕсли ЭтоИП Тогда
		Результат.Команда = НСтр("ru = 'Внести изменения'");
	ИначеЕсли ЭтоСамозанятый Тогда
		Результат.Команда = НСтр("ru = 'Зарегистрировать ИП'");
	Иначе
		Результат.Команда = НСтр("ru = 'Сформировать пакет документов'");
	КонецЕсли;
	
	Если Параметры.ЭтоФизЛицо И Не Параметры.ОГРНЗаполнен Тогда
		Результат.Заголовок = НСтр("ru = 'Регистрация в ЕГРИП'");
	ИначеЕсли Параметры.ЭтоФизЛицо Тогда
		Результат.Заголовок = НСтр("ru = 'Внесение изменений в ЕГРИП'");
	ИначеЕсли Не Параметры.ОГРНЗаполнен Тогда
		Результат.Заголовок = НСтр("ru = 'Регистрация в ЕГРЮЛ'");
	Иначе
		Результат.Заголовок = НСтр("ru = 'Внесение изменений в ЕГРЮЛ'");
	КонецЕсли;
	
	Если Параметры.ЭтоФизЛицо Тогда
		Результат.ЗаголовокЛистЗаписи = НСтр("ru = 'Лист записи ЕГРИП'");
	Иначе
		Результат.ЗаголовокЛистЗаписи = НСтр("ru = 'Лист записи ЕГРЮЛ'");
	КонецЕсли;
	
	Если Не Параметры.ОГРНЗаполнен И Параметры.ПоказыватьЛистЗаписи Тогда
		
		Если Параметры.ЭтоФизЛицо Тогда
			Результат.Описание = НСтр("ru = 'Индивидуальный предприниматель зарегистрирован'");
			Результат.Пояснение = НСтр("ru = 'Онлайн-проверка показала, что новый предприниматель зарегистрирован в ЕГРИП'");
		Иначе
			Результат.Описание = НСтр("ru = 'Организация зарегистрирована'");
			Результат.Пояснение = НСтр("ru = 'Онлайн-проверка показала, что новая организация зарегистрирована в ЕГРЮЛ'");
		КонецЕсли;
		
	ИначеЕсли Параметры.ЗаявлениеЗаполнено Тогда
		
		Если Параметры.ОбновитьСтатус Тогда
			Результат.Описание = НСтр("ru = 'Заявление на рассмотрении в налоговом органе.
			|Для проверки состояния заявления необходимо отправить запрос в налоговую. Для этого может потребоваться подписать запрос электронной подписью.'");
		ИначеЕсли Не Параметры.ОГРНЗаполнен Или Параметры.ВнесениеИзмененийНеЗавершено Тогда
			
			Если ЭтоСамозанятый Тогда
				Результат.Описание = НСтр("ru = 'Передайте пакет документов в налоговый орган.
				|После получения листа записи ЕГРИП перенесите реквизиты ОКВЭД, дату регистрации и ОГРН в программу.'");
			Иначе
				Результат.Описание = НСтр("ru = 'Передайте пакет документов в налоговый орган.
				|После получения листа записи ЕГР перенесите реквизиты ИНН и ОГРН в программу.'");
			КонецЕсли;
			
		ИначеЕсли ЭтоИП И Параметры.СнятиеСУчета Тогда
			Результат.Описание = НСтр("ru = 'Укажите дату прекращения деятельности ИП'");
		ИначеЕсли ЭтоИП Тогда
			Результат.Описание = ТекстОписанияВнесенияИзмененийВЕГРИП();
		Иначе
			Результат.Описание = ТекстОписанияВнесенияИзмененийВЕГРЮЛ();
		КонецЕсли;
		
		Если Параметры.ЭтоФизЛицо Тогда
			Результат.Пояснение = НСтр("ru = 'Онлайн-проверка показала, что в ЕГРИП уже содержатся новые реквизиты'");
		Иначе
			Результат.Пояснение = НСтр("ru = 'Онлайн-проверка показала, что в ЕГРЮЛ уже содержатся новые реквизиты'");
		КонецЕсли;
		
	ИначеЕсли ЭтоСамозанятый Тогда
		
		Результат.Описание = НСтр("ru = 'Хотите расширить свою деятельность?
			|Оформите статус индивидуального предпринимателя в Едином государственном реестре индивидуальных предпринимателей.'");
		
	ИначеЕсли ЭтоИП Тогда
		
		Результат.Описание = ТекстОписанияВнесенияИзмененийВЕГРИП();
		
	Иначе
		
		Результат.Описание = ТекстОписанияВнесенияИзмененийВЕГРЮЛ();
		
	КонецЕсли;
	
	Если Параметры.ОшибкаВнесенияИзменений Тогда
		Результат.Видимость.ПояснениеИзмененияВЕГРОшибка = Истина;
		Результат.Видимость.ПояснениеИзмененияЕстьВЕГР = Ложь;
		Результат.Видимость.СохранениеИзмененийЕГР = Истина;
		Результат.Видимость.ЕГРСформироватьПакетДокументов = Истина;
	ИначеЕсли Параметры.ОбновитьСтатус Тогда
		Результат.Видимость.ГруппаПомощникВнесенияИзмененийЕГР = Истина;
		Результат.Видимость.СохранениеИзмененийЕГР = Истина;
		Результат.Видимость.ПояснениеИзмененийНетВЕГР = Истина;
		Результат.Видимость.ПроверитьСтатусЗаявленияВЕГР = Истина;
	ИначеЕсли Не Параметры.ОГРНЗаполнен Тогда
		Результат.Видимость.ГруппаПомощникВнесенияИзмененийЕГР = Истина;
		Результат.Видимость.ПояснениеИзмененияЕстьВЕГР = Истина;
		Результат.Видимость.СохранениеИзмененийЕГР = Параметры.ПредложитьСохранитьИзменения;
		Результат.Видимость.ЕГРСформироватьПакетДокументов = Истина;
		Результат.Видимость.ПоказатьЛистЗаписиЕГР = ПоказыватьЛистЗаписиЕГР(
			Параметры.АдресДанныхПомощника,
			Параметры.ПоказыватьЛистЗаписи);
		Результат.Видимость.ОбновитьРеквизитыВПрограмме = Параметры.ТребуетОбновленияРеквизитов;
	Иначе
		
		Результат.Видимость.ГруппаПомощникВнесенияИзмененийЕГР = Истина;
		Результат.Видимость.ПояснениеИзмененияЕстьВЕГР = Параметры.ИзмененияДобавленыВРеестр
			И Параметры.ПредложитьСохранитьИзменения;
		Результат.Видимость.СохранениеИзмененийЕГР = Параметры.ПредложитьСохранитьИзменения;
		Результат.Видимость.ОбновитьРеквизитыВПрограмме = Параметры.ТребуетОбновленияРеквизитов;
		Если ПоказыватьЛистЗаписиЕГР(Параметры.АдресДанныхПомощника, Параметры.ПоказыватьЛистЗаписи) Тогда
			Результат.Видимость.ПоказатьЛистЗаписиЕГР = Истина;
		Иначе
			Результат.Видимость.ЕГРСформироватьПакетДокументов = Истина;
			Результат.Видимость.ПоказатьЛистЗаписиЕГР = Ложь;
			Результат.Видимость.ПояснениеИзмененийНетВЕГР = Не Параметры.ИзмененияДобавленыВРеестр
				И Параметры.ПредложитьСохранитьИзменения;
		КонецЕсли;
		
	КонецЕсли;
	
	Результат.Видимость.ОткрытьПомощникСнятияСУчетаВЕГР = ЭтоИП И Не Параметры.ЗаявлениеЗаполнено;
	
	// Блок внесения показывается, если есть заявление на внесение изменений или снятие с учета
	// или это простой интерфейс
	Если Параметры.ПростойИнтерфейс Тогда
		ПоказатьПомощникВнесенияИзмененийЕГР = Параметры.ОрганизацияСоздана
			И Не Параметры.ОбособленноеПодразделение
			И Параметры.ДоступноВнесениеИзменений
			И (Параметры.ИННЗаполнен Или Параметры.ЗаявлениеЗаполнено);
	Иначе
		ПоказатьПомощникВнесенияИзмененийЕГР = Параметры.ДоступноВнесениеИзменений
			И Параметры.ОрганизацияСоздана
			И Параметры.ЗаявлениеЗаполнено;
	КонецЕсли;
	
	Если Параметры.ИПзакрыт Тогда
		Результат.Видимость.ДатаЗакрытия = Истина;
		Результат.Видимость.ПояснениеИзмененийНетВЕГР = Ложь;
	Иначе
		Результат.Видимость.ОписаниеИзмененийЕГР = Истина;
		Если Параметры.СнятиеСУчета Тогда
			Результат.Видимость.ДатаЗакрытия = Не Параметры.ОбновитьСтатус
				И Не Параметры.ОшибкаВнесенияИзменений
				И Не Параметры.ВнесениеИзмененийНеЗавершено;
		Иначе
			Результат.Видимость.ДатаЗакрытия = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Результат.Видимость.ВнесениеИзмененийЕГРФон = ПоказатьПомощникВнесенияИзмененийЕГР;
	Результат.Видимость.СтатусОбновленияЗаявления = Параметры.ВыполняетсяОбновлениеСтатуса;
	
	Возврат Результат;
	
КонецФункции

// Возвращает структуру с параметрами для заполнения описания блока регистрации в ЕГРИП/ЕГРЮЛ.
//
// Возвращаемое значение:
//  Структура:
//  * СтатусФизЛица - Строка - статус физического лица.
//  * ОГРНЗаполнен - Булево - признак заполнения ОГРН.
//  * ИННЗаполнен - Булево - признак заполнения ИНН в организации.
//  * ЭтоФизЛицо - Булево - признак того, что организация является физическим лицом.
//  * ОбновитьСтатус - Булево - признак необходимости обновления статуса.
//  * ПоказыватьЛистЗаписи - Булево - признак необходимости показа листа записи ЕГРИП/ЕГРЮЛ.
//  * ОбновитьРеквизитыОрганизации - Булево - признак необходимости обновления реквизитов организации.
//  * ВнесениеИзмененийНеЗавершено - Булево - признак того, что внесение изменений не завершено.
//  * ЗаявлениеЗаполнено - Булево - признак того, что заявление заполнено.
//  * ОшибкаВнесенияИзменений - Булево - признак ошибки внесения изменений.
//  * ПредложитьСохранитьИзменения - Булево - признак сохранения изменений.
//  * ИзмененияДобавленыВРеестр - Булево - Изменения добавлены в ЕГРЮЛ/ЕГРИП.
//  * ТребуетОбновленияРеквизитов - Булево - признак того, что выполняется обновление статуса.
//  * ДоступноВнесениеИзменений - Булево - признак доступности внесения изменений.
//  * ИПзакрыт - Булево - признак процесса снятия ИП с учета.
//  * ПростойИнтерфейс - Булево - работа в простом интерфейсе.
//  * ОрганизацияСоздана - Булево - организация записана.
//  * ОбособленноеПодразделение - Булево - признак обособленного подразделения.
//  * СнятиеСУчета - Булево - признак снятия с учета.
//  * АдресДанныхПомощника - Неопределено.
//  * ВыполняетсяОбновлениеСтатуса - Булево - статус заявления обновляется.
//
Функция НовыеПараметрыОписанияБлокаРегистрацииВЕГР() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("СтатусФизЛица", "");
	Результат.Вставить("ОГРНЗаполнен", Ложь);
	Результат.Вставить("ИННЗаполнен", Ложь);
	Результат.Вставить("ЭтоФизЛицо", Ложь);
	Результат.Вставить("ОбновитьСтатус", Ложь);
	Результат.Вставить("ПоказыватьЛистЗаписи", Ложь);
	Результат.Вставить("ОбновитьРеквизитыОрганизации", Ложь);
	Результат.Вставить("ВнесениеИзмененийНеЗавершено", Ложь);
	Результат.Вставить("ЗаявлениеЗаполнено", Ложь);
	Результат.Вставить("ОшибкаВнесенияИзменений", Ложь);
	Результат.Вставить("ПредложитьСохранитьИзменения", Ложь);
	Результат.Вставить("ИзмененияДобавленыВРеестр", Ложь);
	Результат.Вставить("ТребуетОбновленияРеквизитов", Ложь);
	Результат.Вставить("ДоступноВнесениеИзменений", Ложь);
	Результат.Вставить("ИПзакрыт", Ложь);
	Результат.Вставить("ПростойИнтерфейс", Ложь);
	Результат.Вставить("ОрганизацияСоздана", Ложь);
	Результат.Вставить("ОбособленноеПодразделение", Ложь);
	Результат.Вставить("СнятиеСУчета", Ложь);
	Результат.Вставить("АдресДанныхПомощника", Неопределено);
	Результат.Вставить("ВыполняетсяОбновлениеСтатуса", Ложь);
	
	Возврат Результат;
	
КонецФункции

// Проверяет, применяется ли ОГРНИП (Основной государственный регистрационный номер индивидуального предпринимателя) 
// на указанную дату. ОГРНИП введен в РФ с 1 января 2004 года.
//
// Параметры:
//  Период  - Дата - дата регистрации ИП для проверки. 
//                   Если дата не заполнена, функция возвращает Истина (считается актуальным).
// 
// Возвращаемое значение:
//  Булево - Истина, если на указанную дату уже присваивался ОГРНИП.
//
Функция ПрименяетсяОГРНИП(Период) Экспорт
	
	Возврат Период >= '20040101';
	
КонецФункции

// Проверяет, применяется ли ОГРН (Основной государственный регистрационный номер) юридического лица
// на указанную дату. ОГРН введен в РФ с 1 июля 2002 года.
//
// Параметры:
//  Период  - Дата - дата регистрации ЮЛ для проверки. 
//                   Если дата не заполнена, функция возвращает Истина (считается актуальным).
// 
// Возвращаемое значение:
//  Булево - Истина, если на указанную дату уже присваивался ОГРН.
//
Функция ПрименяетсяОГРНЮЛ(Период) Экспорт
	
	Возврат Период >= '20020701';
	
КонецФункции

 // Возвращает текст подсказки даты присвоения ОГРНИП
//
// Параметры:
//   Период - Дата
//
// Возвращаемое значение:
//   Строка
//
Функция ТекстПодсказкиДляДатыПрисвоенияОГРНИП() Экспорт
	
	СтрокиПодсказки = Новый Массив;
	СтрокиПодсказки.Добавить(НСтр("ru = 'Дата присвоения основного государственного регистрационного номера. Необходима для заполнения УПД.'"));
	СтрокиПодсказки.Добавить(Символы.ПС);
	СтрокиПодсказки.Добавить(Новый ФорматированнаяСтрока(НСтр("ru='Подробнее'"), , , ,
		"http://its.1c.ru/bmk/bp30/fillingentrepreneur#entregdate"));
	
	Возврат Новый ФорматированнаяСтрока(СтрокиПодсказки);

КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает код значения "Без гражданства" для списка выбора страны гражданства
//
// Возвращаемое значение:
//  Строка
//
Функция КодПустогоЗначенияВСпискеВыбораГражданства() Экспорт
	
	Возврат "000";
	
КонецФункции

// Возвращает значение вида документа "Разрешение на временное проживание" для списка выбора,
// содержащего виды документов, подходящие в качестве основания для проживания в РФ не гражданам РФ
//
// Возвращаемое значение:
//  Строка
//
Функция ЗначениеРазрешенияНаВременноеПроживаниеВСпискеВыбора() Экспорт
	
	Возврат "0";
	
КонецФункции

// Возвращает значение вида документа "Вид на жительство" для списка выбора,
// содержащего виды документов, подходящие в качестве основания для проживания в РФ не гражданам РФ
//
// Возвращаемое значение:
//  Строка
//
Функция ЗначениеВидаНаЖительствоВСпискеВыбора() Экспорт
	
	Возврат "1";
	
КонецФункции

// Возвращает символы, которые допускается использоваться при вводе паспортных данных, как кириллицей, так и латиницей
