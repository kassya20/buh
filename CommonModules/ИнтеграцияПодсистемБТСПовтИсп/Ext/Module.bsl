// strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Подписки БСП.
// 
// Возвращаемое значение:
//  См. ИнтеграцияПодсистемБТС.СобытияБТС
Функция ПодпискиБСП() Экспорт
	
	Подписки = ИнтеграцияПодсистемБТС.СобытияБТС();
	ИнтеграцияПодсистемБСП.ПриОпределенииПодписокНаСобытияБТС(Подписки);
	
	Возврат Подписки;
	
КонецФункции

// Подписки БИП.
// 
// Возвращаемое значение:
//  См. ИнтеграцияПодсистемБТС.СобытияБТС
Функция ПодпискиБИП() Экспорт
	
	Подписки = ИнтеграцияПодсистемБТС.СобытияБТС();
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей") Тогда
		МодульИнтеграцияПодсистемБИП = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияПодсистемБИП");
		МодульИнтеграцияПодсистемБИП.ПриОпределенииПодписокНаСобытияБТС(Подписки);
	КонецЕсли;
	
	Возврат Подписки;
	
КонецФункции

// Подписки Плюс.
// 
// Возвращаемое значение:
//  См. ИнтеграцияПодсистемБТС.СобытияБТС
Функция ПодпискиПлюс() Экспорт
	
	Подписки = ИнтеграцияПодсистемБТС.СобытияБТС();
	Если ОбщегоНазначения.ПодсистемаСуществует("ПлюсСервис") Тогда
		МодульИнтеграцияПодсистемПлюс = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияПодсистемПлюс");
		МодульИнтеграцияПодсистемПлюс.ПриОпределенииПодписокНаСобытияБТС(Подписки);
	КонецЕсли;
	
	Возврат Подписки;
	
КонецФункции

// Подписки БЭД.
// 
// Возвращаемое значение:
//  См. ИнтеграцияПодсистемБТС.СобытияБТС
Функция ПодпискиБЭД() Экспорт
	
	Подписки = ИнтеграцияПодсистемБТС.СобытияБТС();
	Если ОбщегоНазначения.ПодсистемаСуществует("ЭлектронноеВзаимодействие") Тогда
		МодульОбновлениеИнформационнойБазыБЭД = ОбщегоНазначения.ОбщийМодуль("ОбновлениеИнформационнойБазыБЭД");
		ВерсияБЭД = МодульОбновлениеИнформационнойБазыБЭД.ВерсияБиблиотеки();
		Если ОбщегоНазначенияКлиентСервер.СравнитьВерсии(ВерсияБЭД, "1.9.16.1") >= 0 Тогда
			МодульИнтеграцияПодсистемБЭД = ОбщегоНазначения.ОбщийМодуль("ИнтеграцияПодсистемБЭД");
			МодульИнтеграцияПодсистемБЭД.ПриОпределенииПодписокНаСобытияБТС(Подписки);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Подписки;
	
КонецФункции

#КонецОбласти