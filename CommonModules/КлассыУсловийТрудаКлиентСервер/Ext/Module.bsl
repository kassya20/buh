#Область СлужебныйПрограммныйИнтерфейс

// Возвращает вредные (опасные) классы условий труда.
//
// Возвращаемое значение:
//  Массив из ПеречислениеСсылка.КлассыУсловийТрудаПоРезультатамСпециальнойОценки
//
Функция ВредныеИОпасныеКлассыУсловийТруда() Экспорт

	ВредныеКлассы = Новый Массив;
	ВредныеКлассы.Добавить(ПредопределенноеЗначение("Перечисление.КлассыУсловийТрудаПоРезультатамСпециальнойОценки.Вредный1"));
	ВредныеКлассы.Добавить(ПредопределенноеЗначение("Перечисление.КлассыУсловийТрудаПоРезультатамСпециальнойОценки.Вредный2"));
	ВредныеКлассы.Добавить(ПредопределенноеЗначение("Перечисление.КлассыУсловийТрудаПоРезультатамСпециальнойОценки.Вредный3"));
	ВредныеКлассы.Добавить(ПредопределенноеЗначение("Перечисление.КлассыУсловийТрудаПоРезультатамСпециальнойОценки.Вредный4"));
	ВредныеКлассы.Добавить(ПредопределенноеЗначение("Перечисление.КлассыУсловийТрудаПоРезультатамСпециальнойОценки.Опасный"));

	Возврат ВредныеКлассы;

КонецФункции

// Возвращает классы условий труда, при которых флаг ВыявленыВредныеОпасныеФакторы нельзя редактировать вручную.
//
// Возвращаемое значение:
//  Массив из ПеречислениеСсылка.КлассыУсловийТрудаПоРезультатамСпециальнойОценки
//
Функция КлассыУсловийТрудаДляБлокировкиФлагаВредныхФакторов() Экспорт

	ОграничивающиеКлассы = Новый Массив;
	ОграничивающиеКлассы.Добавить(
		ПредопределенноеЗначение("Перечисление.КлассыУсловийТрудаПоРезультатамСпециальнойОценки.ПустаяСсылка"));
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ОграничивающиеКлассы, ВредныеИОпасныеКлассыУсловийТруда());

	Возврат ОграничивающиеКлассы;

КонецФункции

// Устанавливает доступность поля флага ВыявленыВредныеОпасныеФакторы на форме в зависимости от класса условий труда.
//
// Параметры:
//  Элементы - ЭлементыФормы - 
//  КлассУсловийТруда - ПеречислениеСсылка.КлассыУсловийТрудаПоРезультатамСпециальнойОценки - 
//  ИмяЭлементаФлага - Строка - 
//
Процедура УстановитьДоступностьФлагаВредныхФакторов(Элементы, КлассУсловийТруда,
	ИмяЭлементаФлага = "КлассыУсловийТрудаПоДолжностямВыявленыВредныеОпасныеФакторы") Экспорт

	БлокироватьВыявленныеФакторы = КлассыУсловийТрудаДляБлокировкиФлагаВредныхФакторов().Найти(КлассУсловийТруда) <> Неопределено;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, ИмяЭлементаФлага, "ТолькоПросмотр", БлокироватьВыявленныеФакторы);

КонецПроцедуры

#КонецОбласти
