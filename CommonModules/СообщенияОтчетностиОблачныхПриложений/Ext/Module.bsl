// Возвращает ответ на запрос подключения приложения.
// 
// Возвращаемое значение:
//   Структура
//      *ТипЗапроса - Строка - см. ТипЗапросаПодключитьОблачноеПриложение()
//      *Ответ - Структура, см. НовыйДанныеПодключенияПриложения(),
//
Функция ОтветПодключитьОблачноеПриложение() Экспорт
	
	ДанныеПодключения = НовыйДанныеПодключенияПриложения();
	ДанныеПодключения.ИдентификаторПриложения = СообщенияОблачныхПриложений.ИдентификаторЭтогоПриложения();
	ДанныеПодключения.ДоступныеОрганизации = ДоступныеОрганизацииПользователя();
	
	ДанныеОтвета = НовыйОтветПодключитьОблачноеПриложение();
	ДанныеОтвета.Ответ = ДанныеПодключения;
	
	Возврат ДанныеОтвета;
	
КонецФункции

// Конструктор нового запроса данных отчетности от облачных приложений
//
// Возвращаемое значение:
//   Структура
//
Функция НовыйПараметрыЗапросаДанныхОтчетности() Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("ТипЗапроса", ТипЗапросаДанныеОтчетности());
	Параметры.Вставить("Отбор", ОтборЗапросаДанныхОтчетности());
	
	Возврат Параметры;
	
КонецФункции

// Возвращает параметры запуска фонового задания для подключения новых приложений.
//
// Возвращаемое значение:
//   - Структура:
//     * Пользователь - СправочникСсылка.Пользователи - пользователь, подключающий новые приложения.
//     * ПриложенияПользователя - ТаблицаЗначений - см. ПрограммныйИнтерфейсСервиса.Приложения()
//
Функция НовыйПараметрыПодключенияПриложений() Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("Пользователь", Справочники.Пользователи.ПустаяСсылка());
	Параметры.Вставить("ПриложенияПользователя");
	
	Возврат Параметры;
	
КонецФункции

// Конструктор данных для асинхронного опроса облачных приложений.
//
// Возвращаемое значение:
//   - ТаблицаЗначений:
//     * Приложение - СправочникСсылка.ОблачныеПриложения
//     * ИдентификаторЗапроса - Строка
//     * ТипЗапроса - Строка
//
Функция НовыйЗапросыОблачнымПриложениям() Экспорт
	
	Запросы = Новый ТаблицаЗначений;
	
	СообщенияОтчетностиОблачныхПриложенийПереопределяемый.ПриЗаполненииНовогоЗапросаОблачнымПриложениям(Запросы);
	
	Возврат Запросы;
КонецФункции

// Обрабатывает запрос на получение данных отчетности.
// 
// Параметры:
//   Параметры - Структура - см. СообщенияОтчетностиОблачныхПриложений.ОтборЗапросаДанныхОтчетности()
//
// Возвращаемое значение:
//   ИдентификаторЗапроса - Строка - идентификатор запроса
//
Функция ОбработатьЗапросДанныеОтчетностиВФоне(Параметры) Экспорт
	
	ИдентификаторЗапроса = Новый УникальныйИдентификатор();
	
	// Запускаем фоновую обработку запроса.
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияПроцедуры();
	ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		"СообщенияОтчетностиОблачныхПриложений.ОбработатьЗапросДанныеОтчетности",
		ИдентификаторЗапроса,
		Параметры);
	
	Возврат XMLСтрока(ИдентификаторЗапроса);
КонецФункции

// См. СтандартныеПодсистемыСервер.ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод
Процедура ПриОпределенииМетодовРазрешенныхДляВызоваКакПроизвольныйКод(Методы) Экспорт
	
	Методы.Вставить("ПодключитьНовыеПриложения", Истина);
	Методы.Вставить("ЗапроситьСинхронно", Истина);
	Методы.Вставить("ОбработатьЗапросДанныеОтчетности", Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ОбработатьЗапросДанныеОтчетности(ИдентификаторЗапроса, Параметры) Экспорт
	
	Ответ = СообщенияОтчетностиОблачныхПриложений.ОтветДанныеОтчетности(Параметры);
	РегистрыСведений.ВременноеХранилище.Добавить(ИдентификаторЗапроса, Ответ);
	
КонецПроцедуры

Функция ТипЗапросаДанныеОтчетности() Экспорт
	
	Возврат "ДанныеОтчетности";
	
КонецФункции

Функция ТипЗапросаСписокОрганизаций() Экспорт
	
