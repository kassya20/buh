#Область СлужебныйПрограммныйИнтерфейс

// Возвращает подсказку для реквизита, в котором отрисовывается статус самозанятого
// в процессе получения данных
//
// Возвращаемое значение:
//  Строка
//
Функция ЗаголовокПодсказкиПолучениеСтатусаВПроцессе() Экспорт
	
	Возврат НСтр("ru = 'Определяем статус самозанятого...'");
	
КонецФункции

// Возвращает данные, необходимые для оформления статуса самозанятого в форме документа
//
// Параметры:
//  ДатаДокумента- Дата - дата документа
//  ДатаВходящегоДокумента- Дата - дата входящего документа
//  ОтветСервиса - Структура, Неопределено - результат выполнения метода:
//   * Статус - Структура, Неопределено - статус самозанятого:
//     * ИНН - Строка - ИНН физического лица
//     * НаДату - Дата - дата, на которую выполнялась проверка
//     * ПлательщикНПД - Булево - Истина, если физ.лицо применяет НПД
//     * ДатаРегистрации - Дата, Неопределено - дата изменения статуса
//     * ЭтоОкончательноеЗначение - Булево - признак того, что повторно запрашивать значение из сервиса не требуется
//   * Ошибка - Структура, Неопределено - описание ошибки, которую вернул сервис:
//     * Идентификатор - Строка - идентификатор ошибки
//     * Вид - Строка - вид ошибки
//     * Описание - Строка - представление ошибки
//   * Баланс - Число, Неопределено - остаток доступных опций
//
// Возвращаемое значение:
//  Структура:
//   * ПлательщикНПД - Булево, Неопределено - Истина, если физ.лицо применяет НПД
//   * ДатаРегистрации - Дата, Неопределено - дата изменения статуса
//   * ФорматированноеОписание - ФорматированнаяСтрока
//   * ЦветФонаСтатуса - Цвет
//
Функция РезультатПроверкиСтатусаСамозанятогоДляДокумента(ДатаДокумента, ДатаВходящегоДокумента, ОтветСервиса) Экспорт
	
	Статус = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ОтветСервиса, "Статус");
	Ошибка = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ОтветСервиса, "Ошибка");
	Баланс = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ОтветСервиса, "Баланс");
	
	Результат = НовыйРезультатПроверкиСтатусаСамозанятого();
	Если Ошибка <> Неопределено Тогда
		ЭлементыОписания = Новый Массив;
		ЭлементыОписания.Добавить(Ошибка.Описание);
		ЭлементыОписания.Добавить(Символы.ПС);
		ЭлементыОписания.Добавить(СтроковыеФункцииКлиент.ФорматированнаяСтрока(
			НСтр("ru = 'Подробнее о сервисе <a href = ""%1"">1С:Статус самозанятого</a>'"),
			ИнтеграцияСтатусСамозанятогоКлиентСервер.ФормаСервисСтатусСамозанятого()));
		Результат.ФорматированноеОписание = Новый ФорматированнаяСтрока(ЭлементыОписания);
		Результат.ЦветФонаСтатуса = ЦветФонаСтатуса(Статус, Ошибка);
	ИначеЕсли Статус <> Неопределено Тогда
		ЭлементыОписания = Новый Массив;
		Если ЗначениеЗаполнено(ДатаВходящегоДокумента) Тогда
			ОписаниеСтатусаСамозанятого = ОписаниеСтатусаСамозанятогоНаДатуВходящегоДокумента(
				Статус.ПлательщикНПД, Статус.ДатаРегистрации, ДатаВходящегоДокумента);
		Иначе
			ОписаниеСтатусаСамозанятого = ОписаниеСтатусаСамозанятогоНаДатуДокумента(
				Статус.ПлательщикНПД, Статус.ДатаРегистрации, ДатаДокумента);
		КонецЕсли;
		ЭлементыОписания.Добавить(СтроковыеФункцииКлиент.ФорматированнаяСтрока(
			НСтр("ru = '%1
			|<a href = ""%2"">Повторить проверку</a>'"),
			ОписаниеСтатусаСамозанятого,
			НавигационныеСсылки().ВызватьСервисПроверкиСтатусаСамозанятого));
		Если Баланс <> Неопределено Тогда
			ЭлементыОписания.Добавить(Символы.ПС);
			ЭлементыОписания.Добавить(СтроковыеФункцииКлиент.ФорматированнаяСтрока(
				НСтр("ru = '
				|%1
				|Подробнее о сервисе: <a href = ""%2"">1С:Статус самозанятого</a>'"),
				ИнтеграцияСтатусСамозанятогоКлиентСервер.ОписаниеОстаткаОпций(Баланс),
				ИнтеграцияСтатусСамозанятогоКлиентСервер.ФормаСервисСтатусСамозанятого()));
		КонецЕсли;
		Результат.ПлательщикНПД = Статус.ПлательщикНПД;
		Результат.ДатаРегистрации = Статус.ДатаРегистрации;
		Результат.ФорматированноеОписание = Новый ФорматированнаяСтрока(ЭлементыОписания);
		Результат.ЦветФонаСтатуса = ЦветФонаСтатуса(Статус, Ошибка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает данные, необходимые для оформления статуса самозанятого в форме договора
//
// Параметры:
//  ОтветСервиса - Структура, Неопределено - результат выполнения метода:
//   * Статус - Структура, Неопределено - статус самозанятого:
//     * ИНН - Строка - ИНН физического лица
//     * НаДату - Дата - дата, на которую выполнялась проверка
//     * ПлательщикНПД - Булево - Истина, если физ.лицо применяет НПД
//     * ДатаРегистрации - Дата, Неопределено - дата изменения статуса
//     * ЭтоОкончательноеЗначение - Булево - признак того, что повторно запрашивать значение из сервиса не требуется
//   * Ошибка - Структура, Неопределено - описание ошибки, которую вернул сервис:
//     * Идентификатор - Строка - идентификатор ошибки
//     * Вид - Строка - вид ошибки
//     * Описание - Строка - представление ошибки
//   * Баланс - Число, Неопределено - остаток доступных опций
//
// Возвращаемое значение:
//  Структура:
//   * ПлательщикНПД - Булево, Неопределено - Истина, если физ.лицо применяет НПД
//   * ДатаРегистрации - Дата, Неопределено - дата изменения статуса
//   * ФорматированноеОписание - ФорматированнаяСтрока
//   * ЦветФонаСтатуса - Цвет
//
Функция РезультатПроверкиСтатусаСамозанятогоДляДоговора(ОтветСервиса) Экспорт
	
	Статус = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ОтветСервиса, "Статус");
	Ошибка = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ОтветСервиса, "Ошибка");
	Баланс = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ОтветСервиса, "Баланс");
	
	Результат = НовыйРезультатПроверкиСтатусаСамозанятого();
	Если Ошибка <> Неопределено Тогда
		ЭлементыОписания = Новый Массив;
		ЭлементыОписания.Добавить(Ошибка.Описание);
		ЭлементыОписания.Добавить(Символы.ПС);
		ЭлементыОписания.Добавить(СтроковыеФункцииКлиент.ФорматированнаяСтрока(
			НСтр("ru = 'Подробнее о сервисе <a href = ""%1"">1С:Статус самозанятого</a>'"),
			ИнтеграцияСтатусСамозанятогоКлиентСервер.ФормаСервисСтатусСамозанятого()));
		Результат.ФорматированноеОписание = Новый ФорматированнаяСтрока(ЭлементыОписания);
		Результат.ЦветФонаСтатуса = ЦветФонаСтатуса(Статус, Ошибка);
	ИначеЕсли Статус <> Неопределено Тогда
		ЭлементыОписания = Новый Массив;
		ОписаниеСтатусаСамозанятого = ОписаниеСтатусаСамозанятогоДляДоговора(
			Статус.ПлательщикНПД, Статус.ДатаРегистрации, Статус.НаДату);
		ЭлементыОписания.Добавить(СтроковыеФункцииКлиент.ФорматированнаяСтрока(
			НСтр("ru = '%1
			|<a href = ""%2"">Повторить проверку</a>'"),
			ОписаниеСтатусаСамозанятого,
			НавигационныеСсылки().ВызватьСервисПроверкиСтатусаСамозанятого));
		Если Баланс <> Неопределено Тогда
			ЭлементыОписания.Добавить(Символы.ПС);
			ЭлементыОписания.Добавить(СтроковыеФункцииКлиент.ФорматированнаяСтрока(
				НСтр("ru = '
				|%1. Подробнее о сервисе <a href = ""%2"">1С:Статус самозанятого</a>'"),
				ИнтеграцияСтатусСамозанятогоКлиентСервер.ОписаниеОстаткаОпций(Баланс),
				ИнтеграцияСтатусСамозанятогоКлиентСервер.ФормаСервисСтатусСамозанятого()));
		КонецЕсли;
		Результат.ПлательщикНПД = Статус.ПлательщикНПД;
		Результат.ДатаРегистрации = Статус.ДатаРегистрации;
		Результат.ФорматированноеОписание = Новый ФорматированнаяСтрока(ЭлементыОписания);
		Результат.ЦветФонаСтатуса = ЦветФонаСтатуса(Статус, Ошибка);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает данные, необходимые для оформления статуса самозанятого
//
// Параметры:
//  ТекстОшибки - Строка - заполняется, если при получении статуса возникла ошибка
//
// Возвращаемое значение:
//  Структура:
//   * ПлательщикНПД - Булево, Неопределено - Истина, если физ.лицо применяет НПД
//   * ДатаРегистрации - Дата, Неопределено - дата изменения статуса
//   * ФорматированноеОписание - ФорматированнаяСтрока
//   * ЦветФонаСтатуса - Цвет
//
Функция ОшибкаПроверкиСтатусаСамозанятого(ТекстОшибки) Экспорт
	
	Результат = НовыйРезультатПроверкиСтатусаСамозанятого();
	Результат.ПлательщикНПД = Неопределено;
	Результат.ДатаРегистрации = Неопределено;
	Результат.ФорматированноеОписание = СтроковыеФункцииКлиент.ФорматированнаяСтрока(
		НСтр("ru = 'Не удалось выполнить проверку статуса самозанятого в сервисе по причине:
			|<a style=""color: ИнтеграцияСтатусСамозанятогоЦветШрифтаОшибки"">%1</a>
			|Подробнее описание ошибки в <a href = ""%2"">Журнале регистрации</a>'"),
		ТекстОшибки,
		НавигационныеСсылки().ОткрытьЖурналРегистрацииСтатусСамозанятого);
	Результат.ЦветФонаСтатуса = ОбщегоНазначенияКлиент.ЦветСтиля(
		"ИнтеграцияСтатусСамозанятогоЦветФонаОшибкиОбращенияКСервису");
	
	Возврат Результат;
	
КонецФункции

Функция НавигационныеСсылки() Экспорт
	
	НавигационныеСсылки = Новый Структура;
	НавигационныеСсылки.Вставить(
		"ВызватьСервисПроверкиСтатусаСамозанятого",
		"ВызватьСервисПроверкиСтатусаСамозанятого");
	НавигационныеСсылки.Вставить(
		"ОткрытьЖурналРегистрацииСтатусСамозанятого",
		"ОткрытьЖурналРегистрацииСтатусСамозанятого");
	Возврат НавигационныеСсылки;
	
КонецФункции

Функция ОбработчикНавигационныеСсылки(НавигационнаяСсылка) Экспорт
	
	Для Каждого КлючИЗначение Из НавигационныеСсылки() Цикл
		Если КлючИЗначение.Значение = НавигационнаяСсылка Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Процедура ОбработатьНавигационнуюСсылкуДокумента(Форма, Элемент, НавигационнаяСсылка, ДоговорКонтрагента, Дата, ДатаВходящегоДокумента = Неопределено) Экспорт
	
	ВсеНавигационныеСсылки = НавигационныеСсылки();
	Если НавигационнаяСсылка = ВсеНавигационныеСсылки.ВызватьСервисПроверкиСтатусаСамозанятого Тогда
		ИННСамозанятого = РаботаСДоговорамиКонтрагентовБПВызовСервера.ИННВладельца(ДоговорКонтрагента);
		ДатаПолученияСтатуса = ИнтеграцияСтатусСамозанятогоБПКлиент.ДатаПолученияСтатуса(Дата, ДатаВходящегоДокумента);
		ЗапущеноПолучениеСтатуса = ИнтеграцияСтатусСамозанятогоКлиент.НачатьПолучениеСтатусаСамозанятого(
			ДоговорКонтрагента, Форма, ИННСамозанятого, ДатаПолученияСтатуса);
		Если ЗапущеноПолучениеСтатуса Тогда
			Элемент.Заголовок = ЗаголовокПодсказкиПолучениеСтатусаВПроцессе();
		КонецЕсли;
	ИначеЕсли НавигационнаяСсылка = ВсеНавигационныеСсылки.ОткрытьЖурналРегистрацииСтатусСамозанятого Тогда
		ИнтеграцияСтатусСамозанятогоКлиент.ОткрытьЖурналРегистрации(Форма, СтрРазделить("Ошибка,Информация", ","));
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьНавигационнуюСсылкуДоговора(Форма, Элемент, НавигационнаяСсылка, Контрагент, Дата) Экспорт
	
	ВсеНавигационныеСсылки = НавигационныеСсылки();
	Если НавигационнаяСсылка = ВсеНавигационныеСсылки.ВызватьСервисПроверкиСтатусаСамозанятого Тогда
		ИННСамозанятого = ИнтеграцияСтатусСамозанятогоБПВызовСервера.ИННКонтрагента(Контрагент);
		ДатаПолученияСтатуса = ИнтеграцияСтатусСамозанятогоБПКлиент.ДатаПолученияСтатуса(Дата);
		ЗапущеноПолучениеСтатуса = ИнтеграцияСтатусСамозанятогоКлиент.НачатьПолучениеСтатусаСамозанятого(
			Форма, Форма, ИННСамозанятого, ДатаПолученияСтатуса);
		Если ЗапущеноПолучениеСтатуса Тогда
			Элемент.Заголовок = ЗаголовокПодсказкиПолучениеСтатусаВПроцессе();
		КонецЕсли;
	ИначеЕсли НавигационнаяСсылка = ВсеНавигационныеСсылки.ОткрытьЖурналРегистрацииСтатусСамозанятого Тогда
		ИнтеграцияСтатусСамозанятогоКлиент.ОткрытьЖурналРегистрации(Форма, СтрРазделить("Ошибка,Информация", ","));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЦветФонаСтатуса(Статус, Ошибка)
	
	Если Ошибка <> Неопределено Тогда
		ИмяЦвета = "ИнтеграцияСтатусСамозанятогоЦветФонаОшибкиОбращенияКСервису";
	ИначеЕсли Статус <> Неопределено Тогда
		Если Не Статус.ПлательщикНПД Тогда
			ИмяЦвета = "ЦветФонаНекорректногоЗначенияБП";
		Иначе
			ИмяЦвета = "ЦветФонаКорректногоЗначенияБП";
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяЦвета <> Неопределено Тогда
		Возврат ОбщегоНазначенияКлиент.ЦветСтиля(ИмяЦвета);
	Иначе
		Возврат Новый Цвет;
	КонецЕсли;
	
КонецФункции

Функция НовыйРезультатПроверкиСтатусаСамозанятого()
	
	Результат = Новый Структура;
	Результат.Вставить("ПлательщикНПД", Неопределено);
	Результат.Вставить("ДатаРегистрации", Неопределено);
	Результат.Вставить("ФорматированноеОписание", Новый ФорматированнаяСтрока(""));
	Результат.Вставить("ЦветФонаСтатуса", Новый Цвет);
	Возврат Результат;
	
КонецФункции

// Возвращает описание статуса самозанятого для отображения в форме документа
//
// Параметры:
//  ПлательщикНПД - Булево - признак наличия у контрагента статуса самозанятого
//  ДатаРегистрации - Дата - дата присвоения или утраты статуса самозанятого в часовом поясе "Europe/Moscow"
//  ДатаПроверки - Дата - дата входящего документа в часовом поясе "Europe/Moscow"
//
// Возвращаемое значение:
//  Строка
//
Функция ОписаниеСтатусаСамозанятогоНаДатуВходящегоДокумента(ПлательщикНПД, ДатаРегистрации, ДатаПроверки)
	
	Если ПлательщикНПД Тогда
		Если Не ЗначениеЗаполнено(ДатаРегистрации) Тогда
			Результат = СтрШаблон(
				НСтр("ru = 'На дату входящего документа %1 контрагент являлся самозанятым (по московскому времени)'"),
				Формат(ДатаПроверки, "ДЛФ=D"));
		Иначе
			Результат = СтрШаблон(
				НСтр("ru = 'На дату входящего документа %1 контрагент являлся самозанятым. Зарегистрирован %2 (по московскому времени).'"),
				Формат(ДатаПроверки, "ДЛФ=D"),
				Формат(ДатаРегистрации, "ДЛФ=D"));
		КонецЕсли;
	Иначе
		Если Не ЗначениеЗаполнено(ДатаРегистрации) Тогда
			Результат = СтрШаблон(
