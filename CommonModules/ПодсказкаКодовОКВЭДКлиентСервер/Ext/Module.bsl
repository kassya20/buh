
#Область СлужебныйПрограммныйИнтерфейс

// Описывает местонахождение элемента в дереве классификации выручки по кодам ОКВЭД.
// 
// Возвращаемое значение:
//  Структура - Новый поля иерархии:
// * ТекущееПоле - Структура:
//   ** ИмяПоля - Строка
//   ** ЗначениеПоля - ЛюбаяСсылка
// * СписокВсехПолей - Структура - состав ключей структуры не является фиксированным, зависит от настройки полей группировки дерева.
Функция НовыйПоляИерархии() Экспорт
	
	ПоляИерархии = Новый Структура;
	ПоляИерархии.Вставить("ТекущееПоле", Новый Структура);
	ПоляИерархии.Вставить("СписокВсехПолей", Новый Структура);
	
	Возврат ПоляИерархии;
	
КонецФункции

// Поля группировок, для значений которых не показываем подсказку, поскольку предполагаем, что их наименования
// плохо сопоставляются с классификатором ОКВЭД.
// 
// Возвращаемое значение:
//  Массив из Строка
Функция ПоляНеПоказыватьПодсказку() Экспорт
	ПоляНеПоказыватьПодсказку = Новый Массив;
	ПоляНеПоказыватьПодсказку.Добавить("ВидНоменклатуры");
	Возврат ПоляНеПоказыватьПодсказку;
КонецФункции

#КонецОбласти

