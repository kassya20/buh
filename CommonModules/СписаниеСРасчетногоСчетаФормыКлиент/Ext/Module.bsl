Процедура ОповеститьОЗаписиСписанияСРасчетногоСчетаНаВыплатуЗарплатыРаботнику(Объект) Экспорт
	
	ПараметрыЗарплаты = Новый Структура;
	ПараметрыЗарплаты.Вставить("Организация",       Объект.Организация);
	ПараметрыЗарплаты.Вставить("Ссылка",            Объект.Ссылка);
	ПараметрыЗарплаты.Вставить("Ведомость",         Объект.ПлатежнаяВедомость);
	ПараметрыЗарплаты.Вставить("Оплачено",          Объект.Проведен);
	Оповестить("Запись_ПлатежныйДокумент_ВыплатаЗарплаты", ПараметрыЗарплаты);
	
КонецПроцедуры

Процедура ОповеститьОЗаписиСписанияСРасчетногоСчетаНаВыплатуЗарплаты(Объект) Экспорт
	
	Ведомости = Новый Массив;
	Если Объект.ПеречислениеЗаработнойПлаты.Количество() > 1 Тогда
		Для Каждого СтрокаТаблицы ИЗ Объект.ПеречислениеЗаработнойПлаты Цикл
			Ведомости.Добавить(СтрокаТаблицы.Ведомость);
		КонецЦикла;
	КонецЕсли;
	
	ПараметрыЗарплаты = Новый Структура;
	ПараметрыЗарплаты.Вставить("Организация", Объект.Организация);
	ПараметрыЗарплаты.Вставить("Ссылка",            Объект.Ссылка);
	ПараметрыЗарплаты.Вставить("Ведомость",         ?(Объект.ПеречислениеЗаработнойПлаты.Количество() = 1,
		Объект.ПеречислениеЗаработнойПлаты[0].Ведомость, Неопределено));
	ПараметрыЗарплаты.Вставить("Ведомости",         Ведомости);
	ПараметрыЗарплаты.Вставить("Оплачено",          Объект.Проведен);
	Оповестить("Запись_ПлатежныйДокумент_ВыплатаЗарплаты", ПараметрыЗарплаты);
	
КонецПроцедуры

