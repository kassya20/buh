Функция ХозрасчетныйФинансовыеВложения(Период, Организации, ВариантУчета)
		
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ХозрасчетныйОбороты.Счет КАК Группа,
	|	ХозрасчетныйОбороты.СуммаОборот КАК Сумма,
	|	ХозрасчетныйОбороты.Организация КАК Организация,
	|	ХозрасчетныйОбороты.Счет КАК Счет,
	|	ХозрасчетныйОбороты.КорСчет КАК КорСчет
	|ПОМЕСТИТЬ Проценты
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			,
	|			Счет В (&СчетаФИ),
	|			,
	|			Организация В (&Организации)
	|				И КорСубконто1 В
	|					(ВЫБРАТЬ
	|						ПрочиеДоходыИРасходы.Ссылка КАК Ссылка
	|					ИЗ
	|						Справочник.ПрочиеДоходыИРасходы КАК ПрочиеДоходыИРасходы
	|					ГДЕ
	|						ПрочиеДоходыИРасходы.ВидПрочихДоходовИРасходов = ЗНАЧЕНИЕ(Перечисление.ВидыПрочихДоходовИРасходов.ПроцентыКПолучению)),
	|			КорСчет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПрочиеДоходы),
	|			&ПрочиеДоходыРасходы) КАК ХозрасчетныйОбороты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОбороты.Счет КАК Группа,
	|	ХозрасчетныйОбороты.СуммаОборот КАК Сумма,
	|	ХозрасчетныйОбороты.Организация КАК Организация
	|ПОМЕСТИТЬ ПереоценкаДоход
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			,
	|			Счет В (&СчетаФИ),
	|			,
	|			Организация В (&Организации)
	|				И КорСубконто1 В
	|					(ВЫБРАТЬ
	|						ПрочиеДоходыИРасходы.Ссылка КАК Ссылка
	|					ИЗ
	|						Справочник.ПрочиеДоходыИРасходы КАК ПрочиеДоходыИРасходы
	|					ГДЕ
	|						ПрочиеДоходыИРасходы.ВидПрочихДоходовИРасходов = ЗНАЧЕНИЕ(Перечисление.ВидыПрочихДоходовИРасходов.ПереоценкаФинансовыхИнструментов)),
	|			КорСчет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПрочиеДоходы),
	|			&ПрочиеДоходыРасходы) КАК ХозрасчетныйОбороты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОбороты.КорСчет КАК Группа,
	|	ХозрасчетныйОбороты.СуммаОборот КАК Сумма,
	|	ХозрасчетныйОбороты.Организация КАК Организация
	|ПОМЕСТИТЬ ПереоценкаРасход
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Обороты(
	|			&НачалоПериода,
	|			&КонецПериода,
	|			,
	|			Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПрочиеРасходы),
	|			&ПрочиеДоходыРасходы,
	|			Организация В (&Организации)
	|				И Субконто1 В
	|					(ВЫБРАТЬ
	|						ПрочиеДоходыИРасходы.Ссылка КАК Ссылка
	|					ИЗ
	|						Справочник.ПрочиеДоходыИРасходы КАК ПрочиеДоходыИРасходы
	|					ГДЕ
	|						ПрочиеДоходыИРасходы.ВидПрочихДоходовИРасходов = ЗНАЧЕНИЕ(Перечисление.ВидыПрочихДоходовИРасходов.ПереоценкаФинансовыхИнструментов)),
	|			КорСчет В (&СчетаФИ),
	|			) КАК ХозрасчетныйОбороты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХозрасчетныйОстаткиИОбороты.Счет КАК Группа,
	|	ХозрасчетныйОстаткиИОбороты.СуммаНачальныйОстаток КАК Начало,
	|	ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстаток КАК Конец,
	|	ХозрасчетныйОстаткиИОбороты.СуммаОборотДт КАК Дт,
	|	ХозрасчетныйОстаткиИОбороты.СуммаОборотКт КАК Кт,
	|	ХозрасчетныйОстаткиИОбороты.Организация КАК Организация
	|ПОМЕСТИТЬ ОстаткиОбороты
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, , , Счет В (&СчетаФИ), , Организация В (&Организации)) КАК ХозрасчетныйОстаткиИОбороты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Группа,
	|	Организации.Ссылка КАК Организация
	|ПОМЕСТИТЬ ГруппыОрганизации
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный,
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.Ссылка В(&Организации)
	|	И Хозрасчетный.Ссылка В(&СчетаФИ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГруппыОрганизации.Организация КАК Организация,
	|	ГруппыОрганизации.Группа КАК Группа,
	|	ЕСТЬNULL(Проценты.Сумма, 0) КАК Проценты,
	|	ЕСТЬNULL(ПереоценкаДоход.Сумма, 0) КАК ПереоценкаДоход,
	|	ЕСТЬNULL(ПереоценкаРасход.Сумма, 0) КАК ПереоценкаРасход,
	|	ЕСТЬNULL(ОстаткиОбороты.Начало, 0) КАК Начало,
	|	ЕСТЬNULL(ОстаткиОбороты.Конец, 0) КАК Конец,
	|	ЕСТЬNULL(ОстаткиОбороты.Дт, 0) КАК Дт,
	|	ЕСТЬNULL(ОстаткиОбороты.Кт, 0) КАК Кт
	|ИЗ
	|	ГруппыОрганизации КАК ГруппыОрганизации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Проценты КАК Проценты
	|		ПО ГруппыОрганизации.Группа = Проценты.Группа
	|			И ГруппыОрганизации.Организация = Проценты.Организация
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПереоценкаДоход КАК ПереоценкаДоход
	|		ПО ГруппыОрганизации.Группа = ПереоценкаДоход.Группа
	|			И ГруппыОрганизации.Организация = ПереоценкаДоход.Организация
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПереоценкаРасход КАК ПереоценкаРасход
	|		ПО ГруппыОрганизации.Группа = ПереоценкаРасход.Группа
	|			И ГруппыОрганизации.Организация = ПереоценкаРасход.Организация
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиОбороты КАК ОстаткиОбороты
	|		ПО ГруппыОрганизации.Группа = ОстаткиОбороты.Группа
	|			И ГруппыОрганизации.Организация = ОстаткиОбороты.Организация";
	
	                  
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса; 		  
	
	Запрос.УстановитьПараметр("ПрочиеДоходыРасходы", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрочиеДоходыИРасходы);
	Запрос.УстановитьПараметр("СчетаФИ", СчетаУчетаВложений()[ВариантУчета]);    
	Запрос.УстановитьПараметр("НачалоПериода", Период.Начало); 
	Запрос.УстановитьПараметр("КонецПериода", Период.Конец);	
	Запрос.УстановитьПараметр("Организации", Организации); 	 
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции     

Функция ХозрасчетныйРезервыОбесценения(Период, Организации, ВариантУчета = Неопределено)
		
	Запрос = Новый Запрос;	
	
	УсловиеВариантУчета = "
	|	Субконто1 В(&Контрагенты58_05)"; 
	Если ВариантУчета = "Долгосрочные" Тогда
		УсловиеВариантУчета = СтрЗаменить(УсловиеВариантУчета, "Субконто1 В", "НЕ Субконто1 В"); 		
	КонецЕсли;        	
	Если ВариантУчета = Неопределено Тогда
		УсловиеВариантУчета = "ИСТИНА";	
	КонецЕсли; 
	Запрос.УстановитьПараметр("Контрагенты58_05", Контрагенты58_05(Организации,Период));
	
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	Организации.Ссылка КАК Организация,
	|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РезервыПодОбесценениеФинансовыхВложений) КАК Группа,
	|	ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.СуммаНачальныйОстаток, 0) КАК Начало,
	|	ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.СуммаОборотДт, 0) КАК Дт,
	|	ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.СуммаОборотКт, 0) КАК Кт,
	|	ЕСТЬNULL(ХозрасчетныйОстаткиИОбороты.СуммаКонечныйОстаток, 0) КАК Конец
	|ИЗ
	|	Справочник.Организации КАК Организации
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(
	|				&НачалоПериода,
	|				&КонецПериода,
	|				,
	|				,
	|				Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.РезервыПодОбесценениеФинансовыхВложений),
	|				,
	|				Организация В (&Организации)
	|					И &УсловиеВариантУчета) КАК ХозрасчетныйОстаткиИОбороты
	|		ПО ХозрасчетныйОстаткиИОбороты.Организация = Организации.Ссылка";
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"&УсловиеВариантУчета",УсловиеВариантУчета);	
		
	Запрос.УстановитьПараметр("НачалоПериода", Период.Начало); 
	Запрос.УстановитьПараметр("КонецПериода", Период.Конец);	
	Запрос.УстановитьПараметр("Организации", Организации);    
	
	Возврат Запрос.Выполнить().Выгрузить();	
	
КонецФункции

Функция Контрагенты58_05(Организации, Период) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
		"ВЫБРАТЬ
		|	ХозрасчетныйОстаткиИОбороты.Субконто1 КАК Ссылка
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, , , Счет = ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.ПриобретенныеПрава), , Организация В (&Организации)) КАК ХозрасчетныйОстаткиИОбороты";
	
