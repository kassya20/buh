#Область ПрограммныйИнтерфейс

// Описывает состав прикладных данных таблицы отчета.
// Под таблицей понимается совокупность строк с одинаковым составом колонок.
// Обычно каждая таблица в отчете имеет отдельное название, номер и шапку с описанием колонок.
//
// Параметры:
//  Описание - см. ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйОписаниеТаблицыОтчета - заполняемая коллекция
//  ИмяТаблицыОтчета - Строка - имя таблицы из ЗаполнениеБухгалтерскойОтчетностиРазмещение.СоставТаблицОтчета
//
Процедура ОписатьТаблицуОтчета(Описание, ИмяТаблицыОтчета) Экспорт
	
	Если ИмяТаблицыОтчета = "ФинансовыеВложенияНаличиеДвижение" Тогда
		ОписатьТаблицуНаличиеДвижение(Описание);
	КонецЕсли;
		
КонецПроцедуры

// Определяет состав заполняемых пояснений конкретного отчета (за конкретный период, по конкретной организации)
//
// Параметры:
//  ТаблицыОтчета - Структура - Ключ - имя таблицы из ЗаполнениеБухгалтерскойОтчетностиРазмещение.СоставТаблицОтчета; Значение - Булево.
//                  Для заполняемых пояснений следует установить значение Истина, состав коллекции изменять не следует.
//  КонтекстОтчета - см. БухгалтерскаяОтчетностьБРО.НовыйКонтекстОтчета
//
Процедура ОпределитьСоставЗаполняемыхПояснений(ТаблицыОтчета, КонтекстОтчета) Экспорт
	
	ТаблицыОтчета.ФинансовыеВложенияНаличиеДвижение = Истина;
	
КонецПроцедуры

// Заполняет таблицы отчета за один период.
//
// Параметры:
//  ПолучениеДанныхТаблицОтчета - см. ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйПолучениеДанныхТаблицОтчета -
//     процессор, который содержит исходные параметры для получения данных,
//     и в который нужно разместить полученные данные.
//  Классификаторы - Структура - Ключ: имя таблицы отчета; Значение: Структура - Ключ и Значение: имя колонки, содержащей значения по классификатору
//  КонтекстЗаполненияОтчета - см. БухгалтерскаяОтчетностьБРО.НовыйКонтекстЗаполненияОтчета
//
Процедура ЗаполнитьТаблицыОтчета(ПолучениеДанныхТаблицОтчета, Классификаторы, КонтекстЗаполненияОтчета) Экспорт
	
	Если ЗаполнениеБухгалтерскойОтчетностиТабличное.ТаблицаОтчета(ПолучениеДанныхТаблицОтчета, "ФинансовыеВложенияНаличиеДвижение") <> Неопределено Тогда
		ЗаполнитьТаблицуНаличиеДвижение(ПолучениеДанныхТаблицОтчета, Классификаторы, КонтекстЗаполненияОтчета);     
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОписатьТаблицуНаличиеДвижение(Описание) 
			
	Описание.Представление = НСтр("ru = 'Финансовые вложения'");
	Описание.Структура.Добавить("ВариантУчета");
	Описание.Структура.Добавить("Группа"); 
	
	Описание.Классификаторы.Вставить("ВариантУчета", Новый СписокЗначений);
	Описание.Классификаторы.ВариантУчета.Добавить("Долгосрочные",  НСтр("ru = 'Долгосрочные финансовые вложения'"));
	Описание.Классификаторы.ВариантУчета.Добавить("Краткосрочные", НСтр("ru = 'Краткосрочные финансовые вложения'"));
	
	ЧисловыеЗначения = Новый Массив; 
	ЧисловыеЗначения.Добавить("ПервоначальнаяНачало");
	ЧисловыеЗначения.Добавить("КорректировкаНачало");
	ЧисловыеЗначения.Добавить("ПервоначальнаяПоступило");
	ЧисловыеЗначения.Добавить("ПервоначальнаяСписано");
	ЧисловыеЗначения.Добавить("КорректировкаСписано");
	ЧисловыеЗначения.Добавить("КорректировкаПроценты");
	ЧисловыеЗначения.Добавить("КорректировкаПереоценка");
	ЧисловыеЗначения.Добавить("Переклассифицировано");
	ЧисловыеЗначения.Добавить("ПервоначальнаяКонец");
	ЧисловыеЗначения.Добавить("КорректировкаКонец");  
	
	Описание.ЧисловыеЗначения = ЧисловыеЗначения;
	
КонецПроцедуры 

Процедура ЗаполнитьТаблицуНаличиеДвижение(ЗаполняемыеДанные, Классификаторы, КонтекстЗаполненияОтчета)
	
	ПараметрыРасшифровки = ПараметрыРасшифровкиНаличиеДвижение(КонтекстЗаполненияОтчета);
	ШаблоныКолонок = Новый Соответствие;
	ШаблоныРасшифровкиВложения = ШаблоныРасшифровкиНаличиеДвижение(); 
	ШаблоныРасшифровкиРезервы = ШаблоныРасшифровкиНаличиеДвижение(Истина); 
	
	ВыводТаблицы = ЗаполнениеБухгалтерскойОтчетностиТабличное.НачатьВыводТаблицы(
		ЗаполняемыеДанные, "ФинансовыеВложенияНаличиеДвижение", ШаблоныКолонок, ПараметрыРасшифровки); 

	РеквизитыОрганизаций = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
		КонтекстЗаполненияОтчета.Организации, "Наименование");					
	
	Для Каждого ОписаниеВариантаУчета Из Классификаторы.ФинансовыеВложенияНаличиеДвижение.ВариантУчета Цикл
		
		ВариантУчета = ОписаниеВариантаУчета.Значение;
		СчетаУчета = СчетаУчетаВложений();
		
		ХозрасчетныйВложения = ХозрасчетныйФинансовыеВложения(
			КонтекстЗаполненияОтчета.Период, КонтекстЗаполненияОтчета.Организации, ВариантУчета); 	
					
		Для Каждого Счет Из СчетаУчета[ВариантУчета] Цикл  
			
			НаименованиеГруппы = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Счет,"Наименование");
			ПараметрыРасшифровки.НаименованиеГруппы = НаименованиеГруппы;
				
			НоваяСтрока = ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСтрокуТаблицыОтчета(
				ВыводТаблицы, ШаблоныРасшифровкиВложения, ПараметрыРасшифровки);
			НоваяСтрока.Группа = НаименованиеГруппы;
			НоваяСтрока.ВариантУчета = ВариантУчета; 
			
			Для Каждого Организация Из КонтекстЗаполненияОтчета.Организации Цикл  
								
				ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьФилиал(
					ВыводТаблицы, ШаблоныРасшифровкиВложения, Организация, РеквизитыОрганизаций[Организация].Наименование);

				ЗаполнитьСтрокуНаличиеДвижение(
					ВыводТаблицы, 
					ХозрасчетныйВложения.НайтиСтроки(
						Новый Структура("Группа, Организация", Счет, Организация))[0], 
					КонтекстЗаполненияОтчета.Период);   
						
			КонецЦикла;   
				
			ЗаполнениеБухгалтерскойОтчетностиТабличное.ЗакончитьДобавлениеСтрокиТаблицыОтчета(
				ВыводТаблицы, ШаблоныРасшифровкиВложения);    
			
		КонецЦикла;
		
		ХозрасчетныйРезервы = ХозрасчетныйРезервыОбесценения(
			КонтекстЗаполненияОтчета.Период, КонтекстЗаполненияОтчета.Организации, ВариантУчета);	   
			
		НаименованиеГруппы = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ХозрасчетныйРезервы[0].Группа,"Наименование");
		ПараметрыРасшифровки.НаименованиеГруппы = НаименованиеГруппы;
	
		НоваяСтрока = ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСтрокуТаблицыОтчета(
			ВыводТаблицы, ШаблоныРасшифровкиРезервы, ПараметрыРасшифровки);
		НоваяСтрока.Группа = НаименованиеГруппы;		
		НоваяСтрока.ВариантУчета = ВариантУчета;			
		
		Для Каждого Организация Из КонтекстЗаполненияОтчета.Организации Цикл 
			
			ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьФилиал(
				ВыводТаблицы, ШаблоныРасшифровкиРезервы, Организация, РеквизитыОрганизаций[Организация].Наименование);
					
			ЗаполнитьСтрокуРезервы(ВыводТаблицы, ХозрасчетныйРезервы.Найти(Организация, "Организация"), 
				ВариантУчета, КонтекстЗаполненияОтчета.Период);       
				
		КонецЦикла;
		
		ЗаполнениеБухгалтерскойОтчетностиТабличное.ЗакончитьДобавлениеСтрокиТаблицыОтчета(
			ВыводТаблицы, ШаблоныРасшифровкиРезервы);
		
	КонецЦикла; 
	
	
КонецПроцедуры 

Процедура ЗаполнитьСтрокуНаличиеДвижение(ВыводТаблицы, ХозрасчетныйВложение, Период)
	
	Счет = ХозрасчетныйВложение.Группа; 	
	ОСВ_58 = ОСВ(ХозрасчетныйВложение.Организация, Период, Счет);
	
	ПроцентыКПолучению = ПроцентыКПолучению(ХозрасчетныйВложение, Период);
	ПереоценкаДоход = ПереоценкаДоход(ХозрасчетныйВложение, Период);
	ПереоценкаРасход = ПереоценкаРасход(ХозрасчетныйВложение, Период);
		
	// ПервоначальнаяНачало
	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "ПервоначальнаяНачало", 
		СтрШаблон(НСтр("ru='Остаток по счету %1'"), Строка(Счет)),
		ХозрасчетныйВложение.Начало, Счет, ОСВ_58);    
	
	// КорректировкаПроценты 	  
	ДобавитьСлагаемое(ВыводТаблицы, "КорректировкаПроценты", ПроцентыКПолучению); 
	
	
	// КорректировкаПереоценка  
	ДобавитьСлагаемое(ВыводТаблицы, "КорректировкаПереоценка", ПереоценкаДоход); 
	
	ВычестьСлагаемое(ВыводТаблицы, "КорректировкаПереоценка", ПереоценкаРасход); 
				
	// ПервоначальнаяПоступило
	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "ПервоначальнаяПоступило",
		СтрШаблон(НСтр("ru='Оборот Дт %1'"), Строка(Счет)),
		ХозрасчетныйВложение.Дт, Счет, ОСВ_58); 
		
	ВычестьСлагаемое(ВыводТаблицы, "ПервоначальнаяПоступило", ПроцентыКПолучению);  
		
	ВычестьСлагаемое(ВыводТаблицы, "ПервоначальнаяПоступило", ПереоценкаДоход);
			
	// ПервоначальнаяСписано
	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "ПервоначальнаяСписано",
		СтрШаблон(НСтр("ru='Оборот Кт %1'"), Строка(Счет)),
		-ХозрасчетныйВложение.Кт, Счет, ОСВ_58); 
		
	ДобавитьСлагаемое(ВыводТаблицы, "ПервоначальнаяСписано", ПереоценкаРасход); 
	
	// ПервоначальнаяКонец
	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "ПервоначальнаяКонец",
		СтрШаблон(НСтр("ru='Остаток по счету %1'"), Строка(Счет)),
		ХозрасчетныйВложение.Конец, Счет, ОСВ_58); 
		
		
КонецПроцедуры

Процедура ЗаполнитьСтрокуРезервы(ВыводТаблицы, ХозрасчетныйРезерв, ВариантУчета, Период)
	
	Счет = ХозрасчетныйРезерв.Группа;
	СтрСчет = Строка(ХозрасчетныйРезерв.Группа);  
	СтрВариантУчета = ?(ВариантУчета="Долгосрочные", НСтр("ru='долгосрочным'"), НСтр("ru='краткосрочным'"));
	Организация = ХозрасчетныйРезерв.Организация; 
	Организации = Новый Массив;
	Организации.Добавить(Организация);
	ВидСравненияОтбора = ?(ВариантУчета="Долгосрочные", ВидСравненияКомпоновкиДанных.НеВСписке, ВидСравненияКомпоновкиДанных.ВСписке);
	
	Отборы = Новый Массив;
	Отбор = НовыйОтборОтчета();
	Отбор.ВидСравнения = ВидСравненияОтбора; 
	Отбор.Поле = "Субконто%1";
	Отбор.ВидСубконто = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты;
	Контрагенты58_05 = Новый СписокЗначений;  
	Контрагенты58_05.ЗагрузитьЗначения(Контрагенты58_05(Организации, Период));
	Отбор.Значение = Контрагенты58_05;
	Отборы.Добавить(Отбор);
	
	ОСВ_59 = ОСВ(Организация, Период, Счет, Отборы);
	
	// Долгосрочными считаем резервы относящиеся к счету 58, за исключением субсчета 58.05
	// Краткосрочными считаем часть резервов 59, где контрагент в аналитике остатков счета 58.05
	
	// КорректировкаНачало
	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "КорректировкаНачало",
		СтрШаблон(НСтр("ru='Остаток по счету %1 по %2 вложениям'"), СтрСчет, СтрВариантУчета),
		ХозрасчетныйРезерв.Начало,,ОСВ_59);
		
	// КорректировкаПереоценка
	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "КорректировкаПереоценка",
		СтрШаблон(НСтр("ru='Оборот Кт %1 по %2 вложениям'"), СтрСчет, СтрВариантУчета),
		-ХозрасчетныйРезерв.Кт,,ОСВ_59);  

	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "КорректировкаПереоценка",
		СтрШаблон(НСтр("ru='Оборот Дт %1 по %2 вложениям'"), СтрСчет, СтрВариантУчета),
		ХозрасчетныйРезерв.Дт,,ОСВ_59);  
	
	// КорректировкаКонец
	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, "КорректировкаКонец",
		СтрШаблон(НСтр("ru='Остаток по счету %1 по %2 вложениям'"), СтрСчет, СтрВариантУчета),
		ХозрасчетныйРезерв.Конец,,ОСВ_59);
		
КонецПроцедуры

Функция ПараметрыРасшифровкиНаличиеДвижение(КонтекстЗаполненияОтчета)

	ПараметрыТекстов = Новый Структура;	
	ЗаполнениеБухгалтерскойОтчетностиТабличное.УстановитьПараметрыТекстовРасшифровки(ПараметрыТекстов, КонтекстЗаполненияОтчета);	
	ПараметрыТекстов.Вставить("НаименованиеГруппы", "");
	
	Возврат ПараметрыТекстов;
	
КонецФункции

Функция ШаблоныРасшифровкиНаличиеДвижение(Резервы = Ложь)

	Шаблоны = Новый Соответствие;
	
	Если Резервы Тогда        
		
		Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
		Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: накопленная корректировка на [НачалоПериода]'");
		Шаблоны.Вставить("КорректировкаНачало", Шаблон); 
					
		Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
		Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: накопленная корректировка на [КонецПериода]'");
		Шаблоны.Вставить("КорректировкаКонец", Шаблон);  

	Иначе
		
		Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
		Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: первоначальная стоимость на [НачалоПериода]'");
		Шаблоны.Вставить("ПервоначальнаяНачало", Шаблон); 

		Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
		Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: первоначальная стоимость на [КонецПериода]'");
		Шаблоны.Вставить("ПервоначальнаяКонец", Шаблон);  

		Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
		Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: проценты за [Период]'");
		Шаблоны.Вставить("КорректировкаПроценты", Шаблон); 
				
	    Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
		Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: поступило за [Период]'");
		Шаблоны.Вставить("ПервоначальнаяПоступило", Шаблон); 

		Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
		Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: списано первоначальная стоимость за [Период]'");
		Шаблоны.Вставить("ПервоначальнаяСписано", Шаблон);       
		
	КонецЕсли;   

	Шаблон = ЗаполнениеБухгалтерскойОтчетностиТабличное.НовыйШаблонЗаголовковРасшифровки();
	Шаблон.ЗаголовокГруппы = НСтр("ru = '[НаименованиеГруппы]: переоценка за [Период]'");
	Шаблоны.Вставить("КорректировкаПереоценка", Шаблон); 
	
	Возврат Шаблоны;
	
