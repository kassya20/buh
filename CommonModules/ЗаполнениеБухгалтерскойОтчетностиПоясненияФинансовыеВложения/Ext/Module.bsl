	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");

КонецФункции

Функция СчетаУчетаВложений()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	
		"ВЫБРАТЬ
		|	Хозрасчетный.Ссылка КАК Ссылка
		|ИЗ
		|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
		|ГДЕ
		|	Хозрасчетный.Ссылка В ИЕРАРХИИ(&Ссылка)
		|	И Хозрасчетный.ЗапретитьИспользоватьВПроводках = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Хозрасчетный.Код"; 
	
	Запрос.УстановитьПараметр("Ссылка", ПланыСчетов.Хозрасчетный.ФинансовыеВложения); 	
	Долгосрочные = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
		
	Краткосрочные = Новый Массив;
	Краткосрочные.Добавить(ПланыСчетов.Хозрасчетный.ПриобретенныеПрава); 
	Краткосрочные.Добавить(ПланыСчетов.Хозрасчетный.ДепозитныеСчета); 
	Краткосрочные.Добавить(ПланыСчетов.Хозрасчетный.ДепозитныеСчетаВал);

	Долгосрочные = ОбщегоНазначенияКлиентСервер.РазностьМассивов(Долгосрочные, Краткосрочные);	
	
	Возврат Новый Структура("Долгосрочные, Краткосрочные", Долгосрочные, Краткосрочные); 
	
КонецФункции 

Функция ПроцентыКПолучению(ХозрасчетныйВложение, Период)
	
	Счет = ХозрасчетныйВложение.Группа;
	КорСчет = ПланыСчетов.Хозрасчетный.ПрочиеДоходы;
   	ВидСкПроценты = Перечисления.ВидыПрочихДоходовИРасходов.ПроцентыКПолучению; 
	Организация = ХозрасчетныйВложение.Организация;
	
	Слагаемое = НовыйСлагаемое();
	Слагаемое.Описание = СтрШаблон(
		НСтр("ru='Оборот Дт %1 Кт %2 по статьям с видом %3'"),
		Строка(Счет),
		Строка(КорСчет),
		Строка(ВидСкПроценты)); 
		
	Отборы = Новый Массив;
	Отбор = НовыйОтборОтчета();
	Отбор.Поле = "Субконто%1.ВидПрочихДоходовИРасходов";
	Отбор.ВидСубконто = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрочиеДоходыИРасходы;
	Отбор.Значение = ВидСкПроценты;
	Отборы.Добавить(Отбор);
		
	Слагаемое.Отчет = АнализСчета(Организация, Период, КорСчет, Счет, Отборы);	
	Слагаемое.Сумма = ХозрасчетныйВложение.Проценты; 
		
	Возврат Слагаемое;
	
КонецФункции   

Функция ПереоценкаДоход(ХозрасчетныйВложение, Период)
	
	Счет = ХозрасчетныйВложение.Группа;
	КорСчет = ПланыСчетов.Хозрасчетный.ПрочиеДоходы;
	ПереоценкаФИ = Перечисления.ВидыПрочихДоходовИРасходов.ПереоценкаФинансовыхИнструментов;   
