Функция ПереоценкаРасход(ХозрасчетныйВложение, Период)
	
	Счет = ПланыСчетов.Хозрасчетный.ПрочиеРасходы; 
	КорСчет = ХозрасчетныйВложение.Группа;
	ПереоценкаФИ = Перечисления.ВидыПрочихДоходовИРасходов.ПереоценкаФинансовыхИнструментов;   
	Организация = ХозрасчетныйВложение.Организация;
		
	Слагаемое = НовыйСлагаемое();
	Слагаемое.Описание = СтрШаблон(
		НСтр("ru='Оборот Дт %1 по статьям с видом %2 Кт %3'"),
		Строка(Счет),
		Строка(ПереоценкаФИ),
		Строка(КорСчет)); 
		
	Отборы = Новый Массив;
	Отбор = НовыйОтборОтчета();
	Отбор.Поле = "Субконто%1.ВидПрочихДоходовИРасходов";
	Отбор.ВидСубконто = ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.ПрочиеДоходыИРасходы;
	Отбор.Значение = ПереоценкаФИ;
	Отборы.Добавить(Отбор);
		
	Слагаемое.Отчет = АнализСчета(Организация, Период, Счет, КорСчет, Отборы);
		
	Слагаемое.Сумма = ХозрасчетныйВложение.ПереоценкаРасход;
	
	Возврат Слагаемое;
		
КонецФункции

Функция НовыйСлагаемое()
	Возврат Новый Структура("Описание, Отчет, Сумма");
КонецФункции

Процедура ДобавитьСлагаемое(ВыводТаблицы, ИмяКолонки, Слагаемое) 

	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, ИмяКолонки,
		Слагаемое.Описание,
		Слагаемое.Сумма, 
		Неопределено, 
		Слагаемое.Отчет
	);    
	
КонецПроцедуры  

Процедура ВычестьСлагаемое(ВыводТаблицы, ИмяКолонки, Слагаемое) 

	ЗаполнениеБухгалтерскойОтчетностиТабличное.ДобавитьСлагаемое(
		ВыводТаблицы, ИмяКолонки,
		Слагаемое.Описание,
		-Слагаемое.Сумма, 
		Неопределено, 
		Слагаемое.Отчет
	);    
	
КонецПроцедуры

Функция ОСВ(Организация, Период, Счет, Отборы = Неопределено)
	
	НастройкиОтчета = ЗаполнениеБухгалтерскойОтчетностиРасшифровка.ЗначенияНастроекОтчетаФинансовыеВложения(
		Новый Структура("Организация, Счет", Организация, Счет)	
	);	 
	
	Если ЗначениеЗаполнено(Отборы) Тогда	
		Для Каждого Отбор Из Отборы Цикл
				
			ЗаполнениеБухгалтерскойОтчетностиРасшифровка.НастроитьОтборПоВидуСубконто(
				НастройкиОтчета,
				Отбор.Поле,
				Счет,
				Отбор.ВидСубконто,
				Отбор.Значение,
				Отбор.ВидСравнения
			);		
		КонецЦикла;
	КонецЕсли;

	
	Возврат ЗаполнениеБухгалтерскойОтчетностиРасшифровка.НастройкиОтчетаПоЗначениям(НастройкиОтчета, Период);
		
КонецФункции  

Функция АнализСчета(Организация, Период, Счет, КорСчет = Неопределено, Отборы = Неопределено)  
	
	Параметры = Новый Структура("Счет, Организация, ИмяОтчета, ПоСубсчетамКорСчетов", Счет, Организация, "АнализСчета", Истина);
	Если ЗначениеЗаполнено(КорСчет) Тогда
		Параметры.Вставить("КорСчет", КорСчет);
	КонецЕсли;
	
	НастройкиОтчета = ЗаполнениеБухгалтерскойОтчетностиРасшифровка.ЗначенияНастроекОтчетаФинансовыеВложения(
		Параметры); 
		
	Если ЗначениеЗаполнено(Отборы) Тогда	
		Для Каждого Отбор Из Отборы Цикл
				
			ЗаполнениеБухгалтерскойОтчетностиРасшифровка.НастроитьОтборПоВидуСубконто(
				НастройкиОтчета,
				Отбор.Поле,
				Счет,
				Отбор.ВидСубконто,
				Отбор.Значение,
				Отбор.ВидСравнения
			);		
		КонецЦикла;
	КонецЕсли;
		
	Возврат ЗаполнениеБухгалтерскойОтчетностиРасшифровка.НастройкиОтчетаПоЗначениям(НастройкиОтчета, Период);
	
КонецФункции

Функция НовыйОтборОтчета()
	Возврат Новый Структура("ВидСравнения, Поле, Значение, ВидСубконто", ВидСравненияКомпоновкиДанных.Равно);
КонецФункции

#КонецОбласти

