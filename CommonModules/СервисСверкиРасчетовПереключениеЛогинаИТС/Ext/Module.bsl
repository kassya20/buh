Функция СтруктураЗаявления()
	
	ДанныеЗаявления = Новый Структура;
	ДанныеЗаявления.Вставить("ПолноеНаименованиеОрганизации","");
	ДанныеЗаявления.Вставить("Логин",                        "");
	ДанныеЗаявления.Вставить("ИНН",                          "");
	ДанныеЗаявления.Вставить("КПП",                          "");
	ДанныеЗаявления.Вставить("Пользователь",                 "");
	ДанныеЗаявления.Вставить("ФаксимилеПечать",              "");
	ДанныеЗаявления.Вставить("ФаксимилеРуководитель",        "");
	ДанныеЗаявления.Вставить("ФИОРуководителя",              "");
	ДанныеЗаявления.Вставить("Дата",                         "");
	
	Возврат ДанныеЗаявления;
	
КонецФункции

// Возвращает данные заявления для указанной организации.
//
// Параметры:
//   Организация - СправочникСсылка.Организации - организация,
//       для которой формируются данные заявления.
//
// Возвращаемое значение:
//   Структура - данные заявления, см. СтруктураЗаявления().
//
Функция ДанныеЗаявления(Организации)
	
	МассивРезультатов = Новый Массив;
	
	Если Организации.Количество() = 0 Тогда
		Возврат МассивРезультатов;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организации", Организации);
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Организации.Ссылка КАК Организация,
	|	Организации.НаименованиеПолное КАК НаименованиеПолное,
	|	Организации.ИНН КАК ИНН
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.Ссылка В(&Организации)";
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Период = ТекущаяДатаСеанса();
	
	Пока Выборка.Следующий() Цикл
		
		ДанныеЗаявления = СтруктураЗаявления();
		ДанныеЗаявления.ПолноеНаименованиеОрганизации = Строка(Выборка.НаименованиеПолное);
		ДанныеЗаявления.ИНН = Выборка.ИНН;
		ДанныеЗаявления.КПП = СервисСверкиРасчетовПереопределяемый.КППНаДату(Выборка.Организация,ТекущаяДата());
		
		ПодписиОрганизации = СервисСверкиРасчетовПереопределяемый.ПодписиИПечатиОрганизации(Выборка.Организация);
		
		Если ЗначениеЗаполнено(ПодписиОрганизации) Тогда
			Если ЗначениеЗаполнено(ПодписиОрганизации.ФаксимилеПечать) И ПодписиОрганизации.Свойство("ФаксимилеПечать") Тогда
				ДанныеЗаявления.ФаксимилеПечать = Новый ХранилищеЗначения(ПодписиОрганизации.ФаксимилеПечать);
			КонецЕсли;
			Если ЗначениеЗаполнено(ПодписиОрганизации.ФаксимилеРуководитель) И ПодписиОрганизации.Свойство("ФаксимилеРуководитель") Тогда
				ДанныеЗаявления.ФаксимилеРуководитель = Новый ХранилищеЗначения(ПодписиОрганизации.ФаксимилеРуководитель);
			КонецЕсли;
		КонецЕсли;
		
		ОтветственныеЛица = СервисСверкиРасчетовПереопределяемый.ОтветственныеЛица(Выборка.Организация,Период);
		
		ДанныеЗаявления.Пользователь = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ОтветственныеЛица.Руководитель.Наименование);
		
		Если ОтветственныеЛица <> Неопределено И ЗначениеЗаполнено(ОтветственныеЛица.Руководитель) Тогда
			ДанныеЗаявления.ФИОРуководителя = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ОтветственныеЛица.Руководитель.Наименование);
		Иначе
			ДанныеЗаявления.ФИОРуководителя = "";
		КонецЕсли;
		
		Если ОбщегоНазначения.РазделениеВключено() Тогда
			ДанныеЗаявления.Логин = ПолучитьИдентификаторИТС();
		Иначе
			УстановитьПривилегированныйРежим(Истина);
			ДанныеАутентификации = ИнтернетПоддержкаПользователей.ДанныеАутентификацииПользователяИнтернетПоддержки();
			ДанныеЗаявления.Логин = ДанныеАутентификации.Логин;
			УстановитьПривилегированныйРежим(Ложь);
		КонецЕсли;
		
		МассивРезультатов.Добавить(ДанныеЗаявления);
		
	КонецЦикла;
	
	Возврат МассивРезультатов;

КонецФункции

Процедура ДобавитьФаксимиле(Заявление,ОбластьМакета)

	Если ЗначениеЗаполнено(Заявление.ФаксимилеПечать) Тогда
		КартинкаПечать = Заявление.ФаксимилеПечать.Получить();
		Если ЗначениеЗаполнено(КартинкаПечать) Тогда
			ОбластьМакета.Рисунки.ПереключениеПечать_Заявление.Картинка = КартинкаПечать;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Заявление.ФаксимилеРуководитель) Тогда
		КартинкаРуководитель = Заявление.ФаксимилеРуководитель.Получить();
		Если ЗначениеЗаполнено(КартинкаРуководитель) Тогда
			ОбластьМакета.Рисунки.Руководитель_Заявление.Картинка = КартинкаРуководитель;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Заявление.ФИОРуководителя) Тогда
		ОбластьМакета.Параметры.ФИОРуководителя = Заявление.ФИОРуководителя;
	Иначе
		ОбластьМакета.Параметры.ФИОРуководителя = "";
	КонецЕсли;
	
	ОбластьМакета.Параметры.Дата = Формат(ТекущаяДатаСеанса(), "ДФ=dd.MM.yyyy");
	
КонецПроцедуры

Функция ПустаяДатаJSON()

	Возврат ЗаписатьДатуJSON('00010101', ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.УниверсальнаяДата);

КонецФункции

// Преобразует строку в дату.
// 
// Параметры:
//  СтрокаДанных - Строка - значение, преобразуемое в дату
// 
// Возвращаемое значение:
//  Дата - Строка в дату
Функция СтрокаВДату(СтрокаДанных)
	
	Результат = Дата(1,1,1);
	
	Если СтрокаДанных = ПустаяДатаJSON() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = ПрочитатьДатуJSON(СтрокаДанных, ФорматДатыJSON.ISO);
	
	Возврат Результат;
	
КонецФункции

// Преобразует строку в число
// 
// Параметры:
//  Значение - Произвольный - значение, преобразуемое в число
// 
// Возвращаемое значение:
//  Число, Неопределено, Произвольный - Строка в число
Функция СтрокаВЧисло(Значение)
	
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Результат = Значение;
	ИначеЕсли ТипЗнч(Значение) = Тип("Строка") Тогда
		НовоеЗначение = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(Значение);
		Если НовоеЗначение = Неопределено Тогда
			Результат = 0;
		Иначе
			Результат = НовоеЗначение;
		КонецЕсли;
		
	Иначе
		Результат = 0;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Получает значение реквизита структуры/соответствия
// 
// Параметры:
//  Источник - Структура - источник данных.
//  ИмяРеквизита - Строка - Имя реквизита. Поддерживается разделение через "."
//  ТипЗначения - Строка - Тип значения, к которому нужно привести пустое значение реквизита
//  ЗначениеПоУмолчанию - Неопределено, Произвольный - Значение по умолчанию
// 
// Возвращаемое значение:
//  Неопределено, Произвольный, Строка, Дата, Булево, Структура, Массив из Произвольный - Полученное значение
Функция ПолучитьЗначениеСтруктуры(Знач Источник, Знач ИмяРеквизита, ТипЗначения = "", ЗначениеПоУмолчанию = Неопределено)
	
	Значение = ЗначениеПоУмолчанию;
	
	МассивПолей = СтрРазделить(ИмяРеквизита, ".");
	КоличествоПолей = МассивПолей.Количество()-1;
	
	Для Ид = 0 По КоличествоПолей-1 Цикл
		ИмяСвойства = МассивПолей[Ид];
		
		Если ТипЗнч(Источник) = Тип("Структура")
			И Источник.Свойство(ИмяСвойства) Тогда
			Источник = Источник[ИмяСвойства]; // Структура
		Иначе
			Возврат Значение;
		КонецЕсли;
		
	КонецЦикла;
	
	ИмяРеквизита = МассивПолей[КоличествоПолей];
	
	ВыполнитьПреобразование = Ложь;
	
	Если ТипЗнч(Источник) = Тип("Структура") И Источник.Свойство(ИмяРеквизита) Тогда
		
		ИсходноеЗначение = Источник[ИмяРеквизита]; // Произвольный
		ВыполнитьПреобразование = Истина;
		
	ИначеЕсли ТипЗнч(Источник) = Тип("Соответствие") Тогда
		
		ИсходноеЗначение = Источник.Получить(ИмяРеквизита);
		ВыполнитьПреобразование = Истина;
		
	КонецЕсли;
	
	Если ВыполнитьПреобразование Тогда
		
		Если ИсходноеЗначение = Неопределено Тогда
			Значение = ЗначениеПоУмолчанию;
		ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Массив") Тогда
			Значение = ИсходноеЗначение;
		ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Структура") Тогда
			Значение = ИсходноеЗначение;
		ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Дата") Тогда
			Значение = ИсходноеЗначение;
		ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Строка") И ВРег(ИсходноеЗначение) = "NONE" Тогда
			Значение = ЗначениеПоУмолчанию;
		ИначеЕсли ТипЗначения = "" Тогда
			Значение = ИсходноеЗначение;
		ИначеЕсли ТипЗначения = "Дата" Тогда
			Значение = СтрокаВДату(ИсходноеЗначение);
		ИначеЕсли ТипЗначения = "Число" Тогда
			Значение = СтрокаВЧисло(ИсходноеЗначение);
		ИначеЕсли ТипЗначения = "ХранилищеЗначения" Тогда
			Значение = ХранилищеЗначенияИзJSON(ИсходноеЗначение);
		Иначе
			ТребуемыйТип = Новый ОписаниеТипов(ТипЗначения);
			Значение = ТребуемыйТип.ПривестиЗначение(ИсходноеЗначение);
		КонецЕсли;
		
		Если Значение = Неопределено Тогда
			Значение = ЗначениеПоУмолчанию;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

// Хранилище значения из JSON.
// 
// Параметры:
//  Значение - Строка - данные в формате json
// 
// Возвращаемое значение:
//  Строка, Произвольный - Хранилище значения из JSON
Функция ХранилищеЗначенияИзJSON(Знач Значение)
	
	Результат = "";
	Значение = СокрЛП(Значение);
	
	Если Значение <> "" Тогда
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(Значение);
		Попытка
			ЗначениеИзJSON = СериализаторXDTO.ПрочитатьJSON(ЧтениеJSON);
		Исключение
			Возврат Результат;
		КонецПопытки;
		
		ЧтениеJSON.Закрыть();
	
		Если ЗначениеЗаполнено(ЗначениеИзJSON) И ТипЗнч(ЗначениеИзJSON) = Тип("ХранилищеЗначения") Тогда
			Возврат ЗначениеИзJSON.Получить();
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти