Функция ПечатнаяФормаЗаявленияОПереключенииЛогинаИТС() Экспорт
	
	Организации = ОрганизацииДляПовторногоПодключения();
	
	ТабДокументОбщий = Новый ТабличныйДокумент;
	Макет = ПолучитьОбщийМакет("СервисСверкиРасчетовЗаявлениеОПереключенииЛогинаИТС");
	
	Инструкция = Макет.ПолучитьОбласть("ИнструкцияПечать");
	ТабДокументОбщий.Вывести(Инструкция);
	
	СтруктураЗаявлений = ДанныеЗаявления(Организации);
	
	Для каждого Заявление из СтруктураЗаявлений Цикл
		
		ТабДокумент = Новый ТабличныйДокумент;
		Шапка = Макет.ПолучитьОбласть("Заголовок");
		ТелоЗаявления = Макет.ПолучитьОбласть("ТелоЗаявления");
		ЗаполнитьЗначенияСвойств(ТелоЗаявления.Параметры, Заявление);
		
		ТабДокумент.АвтоМасштаб = Истина;
		
		ТабДокумент.Вывести(Шапка);
		ТабДокумент.Вывести(ТелоЗаявления);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Подпись");
		
		ДобавитьФаксимиле(Заявление,ОбластьМакета);
		
		ТабДокумент.Вывести(ОбластьМакета);
		
		ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		ТабДокументОбщий.Вывести(ТабДокумент);
	КонецЦикла;
	
	ПерваяСтрока = 1;
	
	ТабДокументОбщий.ОбластьПечати = ТабДокументОбщий.Область(
		ТабДокументОбщий.ПолеСверху,
		ПерваяСтрока,
		ТабДокументОбщий.ВысотаТаблицы,
		ТабДокументОбщий.ШиринаТаблицы);
	
	ТабДокументОбщий.АвтоМасштаб = Истина;
	
	Возврат ТабДокументОбщий
	
КонецФункции

