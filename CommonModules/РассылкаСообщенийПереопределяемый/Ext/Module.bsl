#Область ПрограммныйИнтерфейс

// Переопределяет данные заполнения нового элемента справочника
//
// Параметры:
//  ДанныеЗаполнения - Структура - см. Справочники.РассылкиСообщений.НовыйДанныеЗаполнения()
//  ПараметрыРассылки - Структура - см. РассылкаСообщений.НовыйПараметрыРассылки()
//  СпециальныеПараметрыРассылки - Структура - параметры, специфичные для конкретного вида рассылки.
//
Процедура ПередДобавлениемРассылки(ДанныеЗаполнения, ПараметрыРассылки, СпециальныеПараметрыРассылки = Неопределено) Экспорт

	Если ПараметрыРассылки.ВидРассылки = Перечисления.ВидыРассылокСообщений.ЗапросНаСверку Тогда
		РассылкаЗапросовНаСверку.ПередДобавлениемРассылки(ДанныеЗаполнения, ПараметрыРассылки, СпециальныеПараметрыРассылки);
	КонецЕсли;

КонецПроцедуры

