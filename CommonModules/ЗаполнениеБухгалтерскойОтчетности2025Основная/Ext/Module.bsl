Функция ПараметрыАлгоритмовБаланса2025(ПараметрыЗаполнения, ОбщиеИтогиПоСчетам)
	
	ПараметрыАлгоритмов = Новый Структура;
	ПараметрыАлгоритмов.Вставить("ЭтоБалансНекоммерческойОрганизации",
		ПараметрыЗаполнения.ЭтоБалансНекоммерческойОрганизации);
	ПараметрыАлгоритмов.Вставить("УчетНа70ВедетсяСводно", ПараметрыЗаполнения.УчетНа70ВедетсяСводно);
	ПараметрыАлгоритмов.Вставить("РазделятьАвансыПоВидамАктивов", ПараметрыЗаполнения.РазделятьАвансыПоВидамАктивов);
	ПараметрыАлгоритмов.Вставить("ПрименятьС2025", Год(ПривестиКДате(ПараметрыЗаполнения.КонецПериодаОтчета)) >= 2025);
	ПараметрыАлгоритмов.Вставить("НастройкаВключенаКлассифицироватьАктивыОбязательства", ПараметрыЗаполнения.НастройкаВключенаКлассифицироватьАктивыОбязательства);
	ПараметрыАлгоритмов.Вставить("КлассифицироватьАктивыОбязательстваПоСрокам",      ПараметрыЗаполнения.КлассифицироватьАктивыОбязательстваПоСрокам);
	Если ПараметрыЗаполнения.КлассифицироватьАктивыОбязательстваПоСрокам Тогда
		ПараметрыАлгоритмов.Вставить("ДебиторскаяЗадолженность",  ОбщиеИтогиПоСчетам.ДанныеЗаполненияДебиторскаяЗадолженность);
		ПараметрыАлгоритмов.Вставить("КредиторскаяЗадолженность", ОбщиеИтогиПоСчетам.ДанныеЗаполненияКредиторскаяЗадолженность);
		ПараметрыАлгоритмов.Вставить("РасчетыПоАренде",           ОбщиеИтогиПоСчетам.ДанныеЗаполненияРасчетыПоАренде);
		ПараметрыАлгоритмов.Вставить("ЗаемныеСредства",           ОбщиеИтогиПоСчетам.ДанныеЗаполненияЗаемныеСредства);
	КонецЕсли;
	
	Возврат ПараметрыАлгоритмов;
	
КонецФункции

Функция АлгоритмыБО2025Кв1_Баланс(ПараметрыАлгоритмов)
	
	Алгоритмы = Новый Массив;
	
	ЗаполнитьАлгоритмыБО2025Кв1_Баланс_Раздел1(Алгоритмы, ПараметрыАлгоритмов);
	ЗаполнитьАлгоритмыБО2025Кв1_Баланс_Раздел2(Алгоритмы, ПараметрыАлгоритмов);
	Если ПараметрыАлгоритмов.ЭтоБалансНекоммерческойОрганизации Тогда
		ЗаполнитьАлгоритмыБО2025Кв1_Баланс_Раздел3_НКО(Алгоритмы, ПараметрыАлгоритмов);
	Иначе
		ЗаполнитьАлгоритмыБО2025Кв1_Баланс_Раздел3(Алгоритмы, ПараметрыАлгоритмов);
	КонецЕсли;
	ЗаполнитьАлгоритмыБО2025Кв1_Баланс_Раздел4(Алгоритмы, ПараметрыАлгоритмов);
	ЗаполнитьАлгоритмыБО2025Кв1_Баланс_Раздел5(Алгоритмы, ПараметрыАлгоритмов);
	
	Возврат Алгоритмы;
	
