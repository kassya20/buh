Функция ДанныеЗаполненияДебиторскаяЗадолженность(МенеджерВременныхТаблиц, КонтекстРасчета)
	
	ВидЗадолженности = Перечисления.ВидыЗадолженности.Дебиторская;
	
	СчетаДебиторская = КлассификацияЗадолженности.СчетаРасчетовДебиторскаяЗадолженность();
	
	СчетаРасчетовДебиторскаяБезАвансов = ОбщегоНазначения.СкопироватьРекурсивно(СчетаДебиторская.СчетаРасчетов);
	
	СчетаУчетаАвансов = КлассификацияЗадолженности.СчетаУчетаАвансовВыданных();
	Для Каждого СчетАвансов Из СчетаУчетаАвансов Цикл
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(СчетаРасчетовДебиторскаяБезАвансов, СчетАвансов);
	КонецЦикла;

	СписокВидовСубконто = КлассификацияЗадолженности.СписокВидовСубконто();
	НаборыСчетов = КлассификацияЗадолженности.НаборыСчетовБаланса(ВидЗадолженности, СписокВидовСубконто);
	ТаблицаСчетов = КлассификацияЗадолженности.НовыйТаблицаСчетов();
	
	КлассификацияЗадолженности.ЗаполнитьНаборыСчетами(НаборыСчетов, СчетаДебиторская.СчетаРасчетов, ТаблицаСчетов);
	
	// дополним таблицу остальными счетами, которые отражены в балансе Дебиторской задолженности
	Счета = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Счета, СчетаДебиторская.СчетаРасчетовПоАренде);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Счета, СчетаДебиторская.СчетаУчетаРБП);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Счета, СчетаДебиторская.СчетаУчетаНМА);
	
	СчетаСРеквизитами = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Счета, "Код, Порядок, Вид");
	
	Для Каждого Счет Из Счета Цикл
		СтрокаТаблицы = ТаблицаСчетов.Добавить();
		СтрокаТаблицы.Счет = Счет;
		СтрокаТаблицы.Код = СчетаСРеквизитами[Счет].Код;
		СтрокаТаблицы.Порядок = СчетаСРеквизитами[Счет].Порядок;
		СтрокаТаблицы.ВидСчета = СчетаСРеквизитами[Счет].Вид;
	КонецЦикла;
	
	Группы = ГруппыДебиторскаяКраткосрочнаяЗадолженность();
	ОпределитьГруппуСчетов(ТаблицаСчетов, Группы);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапросаСводныеДанныеДебиторскаяЗадолженность(НаборыСчетов, КонтекстРасчета, ВидЗадолженности);
	Запрос.УстановитьПараметр("Организации",      КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("НачалоПериода",    НачалоМесяца(КонтекстРасчета.КонецПериодаДата));
	Запрос.УстановитьПараметр("КонецПериода",     Новый Граница(КонтекстРасчета.КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("КонецПериодаДата", КонецДня(КонтекстРасчета.КонецПериодаДата));
	Запрос.УстановитьПараметр("ДатаНачалаДолгосрочногоПериода", КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)) + 1);
	Запрос.УстановитьПараметр("ВидЗадолженности", ВидЗадолженности);
	Запрос.УстановитьПараметр("СчетаУчетаАвансов", СчетаУчетаАвансов);
	Запрос.УстановитьПараметр("СчетаУчетаРБП", СчетаДебиторская.СчетаУчетаРБП);
	Запрос.УстановитьПараметр("СчетаУчетаНМА", СчетаДебиторская.СчетаУчетаНМА);
	Запрос.УстановитьПараметр("СчетаРасчетовПоАренде", СчетаДебиторская.СчетаРасчетовПоАренде);
	Запрос.УстановитьПараметр("СчетаРасчетовДебиторская", СчетаДебиторская.СчетаРасчетов);
	Запрос.УстановитьПараметр("СчетаРасчетовДебиторскаяБезАвансов", СчетаРасчетовДебиторскаяБезАвансов);
	Запрос.УстановитьПараметр("ТаблицаСчетов", ТаблицаСчетов);
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор", ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	Запрос.УстановитьПараметр("ВидАктиваДебиторскаяЗадолженность", Перечисления.ВидыАктивовДляРБП.ДебиторскаяЗадолженность);
	Запрос.УстановитьПараметр("СчетаРезервов", БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам));
	Запрос.УстановитьПараметр("РазделятьАвансыПоВидамАктивов", КонтекстРасчета.РазделятьАвансыПоВидамАктивов);

	ИсключаемыеВидыАктиваАвансов = Новый Массив;
	Если КонтекстРасчета.РазделятьАвансыПоВидамАктивов Тогда
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.Запасы);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ИнвестиционнаяНедвижимость);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.НематериальныеАктивы);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ПрочиеВнеоборотные);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ОсновныеСредства);
		ИсключаемыеВидыАктиваАвансов.Добавить(Перечисления.ВидыАктивовДляАвансов.ПрочиеОборотные);
	КонецЕсли;
	Запрос.УстановитьПараметр("ИсключаемыеВидыАктиваАвансов", ИсключаемыеВидыАктиваАвансов);

	// Виды субконто
	Для Каждого ВидыСубконто Из СписокВидовСубконто Цикл
		Запрос.УстановитьПараметр(ВидыСубконто.Ключ, ВидыСубконто.Значение);
	КонецЦикла;
	
	// Наборы счетов
	Для Каждого Набор Из НаборыСчетов Цикл
		Запрос.УстановитьПараметр(Набор.ИмяНабора, Набор.СписокСчетов);
	КонецЦикла;
		
	Результат = Запрос.ВыполнитьПакет();
	ПоследнийИндекс = Результат.ВГраница();
	
	РасчетныеДанные = Новый Структура;
	РасчетныеДанные.Вставить("Задолженность", Результат[ПоследнийИндекс - 2]);
	РасчетныеДанные.Вставить("РасчетыПоАренде", Результат[ПоследнийИндекс - 1]);
	РасчетныеДанные.Вставить("НераспределенныеВеличины", Результат[ПоследнийИндекс].Выгрузить());

	ДанныеЗаполнения = НовыйДанныеЗаполненияЗадолженности();
	ДанныеЗаполнения.ГруппыКраткосрочная = Группы;
	ОпределитьСоставляющиеБалансаДебиторскаяЗадолженность(ДанныеЗаполнения, РасчетныеДанные, КонтекстРасчета);

	ОбщегоНазначенияБП.УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц);
	
	Возврат ДанныеЗаполнения;

КонецФункции

Функция ТекстЗапросаСводныеДанныеДебиторскаяЗадолженность(НаборыСчетов, КонтекстРасчета, ВидЗадолженности)
	
	ТекстыЗапросов = Новый Массив;
	// Остатки задолженности по счетам, которые участвуют в классификации задолженности по срокам погашения
	КонтекстЗапроса = КлассификацияЗадолженности.НовыйКонтекстЗапросаОстаткиЗадолженности();
	ТекстЗапросаОстатки = КлассификацияЗадолженности.ТекстЗапросаОстаткиЗадолженности(НаборыСчетов, КонтекстЗапроса, ВидЗадолженности);
	Если ЗначениеЗаполнено(ТекстЗапросаОстатки) Тогда
		ТекстыЗапросов.Добавить(ТекстЗапросаОстатки);
	КонецЕсли;
	
	ТекстРасчеты =
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация КАК Организация,
	|	ХозрасчетныйОстатки.Счет КАК Счет,
	|	СУММА(ХозрасчетныйОстатки.СуммаОстаток) КАК СуммаОстаток,
	|	ВЫБОР
	|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		КОГДА ХозрасчетныйОстатки.Субконто3 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РасходыБудущихПериодов.ПустаяСсылка)
	|	КОНЕЦ КАК СтатьяРБП
	|ПОМЕСТИТЬ ОстаткиРасходовБудущихПериодов
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаУчетаРБП), , Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ХозрасчетныйОстатки.Организация,
	|	ХозрасчетныйОстатки.Счет,
	|	ВЫБОР
	|		КОГДА ХозрасчетныйОстатки.Субконто1 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто1
	|		КОГДА ХозрасчетныйОстатки.Субконто2 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто2
	|		КОГДА ХозрасчетныйОстатки.Субконто3 ССЫЛКА Справочник.РасходыБудущихПериодов
	|			ТОГДА ХозрасчетныйОстатки.Субконто3
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РасходыБудущихПериодов.ПустаяСсылка)
	|	КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	СтатьяРБП
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	СУММА(Расчеты.ОстатокДт) КАК ОстатокБУ
	|ПОМЕСТИТЬ ДолгБУ
	|ИЗ
	|	Расчеты КАК Расчеты
	|
	|СГРУППИРОВАТЬ ПО
	|	Расчеты.Организация,
	|	Расчеты.Счет
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Авансы.Организация,
	|	Авансы.Счет,
	|	СУММА(Авансы.ОстатокДт)
	|ИЗ
	|	Авансы КАК Авансы
	|ГДЕ
	|	&ТекстРазделятьАвансыПоВидамАктивов
	|
	|СГРУППИРОВАТЬ ПО
	|	Авансы.Организация,
	|	Авансы.Счет
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	АвансыПоАренде.Организация,
	|	АвансыПоАренде.Счет,
	|	СУММА(АвансыПоАренде.ОстатокБУ)
	|ИЗ
	|	АвансыПоАренде КАК АвансыПоАренде
	|
	|СГРУППИРОВАТЬ ПО
	|	АвансыПоАренде.Организация,
	|	АвансыПоАренде.Счет
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОстаткиРасходовБудущихПериодов.Организация,
	|	ОстаткиРасходовБудущихПериодов.Счет,
	|	СУММА(ОстаткиРасходовБудущихПериодов.СуммаОстаток)
	|ИЗ
	|	ОстаткиРасходовБудущихПериодов КАК ОстаткиРасходовБудущихПериодов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РасходыБудущихПериодов КАК СтатьиРБП
	|		ПО ОстаткиРасходовБудущихПериодов.СтатьяРБП = СтатьиРБП.Ссылка
	|ГДЕ
	|	СтатьиРБП.ВидАктива = &ВидАктиваДебиторскаяЗадолженность
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиРасходовБудущихПериодов.Организация,
	|	ОстаткиРасходовБудущихПериодов.Счет
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Организация,
	|	ХозрасчетныйОстатки.Счет,
	|	СУММА(ХозрасчетныйОстатки.СуммаОстаток)
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаУчетаНМА), , Организация В (&Организации)) КАК ХозрасчетныйОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ХозрасчетныйОстатки.Организация,
	|	ХозрасчетныйОстатки.Счет";
	
	Если КонтекстРасчета.РазделятьАвансыПоВидамАктивов Тогда
		ТекстРасчеты = СтрЗаменить(ТекстРасчеты, "&ТекстРазделятьАвансыПоВидамАктивов", "НЕ Авансы.Субконто2.ВидАктива В (&ИсключаемыеВидыАктиваАвансов)");
	Иначе
		ТекстРасчеты = СтрЗаменить(ТекстРасчеты, "&ТекстРазделятьАвансыПоВидамАктивов", "ИСТИНА");
	КонецЕсли;
	ТекстыЗапросов.Добавить(ТекстРасчеты);
	
	ТекстКлассификация =
	"ВЫБРАТЬ
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация КАК Организация,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет КАК Счет,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ДатаПогашения >= &ДатаНачалаДолгосрочногоПериода КАК Долгосрочный,
	|	СУММА(КлассификацияПоСрокамОтдельныхВидовЗадолженности.ОстатокДолга) КАК ОстатокДолга,
	|	СУММА(КлассификацияПоСрокамОтдельныхВидовЗадолженности.РезервПоСомнительнымДолгам) КАК РезервПоСомнительнымДолгам,
	|	СУММА(КлассификацияПоСрокамОтдельныхВидовЗадолженности.НДСАвансов) КАК НДСАвансов
	|ПОМЕСТИТЬ КлассификацияЗадолженности
	|ИЗ
	|	РегистрСведений.КлассификацияПоСрокамОтдельныхВидовЗадолженности КАК КлассификацияПоСрокамОтдельныхВидовЗадолженности
	|ГДЕ
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Активность
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация В(&Организации)
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.ПериодРасчета МЕЖДУ &НачалоПериода И &КонецПериодаДата
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет В (&СчетаРасчетовДебиторскаяБезАвансов, &СчетаРасчетовПоАренде)
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.ВидЗадолженности = &ВидЗадолженности
	|
	|СГРУППИРОВАТЬ ПО
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ДатаПогашения >= &ДатаНачалаДолгосрочногоПериода
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ДатаПогашения >= &ДатаНачалаДолгосрочногоПериода,
	|	СУММА(КлассификацияПоСрокамОтдельныхВидовЗадолженности.ОстатокДолга),
	|	СУММА(КлассификацияПоСрокамОтдельныхВидовЗадолженности.РезервПоСомнительнымДолгам),
	|	СУММА(КлассификацияПоСрокамОтдельныхВидовЗадолженности.НДСАвансов)
	|ИЗ
	|	РегистрСведений.КлассификацияПоСрокамОтдельныхВидовЗадолженности КАК КлассификацияПоСрокамОтдельныхВидовЗадолженности
	|ГДЕ
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Активность
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация В(&Организации)
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.ПериодРасчета МЕЖДУ &НачалоПериода И &КонецПериодаДата
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет В(&СчетаУчетаАвансов)
	|	И КлассификацияПоСрокамОтдельныхВидовЗадолженности.ВидЗадолженности = &ВидЗадолженности
	|	И &ТекстРазделятьАвансыПоВидамАктивов
	|
	|СГРУППИРОВАТЬ ПО
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет,
	|	КлассификацияПоСрокамОтдельныхВидовЗадолженности.ДатаПогашения >= &ДатаНачалаДолгосрочногоПериода
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Организация,
	|	КлассификацияПоСрокамРасходовБудущихПериодов.Счет,
	|	ИСТИНА,
	|	СУММА(КлассификацияПоСрокамРасходовБудущихПериодов.СуммаДолгосрочная),
	|	СУММА(0),
	|	СУММА(0)
	|ИЗ
	|	РегистрСведений.КлассификацияПоСрокамРасходовБудущихПериодов КАК КлассификацияПоСрокамРасходовБудущихПериодов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РасходыБудущихПериодов КАК СправочникРасходыБудущихПериодов
	|		ПО (ВЫБОР
	|				КОГДА КлассификацияПоСрокамРасходовБудущихПериодов.Субконто1 ССЫЛКА Справочник.РасходыБудущихПериодов
