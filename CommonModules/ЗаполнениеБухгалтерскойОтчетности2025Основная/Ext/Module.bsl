		АлгоритмДопСтроки.Составляющие.Добавить(Составляющая("+ СККР_КонтрагентыДоговоры 76.К"));
		АлгоритмДопСтроки.Составляющие.Добавить(Составляющая("+ СКК 76.Н"));
		
		АлгоритмДопСтроки = ДобавитьНовыйАлгоритмСтроки(АлгоритмСтроки.ДопСтроки, "15212",
			"Доходы, полученные в счет будущих периодов");
		АлгоритмДопСтроки.Составляющие.Добавить(Составляющая("+ СКК 98.01"));
		
		Если НЕ ЭтоБалансНекоммерческойОрганизации Тогда
			АлгоритмДопСтроки = ДобавитьНовыйАлгоритмСтроки(АлгоритмСтроки.ДопСтроки, "15213",
				"Целевое финансирование");
			АлгоритмДопСтроки.Составляющие.Добавить(Составляющая("+ СКК 86"));
		КонецЕсли;

		АлгоритмСтроки = ДобавитьНовыйАлгоритмСтроки(Алгоритмы, "1520",
			"Обязательство по аренде");
		АлгоритмСтроки.Вписываемый = Истина;
		АлгоритмСтроки.ГрафаНаименования = "02";
		
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СКК 76.07", "НастройкиОтчетаКонтрагентыДоговоры"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СКК 76.27", "НастройкиОтчетаКонтрагентыДоговоры"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СКК 76.37", "НастройкиОтчетаКонтрагентыДоговоры"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("- СКД 76.07", "НастройкиОтчетаКонтрагентыДоговоры"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("- СКД 76.27", "НастройкиОтчетаКонтрагентыДоговоры"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("- СКД 76.37", "НастройкиОтчетаКонтрагентыДоговоры"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СК_РасчетыПоАренде НДСсПлатежей"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СК_РасчетыПоАренде Авансы"));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("- СК_РасчетыПоАренде Долгосрочное"));
	КонецЕсли;
	
	#КонецОбласти
	
	#Область Строка1540
	
	АлгоритмСтроки = ДобавитьНовыйАлгоритмСтроки(Алгоритмы, "1540",
		"Оценочные обязательства");
	
	АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СКК 96.01"));
	
	#КонецОбласти
	
	#Область Строка1550
	
	АлгоритмСтроки = ДобавитьНовыйАлгоритмСтроки(Алгоритмы, "1550",	"Другие краткосрочные обязательства"); // Для упрощенной отчетности
	
	#КонецОбласти
	
КонецПроцедуры

Процедура ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_БалансПоГрафеПоАлгоритмам(ПараметрыЗаполнения, ЗначенияПоказателейПоВсемОрганизациям)
	
	Графа = ПараметрыЗаполнения.Графа;
	ЗаголовокГрафы = ПараметрыЗаполнения.ЗаголовокГрафы;
	
	Контейнер = ПараметрыЗаполнения.Контейнер;
	КонтейнерРаздела = Контейнер.Строки.Найти("Баланс", "Идентификатор");
	
	ПроцессорПоказателя = ПараметрыЗаполнения.ПроцессорПоказателя;
	Алгоритмы = ПараметрыЗаполнения.Алгоритмы;

	Если ПараметрыЗаполнения.ЭтоУпрощеннаяОтчетность Тогда
		ЗначенияПоказателей = УпроститьБаланс(Алгоритмы, ЗначенияПоказателейПоВсемОрганизациям, ПараметрыЗаполнения);
		ЗначенияПоказателейПоВсемОрганизациям = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ЗначенияПоказателей);
	КонецЕсли;
	
	Для Каждого ЗначенияПоказателей Из ЗначенияПоказателейПоВсемОрганизациям Цикл
		Для Каждого АлгоритмСтроки Из Алгоритмы Цикл
			
			НомерСтроки = АлгоритмСтроки.Номер;
			
			Если Не НачатьУстановкуЗначенияПоказателя(ПроцессорПоказателя, ЗначенияПоказателей, АлгоритмСтроки) Тогда
				Продолжить;
			КонецЕсли;
			
			ИнициализироватьКодПоказателя(ПроцессорПоказателя, НомерСтроки, Графа, АлгоритмСтроки.Вписываемый);
			
			НаименованиеСтроки = АлгоритмСтроки.Наименование;
			Если ЗначениеЗаполнено(ПроцессорПоказателя.Показатель.НаименованиеПоказателя) Тогда
				НаименованиеСтроки = ПроцессорПоказателя.Показатель.НаименованиеПоказателя;
			КонецЕсли;
			
			ПроцессорПоказателя.Показатель.НаименованиеПоказателя = СтрШаблон("Строка %1 ""%2"", графа ""%3""",
				НомерСтроки, НаименованиеСтроки, ЗаголовокГрафы);
			УстановитьНаименованиеПоказателяРасшифровки(ПроцессорПоказателя.Показатель);
			УстановитьЗначениеПоказателяПоПроцессору(КонтейнерРаздела, ПроцессорПоказателя, АлгоритмСтроки);
			Если АлгоритмСтроки.Вписываемый Тогда
				УстановитьНаименованиеВписываемогоПоказателя(КонтейнерРаздела, АлгоритмСтроки);
			КонецЕсли;
			
			Если АлгоритмСтроки.Свойство("ДопСтроки") Тогда
				
				НомерСтроки = АлгоритмСтроки.Номер;
				ПроцессорПоказателя.Показатель.КодПоказателя = "П100010" + НомерСтроки + Графа;
				
				ИдМСЧ = "П100010" + НомерСтроки;
				
				ОбъявлениеМСЧ = МногострочнаяЧастьРаздела(КонтейнерРаздела, ИдМСЧ);
				
				Если ОбъявлениеМСЧ = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				АктивныеДопСтроки = Новый Массив;
				Для ИндексСтроки = 0 По АлгоритмСтроки.ДопСтроки.ВГраница() Цикл
					ДопСтрокаАлгоритма = АлгоритмСтроки.ДопСтроки[ИндексСтроки];
					
					Если Не НачатьУстановкуЗначенияПоказателя(ПроцессорПоказателя, ЗначенияПоказателей, ДопСтрокаАлгоритма, ИндексСтроки) Тогда
						Продолжить;
					КонецЕсли;
					
					АктивныеДопСтроки.Добавить(ИндексСтроки);
					
				КонецЦикла;
					
				СтрокиМСЧ = СтрокиМногострочнойЧасти(ОбъявлениеМСЧ);
				ШаблонСтрокиМСЧ = СтрокиМСЧ[0]; 
				
				Для Инд = 1 По АктивныеДопСтроки.Количество() - СтрокиМСЧ.Количество() Цикл
					СкопироватьВеткуДерева(ШаблонСтрокиМСЧ);
				КонецЦикла;
				
				СтрокиМСЧ = СтрокиМногострочнойЧасти(ОбъявлениеМСЧ); // актуальный набор строк многострочной части
				
				Для ИндексСтроки = 0 По АктивныеДопСтроки.ВГраница() Цикл
					
					ПостоянныйИдентификаторДопСтроки = АктивныеДопСтроки[ИндексСтроки]; 
					
					ДопСтрокаАлгоритма = АлгоритмСтроки.ДопСтроки[ПостоянныйИдентификаторДопСтроки];
					СтрокаМСЧ = СтрокиМСЧ[ИндексСтроки];

					Если Не НачатьУстановкуЗначенияПоказателя(ПроцессорПоказателя, ЗначенияПоказателей, ДопСтрокаАлгоритма, ПостоянныйИдентификаторДопСтроки) Тогда
						Продолжить;
					КонецЕсли;
					
					НаименованиеСтроки = ДопСтрокаАлгоритма.Наименование;
					ПроцессорПоказателя.Показатель.НаименованиеПоказателя = НаименованиеСтроки;
					
					УстановитьНаименованиеПоказателяРасшифровки(ПроцессорПоказателя.Показатель);
					УстановитьЗначениеПоказателяПоПроцессору(СтрокаМСЧ, ПроцессорПоказателя, АлгоритмСтроки);
					
					// Установка наименования строки "в том числе".
					ИмяПоказателя = "П100010" + НомерСтроки + "02";
					
					ПараметрыПоискаПоказателя = Новый Структура("Тип, Идентификатор", "Показатель", ИмяПоказателя);
					СтрокиПоказателей = СтрокаМСЧ.Строки.НайтиСтроки(ПараметрыПоискаПоказателя);
					СтрокаПоказателя = СтрокиПоказателей[0];
					СтрокаПоказателя.Данные = НаименованиеСтроки;
					
				КонецЦикла;
				
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция РассчитатьПоказателиБаланс(ПроцессорПоказателя, Алгоритмы)

	ЗначенияПоказателей = НовыйЗначенияПоказателей();
	
	Для Каждого АлгоритмСтроки Из Алгоритмы Цикл
		
		ИнициализироватьПоказатель(ПроцессорПоказателя);

		РассчитатьПоказательБаланс(ЗначенияПоказателей, ПроцессорПоказателя, АлгоритмСтроки);
		
		Если АлгоритмСтроки.Свойство("ДопСтроки") Тогда
			
			Для ИндексСтроки = 0 По АлгоритмСтроки.ДопСтроки.ВГраница() Цикл
				ДопСтрокаАлгоритма = АлгоритмСтроки.ДопСтроки[ИндексСтроки];
				
				ПроцессорПоказателя.Показатель.ЗначениеПоказателя = 0;
				ПроцессорПоказателя.Показатель.Расшифровка = Новый Массив;
				
				РассчитатьПоказательБаланс(ЗначенияПоказателей, ПроцессорПоказателя, ДопСтрокаАлгоритма, ИндексСтроки);
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ЗначенияПоказателей;
	
КонецФункции

Процедура РассчитатьПоказательБаланс(ЗначенияПоказателей, ПроцессорПоказателя, АлгоритмСтроки, ИндексСтроки = Неопределено)
	
	Для Каждого Составляющая Из АлгоритмСтроки.Составляющие Цикл
		ОписаниеСоставлящей = Составляющая[0];
		ДопПараметры = Составляющая[1];
		УчестьСоставляющую(ПроцессорПоказателя, ОписаниеСоставлящей, ДопПараметры);
	КонецЦикла;

	ЗначениеПоказателя = ЗначенияПоказателей.Добавить();
	ЗначениеПоказателя.Организация = ПроцессорПоказателя.Организация;
	ЗаполнитьЗначенияСвойств(ЗначениеПоказателя, ПроцессорПоказателя.Показатель);
	Если ИндексСтроки = Неопределено Тогда
		// ФСБУ 4 предусматривает коды только для показателей верхнего уровня (групп показателей)
		ЗначениеПоказателя.КодПоказателя = АлгоритмСтроки.Номер;
	КонецЕсли;  
	ЗначениеПоказателя.Идентификатор = ИдентификаторЗначенияПоказателя(
		АлгоритмСтроки.Номер,
		АлгоритмСтроки.Вписываемый,
		АлгоритмСтроки.Наименование,
		ИндексСтроки);
	ЗначениеПоказателя.Наименование  = АлгоритмСтроки.Наименование;
	
КонецПроцедуры

Функция НачатьУстановкуЗначенияПоказателя(ПроцессорПоказателя, ЗначенияПоказателей, АлгоритмСтроки, ИндексСтроки = Неопределено)
	
	Идентификатор = ИдентификаторЗначенияПоказателя(
		АлгоритмСтроки.Номер,
		АлгоритмСтроки.Вписываемый,
		АлгоритмСтроки.Наименование,
		ИндексСтроки);
	ЗначенияПоказателя = ЗначенияПоказателей.Найти(Идентификатор, "Идентификатор");
	Если ЗначенияПоказателя = Неопределено Тогда
		ПроцессорПоказателя.Показатель.ЗначениеПоказателя = 0;
		ПроцессорПоказателя.Показатель.Расшифровка = Новый Массив;
		Возврат Ложь;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ПроцессорПоказателя.Показатель, ЗначенияПоказателя, "ЗначениеПоказателя, НаименованиеПоказателя, Расшифровка");
	
	Возврат Истина;
	
КонецФункции

Процедура УстановитьНаименованиеПоказателяРасшифровки(Показатель)
	
	Если Не ЗначениеЗаполнено(Показатель.Расшифровка) Тогда
		Возврат;
	КонецЕсли;
	
	Показатель.Расшифровка[0].НаименованиеПоказателя = Показатель.НаименованиеПоказателя;
	Для ИндексРасшифровки = 1 По Показатель.Расшифровка.ВГраница() Цикл
		Показатель.Расшифровка[ИндексРасшифровки].НаименованиеПоказателя = "";
	КонецЦикла; 
	
КонецПроцедуры

Функция ИдентификаторЗначенияПоказателя(НомерСтроки, Вписываемый = Ложь, НаименованиеВписываемогоПоказателя = "", ИндексСтроки = Неопределено)

	ЭлементыИдентификатора = Новый Массив;
	ЭлементыИдентификатора.Добавить(НомерСтроки);
	Если Вписываемый Тогда
		ЭлементыИдентификатора.Добавить(НаименованиеВписываемогоПоказателя);
	КонецЕсли;
	Если ИндексСтроки <> Неопределено Тогда
		ЭлементыИдентификатора.Добавить(ИндексСтроки);
	КонецЕсли;
	
	Возврат СтрСоединить(ЭлементыИдентификатора, "_");
	
КонецФункции

Функция УпроститьБаланс(Алгоритмы, ЗначенияПоказателейПоВсемОрганизациям, ПараметрыЗаполнения)
	
	// См. также ЗаполнениеБухгалтерскойОтчетностиНастраиваемая.НастроитьЗаполняемыеПоказателиУпрощенногоОтчета (и всю область УпрощеннаяОтчетность)
	
	ПоказателиУпрощеннойОтчетности = ПараметрыЗаполнения.ПоказателиУпрощеннойОтчетности;
	
	ЗначенияПоказателей = НовыйЗначенияПоказателей();
	ЗначенияПоказателей.Индексы.Добавить("КодПоказателя, Идентификатор, Наименование");
	
	Отбор = Новый Структура("КодПоказателя, Идентификатор, Наименование");
	Для Каждого ЗначениеПоказателейПоОрганизации Из ЗначенияПоказателейПоВсемОрганизациям Цикл
		Для Каждого ЗначениеПоказателя Из ЗначениеПоказателейПоОрганизации Цикл
			ЗаполнитьЗначенияСвойств(Отбор, ЗначениеПоказателя);
			НайденныеСтроки = ЗначенияПоказателей.НайтиСтроки(Отбор);
			Если НайденныеСтроки.Количество() = 0 Тогда
				ЗаполнитьЗначенияСвойств(ЗначенияПоказателей.Добавить(), ЗначениеПоказателя);
				Продолжить;
			КонецЕсли;
			НайденнаяСтрока = НайденныеСтроки[0];
			НайденнаяСтрока.ЗначениеПоказателя = НайденнаяСтрока.ЗначениеПоказателя + ЗначениеПоказателя.ЗначениеПоказателя;
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НайденнаяСтрока.Расшифровка, ЗначениеПоказателя.Расшифровка)
		КонецЦикла
	КонецЦикла;
	
	ВычитаемыеАлгоритмы = ВычитаемыеАлгоритмы(Алгоритмы);
	
	// Удалим все значения детализирующих показателей.
	КоличествоСтрок = ЗначенияПоказателей.Количество();
	Для НомерСКонца = 1 По КоличествоСтрок Цикл
		ИндексЗначения = КоличествоСтрок - НомерСКонца;
		ЗначениеПоказателя = ЗначенияПоказателей[ИндексЗначения];
		Если Не ЗначениеЗаполнено(ЗначениеПоказателя.КодПоказателя) Тогда
			ЗначенияПоказателей.Удалить(ЗначениеПоказателя);
		КонецЕсли;
	КонецЦикла;
	
	// Составим индекс оставшихся значений
	ИндексЗначенияПоказателей = Новый Соответствие; // Ключ - код строки, Значение - Массив из элементов ЗначенияПоказателей
	Для Каждого ЗначениеПоказателя Из ЗначенияПоказателей Цикл
		ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(ИндексЗначенияПоказателей, ЗначениеПоказателя.КодПоказателя, ЗначениеПоказателя);
	КонецЦикла;
	
	// Составим индекс алгоритмов
	ИндексАлгоритмов = Новый Соответствие; // Ключ - номер показателя; Значение - массив записей из Алгоритмы
	Для Каждого Алгоритм Из Алгоритмы Цикл
		ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(ИндексАлгоритмов, Алгоритм.Номер, Алгоритм);
	КонецЦикла;
	
	ИндексЗначенияПоказателейПоИдентификаторам = Неопределено; // Соответствие (Ключ - идентификатор, Значение - Массив из элементов ЗначенияПоказателей), инцииализируется при первом обращении
	
	// Обобщим показатели
	СхемаСокращения = ЗаполнениеБухгалтерскойОтчетностиУпрощенная.СхемаСокращенияУпрощеннойОтчетности("Баланс", ПараметрыЗаполнения.ЭтоБалансНекоммерческойОрганизации);
	
	НомерРаскрывающегоПоказателя = 99900; // выдаем из диапазона, заведомо не пересекающегося с кодами показателей, установленными Минфином
	
	КодыСтрокНесущественныхПоказателей = БухгалтерскаяОтчетностьБРО.КодыСтрокНесущественныхПоказателей();
	
	Для Каждого СхемаГруппыПоказателей Из СхемаСокращения Цикл
		
		КодОбобщенногоПоказателя = СхемаГруппыПоказателей.Значение[СхемаГруппыПоказателей.Значение.ВГраница()];
		
		АлгоритмыОбобщенногоПоказателя = ИндексАлгоритмов[КодОбобщенногоПоказателя];
		Если Не ЗначениеЗаполнено(АлгоритмыОбобщенногоПоказателя) Тогда
			АлгоритмОбобщенногоПоказателя = ДобавитьНовыйАлгоритмСтроки(Алгоритмы, КодОбобщенногоПоказателя, СхемаГруппыПоказателей.Представление);
			ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(ИндексАлгоритмов, КодОбобщенногоПоказателя, АлгоритмОбобщенногоПоказателя);
			АлгоритмыОбобщенногоПоказателя = ИндексАлгоритмов[КодОбобщенногоПоказателя];
		КонецЕсли;
		
		АлгоритмОбобщенногоПоказателя = АлгоритмыОбобщенногоПоказателя[0];
		АлгоритмОбобщенногоПоказателя.Наименование = СхемаГруппыПоказателей.Представление;
		
		Если Не АлгоритмОбобщенногоПоказателя.Свойство("ДопСтроки") Тогда
			ЗаполнениеБухгалтерскойОтчетностиОсновная.ДополнитьАлгоритмСтрокиДопСтроками(АлгоритмОбобщенногоПоказателя, НомерРаскрывающегоПоказателя);
		КонецЕсли;
		
		ЗначенияПоКодуОбобщенногоПоказателя = ИндексЗначенияПоказателей[КодОбобщенногоПоказателя];
		Если Не ЗначениеЗаполнено(ЗначенияПоКодуОбобщенногоПоказателя) Тогда
			
			ЗначенияОбобщенногоПоказателя = ЗначенияПоказателей.Добавить();
			ЗначенияОбобщенногоПоказателя.КодПоказателя = КодОбобщенногоПоказателя;
			ЗначенияОбобщенногоПоказателя.Идентификатор = ИдентификаторЗначенияПоказателя(
				АлгоритмОбобщенногоПоказателя.Номер,
				АлгоритмОбобщенногоПоказателя.Вписываемый,
				АлгоритмОбобщенногоПоказателя.Наименование);
			ЗначенияОбобщенногоПоказателя.Наименование           = АлгоритмОбобщенногоПоказателя.Наименование;
			ЗначенияОбобщенногоПоказателя.НаименованиеПоказателя = АлгоритмОбобщенногоПоказателя.Наименование;
			
			ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(ИндексЗначенияПоказателей, КодОбобщенногоПоказателя, ЗначенияОбобщенногоПоказателя);
			ЗначенияПоКодуОбобщенногоПоказателя = ИндексЗначенияПоказателей[КодОбобщенногоПоказателя];
			
		КонецЕсли;
		ЗначенияОбобщенногоПоказателя = ЗначенияПоКодуОбобщенногоПоказателя[0];
		
		ОбобщаемыеЗначения = Новый Массив;
		Для Каждого КодПоказателя Из СхемаГруппыПоказателей.Значение Цикл
			ЗначенияПоказателейПоКоду = ИндексЗначенияПоказателей[КодПоказателя];
			Если ЗначенияПоказателейПоКоду = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ОбобщаемыеЗначения, ЗначенияПоказателейПоКоду);
		КонецЦикла;
		
		Если ОбобщаемыеЗначения.Количество() < 2 Тогда
			// Нечего обобщать
			Продолжить;
		КонецЕсли;
		
		// Рассчитаем значение обобщенного показателя, суммировав все, входящие в его состав
		ЗначениеОбобщенногоПоказателя = 0;
		Для Каждого ЗначениеПоказателя Из ОбобщаемыеЗначения Цикл
			СуммируемоеЗначение = ЗначениеПоказателя.ЗначениеПоказателя;
			Если ВычитаемыеАлгоритмы[ЗначениеПоказателя.Идентификатор] = Истина Тогда
				СуммируемоеЗначение = - СуммируемоеЗначение;
			КонецЕсли;
			ЗначениеОбобщенногоПоказателя = ЗначениеОбобщенногоПоказателя + СуммируемоеЗначение;
		КонецЦикла;
		
		// Выберем из сокращаемых показателей наибольший (раскрывающий)
		// Такой выбор делаем только один раз: для отчетного периода, или наиболее позднего, в котором есть значение обобщенного
		ЗначениеЗаполненияИсточник = Неопределено; // т.е. значение заполнения выбранной для раскрытия сокращаемой группы
		ЗначениеРаскрывающегоПоказателя = 0;
		
		КодСтрокиРаскрывающегоПоказателя = ПоказателиУпрощеннойОтчетности[КодОбобщенногоПоказателя];
		Если КодСтрокиРаскрывающегоПоказателя <> Неопределено Тогда
			
			Если ИндексЗначенияПоказателейПоИдентификаторам = Неопределено Тогда
				ИндексЗначенияПоказателейПоИдентификаторам = Новый Соответствие;
				Для Каждого ЗначениеПоказателя Из ЗначенияПоказателей Цикл
					ОбщегоНазначенияБПКлиентСервер.ДополнитьРазделенныйМассив(
						ИндексЗначенияПоказателейПоИдентификаторам,
						ЗначениеПоказателя.Идентификатор,
						ЗначениеПоказателя);
				КонецЦикла;
			КонецЕсли;
			
			ГруппаПоказателей = ИндексЗначенияПоказателейПоИдентификаторам[КодСтрокиРаскрывающегоПоказателя];
			Если ЗначениеЗаполнено(ГруппаПоказателей) Тогда
				ЗначениеЗаполненияИсточник = ГруппаПоказателей[0];
				ЗначениеРаскрывающегоПоказателя = ЗначениеЗаполненияИсточник.ЗначениеПоказателя;
			КонецЕсли;
			
		Иначе
			
			ЗнакОбобщенногоПоказателя = ОбщегоНазначенияБПКлиентСервер.ЗнакЧисла(ЗначениеОбобщенногоПоказателя);
			
			Если ЗнакОбобщенногоПоказателя <> 0 Тогда
				
				Для Каждого ЗначенияРаскрывающегоПоказателя Из ОбобщаемыеЗначения Цикл
					ЗнакРаскрывающегоПоказателя = ОбщегоНазначенияБПКлиентСервер.ЗнакЧисла(ЗначенияРаскрывающегоПоказателя.ЗначениеПоказателя); 
					Если ЗнакРаскрывающегоПоказателя <> ЗнакОбобщенногоПоказателя Тогда
						Продолжить;
					КонецЕсли;
					Если (ЗнакОбобщенногоПоказателя > 0 И ЗначенияРаскрывающегоПоказателя.ЗначениеПоказателя > ЗначениеРаскрывающегоПоказателя)
						Или (ЗнакОбобщенногоПоказателя < 0 И ЗначенияРаскрывающегоПоказателя.ЗначениеПоказателя < ЗначениеРаскрывающегоПоказателя) Тогда
						ЗначениеЗаполненияИсточник = ЗначенияРаскрывающегоПоказателя;
						ЗначениеРаскрывающегоПоказателя = ЗначенияРаскрывающегоПоказателя.ЗначениеПоказателя;
					КонецЕсли;
				КонецЦикла;
				
			КонецЕсли;
			
			Если ЗначениеЗаполненияИсточник <> Неопределено Тогда
				ПоказателиУпрощеннойОтчетности.Вставить(КодОбобщенногоПоказателя, ЗначениеЗаполненияИсточник.Идентификатор);
			КонецЕсли;
			
		КонецЕсли;
		
		// Если он не совпадает по наименованию с обобщенным, добавим раскрывающий показатель для вывода
		Если ЗначениеЗаполненияИсточник <> Неопределено 
			И (КодыСтрокНесущественныхПоказателей[ЗначениеЗаполненияИсточник.КодПоказателя] = Истина
			Или ЗначениеЗаполненияИсточник.Наименование = СхемаГруппыПоказателей.Представление) Тогда
			// Вывод такого показателя не несет информации
			ЗначениеЗаполненияИсточник = Неопределено;
		КонецЕсли;
		
		Если ЗначениеЗаполненияИсточник <> Неопределено Тогда
			
			НомерРаскрывающегоПоказателя = НомерРаскрывающегоПоказателя + 1;
			КодДопСтроки = XMLСтрока(НомерРаскрывающегоПоказателя);
			
			АлгоритмДопСтроки = ДобавитьНовыйАлгоритмСтроки(
				АлгоритмОбобщенногоПоказателя.ДопСтроки,
				КодДопСтроки,
				ЗначениеЗаполненияИсточник.Наименование);
				
			ИндексДопСтроки = АлгоритмОбобщенногоПоказателя.ДопСтроки.ВГраница();
			
			ЗначениеПоказателя = ЗначенияПоказателей.Добавить();
			ЗначениеПоказателя.ЗначениеПоказателя = ЗначениеРаскрывающегоПоказателя;
			ЗначениеПоказателя.Идентификатор = ИдентификаторЗначенияПоказателя(
				АлгоритмДопСтроки.Номер,
				АлгоритмДопСтроки.Вписываемый,
				АлгоритмДопСтроки.Наименование,
				ИндексДопСтроки);
			ЗначениеПоказателя.Наименование = АлгоритмДопСтроки.Наименование;
			
			ДополнитьРасшифровку(ЗначениеПоказателя, ЗначениеЗаполненияИсточник, ВычитаемыеАлгоритмы, Истина);
			
		КонецЕсли;
		
		// Перенесем в обобщенный показатель сведения о сокращаемых показателях
		ЗначенияОбобщенногоПоказателя.ЗначениеПоказателя = ЗначениеОбобщенногоПоказателя;
		Для Каждого ЗначенияСокращаемогоПоказателя Из ОбобщаемыеЗначения Цикл
			Если ЗначенияСокращаемогоПоказателя = ЗначенияОбобщенногоПоказателя Тогда
				Продолжить;
			КонецЕсли;
			ДополнитьРасшифровку(ЗначенияОбобщенногоПоказателя, ЗначенияСокращаемогоПоказателя, ВычитаемыеАлгоритмы);
			ЗначенияПоказателей.Удалить(ЗначенияСокращаемогоПоказателя);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ЗначенияПоказателей;
	
КонецФункции

Процедура ДополнитьРасшифровку(Приемник, Источник, ВычитаемыеАлгоритмы, ОтвязатьПервуюСтроку = Ложь)
	
	// Недостаточно скопировать ссылки на расшифровку, так как
	// а. первая строка расшифровки хранит заголовок, который устанавливается позже, при заполнении контейнера
	// б. для удобства разработчика расшифровки хранятся с потерей знака (см. ВычитаемыеАлгоритмы),
	//    соответственно расшифровки разных показателей при суммировании могут требовать уточнения знака
	
	Если ВычитаемыеАлгоритмы[Источник.Идентификатор] = Истина Тогда
		Для Каждого ЭлементРасшифровкиИсточник Из Источник.Расшифровка Цикл
			ЭлементРасшифровкиПриемник = ОбщегоНазначения.СкопироватьРекурсивно(ЭлементРасшифровкиИсточник);
			ЭлементРасшифровкиПриемник.Сумма = - ЭлементРасшифровкиПриемник.Сумма;
			Если ЭлементРасшифровкиПриемник.ЗнакОперации = "+" Тогда
				ЭлементРасшифровкиПриемник.ЗнакОперации = "-";
			ИначеЕсли ЭлементРасшифровкиПриемник.ЗнакОперации = "-" Тогда
				ЭлементРасшифровкиПриемник.ЗнакОперации = "+";
			КонецЕсли;
			Приемник.Расшифровка.Добавить(ЭлементРасшифровкиПриемник);
		КонецЦикла;
	Иначе
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Приемник.Расшифровка, Источник.Расшифровка);
		Если ОтвязатьПервуюСтроку И ЗначениеЗаполнено(Приемник.Расшифровка) Тогда
			Приемник.Расшифровка[0] = ОбщегоНазначения.СкопироватьРекурсивно(Приемник.Расшифровка[0]);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Функция ВычитаемыеАлгоритмы(Алгоритмы)
	
	// Для удобства разработчика значения, уменьшающие валюту баланса, могут храниться
	// положительными числами (другими словами - с инвертированным знаком).
	// Таким образом, только по значению нельзя определить, уменьшает оно валюту баланса или нет -
	// нужно обращаться к свойствам соответствующего алгоритма.
	
	ВычитаемыеАлгоритмы = Новый Соответствие; // Ключ - идентификатор алгоритма, Значение - Истина
	
	Для Каждого Алгоритм Из Алгоритмы Цикл
		
		ДобавитьВычитаемыйАлгоритм(ВычитаемыеАлгоритмы, Алгоритм);
		
		Если Алгоритм.Свойство("ДопСтроки") Тогда
			Для Каждого ВложенныйАлгоритм Из Алгоритм.ДопСтроки Цикл
				ДобавитьВычитаемыйАлгоритм(ВычитаемыеАлгоритмы, ВложенныйАлгоритм);
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ВычитаемыеАлгоритмы;
	
КонецФункции

Процедура ДобавитьВычитаемыйАлгоритм(ВычитаемыеАлгоритмы, Алгоритм);
	
	Если Не Алгоритм.Вычитаемый Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторАлгоритма = ИдентификаторЗначенияПоказателя(
		Алгоритм.Номер,
		Алгоритм.Вписываемый,
		Алгоритм.Наименование);
		
	ВычитаемыеАлгоритмы.Вставить(ИдентификаторАлгоритма, Истина);
	
КонецПроцедуры

Процедура ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_ОИК(ПараметрыЗаполнения)
	
	ИмяРаздела = "ОИК";
	
	Контейнер = ПараметрыЗаполнения.Контейнер;
	КонтейнерРаздела = Контейнер.Строки.Найти(ИмяРаздела, "Идентификатор");
	
	Организация = ПараметрыЗаполнения.Организация;
	
	// Даты отчетного периода.
	НачалоОтчетногоПериода = ПараметрыЗаполнения.НачалоОтчетногоПериода;
	КонецОтчетногоПериода = ПараметрыЗаполнения.КонецОтчетногоПериода;
	КонецОтчетногоГода = КонецГода(КонецОтчетногоПериода);
	
	// Даты сравнительного периода.
	КонецГодаСравнительногоПериода = ДобавитьМесяц(КонецОтчетногоГода, -12);
	КонецСравнительногоПериода = ДобавитьМесяц(КонецОтчетногоПериода, -12);
	НачалоСравнительногоПериода = НачалоГода(КонецСравнительногоПериода);
	
	// Даты года, предшествующего сравнительному.
	КонецГода_2 = ДобавитьМесяц(КонецОтчетногоГода, -24);
	
	СчетаСРеквизитами = ПараметрыЗаполнения.СчетаСРеквизитами;
	
	ПараметрыРасшифровки = Новый Структура;
	ПараметрыРасшифровки.Вставить("ИмяРаздела", ИмяРаздела);
	ПараметрыРасшифровки.Вставить("КонтейнерРаздела", КонтейнерРаздела);
	ПараметрыРасшифровки.Вставить("Организация", Организация);
	
	ПараметрыОтчетовРасшифровки = Новый Структура;
	ПараметрыОтчетовРасшифровки.Вставить("Организация", Организация);
	ПараметрыОтчетовРасшифровки.Вставить("НачалоПериода", '0001-01-01');
	ПараметрыОтчетовРасшифровки.Вставить("КонецПериода", '0001-01-01');
	
	ОписаниеОборотныхСтрок = Новый Структура;
	ОписаниеОборотныхСтрок.Вставить("Строка3х11", Новый Структура("Номер, Код, Наименование", "", "",
		"Чистая прибыль (убыток)"));
	ОписаниеОборотныхСтрок.Вставить("Строка3х12", Новый Структура("Номер, Код, Наименование", "", "",
		"Переоценка внеоборотных активов"));
	ОписаниеОборотныхСтрок.Вставить("Строка3х27", Новый Структура("Номер, Код, Наименование", "", "",
		"Дивиденды"));
	ОписаниеОборотныхСтрок.Вставить("Строка3х30", Новый Структура("Номер, Код, Наименование", "", "",
		"Иные изменения за счет операций с собственниками (за исключением дивидендов) - всего"));
	ОписаниеОборотныхСтрок.Вставить("Строка3х40", Новый Структура("Номер, Код, Наименование", "", "",
		"Иные изменения - всего"));
	
	#Область РасчетБухгалтерскихИтогов
	
	НастройкиПолученияБухитогов = Новый Структура;
	НастройкиПолученияБухитогов.Вставить("Организация", Организация);
	НастройкиПолученияБухитогов.Вставить("НачалоПериода", '0001-01-01');
	НастройкиПолученияБухитогов.Вставить("КонецПериода", '0001-01-01');
	
	НастройкиПолученияБухитогов.НачалоПериода = НачалоОтчетногоПериода;
	НастройкиПолученияБухитогов.КонецПериода =  КонецОтчетногоПериода;
	СиО_ОтчетныйПериод =
		ЗаполнениеБухгалтерскойОтчетностиИтоги.СальдоИОборотыПоСчетам(НастройкиПолученияБухитогов);
	ОБ_ОтчетныйПериод =
