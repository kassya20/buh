	|		-1 * КлассификацияЗадолженности.ПроцентыПоРассрочке
	|	ИЗ
	|		КлассификацияЗадолженности КАК КлассификацияЗадолженности) КАК ОстаточныеКорректирующиеВеличины
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаточныеКорректирующиеВеличины.Организация,
	|	ОстаточныеКорректирующиеВеличины.Счет
	|
	|ИМЕЮЩИЕ
	|	(СУММА(ОстаточныеКорректирующиеВеличины.НДСАвансов) <> 0
	|		ИЛИ СУММА(ОстаточныеКорректирующиеВеличины.ПроцентыПоРассрочке) <> 0)");

	Возврат СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
КонецФункции

Процедура ОпределитьСоставляющиеБалансаКредиторскаяЗадолженность(ДанныеЗаполнения, РасчетныеДанные, КонтекстРасчета)

	СчетПроцентовПоРассрочке = ПланыСчетов.Хозрасчетный.ПроцентыПоРассрочке; // передаем в состявляющей только 76.08, но значение составляющей включает в себя еще 76.28, 76.38
	СчетНДСАвансов = ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам;
	
	Счета = Новый Массив;
	Счета.Добавить(СчетПроцентовПоРассрочке);
	Счета.Добавить(СчетНДСАвансов);
	
	СчетаСРеквизитами = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Счета, "Код");

	Шаблоны = ШаблоныРасшифровкиКредиторскаяЗадолженность();
	ПараметрыТекста = ПараметрыТекстаРасшифровкиКредиторскаяЗадолженность(КонтекстРасчета, СчетаСРеквизитами);
	
	СоставляющиеКраткосрочная = ДанныеЗаполнения.СоставляющиеКраткосрочная;
	СоставляющиеДолгосрочная = ДанныеЗаполнения.СоставляющиеДолгосрочная;
	
	СтрокаДолг = РасчетныеДанные.Задолженность.Выбрать();
	Пока СтрокаДолг.Следующий() Цикл
		
		// Краткосрочная задолженность
		Составляющая = СоставляющиеКраткосрочная.Добавить();
		Составляющая.Описание = СтрШаблон("+ Задолженность_КК %1", СтрокаДолг.Код);
		Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
		Составляющая.СчетРасчетов = СтрокаДолг.Счет;
		Составляющая.Значение = СтрокаДолг.ОстатокДолга;
		Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ОбщаяЗадолженность", КонтекстРасчета);
		
		Если СтрокаДолг.ЕстьДолгосрочнаяЧасть Тогда
			Составляющая = СоставляющиеКраткосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("- Задолженность_КК %1", СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.Значение = СтрокаДолг.ОстатокДолгаДолгосрочнойЧасти;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ДолгосрочнаяЧасть", КонтекстРасчета);
		КонецЕсли;
		
		Если СтрокаДолг.ЕстьПроцентыПоРассрочке Тогда
			Составляющая = СоставляющиеКраткосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("- Задолженность_КК %1, %2", СчетаСРеквизитами[СчетПроцентовПоРассрочке].Код, СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.СчетКорректирующий = СчетПроцентовПоРассрочке;
			Составляющая.Значение = СтрокаДолг.ПроцентыПоРассрочке;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ПроцентыПоРассрочке", КонтекстРасчета);
		КонецЕсли;
		
		Если СтрокаДолг.ЕстьНДСАвансов Тогда
			Составляющая = СоставляющиеКраткосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("- Задолженность_КК %1, %2", СчетаСРеквизитами[СчетНДСАвансов].Код, СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СчетНДСАвансов;
			Составляющая.Значение = СтрокаДолг.НДСАвансов;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "НДСАвансов", КонтекстРасчета);
		КонецЕсли;
		
		// Долгосрочная задолженность
		Если СтрокаДолг.ЕстьДолгосрочнаяЧасть Тогда
			Составляющая = СоставляющиеДолгосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("+ Задолженность_ДК %1", СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.Значение = СтрокаДолг.ОстатокДолгаДолгосрочнойЧасти;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ДолгосрочнаяЧасть", КонтекстРасчета);
			
			Если СтрокаДолг.ЕстьПроцентыПоРассрочкеДолгосрочнойЧасти Тогда
				Составляющая = СоставляющиеДолгосрочная.Добавить();
				Составляющая.Описание = СтрШаблон("- Задолженность_ДК %1, %2", СчетаСРеквизитами[СчетПроцентовПоРассрочке].Код, СтрокаДолг.Код);
				Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
				Составляющая.СчетРасчетов = СтрокаДолг.Счет;
				Составляющая.СчетКорректирующий = СчетПроцентовПоРассрочке;
				Составляющая.Значение = СтрокаДолг.ПроцентыПоРассрочкеДолгосрочнойЧасти;
				Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ПроцентыПоРассрочке", КонтекстРасчета);
			КонецЕсли;
			
			Если СтрокаДолг.ЕстьНДСАвансовДолгосрочнойЧасти Тогда
				Составляющая = СоставляющиеДолгосрочная.Добавить();
				Составляющая.Описание = СтрШаблон("- Задолженность_ДК %1, %2", СчетаСРеквизитами[СчетНДСАвансов].Код, СтрокаДолг.Код);
				Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
				Составляющая.СчетРасчетов = СчетНДСАвансов;
				Составляющая.Значение = СтрокаДолг.НДСАвансовДолгосрочнойЧасти;
				Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "НДСАвансов", КонтекстРасчета);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// добавляем составляющие, которые отражают остаточную сумму корректирующих величин
	СтрокиТаблицы = РасчетныеДанные.НераспределенныеВеличины.НайтиСтроки(Новый Структура("Счет", СчетПроцентовПоРассрочке));
	Если ЗначениеЗаполнено(СтрокиТаблицы) Тогда
		СтрокиГрупп = СоставляющиеКраткосрочная.НайтиСтроки(Новый Структура("КодГруппы", "15201"));
		Если ЗначениеЗаполнено(СтрокиГрупп) Тогда 
			ИндексСтроки = СоставляющиеКраткосрочная.Индекс(СтрокиГрупп[СтрокиГрупп.Количество() - 1]);
			Составляющая = СоставляющиеКраткосрочная.Вставить(ИндексСтроки + 1);
		Иначе
			Составляющая = СоставляющиеКраткосрочная.Добавить();
		КонецЕсли;
		Составляющая.Описание = СтрШаблон("- Задолженность_КК %1", СчетаСРеквизитами[СчетПроцентовПоРассрочке].Код);
		Составляющая.КодГруппы = "15201";
		Составляющая.СчетРасчетов = СчетПроцентовПоРассрочке;
		Составляющая.СчетКорректирующий = СчетПроцентовПоРассрочке;
		Составляющая.Значение = СтрокиТаблицы[0].ПроцентыПоРассрочке;
		Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ОстаточныйПроценты", КонтекстРасчета);
		Составляющая.Тип = "ОстаточныйПроценты";
	КонецЕсли;
	
	СтрокиГрупп = СоставляющиеКраткосрочная.НайтиСтроки(Новый Структура("КодГруппы", "15202"));
	Если ЗначениеЗаполнено(СтрокиГрупп) Тогда 
		ИндексСтроки = СоставляющиеКраткосрочная.Индекс(СтрокиГрупп[СтрокиГрупп.Количество() - 1]);
		Составляющая = СоставляющиеКраткосрочная.Вставить(ИндексСтроки + 1);
	Иначе
		Составляющая = СоставляющиеКраткосрочная.Добавить();
	КонецЕсли;
	Составляющая.Описание = СтрШаблон("- Задолженность_КК %1", СчетаСРеквизитами[СчетНДСАвансов].Код);
	Составляющая.КодГруппы = "15202";
	Составляющая.СчетРасчетов = СчетНДСАвансов;
	Составляющая.СчетКорректирующий = СчетНДСАвансов;
	СтрокиТаблицы = РасчетныеДанные.НераспределенныеВеличины.НайтиСтроки(Новый Структура("Счет", СчетНДСАвансов));
	Если ЗначениеЗаполнено(СтрокиТаблицы) Тогда
		Составляющая.Значение = СтрокиТаблицы[0].НДСАвансов;
	КонецЕсли;
	Составляющая.Тип = "ОстаточныйНДСАвансов";
	
	Составляющая.ТекстРасшифровки = ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ОстаточныйНДСАвансов", КонтекстРасчета);
	
КонецПроцедуры

Процедура ОпределитьСоставляющиеБалансаАренды(ДанныеЗаполнения, РасчетныеДанные, КонтекстРасчета)
	
	ТекстыРасшифровкиПоказателейАренды = ТекстыРасшифровкиПоказателейАренды(КонтекстРасчета);
	
	СоставляющиеКраткосрочная = ДанныеЗаполнения.СоставляющиеКраткосрочная;
	СоставляющиеДолгосрочная = ДанныеЗаполнения.СоставляющиеДолгосрочная;
	
	СтрокаДолг = РасчетныеДанные.Задолженность.Выбрать();
	Пока СтрокаДолг.Следующий() Цикл
		// Краткосрочная задолженность
		Составляющая = СоставляющиеКраткосрочная.Добавить();
		Составляющая.Описание = "+ ККЗ_РасчетыПоАренде 76.07";
		Составляющая.Значение = СтрокаДолг.ОстатокДолгаКраткосрочнойЧасти;
		Составляющая.ТекстРасшифровки = ТекстыРасшифровкиПоказателейАренды["СК_РасчетыПоАрендеКраткосрочное"];
		
		// Долгосрочная задолженность
		Составляющая = СоставляющиеДолгосрочная.Добавить();
		Составляющая.Описание = "+ ДКЗ_РасчетыПоАренде 76.07";
		Составляющая.Значение = СтрокаДолг.ОстатокДолгаДолгосрочнойЧасти;
		Составляющая.ТекстРасшифровки = ТекстыРасшифровкиПоказателейАренды["СК_РасчетыПоАрендеДолгосрочное"];
	КонецЦикла;
	
КонецПроцедуры

Функция ШаблоныРасшифровкиКредиторскаяЗадолженность()
	
	Шаблоны = Новый Структура;

	Шаблоны.Вставить("ШаблонЗадолженностьСвернутоеСальдо", 
	                 НСтр("ru = 'Сальдо на конец периода по счету [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонЗадолженность", 
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонЗадолженностьРазвернутое",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРасчетов], развернутое по субконто [ВидыСубконто]'"));
	Шаблоны.Вставить("ШаблонЗадолженностьСвернутоеСальдоДолгосрочная", 
	                 НСтр("ru = 'Сальдо на конец периода по счету [СчетРасчетов] (суммы со сроком погашения задолженности не ранее [ДатаДолгосрочногоПериода])'"));
	Шаблоны.Вставить("ШаблонЗадолженностьДолгосрочная",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРасчетов] (суммы со сроком погашения задолженности не ранее [ДатаДолгосрочногоПериода])'")); 
	Шаблоны.Вставить("ШаблонЗадолженностьДолгосрочнаяРазвернутое",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРасчетов], развернутое по субконто [ВидыСубконто] (суммы со сроком погашения задолженности не ранее [ДатаДолгосрочногоПериода])'"));
	Шаблоны.Вставить("ШаблонПроцентыПоОбъектам",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счетов [СчетаПроцентовПоРассрочке] по объектам, учитываемым на счете [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонПроцентыОстаточный",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счетов [СчетаПроцентовПоРассрочке], уменьшенное на величины, выделенные по объектам учета'"));
	Шаблоны.Вставить("ШаблонНДСПоОбъектам",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетНДС], учитываемым на счете [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонНДСОстаточный",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетНДС], уменьшенное на величины, выделенные по объектам учета'"));
	
	Возврат Шаблоны;
	
КонецФункции

Функция ТекстРасшифровкиКредиторскаяЗадолженность(Шаблоны, СтрокаСчет, ПараметрыТекста, МеткаСоставляющей, КонтекстРасчета)
	
	ПараметрыТекста.СчетРасчетов = СтрокаСчет.Код;
	ВидыСубконто = Новый Массив;
	Если СтрокаСчет.ВидСчета = ВидСчета.АктивноПассивный Тогда
		Если ЗначениеЗаполнено(СтрокаСчет.ВидСубконто1) Тогда
			ВидыСубконто.Добавить(СтрШаблон("""%1""", СтрокаСчет.ВидСубконто1));
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаСчет.ВидСубконто2) Тогда
			ВидыСубконто.Добавить(СтрШаблон("""%1""", СтрокаСчет.ВидСубконто2));
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаСчет.ВидСубконто3) Тогда
			ВидыСубконто.Добавить(СтрШаблон("""%1""", СтрокаСчет.ВидСубконто3));
		КонецЕсли;
		ПараметрыТекста.ВидыСубконто = СтрСоединить(ВидыСубконто, ",");
	КонецЕсли;

	Если МеткаСоставляющей = "ОбщаяЗадолженность" Тогда
		Если КонтекстРасчета.СчетаСвернутоеСальдоКредиторская.Найти(СтрокаСчет.Счет) <> Неопределено Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьСвернутоеСальдо, ПараметрыТекста);
		ИначеЕсли СтрокаСчет.ВидСчета = ВидСчета.АктивноПассивный И ЗначениеЗаполнено(ВидыСубконто) Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьРазвернутое, ПараметрыТекста);
		Иначе
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженность, ПараметрыТекста);
		КонецЕсли;
	ИначеЕсли МеткаСоставляющей = "ДолгосрочнаяЧасть" Тогда
		Если КонтекстРасчета.СчетаСвернутоеСальдоКредиторская.Найти(СтрокаСчет.Счет) <> Неопределено Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьСвернутоеСальдоДолгосрочная, ПараметрыТекста);
		ИначеЕсли СтрокаСчет.ВидСчета = ВидСчета.АктивноПассивный И ЗначениеЗаполнено(ВидыСубконто) Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьДолгосрочнаяРазвернутое, ПараметрыТекста);
		Иначе
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьДолгосрочная, ПараметрыТекста);
		КонецЕсли;
	ИначеЕсли МеткаСоставляющей = "ПроцентыПоРассрочке" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонПроцентыПоОбъектам, ПараметрыТекста);
	ИначеЕсли МеткаСоставляющей = "НДСАвансов" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонНДСПоОбъектам, ПараметрыТекста);
	ИначеЕсли МеткаСоставляющей = "ОстаточныйПроценты" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонПроцентыОстаточный, ПараметрыТекста);
	ИначеЕсли МеткаСоставляющей = "ОстаточныйНДСАвансов" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонНДСОстаточный, ПараметрыТекста);
	КонецЕсли;
	
	Возврат ТекстРасшифровки;
	
КонецФункции

Функция ПараметрыТекстаРасшифровкиКредиторскаяЗадолженность(КонтекстРасчета, СчетаСРеквизитами)
	
	СчетаПроцентовПоРассрочке = ПланыСчетов.Хозрасчетный.СчетаПроцентовПоРассрочке();
	КодыСчетовПроцентовПоРассрочке = Новый Массив;
	Для Каждого Счет Из СчетаПроцентовПоРассрочке Цикл
		КодыСчетовПроцентовПоРассрочке.Добавить(Счет.Код);
	КонецЦикла;
		
	ПараметрыТекста = Новый Структура;
	ПараметрыТекста.Вставить("ДатаДолгосрочногоПериода", Формат(КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)) + 1, "ДЛФ=DD"));
	ПараметрыТекста.Вставить("СчетаПроцентовПоРассрочке", СтрСоединить(КодыСчетовПроцентовПоРассрочке, ","));
	ПараметрыТекста.Вставить("СчетНДС", СчетаСРеквизитами[ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам].Код);
	ПараметрыТекста.Вставить("СчетРасчетов", "");
	ПараметрыТекста.Вставить("ВидыСубконто", "");
	
	Возврат ПараметрыТекста;
	
КонецФункции

#КонецОбласти

#Область ЗаемныеСредства

Функция ГруппыДолгосрочныеЗаемныеСредства()
	
	ВидыСчетов = Новый Массив;
	ВидыСчетов.Добавить(ВидСчета.Пассивный);
	ВидыСчетов.Добавить(ВидСчета.АктивноПассивный);
	
	Группы = НовыйГруппы();
	
	Группа = Группы.Добавить();
	Группа.Наименование = НСтр("ru = 'Долгосрочные кредиты'");
	Группа.Код = "14101";
	СчетаСписком = "67.01";
	Группа.СчетаРасчетов = КлассификацияЗадолженности.СчетаИзСписка(СчетаСписком, ВидыСчетов);

	Группа = Группы.Добавить();
	Группа.Наименование = НСтр("ru = 'Долгосрочные займы'");
	Группа.Код = "14102";
	СчетаСписком = "67.03, 67.05";
	Группа.СчетаРасчетов = КлассификацияЗадолженности.СчетаИзСписка(СчетаСписком, ВидыСчетов);
	
	Группа = Группы.Добавить();
	Группа.Наименование = НСтр("ru = 'Долгосрочные кредиты (в валюте)'");
	Группа.Код = "14103";
	СчетаСписком = "67.21";
	Группа.СчетаРасчетов = КлассификацияЗадолженности.СчетаИзСписка(СчетаСписком, ВидыСчетов);

	Группа = Группы.Добавить();
	Группа.Наименование = НСтр("ru = 'Долгосрочные займы (в валюте)'");
	Группа.Код = "14104";
	СчетаСписком = "67.23, 67.25";
	Группа.СчетаРасчетов = КлассификацияЗадолженности.СчетаИзСписка(СчетаСписком, ВидыСчетов);
	
	Возврат Группы;
	
КонецФункции

Функция ДанныеЗаполненияЗаемныеСредства(КонтекстРасчета)
	
	ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская;
	
	СчетаКредитыЗаймы = КлассификацияЗадолженности.СчетаДолгосрочныхКредитовЗаймов();

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СчетаКредитыЗаймы", СчетаКредитыЗаймы);
	Запрос.текст = 
	"ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Счет,
	|	Хозрасчетный.Код КАК Код,
	|	ВЫРАЗИТЬ("""" КАК Строка(10)) КАК КодГруппы,
	|	Хозрасчетный.Порядок КАК Порядок,
	|	Хозрасчетный.Вид КАК ВидСчета
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В(&СчетаКредитыЗаймы)";
	
	ТаблицаСчетов = Запрос.Выполнить().Выгрузить();
	
	Группы = ГруппыДолгосрочныеЗаемныеСредства();
	ОпределитьГруппуСчетов(ТаблицаСчетов, Группы);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организации",       КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("НачалоПериода",     НачалоМесяца(КонтекстРасчета.КонецПериодаДата));
	Запрос.УстановитьПараметр("КонецПериодаДата",  КонтекстРасчета.КонецПериодаДата);
	Запрос.УстановитьПараметр("КонецПериода",     Новый Граница(КонтекстРасчета.КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ВидЗадолженностиКредиторская", ВидЗадолженности);
	Запрос.УстановитьПараметр("ТаблицаСчетов", ТаблицаСчетов);
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор", ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	Запрос.УстановитьПараметр("ДатаНачалаДолгосрочногоПериода", НачалоДня(КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)) + 1));
	Запрос.УстановитьПараметр("СчетаКредитыЗаймы", СчетаКредитыЗаймы);

	СубконтоКонтрагентыДоговоры = Новый Массив;
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыДоговоры.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	Запрос.УстановитьПараметр("СубконтоКонтрагентыДоговоры", СубконтоКонтрагентыДоговоры);

	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаСчетов.Счет КАК Счет,
	|	ТаблицаСчетов.Код КАК Код,
	|	ТаблицаСчетов.КодГруппы КАК КодГруппы,
	|	ТаблицаСчетов.Порядок КАК Порядок,
	|	ТаблицаСчетов.ВидСчета КАК ВидСчета
	|ПОМЕСТИТЬ Счета
	|ИЗ
	|	&ТаблицаСчетов КАК ТаблицаСчетов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Организации.Ссылка КАК Организация,
	|	Счета.Счет КАК Счет,
	|	Счета.Код КАК Код,
	|	Счета.КодГруппы КАК КодГруппы,
	|	Счета.Порядок КАК Порядок,
	|	Счета.ВидСчета КАК ВидСчета
	|ПОМЕСТИТЬ СчетаОрганизации
	|ИЗ
	|	Счета КАК Счета,
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.Ссылка В(&Организации)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	СУММА(Расчеты.ОстатокДолга) КАК ОстатокДолга,
	|	ВЫБОР
	|		КОГДА СУММА(Расчеты.ОстатокДолгаКраткосрочнойЧасти) < 0
	|				ИЛИ СУММА(Расчеты.ОстатокДолга) < 0
	|			ТОГДА 0
	|		КОГДА СУММА(Расчеты.ОстатокДолгаКраткосрочнойЧасти) < СУММА(Расчеты.ОстатокДолга)
	|			ТОГДА СУММА(Расчеты.ОстатокДолгаКраткосрочнойЧасти)
	|		ИНАЧЕ СУММА(Расчеты.ОстатокДолга)
	|	КОНЕЦ КАК ОстатокДолгаКраткосрочнойЧасти
	|ПОМЕСТИТЬ ДанныеБаланса
	|ИЗ
	|	(ВЫБРАТЬ
	|		ХозрасчетныйОстаткиИОбороты.Организация КАК Организация,
	|		ХозрасчетныйОстаткиИОбороты.Счет КАК Счет,
	|		ХозрасчетныйОстаткиИОбороты.СуммаОстатокКт КАК ОстатокДолга,
	|		0 КАК ОстатокДолгаКраткосрочнойЧасти
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаКредитыЗаймы), , Организация В (&Организации)) КАК ХозрасчетныйОстаткиИОбороты
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация,
	|		КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет,
	|		СУММА(0),
	|		СУММА(КлассификацияПоСрокамОтдельныхВидовЗадолженности.ОстатокДолга)
	|	ИЗ
	|		РегистрСведений.КлассификацияПоСрокамОтдельныхВидовЗадолженности КАК КлассификацияПоСрокамОтдельныхВидовЗадолженности
	|	ГДЕ
	|		КлассификацияПоСрокамОтдельныхВидовЗадолженности.Активность
	|		И КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация В(&Организации)
	|		И КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет В(&СчетаКредитыЗаймы)
	|		И КлассификацияПоСрокамОтдельныхВидовЗадолженности.ВидЗадолженности = &ВидЗадолженностиКредиторская
	|		И КлассификацияПоСрокамОтдельныхВидовЗадолженности.ПериодРасчета МЕЖДУ &НачалоПериода И &КонецПериодаДата
	|		И КлассификацияПоСрокамОтдельныхВидовЗадолженности.ДатаПогашения < &ДатаНачалаДолгосрочногоПериода
	|	
	|	СГРУППИРОВАТЬ ПО
	|		КлассификацияПоСрокамОтдельныхВидовЗадолженности.Организация,
	|		КлассификацияПоСрокамОтдельныхВидовЗадолженности.Счет) КАК Расчеты
	|
	|СГРУППИРОВАТЬ ПО
	|	Расчеты.Организация,
	|	Расчеты.Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Счета.Организация КАК Организация,
	|	ЕСТЬNULL(СУММА(ДанныеБаланса.ОстатокДолга), 0) КАК ОстатокДолга,
	|	ЕСТЬNULL(СУММА(ДанныеБаланса.ОстатокДолгаКраткосрочнойЧасти), 0) КАК ОстатокДолгаКраткосрочнойЧасти,
	|	ЕСТЬNULL(СУММА(ДанныеБаланса.ОстатокДолгаКраткосрочнойЧасти) <> 0, ЛОЖЬ) КАК ЕстьКраткосрочнаяЧасть,
	|	Счета.Счет КАК Счет,
	|	Счета.Код КАК Код,
	|	Счета.КодГруппы КАК КодГруппы,
	|	Счета.Порядок КАК Порядок,
	|	Счета.ВидСчета КАК ВидСчета
	|ИЗ
	|	СчетаОрганизации КАК Счета
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеБаланса КАК ДанныеБаланса
	|		ПО Счета.Организация = ДанныеБаланса.Организация
	|			И Счета.Счет = ДанныеБаланса.Счет
	|
	|СГРУППИРОВАТЬ ПО
	|	Счета.Организация,
	|	Счета.Счет,
	|	Счета.Код,
	|	Счета.Порядок,
	|	Счета.ВидСчета,
	|	Счета.КодГруппы
	|
	|УПОРЯДОЧИТЬ ПО
	|	Организация,
	|	Порядок";
	
	РасчетныеДанные = Новый Структура;
	РасчетныеДанные.Вставить("Задолженность", Запрос.Выполнить());
	
	ДанныеЗаполнения = НовыйДанныеЗаполненияЗадолженности();
	ДанныеЗаполнения.Вставить("ГруппыДолгосрочная", Группы);
	ОпределитьСоставляющиеБалансаЗаемныеСредства(ДанныеЗаполнения, РасчетныеДанные, КонтекстРасчета);
	
	Возврат ДанныеЗаполнения;

КонецФункции

Процедура ОпределитьСоставляющиеБалансаЗаемныеСредства(ДанныеЗаполнения, РасчетныеДанные, КонтекстРасчета)
	
	Шаблоны = ШаблоныРасшифровкиЗаемныеСредства();
	ПараметрыТекста = ПараметрыТекстаРасшифровкиЗаемныеСредства(КонтекстРасчета);
	
	СоставляющиеКраткосрочная = ДанныеЗаполнения.СоставляющиеКраткосрочная;
	СоставляющиеДолгосрочная = ДанныеЗаполнения.СоставляющиеДолгосрочная;
	
	СтрокаДолг = РасчетныеДанные.Задолженность.Выбрать();
	Пока СтрокаДолг.Следующий() Цикл
		// Долгосрочная задолженность
		Составляющая = СоставляющиеДолгосрочная.Добавить();
		Составляющая.Описание = СтрШаблон("+ Задолженность_КК %1", СтрокаДолг.Код);
		Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
		Составляющая.СчетРасчетов = СтрокаДолг.Счет;
		Составляющая.Значение = СтрокаДолг.ОстатокДолга;
		Составляющая.ТекстРасшифровки = ТекстРасшифровкиЗаемныеСредства(Шаблоны, СтрокаДолг, ПараметрыТекста, "ОбщаяЗадолженность", КонтекстРасчета);
		
		Если СтрокаДолг.ЕстьКраткосрочнаяЧасть Тогда
			Составляющая = СоставляющиеДолгосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("- Задолженность_КК %1", СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.Значение = СтрокаДолг.ОстатокДолгаКраткосрочнойЧасти;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиЗаемныеСредства(Шаблоны, СтрокаДолг, ПараметрыТекста, "КраткосрочнаяЧасть", КонтекстРасчета);
		КонецЕсли;
		
		// Краткосрочная задолженность
		Если СтрокаДолг.ЕстьКраткосрочнаяЧасть Тогда
			Составляющая = СоставляющиеКраткосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("+ Задолженность_ДК %1", СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.Значение = СтрокаДолг.ОстатокДолгаКраткосрочнойЧасти;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиЗаемныеСредства(Шаблоны, СтрокаДолг, ПараметрыТекста, "КраткосрочнаяЧасть", КонтекстРасчета);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ШаблоныРасшифровкиЗаемныеСредства()
	
	Шаблоны = Новый Структура;

	Шаблоны.Вставить("ШаблонЗадолженность", 
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонЗадолженностьКраткосрочная",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРасчетов] (суммы со сроком погашения задолженности ранее [ДатаДолгосрочногоПериода])'")); 
