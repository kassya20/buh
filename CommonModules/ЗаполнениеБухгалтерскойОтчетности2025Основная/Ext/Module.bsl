	ПараметрыТекста.Вставить("ДатаДолгосрочногоПериода", Формат(КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)) + 1, "ДЛФ=DD"));
	ПараметрыТекста.Вставить("СчетРасчетов", "");
	
