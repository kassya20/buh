		АлгоритмСтроки.Составляющие.Добавить(Составляющая("- СКК_ПоВидуАктива 63, 60.02", ВидАктиваАвансы));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("- СКК_ПоВидуАктива 76.ВА, 60.02", ВидАктиваАвансы));
		
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СКД_ПоВидуАктива 60.22", ВидАктиваАвансы));
		АлгоритмСтроки.Составляющие.Добавить(Составляющая("- СКК_ПоВидуАктива 63, 60.22", ВидАктиваАвансы));
