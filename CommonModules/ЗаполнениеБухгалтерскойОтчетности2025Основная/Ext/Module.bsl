Функция ДанныеЗаполненияКредиторскаяЗадолженность(МенеджерВременныхТаблиц, КонтекстРасчета)
	
	ВидЗадолженности = Перечисления.ВидыЗадолженности.Кредиторская;
	
	// Заполняем счетами расчетов и счетами аренды
	СчетаКредиторская =  КлассификацияЗадолженности.СчетаРасчетовКредиторскаяЗадолженность();

	СписокВидовСубконто = КлассификацияЗадолженности.СписокВидовСубконто();
	НаборыСчетов = КлассификацияЗадолженности.НаборыСчетовБаланса(ВидЗадолженности, СписокВидовСубконто);
	ТаблицаСчетов = КлассификацияЗадолженности.НовыйТаблицаСчетов();
	
	КлассификацияЗадолженности.ЗаполнитьНаборыСчетами(НаборыСчетов, СчетаКредиторская.СчетаРасчетов, ТаблицаСчетов);

	Группы = ГруппыКредиторскаяКраткосрочнаяЗадолженность(КонтекстРасчета);
	ОпределитьГруппуСчетов(ТаблицаСчетов, Группы);
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапросаСводныеДанныеКредиторскаяЗадолженность(НаборыСчетов, КонтекстРасчета, ВидЗадолженности);

	Запрос.УстановитьПараметр("Организации",      КонтекстРасчета.Организации);
	Запрос.УстановитьПараметр("НачалоПериода",    НачалоМесяца(КонтекстРасчета.КонецПериодаДата));
	Запрос.УстановитьПараметр("КонецПериода",     Новый Граница(КонтекстРасчета.КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("КонецПериодаДата", КонецДня(КонтекстРасчета.КонецПериодаДата));
	Запрос.УстановитьПараметр("ДатаНачалаДолгосрочногоПериода", КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)) + 1);
	Запрос.УстановитьПараметр("СчетаРасчетовКредиторская", СчетаКредиторская.СчетаРасчетов);
	Запрос.УстановитьПараметр("СчетаРасчетовПоАренде",   СчетаКредиторская.СчетаРасчетовПоАренде);
	Запрос.УстановитьПараметр("ВидЗадолженности", ВидЗадолженности);
	Запрос.УстановитьПараметр("ТаблицаСчетов",    ТаблицаСчетов);
	Запрос.УстановитьПараметр("ПустойУникальныйИдентификатор", ОбщегоНазначенияКлиентСервер.ПустойУникальныйИдентификатор());
	Запрос.УстановитьПараметр("СчетаНДСАвансовПолученных", БухгалтерскийУчетПовтИсп.СчетаВИерархии(ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатам));

	СубконтоКонтрагентыСФВыданные = Новый Массив;
	СубконтоКонтрагентыСФВыданные.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	СубконтоКонтрагентыСФВыданные.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СФВыданные);
	Запрос.УстановитьПараметр("СубконтоКонтрагентыСФВыданные", СубконтоКонтрагентыСФВыданные);

	Запрос.УстановитьПараметр("СчетаПроцентовПоРассрочке", ПланыСчетов.Хозрасчетный.СчетаПроцентовПоРассрочке());
	
	// Виды субконто
	Для Каждого ВидыСубконто Из СписокВидовСубконто Цикл
		Запрос.УстановитьПараметр(ВидыСубконто.Ключ, ВидыСубконто.Значение);
	КонецЦикла;
	
	// Наборы счетов
	Для Каждого Набор Из НаборыСчетов Цикл
		Запрос.УстановитьПараметр(Набор.ИмяНабора, Набор.СписокСчетов);
	КонецЦикла;
	
	Результат = Запрос.ВыполнитьПакет();
	КоличествоЗапросов = Результат.ВГраница();
	
	РасчетныеДанные = Новый Структура;
	РасчетныеДанные.Вставить("Задолженность", Результат[КоличествоЗапросов - 2]);
	РасчетныеДанные.Вставить("НераспределенныеВеличины", Результат[КоличествоЗапросов].Выгрузить());

	ДанныеЗаполненияЗадолженности = НовыйДанныеЗаполненияЗадолженности();
	ДанныеЗаполненияЗадолженности.Вставить("ГруппыКраткосрочная", Группы);
	ОпределитьСоставляющиеБалансаКредиторскаяЗадолженность(ДанныеЗаполненияЗадолженности, РасчетныеДанные, КонтекстРасчета);
	
	РасчетныеДанные = Новый Структура;
	РасчетныеДанные.Вставить("Задолженность", Результат[КоличествоЗапросов - 1]);
	
	ДанныеЗаполненияАренды = НовыйДанныеЗаполненияЗадолженности();
	ДанныеЗаполненияАренды.Вставить("ГруппыКраткосрочная", ГруппыРасчетыПоАрендеЗадолженность());
	ОпределитьСоставляющиеБалансаАренды(ДанныеЗаполненияАренды, РасчетныеДанные, КонтекстРасчета);
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("Задолженность",   ДанныеЗаполненияЗадолженности);
	ДанныеЗаполнения.Вставить("РасчетыПоАренде", ДанныеЗаполненияАренды);

	ОбщегоНазначенияБП.УничтожитьВременныеТаблицы(МенеджерВременныхТаблиц,,"ОбщийНДСВыданный,ОбщийРезервПоСомнительнымДолгам,ОбязательстваПоАренде,АвансыПоАренде,НДСАвансовРасчетыПоАренде");

	Возврат ДанныеЗаполнения;

КонецФункции

Функция ТекстЗапросаСводныеДанныеКредиторскаяЗадолженность(НаборыСчетов, КонтекстРасчета, ВидЗадолженности)
	
	ТекстыЗапросов = Новый Массив;
	// Остатки задолженности по счетам, которые участвуют в классификации задолженности по срокам погашения
	КонтекстЗапроса = КлассификацияЗадолженности.НовыйКонтекстЗапросаОстаткиЗадолженности();
	ТекстЗапросаОстатки = КлассификацияЗадолженности.ТекстЗапросаОстаткиЗадолженности(НаборыСчетов, КонтекстЗапроса, ВидЗадолженности);
	Если ЗначениеЗаполнено(ТекстЗапросаОстатки) Тогда
		ТекстыЗапросов.Добавить(ТекстЗапросаОстатки);
	КонецЕсли;
	
	ТекстыЗапросов.Добавить(
	"ВЫБРАТЬ
	|	Расчеты.Организация КАК Организация,
	|	Расчеты.Счет КАК Счет,
	|	СУММА(Расчеты.ОстатокКт) КАК ОстатокБУ
	|ПОМЕСТИТЬ ДолгБУ
	|ИЗ
	|	Расчеты КАК Расчеты
	|
	|СГРУППИРОВАТЬ ПО
	|	Расчеты.Организация,
	|	Расчеты.Счет");
	
	ТекстыЗапросов.Добавить(
