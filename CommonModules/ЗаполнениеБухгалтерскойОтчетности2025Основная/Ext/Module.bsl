Функция РазделенноеСальдоСчета_59(КонецПериода, Организация)
	
	СчетаФинансовыхВложений = "58.01, 58.02, 58.03, 58.04, 58.05";
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ФинансовыеВложения.Счет КАК Счет,
		|	ФинансовыеВложения.Субконто1 КАК Контрагент,
		|	ФинансовыеВложения.СуммаОстатокДт КАК СуммаОстатокДт,
		|	Резервы.СуммаОстатокКт КАК СуммаОстатокКт
		|ПОМЕСТИТЬ ВТ_ВсеПроводки
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаУчета), ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты), Организация = &Организация) КАК ФинансовыеВложения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Остатки(&КонецПериода, Счет В (&СчетаРезервов), ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты), Организация = &Организация) КАК Резервы
		|		ПО ФинансовыеВложения.Субконто1 = Резервы.Субконто1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсеПроводки.Контрагент КАК Контрагент,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ВсеПроводки.Счет) КАК Счет
		|ПОМЕСТИТЬ ВТ_КонтрагентыПоКоличеству
		|ИЗ
		|	ВТ_ВсеПроводки КАК ВТ_ВсеПроводки
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ВсеПроводки.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КонтрагентыПоКоличеству.Контрагент КАК Контрагент,
		|	ВТ_КонтрагентыПоКоличеству.Счет КАК Счет
		|ПОМЕСТИТЬ ВТ_ПростыеСлучаи
		|ИЗ
		|	ВТ_КонтрагентыПоКоличеству КАК ВТ_КонтрагентыПоКоличеству
		|ГДЕ
		|	ВТ_КонтрагентыПоКоличеству.Счет = 1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КонтрагентыПоКоличеству.Контрагент КАК Контрагент,
		|	ВТ_КонтрагентыПоКоличеству.Счет КАК Счет
		|ПОМЕСТИТЬ ВТ_СоставныеСлучаи
		|ИЗ
		|	ВТ_КонтрагентыПоКоличеству КАК ВТ_КонтрагентыПоКоличеству
		|ГДЕ
		|	ВТ_КонтрагентыПоКоличеству.Счет <> 1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ПриведениеСчетов.СчетАлгоритма КАК Счет,
		|	СУММА(ВТ_ВсеПроводки.СуммаОстатокКт) КАК Резерв
		|ИЗ
		|	ВТ_ВсеПроводки КАК ВТ_ВсеПроводки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПростыеСлучаи КАК ВТ_ПростыеСлучаи
		|		ПО ВТ_ВсеПроводки.Контрагент = ВТ_ПростыеСлучаи.Контрагент
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПриведениеСчетов КАК ВТ_ПриведениеСчетов
		|		ПО ВТ_ВсеПроводки.Счет = ВТ_ПриведениеСчетов.СчетУчета
		|			И (ВТ_ПриведениеСчетов.СчетАлгоритма В (&СчетаАлгоритма))
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ПриведениеСчетов.СчетАлгоритма";
	
	ЗаполнениеБухгалтерскойОтчетностиИтоги.ДополнитьТекстЗапросаПоВременнымТаблицам(Запрос);
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("КонецПериода", Новый Граница(КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("СчетаАлгоритма",
		ЗаполнениеБухгалтерскойОтчетности.СчетаИзСписка(СчетаФинансовыхВложений));
	Запрос.УстановитьПараметр("СчетаУчета", БухгалтерскийУчетПовтИсп.СчетаВИерархии(Счет("58")));
	Запрос.УстановитьПараметр("СчетаРезервов", БухгалтерскийУчетПовтИсп.СчетаВИерархии(Счет("59")));
	
	ИтоговаяТаблица = Запрос.Выполнить().Выгрузить();
	// Нулевые значения для свертки.
	Для Каждого КодСчета Из Список(СчетаФинансовыхВложений) Цикл
		НоваяСтрокаПоСчету = ИтоговаяТаблица.Добавить();
		НоваяСтрокаПоСчету.Счет = Счет(КодСчета);
	КонецЦикла;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВТ_ПриведениеСчетов.СчетАлгоритма КАК Счет,
		|	ВТ_ВсеПроводки.Контрагент КАК Контрагент,
		|	ВТ_ВсеПроводки.СуммаОстатокДт КАК Вложения,
		|	ВТ_ВсеПроводки.СуммаОстатокКт КАК Резервы
		|ИЗ
		|	ВТ_ВсеПроводки КАК ВТ_ВсеПроводки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_СоставныеСлучаи КАК ВТ_СоставныеСлучаи
		|		ПО ВТ_ВсеПроводки.Контрагент = ВТ_СоставныеСлучаи.Контрагент
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПриведениеСчетов КАК ВТ_ПриведениеСчетов
		|		ПО ВТ_ВсеПроводки.Счет = ВТ_ПриведениеСчетов.СчетУчета
		|			И (ВТ_ПриведениеСчетов.СчетАлгоритма В (&СчетаАлгоритма))
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТ_ВсеПроводки.СуммаОстатокДт УБЫВ
		|ИТОГИ
		|	СУММА(Вложения),
		|	МИНИМУМ(Резервы)
		|ПО
		|	Контрагент,
		|	Счет";
	
	СоставныеСлучаи = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Для Каждого СтрокаКонтрагента Из СоставныеСлучаи.Строки Цикл
		ОбщаяСуммаВложений = СтрокаКонтрагента.Вложения;
		ОбщаяСуммаРезервов = СтрокаКонтрагента.Резервы;
		РаспределямыйРезерв = ОбщаяСуммаРезервов;
		
		Для Каждого СтрокаСчета Из СтрокаКонтрагента.Строки Цикл
			ЭтоПоследняяСтрока =
				(СтрокаКонтрагента.Строки.Индекс(СтрокаСчета) = СтрокаКонтрагента.Строки.Количество() - 1);
			
			Если ЭтоПоследняяСтрока Тогда
				РезервПоСчету = РаспределямыйРезерв;
			Иначе
				СуммаВложения = СтрокаСчета.Вложения;
				РезервПоСчету = Мин(РаспределямыйРезерв,
					Окр(СуммаВложения / ОбщаяСуммаВложений * ОбщаяСуммаРезервов, 2));
				РаспределямыйРезерв = РаспределямыйРезерв - РезервПоСчету;
			КонецЕсли;
			
			НоваяСтрокаПоСчету = ИтоговаяТаблица.Добавить();
			НоваяСтрокаПоСчету.Счет = СтрокаСчета.Счет;
			НоваяСтрокаПоСчету.Резерв = РезервПоСчету;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ИтоговаяТаблица.Свернуть("Счет", "Резерв");
	// Вспомогательные коды для формирования расчетных величин.
	ИтоговаяТаблица.Колонки.Добавить("ВспомогательныйКод", Новый ОписаниеТипов("Строка"));
	Для Каждого КодСчета Из Список(СчетаФинансовыхВложений) Цикл
		ИскомаяСтрока = ИтоговаяТаблица.Найти(Счет(КодСчета));
		ИскомаяСтрока.ВспомогательныйКод = Стрзаменить(КодСчета, ".", "_");
	КонецЦикла;
	
	Возврат ИтоговаяТаблица;
	
КонецФункции

