	|		0
	|	ИЗ
	|		КлассификацияЗадолженности КАК КлассификацияЗадолженности
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		КлассификацияЗадолженности.Организация,
	|		ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным),
	|		0,
	|		-1 * КлассификацияЗадолженности.НДСАвансов
	|	ИЗ
	|		КлассификацияЗадолженности КАК КлассификацияЗадолженности) КАК ОстаточныеКорректирующиеВеличины
	|
	|СГРУППИРОВАТЬ ПО
	|	ОстаточныеКорректирующиеВеличины.Организация,
	|	ОстаточныеКорректирующиеВеличины.Счет
	|
	|ИМЕЮЩИЕ
	|	(СУММА(ОстаточныеКорректирующиеВеличины.РезервПоСомнительнымДолгам) <> 0
	|		ИЛИ СУММА(ОстаточныеКорректирующиеВеличины.НДСАвансов) <> 0)");

	Возврат СтрСоединить(ТекстыЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
КонецФункции

Процедура ОпределитьСоставляющиеБалансаДебиторскаяЗадолженность(ДанныеЗаполнения, РасчетныеДанные, КонтекстРасчета)
	
	СчетРезервов = ПланыСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам;
	СчетНДСАвансов = ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным;

	Счета = Новый Массив;
	Счета.Добавить(СчетРезервов);
	Счета.Добавить(СчетНДСАвансов);
	
	СчетаСРеквизитами = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Счета, "Код");

	Шаблоны = ШаблоныРасшифровкиДебиторскаяЗадолженность();
	ПараметрыТекста = ПараметрыТекстаРасшифровкиДебиторскаяЗадолженность(КонтекстРасчета, СчетаСРеквизитами);
	ТекстыРасшифровкиПоказателейАренды = ТекстыРасшифровкиПоказателейАренды(КонтекстРасчета);
	
	СоставляющиеКраткосрочная = ДанныеЗаполнения.СоставляющиеКраткосрочная;
	СоставляющиеДолгосрочная = ДанныеЗаполнения.СоставляющиеДолгосрочная;
	
	СтрокаДолг = РасчетныеДанные.Задолженность.Выбрать();
	Пока СтрокаДолг.Следующий() Цикл
		
		// Краткосрочная задолженность
		Составляющая = СоставляющиеКраткосрочная.Добавить();
		Составляющая.Описание = СтрШаблон("+ Задолженность_КД %1", СтрокаДолг.Код);
		Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
		Составляющая.СчетРасчетов = СтрокаДолг.Счет;
		Составляющая.Значение = СтрокаДолг.ОстатокДолга;
		Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ОбщаяЗадолженность", КонтекстРасчета);
		ОпределитьТипЗадолженности(Составляющая, СтрокаДолг);
		
		Если СтрокаДолг.ЕстьДолгосрочнаяЧасть Тогда
			Составляющая = СоставляющиеКраткосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("- Задолженность_КД %1", СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.Значение = СтрокаДолг.ОстатокДолгаДолгосрочнойЧасти;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ДолгосрочнаяЧасть", КонтекстРасчета);
			ОпределитьТипЗадолженности(Составляющая, СтрокаДолг);
		КонецЕсли;
		
		Если СтрокаДолг.ЕстьРезерв Тогда
			Составляющая = СоставляющиеКраткосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("- Задолженность_КД %1, %2", СчетаСРеквизитами[СчетРезервов].Код, СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.СчетКорректирующий = СчетРезервов;
			Составляющая.Значение = СтрокаДолг.РезервПоСомнительнымДолгам;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "РезервПоСомнительнымДолгам", КонтекстРасчета);
		КонецЕсли;
		
		Если СтрокаДолг.ЕстьНДСАвансов Тогда
			Составляющая = СоставляющиеКраткосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("- Задолженность_КД %1, %2", СчетаСРеквизитами[СчетНДСАвансов].Код, СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.СчетКорректирующий = СчетНДСАвансов;
			Составляющая.Значение = СтрокаДолг.НДСАвансов;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "НДСАвансов", КонтекстРасчета);
		КонецЕсли;
		
		// Долгосрочная задолженность
		Если СтрокаДолг.ЕстьДолгосрочнаяЧасть Тогда
			Составляющая = СоставляющиеДолгосрочная.Добавить();
			Составляющая.Описание = СтрШаблон("+ Задолженность_ДД %1", СтрокаДолг.Код);
			Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
			Составляющая.СчетРасчетов = СтрокаДолг.Счет;
			Составляющая.Значение = СтрокаДолг.ОстатокДолгаДолгосрочнойЧасти;
			Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ДолгосрочнаяЧасть", КонтекстРасчета);
			ОпределитьТипЗадолженности(Составляющая, СтрокаДолг);
			
			Если СтрокаДолг.ЕстьРезервДолгосрочнойЧасти Тогда
				Составляющая = СоставляющиеДолгосрочная.Добавить();
				Составляющая.Описание = СтрШаблон("- Задолженность_ДД %1, %2", СчетаСРеквизитами[СчетРезервов].Код, СтрокаДолг.Код);
				Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
				Составляющая.СчетРасчетов = СтрокаДолг.Счет;
				Составляющая.СчетКорректирующий = СчетРезервов;
				Составляющая.Значение = СтрокаДолг.РезервПоСомнительнымДолгамДолгосрочнойЧасти;
				Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "РезервПоСомнительнымДолгам", КонтекстРасчета);
			КонецЕсли;
			
			Если СтрокаДолг.ЕстьНДСАвансовДолгосрочнойЧасти Тогда
				Составляющая = СоставляющиеДолгосрочная.Добавить();
				Составляющая.Описание = СтрШаблон("- Задолженность_ДД %1, %2", СчетаСРеквизитами[СчетНДСАвансов].Код, СтрокаДолг.Код);
				Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
				Составляющая.СчетРасчетов = СтрокаДолг.Счет;
				Составляющая.СчетКорректирующий = СчетНДСАвансов;
				Составляющая.Значение = СтрокаДолг.НДСАвансовДолгосрочнойЧасти;
				Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "НДСАвансов", КонтекстРасчета);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	// добавляем составляющие, которые отражают остаточную сумму корректирующих величин
	СтрокиГрупп = СоставляющиеКраткосрочная.НайтиСтроки(Новый Структура("КодГруппы", "12301"));
	Если ЗначениеЗаполнено(СтрокиГрупп) Тогда 
		ИндексСтроки = СоставляющиеКраткосрочная.Индекс(СтрокиГрупп[СтрокиГрупп.Количество() - 1]);
		Составляющая = СоставляющиеКраткосрочная.Вставить(ИндексСтроки + 1);
	Иначе
		Составляющая = СоставляющиеКраткосрочная.Добавить();
	КонецЕсли;
	Составляющая.Описание = СтрШаблон("- Задолженность_КД %1", СчетаСРеквизитами[СчетРезервов].Код);
	Составляющая.КодГруппы = "12301";
	Составляющая.СчетРасчетов = СчетРезервов;
	Составляющая.СчетКорректирующий = СчетРезервов;
	СтрокиТаблицы = РасчетныеДанные.НераспределенныеВеличины.НайтиСтроки(Новый Структура("Счет", СчетРезервов));
	Если ЗначениеЗаполнено(СтрокиТаблицы) Тогда
		Составляющая.Значение = СтрокиТаблицы[0].РезервПоСомнительнымДолгам;
	КонецЕсли;
	Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ОстаточныйРезервПоСомнительнымДолгам", КонтекстРасчета);
	Составляющая.Тип = "ОстаточныйРезерв";
	
	СтрокиГрупп = СоставляющиеКраткосрочная.НайтиСтроки(Новый Структура("КодГруппы", "12302"));
	Если ЗначениеЗаполнено(СтрокиГрупп) Тогда 
		ИндексСтроки = СоставляющиеКраткосрочная.Индекс(СтрокиГрупп[СтрокиГрупп.Количество() - 1]);
		Составляющая = СоставляющиеКраткосрочная.Вставить(ИндексСтроки + 1);
	Иначе
		Составляющая = СоставляющиеКраткосрочная.Добавить();
	КонецЕсли;
	Составляющая.Описание = СтрШаблон("- Задолженность_КД %1", СчетаСРеквизитами[СчетНДСАвансов].Код);
	Составляющая.КодГруппы = "12302";
	Составляющая.СчетРасчетов = СчетНДСАвансов;
	Составляющая.СчетКорректирующий = СчетНДСАвансов;
	СтрокиТаблицы = РасчетныеДанные.НераспределенныеВеличины.НайтиСтроки(Новый Структура("Счет", СчетНДСАвансов));
	Если ЗначениеЗаполнено(СтрокиТаблицы) Тогда
		Составляющая.Значение = СтрокиТаблицы[0].НДСАвансов;
	КонецЕсли;
	Составляющая.ТекстРасшифровки = ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаДолг, ПараметрыТекста, "ОстаточныйНДСАвансов", КонтекстРасчета);
	Составляющая.Тип = "ОстаточныйНДСАвансов";
	
	// Авансы по аренде
	СтрокаДолг = РасчетныеДанные.РасчетыПоАренде.Выбрать();
	Пока СтрокаДолг.Следующий() Цикл
		Составляющая = СоставляющиеКраткосрочная.Добавить();
		Составляющая.Описание = "+ Задолженность_КК 76.07";
		Составляющая.КодГруппы = СтрокаДолг.КодГруппы;
		Составляющая.Значение = СтрокаДолг.ОстатокДолга - СтрокаДолг.НДСАвансов;
		Составляющая.ТекстРасшифровки = ТекстыРасшифровкиПоказателейАренды["СК_РасчетыПоАрендеАвансы"];
		Составляющая.Тип = "Аренда";
	КонецЦикла;
	
КонецПроцедуры

Функция ШаблоныРасшифровкиДебиторскаяЗадолженность()
	
	Шаблоны = Новый Структура;

	Шаблоны.Вставить("ШаблонЗадолженность", 
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонАвансыРазделятьПоВидамАктивов", 
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов][ИсключаемыеВидыАктивов]'"));
	Шаблоны.Вставить("ШаблонЗадолженностьРБП", 
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов] по статьям с видом актива в балансе ""[ВидАктиваДебиторскаяЗадолженность]""'"));
	Шаблоны.Вставить("ШаблонЗадолженностьРазвернутое",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов], развернутое по субконто [ВидыСубконто]'"));
	Шаблоны.Вставить("ШаблонЗадолженностьДолгосрочная",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов] (суммы со сроком погашения задолженности не ранее [ДатаДолгосрочногоПериода])'"));
	Шаблоны.Вставить("ШаблонАвансыРазделятьПоВидамАктивовДолгосрочная",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов][ИсключаемыеВидыАктивов] (суммы со сроком погашения задолженности не ранее [ДатаДолгосрочногоПериода])'"));
	Шаблоны.Вставить("ШаблонЗадолженностьДолгосрочнаяРБП", 
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов] по статьям с видом актива в балансе ""[ВидАктиваДебиторскаяЗадолженность]"" (суммы со сроком погашения задолженности не ранее [ДатаДолгосрочногоПериода])'")); 
	 Шаблоны.Вставить("ШаблонЗадолженностьДолгосрочнаяРазвернутое",
	                 НСтр("ru = 'Сальдо на конец периода по дебету счета [СчетРасчетов], развернутое по субконто [ВидыСубконто] (суммы со сроком погашения задолженности не ранее [ДатаДолгосрочногоПериода])'"));
	Шаблоны.Вставить("ШаблонРезервПоОбъектам",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРезервов] по объектам, учитываемым на счете [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонРезервОстаточный",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетРезервов], уменьшенное на величины, выделенные по объектам учета'"));
	Шаблоны.Вставить("ШаблонНДСПоОбъектам",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетНДС], учитываемым на счете [СчетРасчетов]'"));
	Шаблоны.Вставить("ШаблонНДСОстаточный",
	                 НСтр("ru = 'Сальдо на конец периода по кредиту счета [СчетНДС], уменьшенное на величины, выделенные по объектам учета'"));
	
	Возврат Шаблоны;
	
КонецФункции

Функция ТекстРасшифровкиДебиторскаяЗадолженность(Шаблоны, СтрокаСчет, ПараметрыТекста, МеткаСоставляющей, КонтекстРасчета)
	
	ПараметрыТекста.Вставить("ВидыСубконто", "");
	ПараметрыТекста.СчетРасчетов = СтрокаСчет.Код;
	ВидыСубконто = Новый Массив;
	Если СтрокаСчет.ВидСчета = ВидСчета.АктивноПассивный Тогда
		Если ЗначениеЗаполнено(СтрокаСчет.ВидСубконто1) Тогда
			ВидыСубконто.Добавить(СтрШаблон("""%1""", СтрокаСчет.ВидСубконто1));
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаСчет.ВидСубконто2) Тогда
			ВидыСубконто.Добавить(СтрШаблон("""%1""", СтрокаСчет.ВидСубконто2));
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаСчет.ВидСубконто3) Тогда
			ВидыСубконто.Добавить(СтрШаблон("""%1""", СтрокаСчет.ВидСубконто3));
		КонецЕсли;
		ПараметрыТекста.ВидыСубконто = СтрСоединить(ВидыСубконто, ",");
	КонецЕсли;

	Если МеткаСоставляющей = "ОбщаяЗадолженность" Тогда
		Если СтрокаСчет.ЭтоСчетРБП Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьРБП, ПараметрыТекста);
		ИначеЕсли СтрокаСчет.ВидСчета = ВидСчета.АктивноПассивный И ЗначениеЗаполнено(ВидыСубконто) Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьРазвернутое, ПараметрыТекста);
		ИначеЕсли СтрокаСчет.РазделятьАвансыПоВидамАктивов Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонАвансыРазделятьПоВидамАктивов, ПараметрыТекста);
		Иначе
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженность, ПараметрыТекста);
		КонецЕсли;
	ИначеЕсли МеткаСоставляющей = "ДолгосрочнаяЧасть" Тогда
		Если СтрокаСчет.ЭтоСчетРБП Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьДолгосрочнаяРБП, ПараметрыТекста);
		ИначеЕсли СтрокаСчет.ВидСчета = ВидСчета.АктивноПассивный И ЗначениеЗаполнено(ВидыСубконто) Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьДолгосрочнаяРазвернутое, ПараметрыТекста);
		ИначеЕсли СтрокаСчет.РазделятьАвансыПоВидамАктивов Тогда
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонАвансыРазделятьПоВидамАктивовДолгосрочная, ПараметрыТекста);
		Иначе
			ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонЗадолженностьДолгосрочная, ПараметрыТекста);
		КонецЕсли;
	ИначеЕсли МеткаСоставляющей = "РезервПоСомнительнымДолгам" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонРезервПоОбъектам, ПараметрыТекста);
	ИначеЕсли МеткаСоставляющей = "НДСАвансов" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонНДСПоОбъектам, ПараметрыТекста);
	ИначеЕсли МеткаСоставляющей = "ОстаточныйРезервПоСомнительнымДолгам" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонРезервОстаточный, ПараметрыТекста);
	ИначеЕсли МеткаСоставляющей = "ОстаточныйНДСАвансов" Тогда
		ТекстРасшифровки = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблоны.ШаблонНДСОстаточный, ПараметрыТекста);
	КонецЕсли;
	
	Возврат ТекстРасшифровки;
	
КонецФункции

Функция ПараметрыТекстаРасшифровкиДебиторскаяЗадолженность(КонтекстРасчета, СчетаСРеквизитами)
	
	ПараметрыТекста = Новый Структура;
	ПараметрыТекста.Вставить("ДатаДолгосрочногоПериода", Формат(КонецМесяца(ДобавитьМесяц(КонтекстРасчета.КонецПериодаДата, 12)) + 1, "ДЛФ=DD"));
	ПараметрыТекста.Вставить("СчетРезервов", СчетаСРеквизитами[ПланыСчетов.Хозрасчетный.РезервыПоСомнительнымДолгам].Код);
	ПараметрыТекста.Вставить("СчетНДС",      СчетаСРеквизитами[ПланыСчетов.Хозрасчетный.НДСпоАвансамИПредоплатамВыданным].Код);
	ПараметрыТекста.Вставить("СчетРасчетов", "");
	ПараметрыТекста.Вставить("ВидыСубконто", "");
	ПараметрыТекста.Вставить("ВидАктиваДебиторскаяЗадолженность", Перечисления.ВидыАктивовДляРБП.ДебиторскаяЗадолженность);
	ПараметрыТекста.Вставить("ИсключаемыеВидыАктивов", "");
	
	Если КонтекстРасчета.РазделятьАвансыПоВидамАктивов Тогда
		ПараметрыТекста.ИсключаемыеВидыАктивов = НСтр("ru = ' по договорам, с признаком отражения в балансе не отнесенным к ""Основным средствам"", ""Инвестиционной недвижимости"", ""Нематериальным активам"", ""Прочим внеоборотным активам"", ""Запасам"" или ""Прочим оборотным активам""'");
	КонецЕсли;
	
	Возврат ПараметрыТекста;
	
КонецФункции

