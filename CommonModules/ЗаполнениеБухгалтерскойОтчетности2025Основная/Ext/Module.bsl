	#Область Строка1110
	
	АлгоритмСтроки = ДобавитьНовыйАлгоритмСтрокиСДопСтроками(Алгоритмы, "1110", 11101,
		"Нематериальные активы");
	
	АлгоритмСтроки.Составляющие.Добавить(Составляющая("+ СКД 04"));
