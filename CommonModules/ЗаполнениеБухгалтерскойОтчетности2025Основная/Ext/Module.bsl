Функция ТекстыРасшифровкиПоказателейАренды(ПараметрыЗаполнения)
	
	Разделитель = ", ";
	СчетаСРеквизитами = ПараметрыЗаполнения.СчетаСРеквизитами;
	
	Счет_76_ВА = СчетСРеквизитами("76.ВА", СчетаСРеквизитами).Код;
	
	// Счета, используемые при расчете обязательства по аренде (лизингу)
	СчетаАренды = Новый Массив;
	СчетаАренды.Добавить(СчетСРеквизитами("76.07", СчетаСРеквизитами).Код);
	Если ПараметрыЗаполнения.ИспользуетсяВалютныйУчет Тогда
		СчетаАренды.Добавить(СчетСРеквизитами("76.27", СчетаСРеквизитами).Код);
		СчетаАренды.Добавить(СчетСРеквизитами("76.37", СчетаСРеквизитами).Код);
	КонецЕсли;
	СчетаАренды.Добавить(Счет_76_ВА);
	
	СчетаАрендыСтрокой = ОбщегоНазначенияБПКлиентСервер.ПредставлениеСписка(СчетаАренды, Разделитель);
	
	// Текст расшифровки показателя счета 76.ВА по договорам аренды (лизинга)
	ШаблонНДС = НСтр("ru = 'Сальдо на конец периода по кредиту счета %1 по договорам аренды (лизинга)'");
	Если ПараметрыЗаполнения.РазделятьАвансыПоВидамАктивов Тогда
		ШаблонНДС = НСтр("ru = 'Сальдо на конец периода по кредиту счета %1 по договорам аренды (лизинга), с признаком отражения в балансе не отнесенным к ""Основным средствам"", ""Инвестиционной недвижимости"", ""Нематериальным активам"", ""Прочим внеоборотным активам"", ""Запасам"" или ""Прочим оборотным активам""'");
	КонецЕсли;
	ТекстНДС = СтрШаблон(ШаблонНДС, Счет_76_ВА);
	
	Тексты = Новый Соответствие;
	Тексты.Вставить("СК_РасчетыПоАрендеНДСсПлатежей",
					ТекстНДС);
	Тексты.Вставить("СК_РасчетыПоАрендеАвансы", 
					СтрШаблон(НСтр("ru = 'Авансы по аренде (лизингу) - по данным счетов %1'"), СчетаАрендыСтрокой));
	Тексты.Вставить("СК_РасчетыПоАрендеДолгосрочное", 
					СтрШаблон(НСтр("ru = 'Долгосрочная часть обязательства по аренде (лизингу) - по данным счетов %1'"), СчетаАрендыСтрокой));
	Тексты.Вставить("СК_РасчетыПоАрендеКраткосрочное", 
					СтрШаблон(НСтр("ru = 'Краткосрочная часть обязательства по аренде (лизингу) - по данным счетов %1'"), СчетаАрендыСтрокой));
	
	Возврат Тексты;

КонецФункции

Функция БухгалтерскиеИтоги_Баланс2025Кв1(Организация, КонецПериодаОтчета, ИтогиПоСчетам, КлассифицироватьАктивыОбязательстваПоСрокам = Ложь)
	
	СальдоИОборотыПоСчетам = ИтогиПоСчетам.СальдоИОборотыПоСчетам;
	АвансыПоВидамАктивов   = ИтогиПоСчетам.АвансыПоВидамАктивов;
	
	РассчитанныеЗначения = Новый Соответствие;
	
	РассчитанныеЗначения.Вставить("СальдоИОборотыПоСчетам", ИтогиПоСчетам.СальдоИОборотыПоСчетам);
	РассчитанныеЗначения.Вставить("СиО_КонтрагентыДоговоры", ИтогиПоСчетам.СиО_КонтрагентыДоговоры);
	РассчитанныеЗначения.Вставить("СиО_Контрагенты", ИтогиПоСчетам.СиО_Контрагенты);
