#Область ПрограммныйИнтерфейс

// Рассчитывает показатели баланса организации за период. Рассчитываются показатели всей организации (включая
// филиалы, данные которых доступны пользователю) в разрезе филиалов. При использовании функции для сравнительного
// анализа данных текущего и предыдущих периодов необходимо соблюдать следующие два правила: данные текущего периода
// необходимо получать без учета движений межотчетного периода (ВключаяМежотчетныйПериод = Ложь); данные предыдущих
// периодов необходимо получать с учетом движений межотчетного периода (ВключаяМежотчетныйПериод = Истина). Выполнение
// этих правил минимизирует расхождение данных смежных лет, между которыми изменились правила учета, в том числе
// изменился стандарт учета. Если правила учета изменились в конце предыдущего года, то получаемые на конец предыдущего
// года данные будут приведены к ним. Если правила учета изменились в конце текущего года, то получаемые на конец
// текущего года данные будут соответствовать действующим в этом году положениям. Таким образом, обеспечивается
// максимальное приведение данных разных лет к одним правилам учета.
// 
// Параметры:
//  Период - Дата
//  Организация - СправочникСсылка.Организации
//  ТолькоГруппыПоказателей - Булево - Ложь, если нужно включить детальные показатели (не имеющие кодов показателей)
//  ВключаяМежотчетныйПериод - Булево - Истина, если нужно учитывать движения межотчетного периода
//  ДатаУчетнойПолитики - Дата - дата, на которую определяются настройки учетной политики
// 
// Возвращаемое значение:
//  ТаблицаЗначений - см. НовыйЗначенияПоказателей
//
Функция ПоказателиБаланс(Период, Организация, ТолькоГруппыПоказателей = Истина, ВключаяМежотчетныйПериод = Ложь, ДатаУчетнойПолитики = '00010101') Экспорт
	
	ЗначенияПоказателей = НовыйЗначенияПоказателей();
	
	ДоступныеОрганизации = ОбщегоНазначенияБПВызовСервераПовтИсп.ВсеОрганизацииДанныеКоторыхДоступныПоRLS(Ложь);
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВсяОрганизация = Справочники.Организации.ВсяОрганизация(Организация, Период);
	
	НедоступныеОрганизации = ОбщегоНазначенияКлиентСервер.РазностьМассивов(ВсяОрганизация, ДоступныеОрганизации);
	ОрганизацииДляЗаполнения = ОбщегоНазначенияКлиентСервер.РазностьМассивов(ВсяОрганизация, НедоступныеОрганизации);
	
	ДатаКонцаПериода = КонецМесяца(Период);
	Если ЗначениеЗаполнено(ДатаУчетнойПолитики) Тогда
		КонецОтчетногоПериода = ДатаУчетнойПолитики;
	Иначе
		КонецОтчетногоПериода = ДатаКонцаПериода;
	КонецЕсли;
	АвансыРазделеныПоВидамАктивов = РегламентированнаяОтчетность.АвансыРазделеныПоВидамАктивов(Организация, Период);
	СчетаСРеквизитами = ЗаполнениеБухгалтерскойОтчетностиИтоги.СчетаСРеквизитами();
	ПараметрыСчетов      = ПараметрыСчетов_Баланс2025Кв1();
	
	Для Каждого Филиал Из ОрганизацииДляЗаполнения Цикл
		
		ПараметрыЗаполнения = НовыеПараметрыЗаполненияБаланс();
		ПараметрыЗаполнения.Организация = Филиал;
		// Механика получения итогов не может определить итоги только на конец периода,
		// она для удобства разработчика всегда заодно получает сальдо на начало периода и обороты за период.
		// Для сокращения негативного влияния этой особенности реализации на производительность, передаем такую дату,
		// чтобы получение ненужных данных с большей вероятностью сводилось к чтению из тех же записей физической таблицы итогов,
		// что содержат и нужные данные.
		ПараметрыЗаполнения.НачалоПериодаОтчета   = НачалоМесяца(ДатаКонцаПериода);
		Уточнение = 0;
		Если ВключаяМежотчетныйПериод Тогда
			Уточнение = БухгалтерскийУчет.ВерхняяГраницаУточненияПериода();
		КонецЕсли;
		ПараметрыЗаполнения.КонецПериодаОтчета    = Новый МоментВремениСУточнениемПериода(ДатаКонцаПериода, Уточнение);
		ПараметрыЗаполнения.КонецОтчетногоПериода = КонецОтчетногоПериода;
		
		ПараметрыЗаполнения.РазделятьАвансыПоВидамАктивов = АвансыРазделеныПоВидамАктивов;
		ПараметрыЗаполнения.СчетаСРеквизитами = СчетаСРеквизитами;
		
		ПроцессорПоказателя = НовыйПроцессорПоказателя();
		ПроцессорПоказателя.Организация   = Филиал;
		ПроцессорПоказателя.НачалоПериода = ПараметрыЗаполнения.НачалоПериодаОтчета;
		ПроцессорПоказателя.КонецПериода  = ПараметрыЗаполнения.КонецПериодаОтчета;
		ПроцессорПоказателя.ИмяРаздела = "Баланс";
		ПроцессорПоказателя.СчетаСРеквизитами    = СчетаСРеквизитами;
		ПроцессорПоказателя.ПараметрыСчетов      = ПараметрыСчетов;
		ПроцессорПоказателя.ТекстыРасшифровки    = ТекстыРасшифровкиПоказателейАренды(ПараметрыЗаполнения);
		
		//@skip-check query-in-loop
		ОбщиеИтогиПоСчетам = РассчитатьБухгалтерскиеВеличиныФормаОтчета2025Кв1_Баланс(ПараметрыЗаполнения);
		//@skip-check query-in-loop
		ПроцессорПоказателя.РассчитанныеЗначения = БухгалтерскиеИтоги_Баланс2025Кв1(
			ПараметрыЗаполнения.Организация,
			ПараметрыЗаполнения.КонецПериодаОтчета,
			ОбщиеИтогиПоСчетам);
		
		ПараметрыЗаполнения.ПроцессорПоказателя = ПроцессорПоказателя;
		
		ПараметрыАлгоритмов = ПараметрыАлгоритмовБаланса2025(ПараметрыЗаполнения, ОбщиеИтогиПоСчетам);
		Алгоритмы = АлгоритмыБО2025Кв1_Баланс(ПараметрыАлгоритмов);
	
		ЗначенияПоказателейФилиала = РассчитатьПоказателиБаланс(ПроцессорПоказателя, Алгоритмы);
		
		Для Каждого ЗначениеПоказателя Из ЗначенияПоказателейФилиала Цикл
			Если ТолькоГруппыПоказателей И Не ЗначениеЗаполнено(ЗначениеПоказателя.КодПоказателя) Тогда
				Продолжить;
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(ЗначенияПоказателей.Добавить(), ЗначениеПоказателя);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ЗначенияПоказателей;
	
КонецФункции

// Конструктор коллекции, содержащей рассчитанные значения показателей отчета.
// Здесь Показатель используется в терминологии ФСБУ 4. Соответственно, код показателя - из числа установленных Приложением 10 к ФСБУ 4.
// Только показатели верхнего уровня (агрегированные, группы показателей) обладают кодом, для детальных - пустая строка.
// Следует отличать от терминологии, применяемой в ПроцессорПоказателя. В частности там применяются самодельные "коды".
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
// * Организация - СправочникСсылка.Организации - 
// * КодПоказателя - Строка - из числа установленных Приложением 10 к ФСБУ 4, указывается у групп показателей 
// * Идентификатор - Строка - для получения используется ИдентификаторЗначенияПоказателя
// * Наименование - Строка - как правило, заполнено
// * ЗначениеПоказателя - Число - в рублях
// * НаименованиеПоказателя - Строка - используется во внутренней механике расчета, может быть не заполнено
// * Расшифровка - Массив из Структура - описание порядка расчета
Функция НовыйЗначенияПоказателей() Экспорт
	
	ЗначенияПоказателей = Новый ТаблицаЗначений;
	
	ЗначенияПоказателей.Колонки.Добавить("Организация",            Новый ОписаниеТипов("СправочникСсылка.Организации"));
	ЗначенияПоказателей.Колонки.Добавить("КодПоказателя",          Новый ОписаниеТипов("Строка")); 
	ЗначенияПоказателей.Колонки.Добавить("Идентификатор",          Новый ОписаниеТипов("Строка"));
	ЗначенияПоказателей.Колонки.Добавить("Наименование",           Новый ОписаниеТипов("Строка"));
	// Следующие поля совпадают с ПроцессорПоказателя.Показатель 
	ЗначенияПоказателей.Колонки.Добавить("ЗначениеПоказателя",     Новый ОписаниеТипов("Число"));
	ЗначенияПоказателей.Колонки.Добавить("НаименованиеПоказателя", Новый ОписаниеТипов("Строка"));
	ЗначенияПоказателей.Колонки.Добавить("Расшифровка",            Новый ОписаниеТипов("Массив"));
	
	ЗначенияПоказателей.Индексы.Добавить("Идентификатор");
	
	Возврат ЗначенияПоказателей;
	
КонецФункции

// Рассчитывает итог раздела баланса.
// 
// Параметры:
//  ИмяРаздела - Строка - Имя раздела по БухгалтерскаяОтчетностьБРО.КодыРазделовБаланса
//  ЗначенияПоказателей - см. НовыйЗначенияПоказателей - заранее рассчитанные значения показателей, например, с помощью ПоказателиБаланс
// 
// Возвращаемое значение:
//  Число - итог по разделу баланса
Функция ИтогРазделаБаланса(ИмяРаздела, ЗначенияПоказателей) Экспорт
	
	Итоги = ИтогиРазделовБаланса(ЗначенияПоказателей, ИмяРаздела);
	
	Если Не Итоги.Свойство(ИмяРаздела) Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Итоги[ИмяРаздела];
	
КонецФункции

// Рассчитывает итоги разделов баланса - всех, или с отбором. Для одного раздела см. также ИтогРазделаБаланса 
// 
// Параметры:
//  ЗначенияПоказателей - см. НовыйЗначенияПоказателей - заранее рассчитанные значения показателей, например, с помощью ПоказателиБаланс
//  Отбор - Неопределено - все показатели, без отбора
//        - Массив из Строка - имена разделов по БухгалтерскаяОтчетностьБРО.КодыРазделовБаланса
//        - Строка - имена разделов по БухгалтерскаяОтчетностьБРО.КодыРазделовБаланса, разделенные запятыми
// 
// Возвращаемое значение:
//  Структура Из КлючИЗначение - Итоги разделов баланса:
//         * Ключ - Строка - из числа БухгалтерскаяОтчетностьБРО.КодыРазделовБаланса (с учетом отбора)
//         * Значение - Число - итог по разделу баланса
//
Функция ИтогиРазделовБаланса(ЗначенияПоказателей, Отбор = Неопределено) Экспорт
	
	Итоги = Новый Структура;
	
	Поиск = Новый Соответствие;
	
	ЗначенияОтбора = Новый Массив;
	Если ТипЗнч(Отбор) = Тип("Строка") Тогда
		ЗначенияОтбора = СтрРазделить(Отбор, ",");
	ИначеЕсли ТипЗнч(Отбор) = Тип("Массив") Тогда
		ЗначенияОтбора = Отбор;
	КонецЕсли;
	
	КодыРазделов = БухгалтерскаяОтчетностьБРО.КодыРазделовБаланса();
	
	Если ЗначениеЗаполнено(ЗначенияОтбора) Тогда
		Для Каждого ЗначениеОтбора Из ЗначенияОтбора Цикл
			ЗначениеОтбора = СокрЛП(ЗначениеОтбора);
			КодРаздела = "";
			Если КодыРазделов.Свойство(ЗначениеОтбора, КодРаздела) Тогда
				Поиск.Вставить(КодРаздела, ЗначениеОтбора);
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для Каждого ОписаниеКодаРаздела Из КодыРазделов Цикл
			Поиск.Вставить(ОписаниеКодаРаздела.Значение, ОписаниеКодаРаздела.Ключ);
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого ЗначениеПоиска Из Поиск Цикл
		Итоги.Вставить(ЗначениеПоиска.Значение, 0);
	КонецЦикла;
	
	Для Каждого ЗначениеПоказателя Из ЗначенияПоказателей Цикл
		
		Если ПустаяСтрока(ЗначениеПоказателя.КодПоказателя) Тогда
			Продолжить;
		КонецЕсли;
		
		КодРаздела = БухгалтерскаяОтчетностьБРО.КодРазделаОтчета(ЗначениеПоказателя.КодПоказателя);
		
		ИмяРаздела = Поиск[КодРаздела];
		Если ИмяРаздела = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Итоги[ИмяРаздела] = Итоги[ИмяРаздела] + ЗначениеПоказателя.ЗначениеПоказателя;
		
	КонецЦикла;
	
	Возврат Итоги;
	
КонецФункции

// Определяет идентификатор ячейки фиксированной строки бухгалтерской отчетности.
// 
// Параметры:
//  КодСтроки - Строка - Код показателя согласно Приложению 10 к ФСБУ 4
//  НомерГрафы - Строка - Номер графы (колонки регламентированного отчета БРО)
// 
// Возвращаемое значение:
//  Строка - Идентификатор ячейки
//
Функция ИдентификаторЯчейки(КодСтроки, НомерГрафы) Экспорт
	
	ИдентификаторСтроки = БухгалтерскаяОтчетностьБРО.ИдентификаторФиксированнойСтрокиДляЯчеек(КодСтроки);
	Возврат БухгалтерскаяОтчетностьБРО.ИдентификаторЯчейки(ИдентификаторСтроки, НомерГрафы);
	
КонецФункции

#Область УпрощеннаяОтчетность

// Добавляет в описание показателей упрощенного баланса заполняемые этим модулем.
// 
// Параметры:
//  ПоказателиОтчета - Структура - заполняемая коллекция; для добавления элементов следует использовать РегламентированнаяОтчетность.ВставитьПоказательВСтруктуру 
// 
Процедура ДобавитьЗаполняемыеПоказателиУпрощеннаяОтчетность(ПоказателиОтчета) Экспорт

	ГрафыБаланса = Новый Массив;
	ГрафыБаланса.Добавить("04");
	ГрафыБаланса.Добавить("05");
	ГрафыБаланса.Добавить("06");
	
	Для Каждого Раздел Из БухгалтерскаяОтчетностьБРО.РазделыОтчета() Цикл
	
		СхемаУпрощенногоБаланса = ЗаполнениеБухгалтерскойОтчетностиУпрощенная.СхемаСокращенияУпрощеннойОтчетности(Раздел);
		
		Для Каждого ГруппаПоказателей Из СхемаУпрощенногоБаланса Цикл
			Для Каждого КодПоказателя Из ГруппаПоказателей.Значение Цикл
				Для Каждого КодГрафы Из ГрафыБаланса Цикл
					КодЯчейки = ИдентификаторЯчейки(КодПоказателя, КодГрафы);
					РегламентированнаяОтчетность.ВставитьПоказательВСтруктуру(ПоказателиОтчета, КодЯчейки, Истина, Истина);
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

// Заполняет РегламентированныйОтчетБухОтчетность по форме ФормаОтчета2025Кв1.
//
// Параметры:
//  ПараметрыОтчета - Структура - набор именованных параметров для определения вариантов заполнения отчета:
//    * Организация - СправочникСсылка.Организации
//    * ДатаНачалаПериодаОтчета - Дата
//    * ДатаКонцаПериодаОтчета - Дата, МоментВремениСУточнениемПериода -
//    * ГруппаОрганизаций - СписокЗначений из  СправочникСсылка.Организации
//    * ЗаполняемыеРазделы - Структура
//    * АдресВоВременномХранилище - Строка
//    * ЭтоБалансНекоммерческойОрганизации - Булево
//  Контейнер - ДеревоЗначений - данные разделов.
//  ЭтоУпрощеннаяОтчетность - Булево - Истина для упрощенной отчетности
//
Процедура ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1(ПараметрыОтчета, Контейнер, ЭтоУпрощеннаяОтчетность = Ложь) Экспорт
	
	ОсновнаяОрганизация = ПараметрыОтчета.Организация;
	
	НачалоПериодаОтчета = ПараметрыОтчета.ДатаНачалаПериодаОтчета;
	ДатаКонцаПериодаОтчета = ПараметрыОтчета.ДатаКонцаПериодаОтчета;
	КонецПериодаОтчета = Новый МоментВремениСУточнениемПериода(ДатаКонцаПериодаОтчета, 0);
	
	НачалоПериодаПредыдущегоГода = НачалоГода(ДобавитьМесяц(НачалоПериодаОтчета, -12));
	ДатаКонцаПредыдущегоГода = КонецГода(НачалоПериодаПредыдущегоГода);
	КонецПериодаПредыдущегоГода = Новый МоментВремениСУточнениемПериода(ДатаКонцаПредыдущегоГода,
		БухгалтерскийУчет.ВерхняяГраницаУточненияПериода());
	
	НачалоПериодаГодаПредшествующегоПредыдущему = НачалоГода(ДобавитьМесяц(НачалоПериодаПредыдущегоГода, -12));
	ДатаКонцаГодаПредшествующегоПредыдущему = КонецГода(НачалоПериодаГодаПредшествующегоПредыдущему);
	КонецПериодаГодаПредшествующегоПредыдущему = Новый МоментВремениСУточнениемПериода(
		ДатаКонцаГодаПредшествующегоПредыдущему,
		БухгалтерскийУчет.ВерхняяГраницаУточненияПериода());
	
	ДоступныеОрганизации = ОбщегоНазначенияБПВызовСервераПовтИсп.ВсеОрганизацииДанныеКоторыхДоступныПоRLS(Ложь);
	
	ПолныйСписокОрганизаций = Новый Массив; // Массив из СправочникСсылка.Организации
	
	Если ДоступныеОрганизации.Найти(ОсновнаяОрганизация) <> Неопределено Тогда
		ПолныйСписокОрганизаций.Добавить(ОсновнаяОрганизация);
	КонецЕсли;
	
	Если ПараметрыОтчета.Свойство("ГруппаОрганизаций") Тогда
		Для Каждого Организация Из ПараметрыОтчета.ГруппаОрганизаций Цикл
			Если ДоступныеОрганизации.Найти(Организация.Значение) <> Неопределено Тогда
				ПолныйСписокОрганизаций.Добавить(Организация.Значение);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	СчетаСРеквизитами = ЗаполнениеБухгалтерскойОтчетностиИтоги.СчетаСРеквизитами();
	
	ЗаполнятьБаланс = ПараметрыОтчета.ЗаполняемыеРазделы.Баланс;
	ЗаполнятьОИК = ПараметрыОтчета.ЗаполняемыеРазделы.ОИК;
	
	ЗаполнятьПредыдущиеПериоды = НЕ РасширенныйПериодОтчета(НачалоПериодаОтчета);
	
	// Бухгалтерский баланс.
	Если ЗаполнятьБаланс Тогда
		ПараметрыЗаполненияБаланс = НовыеПараметрыЗаполненияБаланс();
		ПараметрыЗаполненияБаланс.Контейнер = Контейнер;
		ПараметрыЗаполненияБаланс.КонецОтчетногоПериода = КонецДня(ДатаКонцаПериодаОтчета);
		ПараметрыЗаполненияБаланс.ЭтоБалансНекоммерческойОрганизации =
			ПараметрыОтчета.ЭтоБалансНекоммерческойОрганизации;
		ПараметрыЗаполненияБаланс.ЭтоУпрощеннаяОтчетность = ЭтоУпрощеннаяОтчетность;
				
		ПараметрыЗаполненияБаланс.СчетаСРеквизитами = СчетаСРеквизитами;
		
		ПараметрыЗаполненияБаланс.Графа = "04";
		ПараметрыЗаполненияБаланс.ЗаголовокГрафы =
			"На " + Формат(ДатаКонцаПериодаОтчета, "ДФ = 'дд ММММ гггг'")+ " г.";
		ПараметрыЗаполненияБаланс.НачалоПериодаОтчета = НачалоПериодаОтчета;
		ПараметрыЗаполненияБаланс.КонецПериодаОтчета = КонецПериодаОтчета;
		
		ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_БалансПоГрафе(ПараметрыЗаполненияБаланс, ПолныйСписокОрганизаций);
		
		Если ЗаполнятьПредыдущиеПериоды Тогда
			ПараметрыЗаполненияБаланс.Графа = "05";
			ПараметрыЗаполненияБаланс.ЗаголовокГрафы =
				"На " + Формат(ДатаКонцаПредыдущегоГода, "ДФ = 'дд ММММ гггг'")+ " г.";
			ПараметрыЗаполненияБаланс.НачалоПериодаОтчета = НачалоПериодаПредыдущегоГода;
			ПараметрыЗаполненияБаланс.КонецПериодаОтчета = КонецПериодаПредыдущегоГода;
			
			ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_БалансПоГрафе(ПараметрыЗаполненияБаланс, ПолныйСписокОрганизаций);
			
			ПараметрыЗаполненияБаланс.Графа = "06";
			ПараметрыЗаполненияБаланс.ЗаголовокГрафы =
				"На " + Формат(ДатаКонцаГодаПредшествующегоПредыдущему, "ДФ = 'дд ММММ гггг'")+ " г.";
			ПараметрыЗаполненияБаланс.НачалоПериодаОтчета = НачалоПериодаГодаПредшествующегоПредыдущему;
			ПараметрыЗаполненияБаланс.КонецПериодаОтчета = КонецПериодаГодаПредшествующегоПредыдущему;
			
			ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_БалансПоГрафе(ПараметрыЗаполненияБаланс, ПолныйСписокОрганизаций);
			
		КонецЕсли;
		
	КонецЕсли;
		
	Для Каждого Организация Из ПолныйСписокОрганизаций Цикл
			
		// Отчет об изменениях капитала.
		Если ЗаполнятьОИК Тогда
			ПараметрыЗаполненияОИК = НовыеПараметрыЗаполненияОИК();
			ПараметрыЗаполненияОИК.Организация = Организация;
			ПараметрыЗаполненияОИК.Контейнер = Контейнер;
			ПараметрыЗаполненияОИК.НачалоОтчетногоПериода = НачалоПериодаОтчета;
			ПараметрыЗаполненияОИК.КонецОтчетногоПериода = КонецДня(ДатаКонцаПериодаОтчета);
			ПараметрыЗаполненияОИК.СчетаСРеквизитами = СчетаСРеквизитами;
			
			ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_ОИК(ПараметрыЗаполненияОИК);
			
		КонецЕсли;
		
	КонецЦикла;
	
	КонтекстОтчета = КонтекстОтчета(
		НачалоПериодаОтчета,
		КонецПериодаОтчета,
		ЗаполнятьПредыдущиеПериоды,
		НачалоПериодаПредыдущегоГода,
		КонецПериодаПредыдущегоГода,
		ПолныйСписокОрганизаций,
		ЭтоУпрощеннаяОтчетность);
		
	ЗаполнитьОтчетПоНастройкам(
		Контейнер,
		ПараметрыОтчета.ЗаполняемыеРазделы,
		КонтекстОтчета,
		ПолныйСписокОрганизаций,
		ПараметрыОтчета.НастройкиЗаполненияСтрок);
		
	ЗаполнитьТаблицыОтчета(
		Контейнер,
		ПараметрыОтчета.ЗаполняемыеРазделы,
		КонтекстОтчета,
		ПолныйСписокОрганизаций);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("Контейнер", Контейнер);
	
	ПоместитьВоВременноеХранилище(СтруктураДанных, ПараметрыОтчета.АдресВоВременномХранилище);
	
КонецПроцедуры

// Создает таблицу с остатками по авансам с учетом вида актива
// 
// Параметры:
//  Организации - Массив из СправочникСсылка.Организации
//  Период - Дата
//  РазделятьАвансыПоВидамАктивов - Булево
//  АвансыПоВидамАктивов - Неопределено
//                       - Структура
// Возвращаемое значение:
//  см. НовыйАвансыПоВидамАктивовСводно
//
Функция АвансыПоВидамАктивовСводно(Организации, Период, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивов = Неопределено) Экспорт
	
	АвансыСводно = НовыйАвансыПоВидамАктивовСводно();
	
	Если Не РазделятьАвансыПоВидамАктивов Тогда
		Возврат АвансыСводно;
	КонецЕсли;
	
	ИменаТаблиц = Новый Массив;
	ИменаТаблиц.Добавить("СтруктураСКД_60_02");
	ИменаТаблиц.Добавить("СтруктураСКД_60_22");
	ИменаТаблиц.Добавить("СтруктураСКД_60_32");
	
	Для Каждого Организация Из Организации Цикл
		Если АвансыПоВидамАктивов = Неопределено Тогда
			СтруктураСКД_60_02 = РазделенноеСальдоСчетаУчетаАвансов2025(
			Счет("60.02"), Период, РазделятьАвансыПоВидамАктивов, Организация);
			СтруктураСКД_60_22 = РазделенноеСальдоСчетаУчетаАвансов2025(
			Счет("60.22"), Период, РазделятьАвансыПоВидамАктивов, Организация);
			СтруктураСКД_60_32 = РазделенноеСальдоСчетаУчетаАвансов2025(
			Счет("60.32"), Период, РазделятьАвансыПоВидамАктивов, Организация);
			
			АвансыПоВидамАктивов = Новый Структура;
			АвансыПоВидамАктивов.Вставить("РазделятьАвансыПоВидамАктивов", РазделятьАвансыПоВидамАктивов);
			АвансыПоВидамАктивов.Вставить("СтруктураСКД_60_02", СтруктураСКД_60_02);
			АвансыПоВидамАктивов.Вставить("СтруктураСКД_60_22", СтруктураСКД_60_22);
			АвансыПоВидамАктивов.Вставить("СтруктураСКД_60_32", СтруктураСКД_60_32);
		КонецЕсли;
		
		Для Каждого ИмяТаблицы Из ИменаТаблиц Цикл
			Для Каждого СтрокаТаблицы Из АвансыПоВидамАктивов[ИмяТаблицы] Цикл
				СтрокаАвансы = АвансыСводно.Добавить();
				СтрокаАвансы.Организация = Организация;
				СтрокаАвансы.ВидАктива = СтрокаТаблицы.ВидАктива;
				СтрокаАвансы.ОстатокНДС = СтрокаТаблицы.СуммаОстатокКтНДСАвансов;
				СтрокаАвансы.ОстатокРезерва = СтрокаТаблицы.СуммаОстатокКтРезервы;
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
	АвансыСводно.Свернуть("Организация, ВидАктива", "ОстатокНДС, ОстатокРезерва");
	
	Возврат АвансыСводно;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_БалансПоГрафе(ПараметрыЗаполнения, ПолныйСписокОрганизаций)
	
	ИмяРаздела = "Баланс";
	
	НачалоПериодаОтчета = ПараметрыЗаполнения.НачалоПериодаОтчета;
	КонецПериодаОтчета = ПараметрыЗаполнения.КонецПериодаОтчета;
	
	ПроцессорПоказателя = НовыйПроцессорПоказателя();
	ПроцессорПоказателя.ИмяРаздела = ИмяРаздела;
	ПроцессорПоказателя.НачалоПериода = НачалоПериодаОтчета;
	ПроцессорПоказателя.КонецПериода  = КонецПериодаОтчета;
	ПроцессорПоказателя.СчетаСРеквизитами = ПараметрыЗаполнения.СчетаСРеквизитами;
	ПроцессорПоказателя.ПараметрыСчетов = ПараметрыСчетов_Баланс2025Кв1();
	ПроцессорПоказателя.ТекстыРасшифровки = ТекстыРасшифровкиПоказателейАренды(ПараметрыЗаполнения);
	
	ЗначенияПоказателейПоВсемОрганизациям = Новый Массив; // из см. НовыйЗначенияПоказателей;
		
	Для Каждого Организация Из ПолныйСписокОрганизаций Цикл
		
		ПараметрыЗаполнения.Организация = Организация;
		
		ПараметрыЗаполнения.РазделятьАвансыПоВидамАктивов =
			РегламентированнаяОтчетность.АвансыРазделеныПоВидамАктивов(Организация, ПараметрыЗаполнения.КонецОтчетногоПериода);
	
		//@skip-check query-in-loop
		ОбщиеИтогиПоСчетам = РассчитатьБухгалтерскиеВеличиныФормаОтчета2025Кв1_Баланс(ПараметрыЗаполнения);

		//@skip-check query-in-loop
		ПроцессорПоказателя.РассчитанныеЗначения = БухгалтерскиеИтоги_Баланс2025Кв1(
			Организация,
			КонецПериодаОтчета,
			ОбщиеИтогиПоСчетам,
			ПараметрыЗаполнения.КлассифицироватьАктивыОбязательстваПоСрокам);
			
		ПроцессорПоказателя.Организация = Организация;
		
		ПараметрыЗаполнения.ПроцессорПоказателя = ПроцессорПоказателя;
		
		ПараметрыАлгоритмов = ПараметрыАлгоритмовБаланса2025(ПараметрыЗаполнения, ОбщиеИтогиПоСчетам);
		Алгоритмы = АлгоритмыБО2025Кв1_Баланс(ПараметрыАлгоритмов);
		ПараметрыЗаполнения.Вставить("Алгоритмы", Алгоритмы);
		ПараметрыЗаполнения.Вставить("РассчитанныеПараметры", ОбщиеИтогиПоСчетам);
		
		ЗначенияПоказателей = РассчитатьПоказателиБаланс(ПроцессорПоказателя, Алгоритмы);
		ЗначенияПоказателейПоВсемОрганизациям.Добавить(ЗначенияПоказателей);
		
	КонецЦикла;
	
	ЗаполнитьОтчетБухОтчетностьФормаОтчета2025Кв1_БалансПоГрафеПоАлгоритмам(ПараметрыЗаполнения, ЗначенияПоказателейПоВсемОрганизациям);
	
КонецПроцедуры

// Конструктор параметров заполнения бухгалтерского баланса.
// 
// Возвращаемое значение:
//   Структура - Новые параметры заполнения баланс:
//     * Организация - СправочникСсылка.Организации 
//     * Контейнер - ДеревоЗначений
//     * СчетаСРеквизитами - ТаблицаЗначений:
//       ** УсловныйКод - Строка
//       ** Ссылка - ПланСчетовСсылка.Хозрасчетный
//       ** Код - Строка
//       ** Наименование - Строка
//     * Графа - Строка
//     * ЗаголовокГрафы - Строка
//     * НачалоПериодаОтчета - Дата
//     * КонецПериодаОтчета - Дата
//                          - МоментВремениСУточнениемПериода
//     * ПроцессорПоказателя - Структура
//     * Алгоритмы - Массив из Структура
//     * РассчитанныеПараметры - Структура
//
Функция НовыеПараметрыЗаполненияБаланс()
	
	ПараметрыЗаполнения = Новый Структура;
	
	ПараметрыЗаполнения.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
	ПараметрыЗаполнения.Вставить("Контейнер", Новый ДеревоЗначений);
	ПараметрыЗаполнения.Вставить("ЭтоБалансНекоммерческойОрганизации", Ложь);
	ПараметрыЗаполнения.Вставить("ЭтоУпрощеннаяОтчетность", Ложь);
	
	ПараметрыЗаполнения.Вставить("РазделятьАвансыПоВидамАктивов", Ложь);
	ПараметрыЗаполнения.Вставить("НастройкаВключенаКлассифицироватьАктивыОбязательства", Ложь);
	ПараметрыЗаполнения.Вставить("КлассифицироватьАктивыОбязательстваПоСрокам", Ложь);
	ПараметрыЗаполнения.Вставить("КонецОтчетногоПериода", '0001-01-01');
	ПараметрыЗаполнения.Вставить("УчетНа70ВедетсяСводно", ЗаполнениеБухгалтерскойОтчетности.УчетНа70ВедетсяСводно());
	ПараметрыЗаполнения.Вставить("ИспользуетсяВалютныйУчет", БухгалтерскийУчетПереопределяемый.ИспользоватьВалютныйУчет());
	
	СчетаСРеквизитами = Новый ТаблицаЗначений;
	СчетаСРеквизитами.Колонки.Добавить("УсловныйКод", Новый ОписаниеТипов("Строка"));
	СчетаСРеквизитами.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	СчетаСРеквизитами.Колонки.Добавить("Код", Новый ОписаниеТипов("Строка"));
	СчетаСРеквизитами.Колонки.Добавить("Наименование", Новый ОписаниеТипов("Строка"));
	ПараметрыЗаполнения.Вставить("СчетаСРеквизитами", СчетаСРеквизитами);
	
	ПараметрыЗаполнения.Вставить("Графа", "");
	ПараметрыЗаполнения.Вставить("ЗаголовокГрафы", "");
	ПараметрыЗаполнения.Вставить("НачалоПериодаОтчета", '0001-01-01');
	ПараметрыЗаполнения.Вставить("КонецПериодаОтчета", '0001-01-01');
	
	// Параметры, заполняемые и используемые в процессе заполнения отчета сведениями из ИБ.
	ПараметрыЗаполнения.Вставить("ПроцессорПоказателя", Новый Структура);
	ПараметрыЗаполнения.Вставить("Алгоритмы", Новый Массив);
	ПараметрыЗаполнения.Вставить("РассчитанныеПараметры", Новый Структура);
	
	ПараметрыЗаполнения.Вставить("ПоказателиУпрощеннойОтчетности", Новый Соответствие); // Ключ - номер обобщающей строки, Значение - идентификатор раскрывающей строки
	
	Возврат ПараметрыЗаполнения;
	
КонецФункции

Функция РассчитатьБухгалтерскиеВеличиныФормаОтчета2025Кв1_Баланс(ПараметрыЗаполнения)
	
	Организация = ПараметрыЗаполнения.Организация;
	НачалоПериодаОтчета = ПараметрыЗаполнения.НачалоПериодаОтчета;
	КонецПериодаОтчета = ПараметрыЗаполнения.КонецПериодаОтчета;
	
	// На дату отчетного периода определяется настройка в учетной политике "Классифицировать активы и обязательства по срокам".
	// Если она включена, то для сравнительного периода также определяется соответствующая настройка,
	// в случае её отсутствия - наличие регламентной операции «Классификация задолженности по срокам» за этот период.
	ГоловнаяОрганизация = БухгалтерскийУчетПереопределяемый.ГоловнаяОрганизация(Организация);
	ПараметрыЗаполнения.НастройкаВключенаКлассифицироватьАктивыОбязательства = УчетнаяПолитика.КлассифицироватьАктивыОбязательстваПоСрокам(ПараметрыЗаполнения.КонецОтчетногоПериода, ГоловнаяОрганизация);
	Если КонецДня(ПараметрыЗаполнения.КонецОтчетногоПериода) = КонецДня(КонецПериодаОтчета.Дата) Тогда
		ПараметрыЗаполнения.КлассифицироватьАктивыОбязательстваПоСрокам = ПараметрыЗаполнения.НастройкаВключенаКлассифицироватьАктивыОбязательства;
	Иначе
		ПараметрыЗаполнения.КлассифицироватьАктивыОбязательстваПоСрокам = 
			КлассификацияЗадолженности.КлассифицироватьАктивыОбязательстваПоСрокамВБалансе(КонецПериодаОтчета.Дата, ГоловнаяОрганизация, ПараметрыЗаполнения.НастройкаВключенаКлассифицироватьАктивыОбязательства);
	КонецЕсли;
	
	НастройкиПолученияБухитогов = Новый Структура;
	НастройкиПолученияБухитогов.Вставить("Организация",   Организация);
	НастройкиПолученияБухитогов.Вставить("НачалоПериода", НачалоПериодаОтчета);
	НастройкиПолученияБухитогов.Вставить("КонецПериода",  КонецПериодаОтчета);
	
	ОбщиеИтогиПоСчетам = Новый Структура;
	
	СальдоИОборотыПоСчетам = ЗаполнениеБухгалтерскойОтчетностиИтоги.СальдоИОборотыПоСчетам(НастройкиПолученияБухитогов);
	ОбщиеИтогиПоСчетам.Вставить("СальдоИОборотыПоСчетам", СальдоИОборотыПоСчетам);
	
	СчетаДляРасчета = "76.01.1, 76.03, 76.05, 76.06, 76.09, 76.17, 76.21, 76.25, 76.26, 76.29, 76.35, 76.36, 76.39, 76.41, 76.49, 76.К";
	СубконтоДляРасчета = "Контрагенты";
	
	СиО_Контрагенты = СальдоИОборотыПоСчетамИСубконто(НастройкиПолученияБухитогов, СчетаДляРасчета, СубконтоДляРасчета);
	ОбщиеИтогиПоСчетам.Вставить("СиО_Контрагенты", СиО_Контрагенты);
	
	СчетаДляРасчета = "60.01, 60.21, 60.31, 62.01, 62.21, 62.31,
	                  |76.01.1, 76.03, 76.05, 76.06, 76.09, 76.21, 76.25, 76.26, 76.29, 76.35, 76.36, 76.39, 76.К, 76.НА, 76.07, 76.27, 76.37";
	СубконтоДляРасчета = "Контрагенты, Договоры";
	
	СиО_КонтрагентыДоговоры = СальдоИОборотыПоСчетамИСубконто(НастройкиПолученияБухитогов, СчетаДляРасчета, СубконтоДляРасчета);
	ОбщиеИтогиПоСчетам.Вставить("СиО_КонтрагентыДоговоры", СиО_КонтрагентыДоговоры);
	
	СчетаДляРасчета = "68.01, 68.02, 68.03, 68.06, 68.07, 68.08, 68.09, 68.11, 68.12, 68.13, 68.14, 68.15, 68.16, 68.17, 68.21, 68.34, 68.52,
	                  |69.01, 69.02.1, 69.02.2, 69.02.3, 69.02.4, 69.02.5, 69.02.6, 69.02.7,
	                  |69.03.1, 69.03.2, 69.04, 69.05.1, 69.05.2, 69.06.1, 69.06.2, 69.06.3, 69.06.4, 69.06.5, 69.06.6,
	                  |69.09, 69.11, 69.12,
	                  |68.04.1, 68.10";
	СубконтоДляРасчета = "ВидыПлатежейВГосБюджет";
	
	СиО_ВидыПлатежей = СальдоИОборотыПоСчетамИСубконто(НастройкиПолученияБухитогов, СчетаДляРасчета, СубконтоДляРасчета);
	ОбщиеИтогиПоСчетам.Вставить("СиО_ВидыПлатежей", СиО_ВидыПлатежей);
	
	СчетаДляРасчета = "68.04.1, 68.10";
	СубконтоДляРасчета = "ВидыПлатежейВГосБюджет, УровниБюджетов";
	
	СиО_ВидыПлатежейУровниБюджетов = СальдоИОборотыПоСчетамИСубконто(НастройкиПолученияБухитогов, СчетаДляРасчета, СубконтоДляРасчета);
	ОбщиеИтогиПоСчетам.Вставить("СиО_ВидыПлатежейУровниБюджетов", СиО_ВидыПлатежейУровниБюджетов);
	
	СчетаДляРасчета = "70, 71, 73.03, 76.10";
	СубконтоДляРасчета = "РаботникиОрганизаций";
	
	СиО_Работники = СальдоИОборотыПоСчетамИСубконто(НастройкиПолученияБухитогов, СчетаДляРасчета, СубконтоДляРасчета);
	ОбщиеИтогиПоСчетам.Вставить("СиО_Работники", СиО_Работники);
	
	СчетаДляРасчета = "96.09";
	СубконтоДляРасчета = "Резервы";
	
	СиО_Резервы = СальдоИОборотыПоСчетамИСубконто(НастройкиПолученияБухитогов, СчетаДляРасчета, СубконтоДляРасчета);
	ОбщиеИтогиПоСчетам.Вставить("СиО_Резервы", СиО_Резервы);
	
	РазделятьАвансыПоВидамАктивов = ПараметрыЗаполнения.РазделятьАвансыПоВидамАктивов;
	
	СтруктураСКД_60_02 = РазделенноеСальдоСчетаУчетаАвансов2025(
		Счет("60.02"), КонецПериодаОтчета, РазделятьАвансыПоВидамАктивов, Организация);
	СтруктураСКД_60_22 = РазделенноеСальдоСчетаУчетаАвансов2025(
		Счет("60.22"), КонецПериодаОтчета, РазделятьАвансыПоВидамАктивов, Организация);
	СтруктураСКД_60_32 = РазделенноеСальдоСчетаУчетаАвансов2025(
		Счет("60.32"), КонецПериодаОтчета, РазделятьАвансыПоВидамАктивов, Организация);
	
	АвансыПоВидамАктивов = Новый Структура;
	АвансыПоВидамАктивов.Вставить("РазделятьАвансыПоВидамАктивов", РазделятьАвансыПоВидамАктивов);
	АвансыПоВидамАктивов.Вставить("СтруктураСКД_60_02", СтруктураСКД_60_02);
	АвансыПоВидамАктивов.Вставить("СтруктураСКД_60_22", СтруктураСКД_60_22);
	АвансыПоВидамАктивов.Вставить("СтруктураСКД_60_32", СтруктураСКД_60_32);
	
	ОбщиеИтогиПоСчетам.Вставить("АвансыПоВидамАктивов", АвансыПоВидамАктивов);
	
	Если ПараметрыЗаполнения.КлассифицироватьАктивыОбязательстваПоСрокам Тогда
		КонтекстРасчета = Новый Структура;
		Организации = Новый Массив;
		Организации.Добавить(ПараметрыЗаполнения.Организация);
		КонтекстРасчета.Вставить("Организации",   Организации);
		КонтекстРасчета.Вставить("Организация",   ПараметрыЗаполнения.Организация);
		КонтекстРасчета.Вставить("НачалоПериода", НачалоПериодаОтчета);
		КонтекстРасчета.Вставить("КонецПериода",      КонецПериодаОтчета);
		КонтекстРасчета.Вставить("КонецПериодаДата",  КонецПериодаОтчета.Дата);
		КонтекстРасчета.Вставить("РазделятьАвансыПоВидамАктивов", ПараметрыЗаполнения.РазделятьАвансыПоВидамАктивов);
		КонтекстРасчета.Вставить("ИспользуетсяВалютныйУчет",     ПараметрыЗаполнения.ИспользуетсяВалютныйУчет);
		КонтекстРасчета.Вставить("СчетаСРеквизитами",     ПараметрыЗаполнения.СчетаСРеквизитами);
		КонтекстРасчета.Вставить("СчетаСвернутоеСальдоКредиторская", КлассификацияЗадолженности.СчетаСвернутоеСальдоКредиторская());
		КонтекстРасчета.Вставить("КлассифицироватьАктивыОбязательстваПоСрокам", ПараметрыЗаполнения.КлассифицироватьАктивыОбязательстваПоСрокам);
		КонтекстРасчета.Вставить("ЭтоБалансНекоммерческойОрганизации", ПараметрыЗаполнения.ЭтоБалансНекоммерческойОрганизации);
		
		МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		КлассификацияЗадолженности.СоздатьВременныеТаблицыРасчетыПоАренде(МенеджерВременныхТаблиц, КонтекстРасчета);
		АвансыПоВидамАктивовСводно = АвансыПоВидамАктивовСводно(Организации, КонецПериодаОтчета, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивов);
		КлассификацияЗадолженности.СоздатьВременныеТаблицыОбщийНДСАвансовВыданных(МенеджерВременныхТаблиц, КонтекстРасчета, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивовСводно);
		КлассификацияЗадолженности.СоздатьВременныеТаблицыОбщийРезервПоСомнительнымДолгам(МенеджерВременныхТаблиц, КонтекстРасчета, РазделятьАвансыПоВидамАктивов, АвансыПоВидамАктивовСводно);

		ДанныеЗаполненияКредиторскаяЗадолженность = ДанныеЗаполненияКредиторскаяЗадолженность(МенеджерВременныхТаблиц, КонтекстРасчета);
		
		ОбщиеИтогиПоСчетам.Вставить("ДанныеЗаполненияДебиторскаяЗадолженность",  ДанныеЗаполненияДебиторскаяЗадолженность(МенеджерВременныхТаблиц, КонтекстРасчета));
		ОбщиеИтогиПоСчетам.Вставить("ДанныеЗаполненияКредиторскаяЗадолженность", ДанныеЗаполненияКредиторскаяЗадолженность.Задолженность);
		ОбщиеИтогиПоСчетам.Вставить("ДанныеЗаполненияРасчетыПоАренде",           ДанныеЗаполненияКредиторскаяЗадолженность.РасчетыПоАренде);
		ОбщиеИтогиПоСчетам.Вставить("ДанныеЗаполненияЗаемныеСредства",           ДанныеЗаполненияЗаемныеСредства(КонтекстРасчета));
	КонецЕсли;
	
	Возврат ОбщиеИтогиПоСчетам;
	
КонецФункции

Функция РазделенноеСальдоСчетаУчетаАвансов2025(СчетУчетаАвансов, КонецПериода, РазделятьАвансыПоВидамАктивов,
	Организация)
	
	СчетРезервов = Счет("63");
	СчетНДСАвансов = Счет("76.ВА");
	
	ВидыСубконто = Новый Массив;
	ВидыСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	ВидыСубконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Договоры);
	
	ВидыСубконтоСФ = Новый Массив;
	ВидыСубконтоСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты);
	ВидыСубконтоСФ.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.СФПолученные);
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыАктивовДляАвансов.Ссылка КАК ВидАктива
		|ПОМЕСТИТЬ ВТ_ВидыАктивовДляАвансов
		|ИЗ
		|	Перечисление.ВидыАктивовДляАвансов КАК ВидыАктивовДляАвансов
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(Перечисление.ВидыАктивовДляАвансов.ПустаяСсылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ХозрасчетныйОстатки.Счет КАК Счет,
		|	ХозрасчетныйОстатки.Субконто1 КАК Контрагент,
		|	ВТ_КонтрагентыДоговорыСФ.ДоговорКонтрагента КАК Договор,
		|	СУММА(ХозрасчетныйОстатки.СуммаОстатокКт) КАК СуммаОстатокКт
		|ПОМЕСТИТЬ ВТ_ВсеСФАвансов
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонПериода, Счет В (&СчетаНДСАвансов), &ВидыСубконтоСФ,
		|		Организация = &Организация) КАК ХозрасчетныйОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_КонтрагентыДоговорыСФ КАК ВТ_КонтрагентыДоговорыСФ
		|		ПО ХозрасчетныйОстатки.Субконто2 = ВТ_КонтрагентыДоговорыСФ.Ссылка
		|СГРУППИРОВАТЬ ПО
		|	ХозрасчетныйОстатки.Счет,
		|	ХозрасчетныйОстатки.Субконто1,
		|	ВТ_КонтрагентыДоговорыСФ.ДоговорКонтрагента
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Контрагент,
		|	Договор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ВЫРАЗИТЬ(ХозрасчетныйОстаткиОсновной.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВидАктива ЕСТЬ NULL
		|		ИЛИ НЕ &РазделятьАвансыПоВидамАктивов
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыАктивовДляАвансов.ПустаяСсылка)
		|		ИНАЧЕ ВЫРАЗИТЬ(ХозрасчетныйОстаткиОсновной.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВидАктива
		|	КОНЕЦ КАК ВидАктива,
		|	СУММА(ХозрасчетныйОстаткиОсновной.СуммаОстатокДт) КАК СуммаКонечныйОстатокДт,
		|	СУММА(ХозрасчетныйОстаткиРезервы.СуммаОстатокКт) КАК СуммаОстатокКтРезервы,
		|	СУММА(ВТ_ВсеСФАвансов.СуммаОстатокКт) КАК СуммаОстатокКтНДСАвансов
		|ПОМЕСТИТЬ ВТ_Сальдо
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Остатки(&КонПериода, Счет В (&СчетаУчета), &ВидыСубконто,
		|		Организация = &Организация) КАК ХозрасчетныйОстаткиОсновной
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Остатки(&КонПериода, Счет В (&СчетаРезервов), &ВидыСубконто,
		|			Организация = &Организация) КАК ХозрасчетныйОстаткиРезервы
		|		ПО ХозрасчетныйОстаткиОсновной.Субконто2 = ХозрасчетныйОстаткиРезервы.Субконто2
		|		И ХозрасчетныйОстаткиОсновной.Субконто1 = ХозрасчетныйОстаткиРезервы.Субконто1
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВсеСФАвансов КАК ВТ_ВсеСФАвансов
		|		ПО ХозрасчетныйОстаткиОсновной.Субконто2 = ВТ_ВсеСФАвансов.Договор
		|		И ХозрасчетныйОстаткиОсновной.Субконто1 = ВТ_ВсеСФАвансов.Контрагент
		|СГРУППИРОВАТЬ ПО
		|	ВЫБОР
		|		КОГДА ВЫРАЗИТЬ(ХозрасчетныйОстаткиОсновной.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВидАктива ЕСТЬ NULL
		|		ИЛИ НЕ &РазделятьАвансыПоВидамАктивов
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыАктивовДляАвансов.ПустаяСсылка)
		|		ИНАЧЕ ВЫРАЗИТЬ(ХозрасчетныйОстаткиОсновной.Субконто2 КАК Справочник.ДоговорыКонтрагентов).ВидАктива
		|	КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВидыАктивовДляАвансов.ВидАктива КАК ВидАктива,
		|	ЕСТЬNULL(ВТ_Сальдо.СуммаКонечныйОстатокДт, 0) КАК СуммаКонечныйОстатокДт,
		|	ЕСТЬNULL(ВТ_Сальдо.СуммаОстатокКтРезервы, 0) КАК СуммаОстатокКтРезервы,
		|	ЕСТЬNULL(ВТ_Сальдо.СуммаОстатокКтНДСАвансов, 0) КАК СуммаОстатокКтНДСАвансов
		|ИЗ
		|	ВТ_ВидыАктивовДляАвансов КАК ВТ_ВидыАктивовДляАвансов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Сальдо КАК ВТ_Сальдо
		|		ПО ВТ_ВидыАктивовДляАвансов.ВидАктива = ВТ_Сальдо.ВидАктива";
	
	ПараметрыДополнения = ЗаполнениеБухгалтерскойОтчетностиИтоги.НовыеПараметрыДополненияТекстаЗапросаПоДоговорамСчетовФактур();
	ПараметрыДополнения.Организация = Организация;
	ПараметрыДополнения.КонецПериода = Новый Граница(КонецПериода, ВидГраницы.Включая);
	ПараметрыДополнения.СчетаСоСчетамиФактурами.Добавить(СчетНДСАвансов);
	ПараметрыДополнения.ВидСчетовФактур = "СФПолученные";
	
	ЗаполнениеБухгалтерскойОтчетностиИтоги.ДополнитьТекстЗапросаПоДоговорамСчетовФактур(Запрос, ПараметрыДополнения);
	
	Запрос.УстановитьПараметр("КонПериода", Новый Граница(КонецПериода, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Организация", Организация);
