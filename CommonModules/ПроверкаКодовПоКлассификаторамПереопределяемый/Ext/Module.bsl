// см. ПроверкаКодовПоКлассификаторам.ВыполнитьПроверкуКодБК
//
Процедура ПриПроверкеКодаБК(РезультатПроверки, ПараметрыПроверки) Экспорт
	
	ТекстОшибки = ПлатежиВБюджетКлиентСервер.УведомлениеПроверитьКБК(ПараметрыПроверки.КБК, ПараметрыПроверки.Дата);
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		РезультатПроверки.Успешно = Ложь;
		РезультатПроверки.ТекстОшибки = ТекстОшибки;
		Возврат;
	КонецЕсли;
	
	РезультатПроверки.Успешно = Истина;
	РезультатПроверки.ТекстОшибки = "";
	
КонецПроцедуры

