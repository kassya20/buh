#Область ПрограммныйИнтерфейс
 
// Обработчик действия написать telegram.
// 
// Параметры:
//  КонтактнаяИнформация - СправочникСсылка.ВидыКонтактнойИнформации, Строка - Вид контактной информации телефона
//  	или представление контактной информации
//  ДополнительныеПараметры - Структура - Дополнительные параметры
Процедура ОбработчикДействияНаписатьTelegram(КонтактнаяИнформация, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ТипЗнч(КонтактнаяИнформация) = Тип("Строка") Тогда
		ПервыйСимвол = Лев(КонтактнаяИнформация, 1);
		Если ПервыйСимвол = "@" Тогда
			Подстановка = Прав(КонтактнаяИнформация, СтрДлина(КонтактнаяИнформация) - 1);
		Иначе
			Подстановка = КонтактнаяИнформацияБЗККлиентСервер.НомерТелефонаВМеждународномФормате(КонтактнаяИнформация);
		КонецЕсли;
	ИначеЕсли ТипЗнч(КонтактнаяИнформация) = Тип("СправочникСсылка.ВидыКонтактнойИнформации") Тогда
		ПредставлениеКИ = КонтактнаяИнформацияБЗКВызовСервера.ПредставлениеКонтактнойИнформации(КонтактнаяИнформация);
		НомерТелефона = КонтактнаяИнформацияБЗККлиентСервер.НомерТелефонаВМеждународномФормате(ПредставлениеКИ);
		Подстановка = НомерТелефона;
	ИначеЕсли ТипЗнч(КонтактнаяИнформация) = Тип("Структура") Тогда
		КонтактнаяИнформация.Свойство("Представление", ПредставлениеКИ);
		Если Не ЗначениеЗаполнено(ПредставлениеКИ) Тогда
			Возврат;
		КонецЕсли;
		НомерТелефона = КонтактнаяИнформацияБЗККлиентСервер.НомерТелефонаВМеждународномФормате(ПредставлениеКИ);
		Подстановка = НомерТелефона;
	Иначе
		Возврат;
	КонецЕсли;
	
	Ссылка = СтрШаблон("https://t.me/%1", Подстановка);
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(Ссылка);
	
КонецПроцедуры

#КонецОбласти