#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПроинициализироватьФорму()
	
	Если ВоинскийУчетПрежняя = Неопределено Тогда
		РедактированиеПериодическихСведений.ПрочитатьЗаписьДляРедактированияВФорме(ЭтотОбъект, "ВоинскийУчет", ФизическоеЛицоСсылка);
	КонецЕсли;
	
	ОбновитьПолеВоинскийУчетПериод(ЭтотОбъект, ТекущаяДатаСеанса());
	ОбновитьПолеЗабронированОрганизацией();
	ОбновитьДокументВоинскогоУчета();
	
	ЗаполнитьДанныеСверкиСДокументамиВоинскогоУчета();
	ЗаполнитьДанныеСверкиСВоеннымКомиссариатом();
	ЗаполнитьПредполагаемуюДатуСнятияСВоинскогоУчета();
	ЗаполнитьТекстПредупрежденияПользователю();
	
	УстановитьСвойстваЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИЗакрыть(Результат, ДополнительныеПараметры) Экспорт 
	
	СохранитьИЗакрытьНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИЗакрытьНаКлиенте(ЗакрытьФорму = Истина) Экспорт 

	Если НЕ ТолькоПросмотр Тогда
		ТекущийЭлемент = Элементы.ФормаОк;
	КонецЕсли; 
	
	ДополнительныеПараметры = Новый Структура("ЗакрытьФорму", ЗакрытьФорму);
	
	Оповещение = Новый ОписаниеОповещения("СохранитьИЗакрытьНаКлиентеЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	СохранитьДанные(Ложь, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанные(Отказ, ОповещениеЗавершения = Неопределено) Экспорт
	
	Если Не Модифицированность Тогда
		Если ОповещениеЗавершения <> Неопределено Тогда 
			ВыполнитьОбработкуОповещения(ОповещениеЗавершения, Отказ);
		КонецЕсли;
		Возврат;
	КонецЕсли; 
		
	ЗапроситьРежимИзмененияВоинскийУчет(ВоинскийУчет.Период, Отказ, ОповещениеЗавершения);

КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьРежимИзмененияВоинскийУчет(ДатаИзменения, Отказ, ОповещениеЗавершения)
	
	ТекстКнопкиДа = НСтр("ru = 'Изменились сведения о воинском учете'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru =  'При редактировании изменены сведения о воинском учете.
						|Если исправлена прежняя запись о воинском учете (она была ошибочной), нажмите ""Исправлена ошибка"".
						|Если у сотрудника изменились сведения с %1, нажмите'") + " ""%2""",
			Формат(ДатаИзменения, "ДФ='д ММММ гггг ""г""'"),
			ТекстКнопкиДа);
			
	Оповещение = Новый ОписаниеОповещения("ЗапроситьРежимИзмененияДокументВоинскогоУчета", ЭтотОбъект, ОповещениеЗавершения);		
	РедактированиеПериодическихСведенийКлиент.ЗапроситьРежимИзмененияРегистра(ЭтотОбъект, "ВоинскийУчет", ТекстВопроса, ТекстКнопкиДа, Отказ, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьРежимИзмененияДокументВоинскогоУчета(Результат, ОповещениеЗавершения) Экспорт 
	
	Отказ = Результат = Неопределено;
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	
	ТекстКнопкиДа = НСтр("ru = 'Изменились сведения'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru =  'При редактировании изменены сведения о документе воинского учета.
						|Если исправлена прежняя запись (она была ошибочной), нажмите ""Исправлена ошибка"".
						|Если у сотрудника изменились сведения с %1, нажмите'") + " ""%2""",
			Формат(ДокументыФизическихЛиц.Период, "ДФ='д ММММ гггг ""г""'"),
			ТекстКнопкиДа);
			
	Оповещение = Новый ОписаниеОповещения("СохранитьДанныеЗавершение", ЭтотОбъект, ОповещениеЗавершения);		
	РедактированиеПериодическихСведенийКлиент.ЗапроситьРежимИзмененияРегистра(ЭтотОбъект, "ДокументыФизическихЛиц", ТекстВопроса, ТекстКнопкиДа, Отказ, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанныеЗавершение(Отказ, ОповещениеЗавершения) Экспорт  
	
	Если Не Отказ Тогда
		
		Если ПроверитьЗаполнение() Тогда
			
			ВозвращаемыйПараметр = Новый Структура;
			ВозвращаемыйПараметр.Вставить("ИмяФормы", ИмяФормы);
			ВозвращаемыйПараметр.Вставить("АдресВХранилище", АдресДанныхДополнительнойФормыНаСервере(СотрудникиКлиентСервер.ОписаниеДополнительнойФормы(ИмяФормы)));
			
			Оповестить(
				"ИзмененыДанныеДополнительнойФормы",
				ВозвращаемыйПараметр,
				ВладелецФормы);
			
		Иначе
			Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли; 
	
	Если ОповещениеЗавершения <> Неопределено Тогда 
		ВыполнитьОбработкуОповещения(ОповещениеЗавершения, Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИЗакрытьНаКлиентеЗавершение(Отказ, ДополнительныеПараметры) Экспорт 

	Если Не Отказ И Открыта() Тогда
		
		Модифицированность = Ложь;
		Если ДополнительныеПараметры.ЗакрытьФорму Тогда
			Закрыть();
		КонецЕсли; 
		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейПериодическихСведений(ИмяРегистра, ВедущийОбъект) Экспорт
	
	РедактированиеПериодическихСведений.ПрочитатьНаборЗаписей(ЭтотОбъект, ИмяРегистра, ВедущийОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПолеЗабронированОрганизацией()

	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("ФизическоеЛицо", ФизическоеЛицоСсылка);
	
	ДанныеБронирования = РегистрыСведений.БронированиеСотрудников.СрезПоследних(, СтруктураОтбора);
	Если ДанныеБронирования.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ЗабронированОрганизацией = ДанныеБронирования[0].Организация;
	Если ТипЗнч(ДанныеБронирования[0].Регистратор) = Тип("ДокументСсылка.ПриказОБронированииРаботников") Тогда 
		ПриказОБронировании = ДанныеБронирования[0].Регистратор;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВоинскийУчетПоУмолчанию(ВоинскийУчет) Экспорт
	
	Возврат (НЕ ЗначениеЗаполнено(ВоинскийУчет.ОтношениеКВоинскойОбязанности)
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.КатегорияЗапаса)
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.Звание)
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.Состав)
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.ВУС)
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.Годность)
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.Военкомат)
		И НЕ ВоинскийУчет.НаличиеМобпредписания
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.НомерКомандыПартии)
		И НЕ ЗначениеЗаполнено(ВоинскийУчет.ПунктПеречня));
		
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьПолеВоинскийУчетПериод(Форма, ДатаСеанса) Экспорт
	// Не обязательно заполнение поля Период если данные по умолчанию.
	Если ВоинскийУчетПоУмолчанию(Форма.ВоинскийУчет) И 
		НЕ ЗначениеЗаполнено(Форма.ВоинскийУчетПрежняя.Период) Тогда
		Если ЗначениеЗаполнено(Форма.ВоинскийУчет.Период) Тогда
			Форма.ВоинскийУчет.Период = '00010101';
		КонецЕсли; 
	Иначе
		Если НЕ ЗначениеЗаполнено(Форма.ВоинскийУчет.Период) Тогда
			Форма.ВоинскийУчет.Период = ДатаСеанса;
		КонецЕсли; 
	КонецЕсли;
	
	РедактированиеПериодическихСведенийКлиентСервер.ОбновитьОтображениеПолейВвода(Форма, "ВоинскийУчет", Форма.ФизическоеЛицоСсылка);
	
КонецПроцедуры

&НаСервере
Функция АдресДанныхДополнительнойФормыНаСервере(ОписаниеДополнительнойФормы)
	
	СохранитьДанныеДокументаВоинскогоУчета();
	
	Возврат СотрудникиФормы.АдресДанныхДополнительнойФормы(ОписаниеДополнительнойФормы, ЭтотОбъект);
	
КонецФункции

&НаСервере
Процедура СохранитьДанныеДокументаВоинскогоУчета()
	
	КлючевыеСвойства = СтрРазделить("Период,ВидДокумента", ",");
	
	КлючевыеСвойстваЗаполнены = Истина;
	Для Каждого КлючевоеСвойство Из КлючевыеСвойства Цикл 
		Если Не ЗначениеЗаполнено(ДокументыФизическихЛиц[КлючевоеСвойство]) Тогда 
			КлючевыеСвойстваЗаполнены = Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ДокументыФизическихЛицНоваяЗапись Тогда
		Если КлючевыеСвойстваЗаполнены Тогда 
	        НаборЗаписей = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Физлицо.Установить(ФизическоеЛицоСсылка);
			Для Каждого КлючевоеСвойство Из КлючевыеСвойства Цикл
				НаборЗаписей.Отбор[КлючевоеСвойство].Установить(ДокументыФизическихЛиц[КлючевоеСвойство]); 
			КонецЦикла;
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, ДокументыФизическихЛиц);
			НоваяЗапись.Физлицо = ФизическоеЛицоСсылка;
			НаборЗаписей.Записать();
		КонецЕсли;
	    Возврат;
	КонецЕсли;
	
	ИзменилисьДанные = Ложь;
	Если ДокументыФизическихЛицПрежняя <> Неопределено Тогда 
		Для Каждого КлючИЗначение Из ДокументыФизическихЛицПрежняя Цикл 
			Если КлючИЗначение.Значение <> ДокументыФизическихЛиц[КлючИЗначение.Ключ] Тогда 
				ИзменилисьДанные = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ИзменилисьДанные Тогда
		ПрежниеКлючевыеСвойстваЗаполнены = Истина;
		Для Каждого КлючевоеСвойство Из КлючевыеСвойства Цикл 
			Если Не ЗначениеЗаполнено(ДокументыФизическихЛицПрежняя[КлючевоеСвойство]) Тогда 
				ПрежниеКлючевыеСвойстваЗаполнены = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ПрежниеКлючевыеСвойстваЗаполнены Тогда
	        НаборЗаписей = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Физлицо.Установить(ФизическоеЛицоСсылка);
			Для Каждого КлючевоеСвойство Из КлючевыеСвойства Цикл
				НаборЗаписей.Отбор[КлючевоеСвойство].Установить(ДокументыФизическихЛицПрежняя[КлючевоеСвойство]); 
			КонецЦикла;
			НаборЗаписей.Записать();
		КонецЕсли;
		Если КлючевыеСвойстваЗаполнены Тогда 
	        НаборЗаписей = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Физлицо.Установить(ФизическоеЛицоСсылка);
			Для Каждого КлючевоеСвойство Из КлючевыеСвойства Цикл
				НаборЗаписей.Отбор[КлючевоеСвойство].Установить(ДокументыФизическихЛиц[КлючевоеСвойство]); 
			КонецЦикла;
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, ДокументыФизическихЛиц);
			НоваяЗапись.Физлицо = ФизическоеЛицоСсылка;
			НаборЗаписей.Записать();
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ОтношениеКВоинскойОбязанностиПриИзмененииНаСервере()
	
	ЗаполнитьПредполагаемуюДатуСнятияСВоинскогоУчета();
	УстановитьСвойстваЭлементовФормы();
	
КонецПроцедуры

&НаСервере
Процедура ВоинскийУчетЗваниеПриИзмененииНаСервере()
	
	ВоинскийУчет.Состав = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВоинскийУчет.Звание, "Состав");
	ВоинскийУчетСоставПриИзмененииНаСервере();
	ЗаполнитьПредполагаемуюДатуСнятияСВоинскогоУчета();
	УстановитьСвойстваЭлементовФормы(); 
	
КонецПроцедуры
	
&НаСервере
Процедура ВоинскийУчетСоставПриИзмененииНаСервере()

	УстановитьСвойстваЭлементовФормы();
	
	Если ЗначениеЗаполнено(ВоинскийУчет.Состав)  
		И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВоинскийУчет.Состав, "ОфицерскийСостав") = Истина Тогда 
		ВоинскийУчет.КатегорияЗапаса = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВоинскийУчетОтношениеКВоинскомуУчетуПриИзмененииНаСервере()
	
	Если ВоинскийУчет.ОтношениеКВоинскомуУчету <> Перечисления.ОтношениеКВоинскомуУчету.СнятПоВозрасту 
		И ВоинскийУчет.ОтношениеКВоинскомуУчету <> Перечисления.ОтношениеКВоинскомуУчету.СнятПоСостояниюЗдоровья Тогда 
		ВоинскийУчет.ДатаСнятияСВоинскогоУчета = Дата(1, 1, 1);
	КонецЕсли;
	
	УстановитьСвойстваЭлементовФормы();
	
КонецПроцедуры

&НаСервере
Процедура ДокументыФизическихЛицВидДокументаПриИзмененииНаСервере()
	
	ЗаполнитьТекстПредупрежденияПользователю();
	УстановитьСвойстваЭлементовФормы();
	
КонецПроцедуры

&НаКлиенте
Функция ВоинскийУчетЗаблокироватьФизическоеЛицо()
	
	Если Не ЗаблокироватьОбъектВФормеВладельце() Тогда
		
		ЗаполнитьЗначенияСвойств(ВоинскийУчет, ВоинскийУчетПрежняя);
		Возврат Ложь;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
Функция ЗаблокироватьОбъектВФормеВладельце() Экспорт
	
	Возврат СотрудникиКлиент.ЗаблокироватьОбъектВФормеВладельцеДополнительнойФормы(ЭтотОбъект, ИзФормыСотрудника);
	
КонецФункции

&НаСервере
Процедура УстановитьСвойстваЭлементовФормы()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, 
		"ВоинскийУчетДатаСнятияСВоинскогоУчета", 
		"ТолькоПросмотр", 
		ВоинскийУчет.ОтношениеКВоинскомуУчету <> Перечисления.ОтношениеКВоинскомуУчету.СнятПоВозрасту 
			И ВоинскийУчет.ОтношениеКВоинскомуУчету <> Перечисления.ОтношениеКВоинскомуУчету.СнятПоСостояниюЗдоровья);
	
	ОфицерскийСостав = Ложь;
	Если ЗначениеЗаполнено(ВоинскийУчет.Состав) Тогда 
		ОфицерскийСостав = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВоинскийУчет.Состав, "ОфицерскийСостав");
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВоинскийУчетКатегорияЗапаса", "Доступность", Не ОфицерскийСостав);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВоинскийУчетКатегорияЗапаса", "АвтоОтметкаНезаполненного", 
		Не ОфицерскийСостав И ВоинскийУчет.ОтношениеКВоинскойОбязанности = Перечисления.ОтношениеКВоинскойОбязанности.Военнообязанный);
		
	Если ОфицерскийСостав Или ВоинскийУчет.ОтношениеКВоинскойОбязанности <> Перечисления.ОтношениеКВоинскойОбязанности.Военнообязанный Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВоинскийУчетКатегорияЗапаса", "ОтметкаНезаполненного", Ложь);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, 
		"ГруппаДокументВоинскогоУчета", "Видимость", ОбщегоНазначения.СсылкаСуществует(ФизическоеЛицоСсылка));
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"НадписьПредполагаемаяДатаСнятияСВоинскогоУчета", "Заголовок", Формат(ПредполагаемаяДатаСнятияСВоинскогоУчета, "ДЛФ=Д"));
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"НадписьПредполагаемаяДатаСнятияСВоинскогоУчета", "ЦветТекста", 
		?(ПредполагаемаяДатаСнятияСВоинскогоУчета > ТекущаяДатаСеанса(), ЦветаСтиля.ПоясняющийТекст, ЦветаСтиля.ПоясняющийОшибкуТекст));
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ГруппаПредупреждениеПользователю", "Видимость", ЗначениеЗаполнено(ТекстПредупрежденияПользователю));
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"НадписьПредупреждениеПользователю", "Заголовок", ТекстПредупрежденияПользователю);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДокументВоинскогоУчета()
	
	Если Не ЗначениеЗаполнено(ФизическоеЛицоСсылка) Тогда 
		Возврат;
	КонецЕсли;
	
	РедактированиеПериодическихСведений.ИнициализироватьЗаписьДляРедактированияВФорме(ЭтаФорма, "ДокументыФизическихЛиц", ФизическоеЛицоСсылка);
	
	МенеджерЗаписи = РегистрыСведений.ДокументыФизическихЛиц.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Физлицо = ФизическоеЛицоСсылка;
	
	ДокументыФизическогоЛица = ОбщегоНазначения.ОбщийМодуль("ВоинскийУчет").ДокументыВоинскогоУчетаФизическихЛиц(ФизическоеЛицоСсылка, Истина);
	Если ДокументыФизическогоЛица.Количество() > 0 Тогда 
		МенеджерЗаписи.Период = ДокументыФизическогоЛица[0].ПериодЗаписи;
		МенеджерЗаписи.ВидДокумента = ДокументыФизическогоЛица[0].ВидДокумента;
	КонецЕсли;
	
	МенеджерЗаписи.Прочитать();
	ЗначениеВРеквизитФормы(МенеджерЗаписи, "ДокументыФизическихЛиц");
	
	МетаданныеРегистра = Метаданные.РегистрыСведений.ДокументыФизическихЛиц;
	ДанныеДокумента = ОбщегоНазначения.СтруктураПоМенеджеруЗаписи(МенеджерЗаписи, МетаданныеРегистра);
	
	ДокументыФизическихЛицПрежняя = Новый ФиксированнаяСтруктура(ДанныеДокумента);
	ДокументыФизическихЛицНоваяЗапись = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеСверкиСДокументамиВоинскогоУчета()
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицоСсылка);
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДанныеСверкиСДокументамиВоинскогоУчета.Регистратор КАК Регистратор
		|ИЗ
		|	РегистрСведений.ДанныеСверкиСДокументамиВоинскогоУчета.СрезПоследних(, ФизическоеЛицо = &ФизическоеЛицо) КАК ДанныеСверкиСДокументамиВоинскогоУчета";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		СверкаСДокументамиВоинскогоУчета = Выборка.Регистратор;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
