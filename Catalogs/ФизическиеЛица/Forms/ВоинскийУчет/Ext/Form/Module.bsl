КонецПроцедуры

&НаКлиенте
Процедура СоздатьИзвещениеОПриемеИлиУвольнении(Команда)
	
	ДатаОкончания = ОбщегоНазначенияКлиент.ДатаСеанса() + 86400 * 3;
	ДатаНачала = ДатаОкончания - 86400 * 7;
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Организация", ОрганизацияСсылка);
	ЗначенияЗаполнения.Вставить("НачалоПериода", ДатаНачала);
	ЗначенияЗаполнения.Вставить("ОкончаниеПериода", ДатаОкончания);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	ПараметрыФормы.Вставить("ФизическоеЛицо", ФизическоеЛицоСсылка);
	ПараметрыФормы.Вставить("ЗаполнитьПриОткрытии", Истина);
	
	ОткрытьФорму("Документ.ИзвещениеОПриемеИлиУвольненииДляВоенкомата.ФормаОбъекта", ПараметрыФормы);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЛистокСообщенияОбИзменениях(Команда)
	
	ЗначенияЗаполнения = Новый Структура;
	ЗначенияЗаполнения.Вставить("Организация", ОрганизацияСсылка);
	ЗначенияЗаполнения.Вставить("Сотрудник", СотрудникСсылка);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	ОткрытьФорму("Документ.ЛистокСообщенияДляВоенкомата.ФормаОбъекта", ПараметрыФормы);
	
КонецПроцедуры

&НаКлиенте
Процедура СверкаСДокументамиВоинскогоУчетаСоздать(Команда)
	
	Если Не ЗначениеЗаполнено(ФизическоеЛицоСсылка) Тогда 
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("Не заполнено физическое лицо."));
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Основание", ФизическоеЛицоСсылка);
	
	ОткрытьФорму("Документ.СверкаСДокументамиВоинскогоУчета.ФормаОбъекта", ПараметрыФормы, ЭтаФорма);
	
