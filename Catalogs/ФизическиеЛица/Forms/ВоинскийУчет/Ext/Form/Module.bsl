КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПредполагаемуюДатуСнятияСВоинскогоУчета()
	
	ПредполагаемаяДатаСнятияСВоинскогоУчета = Неопределено;
	
	РассчитатьДатуСнятияСУчета = Не ЗначениеЗаполнено(ВоинскийУчет.ДатаСнятияСВоинскогоУчета)
		И ВоинскийУчет.ОтношениеКВоинскойОбязанности = Перечисления.ОтношениеКВоинскойОбязанности.Военнообязанный
		И ЗначениеЗаполнено(ВоинскийУчет.Звание);
	
	Если Не РассчитатьДатуСнятияСУчета Тогда
		ЗаполнитьТекстПредупрежденияПользователю();
		Возврат;
	КонецЕсли;
	
	ДанныеСотрудника = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ФизическоеЛицоСсылка, "Пол, ДатаРождения");
	ДанныеЗвания = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВоинскийУчет.Звание, 
		"ПредельныйВозрастПребыванияВЗапасеМужчин, ПредельныйВозрастПребыванияВЗапасеЖенщин");
	
	Если ДанныеСотрудника.Пол = Перечисления.ПолФизическогоЛица.Мужской
		И ЗначениеЗаполнено(ДанныеЗвания.ПредельныйВозрастПребыванияВЗапасеМужчин) Тогда 
		ПредполагаемаяДатаСнятияСВоинскогоУчета = ДобавитьМесяц(ДанныеСотрудника.ДатаРождения, ДанныеЗвания.ПредельныйВозрастПребыванияВЗапасеМужчин * 12);   
		Если ДанныеЗвания.ПредельныйВозрастПребыванияВЗапасеМужчин = 55 Тогда 
			Если Год(ДанныеСотрудника.ДатаРождения) + 50 < 2024 Тогда
				ПредполагаемаяДатаСнятияСВоинскогоУчета = ДобавитьМесяц(ДанныеСотрудника.ДатаРождения, 50 * 12);
			ИначеЕсли Год(ДанныеСотрудника.ДатаРождения) + 50 = 2024 Тогда
				ПредполагаемаяДатаСнятияСВоинскогоУчета = ДобавитьМесяц(ДанныеСотрудника.ДатаРождения, 51 * 12);
			ИначеЕсли Год(ДанныеСотрудника.ДатаРождения) + 50 = 2025 Тогда
				ПредполагаемаяДатаСнятияСВоинскогоУчета = ДобавитьМесяц(ДанныеСотрудника.ДатаРождения, 52 * 12);
			ИначеЕсли Год(ДанныеСотрудника.ДатаРождения) + 50 = 2026 Тогда
				ПредполагаемаяДатаСнятияСВоинскогоУчета = ДобавитьМесяц(ДанныеСотрудника.ДатаРождения, 53 * 12);
			ИначеЕсли Год(ДанныеСотрудника.ДатаРождения) + 50 = 2027 Тогда
				ПредполагаемаяДатаСнятияСВоинскогоУчета = ДобавитьМесяц(ДанныеСотрудника.ДатаРождения, 54 * 12);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ДанныеСотрудника.Пол = Перечисления.ПолФизическогоЛица.Женский
		И ЗначениеЗаполнено(ДанныеЗвания.ПредельныйВозрастПребыванияВЗапасеЖенщин) Тогда
		ПредполагаемаяДатаСнятияСВоинскогоУчета = ДобавитьМесяц(ДанныеСотрудника.ДатаРождения, ДанныеЗвания.ПредельныйВозрастПребыванияВЗапасеЖенщин * 12); 
	КонецЕсли;
	
	ЗаполнитьТекстПредупрежденияПользователю();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстПредупрежденияПользователю()
	
	ТекстПредупрежденияПользователю = "";
	
	Если ДокументыФизическихЛиц.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.ВременноеУдостоверениеВзаменПриписногоУдостоверения
		Или ДокументыФизическихЛиц.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.УдостоверениеГражданинаПодлежащегоПризыву Тогда 
		ДатаРождения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФизическоеЛицоСсылка, "ДатаРождения");
		Если ДатаРождения <> Неопределено И ДобавитьМесяц(ДатаРождения, 30 * 12) <= ТекущаяДатаСеанса() Тогда 
			ТекстПредупрежденияПользователю = НСтр("ru = 'Необходимо актуализировать документ воинского учета по достижении 30 лет.'");
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПредполагаемаяДатаСнятияСВоинскогоУчета)
		И ПредполагаемаяДатаСнятияСВоинскогоУчета <= ТекущаяДатаСеанса() Тогда 
		ТекстПредупрежденияПользователю = НСтр("ru = 'Сотрудник достиг предельного возраста пребывания в запасе. Необходимо снять его с воинского учета.'");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСоответствиеДанныхУчета()
	
	Если (ВоинскийУчет.ОтношениеКВоинскомуУчету = ПредопределенноеЗначение("Перечисление.ОтношениеКВоинскомуУчету.СнятПоВозрасту") 
			Или ВоинскийУчет.ОтношениеКВоинскомуУчету = ПредопределенноеЗначение("Перечисление.ОтношениеКВоинскомуУчету.СнятПоСостояниюЗдоровья"))
		И ВоинскийУчет.ОтношениеКВоинскойОбязанности = ПредопределенноеЗначение("Перечисление.ОтношениеКВоинскойОбязанности.Военнообязанный") Тогда 
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Сотрудник не может быть одновременно военнообязанным и снятым с учета.'"), ,
			"ВоинскийУчет.ОтношениеКВоинскойОбязанности");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
