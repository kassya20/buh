КонецФункции

&НаКлиенте
Процедура ЗапроситьВнешнююСистему(ОписаниеМетода)
	
	УстановитьОтображениеДлительнойОперацииМетода(ОписаниеМетода.Имя, Истина);
	
	ДлительнаяОперация = НачатьЗапросВнешнейСистемы(ОписаниеМетода, УникальныйИдентификатор);
	
	ЗавершитьОжиданиеВнешнейСистемы(ДлительнаяОперация, ОписаниеМетода);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НачатьЗапросВнешнейСистемы(ОписаниеМетода, ИдентификаторФормы)
	
	ПараметрыВыполненияВФоне = ДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторФормы);
	ПараметрыВыполненияВФоне.КлючФоновогоЗадания         = Строка(ИдентификаторФормы);
	
	Если ВыполнятьСкрытно(ОписаниеМетода.Имя) Тогда
		ПараметрыВыполненияВФоне.ОжидатьЗавершение = 0;
	КонецЕсли;
	
	Если ОписаниеМетода.Имя = "ЗапроситьПоставляемоеОписаниеВнешнейСистемы" Тогда
		
		ПараметрыМетода = Новый Структура(
			"ИдентификаторСистемы",
			ОбменДаннымиСВнешнимиСистемамиБПКлиентСервер.ИдентификаторСистемыSmartway());
		
		ПараметрыВыполненияВФоне.НаименованиеФоновогоЗадания = 
			НСтр("ru = 'Проверка доступа к внешним системам'");
		
		Возврат ДлительныеОперации.ВыполнитьВФоне(
			"Справочники.НастройкиЗагрузкиДанныхВнешнихСистем.ЗапроситьПоставляемоеОписаниеВнешнейСистемы",
			ПараметрыМетода,
			ПараметрыВыполненияВФоне);
			
	ИначеЕсли ОписаниеМетода.Имя = "ПодключитьВнешнююСистемуВФоне" Тогда
		
		ПараметрыМетода = Новый Структура(
			"ИдентификаторСистемы",
			ОбменДаннымиСВнешнимиСистемамиБПКлиентСервер.ИдентификаторСистемыSmartway());
		
		ПараметрыВыполненияВФоне.НаименованиеФоновогоЗадания = 
			НСтр("ru = 'Получение кода разрешения доступа к данным внешней системы'");
		
		Возврат ДлительныеОперации.ВыполнитьВФоне(
			"Справочники.НастройкиЗагрузкиДанныхВнешнихСистем.ПодключитьВнешнююСистемуВФоне",
			ПараметрыМетода,
			ПараметрыВыполненияВФоне);
			
	ИначеЕсли ОписаниеМетода.Имя = "ОбновитьПоставляемоеОписаниеВнешнейСистемыВФоне" Тогда
		
		ПараметрыВыполненияВФоне.НаименованиеФоновогоЗадания = 
			НСтр("ru = 'Обновление описания внешней системы'");
		
		Возврат ДлительныеОперации.ВыполнитьВФоне(
			"Справочники.НастройкиЗагрузкиДанныхВнешнихСистем.ОбновитьПоставляемоеОписаниеВнешнейСистемыВФоне",
			ОписаниеМетода.Параметры,
			ПараметрыВыполненияВФоне);
			
	ИначеЕсли ОписаниеМетода.Имя = "ЗагрузитьВФоне" Тогда
		
		ПараметрыВыполненияВФоне.НаименованиеФоновогоЗадания = 
			НСтр("ru = 'Получение данных из внешней системы'");
		
		Возврат ДлительныеОперации.ВыполнитьВФоне(
			"Справочники.НастройкиЗагрузкиДанныхВнешнихСистем.ЗагрузитьВФоне",
			ОписаниеМетода.Параметры,
			ПараметрыВыполненияВФоне);
		
	ИначеЕсли ОписаниеМетода.Имя = "ЗапроситьАктивностьВнешнейСистемы" Тогда
		
		ПараметрыВыполненияВФоне.НаименованиеФоновогоЗадания = 
			НСтр("ru = 'Проверка активности внешней системы'");
		
		Возврат ДлительныеОперации.ВыполнитьВФоне(
			"Справочники.НастройкиЗагрузкиДанныхВнешнихСистем.ЗапроситьАктивностьВнешнейСистемы",
			ОписаниеМетода.Параметры,
			ПараметрыВыполненияВФоне);
			
	ИначеЕсли ОписаниеМетода.Имя = "ЗапроситьОтСервисаАктивностьВнешнейСистемы" Тогда
		
		ПараметрыВыполненияВФоне.НаименованиеФоновогоЗадания = 
			НСтр("ru = 'Проверка актуальности внешней системы'");
		
		Возврат ДлительныеОперации.ВыполнитьВФоне(
			"Справочники.НастройкиЗагрузкиДанныхВнешнихСистем.ЗапроситьОтСервисаАктивностьВнешнейСистемы",
			ОписаниеМетода.Параметры,
			ПараметрыВыполненияВФоне);
			
	ИначеЕсли ОписаниеМетода.Имя = "ЗапроситьОтключение" Тогда
		
		ПараметрыВыполненияВФоне.НаименованиеФоновогоЗадания = 
			НСтр("ru = 'Отключение внешней системы'");
		
		Возврат ДлительныеОперации.ВыполнитьВФоне(
			"Справочники.НастройкиЗагрузкиДанныхВнешнихСистем.ЗапроситьОтключение",
			ОписаниеМетода.Параметры,
			ПараметрыВыполненияВФоне);
		
	КонецЕсли;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЗавершитьЗапросВнешнейСистемы(ДлительнаяОперация, Форма, ОписаниеМетода)
	
	Ответ = Новый Структура;
	Ответ.Вставить("Получен",            Ложь);
	Ответ.Вставить("Содержание",         Неопределено);
	Ответ.Вставить("ДлительнаяОперация", Неопределено);
	
	Если ДлительнаяОперация = Неопределено Тогда
		// Пользователь уже закрыл форму
		Возврат Ответ;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Выполняется" Тогда
		
		Ответ.ДлительнаяОперация = ДлительнаяОперация;
		
		Если Не МожноПродолжатьБезИнтернетПоддержки(Форма.Настройка) Тогда
			ОтобразитьРазделДиалогаПолучение(Форма, "ДлительныйЗапрос");
		КонецЕсли;
		
		Возврат Ответ;
		
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус <> "Выполнено" Тогда
		
		Если ВыполнятьСкрытно(ОписаниеМетода.Имя) Тогда
			Возврат Ответ; // не показываем данные об ошибке
		КонецЕсли;
		
		// Ошибка
		Форма.ОписаниеМетодаОшибочногоДействия = ОписаниеМетода;
		Форма.Элементы.ПредставлениеОшибки.Заголовок = ДлительнаяОперация.КраткоеПредставлениеОшибки; // Используется декорация, так как она подстраивается под размер контента
		ОтобразитьРазделДиалогаПолучение(Форма, "Ошибка");
		Возврат Ответ; // вся информация отображена на форме
		
	КонецЕсли;
	
	Ответ.Содержание = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	
	Если Ответ.Содержание = "НетИнтернетПоддержки" Тогда
		Если Не МожноПродолжатьБезИнтернетПоддержки(Форма.Настройка) Тогда
			ОтобразитьРазделДиалогаПолучение(Форма, "ДлительныйЗапрос");
		КонецЕсли;
		Возврат Ответ;
	ИначеЕсли Ответ.Содержание = "Отключено" Тогда
		ОтобразитьРазделДиалогаПолучение(Форма, "Остановлено");
		Возврат Ответ;
	КонецЕсли;
	
	Ответ.Получен = Истина;
	Возврат Ответ;
	
КонецФункции

&НаКлиенте
Процедура ОжидатьРезультатЗапросаВнешнейСистемы(Ответ, ОписаниеМетода)
	
	// Ответ - результат ЗавершитьЗапросВнешнейСистемы
	
	Если Ответ.Содержание = "НетИнтернетПоддержки" Тогда
		
		// Попросим уточнить реквизиты и запустим повторно
		ИнтернетПоддержкаПользователейКлиент.ПодключитьИнтернетПоддержкуПользователей(
			Новый ОписаниеОповещения("ПриПодключенииИнтернетПоддержки", ЭтотОбъект, ОписаниеМетода),
			ЭтотОбъект);
		Возврат;
		
	ИначеЕсли Ответ.ДлительнаяОперация <> Неопределено Тогда
		
		// Начинаем ожидание
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		
		ОбработчикОжидания = Новый ОписаниеОповещения("ЗавершитьОжиданиеВнешнейСистемы", ЭтотОбъект, ОписаниеМетода);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(Ответ.ДлительнаяОперация, ОбработчикОжидания, ПараметрыОжидания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьОжиданиеВнешнейСистемы(ДлительнаяОперация, ОписаниеМетода) Экспорт // обработчик оповещения
	
	Ответ = ЗавершитьЗапросВнешнейСистемы(ДлительнаяОперация, ЭтотОбъект, ОписаниеМетода);
	
	Если Ответ.Получен Тогда
		УстановитьОтображениеДлительнойОперацииМетода(ОписаниеМетода.Имя, Ложь);
		ОтобразитьОтветВнешнейСистемы(Ответ.Содержание, ОписаниеМетода.Имя);
	Иначе
		ОжидатьРезультатЗапросаВнешнейСистемы(Ответ, ОписаниеМетода);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриПодключенииИнтернетПоддержки(РезультатПодключения, ОписаниеМетода) Экспорт // Обработчик оповещения
	
	Если РезультатПодключения = Неопределено Тогда
		Если Не МожноПродолжатьБезИнтернетПоддержки(Настройка) Тогда
			// Без интернет-поддержки форму невозможно использовать
			Закрыть();
		Иначе
			УстановитьОтображениеДлительнойОперацииМетода(ОписаниеМетода.Имя, Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ЗапроситьВнешнююСистему(ОписаниеМетода);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ВыгрузкаСпискаСотрудников

&НаСервереБезКонтекста
Процедура ВключитьВыключитьОтправкуДанныхНаСервере(Значение)
	
	Константы.ИспользоватьАвтоматическуюОтправкуСотрудниковБронированияКомандировок.Установить(Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ВключитьОтправкуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ВключитьОтправкуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ВключитьОтправкуНаСервере()
	
	ПроверитьНастройкиОтправки();
	ПрочитатьНастройкуОтправки();
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьНастройкиОтправки() Экспорт
	
	ОтправкаНастроена = ОтправкаНастроена(СистемаБронирования);
	ВключитьВыключитьОтправкуДанныхНаСервере(ОтправкаНастроена);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНастройкуОтправки()
	
	ОтправкаИспользуется = Константы.ИспользоватьАвтоматическуюОтправкуСотрудниковБронированияКомандировок.Получить();
	ОтправкаНастроена = ОтправкаНастроена(СистемаБронирования);
	Если ОтправкаИспользуется И ОтправкаНастроена Тогда
		НастройкиОтправкиСотрудников = НастройкиОтправкиСотрудников(СистемаБронирования);
		ДатаОтправки = НастройкиОтправкиСотрудников.ДатаПоследнейОперации;
		ОтобразитьРазделДиалогаОтправка(ЭтотОбъект, "ОтправкаВключено");
	Иначе
		ОтобразитьРазделДиалогаОтправка(ЭтотОбъект, "ОтправкаОтключено");
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НастройкиОтправкиСотрудников(СистемаБронирования)
	
	НастройкиОтправкиСотрудников = РегулярнаяОтправкаСотрудников.НастройкиОтправкиСотрудников(СистемаБронирования);
	Возврат НастройкиОтправкиСотрудников;
	
КонецФункции

&НаСервереБезКонтекста
Функция ОтправкаНастроена(СистемаБронирования)
	
	НастройкиSmartway = БронированиеКомандировок.НовыеНастройкиСистемыБронирования();
	БронированиеКомандировок.ЗаполнитьНастройкиСистемыБронирования(НастройкиSmartway, СистемаБронирования);
	
	ОтправкаНастроена = ЗначениеЗаполнено(НастройкиSmartway.Логин) И ЗначениеЗаполнено(НастройкиSmartway.Пароль);
	
	Возврат ОтправкаНастроена;
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_Отправить()
	
	ЗарегистрироватьИзмененияСотрудниковПринудительно(СистемаБронирования);
	НачатьОтправкуСотрудников();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗарегистрироватьИзмененияСотрудниковПринудительно(СистемаБронирования)
	
	НастройкиОтправкиСотрудников = НастройкиОтправкиСотрудников(СистемаБронирования);
	РезультатСохранения = РегулярнаяОтправкаСотрудников.СтруктураРезультатСохраненияНастройки();
	РегулярнаяОтправкаСотрудников.СохранитьНастройкиОтправкиСотрудников(НастройкиОтправкиСотрудников, РезультатСохранения);
	
	Сотрудники = РегулярнаяОтправкаСотрудников.СотрудникиБронированияКомандировок(СистемаБронирования, Неопределено, Неопределено, Неопределено);
	Если Сотрудники.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru = 'Данные для отправки не найдены.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	Иначе
		РегулярнаяОтправкаСотрудников.ЗарегистрироватьИзмененияСотрудниковПринудительно(СистемаБронирования);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьОтправкуСотрудников()
	
	РезультатВыполненияДлительнойОперации = Неопределено;
	ДлительнаяОперация = НачатьОтправкуСотрудниковНаСервере(УникальныйИдентификатор, СистемаБронирования);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьОтправкуСотрудников", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НачатьОтправкуСотрудниковНаСервере(ИдентификаторФормы, СистемаБронирования)
	
	ПараметрыПроцедуры = Новый Структура("СистемаБронирования, ФизическоеЛицо");
	ПараметрыПроцедуры.СистемаБронирования = СистемаБронирования;
	ПараметрыПроцедуры.ФизическоеЛицо = Неопределено;

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Отправка информации о сотрудниках в систему %1'"), Строка(СистемаБронирования));
		
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "РегулярнаяОтправкаСотрудников.ОтправитьСотрудниковВСистемуБронированияДлительнаяОперация",
		ПараметрыПроцедуры);

КонецФункции

&НаКлиенте
Процедура ЗавершитьОтправкуСотрудников(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если Результат.Статус = "Ошибка" Тогда
		Элементы.ОтправкаПредставлениеОшибки.Заголовок = Результат.КраткоеПредставлениеОшибки;
		ОтобразитьРазделДиалогаОтправка(ЭтотОбъект, "ОтправкаОшибка");
	Иначе
		РезультатОтправки = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		Если Не РезультатОтправки.Выполнено Тогда
			Элементы.ОтправкаПредставлениеОшибки.Заголовок = РезультатОтправки.ТекстОшибки;
			ОтобразитьРазделДиалогаОтправка(ЭтотОбъект, "ОтправкаОшибка");
		Иначе
			НастройкиОтправкиСотрудников = НастройкиОтправкиСотрудников(СистемаБронирования);
			ДатаОтправки = НастройкиОтправкиСотрудников.ДатаПоследнейОперации;
			ОтобразитьРазделДиалогаОтправка(ЭтотОбъект, "ОтправкаВключено");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОтобразитьРазделДиалогаОтправка(Форма, ИмяОтображаемогоРаздела)
	
	РазделыДиалога = Новый Массив;
	РазделыДиалога.Добавить("ОтправкаДлительныйЗапрос");
	РазделыДиалога.Добавить("ОтправкаОтключено");
	РазделыДиалога.Добавить("ОтправкаВключено");
	РазделыДиалога.Добавить("ОтправкаОшибка");
	
	Для Каждого ИмяЭлемента Из РазделыДиалога Цикл
		Форма.Элементы[ИмяЭлемента].Видимость = (ИмяЭлемента = ИмяОтображаемогоРаздела);
	КонецЦикла;
	
КонецПроцедуры

