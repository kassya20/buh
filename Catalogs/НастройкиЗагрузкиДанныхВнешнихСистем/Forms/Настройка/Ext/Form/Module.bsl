&НаКлиентеНаСервереБезКонтекста
Функция ОписаниеМетода(Имя, Параметры = Неопределено)
	
	ОписаниеМетода = Новый Структура;
	ОписаниеМетода.Вставить("Имя",       Имя);
	ОписаниеМетода.Вставить("Параметры", Параметры);
