#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ВидМаркетплейса") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
			Список, "ВидМаркетплейса", Параметры.ВидМаркетплейса, ВидСравненияКомпоновкиДанных.Равно,,Истина);
		Элементы.ДобавитьПодключение.Вид = ВидГруппыФормы.ГруппаКнопок;
		Элементы.ФормаДобавитьOzon.Видимость   = (Параметры.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.OZON);
		Элементы.ФормаДобавитьWB.Видимость     = (Параметры.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.Wildberries);
		Элементы.ФормаДобавитьЯндекс.Видимость = (Параметры.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.ЯндексМаркет);
		Элементы.ТокенДоступа.Видимость = (Параметры.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.Wildberries);
		Если Параметры.ВидМаркетплейса = Перечисления.ВидыМаркетплейсов.Wildberries Тогда
			Список.КомпоновщикНастроек.Настройки.ДополнительныеСвойства.Вставить("ПоказыватьИнформациюОТокенах", Истина);
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Свойство("СкрытьАвтозагрузку") Тогда
		СкрытьАвтозагрузку = Параметры.СкрытьАвтозагрузку;
	КонецЕсли;
	
	Элементы.ДобавитьПодключение.Видимость = ОбменСМаркетплейсВызовСервера.ДоступенОбменСМаркетплейс();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	СписокПриПолученииДанныхOzonНаСервере(ИмяЭлемента, Настройки, Строки);
	СписокПриПолученииДанныхWBНаСервере(ИмяЭлемента, Настройки, Строки);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьOzon(Команда)
	
	ОткрытьНастройкуМаркетплейса(ПредопределенноеЗначение("Перечисление.ВидыМаркетплейсов.OZON"));
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьWB(Команда)
	
	ОткрытьНастройкуМаркетплейса(ПредопределенноеЗначение("Перечисление.ВидыМаркетплейсов.Wildberries"));
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьЯндекс(Команда)
	
	ОткрытьНастройкуМаркетплейса(ПредопределенноеЗначение("Перечисление.ВидыМаркетплейсов.ЯндексМаркет"));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОткрытьНастройкуМаркетплейса(Маркетплейс)
	
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("ВидМаркетплейса", Маркетплейс);
	Если СкрытьАвтозагрузку Тогда
		ПараметрыФормы.Вставить("СкрытьАвтозагрузку", Истина);
	КонецЕсли;
		
	ОткрытьФорму("Справочник.НастройкиИнтеграцииМаркетплейс.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхOzonНаСервере(ИмяЭлемента, Настройки, Строки)
	
	МагазиныOzon = ИнтеграцияOzon.МагазиныOzon();
	Если Не ЗначениеЗаполнено(МагазиныOzon) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого МагазинOzon Из МагазиныOzon Цикл
		СтрокаСписка = Строки.Получить(МагазинOzon.Ключ);
		Если СтрокаСписка <> Неопределено Тогда
			СтрокаСписка.Оформление["Владелец"].УстановитьЗначениеПараметра("Текст", МагазинOzon.Значение);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхWBНаСервере(ИмяЭлемента, Настройки, Строки)
	
	// Колонку "ТокенДоступа" отображаем только для формы списка,
	// открытой с отбором по виду маркетплейса = Wildberries
	Если Не Настройки.ДополнительныеСвойства.Свойство("ПоказыватьИнформациюОТокенах") Тогда
		Возврат;
	КонецЕсли;
	
	СостоянияТокенов = ИнтеграцияWildberries.СостоянияТокенов();
	Если Не ЗначениеЗаполнено(СостоянияТокенов) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СостояниеТокена Из СостоянияТокенов Цикл
		СтрокаСписка = Строки.Получить(СостояниеТокена.Ключ);
		Если СтрокаСписка <> Неопределено Тогда
			СтрокаСписка.Данные.ТокенДоступа = СостояниеТокена.Значение.Состояние;
			Если СостояниеТокена.Значение.ЕстьОшибка Тогда
				СтрокаСписка.Оформление["ТокенДоступа"].УстановитьЗначениеПараметра(
					"ЦветТекста", ЦветаСтиля.РезультатПроблемаЦвет);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти