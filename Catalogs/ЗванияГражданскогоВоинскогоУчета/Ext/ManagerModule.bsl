// Процедура выполняет первоначальное заполнение классификатора.
Процедура НачальноеЗаполнение() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КлассификаторВоинскихЗваний.Ссылка КАК ОбщевойсковоеЗвание,
		|	ПРЕДСТАВЛЕНИЕ(КлассификаторВоинскихЗваний.Ссылка) КАК Наименование
		|ИЗ
		|	Перечисление.КлассификаторВоинскихЗваний КАК КлассификаторВоинскихЗваний
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЗванияГражданскогоВоинскогоУчета КАК ЗванияГражданскогоВоинскогоУчета
		|		ПО КлассификаторВоинскихЗваний.Ссылка = ЗванияГражданскогоВоинскогоУчета.ОбщевойсковоеЗвание
		|ГДЕ
		|	ЗванияГражданскогоВоинскогоУчета.Ссылка ЕСТЬ NULL 
		|
		|УПОРЯДОЧИТЬ ПО
		|	КлассификаторВоинскихЗваний.Порядок";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СоответствиеЗванийИСоставов = СоответствиеВоинскихЗванийИСоставов();
	ПредельныйВозрастЗваний = ПредельныйВозрастПребыванияВЗапасеВоинскихЗваний();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			СправочникОбъект = Справочники.ЗванияГражданскогоВоинскогоУчета.СоздатьЭлемент();
			ЗаполнитьЗначенияСвойств(СправочникОбъект, Выборка);
			СправочникОбъект.Состав = СоответствиеЗванийИСоставов[Выборка.ОбщевойсковоеЗвание];
			ПредельныйВозраст = ПредельныйВозрастЗваний[Выборка.ОбщевойсковоеЗвание];
			Если ПредельныйВозраст <> Неопределено Тогда 
				СправочникОбъект.ПредельныйВозрастПребыванияВЗапасеМужчин = ПредельныйВозраст.Мужчины;
				СправочникОбъект.ПредельныйВозрастПребыванияВЗапасеЖенщин = ПредельныйВозраст.Женщины;
			КонецЕсли;
			СправочникОбъект.Записать();
			
		КонецЦикла;
		
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗаполнитьПредельныйВозрастПребыванияВЗапасе(ПараметрыОбновления = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	ЗванияГражданскогоВоинскогоУчета.Ссылка КАК Ссылка,
		|	ЗванияГражданскогоВоинскогоУчета.ОбщевойсковоеЗвание КАК ОбщевойсковоеЗвание,
		|	ЕСТЬNULL(ЗванияГражданскогоВоинскогоУчета.Состав.ОфицерскийСостав, ЛОЖЬ) КАК ОфицерскийСостав
		|ИЗ
		|	Справочник.ЗванияГражданскогоВоинскогоУчета КАК ЗванияГражданскогоВоинскогоУчета
		|ГДЕ
		|	ЗванияГражданскогоВоинскогоУчета.ПредельныйВозрастПребыванияВЗапасеМужчин = 0
		|	И ЗванияГражданскогоВоинскогоУчета.ПредельныйВозрастПребыванияВЗапасеЖенщин = 0
		|	И ЗванияГражданскогоВоинскогоУчета.ОбщевойсковоеЗвание <> ЗНАЧЕНИЕ(Перечисление.КлассификаторВоинскихЗваний.ПустаяСсылка)";
	
	Если ПараметрыОбновления = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 1000", "");
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() = 0 Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	
	ПредельныйВозрастЗваний = ПредельныйВозрастПребыванияВЗапасеВоинскихЗваний();
	
	Пока Выборка.Следующий() Цикл 
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "Справочник.ЗванияГражданскогоВоинскогоУчета", "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		ВоинскоеЗвание = Выборка.Ссылка.ПолучитьОбъект();
		ПредельныйВозраст = ПредельныйВозрастЗваний[Выборка.ОбщевойсковоеЗвание];
		Если ПредельныйВозраст <> Неопределено Тогда 
			ВоинскоеЗвание.ПредельныйВозрастПребыванияВЗапасеМужчин = ПредельныйВозраст.Мужчины;
			ВоинскоеЗвание.ПредельныйВозрастПребыванияВЗапасеЖенщин = ПредельныйВозраст.Женщины;
		Иначе 
			ВоинскоеЗвание.ПредельныйВозрастПребыванияВЗапасеЖенщин = ?(Выборка.ОфицерскийСостав, 50, 45);
		КонецЕсли;
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ВоинскоеЗвание);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	КонецЦикла;
	
КонецПроцедуры

