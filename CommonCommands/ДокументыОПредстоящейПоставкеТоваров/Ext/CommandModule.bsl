
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)

	ПараметрыОткрытия = ОбщегоНазначенияБПКлиентСервер.ПараметрыОткрытияФормыСОжиданием(ПараметрыВыполненияКоманды);
	ПараметрыОткрытия.Заголовок               = НСтр("ru = 'Документы о предстоящей поставке товаров (ДОПП)'");
	ПараметрыОткрытия.ИмяФормы                = "Документ.ЗаявлениеОВвозеТоваров.ФормаСписка";
	ПараметрыОткрытия.Уникальность            = "ФормаСписка_ДОПП";
	ПараметрыОткрытия.ЗамерПроизводительности = "СозданиеФормыСпискаДОПП";
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Заголовок",  ПараметрыОткрытия.Заголовок);
	ПараметрыФормы.Вставить("ВидОперации", ПредопределенноеЗначение("Перечисление.ВидыОперацийВвозТоваровИзЕАЭС.ДОПП"));
	
	ОбщегоНазначенияБПКлиент.ОткрытьФормуСОжиданием(ПараметрыОткрытия, ПараметрыФормы);

КонецПроцедуры
