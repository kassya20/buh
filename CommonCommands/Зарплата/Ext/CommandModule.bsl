	ОценкаПроизводительностиКлиент.ЗамерВремени("ПростойИнтерфейсЗарплата", , Истина);
	
	ОткрытьФорму("ЖурналДокументов.ЖурналОпераций.Форма.ФормаСпискаОтражениеЗарплаты",
		,
		ПараметрыВыполненияКоманды.Источник,
		ПараметрыВыполненияКоманды.Уникальность,
		ПараметрыВыполненияКоманды.Окно,
		ПараметрыВыполненияКоманды.НавигационнаяСсылка);
		
КонецПроцедуры

