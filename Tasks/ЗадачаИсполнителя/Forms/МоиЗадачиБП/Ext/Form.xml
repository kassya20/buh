				<Field>Список.Ссылка</Field>
				<Field>Список.СтатусЗадачи</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ЗадачиПоИсполнителю.Ссылка КАК Ссылка,
	ЗадачиПоИсполнителю.ПометкаУдаления КАК ПометкаУдаления,
	ЗадачиПоИсполнителю.Номер КАК Номер,
	ЗадачиПоИсполнителю.Дата КАК Дата,
	ЗадачиПоИсполнителю.Наименование КАК Наименование,
	ЗадачиПоИсполнителю.Выполнена КАК Выполнена,
	ВЫБОР
		КОГДА ЗадачиПоИсполнителю.Важность = ЗНАЧЕНИЕ(Перечисление.ВариантыВажностиЗадачи.Высокая)
			ТОГДА 2
		ИНАЧЕ 1
	КОНЕЦ КАК ВажностьКартинка,
	ЗадачиПоИсполнителю.Важность КАК Важность,
	ЗадачиПоИсполнителю.ДатаИсполнения КАК ДатаИсполнения,
	ЗадачиПоИсполнителю.Автор КАК Автор,
	ЗадачиПоИсполнителю.Описание КАК Описание,
	ЗадачиПоИсполнителю.СрокИсполнения КАК СрокИсполнения,
	ЗадачиПоИсполнителю.СрокИсполнения КАК Время,
	ЗадачиПоИсполнителю.РезультатВыполнения КАК РезультатВыполнения,
	ЗадачиПоИсполнителю.Исполнитель КАК Исполнитель,
	ЗадачиПоИсполнителю.Важность КАК ПрикрепленныйФайл,
	ВЫБОР
		КОГДА ЗадачиПоИсполнителю.Автор = &amp;Пользователь
		ИЛИ ЗадачиПоИсполнителю.Исполнитель = &amp;Пользователь
		ИЛИ ЗадачиПоИсполнителю.Исполнитель = НЕОПРЕДЕЛЕНО
		И (ЗадачиПоИсполнителю.РольИсполнителя В (&amp;РолиИсполнителя)
		ИЛИ ЗадачиПоИсполнителю.ГруппаИсполнителейЗадач В (&amp;ГруппыИсполнителяЗадач))
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК МоиЗадачи,
	ЗадачиПоИсполнителю.ПринятаКИсполнению КАК ПринятаКИсполнению,
	ВЫБОР
		КОГДА ЧАС(ЗадачиПоИсполнителю.СрокИсполнения) = 23
		И МИНУТА(ЗадачиПоИсполнителю.СрокИсполнения) = 59
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ПоказыватьВремя,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА ИСТИНА
		КОГДА НаличиеФайлов.ЕстьФайлы
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ЕстьФайлы,
	ЗадачиПоИсполнителю.СтатусЗадачи КАК СтатусЗадачи,
	ВЫБОР
		КОГДА ЗадачиПоИсполнителю.ПометкаУдаления
			ТОГДА 2
		КОГДА ЗадачиПоИсполнителю.Выполнена
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК СтатусУдаленияВыполненияЗадачи,
	ЗадачиПоИсполнителю.РольИсполнителя КАК РольИсполнителя,
	ЗадачиПоИсполнителю.БизнесПроцесс КАК БизнесПроцесс,
	ЗадачиПоИсполнителю.БизнесПроцесс = Неопределено КАК ДоступноИзменениеСтатуса,
	ВЫБОР
		КОГДА ЗадачиПоИсполнителю.Предмет ССЫЛКА Справочник.КонтактныеЛица
		И ВЫРАЗИТЬ(ЗадачиПоИсполнителю.Предмет КАК Справочник.КонтактныеЛица).Лид
			ТОГДА ВЫРАЗИТЬ(ЗадачиПоИсполнителю.Предмет КАК Справочник.КонтактныеЛица)
		КОГДА ЗадачиПоИсполнителю.Предмет ССЫЛКА Справочник.Контрагенты
			ТОГДА ВЫРАЗИТЬ(ЗадачиПоИсполнителю.Предмет КАК Справочник.Контрагенты)
		ИНАЧЕ Неопределено
	КОНЕЦ КАК Клиент
ИЗ
	Задача.ЗадачаИсполнителя КАК ЗадачиПоИсполнителю
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ЗадачиПоИсполнителю.Ссылка = НаличиеФайлов.ОбъектСФайлами
ГДЕ
	(&amp;ВыбранныйИсполнитель ЕСТЬ NULL
	ИЛИ ЗадачиПоИсполнителю.Исполнитель = &amp;ВыбранныйИсполнитель
	ИЛИ ЗадачиПоИсполнителю.Исполнитель = НЕОПРЕДЕЛЕНО
	И (ЗадачиПоИсполнителю.РольИсполнителя В (&amp;РолиИсполнителя)
	ИЛИ ЗадачиПоИсполнителю.ГруппаИсполнителейЗадач В (&amp;ГруппыИсполнителяЗадач)))</QueryText>
