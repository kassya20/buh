&НаКлиенте
Процедура ОплатыВыбор(Таблица, ИдентификаторСтроки, Поле, СтандартнаяОбработка)
	ТекущаяСтрока = Таблица.ДанныеСтроки(ИдентификаторСтроки);
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если Поле.Имя = "ОплатыПолеРасшифровки" И Не ТекущаяСтрока.ЭтоРасшифровка И ТекущаяСтрока.ЕстьПодчиненные Тогда
		ОплатыРазвернутьВсе = Ложь;
		ОплатыСвернутьВсе = Ложь;
		ТекущаяСтрока.ВидимостьПодчиненных = Не ТекущаяСтрока.ВидимостьПодчиненных;
		ОбновитьЭлементыФормы();
	ИначеЕсли ТекущаяСтрока.ЭтоРасшифровка Или ТолькоПросмотр Тогда
		СсылочныеПоля = "ОплатыФизическоеЛицо, ОплатыСотрудник, ОплатыРебенок, ОплатыДокументОснование";
		Если СтрНайти(СсылочныеПоля, Поле.Имя) > 0 Тогда
			ПоказатьЗначение(,ТекущаяСтрока[СтрЗаменить(Поле.Имя, "Оплаты", "")]);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

