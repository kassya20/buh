Процедура ОчиститьДанныеОбОтправкеЗавершение(Ответ, ПараметрыВыполнения) Экспорт
	Если Ответ <> Неопределено И Ответ.Значение = КодВозвратаДиалога.Да Тогда
		ОчиститьДанныеОбОтправкеНаСервере();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОчиститьДанныеОбОтправкеНаСервере()
	Если Не ЗначениеЗаполнено(Объект.ДатаОтправки)
		И Не ЗначениеЗаполнено(Объект.ИдентификаторСообщения) Тогда
		Возврат;
	КонецЕсли;
	МенеджерРегистра = РегистрыСведений.РегистрацииЗаявленийОВозмещенииВыплатРодителямДетейИнвалидов;
	Набор = МенеджерРегистра.НачатьЗаписьНабора(Объект.ИдентификаторСообщения);
	Если Набор = Неопределено Или Набор.Количество() = 0 Тогда
		МенеджерРегистра.ОтменитьЗаписьНабора(Набор);
	Иначе
		Набор.Очистить();
		МенеджерРегистра.ЗавершитьЗаписьНабора(Набор);
	КонецЕсли;
	
	Объект.ДатаОтправки = Неопределено;
	Объект.ИдентификаторСообщения = Неопределено;
	Записать();
КонецПроцедуры

&НаСервереБезКонтекста
Функция Исправление(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Шапка.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидов КАК Шапка
	|ГДЕ
	|	Шапка.ИсправленныйДокумент = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

#КонецОбласти

&НаСервере
Процедура ОбработатьОтображениеПолейСтраховогоНомераПФР()
	Для Каждого СтрокаОплат Из Объект.Оплаты Цикл
		Если КадровыйУчетКлиентСервер.СНИЛСЗаполнен(СтрокаОплат.СотрудникСНИЛС) Тогда
			РегламентированныеДанныеКлиентСервер.СтраховойНомерПФРСоответствуетТребованиям(СтрокаОплат.СотрудникСНИЛС, СтрокаОплат.СотрудникСНИЛСТекстПроверки);
		Иначе
			СтрокаОплат.СотрудникСНИЛСТекстПроверки = "";
		КонецЕсли;
		Если КадровыйУчетКлиентСервер.СНИЛСЗаполнен(СтрокаОплат.РебенокСНИЛС) Тогда
			РегламентированныеДанныеКлиентСервер.СтраховойНомерПФРСоответствуетТребованиям(СтрокаОплат.РебенокСНИЛС, СтрокаОплат.РебенокСНИЛСТекстПроверки);
		Иначе
			СтрокаОплат.РебенокСНИЛСТекстПроверки = "";
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИдентификаторыСтрокСовместителей()
	Отбор = Новый Структура("ФизическоеЛицо, Месяц, ЭтоРасшифровка");
	СуммаПособий = 0;
	СуммаВзносов = 0;
	КоличествоСтраниц = 0;
	Найденные = Объект.Оплаты.НайтиСтроки(Новый Структура("ЭтоРасшифровка", Ложь));
	Для Каждого ОсновнаяСтрока Из Найденные Цикл
		// Сброс идентификаторов для строк верхнего уровня и получение итогов.
		ОсновнаяСтрока.ИдентификаторРодителя = -1;
		ОсновнаяСтрока.ЕстьПодчиненные = Ложь;
		// Получение итогов.
		СуммаПособий = СуммаПособий + ОсновнаяСтрока.СуммаПособия;
		СуммаВзносов = СуммаВзносов + ОсновнаяСтрока.СуммаВзносов;
		КоличествоСтраниц = КоличествоСтраниц + ОсновнаяСтрока.КоличествоСтраниц;
		// Сопоставление строк и заполнение данных для выстраивания иерархии.
		ЗаполнитьЗначенияСвойств(Отбор, ОсновнаяСтрока);
		Отбор.ЭтоРасшифровка = Истина;
		НайденныеПодчиненные = Объект.Оплаты.НайтиСтроки(Отбор);
		Если НайденныеПодчиненные.Количество() > 0 Тогда
			ОсновнаяСтрока.ЕстьПодчиненные = Истина;
			ИдентификаторРодителя = ОсновнаяСтрока.ПолучитьИдентификатор();
			Для Каждого ПодчиненнаяСтрока Из НайденныеПодчиненные Цикл
				ПодчиненнаяСтрока.ИдентификаторРодителя = ИдентификаторРодителя;
				ПодчиненнаяСтрока.ЕстьПодчиненные = Ложь;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииСотрудникаИляФизическогоЛица()
	ТекущаяСтрока = Элементы.Оплаты.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Идентификатор = ТекущаяСтрока.ПолучитьИдентификатор();
	ФиксацияВторичныхДанныхВДокументахКлиентСервер.СброситьФиксациюИзмененийРеквизитовПоОснованиюЗаполнения(ЭтотОбъект, "Сотрудник", Идентификатор);
	ФиксацияВторичныхДанныхВДокументахКлиентСервер.СброситьФиксациюИзмененийРеквизитовПоОснованиюЗаполнения(ЭтотОбъект, "Ребенок", Идентификатор);
КонецПроцедуры

&НаКлиенте
Процедура ОплатыПередУдалением(Элемент, Отказ)
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура("ФизическоеЛицо,Месяц");
	Для Каждого Идентификатор Из Элемент.ВыделенныеСтроки Цикл
		НайденнаяСтрока = Объект.Оплаты.НайтиПоИдентификатору(Идентификатор);
		Если НайденнаяСтрока = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(Отбор, НайденнаяСтрока);
		Отбор.Вставить("ЭтоРасшифровка", Истина);
		СтрокиКУдалению = Объект.Оплаты.НайтиСтроки(Отбор);
		Для Каждого СтрокаКУдалению Из СтрокиКУдалению Цикл
			Объект.Оплаты.Удалить(СтрокаКУдалению);
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеКорректировки()
	ЗаполнитьДанныеКорректировки();
	ОбновитьЭлементыФормы();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеКорректировки()
	СуммаВзносовДо = 0;
	СуммаПособийДо = 0;
	КорректировкаВзносов = 0;
	КорректировкаПособий = 0;
	Если Не Объект.Перерасчет Тогда
		Возврат;
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидовОплаты.СуммаПособия), 0) КАК СуммаПособия,
		|	ЕСТЬNULL(СУММА(ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидовОплаты.СуммаВзносов), 0) КАК СуммаВзносов
		|ИЗ
		|	Документ.ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидов.Оплаты КАК ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидовОплаты
		|ГДЕ
		|	ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидовОплаты.Ссылка = &Ссылка
		|	И НЕ ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидовОплаты.ЭтоРасшифровка
		|	И ЗаявлениеВФССОВозмещенииВыплатРодителямДетейИнвалидовОплаты.Ссылка.Проведен";
	Запрос.УстановитьПараметр("Ссылка", Объект.ИсправленныйДокумент);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СуммаВзносовДо = СуммаВзносовДо + Выборка.СуммаВзносов;
		СуммаПособийДо = СуммаПособийДо + Выборка.СуммаПособия;
	КонецЦикла;
	КорректировкаВзносов = СуммаВзносов - СуммаВзносовДо;
	КорректировкаПособий = СуммаПособий - СуммаПособийДо;
	Объект.ОтправлятьЧерезСЭДО = ВидОтправкиИсправленногоДокумента(КорректировкаВзносов, КорректировкаПособий, Объект.ОтправлятьЧерезСЭДО);
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВидОтправкиИсправленногоДокумента(КорректировкаВзносов, КорректировкаПособий, ОтправлятьЧерезСЭДО)
	Если КорректировкаВзносов < 0 Или КорректировкаПособий < 0 Тогда
		ОтправлятьЧерезСЭДО = Ложь;
	КонецЕсли;
	Возврат ОтправлятьЧерезСЭДО;
КонецФункции

#КонецОбласти
