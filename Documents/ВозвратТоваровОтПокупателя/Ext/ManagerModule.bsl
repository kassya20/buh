Процедура ДополнитьДанныеЗаполненияСчетовУчета(ДанныеЗаполнения) Экспорт

	Если ДанныеЗаполнения.Свойство("Оборудование") Тогда
		
		ДанныеЗаполнения.Оборудование = (ДанныеЗаполнения.ВидОперации = Перечисления.ВидыОперацийВозвратТоваровОтПокупателя.Оборудование);
		
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("ВыкупленныеКомиссионеромТовары") Тогда
		
		ДанныеЗаполнения.ВыкупленныеКомиссионеромТовары = 
			(ДанныеЗаполнения.ВидОперации = Перечисления.ВидыОперацийВозвратТоваровОтПокупателя.ВыкупленныеКомиссионеромТовары);
		
	КонецЕсли;
		
	Если ДанныеЗаполнения.Свойство("ТоварыНаСкладКомиссионера") Тогда
		
		ДанныеЗаполнения.ТоварыНаСкладКомиссионера =
			(ДанныеЗаполнения.ВидОперации = Перечисления.ВидыОперацийВозвратТоваровОтПокупателя.ТоварыНаСкладКомиссионера);
		
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("ОтгруженныеТовары") Тогда
		
		ДанныеЗаполнения.ОтгруженныеТовары = 
			(ДанныеЗаполнения.ВидОперации = Перечисления.ВидыОперацийВозвратТоваровОтПокупателя.ОтгруженныеТовары);
		
	КонецЕсли;	

КонецПроцедуры


