		Возврат;
	КонецЕсли;
	
	Если Ожидание = 0 И ДоступныеСтатьиРасходов.Количество() > 0 Тогда
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.ЗагрузитьЗначения(ДоступныеСтатьиРасходов.ВыгрузитьЗначения());
	КонецЕсли;

КонецПроцедуры

