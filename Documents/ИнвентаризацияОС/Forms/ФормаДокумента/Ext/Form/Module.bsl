&НаКлиенте
Процедура СброситьФакт(Команда)
	
	Для Каждого СтрокаОС Из Объект.ОС Цикл
		СтрокаОС.НаличиеФактическое = Ложь;
		СтрокаОС.КоличествоФактическое = 0;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВводШтрихкодаЗавершение(Штрихкод, ДополнительныеПараметры) Экспорт
	
	ЭтоШтрихкод = Ложь;
	
	Если Не Штрихкод = Неопределено Тогда
		ДлинаИнвентарногоНомера = ПолучитьДлинуКодаСправочникаОС();
		Если СтрДлина(Штрихкод) >= 12 И Лев(Штрихкод, 6) = "299000" Тогда
			Штрихкод = Лев(Штрихкод, 12);
			ЧастьКодаОС = Прав(Штрихкод, 6);
			ЭтоШтрихкод = Истина;
		ИначеЕсли СтрДлина(Штрихкод) = ДлинаИнвентарногоНомера И СтрНайти(Штрихкод, "-") > 0 Тогда
			ЧастьКодаОС = Штрихкод;	
		Иначе
			ПоказатьПредупреждение(,"Штрихкод не является инвентарным номером основного средства", ,"Проверка штрихкода");
			Возврат;
		КонецЕсли;
		
		Если ЭтоМобильныйКлиент Тогда
			ДобавитьПоКодуОСНаСервере(ЧастьКодаОС, ЭтоШтрихкод, ДополнительныеПараметры);
			
			Если НЕ ЗначениеЗаполнено(ДополнительныеПараметры.КоличествоФактическое) Тогда
				ТекстСообщения = НСтр("ru = 'ОС не найдено на остатках выбранной организации.'");
				ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
				
				Возврат;
			КонецЕсли;
			
			ДополнительныеПараметры.ПроизведеноСканирование = Истина;
			
			ОткрытьФормуСтрокиМК(ДополнительныеПараметры);
		Иначе
			ДобавитьПоКодуОСНаСервере(ЧастьКодаОС, ЭтоШтрихкод);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДлинуКодаСправочникаОС()
	
	Возврат Метаданные.Справочники.ОсновныеСредства.ДлинаКода;
	
КонецФункции

&НаСервере
Функция ПолучитьШтрихкодПоИнвентарномуНомеру(Знач КодИнвентарныйНомер)
	
	Результат = "";
	ИнвентарныйНомер = Прав(КодИнвентарныйНомер, ПолучитьДлинуКодаСправочникаОС()-3);
	Если Не ОбщегоНазначенияКлиентСервер.ЭтоЧисло(ИнвентарныйНомер) Или СтрДлина(ИнвентарныйНомер) < 6 Тогда
		Возврат Результат;
	КонецЕсли;
	Результат = "299000" + СокрЛП(ИнвентарныйНомер);
	КонтрольныйСимвол = РегистрыСведений.ШтрихкодыНоменклатуры.КонтрольныйСимволEAN(Результат, 13);
	Штрихкод = Результат + КонтрольныйСимвол;
	
	Возврат Штрихкод;
		
КонецФункции

&НаСервере
Процедура ДобавитьПоКодуОСНаСервере(КодОС, ЭтоШтрихкод = Ложь, ПараметрыДляЗаполнения = Неопределено)
	
	Если ЭтоШтрихкод Тогда
		ОС = ПолучитьОСПочастиКода(КодОС);
	Иначе
		ОС = Справочники.ОсновныеСредства.НайтиПоКоду(КодОС);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОС) Тогда
		ПараметрыПоиска = Новый Структура("ОсновноеСредство", ОС);
		СтрокиОС = Объект.ОС.НайтиСтроки(ПараметрыПоиска);
		ЭтоИнвентарноеОС = ЭтоИнвентарноеОС(ОС);
		
		Если СтрокиОС.Количество() = 0 Тогда
			ДополнительныеПараметры = Новый Структура("Дата, Организация, ПодразделениеОрганизации, ОтветственноеЛицо");
			ЗаполнитьЗначенияСвойств(ДополнительныеПараметры, Объект);
			СписокОС = Новый Массив;
			СписокОС.Добавить(ОС);
			Таб = Документы.ИнвентаризацияОС.ОстаткиОС(ДополнительныеПараметры, СписокОС);
			Если Таб.Количество()>0 Тогда
				СтрокаОС = Таб[0];
				НоваяСтрока = Объект.ОС.Добавить();
				НоваяСтрока.ОсновноеСредство        = СтрокаОС.ОсновноеСредство;
				НоваяСтрока.СтоимостьПоДаннымУчета  = СтрокаОС.ВосстановительнаяСтоимость;
				НоваяСтрока.ИнвентарныйНомер		= СтрокаОС.ОсновноеСредство.Код;
				НоваяСтрока.КоличествоПоДаннымУчета = СтрокаОС.КоличествоПоУчету;
				НоваяСтрока.КоличествоФактическое 	= 1;
				Если ЭтоИнвентарноеОС Тогда
					Если СтрокаОС.КоличествоПоУчету = 1 Тогда 
						НоваяСтрока.НаличиеПоДаннымУчета    = Истина;
						НоваяСтрока.НаличиеФактическое      = Истина;
					Иначе
						НоваяСтрока.НаличиеПоДаннымУчета    = Ложь;
						НоваяСтрока.НаличиеФактическое      = Истина;
					КонецЕсли;
					НоваяСтрока.СтоимостьПоУчетуЗаЕдиницу = СтрокаОС.СтоимостьПоУчетуЗаЕдиницу;
					НоваяСтрока.СтоимостьПоРезультатамИнвентаризации = СтрокаОС.ВосстановительнаяСтоимость;
					
					Если ПараметрыДляЗаполнения <> Неопределено И ЭтоМобильныйКлиент Тогда
						ЗаполнитьЗначенияСвойств(ПараметрыДляЗаполнения, НоваяСтрока);
						ПараметрыДляЗаполнения.ИнвентарноеОС = ЭтоИнвентарноеОС;
						
						ПараметрыМестонахожденияОС = ПараметрыМестонахожденияМК(НоваяСтрока.ОсновноеСредство,
							Объект.Дата, Объект.Организация);
						
						НайденныйМОЛ = ПараметрыМестонахожденияОС.МОЛ;
						НайденноеМестонахождениеОС = ПараметрыМестонахожденияОС.Местонахождение;
						
						ПараметрыДляЗаполнения.Местонахождение = НайденноеМестонахождениеОС;
						ПараметрыДляЗаполнения.МОЛ = НайденныйМОЛ;
						
						НоваяСтрока.МОЛ = НайденныйМОЛ;
						НоваяСтрока.МестонахождениеМК = НайденноеМестонахождениеОС;
					КонецЕсли;
				Иначе
					НоваяСтрока.СтоимостьПоРезультатамИнвентаризации = СтрокаОС.СтоимостьПоУчетуЗаЕдиницу;
				КонецЕсли;
				НоваяСтрока.СтоимостьФактическая    = НоваяСтрока.СтоимостьПоРезультатамИнвентаризации;
				РассчитатьВычисляемыеПоляПоСтроке(НоваяСтрока, ВедетсяУчетГрупповыхОС);
			Иначе
				Если ЭтоМобильныйКлиент Тогда
					ПараметрыМестонахожденияОС = ПараметрыМестонахожденияМК(ОС,
						Объект.Дата, Объект.Организация);
					
					Если ЗначениеЗаполнено(ПараметрыМестонахожденияОС.КоличествоПоДаннымУчета)
					ИЛИ ЗначениеЗаполнено(ПараметрыМестонахожденияОС.Местонахождение)
					ИЛИ ЗначениеЗаполнено(ПараметрыМестонахожденияОС.МОЛ) Тогда
						ЗаполнитьЗначенияСвойств(ПараметрыДляЗаполнения, ПараметрыМестонахожденияОС);
						ПараметрыДляЗаполнения.КоличествоФактическое = 1;
						ПараметрыДляЗаполнения.ОсновноеСредство = ОС;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Иначе
			СтрокаТЧ = СтрокиОС[0];
			
			Если ЭтоИнвентарноеОС Тогда
				СтрокаТЧ.НаличиеФактическое = Истина;
				СтрокаТЧ.СтоимостьФактическая = СтрокаТЧ.СтоимостьПоДаннымУчета;
				
				Если ЭтоМобильныйКлиент Тогда
					Если НЕ СтрокаТЧ.ПризнакПроинвентаризированоМК Тогда
						СтрокаТЧ.КоличествоФактическое = СтрокаТЧ.КоличествоФактическое + 1;
					КонецЕсли;
					
					Если ПараметрыДляЗаполнения <> Неопределено Тогда
						ЗаполнитьЗначенияСвойств(ПараметрыДляЗаполнения, СтрокаТЧ);
						
						ПараметрыДляЗаполнения.ИнвентарноеОС = ЭтоИнвентарноеОС;
						
						ПараметрыМестонахожденияОС = ПараметрыМестонахожденияМК(ОС,
							Объект.Дата, Объект.Организация);
						
						ПараметрыДляЗаполнения.Местонахождение = ПараметрыМестонахожденияОС.Местонахождение;
						ПараметрыДляЗаполнения.МОЛ = ПараметрыМестонахожденияОС.МОЛ;
					КонецЕсли;
				КонецЕсли;
			Иначе
				СтрокаТЧ.КоличествоФактическое = СтрокаТЧ.КоличествоФактическое + 1;
				СтрокаТЧ.СтоимостьФактическая = СтрокаТЧ.СтоимостьПоУчетуЗаЕдиницу * СтрокаТЧ.КоличествоФактическое;
			КонецЕсли;
			СтрокаТЧ.СтоимостьПоРезультатамИнвентаризации = СтрокаТЧ.СтоимостьФактическая;
			РассчитатьВычисляемыеПоляПоСтроке(СтрокаТЧ, ВедетсяУчетГрупповыхОС);
		КонецЕсли;
	
		ЗаполнитьРеквизитыТЧ();
	КонецЕсли;
	
	УправлениеВидимостьюМК();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОСПоЧастиКода(ЧастьКодаОС)
	
	ОсновноеСредство = Справочники.ОсновныеСредства.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОсновныеСредства.Ссылка КАК ОсновноеСредство
	|ИЗ
	|	Справочник.ОсновныеСредства КАК ОсновныеСредства
	|ГДЕ
	|	ПОДСТРОКА(ОсновныеСредства.Код, 4, 6) = &ЧастьКодаОС";
	
	Запрос.УстановитьПараметр("ЧастьКодаОС",ЧастьКодаОС);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ОсновноеСредство = Выборка.ОсновноеСредство;
	КонецЕсли;
	
	Возврат ОсновноеСредство;
	
КонецФункции

#КонецОбласти

#Область ТСД

&НаСервере
Процедура УстановитьВидимостьГруппыКнопокТСД()
	
	Элементы.ГруппаОСТСД.Видимость = МенеджерОборудованияБП.ИспользуетсяОборудование("ТерминалСбораДанных");
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьДанныеВТСД(Команда)
	
	#Если ВебКлиент Тогда
	ПоказатьПредупреждение(,("ru = 'Работа с торговым оборудованием не поддерживается в режиме веб-клиента.
					|Для использования терминала сбора данных запустите программу в режиме тонкого клиента.'"), 15);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Данные по основным средствам не выгружены'"));
	Возврат;
	#КонецЕсли

	Если Объект.ОС.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Табличная часть ОС не заполнена.
								|Отсутствуют данные для выгрузки в ТСД");
		Возврат;
	КонецЕсли;

	ТаблицаТСД = ПолучитьТаблицуОСДляТСД();
	Если ТаблицаТСД.Количество() = 0 Тогда
		ПоказатьПредупреждение(, "Отсуствуют данные для выгрузки в терминал");
		Возврат;
	КонецЕсли;
	
	ВыгрузитьДанныеВТСД_ВыполнитьВыгрузку(ТаблицаТСД);

КонецПроцедуры

&НаСервере
Функция ПолучитьТаблицуОСДляТСД()
	
	ОбъектФормы 	= РеквизитФормыВЗначение("Объект");
	ТаблицаОС 		= ОбъектФормы.ОС.Выгрузить();
	ТаблицаДляТСД 	= Новый Массив;
	
	Запрос 			= Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ОсновныеСредства.ОсновноеСредство КАК Справочник.ОсновныеСредства) КАК ОсновноеСредство,
	|	ВЫРАЗИТЬ(ОсновныеСредства.СтоимостьПоРезультатамИнвентаризации КАК ЧИСЛО(15, 2)) КАК Стоимость,
	|	0 КАК Количество
	|ПОМЕСТИТЬ втОсновныеСредства
	|ИЗ
	|	&ОсновныеСредства КАК ОсновныеСредства
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втОсновныеСредства.ОсновноеСредство КАК Номенклатура,
	|	втОсновныеСредства.ОсновноеСредство.Код КАК КодОС,
	|	втОсновныеСредства.Стоимость КАК Цена,
	|	втОсновныеСредства.Количество КАК Количество,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(13)) КАК Штрихкод
	|ИЗ
	|	втОсновныеСредства КАК втОсновныеСредства";
	
	Запрос.УстановитьПараметр("ОсновныеСредства", ТаблицаОС);
	ОсновныеСредства = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаОсновноеСредство Из ОсновныеСредства Цикл
		СтрокаОсновноеСредство.Штрихкод = ПолучитьШтрихкодПоИнвентарномуНомеру(СтрокаОсновноеСредство.КодОС);
		НоваяСтрока = Новый Структура("Номенклатура, Цена, Количество, Штрихкод");
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаОсновноеСредство);
		ТаблицаДляТСД.Добавить(НоваяСтрока);
	КонецЦикла;
	 
	Возврат ТаблицаДляТСД;
	
КонецФункции

&НаКлиенте
Процедура ВыгрузитьДанныеВТСД_ВыполнитьВыгрузку(ТаблицаТСД) Экспорт
	
	ОповещениеПослеВыгрузки = Новый ОписаниеОповещения("ПослеВыгрузкиВТСД", ЭтаФорма, Неопределено);
	МенеджерОборудованияКлиент.НачатьВыгрузкуДанныеВТСД(ОповещениеПослеВыгрузки, ЭтаФорма.УникальныйИдентификатор, ТаблицаТСД);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыгрузкиВТСД(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат.Результат Тогда
		ПоказатьОповещениеПользователя("Данные успешно выгружены", ,"Выгрузка данных  в ТСД"
			,БиблиотекаКартинок.ВыгрузитьВТСД,СтатусОповещенияПользователя.Информация);
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ОписаниеОшибки);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанныеИзТСД(Команда)
	
	#Если ВебКлиент Тогда
	ПоказатьПредупреждение(,НСтр("ru = 'Работа с торговым оборудованием не поддерживается в режиме веб-клиента.
					|Для использования терминала сбора данных запустите программу в режиме тонкого клиента.'"), 15);
	Возврат;
	#КонецЕсли

	Если Объект.ОС.Количество() = 0 Тогда
		ЗаполнитьДанныеУчетаИФактические(Неопределено);
	КонецЕсли;
	СброситьФакт(Неопределено);
	
	ЗаблокироватьДанныеФормыДляРедактирования();
	ЭтаФорма.Доступность = Ложь; // Блокируем интерфейс пользователя.
	СворачиватьДанные    = Истина; // Флаг определяет, будет ли сворачиваться загружаемая таблица (группировка по штрихкоду).
	
	Оповещение = Новый ОписаниеОповещения("ЗагрузитьДанныеИзТСДЗавершение", ЭтотОбъект);
	МенеджерОборудованияКлиент.НачатьЗагрузкуДанныеИзТСД(Оповещение, УникальныйИдентификатор, СворачиватьДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьДанныеИзТСДЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ЭтаФорма.Доступность = Истина; // Разблокировка интерфейса пользователя.
	
	Если Результат.Результат Тогда
		ТаблицаТСД = Результат.ТаблицаТоваров;
		ЗаполнитьПоДаннымИзТСДНаСервере(ТаблицаТСД);
		Элементы.ОС.Обновить();
		ПоказатьПредупреждение(, Нстр("ru = 'Данные загружены'"));
	Иначе
		ТекстСообщения = НСтр("ru = 'При выполнении операции произошла ошибка:""%1"".'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Результат.ОписаниеОшибки);
		ПоказатьПредупреждение(, ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоДаннымИзТСДНаСервере(ДанныеТСД)
	
	ТаблицаТСД = Новый ТаблицаЗначений;
	ТаблицаТСД.Колонки.Добавить("Штрихкод"	, Новый ОписаниеТипов("Строка",,,,Новый КвалификаторыСтроки(13)));
	ТаблицаТСД.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(10,1)));
	
	Для Каждого СтруктураДанных Из ДанныеТСД Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаТСД.Добавить(), СтруктураДанных);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаТСД.Штрихкод КАК Штрихкод,
	|	ВЫРАЗИТЬ(ТаблицаТСД.Количество КАК ЧИСЛО(10, 1)) КАК Количество
	|ПОМЕСТИТЬ втДанныеТСД
	|ИЗ
	|	&ТаблицаТСД КАК ТаблицаТСД
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОсновныеСредства.Ссылка КАК ОсновноеСредство,
	|	ВЫБОР
	|		КОГДА втДанныеТСД.Количество > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НаличиеФактическое,
	|	втДанныеТСД.Количество КАК КоличествоФактическое
	|ИЗ
	|	втДанныеТСД КАК втДанныеТСД
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОсновныеСредства КАК ОсновныеСредства
	|		ПО (ПОДСТРОКА(втДанныеТСД.Штрихкод, 7, 6) ПОДОБНО ПРАВ(ОсновныеСредства.Код, 6))";
	
	Запрос.УстановитьПараметр("ТаблицаТСД", ТаблицаТСД);
	Таб = Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаТЧ Из Объект.ОС Цикл
		СтрокаТаблицы = Таб.Найти(СтрокаТЧ.ОсновноеСредство, "ОсновноеСредство");
		Если Не СтрокаТаблицы = Неопределено Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТаблицы, "НаличиеФактическое,КоличествоФактическое", "ОсновноеСредство");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьКолонок()
	
	Если ЭтоМобильныйКлиент Тогда
		Возврат;
	КонецЕсли;
	
	Если ВедетсяУчетГрупповыхОС Тогда
		Элементы.ОС.ПодчиненныеЭлементы.ОСКоличествоПоДаннымУчета.Видимость = Истина;
		Элементы.ОС.ПодчиненныеЭлементы.ОСКоличествоФактическое.Видимость 	= Истина;
		Элементы.ОС.ПодчиненныеЭлементы.ОСНаличиеПоДаннымУчета.Видимость 	= Ложь;
		Элементы.ОС.ПодчиненныеЭлементы.ОСНаличиеФактическое.Видимость 		= Ложь;
	Иначе
		Элементы.ОС.ПодчиненныеЭлементы.ОСКоличествоПоДаннымУчета.Видимость = Ложь;
		Элементы.ОС.ПодчиненныеЭлементы.ОСКоличествоФактическое.Видимость 	= Ложь;
		Элементы.ОС.ПодчиненныеЭлементы.ОСНаличиеПоДаннымУчета.Видимость 	= Истина;
		Элементы.ОС.ПодчиненныеЭлементы.ОСНаличиеФактическое.Видимость 		= Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область УчетГрупповыхОС

&НаСервереБезКонтекста
Функция ЭтоИнвентарноеОС(ОсновноеСредство)
	
	ИнвентарноеОС = Ложь;
	Если ОсновноеСредство.ЕдиницаУчета = Перечисления.ЕдиницыУчетаОС.ИнвентарныйОбъект Тогда
		ИнвентарноеОС = Истина;
	КонецЕсли;
	
	Возврат ИнвентарноеОС;
	
КонецФункции

&НаКлиенте
Процедура ОрганизацияПодразделениеМОЛ_ПриИзменении()
	
	Если Объект.ОС.Количество()>0 Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеОтветаНаВопросОПерезаполнении", ЭтаФорма);
		ПоказатьВопрос(Оповещение,"Табличная часть будет перезаполнена, продолжить?", РежимДиалогаВопрос.ДаНет, ,КодВозвратаДиалога.Да, "Перезаполнение табличной части");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтветаНаВопросОПерезаполнении(ОтветПользователя, ДополнительныеПараметры) Экспорт
	
	Если ОтветПользователя = КодВозвратаДиалога.Да ТОгда
		ЗаполнитьДанныеУчетаИФактическиеСервер();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область МобильныйКлиент

&НаСервере
Процедура МобильныйКлиентАдаптацияФормы()
	
	ЭтоМобильныйКлиент = ОбщегоНазначения.ЭтоМобильныйКлиент();
	
	Если Не ЭтоМобильныйКлиент Тогда
		Возврат;
	КонецЕсли;
	
	УправлениеДоступностьюМК();
	
	МобильныйКлиентБПФормаОбъекта.НастроитьФорму(ЭтотОбъект);
	
	АдаптироватьМКШапкаФормы();
	АдаптироватьМККоманднаяПанельФормы();
	АдаптироватьМКСписокФормыИнвКомиссия();
	АдаптироватьМКСписокФормыОС();
	
	ОтображениеСтрокМК = "КПересчету";
	СтруктураОтбора = Новый ФиксированнаяСтруктура("ПризнакПроинвентаризированоМК", Ложь);
	Элементы.ОС.ОтборСтрок = СтруктураОтбора;
	
	УстановитьЗаголовокОтбораСтрокМК(Объект.ОС);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМККоманднаяПанельФормы()
	
	МобильныйКлиентБПФормаОбъекта.АдаптироватьМККоманднаяПанель(ЭтотОбъект);
	
	МобильныйКлиентБПФормаОбъекта.ПеренестиКомандыВМККомандыФормы(Элементы, Элементы.ГруппаКнопокКоманднойПанели.ПодчиненныеЭлементы);
	
	МобильныйКлиентБПФормаОбъекта.ПеренестиКомандыВПодменюМКПоделиться(Элементы, Элементы.ПодменюПечать.ПодчиненныеЭлементы);
	
	ПодменюОтправить = Элементы.Найти("ПодменюОтправить");
	Если ПодменюОтправить <> Неопределено Тогда
		МобильныйКлиентБПФормаОбъекта.СкрытьЭлементФормы(Элементы, ПодменюОтправить);
	КонецЕсли;
	
	Элементы.Переместить(Элементы.ГруппаКомандаСканировать, ЭтотОбъект);
	Элементы.Переместить(Элементы.КомандаМКСканироватьОС, Элементы.ГруппаКомандаСканировать);
	Элементы.Переместить(Элементы.НижняяКоманднаяПанельМК, ЭтотОбъект, Элементы.ГруппаПрочиеРеквизиты);
	Элементы.Переместить(Элементы.КомандаМКДобавитьСтрокуОС, Элементы.НижняяКоманднаяПанельМК);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКШапкаФормы()
	
	МобильныйКлиентБПФормаОбъекта.АдаптироватьНомерДатаФормаДокумента(Элементы, Элементы.ГруппаНомерДата, Ложь);
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.ГруппаНомерДата);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.Организация);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.ПодразделениеОрганизации);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.МОЛ);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.РежимОтображенияСтрокМК);
	
	Элементы.Организация.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.КомандаМКЗаполнитьОС);
	
	Элементы.Переместить(Элементы.ГруппаОС, ЭтотОбъект);
	Элементы.Переместить(Элементы.ГруппаПрочиеРеквизиты, ЭтотОбъект);
	Элементы.Переместить(Элементы.ГруппаПроведениеИнвентаризации, Элементы.ГруппаПрочиеРеквизиты);
	Элементы.Переместить(Элементы.ГруппаКомментарийОтветственный, Элементы.ГруппаПроведениеИнвентаризации);
	
	ОформляемыеКнопки = Новый Массив;
	
	ОформляемыеКнопки.Добавить(Элементы.КомандаМКСканироватьОС);
	ОформляемыеКнопки.Добавить(Элементы.КомандаМКЗаполнитьОС);
	
	МобильныйКлиентБПФормаОбъекта.ОформитьАкцентнуюКнопкуФормы(ОформляемыеКнопки, 20, Ложь, Ложь);
	
	МобильныйКлиентБПФормаОбъекта.СкрытьЭлементФормы(Элементы, Элементы.ГруппаИтоги);
	
	УправлениеВидимостьюМК();
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКСписокФормыОС()
	
	НовыйЭлемент = Элементы.Добавить("ОСПредставлениеКоличестваМК", Тип("ПолеФормы"), Элементы.ОС);
	НовыйЭлемент.ПутьКДанным = "Объект.ОС.ПредставлениеКоличестваМК";
	НовыйЭлемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
	
	МобильныйКлиентБПФормаОбъекта.ПодготовитьТабличноеПолеФормыДокументаМногострочное(ЭтотОбъект, "ОС");
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементВГруппуМК_ТабличноеПоле_Строка(ЭтотОбъект, Элементы.ОСОсновноеСредство, 1, "ОС");
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементВГруппуМК_ТабличноеПоле_Строка(ЭтотОбъект, Элементы.ОСИнвентарныйНомер, 2, "ОС");
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементВГруппуМК_ТабличноеПоле_Строка(ЭтотОбъект, Элементы.ОСПредставлениеКоличестваМК, 2, "ОС");
	
	Элементы.Переместить(Элементы.ОС, Элементы.ГруппаОС);
	
	Элементы.ОС.Шапка = Ложь;
	Элементы.ОС.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	Элементы.ОС.ВариантУправленияВысотой = ВариантУправленияВысотойТаблицы.ВСтрокахТаблицы;
	
	ИменаЭлементовИсключений = Новый Массив;
	ИменаЭлементовИсключений.Добавить("ОСОсновноеСредство");
	ИменаЭлементовИсключений.Добавить("ОСИнвентарныйНомер");
	ИменаЭлементовИсключений.Добавить("ОСПредставлениеКоличестваМК");
	
	МобильныйКлиентБПФормаОбъекта.СкрытьПодчиненныеЭлементыСИсключениямиРекурсивно(Элементы,
		Элементы.ОС.ПодчиненныеЭлементы, ИменаЭлементовИсключений);
	
	Элементы.ОС.УстановитьДействие("Выбор", "Подключаемый_ОСВыборМК");
	
	Элементы.КомандаМКДобавитьСтрокуОС.Картинка = БиблиотекаКартинок.ДобавитьЭлементСписка;
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКСписокФормыИнвКомиссия()
	
	КомандыПоля = МобильныйКлиентБПФормаОбъекта.НовыйОписаниеКомандТабличноеПолеФормы();
	КомандыПоля.ИмяКомандыПодбор ="ИнвентаризационнаяКомиссияПодборФизическихЛиц";
	КомандыПоля.ИмяКомандыДобавитьСтроку = "ИнвентаризационнаяКомиссияДобавить";
	
	ОписаниеГруппыПоля = МобильныйКлиентБПФормаОбъекта.НовыйОписаниеГруппыТабличноеПолеФормы();
	ОписаниеГруппыПоля.ЗаголовокГруппы = НСтр("ru = 'Инвентаризационная комиссия'");
	ОписаниеГруппыПоля.ПутьКДаннымЗаголовка = "Объект.ИнвентаризационнаяКомиссия.КоличествоСтрок";
	ОписаниеГруппыПоля.ПоказатьГруппуНового = Истина;
	
	ОписаниеКолонокПоля = МобильныйКлиентБПФормаОбъекта.НовыйОписаниеКолонокПоляТабличноеПолеФормы();
	ОписаниеКолонокПоля.КолонкаНомерСтроки = "ИнвентаризационнаяКомиссияНомерСтроки";
	ОписаниеКолонокПоля.ВажныеКолонки = "ИнвентаризационнаяКомиссияФизЛицо,ИнвентаризационнаяКомиссияПредседатель";
	ОписаниеКолонокПоля.УстановитьВерхниеЗаголовки = 
		"ИнвентаризационнаяКомиссияФизЛицо";

	МобильныйКлиентБПФормаОбъекта.ПодготовитьТабличноеПолеФормыДокумента(ЭтотОбъект,
		Элементы.ИнвентаризационнаяКомиссия, ОписаниеГруппыПоля, КомандыПоля, ОписаниеКолонокПоля);
	
	Если Элементы.Найти("ГруппаТабличногоПоляИнвентаризационнаяКомиссия") <> Неопределено Тогда
		Элементы.Переместить(Элементы.ГруппаТабличногоПоляИнвентаризационнаяКомиссия, Элементы.ГруппаПроведениеИнвентаризации);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьМКСтрокиОС(ТаблицаОС)
	
	Для каждого СтрокаОС Из ТаблицаОС Цикл
		Если НЕ ВедетсяУчетГрупповыхОС Тогда
			Если НЕ СтрокаОС.НаличиеФактическое И СтрокаОС.КоличествоФактическое > 0 Тогда
				СтрокаОС.КоличествоФактическое = 0;
			КонецЕсли;
		КонецЕсли;
		
		СтрокаОС.ПредставлениеКоличестваМК = СтрШаблон(НСтр("ru='%1 из %2'"), СтрокаОС.КоличествоФактическое, СтрокаОС.КоличествоПоДаннымУчета);
		СтрокаОС.ПризнакПроинвентаризированоМК = ?(СтрокаОС.КоличествоФактическое = СтрокаОС.КоличествоПоДаннымУчета, Истина, Ложь);
		СтрокаОС.ИнвентарныйНомер = СтрШаблон(НСтр("ru='Инв. № %1'"), СтрокаОС.ИнвентарныйНомер);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_КомандаМКЗаполнитьОС(Команда)
	
	ПерезаполнитьДанныеУчетаИФактические();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_КомандаМКСканироватьОС(Команда)
	
	Штрихкод = "";
	
	ДопПараметры = ПараметрыОткрытияФормыСтрокиМК();
	
	ВводШтрихкода = Новый ОписаниеОповещения("ВводШтрихкодаЗавершение", ЭтаФорма, ДопПараметры);
	
	Если МобильныйКлиентБПКлиент.ЭтоМобильныйКлиент()
		И МобильныйКлиентБПКлиент.ДоступноСканированиеШтрихкодов() Тогда
		МобильныйКлиентБПКлиент.НачатьСканированиеШтрихКодов("Отсканируйте штрихкод с этикетки основного средства", ВводШтрихкода);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_КомандаМКДобавитьСтрокуОС(Команда)
	
	ПараметрыОткрытия = ПараметрыОткрытияФормыСтрокиМК();
	
	ПараметрыОткрытия.НоваяСтрока = Истина;
	
	ОткрытьФормуСтрокиМК(ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_РежимОтображенияСтрокМКПриИзменении(Элемент)
	
	Если ОтображениеСтрокМК = "Все" Тогда
		Элементы.ОС.ОтборСтрок = Неопределено;
	Иначе
		СтруктураОтбора = Новый ФиксированнаяСтруктура("ПризнакПроинвентаризированоМК", Ложь);
		
		Элементы.ОС.ОтборСтрок = СтруктураОтбора;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеВидимостьюМК()
	
	Если НЕ ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ОС.Количество() = 0 Тогда
		Элементы.РежимОтображенияСтрокМК.Видимость = Ложь;
		Элементы.КомандаМКЗаполнитьОС.Видимость = Истина;
		Элементы.КомандаМКСканироватьОС.Видимость = Ложь;
	Иначе
		Элементы.РежимОтображенияСтрокМК.Видимость = Истина;
		Элементы.КомандаМКЗаполнитьОС.Видимость = Ложь;
		Элементы.КомандаМКСканироватьОС.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УправлениеДоступностьюМК()
	
	Если НЕ ПравоДоступа("Изменение", Метаданные.Документы.ИнвентаризацияОС) Тогда
		Для каждого Элемент Из Элементы.ГруппаМобильныйКлиент.ПодчиненныеЭлементы Цикл
			Элемент.Доступность = Ложь;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовокОтбораСтрокМК(ТаблицаОС)
	
	Если Элементы.Найти("РежимОтображенияСтрокМК") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура("ПризнакПроинвентаризированоМК", Ложь);
	
	НеПроверенныеСтроки = ТаблицаОС.НайтиСтроки(СтруктураОтбора);
	
	НовоеПредставление = СтрШаблон(НСтр("ru='Ожидают инвентаризации (%1)'"), НеПроверенныеСтроки.Количество());
	
	Элементы.РежимОтображенияСтрокМК.СписокВыбора[1].Представление = НовоеПредставление;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОСВыборМК(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элементы.ОС.ТекущиеДанные;
	
	ПараметрыОткрытия = ПараметрыОткрытияФормыСтрокиМК();
	
	ЗаполнитьЗначенияСвойств(ПараметрыОткрытия, ТекущиеДанные);
	
	ИнвентарноеОС = ЭтоИнвентарноеОС(ТекущиеДанные.ОсновноеСредство);
	
	ПараметрыОткрытия.ИнвентарноеОС = ИнвентарноеОС;
	ПараметрыОткрытия.ИнвентарныйНомер = СтрЗаменить(ТекущиеДанные.ИнвентарныйНомер, "Инв. №", "");
	
	ОСПринадлежитДругомуМОЛ = ТекущиеДанные.МОЛ <> Объект.ОтветственноеЛицо;
	ОСПринадлежитДругомуПодразделению = ТекущиеДанные.МестонахождениеМК <> Объект.ПодразделениеОрганизации;
	
	Если ОСПринадлежитДругомуМОЛ ИЛИ ОСПринадлежитДругомуПодразделению Тогда
		ПараметрыМестонахожденияОС = ПараметрыМестонахожденияМК(ТекущиеДанные.ОсновноеСредство,
			Объект.Дата, Объект.Организация);
	
		ПараметрыОткрытия.Местонахождение = ПараметрыМестонахожденияОС.Местонахождение;
		Если ИнвентарноеОС Тогда
			ПараметрыОткрытия.МОЛ = ПараметрыМестонахожденияОС.МОЛ;
		КонецЕсли;
		ПараметрыОткрытия.КоличествоПоДаннымУчета = ПараметрыМестонахожденияОС.КоличествоПоДаннымУчета;
	Иначе
		ПараметрыОткрытия.Местонахождение = Объект.ПодразделениеОрганизации;
		ПараметрыОткрытия.МОЛ = Объект.ОтветственноеЛицо;
	КонецЕсли;
	
	ОткрытьФормуСтрокиМК(ПараметрыОткрытия);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуСтрокиМК(ПараметрыОткрытия)
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ОбновитьТабличнуюЧастьМК", ЭтотОбъект);
	
	ОткрытьФорму("Документ.ИнвентаризацияОС.Форма.ФормаСтрокиМобильныйКлиент",
		ПараметрыОткрытия, ЭтотОбъект,,,, ОповещениеОЗакрытии,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Функция ПараметрыОткрытияФормыСтрокиМК()
	
	ПараметрыОткрытия = Новый Структура;
	
	ПараметрыОткрытия.Вставить("ОсновноеСредство");
	ПараметрыОткрытия.Вставить("ИнвентарныйНомер");
	ПараметрыОткрытия.Вставить("КоличествоПоДаннымУчета");
	ПараметрыОткрытия.Вставить("КоличествоФактическое");
	ПараметрыОткрытия.Вставить("Местонахождение");
	ПараметрыОткрытия.Вставить("МОЛ");
	ПараметрыОткрытия.Вставить("ИнвентарноеОС");
	
	//значения по умолчанию
	ПараметрыОткрытия.Вставить("Дата", Объект.Дата);
	ПараметрыОткрытия.Вставить("Организация", Объект.Организация);
	ПараметрыОткрытия.Вставить("НоваяСтрока", Ложь);
	ПараметрыОткрытия.Вставить("ПроизведеноСканирование", Ложь);
	
	Возврат ПараметрыОткрытия;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПараметрыМестонахожденияМК(ОС, Дата, Организация)
	
	Результат = Новый Структура("КоличествоПоДаннымУчета, Местонахождение, МОЛ");
	
	МассивОС = Новый Массив;
	МассивОС.Добавить(ОС);
	
	ПараметрыЗапросаОстатков = Новый Структура("Организация, Дата, ПодразделениеОрганизации, ОтветственноеЛицо",
		Организация, Дата);
	
	ТаблицаОС = Документы.ИнвентаризацияОС.ОстаткиОС(ПараметрыЗапросаОстатков, МассивОС);
	
	Для каждого СтрокаОС Из ТаблицаОС Цикл
		Результат.Местонахождение = СтрокаОС.Местонахождение;
		Результат.МОЛ = СтрокаОС.МОЛ;
		Результат.КоличествоПоДаннымУчета = СтрокаОС.КоличествоПоУчету;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьТабличнуюЧастьМК(Результат, ДопПараметры) Экспорт
	
	ОбновитьТабличнуюЧастьНаСервереМК(Результат);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТабличнуюЧастьНаСервереМК(Результат)
	
	СтруктураПоиска = Новый Структура("ОсновноеСредство", Результат.ОсновноеСредство);
	
	НайденныеСтроки = Объект.ОС.НайтиСтроки(СтруктураПоиска);
	
	Если НайденныеСтроки.Количество() = 0 И Результат.ОсновноеСредство <> Неопределено Тогда
		НоваяСтрокаОС = Объект.ОС.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаОС, Результат);
		НоваяСтрокаОС.МестонахождениеМК = Результат.Местонахождение;
		РассчитатьВычисляемыеПоляПоСтроке(НоваяСтрокаОС, ВедетсяУчетГрупповыхОС);
		Если НЕ ВедетсяУчетГрупповыхОС Тогда
			НоваяСтрокаОС.НаличиеФактическое = ?(НоваяСтрокаОС.КоличествоФактическое <> 0, Истина, Ложь);
		КонецЕсли;
	Иначе
		Для каждого СтрокаОС ИЗ НайденныеСтроки Цикл
			СтрокаОС.КоличествоФактическое = Результат.КоличествоФактическое;
			РассчитатьВычисляемыеПоляПоСтроке(СтрокаОС, ВедетсяУчетГрупповыхОС);
			Если НЕ ВедетсяУчетГрупповыхОС Тогда
				СтрокаОС.НаличиеФактическое = ?(СтрокаОС.КоличествоФактическое <> 0, Истина, Ложь);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ЗаполнитьРеквизитыТЧ();
	
	УправлениеВидимостьюМК();
	
КонецПроцедуры

#КонецОбласти