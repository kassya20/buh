			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ВЫБОР
		КОГДА ДокументПоступлениеДопРасходов.РучнаяКорректировка = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА ДокументПоступлениеДопРасходов.ПометкаУдаления = ИСТИНА
						ТОГДА 10
					КОГДА ДокументПоступлениеДопРасходов.Проведен = ЛОЖЬ
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ДокументПоступлениеДопРасходов.ПометкаУдаления = ИСТИНА
					ТОГДА 2
				КОГДА ДокументПоступлениеДопРасходов.Проведен = ИСТИНА
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостояниеДокумента,
	ДокументПоступлениеДопРасходов.Ссылка КАК Ссылка,
	ДокументПоступлениеДопРасходов.ПометкаУдаления КАК ПометкаУдаления,
	ДокументПоступлениеДопРасходов.Номер КАК Номер,
	ДокументПоступлениеДопРасходов.Дата КАК Дата,
	ДокументПоступлениеДопРасходов.Проведен КАК Проведен,
	ДокументПоступлениеДопРасходов.Организация КАК Организация,
	ДокументПоступлениеДопРасходов.СуммаДокумента КАК СуммаДокумента,
	ДокументПоступлениеДопРасходов.Сумма КАК Сумма,
	ДокументПоступлениеДопРасходов.СпособРаспределения КАК СпособРаспределения,
	ДокументПоступлениеДопРасходов.СтавкаНДС КАК СтавкаНДС,
	ДокументПоступлениеДопРасходов.СуммаНДС КАК СуммаНДС,
	ДокументПоступлениеДопРасходов.ВалютаДокумента КАК ВалютаДокумента,
	ДокументПоступлениеДопРасходов.Контрагент КАК Контрагент,
	ДокументПоступлениеДопРасходов.ДоговорКонтрагента КАК ДоговорКонтрагента,
	ДокументПоступлениеДопРасходов.СпособЗачетаАвансов КАК СпособЗачетаАвансов,
	ДокументПоступлениеДопРасходов.КратностьВзаиморасчетов КАК КратностьВзаиморасчетов,
	ДокументПоступлениеДопРасходов.КурсВзаиморасчетов КАК КурсВзаиморасчетов,
	ДокументПоступлениеДопРасходов.Содержание КАК Содержание,
	ДокументПоступлениеДопРасходов.СуммаВключаетНДС КАК СуммаВключаетНДС,
	ДокументПоступлениеДопРасходов.Ответственный КАК Ответственный,
	ДокументПоступлениеДопРасходов.НДСВключенВСтоимость КАК НДСВключенВСтоимость,
	ДокументПоступлениеДопРасходов.СчетУчетаРасчетовСКонтрагентом КАК СчетУчетаРасчетовСКонтрагентом,
	ДокументПоступлениеДопРасходов.СчетУчетаРасчетовПоАвансам КАК СчетУчетаРасчетовПоАвансам,
	ДокументПоступлениеДопРасходов.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	ДокументПоступлениеДопРасходов.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
	ДокументПоступлениеДопРасходов.РучнаяКорректировка КАК РучнаяКорректировка,
	ДокументПоступлениеДопРасходов.Комментарий КАК Комментарий,
	ДокументПоступлениеДопРасходов.МоментВремени КАК МоментВремени,
	СостоянияЭД.ПредставлениеСостояния КАК СостояниеЭДО,
	ВЫБОР
		КОГДА СтатусыДокументов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовПоступления.ОригиналПолучен)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК Оригинал,
	ВЫБОР
		КОГДА ДокументыСОшибкамиПроверкиКонтрагентов.Документ ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК СодержитНекорректныхКонтрагентов,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 1
		КОГДА НаличиеФайлов.ЕстьФайлы
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК ЕстьФайлы,
	ЕСТЬNULL(СтатусыДокументов.СтатусСчетаФактуры, ЗНАЧЕНИЕ(Перечисление.СтатусыСчетаФактуры.ПустаяСсылка)) КАК СчетФактура,
	ВЫБОР
		КОГДА СтатусыДокументов.СтатусЧекаНПД = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековНПД.Получен)
			ТОГДА "Чек НПД"
		КОГДА СтатусыДокументов.СтатусОригиналаСчетаФактуры = ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовПоступления.ОригиналПолучен)
			ТОГДА "СФ"
		ИНАЧЕ ""
	КОНЕЦ КАК ДополнительныеДокументы,
	СтатусыДокументов.СтатусЧекаНПД КАК СтатусЧекаНПД
ИЗ
	Документ.ПоступлениеДопРасходов КАК ДокументПоступлениеДопРасходов
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументов КАК СтатусыДокументов
		ПО ДокументПоступлениеДопРасходов.Организация = СтатусыДокументов.Организация
			И ДокументПоступлениеДопРасходов.Ссылка = СтатусыДокументов.Документ}
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыСОшибкамиПроверкиКонтрагентов КАК ДокументыСОшибкамиПроверкиКонтрагентов
		ПО ДокументПоступлениеДопРасходов.Ссылка = ДокументыСОшибкамиПроверкиКонтрагентов.Документ
			И (&amp;ИспользованиеПроверкиВозможно)}
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ДокументПоступлениеДопРасходов.Ссылка = НаличиеФайлов.ОбъектСФайлами}
