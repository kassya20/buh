#Область ТабличныйДокумент

Процедура ДополнитьБюджетОстатками(ДанныеБюджета, Реквизиты)

	// Суммы
	ТаблицаДоходов = ДанныеБюджета.Доходы.Скопировать(Новый Структура("ЭтоГруппа", Ложь));
	ТаблицаДоходов.Свернуть("ДатаПланирования", "Сумма,СуммаДоКорректировки,СуммаКорректировки");
	ТаблицаРасходов = ДанныеБюджета.РасходыПоНаправлениямДеятельности.Скопировать();
	ТаблицаРасходов.Свернуть("ДатаПланирования", "Сумма,СуммаДоКорректировки,СуммаКорректировки");
	
	ТаблицаОстатков = ТаблицаДоходов.Скопировать();
	Для Каждого Строка Из ТаблицаРасходов Цикл
		НоваяСтрока = ТаблицаОстатков.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка, , "Сумма");
		НоваяСтрока.Сумма = -Строка.Сумма;
		НоваяСтрока.СуммаДоКорректировки = -Строка.СуммаДоКорректировки;
		НоваяСтрока.СуммаКорректировки = -Строка.СуммаКорректировки;
	КонецЦикла;
	ТаблицаОстатков.Свернуть("ДатаПланирования", "Сумма,СуммаДоКорректировки,СуммаКорректировки");
	ТаблицаОстатков.Сортировать("ДатаПланирования Возр");
	
	ТаблицаОстатковНачало = ТаблицаОстатков.СкопироватьКолонки();
	ТаблицаОстатковКонец = ТаблицаОстатков.СкопироватьКолонки();
	
	НакопленныйОстаток = Реквизиты.ОстатокНаНачало;
	НакопленныйОстатокДоКорректировки = Реквизиты.ОстатокНаНачалоДоКорректировки;
	НакопленныйОстатокКорректировка = Реквизиты.ОстатокНаНачалоКорректировка;
	
	Для Каждого Строка Из ТаблицаОстатков Цикл
		Если Не ЗначениеЗаполнено(Строка.ДатаПланирования) Тогда
			СтрокаНачало = ТаблицаОстатковНачало.Добавить();
			СтрокаНачало.Сумма = Реквизиты.ОстатокНаНачало;
			СтрокаНачало.СуммаДоКорректировки = Реквизиты.ОстатокНаНачалоДоКорректировки;
			СтрокаНачало.СуммаКорректировки = Реквизиты.ОстатокНаНачалоКорректировка;
			
			СтрокаКонец = ТаблицаОстатковКонец.Добавить();
			СтрокаКонец.Сумма = Реквизиты.ОстатокНаНачало + Строка.Сумма;
			СтрокаКонец.СуммаДоКорректировки = Реквизиты.ОстатокНаНачалоДоКорректировки + Строка.СуммаДоКорректировки;
			СтрокаКонец.СуммаКорректировки = Реквизиты.ОстатокНаНачалоКорректировка + Строка.СуммаКорректировки;
			
		Иначе
			СтрокаНачало = ТаблицаОстатковНачало.Добавить();
			СтрокаНачало.ДатаПланирования = Строка.ДатаПланирования;
			СтрокаНачало.Сумма = НакопленныйОстаток;
			СтрокаНачало.СуммаДоКорректировки = НакопленныйОстатокДоКорректировки;
			СтрокаНачало.СуммаКорректировки = НакопленныйОстатокКорректировка;
			
			СтрокаКонец = ТаблицаОстатковКонец.Добавить();
			СтрокаКонец.ДатаПланирования = Строка.ДатаПланирования;
			НакопленныйОстаток = НакопленныйОстаток + Строка.Сумма;
			НакопленныйОстатокДоКорректировки = НакопленныйОстатокДоКорректировки + Строка.СуммаДоКорректировки;
			НакопленныйОстатокКорректировка = НакопленныйОстатокКорректировка + Строка.СуммаКорректировки;
			СтрокаКонец.Сумма = НакопленныйОстаток;
			СтрокаКонец.СуммаДоКорректировки = НакопленныйОстатокДоКорректировки;
			СтрокаКонец.СуммаКорректировки = НакопленныйОстатокКорректировка;
		КонецЕсли;
	КонецЦикла;
	
	ДанныеБюджета.Вставить("ОстаткиНачало", ТаблицаОстатковНачало);
	ДанныеБюджета.Вставить("ОстаткиКонец",  ТаблицаОстатковКонец);
	
КонецПроцедуры

Процедура ВывестиШапку(РеквизитыДокумента, КолонкиДетализации, ТабличныйДокумент, Макет)
	
	// Шапка
	Шапка = Макет.ПолучитьОбласть("Шапка");
	Шапка.Параметры.Заполнить(РеквизитыДокумента);
	ТабличныйДокумент.Вывести(Шапка);
	
	// Шапка таблицы
	ШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы|ОсновнаяЧасть");
	ТабличныйДокумент.Вывести(ШапкаТаблицы);
	ШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы|Итого");
	ТабличныйДокумент.Присоединить(ШапкаТаблицы);
	
	СтруктураПараметров = Новый Структура;
	Если РеквизитыДокумента.Детализация = Перечисления.Периодичность.Квартал Тогда
		НадписьДетализация = НСтр("ru='кварталам'");
	Иначе
		НадписьДетализация = НСтр("ru='месяцам'");
	КонецЕсли;
	СтруктураПараметров.Вставить("НадписьДетализация", НадписьДетализация);
	
	НомерЯчейкиНачало = ТабличныйДокумент.ШиринаТаблицы;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		СтруктураПараметров.Вставить("ДетализацияПериода", Колонка.Заголовок);
		ШапкаТаблицаПериод = Макет.ПолучитьОбласть("ШапкаТаблицы|Детализация");
		ШапкаТаблицаПериод.Параметры.Заполнить(СтруктураПараметров);
		ТабличныйДокумент.Присоединить(ШапкаТаблицаПериод);
	КонецЦикла;
	НомерЯчейкиКонец = ТабличныйДокумент.ШиринаТаблицы;
	НомерСтроки = ТабличныйДокумент.ВысотаТаблицы - 2; // Объединяем только верхнюю строку, где написано "В том числе по"
	ТабличныйДокумент.Область(НомерСтроки, НомерЯчейкиНачало - 2, НомерСтроки, НомерЯчейкиКонец).Объединить();
	
КонецПроцедуры

Процедура ВывестиДоходы(ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет)
	
	ЕстьКорректировкиПоДоходам = Ложь;
	Для Каждого СтрокаДоходы Из ДанныеБюджета.Доходы Цикл
		Если СтрокаДоходы.СуммаКорректировки <> 0 Тогда
			ЕстьКорректировкиПоДоходам = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЕстьКорректировкиПоДоходам Тогда
		Возврат;
	КонецЕсли;
	
	// Раздел "Доходы"
	Раздел = НСтр("ru='Финансирование'");
	ВывестиРаздел(Раздел, КолонкиДетализации, ТабличныйДокумент, Макет);
	
	// Строки таблицы
	СтруктураПоиска = Новый Структура("Родитель", Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
	ТаблицаСтруктурыДоходов = ДанныеБюджета.СтруктураДоходов.Скопировать(СтруктураПоиска);
	ТаблицаИтоговПоДоходам = ДанныеБюджета.Доходы.СкопироватьКолонки();
	ДанныеБюджета.Вставить("ИтогиПоДоходам", ТаблицаИтоговПоДоходам);
	ВывестиДоходыСИерархией(ТаблицаСтруктурыДоходов, "", ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет, 0);
	
	// Итоги по разделу
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Итого финансирования:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	ТаблицаДоходов = ДанныеБюджета.ИтогиПоДоходам;
	ТаблицаДоходов.Свернуть("ДатаПланирования", "Сумма,СуммаДоКорректировки,СуммаКорректировки");
	ВывестиСуммы(ТаблицаДоходов, "ИтогоПоРазделу", Макет, ТабличныйДокумент, КолонкиДетализации);
	
КонецПроцедуры

Процедура ВывестиДоходыСИерархией(ТаблицаСтруктураДоходов, НомерПоПорядку, ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет, Уровень)
	
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаДохода|ОсновнаяЧасть");
	НовыйНомерПоПорядку = 1;
	Для Каждого СтрокаДоходы Из ТаблицаСтруктураДоходов Цикл
		
		ТаблицаДоходовПоСтатье = ДанныеБюджета.Доходы.Скопировать(Новый Структура("СтатьяДохода", СтрокаДоходы.СтатьяДохода));
		ТаблицаДоходовПоСтатье.Сортировать("ДатаПланирования Возр");
		СтрокаИтого = ТаблицаДоходовПоСтатье[0];
		Если Не ЗначениеЗаполнено(СтрокаИтого.СуммаКорректировки) Тогда
			// Нет корректировок
			Продолжить;
		КонецЕсли;
	
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("НомерСтроки",  СтрШаблон("%1%2", НомерПоПорядку, НовыйНомерПоПорядку));
		СтруктураПараметров.Вставить("СтатьяДохода", СтрокаДоходы.СтатьяДохода);
		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ОбластьСтрока.Области.СтатьяДохода.Отступ = Уровень * 2;
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		ВывестиСуммы(ТаблицаДоходовПоСтатье, "СтрокаДохода", Макет, ТабличныйДокумент, КолонкиДетализации);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДоходовПоСтатье, ДанныеБюджета.ИтогиПоДоходам);
		
		Если СтрокаДоходы.ЭтоГруппа Тогда
			НомерПоПорядкуДляСледующейГруппы = СтрШаблон("%1%2.", НомерПоПорядку, НовыйНомерПоПорядку);
			НоваяТаблицаСтруктурыДоходов = ДанныеБюджета.СтруктураДоходов.Скопировать(
				Новый Структура("Родитель", СтрокаДоходы.СтатьяДохода));
			НовыйУровень = Уровень + 1;
			ВывестиДоходыСИерархией(
				НоваяТаблицаСтруктурыДоходов,
				НомерПоПорядкуДляСледующейГруппы,
				ДанныеБюджета,
				КолонкиДетализации,
				ТабличныйДокумент,
				Макет,
				НовыйУровень);
		КонецЕсли;
		НовыйНомерПоПорядку = НовыйНомерПоПорядку + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиРаздел(ИмяРаздела, КолонкиДетализации, ТабличныйДокумент, Макет)

	Раздел = Макет.ПолучитьОбласть("Раздел|ОсновнаяЧасть");
	Раздел.Параметры.Заполнить(Новый Структура("Раздел", ИмяРаздела));
	ТабличныйДокумент.Вывести(Раздел);
	РазделИтого = Макет.ПолучитьОбласть("Раздел|Итого");
	ТабличныйДокумент.Присоединить(РазделИтого);
	
	НомерЯчейкиНачало = РазделИтого.ШиринаТаблицы + Раздел.ШиринаТаблицы + 1;
	Счетчик = 1;
	Пока Счетчик < КолонкиДетализации.Количество() Цикл
		РазделПериод = Макет.ПолучитьОбласть("Раздел|Детализация");
		ТабличныйДокумент.Присоединить(РазделПериод);
		Счетчик = Счетчик + 1;
	КонецЦикла;
	НомерЯчейкиКонец = ТабличныйДокумент.ШиринаТаблицы;
	НомерСтроки = ТабличныйДокумент.ВысотаТаблицы;
	ОбластьОбъединения = ТабличныйДокумент.Область(НомерСтроки, НомерЯчейкиНачало, НомерСтроки, НомерЯчейкиКонец);
	ОбластьОбъединения.Объединить();
	ОбластьОбъединения.ГраницаСправа = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
	
КонецПроцедуры

Процедура ВывестиОстаткиНаНачало(Остатки, ТабличныйДокумент, Макет, КолонкиДетализации)
	
	Остатки.Сортировать("ДатаПланирования Возр");
	СтрокаИтого = Остатки[0];
	Если Не ЗначениеЗаполнено(СтрокаИтого.СуммаКорректировки) Тогда
		// Нет корректировок
		Возврат;
	КонецЕсли;
	
	// Остатки
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Остаток на начало:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	// Суммы
	ВывестиСуммы(Остатки, "ИтогоПоРазделу", Макет, ТабличныйДокумент, КолонкиДетализации);
	
КонецПроцедуры

Процедура ВывестиОстаткиНаКонец(Остатки, ТабличныйДокумент, Макет, КолонкиДетализации)
	
	Остатки.Сортировать("ДатаПланирования Возр");
	СтрокаИтого = Остатки[0];
	Если Не ЗначениеЗаполнено(СтрокаИтого.СуммаКорректировки) Тогда
		// Нет корректировок
		Возврат;
	КонецЕсли;
	
	// Остатки
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Остаток на конец:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	ВывестиСуммы(Остатки, "ИтогоПоРазделу", Макет, ТабличныйДокумент, КолонкиДетализации);
	
КонецПроцедуры

Процедура ВывестиРасходы(ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет)
	
	ЕстьКорректировкиПоРасходам = Ложь;
	Для Каждого СтрокаРасходы Из ДанныеБюджета.Расходы Цикл
		Если СтрокаРасходы.СуммаКорректировки <> 0 Тогда
			ЕстьКорректировкиПоРасходам = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЕстьКорректировкиПоРасходам Тогда
		Возврат;
	КонецЕсли;
	
	// Раздел "Расходы"
	Раздел = НСтр("ru='Расходы'");
	ВывестиРаздел(Раздел, КолонкиДетализации, ТабличныйДокумент, Макет);
	
	// Строки таблицы
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаНаправлениеДеятельности|ОсновнаяЧасть");
	НомерПоПорядку = 1;
	
	ТаблицаРасходыПоНаправлениямДеятельности = ДанныеБюджета.СтруктураРасходов.Скопировать();
	ТаблицаРасходыПоНаправлениямДеятельности.Свернуть("НаправлениеДеятельности");
	ТаблицаИтоговПоРасходам = ДанныеБюджета.РасходыПоНаправлениямДеятельности.СкопироватьКолонки();
	Для Каждого НаправлениеДеятельности Из ТаблицаРасходыПоНаправлениямДеятельности.ВыгрузитьКолонку("НаправлениеДеятельности") Цикл
		
		Отбор = Новый Структура("НаправлениеДеятельности", НаправлениеДеятельности);
		ТаблицаРасходовПоНаправлениямДеятельности = ДанныеБюджета.РасходыПоНаправлениямДеятельности.Скопировать(Отбор);
		ТаблицаРасходовПоНаправлениямДеятельности.Сортировать("ДатаПланирования Возр");
		СтрокаИтого = ТаблицаРасходовПоНаправлениямДеятельности[0];
		Если Не ЗначениеЗаполнено(СтрокаИтого.СуммаКорректировки) Тогда
			// По данному направлению деятельности нет корректровок
			Продолжить;
		КонецЕсли;
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("НомерСтроки",   НомерПоПорядку);
		СтруктураПараметров.Вставить("НаправлениеДеятельности", НаправлениеДеятельности);
		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		ВывестиСуммы(ТаблицаРасходовПоНаправлениямДеятельности, "СтрокаНаправлениеДеятельности", Макет, ТабличныйДокумент, КолонкиДетализации);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаРасходовПоНаправлениямДеятельности, ТаблицаИтоговПоРасходам);
		
		// Выводим подчиненные статьи расходов
		Отбор = Новый Структура(
			"НаправлениеДеятельности, Родитель",
			НаправлениеДеятельности, Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
		Уровень = 1;
		НомерПоПорядкуДляСтатьи = СтрШаблон("%1.", НомерПоПорядку);
		ВывестиСтрокиРасходовПоНаправлениюДеятельности(
			ДанныеБюджета,
			Отбор,
			НомерПоПорядкуДляСтатьи,
			Макет,
			ТабличныйДокумент,
			Уровень,
			КолонкиДетализации);
		
		НомерПоПорядку = НомерПоПорядку + 1;
		
	КонецЦикла;
	
	ТаблицаИтоговПоРасходам.Свернуть("ДатаПланирования", "Сумма,СуммаДоКорректировки,СуммаКорректировки");
	ТаблицаИтоговПоРасходам.Сортировать("ДатаПланирования Возр");
	
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Итого расходов:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	ВывестиСуммы(ТаблицаИтоговПоРасходам, "ИтогоПоРазделу", Макет, ТабличныйДокумент, КолонкиДетализации);
	
КонецПроцедуры

Процедура ВывестиСтрокиРасходовПоНаправлениюДеятельности(ДанныеБюджета, Отбор, НомерПоПорядкуДляСтатьи, Макет, ТабличныйДокумент, Уровень, КолонкиДетализации)

	ТаблицаСтруктураРасходов = ДанныеБюджета.СтруктураРасходов.Скопировать(Отбор);
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаРасхода|ОсновнаяЧасть");
		
	НомерПоПорядку = 1;
	Для Каждого СтрокаРасходов Из ТаблицаСтруктураРасходов Цикл
		
		СтатьяРасхода = СтрокаРасходов.СтатьяРасхода;
		Если Не ЗначениеЗаполнено(СтатьяРасхода) Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("НомерСтроки",   СтрШаблон("%1%2", НомерПоПорядкуДляСтатьи, НомерПоПорядку));
		СтруктураПараметров.Вставить("СтатьяРасхода", СтатьяРасхода);
		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ОбластьСтрока.Области.СтатьяРасхода.Отступ = Уровень * 2;
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		ТаблицаПоСтатьям = ДанныеБюджета.Расходы.Скопировать(
			Новый Структура("НаправлениеДеятельности, СтатьяРасхода", 
			Отбор.НаправлениеДеятельности, СтатьяРасхода));
		ВывестиСуммы(ТаблицаПоСтатьям, "СтрокаРасхода", Макет, ТабличныйДокумент, КолонкиДетализации);
		
		Если СтрокаРасходов.ЭтоГруппа Тогда
			НовыйОтбор = ОбщегоНазначения.СкопироватьРекурсивно(Отбор);
			НовыйОтбор.Родитель = СтатьяРасхода;
			НовыйНомерПоПорядкуДляСтатьи = СтрШаблон("%1%2.", НомерПоПорядкуДляСтатьи, НомерПоПорядку);
			НовыйУровень = Уровень + 1;
			ВывестиСтрокиРасходовПоНаправлениюДеятельности(
				ДанныеБюджета,
				НовыйОтбор,
				НовыйНомерПоПорядкуДляСтатьи,
				Макет,
				ТабличныйДокумент,
				НовыйУровень,
				КолонкиДетализации);
		КонецЕсли;
		
		НомерПоПорядку = НомерПоПорядку + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиСуммы(Таблица, ИмяОбласти, Макет, ТабличныйДокумент, КолонкиДетализации)
	
	Если Таблица.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Таблица.Сортировать("ДатаПланирования Возр");
	
	// У итого нет даты планирования
	СтрокаИтого = Таблица[0];
	
	ОбластьСтрокаИтого = Макет.ПолучитьОбласть(СтрШаблон("%1|Итого", ИмяОбласти));
	ОбластьСтрокаИтого.Параметры.Заполнить(СтрокаИтого);
	ТабличныйДокумент.Присоединить(ОбластьСтрокаИтого);
	
	Для Каждого КолонкаДетализации Из КолонкиДетализации Цикл
		ОбластьСтрокаДетализация = Макет.ПолучитьОбласть(СтрШаблон("%1|Детализация", ИмяОбласти));
		СтрокаТаблицы = Таблица.Найти(КолонкаДетализации.Дата, "ДатаПланирования");
		Если СтрокаТаблицы <> Неопределено Тогда
			ОбластьСтрокаДетализация.Параметры.Заполнить(СтрокаТаблицы);
		КонецЕсли;
		ТабличныйДокумент.Присоединить(ОбластьСтрокаДетализация);
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиПодвал(РеквизитыДокумента, ТабличныйДокумент, Макет)
	
	ОтветственныеЛицаОрганизации = ОтветственныеЛицаБП.ОтветственныеЛица(
		РеквизитыДокумента.Организация, РеквизитыДокумента.Период);
	
	Подвал = Макет.ПолучитьОбласть("Подвал");
	Подвал.Параметры.Заполнить(ОтветственныеЛицаОрганизации);
	ТабличныйДокумент.Вывести(Подвал);
	
КонецПроцедуры

#КонецОбласти

Функция ДокументКорректировкиБюджета(Бюджет)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Бюджет", Бюджет);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КорректировкаБюджета.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.КорректировкаБюджета КАК КорректировкаБюджета
	|ГДЕ
	|	КорректировкаБюджета.Бюджет = &Бюджет
	|	И НЕ КорректировкаБюджета.ПометкаУдаления";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Документы.КорректировкаБюджета.ПустаяСсылка();
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Ссылка;
	КонецЕсли;

КонецФункции

Функция ДокументОснованиеКорректировки(Ссылка)
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.Бюджет") Тогда
		Возврат Ссылка;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КорректировкаБюджета", Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КорректировкаБюджета.Бюджет КАК Бюджет
	|ИЗ
	|	Документ.КорректировкаБюджета КАК КорректировкаБюджета
	|ГДЕ
	|	КорректировкаБюджета.Ссылка = &КорректировкаБюджета";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Бюджет;
	
КонецФункции

Функция ДанныеБюджетаДляКорректировки(Бюджет)
	
	ДанныеКорректировки = БюджетДоходовРасходов.НовыйДанныеКорректировки();
	
	ДанныеБюджета = Документы.Бюджет.ДанныеБюджета(Бюджет);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеБюджета.Реквизиты, ДанныеКорректировки.Реквизиты);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеБюджета.Доходы, ДанныеКорректировки.Доходы);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеБюджета.Расходы, ДанныеКорректировки.Расходы);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеБюджета.РасходыПоНаправлениямДеятельности, ДанныеКорректировки.РасходыПоНаправлениямДеятельности);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеБюджета.СтруктураДоходов, ДанныеКорректировки.СтруктураДоходов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ДанныеБюджета.СтруктураРасходов, ДанныеКорректировки.СтруктураРасходов);
	
	Реквизиты = ДанныеКорректировки.Реквизиты[0];
	Реквизиты.ОстатокНаНачалоДоКорректировки = ДанныеКорректировки.Реквизиты[0].ОстатокНаНачало;
	Реквизиты.Бюджет = Бюджет;
	Реквизиты.Утвержден = Ложь;
	
	ЗаполнитьСуммыКорректировокПоУмолчанию(ДанныеКорректировки.Доходы);
	ЗаполнитьСуммыКорректировокПоУмолчанию(ДанныеКорректировки.Расходы);
	ЗаполнитьСуммыКорректировокПоУмолчанию(ДанныеКорректировки.РасходыПоНаправлениямДеятельности);
	
	Возврат ДанныеКорректировки;
	
КонецФункции

Процедура ЗаполнитьСуммыКорректировокПоУмолчанию(ТаблицаДокумента)
	
	Для Каждого СтрокаТаблицы Из ТаблицаДокумента Цикл
		СтрокаТаблицы.СуммаДоКорректировки = СтрокаТаблицы.Сумма;
		СтрокаТаблицы.СуммаКорректировки = 0;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьКорректировкуИзЗагрузки(ДокументСоздания, ДокументСсылка) Экспорт
	
	ДокументСоздания.Заполнить(ДокументСсылка);
	ДокументСоздания.Дата = ТекущаяДатаСеанса();
	ДокументСоздания.Период = ТекущаяДатаСеанса();
	ДокументСоздания.Бюджет = ДокументСсылка; 
	ДокументСоздания.Детализация = ДокументСсылка.Детализация;
	ДокументСоздания.Организация = ДокументСсылка.Организация;
	
КонецПроцедуры
#КонецОбласти

#КонецЕсли