// Функция возвращает время документа по умолчанию.
// Требуется если пользователь используется опцию:
// "Время документов устанавливать автоматически".
//
// Возвращаемое значение:
//    Структура - Структура с ключами "Часы" и "Минуты".
//
Функция ВремяДокументаПоУмолчанию() Экспорт
	
	Возврат Новый Структура("Часы, Минуты", 8, 0);
	
КонецФункции

// Возвращает последнюю корректировку бюджета. Последняя корректировка хранит актуальную структуру бюджета
//
// Параметры:
//    Бюджет - ДокументСсылка.Бюджет - Ссылка на бюджет
// Возвращаемое значение:
//     - ДокументСсылка.КорректировкаБюджета - последняя корректировка
//     - ДокументСсылка.Бюджет - ссылка на сам бюджет, если корректировок нет
//
Функция ПоследняяКорректировка(Бюджет) Экспорт
	
	КорректировкаБюджета = ДокументКорректировкиБюджета(Бюджет);
	Если КорректировкаБюджета.Пустая() Тогда
		Возврат Бюджет;
	КонецЕсли;
	
	Возврат ПоследняяКорректировка(КорректировкаБюджета);
	
КонецФункции

// Возвращает массив со всеми корректировками бюджета
//
// Параметры:
//    Ссылка - ДокументСсылка.Бюджет - Ссылка на бюджет
// Возвращаемое значение:
//     - Массив из ДокументСсылка.КорректировкаБюджета
//
Функция ВсеКорректировки(Знач Ссылка) Экспорт
	
	ВсеКорректировки = Новый Массив;
	ЕстьКорректировка = Истина;
	
	Пока ЕстьКорректировка Цикл
		Ссылка = ДокументКорректировкиБюджета(Ссылка);
		Если Не Ссылка.Пустая() Тогда
			ВсеКорректировки.Добавить(Ссылка);
		Иначе
			ЕстьКорректировка = Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ВсеКорректировки;
	
КонецФункции

// Возвращает ссылку на исходный бюджет, по которому введена корректировка
//
// Параметры:
//    Ссылка - ДокументСсылка.КорректировкаБюджета - Ссылка на корректировку
// Возвращаемое значение:
//     - ДокументСсылка.Бюджет
//
Функция БюджетПоКорректировке(Знач Ссылка) Экспорт
	
	Ссылка = ДокументОснованиеКорректировки(Ссылка);
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.Бюджет") Тогда
		Возврат Ссылка;
	КонецЕсли;
	
	Возврат БюджетПоКорректировке(Ссылка);
	
КонецФункции

// Функция возвращает данные корректировки бюджета
//
// Параметры:
//    Ссылка - ДокументСсылка.КорректировкаБюджета - Ссылка на документ, которых хранит данные корректировки.
// Возвращаемое значение:
//    Структура - см. БюджетДоходовРасходов.НовыйДанныеКорректировки
//
Функция ДанныеКорректировки(Ссылка) Экспорт
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.Бюджет") Тогда
		// Вернем данные исходного бюджета,
		// дополненные колонками для сумм корректировки
		Возврат ДанныеБюджетаДляКорректировки(Ссылка);
	КонецЕсли;
	
	ДанныеКорректировки = БюджетДоходовРасходов.НовыйДанныеКорректировки();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КорректировкаБюджета.Организация КАК Организация,
	|	КорректировкаБюджета.Детализация КАК Детализация,
	|	КорректировкаБюджета.Бюджет КАК Бюджет,
	|	КорректировкаБюджета.Период КАК Период,
	|	КорректировкаБюджета.Утвержден КАК Утвержден,
	|	КорректировкаБюджета.ОстатокНаНачало КАК ОстатокНаНачало,
	|	КорректировкаБюджета.ОстатокНаНачалоДоКорректировки КАК ОстатокНаНачалоДоКорректировки,
	|	КорректировкаБюджета.ОстатокНаНачалоКорректировка КАК ОстатокНаНачалоКорректировка,
	|	КорректировкаБюджета.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.КорректировкаБюджета КАК КорректировкаБюджета
	|ГДЕ
	|	КорректировкаБюджета.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КорректировкаБюджетаДоходы.ДатаПланирования КАК ДатаПланирования,
	|	КорректировкаБюджетаДоходы.СтатьяДохода КАК СтатьяДохода,
	|	КорректировкаБюджетаДоходы.ЭтоГруппа КАК ЭтоГруппа,
	|	КорректировкаБюджетаДоходы.Сумма КАК Сумма,
	|	КорректировкаБюджетаДоходы.СуммаДоКорректировки КАК СуммаДоКорректировки,
	|	КорректировкаБюджетаДоходы.СуммаКорректировки КАК СуммаКорректировки
	|ИЗ
	|	Документ.КорректировкаБюджета.Доходы КАК КорректировкаБюджетаДоходы
	|ГДЕ
	|	КорректировкаБюджетаДоходы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КорректировкаБюджетаРасходы.ДатаПланирования КАК ДатаПланирования,
	|	КорректировкаБюджетаРасходы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	КорректировкаБюджетаРасходы.СтатьяРасхода КАК СтатьяРасхода,
	|	КорректировкаБюджетаРасходы.ЭтоГруппа КАК ЭтоГруппа,
	|	КорректировкаБюджетаРасходы.Сумма КАК Сумма,
	|	КорректировкаБюджетаРасходы.СуммаДоКорректировки КАК СуммаДоКорректировки,
	|	КорректировкаБюджетаРасходы.СуммаКорректировки КАК СуммаКорректировки
	|ИЗ
	|	Документ.КорректировкаБюджета.Расходы КАК КорректировкаБюджетаРасходы
	|ГДЕ
	|	КорректировкаБюджетаРасходы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КорректировкаБюджетаРасходыПоНаправлениямДеятельности.ДатаПланирования КАК ДатаПланирования,
	|	КорректировкаБюджетаРасходыПоНаправлениямДеятельности.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	КорректировкаБюджетаРасходыПоНаправлениямДеятельности.Сумма КАК Сумма,
	|	КорректировкаБюджетаРасходыПоНаправлениямДеятельности.СуммаДоКорректировки КАК СуммаДоКорректировки,
	|	КорректировкаБюджетаРасходыПоНаправлениямДеятельности.СуммаКорректировки КАК СуммаКорректировки
	|ИЗ
	|	Документ.КорректировкаБюджета.РасходыПоНаправлениямДеятельности КАК КорректировкаБюджетаРасходыПоНаправлениямДеятельности
	|ГДЕ
	|	КорректировкаБюджетаРасходыПоНаправлениямДеятельности.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаПланирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КорректировкаБюджетаСтруктураДоходов.СтатьяДохода КАК СтатьяДохода,
	|	КорректировкаБюджетаСтруктураДоходов.Родитель КАК Родитель,
	|	КорректировкаБюджетаСтруктураДоходов.ЭтоГруппа КАК ЭтоГруппа
	|ИЗ
	|	Документ.КорректировкаБюджета.СтруктураДоходов КАК КорректировкаБюджетаСтруктураДоходов
	|ГДЕ
	|	КорректировкаБюджетаСтруктураДоходов.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	КорректировкаБюджетаСтруктураДоходов.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КорректировкаБюджетаСтруктураРасходов.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	КорректировкаБюджетаСтруктураРасходов.СтатьяРасхода КАК СтатьяРасхода,
	|	КорректировкаБюджетаСтруктураРасходов.Родитель КАК Родитель,
	|	КорректировкаБюджетаСтруктураРасходов.ЭтоГруппа КАК ЭтоГруппа
	|ИЗ
	|	Документ.КорректировкаБюджета.СтруктураРасходов КАК КорректировкаБюджетаСтруктураРасходов
	|ГДЕ
	|	КорректировкаБюджетаСтруктураРасходов.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	КорректировкаБюджетаСтруктураРасходов.НомерСтроки";
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаРеквизиты = РезультатыЗапроса[0].Выбрать();
	ВыборкаРеквизиты.Следующий();
	ЗаполнитьЗначенияСвойств(ДанныеКорректировки.Реквизиты.Добавить(), ВыборкаРеквизиты);
	
	ВыборкаДоходы = РезультатыЗапроса[1].Выбрать();
	Пока ВыборкаДоходы.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеКорректировки.Доходы.Добавить(), ВыборкаДоходы);
	КонецЦикла;
	
	ВыборкаРасходы = РезультатыЗапроса[2].Выбрать();
	Пока ВыборкаРасходы.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеКорректировки.Расходы.Добавить(), ВыборкаРасходы);
	КонецЦикла;
	
	ВыборкаРасходыПоНаправлениямДеятельности = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаРасходыПоНаправлениямДеятельности.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(
			ДанныеКорректировки.РасходыПоНаправлениямДеятельности.Добавить(), ВыборкаРасходыПоНаправлениямДеятельности);
	КонецЦикла;
		
	ВыборкаСтруктураДоходов = РезультатыЗапроса[4].Выбрать();
	Пока ВыборкаСтруктураДоходов.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеКорректировки.СтруктураДоходов.Добавить(), ВыборкаСтруктураДоходов);
	КонецЦикла;
	
	ВыборкаСтруктураРасходов = РезультатыЗапроса[5].Выбрать();
	Пока ВыборкаСтруктураРасходов.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеКорректировки.СтруктураРасходов.Добавить(), ВыборкаСтруктураРасходов);
	КонецЦикла;
	
	Возврат ДанныеКорректировки;
	
КонецФункции

// Функция возвращает табличный документ с корректировкой бюджета
//
// Параметры:
//    Параметры - Структура - Структура с обязательным параметром Ссылка на документ "КорректировкаБюджета"
// Возвращаемое значение:
//    ТабличныйДокумент - Печатная форма
//
Функция СформироватьПечатнуюФорму(Параметры) Экспорт
	
	ДанныеКорректировки = ДанныеКорректировки(Параметры.Ссылка);
	РеквизитыДокумента = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ДанныеКорректировки.Реквизиты[0]);
	РеквизитыДокумента.Вставить("ДокументПредставление", Строка(Параметры.Ссылка));
	
	РеквизитыБюджета = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Параметры.Бюджет, "Детализация,Период");
	КолонкиДетализации = БюджетДоходовРасходов.НовыйКолонкиДетализации();
	БюджетДоходовРасходов.ЗаполнитьКолонкиДетализации(КолонкиДетализации, РеквизитыБюджета);
	
	ДополнитьБюджетОстатками(ДанныеКорректировки, РеквизитыДокумента);
	
	ТекущаяКорректировка = Новый ТабличныйДокумент;
	Макет = ПолучитьМакет("КорректировкаБюджета");
	
	ВывестиШапку(РеквизитыДокумента, КолонкиДетализации, ТекущаяКорректировка, Макет);
	
	ВывестиОстаткиНаНачало(ДанныеКорректировки.ОстаткиНачало, ТекущаяКорректировка, Макет, КолонкиДетализации);
	
	ВывестиДоходы(ДанныеКорректировки, КолонкиДетализации, ТекущаяКорректировка, Макет);
	
	ВывестиРасходы(ДанныеКорректировки, КолонкиДетализации, ТекущаяКорректировка, Макет);
	
	ВывестиОстаткиНаКонец(ДанныеКорректировки.ОстаткиКонец, ТекущаяКорректировка, Макет, КолонкиДетализации);
	
	ВывестиПодвал(РеквизитыДокумента, ТекущаяКорректировка, Макет);
	
	Возврат ТекущаяКорректировка;
	
КонецФункции

// Получает описание предопределенных наборов свойств.
//
// Параметры:
//  Наборы - ДеревоЗначений - с колонками:
//     * Имя           - Строка - Имя набора свойств. Формируется из полного имени объекта
//                       метаданных заменой символа "." на "_".
//                       Например, "Документ_КорректировкаБюджета".
//     * Идентификатор - УникальныйИдентификатор - Идентификатор ссылки предопределенного элемента.
//     * Используется  - Неопределено, Булево - Признак того, что набор свойств используется.
//                       Например, можно использовать для скрытия набора по функциональным опциям.
//                       Значение по умолчанию - Неопределено, соответствует значению Истина.
//     * ЭтоГруппа     - Булево - Истина, если набор свойств является группой.
//
Процедура ПриПолученииПредопределенныхНаборовСвойств(Наборы) Экспорт
	
	Набор = Наборы.Строки.Добавить();
	Набор.Имя = "Документ_КорректировкаБюджета";
	Набор.ЭтоГруппа = Истина;
	Набор.Идентификатор = Новый УникальныйИдентификатор("08e94c2b-54ce-4498-8b3f-8f4cd0acaaa0");
	Набор.Используется  = ПолучитьФункциональнуюОпцию("ВестиУчетБюджета");
	
КонецПроцедуры

