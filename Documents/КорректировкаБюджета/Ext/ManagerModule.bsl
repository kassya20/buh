#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	Если ВидФормы = "ФормаОбъекта" Тогда
		// Корректировка редактируется через форму специальной обработки "КорректировкаБюджета"
		Если Параметры.Свойство("Ключ") Тогда
			Параметры.Вставить("ДокументСсылка", Параметры.Ключ);
		КонецЕсли;
		Если ДополнительнаяИнформация.Свойство("ПовторноеИспользование") Тогда
			ДополнительнаяИнформация.ПовторноеИспользование = Истина;
		КонецЕсли;
		ВыбраннаяФорма = "Обработка.КорректировкаБюджета.Форма";
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПолученияПредставления(Данные, Представление, СтандартнаяОбработка)
	
	Если Данные.Свойство("Номер") И Данные.Свойство("Дата") Тогда
		СтандартнаяОбработка = Ложь;
		Представление = СтрШаблон(НСтр("ru='Корректировка бюджета № %1 от %2'", ОбщегоНазначения.КодОсновногоЯзыка()),
			ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Данные.Номер, Истина),
			Формат(Данные.Дата, "ДФ=dd.MM.yyyy"));
	КонецЕсли;
	
КонецПроцедуры

