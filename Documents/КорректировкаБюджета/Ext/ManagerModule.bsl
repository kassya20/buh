//
// Параметры:
//  Настройки - Структура - настройки подсистемы.
Процедура ПриОпределенииНастроекВерсионированияОбъектов(Настройки) Экспорт

КонецПроцедуры

// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

#КонецОбласти

#Область ПодготовкаПараметровПроведения

Функция ПодготовитьПараметрыПроведения(ДокументСсылка, Отказ) Экспорт
	
	ПараметрыПроведения = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	
	НомераТаблиц = Новый Структура;
	
	Запрос.Текст = ТекстЗапросаРеквизитыДокумента(НомераТаблиц);
	Результат    = Запрос.ВыполнитьПакет();
	ТаблицаРеквизиты = Результат[НомераТаблиц["Реквизиты"]].Выгрузить();
	ПараметрыПроведения.Вставить("Реквизиты", ТаблицаРеквизиты);
	
	НомераТаблиц = Новый Структура;
	Запрос.Текст = ТекстЗапросаРасходы(НомераТаблиц) +
		ТекстЗапросаДоходы(НомераТаблиц) +
		ТекстЗапросаСтруктураДоходов(НомераТаблиц) +
		ТекстЗапросаСтруктураРасходов(НомераТаблиц);
	
	Результат = Запрос.ВыполнитьПакет();
	
	Если Не ПустаяСтрока(Запрос.Текст) Тогда
		Для Каждого НомерТаблицы Из НомераТаблиц Цикл
			ПараметрыПроведения.Вставить(НомерТаблицы.Ключ, Результат[НомерТаблицы.Значение].Выгрузить());
		КонецЦикла;
	КонецЕсли;
	
	Возврат ПараметрыПроведения;
	
КонецФункции 

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПодготовкаПараметровПроведения

Функция ТекстЗапросаРеквизитыДокумента(НомераТаблиц)
	
	НомераТаблиц.Вставить("ВременнаяТаблицаРеквизиты", НомераТаблиц.Количество());
	НомераТаблиц.Вставить("Реквизиты", НомераТаблиц.Количество());
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	КорректировкаБюджета.Ссылка КАК Регистратор,
	|	КорректировкаБюджета.Дата КАК Период,
	|	КорректировкаБюджета.Организация КАК Организация,
	|	КорректировкаБюджета.Детализация КАК Детализация
	|ПОМЕСТИТЬ Реквизиты
	|ИЗ
	|	Документ.КорректировкаБюджета КАК КорректировкаБюджета
	|ГДЕ
	|	КорректировкаБюджета.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Реквизиты.Регистратор КАК Регистратор,
	|	Реквизиты.Период КАК Период,
	|	Реквизиты.Организация КАК Организация,
	|	Реквизиты.Детализация КАК Детализация
	|ИЗ
	|	Реквизиты КАК Реквизиты";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаРасходы(НомераТаблиц)
	
	НомераТаблиц.Вставить("Расходы", НомераТаблиц.Количество());
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	КорректировкаБюджетаРасходы.ДатаПланирования КАК Период,
	|	КорректировкаБюджетаРасходы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	КорректировкаБюджетаРасходы.СтатьяРасхода КАК СтатьяРасхода,
	|	КорректировкаБюджетаРасходы.СуммаКорректировки КАК Сумма,
	|	КорректировкаБюджетаРасходы.СуммаДоКорректировки КАК СуммаДоКорректировки,
	|	КорректировкаБюджетаРасходы.СуммаКорректировки КАК СуммаКорректировки
	|ИЗ
	|	Документ.КорректировкаБюджета.Расходы КАК КорректировкаБюджетаРасходы
	|ГДЕ
	|	КорректировкаБюджетаРасходы.Ссылка = &Ссылка
	|	И КорректировкаБюджетаРасходы.ДатаПланирования <> ДАТАВРЕМЯ(1, 1, 1)
	|	И НЕ КорректировкаБюджетаРасходы.ЭтоГруппа";
	
	Возврат ТекстЗапроса + ОбщегоНазначенияБПВызовСервера.ТекстРазделителяЗапросовПакета();
КонецФункции

