#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
#Область ПрограммныйИнтерфейс

// Функция возвращает время документа по умолчанию.
// Требуется если пользователь используется опцию:
// "Время документов устанавливать автоматически".
//
// Возвращаемое значение:
//    Структура - Структура с ключами "Часы" и "Минуты".
//
Функция ВремяДокументаПоУмолчанию() Экспорт
	
	Возврат Новый Структура("Часы, Минуты", 8, 0);
	
КонецФункции

// Функция возвращает последний бюджет по организации
//
// Параметры:
//    Организация - Справочник.Организации - Организация, по которой был сформирован бюджет
// Возвращаемое значение:
//    ДокументСсылка.Бюджет - Ссылка на Документ "Бюджет"
//
Функция ПоследнийБюджет(Организация) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Бюджет.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Бюджет КАК Бюджет
	|ГДЕ
	|	Бюджет.Организация = &Организация
	|	И Бюджет.Проведен
	|
	|УПОРЯДОЧИТЬ ПО
	|	Бюджет.Период УБЫВ";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Документы.Бюджет.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

// Функция возвращает бюджет по организации и периоду
//
// Параметры:
//    Организация - Справочник.Организации - Организация, по которой был сформирован бюджет
//    Период - Дата - Период, на который составляется бюджет (год)
// Возвращаемое значение:
//    ДокументСсылка.Бюджет - Ссылка на Документ "Бюджет"
//
Функция БюджетНаПериод(Организация, Период) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период",      Период);
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Бюджет.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Бюджет КАК Бюджет
	|ГДЕ
	|	Бюджет.Организация = &Организация
	|	И Бюджет.Проведен
	|	И Бюджет.Период = &Период
	|
	|УПОРЯДОЧИТЬ ПО
	|	Бюджет.Период УБЫВ";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Документы.Бюджет.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

// Функция возвращает признак есть ли бюджет по организации в этом периоде
//
// Параметры:
//    Организация - Справочник.Организации - Организация, по которой запрашивается бюджет
//    Период - Дата - Дата, на которую запрашивается бюджет
// Возвращаемое значение:
//    Булево - Истина, в случае если бюджет на указанный период есть
//
Функция ЕстьБюджетНаПериод(Организация, Период) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ВестиУчетБюджета") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период",      НачалоГода(Период));
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
	|	Бюджет.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Бюджет КАК Бюджет
	|ГДЕ
	|	Бюджет.Организация = &Организация
	|	И Бюджет.Проведен
	|	И Бюджет.Период = &Период";
	РезультатЗапроса = Запрос.Выполнить();
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

// Функция возвращает данные бюджета
//
// Параметры:
//    Ссылка - Документ.Бюджет - Ссылка на документ, которых хранит данные бюджета.
// Возвращаемое значение:
//    Структура - Структура с данными документа
//
Функция ДанныеБюджета(Ссылка) Экспорт
	
	ДанныеБюджета = БюджетДоходовРасходов.НовыйДанныеБюджета();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Бюджет.Организация КАК Организация,
	|	Бюджет.Детализация КАК Детализация,
	|	Бюджет.Период КАК Период,
	|	Бюджет.Утвержден КАК Утвержден,
	|	Бюджет.ОстатокНаНачало КАК ОстатокНаНачало,
	|	Бюджет.Комментарий КАК Комментарий
	|ИЗ
	|	Документ.Бюджет КАК Бюджет
	|ГДЕ
	|	Бюджет.Ссылка = &Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(ДанныеБюджета.Реквизиты.Добавить(), Выборка);
	
	Реквизиты = ДанныеБюджета.Реквизиты[0];
	
	Запрос.УстановитьПараметр("ПоМесяцам", Реквизиты.Детализация = Перечисления.Периодичность.Месяц);
	Запрос.УстановитьПараметр("НачалоГода", НачалоГода(Реквизиты.Период));
	Запрос.УстановитьПараметр("КонецГода", КонецГода(Реквизиты.Период));
	Запрос.УстановитьПараметр("Организация", Реквизиты.Организация);
	
	Запрос.УстановитьПараметр("КорректировкиБюджета", Документы.КорректировкаБюджета.ВсеКорректировки(Ссылка));
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БюджетДоходы.ДатаПланирования КАК ДатаПланирования,
	|	БюджетДоходы.СтатьяДохода КАК СтатьяДохода,
	|	БюджетДоходы.ЭтоГруппа КАК ЭтоГруппа,
	|	СУММА(БюджетДоходы.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ВТ_БюджетДоходы
	|ИЗ
	|	Документ.Бюджет.Доходы КАК БюджетДоходы
	|ГДЕ
	|	БюджетДоходы.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	БюджетДоходы.ДатаПланирования,
	|	БюджетДоходы.СтатьяДохода,
	|	БюджетДоходы.ЭтоГруппа
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КорректировкаДоходы.ДатаПланирования,
	|	КорректировкаДоходы.СтатьяДохода,
	|	КорректировкаДоходы.ЭтоГруппа,
	|	СУММА(КорректировкаДоходы.СуммаКорректировки)
	|ИЗ
	|	Документ.КорректировкаБюджета.Доходы КАК КорректировкаДоходы
	|ГДЕ
	|	КорректировкаДоходы.Ссылка В(&КорректировкиБюджета)
	|
	|СГРУППИРОВАТЬ ПО
	|	КорректировкаДоходы.ДатаПланирования,
	|	КорректировкаДоходы.СтатьяДохода,
	|	КорректировкаДоходы.ЭтоГруппа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_БюджетДоходы.ДатаПланирования КАК ДатаПланирования,
	|	ВТ_БюджетДоходы.СтатьяДохода КАК СтатьяДохода,
	|	ВТ_БюджетДоходы.ЭтоГруппа КАК ЭтоГруппа,
	|	СУММА(ВТ_БюджетДоходы.Сумма) КАК Сумма
	|ИЗ
	|	ВТ_БюджетДоходы КАК ВТ_БюджетДоходы
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_БюджетДоходы.ДатаПланирования,
	|	ВТ_БюджетДоходы.СтатьяДохода,
	|	ВТ_БюджетДоходы.ЭтоГруппа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БюджетРасходы.ДатаПланирования КАК ДатаПланирования,
	|	БюджетРасходы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	БюджетРасходы.СтатьяРасхода КАК СтатьяРасхода,
	|	БюджетРасходы.ЭтоГруппа КАК ЭтоГруппа,
	|	СУММА(БюджетРасходы.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ВТ_БюджетРасходы
	|ИЗ
	|	Документ.Бюджет.Расходы КАК БюджетРасходы
	|ГДЕ
	|	БюджетРасходы.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	БюджетРасходы.ДатаПланирования,
	|	БюджетРасходы.НаправлениеДеятельности,
	|	БюджетРасходы.СтатьяРасхода,
	|	БюджетРасходы.ЭтоГруппа
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КорректировкаРасходы.ДатаПланирования,
	|	КорректировкаРасходы.НаправлениеДеятельности,
	|	КорректировкаРасходы.СтатьяРасхода,
	|	КорректировкаРасходы.ЭтоГруппа,
	|	СУММА(КорректировкаРасходы.СуммаКорректировки)
	|ИЗ
	|	Документ.КорректировкаБюджета.Расходы КАК КорректировкаРасходы
	|ГДЕ
	|	КорректировкаРасходы.Ссылка В(&КорректировкиБюджета)
	|
	|СГРУППИРОВАТЬ ПО
	|	КорректировкаРасходы.ДатаПланирования,
	|	КорректировкаРасходы.НаправлениеДеятельности,
	|	КорректировкаРасходы.СтатьяРасхода,
	|	КорректировкаРасходы.ЭтоГруппа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_БюджетРасходы.ДатаПланирования КАК ДатаПланирования,
	|	ВТ_БюджетРасходы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ВТ_БюджетРасходы.СтатьяРасхода КАК СтатьяРасхода,
	|	ВТ_БюджетРасходы.ЭтоГруппа КАК ЭтоГруппа,
	|	СУММА(ВТ_БюджетРасходы.Сумма) КАК Сумма
	|ИЗ
	|	ВТ_БюджетРасходы КАК ВТ_БюджетРасходы
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_БюджетРасходы.ДатаПланирования,
	|	ВТ_БюджетРасходы.НаправлениеДеятельности,
	|	ВТ_БюджетРасходы.СтатьяРасхода,
	|	ВТ_БюджетРасходы.ЭтоГруппа";
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаДоходы = РезультатыЗапроса[1].Выбрать();
	Пока ВыборкаДоходы.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.Доходы.Добавить(), ВыборкаДоходы);
	КонецЦикла;
	
	ВыборкаРасходы = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаРасходы.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.Расходы.Добавить(), ВыборкаРасходы);
	КонецЦикла;
	
	// Будет модифицирован схемой
	ТекстЗапросаСтруктураБюджета = 
	"ВЫБРАТЬ
	|	БюджетРасходыПоНаправлениямДеятельности.ДатаПланирования КАК ДатаПланирования,
	|	БюджетРасходыПоНаправлениямДеятельности.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	БюджетРасходыПоНаправлениямДеятельности.Сумма КАК Сумма
	|ИЗ
	|	Документ.Бюджет.РасходыПоНаправлениямДеятельности КАК БюджетРасходыПоНаправлениямДеятельности
	|ГДЕ
	|	БюджетРасходыПоНаправлениямДеятельности.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаПланирования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БюджетСтруктураДоходов.СтатьяДохода КАК СтатьяДохода,
	|	БюджетСтруктураДоходов.Родитель КАК Родитель,
	|	БюджетСтруктураДоходов.ЭтоГруппа КАК ЭтоГруппа
	|ИЗ
	|	Документ.Бюджет.СтруктураДоходов КАК БюджетСтруктураДоходов
	|ГДЕ
	|	БюджетСтруктураДоходов.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	БюджетСтруктураДоходов.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	БюджетСтруктураРасходов.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	БюджетСтруктураРасходов.СтатьяРасхода КАК СтатьяРасхода,
	|	БюджетСтруктураРасходов.Родитель КАК Родитель,
	|	БюджетСтруктураРасходов.ЭтоГруппа КАК ЭтоГруппа
	|ИЗ
	|	Документ.Бюджет.СтруктураРасходов КАК БюджетСтруктураРасходов
	|ГДЕ
	|	БюджетСтруктураРасходов.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	БюджетСтруктураРасходов.НомерСтроки";
	
	// Актуальная структура бюджета хранится всегда в последней корректировке,
	// либо в самом бюджете, если корректировки не вводились.
	ПоследняяКорректировка = Документы.КорректировкаБюджета.ПоследняяКорректировка(Ссылка);
	ИмяДокумента = ПоследняяКорректировка.Метаданные().Имя;
	
	СхемаЗапросаСтруктураБюджета = Новый СхемаЗапроса;
	СхемаЗапросаСтруктураБюджета.УстановитьТекстЗапроса(ТекстЗапросаСтруктураБюджета);
	
	Для Каждого ЗапросПакета Из СхемаЗапросаСтруктураБюджета.ПакетЗапросов Цикл
		ПолноеИмяТаблицыДокумента = ЗапросПакета.Операторы[0].Источники[0].Источник.ИмяТаблицы;
		ЧастиИмениТаблицыДокумента = СтрРазделить(ПолноеИмяТаблицыДокумента, ".");
		ИмяТабличнойЧасти = ЧастиИмениТаблицыДокумента[ЧастиИмениТаблицыДокумента.ВГраница()];
		ТаблицаСхемы = ЗапросПакета.ДоступныеТаблицы.Найти(СтрШаблон("Документ.%1.%2", ИмяДокумента, ИмяТабличнойЧасти));
		ЗапросПакета.Операторы[0].Источники.Заменить(0, ТаблицаСхемы);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("Ссылка", ПоследняяКорректировка);
	Запрос.Текст = СхемаЗапросаСтруктураБюджета.ПолучитьТекстЗапроса();
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ВыборкаПоНаправлениямДеятельности = РезультатыЗапроса[0].Выбрать();
	Пока ВыборкаПоНаправлениямДеятельности.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.РасходыПоНаправлениямДеятельности.Добавить(), ВыборкаПоНаправлениямДеятельности);
	КонецЦикла;
	
	ВыборкаСтруктураДоходов = РезультатыЗапроса[1].Выбрать();
	Пока ВыборкаСтруктураДоходов.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.СтруктураДоходов.Добавить(), ВыборкаСтруктураДоходов);
	КонецЦикла;
	
	ВыборкаСтруктураРасходов = РезультатыЗапроса[2].Выбрать();
	Пока ВыборкаСтруктураРасходов.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.СтруктураРасходов.Добавить(), ВыборкаСтруктураРасходов);
	КонецЦикла;
	
	Возврат ДанныеБюджета;
	
КонецФункции

// Функция возвращает табличный документ с бюджетом доходов и расходов
//
// Параметры:
//    Параметры - Структура - Структура с обязательным параметром Ссылка на документ "Бюджет"
// Возвращаемое значение:
//    ТабличныйДокумент - Печатная форма бюджета доходов и расходов
//
Функция СформироватьПечатнуюФорму(Параметры) Экспорт
	
	ДанныеБюджета      = ДанныеБюджета(Параметры.Ссылка);
	РеквизитыДокумента = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ДанныеБюджета.Реквизиты[0]);
	КолонкиДетализации = БюджетДоходовРасходов.НовыйКолонкиДетализации();
	БюджетДоходовРасходов.ЗаполнитьКолонкиДетализации(КолонкиДетализации, РеквизитыДокумента);
	
	ДополнитьБюджетОстатками(ДанныеБюджета, РеквизитыДокумента);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Макет = ПолучитьМакет("БюджетДоходовРасходов");
	
	ВывестиШапку(РеквизитыДокумента, КолонкиДетализации, ТабличныйДокумент, Макет);
	
	ВывестиОстаткиНаНачало(ДанныеБюджета.ОстаткиНачало, ТабличныйДокумент, Макет);
	
	ВывестиДоходы(ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет);
	
	ВывестиРасходы(ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет);
	
	ВывестиОстаткиНаКонец(ДанныеБюджета.ОстаткиКонец, ТабличныйДокумент, Макет);
	
	ВывестиПодвал(РеквизитыДокумента, ТабличныйДокумент, Макет);
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Получает описание предопределенных наборов свойств.
//
// Параметры:
//  Наборы - ДеревоЗначений - с колонками:
//     * Имя           - Строка - Имя набора свойств. Формируется из полного имени объекта
//                       метаданных заменой символа "." на "_".
//                       Например, "Документ_ЗаказПокупателя".
//     * Идентификатор - УникальныйИдентификатор - Идентификатор ссылки предопределенного элемента.
//     * Используется  - Неопределено, Булево - Признак того, что набор свойств используется.
//                       Например, можно использовать для скрытия набора по функциональным опциям.
//                       Значение по умолчанию - Неопределено, соответствует значению Истина.
//     * ЭтоГруппа     - Булево - Истина, если набор свойств является группой.
//
Процедура ПриПолученииПредопределенныхНаборовСвойств(Наборы) Экспорт
	
	Набор = Наборы.Строки.Добавить();
	Набор.Имя = "Документ_Бюджет";
	Набор.ЭтоГруппа = Истина;
	Набор.Идентификатор = Новый УникальныйИдентификатор("bc9f1ac7-943d-41b7-b3f3-15e54e453373");
	Набор.Используется  = ПолучитьФункциональнуюОпцию("ВестиУчетБюджета");
	
