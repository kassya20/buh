Процедура ДополнитьБюджетОстатками(ДанныеБюджета, Реквизиты)

	// Суммы
	ТаблицаДоходов = ДанныеБюджета.Доходы.Скопировать(Новый Структура("ЭтоГруппа", Ложь));
	ТаблицаДоходов.Свернуть("ДатаПланирования", "Сумма");
	ТаблицаРасходов = ДанныеБюджета.РасходыПоНаправлениямДеятельности.Скопировать();
	ТаблицаРасходов.Свернуть("ДатаПланирования", "Сумма");
	
	ТаблицаОстатков = ТаблицаДоходов.Скопировать();
	Для Каждого Строка Из ТаблицаРасходов Цикл
		НоваяСтрока = ТаблицаОстатков.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка, , "Сумма");
		НоваяСтрока.Сумма = -Строка.Сумма;
	КонецЦикла;
	ТаблицаОстатков.Свернуть("ДатаПланирования", "Сумма");
	ТаблицаОстатков.Сортировать("ДатаПланирования Возр");
	
	ТаблицаОстатковНачало = ТаблицаОстатков.СкопироватьКолонки();
	ТаблицаОстатковКонец = ТаблицаОстатков.СкопироватьКолонки();
	
	НакопленныйОстаток = Реквизиты.ОстатокНаНачало;
	
	Для Каждого Строка Из ТаблицаОстатков Цикл
		Если Не ЗначениеЗаполнено(Строка.ДатаПланирования) Тогда
			СтрокаНачало = ТаблицаОстатковНачало.Добавить();
			СтрокаНачало.Сумма = Реквизиты.ОстатокНаНачало;
			СтрокаКонец = ТаблицаОстатковКонец.Добавить();
			СтрокаКонец.Сумма = Реквизиты.ОстатокНаНачало + Строка.Сумма;
		Иначе
			СтрокаНачало = ТаблицаОстатковНачало.Добавить();
			СтрокаНачало.ДатаПланирования = Строка.ДатаПланирования;
			СтрокаНачало.Сумма = НакопленныйОстаток;
			
			СтрокаКонец = ТаблицаОстатковКонец.Добавить();
			СтрокаКонец.ДатаПланирования = Строка.ДатаПланирования;
			НакопленныйОстаток = НакопленныйОстаток + Строка.Сумма;
			СтрокаКонец.Сумма = НакопленныйОстаток;
		КонецЕсли;
	КонецЦикла;
	
	ДанныеБюджета.Вставить("ОстаткиНачало", ТаблицаОстатковНачало);
	ДанныеБюджета.Вставить("ОстаткиКонец",  ТаблицаОстатковКонец);
	
КонецПроцедуры

Процедура ВывестиШапку(РеквизитыДокумента, КолонкиДетализации, ТабличныйДокумент, Макет)
	
	// Шапка
	РеквизитыДокумента.Вставить("ПериодПредставление", Формат(РеквизитыДокумента.Период, "ДФ='yyyy ""г.""'"));
	Шапка = Макет.ПолучитьОбласть("Шапка");
	Шапка.Параметры.Заполнить(РеквизитыДокумента);
	ТабличныйДокумент.Вывести(Шапка);
	
	// Шапка таблицы
	ШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы|ОсновнаяЧасть");
	ТабличныйДокумент.Вывести(ШапкаТаблицы);
	ШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы|Итого");
	ТабличныйДокумент.Присоединить(ШапкаТаблицы);
	
	СтруктураПараметров = Новый Структура;
	Если РеквизитыДокумента.Детализация = Перечисления.Периодичность.Квартал Тогда
		НадписьДетализация = НСтр("ru='кварталам'");
	Иначе
		НадписьДетализация = НСтр("ru='месяцам'");
	КонецЕсли;
	СтруктураПараметров.Вставить("НадписьДетализация", НадписьДетализация);
	
	НомерЯчейкиНачало = ТабличныйДокумент.ШиринаТаблицы;
	Для Каждого Колонка Из КолонкиДетализации Цикл
		СтруктураПараметров.Вставить("ДетализацияПериода", Колонка.Заголовок);
		ШапкаТаблицаПериод = Макет.ПолучитьОбласть("ШапкаТаблицы|Детализация");
		ШапкаТаблицаПериод.Параметры.Заполнить(СтруктураПараметров);
		ТабличныйДокумент.Присоединить(ШапкаТаблицаПериод);
	КонецЦикла;
	НомерЯчейкиКонец = ТабличныйДокумент.ШиринаТаблицы;
	НомерСтроки = ТабличныйДокумент.ВысотаТаблицы - 1; // Объединяем только верхнюю строку, где написано "В том числе по"
	ТабличныйДокумент.Область(НомерСтроки, НомерЯчейкиНачало, НомерСтроки, НомерЯчейкиКонец).Объединить();
	
КонецПроцедуры

Процедура ВывестиДоходы(ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет)
	
	Если Не ЗначениеЗаполнено(ДанныеБюджета.Доходы) Тогда
		Возврат;
	КонецЕсли;
	
	// Раздел "Доходы"
	Раздел = НСтр("ru='Финансирование'");
	ВывестиРаздел(Раздел, КолонкиДетализации, ТабличныйДокумент, Макет);
	
	// Строки таблицы
	СтруктураПоиска = Новый Структура("Родитель", Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
	ТаблицаСтруктурыДоходов = ДанныеБюджета.СтруктураДоходов.Скопировать(СтруктураПоиска);
	ВывестиДоходыСИерархией(ТаблицаСтруктурыДоходов, "", ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет, 0);
	
	// Итоги по разделу
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Итого финансирования:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	ТаблицаДоходов = ДанныеБюджета.Доходы.Скопировать();
	ТаблицаДоходов.Свернуть("ДатаПланирования", "Сумма");
	ВывестиСуммы(ТаблицаДоходов, "ИтогоПоРазделу", Макет, ТабличныйДокумент);
	
КонецПроцедуры

Процедура ВывестиДоходыСИерархией(ТаблицаСтруктураДоходов, НомерПоПорядку, ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет, Уровень)
	
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаДохода|ОсновнаяЧасть");
	НовыйНомерПоПорядку = 1;
	
	Для Каждого СтрокаДоходы Из ТаблицаСтруктураДоходов Цикл
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("НомерСтроки",  СтрШаблон("%1%2", НомерПоПорядку, НовыйНомерПоПорядку));
		СтруктураПараметров.Вставить("СтатьяДохода", СтрокаДоходы.СтатьяДохода);
		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ОбластьСтрока.Области.СтатьяДохода.Отступ = Уровень * 2;
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		ТаблицаДоходовПоСтатье = ДанныеБюджета.Доходы.Скопировать(Новый Структура("СтатьяДохода", СтрокаДоходы.СтатьяДохода));
		ВывестиСуммы(ТаблицаДоходовПоСтатье, "СтрокаДохода", Макет, ТабличныйДокумент);
		
		Если СтрокаДоходы.ЭтоГруппа Тогда
			НомерПоПорядкуДляСледующейГруппы = СтрШаблон("%1%2.", НомерПоПорядку, НовыйНомерПоПорядку);
			НоваяТаблицаСтруктурыДоходов = ДанныеБюджета.СтруктураДоходов.Скопировать(
				Новый Структура("Родитель", СтрокаДоходы.СтатьяДохода));
			НовыйУровень = Уровень + 1;
			ВывестиДоходыСИерархией(
				НоваяТаблицаСтруктурыДоходов,
				НомерПоПорядкуДляСледующейГруппы,
				ДанныеБюджета,
				КолонкиДетализации,
				ТабличныйДокумент,
				Макет,
				НовыйУровень);
		КонецЕсли;
		НовыйНомерПоПорядку = НовыйНомерПоПорядку + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиРаздел(ИмяРаздела, КолонкиДетализации, ТабличныйДокумент, Макет)

	Раздел = Макет.ПолучитьОбласть("Раздел|ОсновнаяЧасть");
	Раздел.Параметры.Заполнить(Новый Структура("Раздел", ИмяРаздела));
	ТабличныйДокумент.Вывести(Раздел);
	РазделИтого = Макет.ПолучитьОбласть("Раздел|Итого");
	ТабличныйДокумент.Присоединить(РазделИтого);
	
	НомерЯчейкиНачало = РазделИтого.ШиринаТаблицы + Раздел.ШиринаТаблицы + 1;
	Счетчик = 1;
	Пока Счетчик < КолонкиДетализации.Количество() Цикл
		РазделПериод = Макет.ПолучитьОбласть("Раздел|Детализация");
		ТабличныйДокумент.Присоединить(РазделПериод);
		Счетчик = Счетчик + 1;
	КонецЦикла;
	НомерЯчейкиКонец = ТабличныйДокумент.ШиринаТаблицы;
	НомерСтроки = ТабличныйДокумент.ВысотаТаблицы;
	ОбластьОбъединения = ТабличныйДокумент.Область(НомерСтроки, НомерЯчейкиНачало, НомерСтроки, НомерЯчейкиКонец);
	ОбластьОбъединения.Объединить();
	ОбластьОбъединения.ГраницаСправа = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
	
КонецПроцедуры

Процедура ВывестиОстаткиНаНачало(Остатки, ТабличныйДокумент, Макет)
	
	// Остатки
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Остаток на начало:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	// Суммы
	ВывестиСуммы(Остатки, "ИтогоПоРазделу", Макет, ТабличныйДокумент);
	
КонецПроцедуры

Процедура ВывестиОстаткиНаКонец(Остатки, ТабличныйДокумент, Макет)
	
	// Остатки
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Остаток на конец:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	ВывестиСуммы(Остатки, "ИтогоПоРазделу", Макет, ТабличныйДокумент);
	
КонецПроцедуры

Процедура ВывестиРасходы(ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет)
	
	Если  Не ЗначениеЗаполнено(ДанныеБюджета.Расходы) Тогда
		Возврат;
	КонецЕсли;
	
	// Раздел "Расходы"
	Раздел = НСтр("ru='Расходы'");
	ВывестиРаздел(Раздел, КолонкиДетализации, ТабличныйДокумент, Макет);
	
	// Строки таблицы
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаНаправлениеДеятельности|ОсновнаяЧасть");
	НомерПоПорядку = 1;
	
	ТаблицаРасходыПоНаправлениямДеятельности = ДанныеБюджета.СтруктураРасходов.Скопировать();
	ТаблицаРасходыПоНаправлениямДеятельности.Свернуть("НаправлениеДеятельности");
	Для Каждого НаправлениеДеятельности Из ТаблицаРасходыПоНаправлениямДеятельности.ВыгрузитьКолонку("НаправлениеДеятельности") Цикл
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("НомерСтроки",   НомерПоПорядку);
		СтруктураПараметров.Вставить("НаправлениеДеятельности", НаправлениеДеятельности);
		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		Отбор = Новый Структура("НаправлениеДеятельности", НаправлениеДеятельности);
		ТаблицаРасходовПоНаправлениямДеятельности = ДанныеБюджета.РасходыПоНаправлениямДеятельности.Скопировать(Отбор);
		ВывестиСуммы(ТаблицаРасходовПоНаправлениямДеятельности, "СтрокаНаправлениеДеятельности", Макет, ТабличныйДокумент);
		
		// Выводим подчиненные статьи расходов
		Отбор = Новый Структура(
			"НаправлениеДеятельности, Родитель",
			НаправлениеДеятельности, Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
		Уровень = 1;
		НомерПоПорядкуДляСтатьи = СтрШаблон("%1.", НомерПоПорядку);
		ВывестиСтрокиРасходовПоНаправлениюДеятельности(
			ДанныеБюджета,
			Отбор,
			НомерПоПорядкуДляСтатьи,
			Макет,
			ТабличныйДокумент,
			Уровень);
		
		НомерПоПорядку = НомерПоПорядку + 1;
		
	КонецЦикла;
	
	// Итоги по разделу
	ОбластьИтогоПоРазделу = Макет.ПолучитьОбласть("ИтогоПоРазделу|ОсновнаяЧасть");
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("НадписьИтогоПоРазделу", НСтр("ru='Итого расходов:'"));
	ОбластьИтогоПоРазделу.Параметры.Заполнить(СтруктураПараметров);
	ТабличныйДокумент.Вывести(ОбластьИтогоПоРазделу);
	
	ТаблицаРасходов = ДанныеБюджета.РасходыПоНаправлениямДеятельности.Скопировать();
	ТаблицаРасходов.Свернуть("ДатаПланирования", "Сумма");
	ВывестиСуммы(ТаблицаРасходов, "ИтогоПоРазделу", Макет, ТабличныйДокумент);
	
КонецПроцедуры

Процедура ВывестиСтрокиРасходовПоНаправлениюДеятельности(ДанныеБюджета, Отбор, НомерПоПорядкуДляСтатьи, Макет, ТабличныйДокумент, Уровень)

	ТаблицаСтруктураРасходов = ДанныеБюджета.СтруктураРасходов.Скопировать(Отбор);
	ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаРасхода|ОсновнаяЧасть");
		
	НомерПоПорядку = 1;
	Для Каждого СтрокаРасходов Из ТаблицаСтруктураРасходов Цикл
		
		
		СтатьяРасхода = СтрокаРасходов.СтатьяРасхода;
		Если Не ЗначениеЗаполнено(СтатьяРасхода) Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("НомерСтроки",   СтрШаблон("%1%2", НомерПоПорядкуДляСтатьи, НомерПоПорядку));
		СтруктураПараметров.Вставить("СтатьяРасхода", СтатьяРасхода);
		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ОбластьСтрока.Области.СтатьяРасхода.Отступ = Уровень * 2;
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		ТаблицаПоСтатьям = ДанныеБюджета.Расходы.Скопировать(
			Новый Структура("НаправлениеДеятельности, СтатьяРасхода", 
			Отбор.НаправлениеДеятельности, СтатьяРасхода));
		ВывестиСуммы(ТаблицаПоСтатьям, "СтрокаРасхода", Макет, ТабличныйДокумент);
		
		Если СтрокаРасходов.ЭтоГруппа Тогда
			НовыйОтбор = ОбщегоНазначения.СкопироватьРекурсивно(Отбор);
			НовыйОтбор.Родитель = СтатьяРасхода;
			НовыйНомерПоПорядкуДляСтатьи = СтрШаблон("%1%2.", НомерПоПорядкуДляСтатьи, НомерПоПорядку);
			НовыйУровень = Уровень + 1;
			ВывестиСтрокиРасходовПоНаправлениюДеятельности(
				ДанныеБюджета,
				НовыйОтбор,
				НовыйНомерПоПорядкуДляСтатьи,
				Макет,
				ТабличныйДокумент,
				НовыйУровень);
		КонецЕсли;
		
		НомерПоПорядку = НомерПоПорядку + 1;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиСуммы(Таблица, ИмяОбласти, Макет, ТабличныйДокумент)
	
	Таблица.Сортировать("ДатаПланирования Возр");
	
	Для Каждого Строка Из Таблица Цикл
		Если Не ЗначениеЗаполнено(Строка.ДатаПланирования) Тогда
			// У итого нет даты планирования
			ОбластьСтрокаДетализация = Макет.ПолучитьОбласть(СтрШаблон("%1|Итого", ИмяОбласти));
		Иначе
			ОбластьСтрокаДетализация = Макет.ПолучитьОбласть(СтрШаблон("%1|Детализация", ИмяОбласти));
		КонецЕсли;
		ОбластьСтрокаДетализация.Параметры.Заполнить(Строка);
		ТабличныйДокумент.Присоединить(ОбластьСтрокаДетализация);
	КонецЦикла;
	
КонецПроцедуры

Процедура ВывестиПодвал(РеквизитыДокумента, ТабличныйДокумент, Макет)
	
	ОтветственныеЛицаОрганизации = ОтветственныеЛицаБП.ОтветственныеЛица(
		РеквизитыДокумента.Организация, РеквизитыДокумента.Период);
	
	Подвал = Макет.ПолучитьОбласть("Подвал");
	Подвал.Параметры.Заполнить(ОтветственныеЛицаОрганизации);
	ТабличныйДокумент.Вывести(Подвал);
	
КонецПроцедуры

Функция ТабличныйДокументДляВыгрузкиВExcel(Объект, КолонкиДетализации) Экспорт 
	
	ДанныеБюджета = БюджетДоходовРасходов.НовыйДанныеБюджета(); 
	
	Для Каждого Строка Из Объект.Доходы Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.Доходы.Добавить(), Строка);
	КонецЦикла;  
	
	Для Каждого Строка Из Объект.СтруктураДоходов Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.СтруктураДоходов.Добавить(), Строка);
	КонецЦикла; 
	
	Для Каждого Строка Из Объект.Расходы Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.Расходы.Добавить(), Строка);
	КонецЦикла;
	
	Для Каждого Строка Из Объект.СтруктураРасходов Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.СтруктураРасходов.Добавить(), Строка);
	КонецЦикла; 
	
	Для Каждого Строка Из Объект.РасходыПоНаправлениямДеятельности Цикл
		ЗаполнитьЗначенияСвойств(ДанныеБюджета.РасходыПоНаправлениямДеятельности.Добавить(), Строка);
	КонецЦикла;
	
	Макет = Обработки.Бюджет.ПолучитьМакет("ВыгрузкаВФайл");
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	ОбластьШапкаОсновное = Макет.ПолучитьОбласть("Шапка|ОсновнаяЧасть");
	ТабличныйДокумент.Вывести(ОбластьШапкаОсновное); 
	   
	ОбластьШапкаПериод = Макет.ПолучитьОбласть("Шапка|Детализация");
		
	Для Каждого Колонка Из КолонкиДетализации Цикл
		ОбластьШапкаПериод.Параметры.Период = Колонка.Заголовок;
		ТабличныйДокумент.Присоединить(ОбластьШапкаПериод);
	КонецЦикла;
	
	СтруктураПоиска = Новый Структура("Родитель", Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());
	ТаблицаСтруктурыДоходов = ДанныеБюджета.СтруктураДоходов.Скопировать(СтруктураПоиска);
	ЗаполнитьДоходыСИерархией(ТаблицаСтруктурыДоходов, ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет);
	ЗаполнитьРасходыСИерархией(ДанныеБюджета, ТабличныйДокумент, Макет);
	
	// Скроем колонки с UID`ами статьи ддс и направления деятельности
	ТабличныйДокумент.Область("C3").Видимость = Ложь;
	ТабличныйДокумент.Область("C4").Видимость = Ложь; 
	ТабличныйДокумент.Область("C5").Видимость = Ложь;
	ТабличныйДокумент.Область("C7").Видимость = Ложь;
			
	Возврат ТабличныйДокумент;
		
КонецФункции 

Процедура ЗаполнитьДоходыСИерархией(ТаблицаСтруктураДоходов, ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет)
	
	Раздел = НСтр("ru = 'Финансирование'");  
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка|ОсновнаяЧасть");
	
	Для Каждого СтрокаДоходы Из ТаблицаСтруктураДоходов Цикл		
		
		Если СтрокаДоходы.ЭтоГруппа Тогда
			НоваяТаблицаСтруктурыДоходов = ДанныеБюджета.СтруктураДоходов.Скопировать(Новый Структура("Родитель", СтрокаДоходы.СтатьяДохода));
			ЗаполнитьДоходыСИерархией(НоваяТаблицаСтруктурыДоходов, ДанныеБюджета, КолонкиДетализации, ТабличныйДокумент, Макет);
			Продолжить;
		КонецЕсли;
		
		СтруктураПараметров = Новый Структура;  
		СтруктураПараметров.Вставить("УИДСтатьиДДС", СтрокаДоходы.СтатьяДохода.УникальныйИдентификатор());
		СтруктураПараметров.Вставить("Раздел", Раздел);
		СтруктураПараметров.Вставить("СтатьяДДС", СтрокаДоходы.СтатьяДохода);
		СтруктураПараметров.Вставить("УИДСтатьиДДС", СтрокаДоходы.СтатьяДохода.УникальныйИдентификатор());
		Если ЗначениеЗаполнено(СтрокаДоходы.Родитель) Тогда
			СтруктураПараметров.Вставить("ГруппаСтатей", СтрокаДоходы.Родитель);  
			СтруктураПараметров.Вставить("УИДГруппыСтатей", СтрокаДоходы.Родитель.УникальныйИдентификатор());
		КонецЕсли;
		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		ТаблицаДоходовПоСтатье = ДанныеБюджета.Доходы.Скопировать(Новый Структура("СтатьяДохода", СтрокаДоходы.СтатьяДохода));
		ЗаполнитьСуммы(ТаблицаДоходовПоСтатье, "Строка", Макет, ТабличныйДокумент);

	КонецЦикла;
	
КонецПроцедуры 

Процедура ЗаполнитьСуммы(Таблица, ИмяОбласти, Макет, ТабличныйДокумент)
	
	Таблица.Сортировать("ДатаПланирования Возр");
	ГодоваяСумма = 0;
	ОбластьСтрокаДетализация = Макет.ПолучитьОбласть(СтрШаблон("%1|Детализация", ИмяОбласти)); 
	
	Для Каждого Строка Из Таблица Цикл
		Если ЗначениеЗаполнено(Строка.ДатаПланирования) Тогда 
			ОбластьСтрокаДетализация.Параметры.Заполнить(Строка);
			ТабличныйДокумент.Присоединить(ОбластьСтрокаДетализация);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьРасходыСИерархией(ДанныеБюджета, ТабличныйДокумент, Макет)
	
	Раздел = НСтр("ru = 'Расход'");
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка|ОсновнаяЧасть");	
	ТаблицаРасходыПоНаправлениямДеятельности = ДанныеБюджета.СтруктураРасходов.Скопировать();
	ТаблицаРасходыПоНаправлениямДеятельности.Свернуть("НаправлениеДеятельности"); 
	
	Для Каждого НаправлениеДеятельности Из ТаблицаРасходыПоНаправлениямДеятельности.ВыгрузитьКолонку("НаправлениеДеятельности") Цикл	
		Отбор = Новый Структура("НаправлениеДеятельности, Родитель", НаправлениеДеятельности, Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка());	
		ЗаполнитьСтрокиРасходовПоНаправлениюДеятельностиИСтатье(ДанныеБюджета, Отбор, Макет, ТабличныйДокумент, Раздел);		
	КонецЦикла; 
	
КонецПроцедуры 

Процедура ЗаполнитьСтрокиРасходовПоНаправлениюДеятельностиИСтатье(ДанныеБюджета, Отбор, Макет, ТабличныйДокумент, Раздел)
	
	ТаблицаСтруктураРасходов = ДанныеБюджета.СтруктураРасходов.Скопировать(Отбор);
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка|ОсновнаяЧасть");
	
	Для Каждого СтрокаРасходов Из ТаблицаСтруктураРасходов Цикл
		
		СтатьяРасхода = СтрокаРасходов.СтатьяРасхода;
		НаправлениеДеятельности = СтрокаРасходов.НаправлениеДеятельности;
		Если Не ЗначениеЗаполнено(СтатьяРасхода) Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаРасходов.ЭтоГруппа Тогда
			НовыйОтбор = ОбщегоНазначения.СкопироватьРекурсивно(Отбор);
			НовыйОтбор.Родитель = СтатьяРасхода;
			ЗаполнитьСтрокиРасходовПоНаправлениюДеятельностиИСтатье(ДанныеБюджета, НовыйОтбор, Макет, ТабличныйДокумент, Раздел);
			Продолжить;
		КонецЕсли;
		
		СтруктураПараметров = Новый Структура; 
		СтруктураПараметров.Вставить("УИДНаправленияДеятельности", НаправлениеДеятельности.УникальныйИдентификатор()); 
		СтруктураПараметров.Вставить("УИДСтатьиДДС", СтатьяРасхода.УникальныйИдентификатор());
		СтруктураПараметров.Вставить("Раздел", Раздел);
		СтруктураПараметров.Вставить("НаправлениеДеятельности", НаправлениеДеятельности);
		СтруктураПараметров.Вставить("СтатьяДДС", СтатьяРасхода);
		Если ЗначениеЗаполнено(СтрокаРасходов.Родитель) Тогда
			СтруктураПараметров.Вставить("ГруппаСтатей", СтрокаРасходов.Родитель);
			СтруктураПараметров.Вставить("УИДГруппыСтатей", СтрокаРасходов.Родитель.УникальныйИдентификатор());
		КонецЕсли;

		ОбластьСтрока.Параметры.Заполнить(СтруктураПараметров);
		ТабличныйДокумент.Вывести(ОбластьСтрока);
		
		ТаблицаПоСтатьям = ДанныеБюджета.Расходы.Скопировать(
			Новый Структура("НаправлениеДеятельности, СтатьяРасхода", Отбор.НаправлениеДеятельности, СтатьяРасхода));
		ЗаполнитьСуммы(ТаблицаПоСтатьям, "Строка", Макет, ТабличныйДокумент);
		
	КонецЦикла;
	
КонецПроцедуры 
#КонецОбласти
#КонецЕсли