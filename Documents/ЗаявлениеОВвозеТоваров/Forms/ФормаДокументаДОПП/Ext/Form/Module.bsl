&НаСервере
Процедура ЗаполнитьПоПоступлениямНаСервере(ДокументОснование) Экспорт
	
	ДанныеОбъекта = Новый Структура("Дата,Организация,ВалютаДокумента,Дата,ОсобыйПризнакЗаявителя");
	ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Объект);
	ДанныеОбъекта.Вставить("ВалютаРегламентированногоУчета", ВалютаРегламентированногоУчета);
	
	ТоварыПоДаннымПоступления = ТоварыПоДаннымДокументаПоступления(ДанныеОбъекта, ДокументОснование);
	Для каждого ДанныеНовойСтроки Из ТоварыПоДаннымПоступления Цикл
		НоваяСтрока = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеНовойСтроки);
		НоваяСтрока.ОсобыйПризнакДОПП = Объект.ОсобыйПризнакДОПП;
	КонецЦикла;
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	ОбновитьИтоги(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Функция ТоварыПоДаннымДокументаПоступления(ДанныеОбъекта, ДокументОснование)

	ВидыОпераций = Новый Массив;
	ВидыОпераций.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Товары);
	ВидыОпераций.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ПокупкаКомиссия);
	ВидыОпераций.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Оборудование);
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	Запрос.УстановитьПараметр("ВидыОпераций",         ВидыОпераций);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Количество КАК Количество,
	|	Товары.Сумма КАК ФактурнаяСтоимость,
	|	Товары.СчетУчета КАК СчетУчета,
	|	0 КАК НалоговаяБазаНДС,
	|	0 КАК СуммаНДС,
	|	0 КАК СуммаАкциза,
	|	0 КАК ОбеспечительныйПлатеж,
	|	Товары.НомерГТД КАК НомерТД,
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	1 КАК НомерТабличнойЧасти,
	|	ЕСТЬNULL(СправочникНоменклатура.ЕдиницаИзмерения, ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)) КАК ЕдиницаИзмерения,
	|	ЕСТЬNULL(СправочникНоменклатура.КодТНВЭД, """") КАК КодТНВЭД,
	|	ЕСТЬNULL(СправочникНоменклатура.ВидСтавкиНДС, ЗНАЧЕНИЕ(Перечисление.ВидыСтавокНДС.ПустаяСсылка)) КАК ВидСтавкиНДС,
	|	ВЫБОР
	|		КОГДА Товары.СтранаПроисхождения = ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(СправочникНоменклатура.СтранаПроисхождения, ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка))
	|		ИНАЧЕ Товары.СтранаПроисхождения
	|	КОНЕЦ КАК СтранаПроисхождения,
	|	Товары.ПрослеживаемыйТовар КАК ПрослеживаемыйТовар,
	|	Товары.Склад КАК Склад
	|ИЗ
	|	Документ.ПоступлениеТоваровУслуг.Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторТНВЭД КАК КлассификаторТНВЭД
	|			ПО СправочникНоменклатура.КодТНВЭД = КлассификаторТНВЭД.Ссылка
	|		ПО Товары.Номенклатура = СправочникНоменклатура.Ссылка
	|ГДЕ
	|	Товары.Ссылка В(&ДокументОснование)
	|	И Товары.Ссылка.ВидОперации В(&ВидыОпераций)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Оборудование.Номенклатура,
	|	Оборудование.Количество,
	|	Оборудование.Сумма,
	|	Оборудование.СчетУчета,
	|	0,
	|	0,
	|	0,
	|	0,
	|	Оборудование.НомерГТД,
	|	Оборудование.НомерСтроки,
	|	2,
	|	ЕСТЬNULL(СправочникНоменклатура.ЕдиницаИзмерения, ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)),
	|	ЕСТЬNULL(СправочникНоменклатура.КодТНВЭД, """"),
	|	ЕСТЬNULL(СправочникНоменклатура.ВидСтавкиНДС, ЗНАЧЕНИЕ(Перечисление.ВидыСтавокНДС.ПустаяСсылка)),
	|	ВЫБОР
	|		КОГДА Оборудование.СтранаПроисхождения = ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(СправочникНоменклатура.СтранаПроисхождения, ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка))
	|		ИНАЧЕ Оборудование.СтранаПроисхождения
	|	КОНЕЦ,
	|	Оборудование.ПрослеживаемыйТовар,
	|	NULL
	|ИЗ
	|	Документ.ПоступлениеТоваровУслуг.Оборудование КАК Оборудование
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторТНВЭД КАК КлассификаторТНВЭД
	|			ПО СправочникНоменклатура.КодТНВЭД = КлассификаторТНВЭД.Ссылка
	|		ПО Оборудование.Номенклатура = СправочникНоменклатура.Ссылка
	|ГДЕ
	|	Оборудование.Ссылка В(&ДокументОснование)
	|	И Оборудование.Ссылка.ВидОперации В(&ВидыОпераций)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерТабличнойЧасти,
	|	НомерСтроки";
	
	РезультатЗапрос = Запрос.Выполнить();
	Если РезультатЗапрос.Пустой() Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;
	
	ТаблицаЗначенийТовары = РезультатЗапрос.Выгрузить();
	ТаблицаЗначенийТовары.Колонки.Добавить("СтавкаНДС", Новый ОписаниеТипов("ПеречислениеСсылка.СтавкиНДС"));
	ТаблицаЗначенийТовары.Колонки.Добавить("КоэффициентПересчета");
	ТаблицаЗначенийТовары.Колонки.Добавить("ОкруглятьДоЦелого");
	ТаблицаЗначенийТовары.Колонки.Добавить("ТвердаяСтавкаАкциза");
	ТаблицаЗначенийТовары.Колонки.Добавить("ЕдиницаИзмеренияАкциза");
	ТаблицаЗначенийТовары.Колонки.Добавить("НалоговаяБазаАкцизы");
	ТаблицаЗначенийТовары.Колонки.Добавить("ПодакцизныйТовар");
	ТаблицаЗначенийТовары.Колонки.Добавить("КодВидаПодакцизногоТовара");
	ТаблицаЗначенийТовары.Колонки.Добавить("КБК");
	ТаблицаЗначенийТовары.Колонки.Добавить("МаркируемаяПродукция");

	Если ПолучитьФункциональнуюОпцию("ИмпортПодакцизныхТоваров") Тогда
		ПараметрыЗаполнения = Новый Структура;
		УчетАкцизов.ПараметрыДляЗаполненияДанныхПоАкцизам(ПараметрыЗаполнения);
		ПараметрыЗаполнения.Импорт          = Истина;
		ПараметрыЗаполнения.ЗаявлениеОВвозе = Истина;
		ПараметрыЗаполнения.ДОПП            = Истина;
		УчетАкцизов.ЗаполнитьДанныеПоАкцизам(ТаблицаЗначенийТовары, ДанныеОбъекта.Организация, ДанныеОбъекта.Дата, ПараметрыЗаполнения);
	КонецЕсли;
	Для каждого СтрокаТоваров Из ТаблицаЗначенийТовары Цикл
		СтрокаТоваров.СтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(СтрокаТоваров.ВидСтавкиНДС, ДанныеОбъекта.Дата);
		РасчитатьСуммыВТабличнойЧастиНаСервере(СтрокаТоваров, ДанныеОбъекта);
	КонецЦикла;
	
	Возврат ТаблицаЗначенийТовары;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьИзСчетаЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	ДокументОснование = РезультатЗакрытия;
	
	Если ДокументОснование <> Неопределено Тогда
		ЗаполнитьПоСчетуНаСервере(ДокументОснование);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоСчетуНаСервере(ДокументОснование) Экспорт
	
	ДанныеОбъекта = Новый Структура("Дата,Организация,ВалютаДокумента,Дата,ОсобыйПризнакЗаявителя");
	ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Объект);
	ДанныеОбъекта.Вставить("ВалютаРегламентированногоУчета", ВалютаРегламентированногоУчета);

	ТоварыПоДаннымСчета = Документы.ЗаявлениеОВвозеТоваров.ТоварыПоСчетуПоставщика(ДанныеОбъекта, ДокументОснование);
	Для каждого ДанныеНовойСтроки Из ТоварыПоДаннымСчета Цикл
		НоваяСтрока = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеНовойСтроки);
		НоваяСтрока.ОсобыйПризнакДОПП = Объект.ОсобыйПризнакДОПП;
	КонецЦикла;
	
	СчетаУчетаВДокументах.ЗаполнитьСтроки(Объект.Товары, "Товары", Объект, Документы.ЗаявлениеОВвозеТоваров, Истина);
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	ОбновитьИтоги(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

