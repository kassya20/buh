&НаСервере
Процедура ЗаполнитьДокументПоСчетуНаОплату(СчетНаОплату)
	
	Объект.ВидОперации = Перечисления.ВидыОперацийВвозТоваровИзЕАЭС.ДОПП;
	РеквизитыСчета = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СчетНаОплату,
		"Организация,Контрагент,ДоговорКонтрагента,ВалютаДокумента,Дата");
	ЗаполнитьЗначенияСвойств(Объект, РеквизитыСчета);
	Объект.ДатаВвоза = РеквизитыСчета.Дата;
	
	ДанныеОбъекта = Новый Структура("Дата,Организация,ВалютаДокумента,ДатаВвоза,ОсобыйПризнакЗаявителя");
	ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Объект);
	ДанныеОбъекта.Вставить("ВалютаРегламентированногоУчета", ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета());
		
	ТоварыПоСчетуПоставщика = Документы.ЗаявлениеОВвозеТоваров.ТоварыПоСчетуПоставщика(ДанныеОбъекта, СчетНаОплату);
		
	Если ТоварыПоСчетуПоставщика.Количество() > 0 Тогда
		Объект.Товары.Загрузить(ТоварыПоСчетуПоставщика);
	КонецЕсли;
	
	СчетаУчетаВДокументах.ЗаполнитьСтроки(Объект.Товары, "Товары", Объект, Документы.ЗаявлениеОВвозеТоваров, Истина);

КонецПроцедуры

&НаСервере
Функция ПроверкиФорматаДОППВыполнены()
	
	ПроверкиВыполнены = Истина;
	
	// Проверка уникальности регистрационных номеров
	Если СокрЛП(Объект.РегистрационныйЗнак) = СокрЛП(Объект.РегистрационныйЗнакПрицепа)
	 Или СокрЛП(Объект.РегистрационныйЗнак) = СокрЛП(Объект.РегистрационныйЗнакПрицепаДополнительный) Тогда
		
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Регистрационный номер не уникален.'"), ,
			"РегистрационныйЗнак",
			"Объект");
		ПроверкиВыполнены = Ложь;
	КонецЕсли;
	
	Если СокрЛП(Объект.РегистрационныйЗнакПрицепа) = СокрЛП(Объект.РегистрационныйЗнакПрицепаДополнительный)
	   И ЗначениеЗаполнено(Объект.РегистрационныйЗнакПрицепа) Тогда
		
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Регистрационный номер прицепа не уникален.'"), ,
			"РегистрационныйЗнакПрицепа",
			"Объект");
		ПроверкиВыполнены = Ложь;
		
	КонецЕсли;
	
	Если КонецДня(Объект.ДатаВвоза) < Объект.Дата Тогда
	
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Дата ввоза не может быть ранее даты регистрации ДОПП.'"), ,
			"ДатаВвоза",
			"Объект");
		ПроверкиВыполнены = Ложь;
	
	КонецЕсли;
	
	Возврат ПроверкиВыполнены;

КонецФункции

&НаСервере
Процедура ЗарегистрироватьАктуализироватьДОПП()
	
	Если Не ПроверкиФорматаДОППВыполнены() Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтатусДОППТекст) Тогда
		// ДОПП был зарегистрирован в СПОТ, актуализация не выполняется.
		// При необходимости исправления ранее зарегистрированного ДОПП необходимо формировать корректировочный ДОПП.
		Возврат;
	КонецЕсли;
	
	СоздатьРеглОтчетДОПП();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьРеглОтчетДОПП(Корректировочный = Ложь)
	
	КонтейнерДОПП = Отчеты.РегламентированноеУведомлениеДокументОПредстоящейПоставке.КонтейнерДляЗаполнения(
		ИмяФормыДОПП(Объект.Дата));
	ПараметрыСоздания = ДанныеДляЗаполненияРеглОтчетаДОПП(КонтейнерДОПП, Объект.Ссылка, СсылкаНаДОПП, НомерРеглДОПП, Корректировочный);
	СсылкаНаДОПП = Отчеты.РегламентированноеУведомлениеДокументОПредстоящейПоставке.НовыйДОПП(ПараметрыСоздания);
	ДатаРеглДОПП = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаДОПП, "Дата");
	
	Если Корректировочный Тогда
		ЗаполнитьТекстПроДОПП();
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИмяФормыДОПП(Дата)
	
	Если Дата >= '20260101' Тогда
		Возврат "Форма2026_1";
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеДляЗаполненияРеглОтчетаДОПП(КонтейнерДОПП, УчетныйДокументДОПП, СсылкаНаДОПП, НомерРеглДОПП, Корректировочный)
	
	ЗаполнитьКонтейнерДОПП(КонтейнерДОПП, УчетныйДокументДОПП, СсылкаНаДОПП, НомерРеглДОПП, Корректировочный);
	
	Если Корректировочный Тогда
		// Необходимо создать новый регл. отчета с номером корректировки + 1, а не актуализировать предыдущий.
		СсылкаНаДОПП = Документы.УведомлениеОСпецрежимахНалогообложения.ПустаяСсылка();
	КонецЕсли;
	
	РеквизитыУчетногоДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(УчетныйДокументДОПП, "Организация, Дата");
	
	ПараметрыСоздания = Новый Структура();
	ПараметрыСоздания.Вставить("Организация",       РеквизитыУчетногоДокумента.Организация);
	ПараметрыСоздания.Вставить("РегистрацияВИФНС",  Справочники.Организации.РегистрацияВНалоговомОрганеНаДату(РеквизитыУчетногоДокумента.Организация, РеквизитыУчетногоДокумента.Дата));
	ПараметрыСоздания.Вставить("Контейнер",         КонтейнерДОПП);
	ПараметрыСоздания.Вставить("ДокументОснование", УчетныйДокументДОПП);
	ПараметрыСоздания.Вставить("ИмяФормы",          "Форма2026_1");
	ПараметрыСоздания.Вставить("Ссылка",            СсылкаНаДОПП);
	
	Возврат ПараметрыСоздания;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаполнитьКонтейнерДОПП(КонтейнерДОПП, УчетныйДокументДОПП, СсылкаНаДОПП, НомерРеглДОПП, Корректировочный)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", УчетныйДокументДОПП);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(ЗаявлениеОВвозеТоваровТовары.ОбеспечительныйПлатеж) КАК ОбеспечительныйПлатеж
	|ПОМЕСТИТЬ СуммаОбеспечительногоПлатежа
	|ИЗ
	|	Документ.ЗаявлениеОВвозеТоваров.Товары КАК ЗаявлениеОВвозеТоваровТовары
	|ГДЕ
	|	ЗаявлениеОВвозеТоваровТовары.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявлениеОВвозеТоваров.Дата КАК Дата,
	|	ЗаявлениеОВвозеТоваров.Организация КАК Организация,
	|	ЗаявлениеОВвозеТоваров.Контрагент КАК Контрагент,
	|	ЗаявлениеОВвозеТоваров.ДоговорКонтрагента КАК ДоговорКонтрагента,
	|	ЗаявлениеОВвозеТоваров.ВалютаДокумента КАК ВалютаДокумента,
	|	ЗаявлениеОВвозеТоваров.ДатаВвоза КАК ДатаВвоза,
	|	ЗаявлениеОВвозеТоваров.Перевозчик КАК Перевозчик,
	|	ЗаявлениеОВвозеТоваров.РегистрационныйЗнак КАК РегистрационныйЗнак,
	|	ЗаявлениеОВвозеТоваров.РегистрационныйЗнакПрицепа КАК РегистрационныйЗнакПрицепа,
	|	ЗаявлениеОВвозеТоваров.РегистрационныйЗнакПрицепаДополнительный КАК РегистрационныйЗнакПрицепаДополнительный,
	|	ЗаявлениеОВвозеТоваров.ОсобыйПризнакДОПП КАК ОсобыйПризнакДОПП,
	|	ЗаявлениеОВвозеТоваров.ОсобыйПризнакЗаявителя КАК ОсобыйПризнакЗаявителя,
	|	ЗаявлениеОВвозеТоваров.ИнойОсобыйПризнакЗаявителя КАК ИнойОсобыйПризнакЗаявителя,
	|	Валюты.Код КАК КодаВалюты,
	|	ДоговорыКонтрагентов.Дата КАК ДатаДоговора,
	|	ДоговорыКонтрагентов.Номер КАК НомерДоговора,
	|	Организации.НаименованиеПолное КАК ОрганизацияНаименованиеПолное,
	|	Организации.ИНН КАК ОрганизацияИНН,
	|	Организации.КПП КАК ОрганизацияКПП,
	|	КонтрагентПродавец.НаименованиеПолное КАК ПродавецНаименованиеПолное,
	|	КонтрагентПродавец.ИНН КАК ПродавецИНН,
	|	КонтрагентПродавец.КПП КАК ПродавецКПП,
	|	КонтрагентПродавец.РегистрационныйНомер КАК ПродавецРегистрационныйНомер,
	|	КонтрагентПродавец.СтранаРегистрации КАК ПродавецСтранаРегистрации,
	|	КонтрагентПеревозчик.НаименованиеПолное КАК ПеревозчикНаименованиеПолное,
	|	КонтрагентПеревозчик.ИНН КАК ПеревозчикИНН,
	|	КонтрагентПеревозчик.КПП КАК ПеревозчикКПП,
	|	КонтрагентПеревозчик.РегистрационныйНомер КАК ПеревозчикРегистрационныйНомер,
	|	КонтрагентПеревозчик.СтранаРегистрации КАК ПеревозчикСтранаРегистрации,
	|	СтранаРегистрацииПеревозчика.Код КАК КодСтраныРегистрацииПеревозчика,
	|	СтранаРегистрацииПродавца.Код КАК КодСтраныРегистрацииПродавца,
	|	СуммаОбеспечительногоПлатежа.ОбеспечительныйПлатеж КАК ОбеспечительныйПлатеж
	|ИЗ
	|	Документ.ЗаявлениеОВвозеТоваров КАК ЗаявлениеОВвозеТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Валюты КАК Валюты
	|		ПО ЗаявлениеОВвозеТоваров.ВалютаДокумента = Валюты.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|		ПО ЗаявлениеОВвозеТоваров.ДоговорКонтрагента = ДоговорыКонтрагентов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	|		ПО ЗаявлениеОВвозеТоваров.Организация = Организации.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентПродавец
	|		ПО ЗаявлениеОВвозеТоваров.Контрагент = КонтрагентПродавец.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК КонтрагентПеревозчик
	|		ПО ЗаявлениеОВвозеТоваров.Перевозчик = КонтрагентПеревозчик.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтраныМира КАК СтранаРегистрацииПеревозчика
	|		ПО (КонтрагентПеревозчик.СтранаРегистрации = СтранаРегистрацииПеревозчика.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтраныМира КАК СтранаРегистрацииПродавца
	|		ПО (КонтрагентПродавец.СтранаРегистрации = СтранаРегистрацииПродавца.Ссылка),
	|	СуммаОбеспечительногоПлатежа КАК СуммаОбеспечительногоПлатежа
	|ГДЕ
	|	ЗаявлениеОВвозеТоваров.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаявлениеОВвозеТоваровТовары.НомерСтроки КАК НомерСтроки,
	|	ЗаявлениеОВвозеТоваровТовары.Номенклатура КАК Номенклатура,
	|	ЗаявлениеОВвозеТоваровТовары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЗаявлениеОВвозеТоваровТовары.Количество КАК Количество,
	|	ЗаявлениеОВвозеТоваровТовары.ФактурнаяСтоимость КАК ФактурнаяСтоимость,
	|	ЗаявлениеОВвозеТоваровТовары.НалоговаяБазаНДС КАК НалоговаяБазаНДС,
	|	ЗаявлениеОВвозеТоваровТовары.СуммаНДС КАК СуммаНДС,
	|	ЗаявлениеОВвозеТоваровТовары.СтранаПроисхождения КАК СтранаПроисхождения,
	|	ЗаявлениеОВвозеТоваровТовары.НалоговаяБазаАкцизы КАК НалоговаяБазаАкцизы,
	|	ЗаявлениеОВвозеТоваровТовары.ТвердаяСтавкаАкциза КАК ТвердаяСтавкаАкциза,
	|	ЗаявлениеОВвозеТоваровТовары.АдвалорнаяСтавкаАкциза КАК АдвалорнаяСтавкаАкциза,
	|	ЗаявлениеОВвозеТоваровТовары.СуммаАкциза КАК СуммаАкциза,
	|	ЗаявлениеОВвозеТоваровТовары.ПодакцизныйТовар КАК ПодакцизныйТовар,
	|	ЗаявлениеОВвозеТоваровТовары.ОсобыйПризнакДОПП КАК ОсобыйПризнакДОПП,
	|	КлассификаторТНВЭД.Код КАК КодТНВЭД,
	|	СтраныМира.Код КАК КодСтраныПроисхождения,
	|	СтраныМира.НаименованиеПолное КАК НаименованиеПолноеСтраныПроисхождения,
	|	КлассификаторЕдиницИзмерения.Код КАК КодЕдиницыИзмерения,
	|	НомераГТД.Код КАК НомерДекларацииНаТовары,
	|	ВЫБОР
	|		КОГДА ЗаявлениеОВвозеТоваровТовары.СтавкаНДС = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС22)
	|			ТОГДА ""22""
	|		КОГДА ЗаявлениеОВвозеТоваровТовары.СтавкаНДС = ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС10)
	|			ТОГДА ""10""
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК СтавкаНДС,
	|	ТоварНоменклатура.НаименованиеПолное КАК ТоварНаименованиеПолное,
	|	КодыВидовПодакцизныхТоваров.Код КАК КодВидаПодакцизногоТовара,
	|	ЗаявлениеОВвозеТоваровТовары.МаркируемаяПродукция КАК МаркируемаяПродукция
	|ИЗ
	|	Документ.ЗаявлениеОВвозеТоваров.Товары КАК ЗаявлениеОВвозеТоваровТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторТНВЭД КАК КлассификаторТНВЭД
	|		ПО ЗаявлениеОВвозеТоваровТовары.КодТНВЭД = КлассификаторТНВЭД.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтраныМира КАК СтраныМира
	|		ПО ЗаявлениеОВвозеТоваровТовары.СтранаПроисхождения = СтраныМира.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
	|		ПО ЗаявлениеОВвозеТоваровТовары.ЕдиницаИзмерения = КлассификаторЕдиницИзмерения.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НомераГТД КАК НомераГТД
	|		ПО ЗаявлениеОВвозеТоваровТовары.НомерТД = НомераГТД.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК ТоварНоменклатура
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КодыВидовПодакцизныхТоваров КАК КодыВидовПодакцизныхТоваров
	|			ПО ТоварНоменклатура.КодВидаПодакцизногоТовара = КодыВидовПодакцизныхТоваров.Ссылка
	|		ПО ЗаявлениеОВвозеТоваровТовары.Номенклатура = ТоварНоменклатура.Ссылка
	|ГДЕ
	|	ЗаявлениеОВвозеТоваровТовары.Ссылка = &Ссылка";
	Результат = Запрос.ВыполнитьПакет();
	ТаблицаШапка = Результат[1].Выгрузить();
	ТаблицаТовары = Результат[2].Выгрузить();
	
	Если ТаблицаШапка.Количество() = 0 Или ТаблицаТовары.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Шапка = ТаблицаШапка[0];
	
	// Титул - Структура
	Титул = КонтейнерДОПП.Титульная;
	
	ГоловнаяОрганизация         = БухгалтерскийУчетПереопределяемый.ГоловнаяОрганизация(Шапка.Организация);
	РегистрацияВНалоговомОргане = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ГоловнаяОрганизация, "РегистрацияВНалоговомОргане");
	ЭтоЮЛ                       = ОбщегоНазначенияБПВызовСервераПовтИсп.ЭтоЮрЛицо(ГоловнаяОрганизация);
	Реквизиты                   = РегистрацияВНОСервер.ДанныеРегистрации(РегистрацияВНалоговомОргане);
	КодНалоговогоОргана         = Реквизиты.Код;
	
	Если ЭтоЮЛ Тогда 
		СтрокаСведений = "ФамилияРук,ИмяРук,ОтчествоРук";
		СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(
			ГоловнаяОрганизация,
			Шапка.Дата,
			СтрокаСведений);
	Иначе
		СтрокаСведений = "ФамилияИП,ИмяИП,ОтчествоИП";
		СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(
			ГоловнаяОрганизация,
			Шапка.Дата,
			СтрокаСведений);
	КонецЕсли;
	
	СведенияОПродавце   = БухгалтерскийУчетПереопределяемый.СведенияОЮрФизЛице(Шапка.Контрагент, Шапка.Дата);
	Титул.ДатаВвоз      = Шапка.ДатаВвоза;
	Титул.НаимОрг       = Шапка.ОрганизацияНаименованиеПолное;
	Титул.ИНН           = Шапка.ОрганизацияИНН;
	Титул.КПП           = Шапка.ОрганизацияКПП;
	
	Титул.ОсПрЗаяв      = Шапка.ОсобыйПризнакЗаявителя;
	Титул.ИнОсПрЗаяв    = ?(Шапка.ОсобыйПризнакЗаявителя = 2, Шапка.ИнойОсобыйПризнакЗаявителя, "");
	Титул.КодНО         = КодНалоговогоОргана;
	
	Титул.НаимПерев     = Шапка.ПеревозчикНаименованиеПолное;
	Титул.ОКСМПерев     = Шапка.КодСтраныРегистрацииПеревозчика;
	Титул.РегНомПерев = ?(Шапка.ПеревозчикСтранаРегистрации = Справочники.СтраныМира.Россия, Шапка.ПеревозчикИНН, Шапка.ПеревозчикРегистрационныйНомер);
	
	Титул.НаимПрод      = Шапка.ПродавецНаименованиеПолное;
	Титул.АдресПрод     = СведенияОПродавце.ЮридическийАдрес;
	Титул.ОКСМПрод      = Шапка.КодСтраныРегистрацииПродавца;
	Титул.РегНомПрод  = ?(Шапка.ПродавецСтранаРегистрации = Справочники.СтраныМира.Россия, Шапка.ПродавецИНН, Шапка.ПродавецРегистрационныйНомер);
	
	Титул.СумОбПлат     = Окр(Шапка.ОбеспечительныйПлатеж);
	
	Титул.ВидТС         = "1";
	Титул.РегЗнакТС     = Шапка.РегистрационныйЗнак;
	Титул.НомерПрицеп1  = Шапка.РегистрационныйЗнакПрицепа;
	Титул.НомерПрицеп2  = Шапка.РегистрационныйЗнакПрицепаДополнительный;
	
	Титул.ДАТА_ПОДПИСИ  = Шапка.Дата;
	
	ПодписантФамилия  = "";
	ПодписантИмя      = "";
	ПодписантОтчество = "";
	Если ЗначениеЗаполнено(Реквизиты.Представитель) Тогда
		СведенияОПредставителе = РегламентированнаяОтчетностьВызовСервера.ПолучитьПоКодамСведенияОПредставителе(
			Шапка.Организация,
			КодНалоговогоОргана,
			Реквизиты.КПП);
		Если ЗначениеЗаполнено(СведенияОПредставителе.НаименованиеОрганизацииПредставителя) Тогда
			ПодписантСтр = СведенияОПредставителе.ФИОПредставителя;
			ФИО = РегламентированнаяОтчетность.РазложитьФИО(ПодписантСтр);
			ПодписантФамилия = СокрЛП(ФИО.Фамилия);
			ПодписантИмя = СокрЛП(ФИО.Имя);
			ПодписантОтчество = СокрЛП(ФИО.Отчество);
		Иначе
			ДанныеПредставителя = РегламентированнаяОтчетностьПереопределяемый.ПолучитьСведенияОФизЛице(
				Реквизиты.Представитель,
				,
				Шапка.Дата);
			ПодписантФамилия  = СокрЛП(ДанныеПредставителя.Фамилия);
			ПодписантИмя      = СокрЛП(ДанныеПредставителя.Имя);
			ПодписантОтчество = СокрЛП(ДанныеПредставителя.Отчество);
			ПодписантСтр = СокрЛП(ПодписантФамилия + " " + ПодписантИмя + " " + ПодписантОтчество);
		КонецЕсли;
		Титул.Вставить("ФИО_РУКОВОДИТЕЛЯ_ПРЕДСТАВИТЕЛЯ", ПодписантСтр);
		Титул.Вставить("ПРИЗНАК_НП_ПОДВАЛ",              "2");
		Титул.Вставить("НаимДок",                        Реквизиты.ДокументПредставителя);
	Иначе
		Если ЭтоЮЛ Тогда
			ПодписантФамилия  = СведенияОбОрганизации.ФамилияРук;
			ПодписантИмя      = СведенияОбОрганизации.ИмяРук;
			ПодписантОтчество = СведенияОбОрганизации.ОтчествоРук;
		Иначе
			ПодписантФамилия  = СведенияОбОрганизации.ФамилияИП;
			ПодписантИмя      = СведенияОбОрганизации.ИмяИП;
			ПодписантОтчество = СведенияОбОрганизации.ОтчествоИП;
		КонецЕсли;
		ПодписантСтр = СокрЛП(ПодписантФамилия + " " + ПодписантИмя + " " + ПодписантОтчество);
		Титул.Вставить("ФИО_РУКОВОДИТЕЛЯ_ПРЕДСТАВИТЕЛЯ", ПодписантСтр);
		Титул.Вставить("ПРИЗНАК_НП_ПОДВАЛ",              "1");
		Титул.Вставить("НаимДок",                        "");
	КонецЕсли;
	
	//Титул.Фамилия
	//Титул.Имя
	//Титул.Отчество
	
	Если Корректировочный Тогда
		ТекущийНомКорр  = Отчеты.РегламентированноеУведомлениеДокументОПредстоящейПоставке.НомерКорректировкиДОПП(СсылкаНаДОПП);
		Титул.НомКорр   = ?(ЗначениеЗаполнено(ТекущийНомКорр), ТекущийНомКорр + 1, 1);
		Титул.НомерДОПП = НомерРеглДОПП;
	ИначеЕсли ЗначениеЗаполнено(СсылкаНаДОПП) Тогда
		// Необходимо передать текущий номер ДОПП и корректировки при актуализации корректировочного ДОПП.
		ТекущийНомКорр  = Отчеты.РегламентированноеУведомлениеДокументОПредстоящейПоставке.НомерКорректировкиДОПП(СсылкаНаДОПП);
		Титул.НомКорр   = ТекущийНомКорр;
		Титул.НомерДОПП = НомерРеглДОПП;
	КонецЕсли;
	
	// Договор - ТаблицаЗначений
	Договоры = КонтейнерДОПП.Договор;
	Договор = Договоры.Добавить();
	
	ДатаКурсаВалют = Шапка.Дата - 86400;
	СтруктураКурса = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Шапка.ВалютаДокумента, ДатаКурсаВалют);
	УИДДоговора    = Новый УникальныйИдентификатор();
	
	Договор.БазаВалют     = СтруктураКурса.Кратность;
	Договор.КурсВалют     = СтруктураКурса.Курс;
	Договор.ДатаКурсВалют = ДатаКурсаВалют;
	Договор.КодВалют      = Шапка.КодаВалюты;
	Договор.ДатаДог       = Шапка.ДатаДоговора;
	Договор.НомерДог      = Шапка.НомерДоговора;
	Договор.УИД           = УИДДоговора;
	Договор.ПрСпецТов     = "2";
	
	// ТоварыДоговор - ТаблицаЗначений
	ТоварДоговор = КонтейнерДОПП.ТоварДоговор;
	
	Для каждого СтрокаТовара Из ТаблицаТовары Цикл
		
		ЭлементКонтейнера = ТоварДоговор.Добавить();
		
		ЭлементКонтейнера.АкцАдвСт         = СтрокаТовара.АдвалорнаяСтавкаАкциза;
		ЭлементКонтейнера.АкцизАдвБаза     = ?(СтрокаТовара.АдвалорнаяСтавкаАкциза > 0, СтрокаТовара.НалоговаяБазаАкцизы, 0);
		ЭлементКонтейнера.СумАкцизАдв      = ?(СтрокаТовара.АдвалорнаяСтавкаАкциза > 0, СтрокаТовара.СуммаАкциза, 0);
		
		ЭлементКонтейнера.АкцТвСт          = СтрокаТовара.ТвердаяСтавкаАкциза;
		ЭлементКонтейнера.АкцизТвБаза      = ?(СтрокаТовара.ТвердаяСтавкаАкциза > 0, СтрокаТовара.НалоговаяБазаАкцизы, 0);
		ЭлементКонтейнера.СумАкцизТв       = ?(СтрокаТовара.ТвердаяСтавкаАкциза > 0, СтрокаТовара.СуммаАкциза, 0);
		
		ЭлементКонтейнера.КодПТ            = СтрокаТовара.КодВидаПодакцизногоТовара;
		ЭлементКонтейнера.НаимТов          = СтрокаТовара.ТоварНаименованиеПолное;
		
		ЭлементКонтейнера.КолТов           = СтрокаТовара.Количество;
		ЭлементКонтейнера.НДСБаза          = СтрокаТовара.НалоговаяБазаНДС;
		ЭлементКонтейнера.НДССт            = СтрокаТовара.СтавкаНДС;
		ЭлементКонтейнера.НомерДекл        = СтрокаТовара.НомерДекларацииНаТовары;
		ЭлементКонтейнера.ОКЕИ             = СтрокаТовара.КодЕдиницыИзмерения;
		ЭлементКонтейнера.ОсобПризн        = СтрокаТовара.ОсобыйПризнакДОПП;
		ЭлементКонтейнера.ПрПТ             = ?(СтрокаТовара.ПодакцизныйТовар, "1", "0");
		ЭлементКонтейнера.СтоимТов         = СтрокаТовара.ФактурнаяСтоимость;
		ЭлементКонтейнера.ОКСМПроисх       = СтрокаТовара.КодСтраныПроисхождения;
		ЭлементКонтейнера.СтрПроисх        = СтрокаТовара.НаименованиеПолноеСтраныПроисхождения;
		ЭлементКонтейнера.СумНДС           = СтрокаТовара.СуммаНДС;
		ЭлементКонтейнера.ТНВЭД            = СтрокаТовара.КодТНВЭД;
		ЭлементКонтейнера.МаркируемыйТовар = СтрокаТовара.МаркируемаяПродукция;
		ЭлементКонтейнера.УИД              = Новый УникальныйИдентификатор();
		ЭлементКонтейнера.УИДРодителя      = УИДДоговора;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура НайтиРеглУведомлениеДОПП()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийДокумент", Объект.Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	УведомлениеОСпецрежимахНалогообложения.Ссылка КАК Ссылка,
	|	УведомлениеОСпецрежимахНалогообложения.Дата КАК Дата
	|ИЗ
	|	Документ.УведомлениеОСпецрежимахНалогообложения КАК УведомлениеОСпецрежимахНалогообложения
	|ГДЕ
	|	УведомлениеОСпецрежимахНалогообложения.Основание = &ТекущийДокумент
	|	И НЕ УведомлениеОСпецрежимахНалогообложения.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		СсылкаНаДОПП  = Выборка.Ссылка;
		ДатаРеглДОПП  = Выборка.Дата;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТекстПроДОПП()
	
	Если ЗначениеЗаполнено(СсылкаНаДОПП) Тогда
		
		Элементы.ДекорацияСсылкаНаДОПП.Видимость = Истина;
		Элементы.СкорректироватьДОПП.Видимость   = Истина;
		
		СтатусИСведенияКвитанций = Отчеты.РегламентированноеУведомлениеДокументОПредстоящейПоставке.СтатусИСведенияКвитанций(СсылкаНаДОПП);
		СтатусДОППТекст          = СтатусИСведенияКвитанций.СтатусДОППТекстом;
		НомерРеглДОПП            = СтатусИСведенияКвитанций.НомерДОПП;
		НомерКорректировкиДОПП   = Отчеты.РегламентированноеУведомлениеДокументОПредстоящейПоставке.НомерКорректировкиДОПП(СсылкаНаДОПП);
		
		Если НомерКорректировкиДОПП = 0 Тогда
			НомерКорректировкиТекст = "";
		Иначе
			НомерКорректировкиТекст = СтрШаблон(" (корр. %1)", НомерКорректировкиДОПП);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтатусДОППТекст) Тогда
			Элементы.ГруппаРегистрационныеДанныеДОПП.Видимость = Ложь;
			Элементы.ДекорацияСсылкаНаДОПП.Заголовок = СтрШаблон("Документ о предстоящей поставке%1 %2 от %3 (%4)", 
				НомерКорректировкиТекст, ?(НомерРеглДОПП = "", "ДДММГГННННННН", НомерРеглДОПП), ДатаРеглДОПП, СтатусДОППТекст);
		Иначе
			Элементы.ГруппаРегистрационныеДанныеДОПП.Видимость = Истина;
			Элементы.ДекорацияСсылкаНаДОПП.Заголовок = СтрШаблон("Документ о предстоящей поставке%1 от %2", НомерКорректировкиТекст, ДатаРеглДОПП);
		КонецЕсли;
		
	Иначе
		Элементы.ДекорацияСсылкаНаДОПП.Видимость           = Ложь;
		Элементы.ГруппаРегистрационныеДанныеДОПП.Видимость = Ложь;
		Элементы.СкорректироватьДОПП.Видимость             = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередИзменениемПризнакаДОППЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		УстановитьОсобыйПризнакДОППВТаблице();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОсобыйПризнакДОППВТаблице()
	
	Для каждого СтрокаТаблицы Из Объект.Товары Цикл
		СтрокаТаблицы.ОсобыйПризнакДОПП = Объект.ОсобыйПризнакДОПП;
		АктуализироватьНалогиПоСтрокеТовары(СтрокаТаблицы);
	КонецЦикла;
	
	УправлениеФормой(ЭтотОбъект);
	ОбновитьИтоги(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораСтавкиНДС()
	
	УчетНДС.УстановитьПараметрыВыбораСтавкиНДС(ЭтотОбъект, "ТоварыСтавкаНДС", "ДОПП");
	
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыВыбораДоговора()
	
	ВидыДоговоров = Новый Массив;
	ВидыДоговоров.Добавить(Перечисления.ВидыДоговоровКонтрагентов.СПоставщиком);
	ВидыДоговоров.Добавить(Перечисления.ВидыДоговоровКонтрагентов.СПокупателем);
	МассивВидовДоговоров = Новый ФиксированныйМассив(ВидыДоговоров);
	
	НовыйМассивПараметров = Новый Массив();
	НовыйМассивПараметров.Добавить(Новый ПараметрВыбора("Отбор.ВидДоговора", МассивВидовДоговоров));
	
	НовыеПараметрыВыбора = Новый ФиксированныйМассив(НовыйМассивПараметров);
	Элементы.ДоговорКонтрагента.ПараметрыВыбора = НовыеПараметрыВыбора;
	
КонецПроцедуры

#КонецОбласти

#Область Инициализация

ЭтоНоваяСтрока = Ложь;

#КонецОбласти


