&НаСервере
Процедура ЗаполнитьКоллекциюСписковВыбора()
	
	ЗаполнитьСписокВыбораОсобогоПризнакаЗаявителя(Элементы.ОсобыйПризнакЗаявителя.СписокВыбора);
	ЗаполнитьСписокВыбораОсобогоПризнакаДОПП(Элементы.ОсобыйПризнакДОПП.СписокВыбора);
	ЗаполнитьСписокВыбораОсобогоПризнакаДОПП(Элементы.ТоварыОсобыйПризнакДОПП.СписокВыбора);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокВыбораОсобогоПризнакаДОПП(СписокВыбора)

	СписокВыбора.Очистить();
	СписокВыбора.Добавить("0",  "0 – Отсутствует");
	СписокВыбора.Добавить("1",  "1 – Товары, не подлежащие налогообложению");
	СписокВыбора.Добавить("4",  "4 – Передача в рамках одного юридического лица");
	СписокВыбора.Добавить("5",  "5 – Переработка давальческого сырья");
	СписокВыбора.Добавить("6",  "6 – Возврат товара");
	СписокВыбора.Добавить("7",  "7 – Аренда оборудования");
	СписокВыбора.Добавить("8",  "8 – Выставочный экземпляр");
	СписокВыбора.Добавить("9",  "9 – Лизинг");
	СписокВыбора.Добавить("10", "10 – Договор между двумя российскими организациями");
	СписокВыбора.Добавить("11", "11 – Договор с физическим лицом (не ИП)");

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокВыбораОсобогоПризнакаЗаявителя(СписокВыбора)

	СписокВыбора.Очистить();
	СписокВыбора.Добавить("0",  "0 – Отсутствует");
	СписокВыбора.Добавить("1",  "1 – Освобождение от внесения обеспечительного платежа");
	СписокВыбора.Добавить("2",  "2 – Иной признак");

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДобавленныеКолонкиТаблиц()

	Для Каждого СтрокаТаблицы Из Объект.Товары Цикл
		ЗаполнитьДобавленныеКолонкиСтрокиТаблицыТовары(СтрокаТаблицы);
	КонецЦикла;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьДобавленныеКолонкиСтрокиТаблицыТовары(СтрокаТаблицы)
	
	ЗаполнитьЗаголовкиСтрок(СтрокаТаблицы);
	ЗаполнитьПризнакЕдиницыРазличаются(СтрокаТаблицы);
	ЗаполнитьАналитикуАкцизов(СтрокаТаблицы);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьЗаголовкиСтрок(СтрокаТаблицы)
	
	СтрокаТаблицы.НадписьНомерДокумента = НСтр("ru='Номер:'");
	СтрокаТаблицы.НадписьДатаДокумента  = НСтр("ru='Дата:'");
	СтрокаТаблицы.НадписьПоДокументу    = НСтр("ru='По документу:'");
	СтрокаТаблицы.НадписьПоТНВЭД        = НСтр("ru='По ТН ВЭД:'");
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьАналитикуАкцизов(СтрокаТабличнойЧасти)
	
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.СуммаАкциза) Тогда
		
		Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.ТвердаяСтавкаАкциза) Тогда
			
			Если СтрокаТабличнойЧасти.ЕдиницаИзмеренияАкциза = "112" Тогда
				ЕдиницаНалоговойБазы = НСтр("ru='литров'");
				ЕдиницаСтавки = НСтр("ru='за литр'");
			ИначеЕсли СтрокаТабличнойЧасти.ЕдиницаИзмеренияАкциза = "168" Тогда
				ЕдиницаНалоговойБазы = НСтр("ru='тонн'");
				ЕдиницаСтавки = НСтр("ru='за тонну'");
			ИначеЕсли СтрокаТабличнойЧасти.ЕдиницаИзмеренияАкциза = "251" Тогда
				ЕдиницаНалоговойБазы = НСтр("ru='лошадиных сил'");
				ЕдиницаСтавки = НСтр("ru='за лошадиную силу'");
			ИначеЕсли СтрокаТабличнойЧасти.ЕдиницаИзмеренияАкциза = "831" Тогда
				ЕдиницаНалоговойБазы = НСтр("ru='литров 100% спирта'");
				ЕдиницаСтавки = НСтр("ru='за литр 100% спирта'");
			Иначе
				ЭлементЕдиницыИзмеренияАкциза = Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(СтрокаТабличнойЧасти.ЕдиницаИзмеренияАкциза);
				Если ЭлементЕдиницыИзмеренияАкциза <> Неопределено Тогда
					ЕдиницаНалоговойБазы = ЭлементЕдиницыИзмеренияАкциза;
					ЕдиницаСтавки = НСтр("ru='за '" + ЭлементЕдиницыИзмеренияАкциза);
				КонецЕсли
			КонецЕсли;
			
			ТекстСообщения = НСтр("ru='%1 руб. (%2 %3 * %4 %5)'");
			
			СтрокаТабличнойЧасти.АналитикаАкциза = СтрШаблон(ТекстСообщения,
				СтрокаТабличнойЧасти.СуммаАкциза,
				СтрокаТабличнойЧасти.НалоговаяБазаАкцизы,
				ЕдиницаНалоговойБазы,
				СтрокаТабличнойЧасти.ТвердаяСтавкаАкциза,
				ЕдиницаСтавки);
			
		Иначе
			
			ТекстСообщения = НСтр("ru='%1 руб. (%2 руб. * %3%%)'");
			
			СтрокаТабличнойЧасти.АналитикаАкциза = СтрШаблон(ТекстСообщения,
				СтрокаТабличнойЧасти.СуммаАкциза,
				СтрокаТабличнойЧасти.НалоговаяБазаАкцизы,
				СтрокаТабличнойЧасти.АдвалорнаяСтавкаАкциза);
			
		КонецЕсли;
		
	Иначе
		СтрокаТабличнойЧасти.АналитикаАкциза = НСтр("ru='Без акциза'");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьПризнакЕдиницыРазличаются(СтрокаТаблицы)
	
	СтрокаТаблицы.ЕдиницыРазличаются = СтрокаТаблицы.ЕдиницаИзмерения <> СтрокаТаблицы.КодТНВЭД.ЕдиницаИзмерения;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьМассивВидовДоговоров()

	СписокВидовДоговоров = Новый Массив;
	СписокВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПоставщиком"));
	СписокВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионеромНаЗакупку"));
	
	Возврат СписокВидовДоговоров;

КонецФункции

&НаСервере
Процедура ТоварыНоменклатураПриИзмененииНаСервере(СтрокаТабличнойЧасти, Знач ДанныеОбъекта)
	
	Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
		Возврат;
	КонецЕсли;
	
	СведенияОНоменклатуре = БухгалтерскийУчетПереопределяемый.ПолучитьСведенияОНоменклатуре(
		СтрокаТабличнойЧасти.Номенклатура, ДанныеОбъекта);
		
	Если СведенияОНоменклатуре = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если СведенияОНоменклатуре.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.Общая
	 Или СведенияОНоменклатуре.ВидСтавкиНДС = Перечисления.ВидыСтавокНДС.ОбщаяРасчетная Тогда
		СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Общая, ДанныеОбъекта.Дата);
	Иначе
		СтрокаТабличнойЧасти.СтавкаНДС = Перечисления.СтавкиНДС.СтавкаНДС(Перечисления.ВидыСтавокНДС.Пониженная, ДанныеОбъекта.Дата);
	КонецЕсли;
	СтрокаТабличнойЧасти.ЕдиницаИзмерения    = СведенияОНоменклатуре.ЕдиницаИзмерения;
	СтрокаТабличнойЧасти.СтранаПроисхождения = СведенияОНоменклатуре.СтранаПроисхождения;
	СтрокаТабличнойЧасти.КодТНВЭД            = СведенияОНоменклатуре.КодТНВЭД;
	
	Если ВедетсяУчетПрослеживаемыхТоваров Тогда
		СтрокаТабличнойЧасти.ПрослеживаемыйТовар = СведенияОНоменклатуре.ПрослеживаемыйТовар;
	Иначе
		СтрокаТабличнойЧасти.ПрослеживаемыйТовар = Ложь;
	КонецЕсли;
	
	Если ДанныеОбъекта.ЕстьУчетПодакцизныхТоваров Тогда
		
		СтрокаТабличнойЧасти.НалоговаяБазаНДС          = СтрокаТабличнойЧасти.НалоговаяБазаНДС - СтрокаТабличнойЧасти.СуммаАкциза;
		КодВидаПодакцизногоТовара                      = СведенияОНоменклатуре.КодВидаПодакцизногоТовара;
		СтрокаТабличнойЧасти.КоэффициентПересчета      = СведенияОНоменклатуре.КоэффициентПересчета;
		СтрокатабличнойЧасти.ЕдиницаИзмеренияАкциза    = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СведенияОНоменклатуре.ЕдиницаИзмеренияДляРасчетаАкциза, "Код");
		
		// СведенияОНоменклатуре.МаркируемаяПродукция
		
		Если ЗначениеЗаполнено(КодВидаПодакцизногоТовара) Тогда
			
			ВидТовара = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КодВидаПодакцизногоТовара, "ВидТовара");
			АкцизПоНоменклатуреНачисляется = ДанныеОбъекта.ВидыПроизведенныхПодакцизныхТоваров.НайтиПоЗначению(ВидТовара);
			
			Если АкцизПоНоменклатуреНачисляется = Неопределено Тогда
				ОбнулитьДанныеПоАкцизам(СтрокаТабличнойЧасти);
			Иначе
				СтрокаТабличнойЧасти.ПодакцизныйТовар          = Истина;
				СтрокаТабличнойЧасти.КодВидаПодакцизногоТовара = КодВидаПодакцизногоТовара;
				СтрокаТабличнойЧасти.КБК                       = Документы.ЗаявлениеОВвозеТоваров.КБКПоКодуВидаПодакцизногоТовара(КодВидаПодакцизногоТовара);
				СтрокаТабличнойЧасти.МаркируемаяПродукция      = СведенияОНоменклатуре.МаркируемаяПродукция;
				
				СтруктураРасчетаАкциза = Новый Структура("Ставка, ОкруглятьДоЦелого", 0, Ложь);
				УчетАкцизов.ПолучитьСтавкуАкциза(КодВидаПодакцизногоТовара, ДанныеОбъекта.Дата, СтруктураРасчетаАкциза);
				
				СтрокаТабличнойЧасти.ТвердаяСтавкаАкциза      = СтруктураРасчетаАкциза.Ставка;
				СтрокаТабличнойЧасти.ОкруглятьДоЦелого        = СтруктураРасчетаАкциза.ОкруглятьДоЦелого;
				
				УчетАкцизовКлиентСервер.РассчитатьСуммуАкцизаВТабЧастиПоЗаявлениюОВвозе(СтрокаТабличнойЧасти, Истина);
				
			КонецЕсли;
			
		Иначе
			
			ОбнулитьДанныеПоАкцизам(СтрокаТабличнойЧасти);
			
		КонецЕсли;
		
	КонецЕсли;
		
	Если СведенияОНоменклатуре.Свойство("СчетаУчета") Тогда
		// СведенияОНоменклатуре - структура сведений номенклатуры
		СчетаУчета = СведенияОНоменклатуре.СчетаУчета;
	Иначе
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СчетаУчета.СчетУчета)
		И СчетаУчета.СчетУчетаЯвляетсяЗабалансовым =
		(СчетаУчета.СчетУчета = ПланыСчетов.Хозрасчетный.ТМЦпринятыеНаОтветственноеХранение) Тогда
		СтрокаТабличнойЧасти.СчетУчета = СчетаУчета.СчетУчета;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбнулитьДанныеПоАкцизам(СтрокаТабличнойЧасти)

	СтрокаТабличнойЧасти.ПодакцизныйТовар          = Ложь;
	СтрокаТабличнойЧасти.СуммаАкциза               = 0;
	СтрокаТабличнойЧасти.КоэффициентПересчета      = 0;
	СтрокаТабличнойЧасти.ТвердаяСтавкаАкциза       = 0;
	СтрокаТабличнойЧасти.НалоговаяБазаАкцизы       = 0;
	СтрокаТабличнойЧасти.ОкруглятьДоЦелого         = Ложь;
	СтрокаТабличнойЧасти.ЕдиницаИзмеренияАкциза    = "";
	СтрокаТабличнойЧасти.КодВидаПодакцизногоТовара = Справочники.КодыВидовПодакцизныхТоваров.ПустаяСсылка();
	СтрокаТабличнойЧасти.КБК                       = "";
	СтрокаТабличнойЧасти.МаркируемаяПродукция      = Ложь;

КонецПроцедуры

&НаСервере
Процедура РасчитатьСуммыВТабличнойЧастиНаСервере(СтрокаТабличнойЧасти, ДанныеОбъекта)
	
	Документы.ЗаявлениеОВвозеТоваров.РасчитатьСуммыВТабличнойЧастиДОПП(СтрокаТабличнойЧасти, ДанныеОбъекта);
	ОбновитьИтоги(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораАкцизы(ВыбранноеЗначение)
	
	СтрокаТабличнойЧасти = Элементы.Товары.ТекущиеДанные;
	
	ДанныеСтрокиТаблицы = Новый Структура(
		"ФактурнаяСтоимость,НалоговаяБазаНДС,СтавкаНДС,СуммаНДС,ОбеспечительныйПлатеж,КодВидаПодакцизногоТовара,КБК,МаркируемаяПродукция,
		|НалоговаяБазаАкцизы,ЕдиницаИзмеренияАкциза,ТвердаяСтавкаАкциза,АдвалорнаяСтавкаАкциза,СуммаАкциза,АналитикаАкциза");
		
	ДанныеОбъекта = Новый Структура(
		"ВалютаРегламентированногоУчета,ВалютаДокумента,Дата,ОсобыйПризнакЗаявителя",
		ВалютаРегламентированногоУчета, Объект.ВалютаДокумента, Объект.Дата, Объект.ОсобыйПризнакЗаявителя);
		
	ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, СтрокаТабличнойЧасти);
	ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, ВыбранноеЗначение);
	
	РасчитатьСуммыВТабличнойЧастиНаСервере(ДанныеСтрокиТаблицы, ДанныеОбъекта);
	ЗаполнитьАналитикуАкцизов(ДанныеСтрокиТаблицы);
	
	ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, ДанныеСтрокиТаблицы);
	ОбновитьИтоги(ЭтотОбъект);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ДоговорКонтрагентаПриИзмененииНаСервере()

	ВалютаДоговора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ДоговорКонтрагента, "ВалютаВзаиморасчетов");
	
	Если Объект.ВалютаДокумента <> ВалютаДоговора Тогда
		
		Объект.ВалютаДокумента = ВалютаДоговора;
		НаименованиеВалютыДокумента = Объект.ВалютаДокумента.Наименование;
		
		ДанныеОбъекта = Новый Структура(
			"ВалютаРегламентированногоУчета,ВалютаДокумента,Дата,ОсобыйПризнакЗаявителя",
			ВалютаРегламентированногоУчета, Объект.ВалютаДокумента, Объект.Дата, Объект.ОсобыйПризнакЗаявителя);
		
		Для каждого СтрокаТабличнойЧасти Из Объект.Товары Цикл
			
			РасчитатьСуммыВТабличнойЧастиНаСервере(СтрокаТабличнойЧасти, ДанныеОбъекта);
			
		КонецЦикла;
		
		УправлениеФормой(ЭтотОбъект);
		ОбновитьИтоги(ЭтотОбъект);
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОсобыйПризнакЗаявителяПриИзмененииНаСервере()
	
	ДанныеОбъекта = Новый Структура(
		"ВалютаРегламентированногоУчета,ВалютаДокумента,Дата,ОсобыйПризнакЗаявителя",
		ВалютаРегламентированногоУчета, Объект.ВалютаДокумента, Объект.Дата, Объект.ОсобыйПризнакЗаявителя);
	
	Для каждого СтрокаТабличнойЧасти Из Объект.Товары Цикл
		
		РасчитатьСуммыВТабличнойЧастиНаСервере(СтрокаТабличнойЧасти, ДанныеОбъекта);
		
	КонецЦикла;
	
	УправлениеФормой(ЭтотОбъект);
	ОбновитьИтоги(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	УстановитьФункциональныеОпцииФормы();
	УстановитьОсобыйПризнакЗаявителя();
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		КонтрагентОбработатьИзменение();
	КонецЕсли;
	
	ПересчитатьСуммыАкциза();
	
	УправлениеФормой(ЭтотОбъект);
	
	СтруктураРеквизитовВыгрузки = ОбновитьДанныеРеквизитовВыгрузки();
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСуммыАкциза()
	
	Если ИмпортПодакцизныхТоваров Тогда
		Для Каждого Строка Из Объект.Товары Цикл 
			Строка.НалоговаяБазаНДС = Строка.НалоговаяБазаНДС - Строка.СуммаАкциза;
		КонецЦикла;
		ПараметрыЗаполнения = Новый Структура;
		УчетАкцизов.ПараметрыДляЗаполненияДанныхПоАкцизам(ПараметрыЗаполнения);
		ПараметрыЗаполнения.Импорт          = Истина;
		ПараметрыЗаполнения.ЗаявлениеОВвозе = Истина;
		ПараметрыЗаполнения.ДОПП            = Истина;
		УчетАкцизов.ЗаполнитьДанныеПоАкцизам(Объект.Товары, Объект.Организация, Объект.Дата, ПараметрыЗаполнения);
		ДанныеОбъекта = Новый Структура("ОсобыйПризнакЗаявителя", Объект.ОсобыйПризнакЗаявителя);
		Для Каждого Строка Из Объект.Товары Цикл
			ДанныеСтрокиТаблицы = Новый Структура(
				"НалоговаяБазаАкцизы,ЕдиницаИзмеренияАкциза,ТвердаяСтавкаАкциза,АдвалорнаяСтавкаАкциза,СуммаАкциза,АналитикаАкциза");
			ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, Строка);
			ЗаполнитьАналитикуАкцизов(ДанныеСтрокиТаблицы);
			Строка.АналитикаАкциза = ДанныеСтрокиТаблицы.АналитикаАкциза;
			РассчитатьНалогиПоСтроке(ДанныеОбъекта, Строка);
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ДатаПриИзмененииНаСервере()
	
	Если Объект.ВалютаДокумента <> ВалютаРегламентированногоУчета Тогда
		
		ДанныеОбъекта = Новый Структура(
			"ВалютаРегламентированногоУчета,ВалютаДокумента,Дата,ОсобыйПризнакЗаявителя",
			ВалютаРегламентированногоУчета, Объект.ВалютаДокумента, Объект.Дата, Объект.ОсобыйПризнакЗаявителя);
		
		Для каждого СтрокаТабличнойЧасти Из Объект.Товары Цикл
			РасчитатьСуммыВТабличнойЧастиНаСервере(СтрокаТабличнойЧасти, ДанныеОбъекта);
		КонецЦикла;
		
	КонецЕсли;
	
	УстановитьФункциональныеОпцииФормы();
	РаботаСНоменклатуройБП.ОбновитьПризнакПрослеживаемости(Объект.Товары, ВедетсяУчетПрослеживаемыхТоваров, Объект.Дата);
	
	ПересчитатьСуммыАкциза();
	
	УстановитьПараметрыВыбораСтавкиНДС();
	УправлениеФормой(ЭтотОбъект);
	ОбновитьИтоги(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура КонтрагентПриИзмененииНаСервере()

	КонтрагентОбработатьИзменение();
	
	УправлениеФормой(ЭтотОбъект);

КонецПроцедуры

&НаСервере
Процедура КонтрагентОбработатьИзменение()

	РаботаСДоговорамиКонтрагентовБП.УстановитьДоговорКонтрагента(
		Объект.ДоговорКонтрагента, Объект.Контрагент, Объект.Организация, 
		ПолучитьМассивВидовДоговоров());
		
	Если ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
		ДоговорКонтрагентаПриИзмененииНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура УстановитьОсобыйПризнакЗаявителя()
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Организация, "КрупнейшийНалогоплательщик") = Истина Тогда
			Объект.ОсобыйПризнакЗаявителя = "1";
			ОсобыйПризнакЗаявителяПриИзмененииНаСервере();
			Возврат;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаявлениеОВвозеТоваров.ОсобыйПризнакЗаявителя КАК ОсобыйПризнакЗаявителя,
		|	ЗаявлениеОВвозеТоваров.ИнойОсобыйПризнакЗаявителя КАК ИнойОсобыйПризнакЗаявителя
		|ИЗ
		|	Документ.ЗаявлениеОВвозеТоваров КАК ЗаявлениеОВвозеТоваров
		|ГДЕ
		|	ЗаявлениеОВвозеТоваров.Организация = &Организация
		|	И ЗаявлениеОВвозеТоваров.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийВвозТоваровИзЕАЭС.ДОПП)
		|	И НЕ ЗаявлениеОВвозеТоваров.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаявлениеОВвозеТоваров.Дата УБЫВ";
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Объект.ОсобыйПризнакЗаявителя     = Выборка.ОсобыйПризнакЗаявителя;
			Объект.ИнойОсобыйПризнакЗаявителя = Выборка.ИнойОсобыйПризнакЗаявителя;
		КонецЕсли;
		
		ОсобыйПризнакЗаявителяПриИзмененииНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередЗаполнениемТабличнойЧастиЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	
