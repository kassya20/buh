
#Область ОписаниеПеременных

&НаКлиенте
Перем ЭтоНоваяСтрока;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		Если ЗначениеЗаполнено(Параметры.Организация) Тогда
			Объект.Организация = Параметры.Организация;
		КонецЕсли;
		Если ЗначениеЗаполнено(Параметры.ДокументОснование) Тогда
			ЗаполнитьДокументПоСчетуНаОплату(Параметры.ДокументОснование);
		КонецЕсли;
		ПодготовитьФормуНаСервере();
	КонецЕсли;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов
	
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		СтруктураРеквизитовВыгрузки = Объект.Ссылка.ПолучитьОбъект().СтруктураРеквизитовВыгрузки.Получить();
	КонецЕсли;
		
	Если СтруктураРеквизитовВыгрузки = Неопределено Тогда
		СтруктураРеквизитовВыгрузки = Параметры.ЗначениеКопирования.СтруктураРеквизитовВыгрузки.Получить();
		Если СтруктураРеквизитовВыгрузки = Неопределено Тогда
			СтруктураРеквизитовВыгрузки = ОбновитьДанныеРеквизитовВыгрузки();
		КонецЕсли;
	КонецЕсли;
	
	Документы.ЗаявлениеОВвозеТоваров.ОбновитьСтруктуруРеквизитовВыгрузки(СтруктураРеквизитовВыгрузки);
	
	НайтиРеглУведомлениеДОПП();
	ЗаполнитьТекстПроДОПП();
	УстановитьПараметрыВыбораСтавкиНДС();
	УстановитьПараметрыВыбораДоговора();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения
	
	ПодготовитьФормуНаСервере();
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.ПослеЗаписи(ЭтотОбъект, Объект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	Оповестить("Запись_ЗаявлениеОВвозеТоваров", ПараметрыЗаписи, Объект.Ссылка);
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	ОбновитьИтоги(ЭтотОбъект);
	УстановитьЗаголовокФормы(ЭтотОбъект);
	
	УстановитьСостояниеДокумента();
	
	Если Не Объект.ПометкаУдаления Тогда
		ЗарегистрироватьАктуализироватьДОПП();
		ЗаполнитьТекстПроДОПП();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ИсточникВыбора.ИмяФормы = "Документ.ЗаявлениеОВвозеТоваров.Форма.ФормаРедактированияАкцизов" Тогда
		ОбработкаВыбораАкцизы(ВыбранноеЗначение);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ТекущийОбъект.СтруктураРеквизитовВыгрузки = Новый ХранилищеЗначения(СтруктураРеквизитовВыгрузки);
	
	ПроведениеСервер.УстановитьПризнакПроверкиРеквизитов(Отказ, ТекущийОбъект, ПараметрыЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Дата) Тогда
		ДатаПриИзмененииНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		КонтрагентПриИзмененииНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОсобыйПризнакДОПППриИзменении(Элемент)
	
	Если Объект.Товары.Количество() > 0 Тогда
		Оповещение = Новый ОписаниеОповещения(
			"ВопросПередИзменениемПризнакаДОППЗавершение", ЭтотОбъект, Новый Структура);
		ТекстВопроса = НСтр("ru = 'Особый признак ДОПП будет установлен для всех строк. Продолжить?'");
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет,, КодВозвратаДиалога.Да);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		ОрганизацияПриИзмененииНаСервере();
	КонецЕсли;

КонецПроцедуры 

&НаКлиенте
Процедура ОсобыйПризнакЗаявителяПриИзменении(Элемент)
	
	Если Объект.ОсобыйПризнакЗаявителя <> 2 Тогда
		Объект.ИнойОсобыйПризнакЗаявителя = "";
	КонецЕсли;
	
	ОсобыйПризнакЗаявителяПриИзмененииНаСервере();
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДоговорКонтрагентаПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(Объект.ДоговорКонтрагента) Тогда
		ДоговорКонтрагентаПриИзмененииНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РегистрационныйЗнакПрицепаПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(Объект.РегистрационныйЗнакПрицепа) Тогда
		Объект.РегистрационныйЗнакПрицепаДополнительный = "";
	КонецЕсли;
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияСсылкаНаДОППНажатие(Элемент)
	
	ПараметрыОткрытия = Новый Структура();
	ПараметрыОткрытия.Вставить("Ключ", СсылкаНаДОПП);
	ФормаДОПП = ОткрытьФорму("Документ.УведомлениеОСпецрежимахНалогообложения.Форма.ФормаДокумента",
		ПараметрыОткрытия, ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыТовары

&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
		Возврат;
	КонецЕсли;
	
	ПриИзмененииНоменклатуры(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
	
	Если ЕстьУчетПодакцизныхТоваров Тогда
		
		ТекущиеДанные = Элементы.Товары.ТекущиеДанные;	
		ТекущиеДанные.НалоговаяБазаНДС = ТекущиеДанные.НалоговаяБазаНДС - ТекущиеДанные.СуммаАкциза;
		УчетАкцизовКлиентСервер.РассчитатьСуммуАкцизаВТабЧастиПоЗаявлениюОВвозе(ТекущиеДанные, Истина);
		ТекущиеДанные.НалоговаяБазаНДС = ТекущиеДанные.НалоговаяБазаНДС + ТекущиеДанные.СуммаАкциза;
		ДанныеСтрокиТаблицы = Новый Структура(
			"НалоговаяБазаАкцизы,ЕдиницаИзмеренияАкциза,ТвердаяСтавкаАкциза,АдвалорнаяСтавкаАкциза,СуммаАкциза,АналитикаАкциза");
		ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, ТекущиеДанные);
		ЗаполнитьАналитикуАкцизов(ДанныеСтрокиТаблицы);
		ТекущиеДанные.АналитикаАкциза = ДанныеСтрокиТаблицы.АналитикаАкциза;
		ДанныеОбъекта = Новый Структура("ОсобыйПризнакЗаявителя", Объект.ОсобыйПризнакЗаявителя);
		РассчитатьНалогиПоСтроке(ДанныеОбъекта, ТекущиеДанные);
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСтавкаНДСПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	// При изменении ставки НДС перерасчитываем сумму НДС
	
	ДанныеОбъекта = Новый Структура("ОсобыйПризнакЗаявителя", Объект.ОсобыйПризнакЗаявителя);
	РассчитатьНалогиПоСтроке(ДанныеОбъекта, ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыНалоговаяБазаНДСПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	// При изменении налоговой базы перерасчитываем сумму НДС
	
	ДанныеОбъекта = Новый Структура("ОсобыйПризнакЗаявителя", Объект.ОсобыйПризнакЗаявителя);
	РассчитатьНалогиПоСтроке(ДанныеОбъекта, ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыФактурнаяСтоимостьПриИзменении(Элемент)

	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	
	ДанныеСтрокиТаблицы = Новый Структура(
		"ФактурнаяСтоимость,НалоговаяБазаНДС,СтавкаНДС,
		|СуммаНДС,СуммаАкциза,ОбеспечительныйПлатеж,МаркируемаяПродукция");
		
	ДанныеОбъекта = Новый Структура(
		"ВалютаРегламентированногоУчета,Дата,ВалютаДокумента,ОсобыйПризнакЗаявителя",
		ВалютаРегламентированногоУчета, Объект.Дата, Объект.ВалютаДокумента, Объект.ОсобыйПризнакЗаявителя);
		
	ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, ТекущиеДанные);
	
	РасчитатьСуммыВТабличнойЧастиНаСервере(ДанныеСтрокиТаблицы, ДанныеОбъекта);
	
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, ДанныеСтрокиТаблицы);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыАналитикаАкцизаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ВыбраннаяСтрока = Элементы.Товары.ТекущаяСтрока;
	ОткрытьФормуРедактированияАкцизов(ВыбраннаяСтрока);

КонецПроцедуры

&НаКлиенте
Процедура ТоварыОсобыйПризнакДОПППриИзменении(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	АктуализироватьНалогиПоСтрокеТовары(СтрокаТаблицы);
	ОбновитьИтоги(ЭтотОбъект);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриИзменении(Элемент)
	
	ОбновитьИтоги(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПослеУдаления(Элемент)
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "ТоварыАналитикаАкциза" Тогда
		ОткрытьФормуРедактированияАкцизов(ВыбраннаяСтрока);
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
	Если Поле.Имя = "ТоварыПрослеживаемыйТовар" Тогда
		ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
		Если ТекущиеДанные.ПрослеживаемыйТовар Тогда
			ПрослеживаемостьФормыКлиентБП.ПоказатьПредупреждениеПрослеживаемыйТовар();
		Конецесли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриАктивизацииЯчейки(Элемент)
	
	Если Элементы.Товары.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если ЭтоНоваяСтрока Тогда
		ТекущаяКолонкаТаблицы = Элементы.Товары.ТекущийЭлемент;
		Если ТекущаяКолонкаТаблицы.Имя = "ТоварыАналитикаАкциза" Тогда
			ВыбраннаяСтрока = Элементы.Товары.ТекущаяСтрока;
			ОткрытьФормуРедактированияАкцизов(ВыбраннаяСтрока);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)

	ЭтоНоваяСтрока = НоваяСтрока;
	
	Если НЕ НоваяСтрока ИЛИ Копирование Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗаголовкиСтрок(Элементы.Товары.ТекущиеДанные);
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	СтрокаТаблицы.АналитикаАкциза = НСтр("ru='Без акциза'");
	СтрокаТаблицы.ОсобыйПризнакДОПП = Объект.ОсобыйПризнакДОПП;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	
	Если ОтменаРедактирования И НоваяСтрока Тогда
		// Закроем форму редактирования строки, т.к. пользователь отменяет ввод
		Оповестить("ФормаРедактированияАкцизов_Закрыть", Неопределено, ЭтотОбъект);
	КонецЕсли;
	
	ЭтоНоваяСтрока = Ложь;
	
	ОбновитьИтоги(ЭтотОбъект);
	
КонецПроцедуры


#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ТоварыДобавитьИзПоступления(Команда)
	
	ОткрытьФормуВыбораПоступленияТоваровУслугДляЗаполнения();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзСчетаПоставщика(Команда)
	
	ОткрытьФормуВыбораСчетаПоставщика();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьИзДокументаОПредстоящейПоставке(Команда)
	
	ОткрытьФормуВыбораДОПП();
	
КонецПроцедуры

&НаКлиенте
Процедура СкорректироватьДОПП(Команда)
	
	СоздатьРеглОтчетДОПП(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура НастроитьПараметрыВыгрузки(Команда)
	
	ОткрытьФормуВыгрузки2015();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область УправлениеФормой

&НаСервере
Процедура ПодготовитьФормуНаСервере()

	УстановитьФункциональныеОпцииФормы();
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	ЗаполнитьКоллекциюСписковВыбора();
	
	УстановитьОсобыйПризнакЗаявителя();
	УстановитьСостояниеДокумента();
	
	НаименованиеВалютыДокумента = Объект.ВалютаДокумента.Наименование;
	ВалютаРегламентированногоУчета = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	
	ОбновитьИтоги(ЭтотОбъект);
	
	УстановитьЗаголовокФормы(ЭтотОбъект);
	
	УправлениеФормой(ЭтотОбъект);
	
	УстановитьУсловноеОформление();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УправлениеФормой(Форма)
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	Элементы.ДоговорКонтрагента.Доступность = ЗначениеЗаполнено(Объект.Организация) И ЗначениеЗаполнено(Объект.Контрагент);
	
	Элементы.ТоварыСтоимостьВал.Заголовок = СтрШаблон(
		НСтр("ru='Фактурная стоимость (%1)'"),
		Форма.НаименованиеВалютыДокумента); 
		
	Элементы.РегистрационныйЗнакПрицепаДополнительный.Доступность = ЗначениеЗаполнено(Объект.РегистрационныйЗнакПрицепа);
	Элементы.ИнойОсобыйПризнакЗаявителя.Видимость = Объект.ОсобыйПризнакЗаявителя = "2";
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьЗаголовокФормы(Форма)
	
	Объект = Форма.Объект;
	ТекстЗаголовка = НСтр("ru = 'Документ о предстоящей поставке товаров'");
		
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ТекстЗаголовка = ТекстЗаголовка + СтрШаблон(НСтр("ru=' %1 от %2'"), Объект.Номер, Объект.Дата);
	Иначе
		ТекстЗаголовка = ТекстЗаголовка + НСтр("ru = ' (создание)'");
	КонецЕсли;
	
	Форма.Заголовок = ТекстЗаголовка;

КонецПроцедуры

&НаСервере
Процедура УстановитьФункциональныеОпцииФормы() Экспорт
	
	ПлательщикНДС = УчетнаяПолитика.ПлательщикНДС(Объект.Организация, Объект.Дата)
		ИЛИ УчетнаяПолитика.ПлательщикНДСНаУСНСВычетами(Объект.Организация, Объект.Дата);
	
	ОбщегоНазначенияБПКлиентСервер.УстановитьПараметрыФункциональныхОпцийФормыДокумента(ЭтотОбъект);
	ВедетсяУчетПрослеживаемыхТоваров =
		ПолучитьФункциональнуюОпцию("ВестиУчетПрослеживаемыхТоваров")
		И ПрослеживаемостьБРУ.ВедетсяУчетПрослеживаемыхТоваров(Объект.Дата);
		
	ИмпортПодакцизныхТоваров = ПолучитьФункциональнуюОпцию("ИмпортПодакцизныхТоваров");
	Если ИмпортПодакцизныхТоваров Тогда
		УчетАкцизов.СписокИмпортируемыхПодакцизныхТоваров(Объект.Организация, ВидыПроизведенныхПодакцизныхТоваров);
		ЕстьУчетПодакцизныхТоваров = ВидыПроизведенныхПодакцизныхТоваров.Количество() > 0;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	УсловноеОформление.Элементы.Очистить();
	
	// Признак прослеживаемости
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТоварыПрослеживаемыйТовар");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"ВедетсяУчетПрослеживаемыхТоваров", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	// ТоварыСклад
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТоварыСклад");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор, 
		"УказыватьСкладВТабличнойЧасти", ВидСравненияКомпоновкиДанных.Равно, Ложь);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	// ТоварыСтавкаНДС
	ЭлементУО = УсловноеОформление.Элементы.Добавить();
	КомпоновкаДанныхКлиентСервер.ДобавитьОформляемоеПоле(ЭлементУО.Поля, "ТоварыСтавкаНДС");
	ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(ЭлементУО.Отбор,
		"Объект.Товары.ТоварыОсобыйПризнакДОПП", ВидСравненияКомпоновкиДанных.НеРавно, 0);
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", Ложь);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьИтоги(Форма)
	
	Объект = Форма.Объект;
	Форма.ОбеспечительныйПлатеж = Окр(Объект.Товары.Итог("ОбеспечительныйПлатеж"));
	
КонецПроцедуры

&НаКлиенте
Процедура АктуализироватьНалогиПоСтрокеТовары(СтрокаТаблицы)
	
	Если СтрокаТаблицы.ОсобыйПризнакДОПП = "0" Тогда
		ПриИзмененииНоменклатуры(СтрокаТаблицы);
		ДанныеОбъекта = Новый Структура(
			"ВалютаРегламентированногоУчета,ВалютаДокумента,Дата,ОсобыйПризнакЗаявителя",
			ВалютаРегламентированногоУчета, Объект.ВалютаДокумента, Объект.Дата, Объект.ОсобыйПризнакЗаявителя); 
		ДанныеСтрокиТаблицы = Новый Структура(
			"ФактурнаяСтоимость,НалоговаяБазаНДС,СтавкаНДС,СуммаНДС,ОбеспечительныйПлатеж,КодВидаПодакцизногоТовара,КБК,МаркируемаяПродукция,
			|НалоговаяБазаАкцизы,ЕдиницаИзмеренияАкциза,ТвердаяСтавкаАкциза,АдвалорнаяСтавкаАкциза,СуммаАкциза,АналитикаАкциза");
		ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, СтрокаТаблицы);
		РасчитатьСуммыВТабличнойЧастиНаСервере(ДанныеСтрокиТаблицы, ДанныеОбъекта);
		ЗаполнитьАналитикуАкцизов(ДанныеСтрокиТаблицы);
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ДанныеСтрокиТаблицы);

	Иначе
		СтрокаТаблицы.СтавкаНДС                 = ПредопределенноеЗначение("Перечисление.СтавкиНДС.ПустаяСсылка");
		СтрокаТаблицы.СуммаНДС                  = 0;
		СтрокаТаблицы.НалоговаяБазаНДС          = 0;
		СтрокаТаблицы.НалоговаяБазаАкцизы       = 0;
		СтрокаТаблицы.ТвердаяСтавкаАкциза       = 0;
		СтрокаТаблицы.АдвалорнаяСтавкаАкциза    = 0;
		СтрокаТаблицы.СуммаАкциза               = 0;
		СтрокаТаблицы.ПодакцизныйТовар          = Ложь;
		СтрокаТаблицы.АналитикаАкциза           = НСтр("ru='Без акциза'");
		СтрокаТаблицы.ОбеспечительныйПлатеж     = 0;
		СтрокаТаблицы.КодВидаПодакцизногоТовара = ПредопределенноеЗначение("Справочник.КодыВидовПодакцизныхТоваров.ПустаяСсылка");
		СтрокаТаблицы.КБК                       = "";
		СтрокаТаблицы.МаркируемаяПродукция      = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьНалогиПоСтроке(ДанныеОбъекта, СтрокаТабличнойЧасти)
	
	Если СтрокаТабличнойЧасти.НалоговаяБазаНДС <> 0 Тогда
		СтрокаТабличнойЧасти.СуммаНДС = УчетНДСКлиентСервер.РассчитатьСуммуНДС(
			СтрокаТабличнойЧасти.НалоговаяБазаНДС,
			Ложь,
			УчетНДСВызовСервераПовтИсп.ПолучитьСтавкуНДС(СтрокаТабличнойЧасти.СтавкаНДС));
	КонецЕсли;
	
	Если ДанныеОбъекта.ОсобыйПризнакЗаявителя = "0" Тогда
		Если СтрокаТабличнойЧасти.МаркируемаяПродукция Тогда
			СтрокаТабличнойЧасти.ОбеспечительныйПлатеж = СтрокаТабличнойЧасти.СуммаНДС;
		Иначе
			СтрокаТабличнойЧасти.ОбеспечительныйПлатеж = СтрокаТабличнойЧасти.СуммаНДС + СтрокаТабличнойЧасти.СуммаАкциза;
		КонецЕсли;
	Иначе
		СтрокаТабличнойЧасти.ОбеспечительныйПлатеж = 0;
	КонецЕсли;

КонецПроцедуры 

&НаКлиенте
Процедура ПриИзмененииНоменклатуры(СтрокаТабличнойЧасти)
	
	ДанныеСтрокиТаблицы = Новый Структура(
		"Номенклатура,ЕдиницаИзмерения,СтранаПроисхождения,КодТНВЭД,
		|СчетУчета,СуммаНДС,СтавкаНДС,
		|СтранаПроисхождения,НалоговаяБазаНДС,
		|Количество,ЕдиницыРазличаются,ПрослеживаемыйТовар,ФактурнаяСтоимость,
		|КоэффициентПересчета,ОкруглятьДоЦелого,ПодакцизныйТовар,КодВидаПодакцизногоТовара,КБК,МаркируемаяПродукция,
		|СуммаАкциза,НалоговаяБазаАкцизы,ТвердаяСтавкаАкциза,ЕдиницаИзмеренияАкциза,АналитикаАкциза,ДоговорКонтрагента,ОбеспечительныйПлатеж");
	ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, СтрокаТабличнойЧасти);
	
	ДанныеОбъекта = Новый Структура("Дата,Организация,
		|ВалютаДокумента,ДоговорКонтрагента,Реализация,ЕстьУчетПодакцизныхТоваров,ВидыПроизведенныхПодакцизныхТоваров,ОсобыйПризнакЗаявителя");
	ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Объект);
	
	ДанныеОбъекта.Реализация = Ложь;
	ДанныеОбъекта.ЕстьУчетПодакцизныхТоваров = ЕстьУчетПодакцизныхТоваров;
	ДанныеОбъекта.ВидыПроизведенныхПодакцизныхТоваров = ВидыПроизведенныхПодакцизныхТоваров;
	
	ТоварыНоменклатураПриИзмененииНаСервере(ДанныеСтрокиТаблицы, ДанныеОбъекта);
	
	ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, ДанныеСтрокиТаблицы);
	Если ЕстьУчетПодакцизныхТоваров Тогда
		СтрокаТабличнойЧасти.НалоговаяБазаНДС = СтрокаТабличнойЧасти.НалоговаяБазаНДС + СтрокаТабличнойЧасти.СуммаАкциза;
		ДанныеСтрокиТаблицы = Новый Структура(
			"НалоговаяБазаАкцизы,ЕдиницаИзмеренияАкциза,ТвердаяСтавкаАкциза,АдвалорнаяСтавкаАкциза,СуммаАкциза,АналитикаАкциза");
		ЗаполнитьЗначенияСвойств(ДанныеСтрокиТаблицы, СтрокаТабличнойЧасти);
		ЗаполнитьАналитикуАкцизов(ДанныеСтрокиТаблицы);
		СтрокаТабличнойЧасти.АналитикаАкциза = ДанныеСтрокиТаблицы.АналитикаАкциза;
	КонецЕсли;
	
	РассчитатьНалогиПоСтроке(ДанныеОбъекта, СтрокаТабличнойЧасти);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСостояниеДокумента()
	
	СостояниеДокумента = ОбщегоНазначенияБП.СостояниеДокумента(Объект);
	
КонецПроцедуры

