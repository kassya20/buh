#Область ОбработатьЗаписьСвязаннойЗаявки

&НаКлиенте
Процедура ОбработатьЗаписьСвязаннойЗаявки() Экспорт
	
	ОбработатьЗаписьСвязаннойЗаявкиНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьЗаписьСвязаннойЗаявкиНаСервере()
	
	ОписаниеДокумента = ОписаниеДокумента();
	ЗаявкиСотрудниковФормы.ПрочитатьВывестиСвязанныеЗаявки(ЭтаФорма, Объект, ОписаниеДокумента);
	ЗаявкиСотрудниковФормы.УстановитьДоступностьВыполненияПоСвязаннымЗаявкам(ЭтаФорма,ОписаниеДокумента);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработкаЗаписиОтменяющейЗаявки

&НаКлиенте
Процедура ОбработатьЗаписьОтменяющейЗаявки() Экспорт

	ОбработатьЗаписьОтменяющейЗаявкиНаСервере();

КонецПроцедуры

&НаСервере
Процедура ОбработатьЗаписьОтменяющейЗаявкиНаСервере()
	
	Прочитать();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработкаДанныхЗаявления

&НаСервере
Процедура ПроверкаДанныхЗаявления()
	
	ЦветАвто = Новый Цвет;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиНомераСчета",
		"Видимость", Ложь);
	
	РеквизитыБанка = ПолучитьБанкПоБИКу(Объект.БИК);
	Если РеквизитыБанка = Неопределено Тогда
		
		ЦветТекстаПроверкиБанка	= ЦветСтиляПоясняющийОшибкуТекст;
		ЗаголовокПроверкиБанка	= НСтр("ru = 'Не найден в классификаторе банков'");
		
	ИначеЕсли РеквизитыБанка.ДеятельностьПрекращена Тогда
		
		ЦветТекстаПроверкиБанка	= ЦветСтиляПоясняющийОшибкуТекст;
		ЗаголовокПроверкиБанка	= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
									НСтр("ru = 'Деятельность банка %1 прекращена'"),
									РеквизитыБанка.Наименование);
		
	Иначе
		
		ЦветТекстаПроверкиБанка	= ЦветСтиляИнформационнойНадписи;
		ЗаголовокПроверкиБанка	= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
									НСтр("ru = '%1'"),
									РеквизитыБанка.Наименование);
		
		РезультатПроверки = ПроверкиБЗККлиентСервер.РезультатПроверкиНомераСчета(
			Объект.НомерСчета,
			Объект.БИК,
			РеквизитыБанка.КоррСчет);
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиНомераСчета",
			"Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиНомераСчета",
			"Заголовок", РезультатПроверки.Пояснение);
		
		Если РезультатПроверки.Успех Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиНомераСчета",
				"ЦветТекста", ЦветСтиляИнформационнойНадписи);
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиНомераСчета",
				"ЦветТекста", ЦветСтиляПоясняющийОшибкуТекст);
		КонецЕсли;
		
		СуществующийБанковскийСчет = БанковскийСчет(РеквизитыБанка.Ссылка, Объект.НомерСчета, Объект.ФизическоеЛицо);
		БанковскийСчетСуществует = ЗначениеЗаполнено(СуществующийБанковскийСчет);
		Если БанковскийСчетСуществует Тогда
			ТекстЗаголовка = НСтр("ru = 'Банковский счет уже создан, нажмите здесь, чтобы выбрать'");
			ЦветНадписиПояснения = ЦветСтиляИнформационнойНадписи;
		Иначе
			ТекстЗаголовка = НСтр("ru = '<банковский счет не создан>'");
			ЦветНадписиПояснения = ЦветСтиляПоясняющийТекст;
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
			"Заголовок", ТекстЗаголовка);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
			"Гиперссылка", БанковскийСчетСуществует);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
			"ЦветТекста", ЦветНадписиПояснения);
		
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиБанка",
		"ЦветТекста", ЦветТекстаПроверкиБанка);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиБанка",
		"Заголовок", ЗаголовокПроверкиБанка);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьБанковскийСчет()
	
	Если Не ЗначениеЗаполнено(СуществующийБанковскийСчет) Тогда
		Если РеквизитыБанка = Неопределено Тогда
			Возврат;
		КонецЕсли;
		СуществующийБанковскийСчет = БанковскийСчет(РеквизитыБанка.Ссылка, Объект.НомерСчета, Объект.ФизическоеЛицо);
	КонецЕсли;
	
	БанковскийСчетСуществует = ЗначениеЗаполнено(СуществующийБанковскийСчет);
	Если БанковскийСчетСуществует Тогда
		ТекстЗаголовка = НСтр("ru = 'Банковский счет уже создан, нажмите здесь, чтобы выбрать'");
		ЦветНадписиПояснения = ЦветСтиляИнформационнойНадписи;
	Иначе
		ТекстЗаголовка = НСтр("ru = '<банковский счет не создан>'");
		ЦветНадписиПояснения = ЦветСтиляПоясняющийТекст;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"Заголовок", ТекстЗаголовка);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"Гиперссылка", БанковскийСчетСуществует);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"ЦветТекста", ЦветНадписиПояснения);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьБанкПоБИКу(БИК)
	
	НайденныйБанк = Неопределено;
	
	Если НЕ ЗначениеЗаполнено(БИК) Тогда
		Возврат НайденныйБанк;
	КонецЕсли;
	
	СведенияБИК = РаботаСБанками.СведенияБИК(БИК);
	Если Не ЗначениеЗаполнено(СведенияБИК) Тогда
		Возврат НайденныйБанк;
	КонецЕсли;
	
	Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СведенияБИК[0]);
	
КонецФункции

&НаСервереБезКонтекста
Функция БанковскийСчет(Банк, НомерСчета, Владелец)
	
	Результат = Неопределено;
	
	Если Не ЗначениеЗаполнено(Банк) Или Не ЗначениеЗаполнено(НомерСчета) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Возврат ЗаявкиСотрудников.БанковскийСчетФизическогоЛица(Банк, НомерСчета, Владелец);
	
КонецФункции

&НаКлиенте
Процедура СоздатьБанковскийСчетЗавершение(СозданныйБанковскийСчет, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(СозданныйБанковскийСчет) Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьБанковскийСчет(СозданныйБанковскийСчет);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьСпособВыплатыЗарплатыЗавершение(Параметры, ДополнительныеПараметры) Экспорт
	
	ЗаполнитьБанковскийСчет();
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработкаБанковскогоСчета

&НаКлиенте
Процедура ВыбратьБанковскийСчетЗавершение(ВыбранныйБанковскийСчет, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйБанковскийСчет = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДобавитьБанковскийСчет(ВыбранныйБанковскийСчет);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьБанковскийСчетЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		УдалитьБанковскийСчет();
	КонецЕсли;
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьБанковскийСчет(БанковскийСчетДляДобавления)
	
	Объект.БанковскийСчет = БанковскийСчетДляДобавления;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаБанковскийСчет",
		"Видимость", Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьБанковскийСчет()
	
	Объект.БанковскийСчет = Неопределено;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"Видимость", Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"Доступность", Не ТолькоПросмотр);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаБанковскийСчет",
		"Видимость", Ложь);
	
	ЗаполнитьБанковскийСчет();
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Процедура ИнициализацияФормы()
	
	ЦветСтиляПоясняющийОшибкуТекст	= ЦветаСтиля.ПоясняющийОшибкуТекст;
	ЦветСтиляИнформационнойНадписи	= ЦветаСтиля.ТекстИнформационнойНадписи;
	ЦветСтиляПоясняющийТекст		= ЦветаСтиля.ПоясняющийТекст;
	
	ДоступенРасширенныйФункционал = ИнтеграцияУправлениеПерсоналом.ДоступенРасширенныйФункционал();
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиБанка",
		"Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиНомераСчета",
		"Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаДокументыПоЗаявкеГлавная",
		"Видимость", ДоступенРасширенныйФункционал);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаБанковскийСчет",
		"Видимость", Ложь);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"Видимость", Ложь);
	
	ТекстПояснения = НСтр("ru = 'Выполнение заявки недоступно. Необходимо выполнить или отклонить отменяющую заявку.'");
	
	Если Объект.ТипОбъекта = Перечисления.ТипыОбъектовИнтеграцияУправлениеПерсоналом.ОтменаЗаявки Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаДокументыПоЗаявкеГлавная",
			"Видимость", Ложь);
		
		ТекстПояснения = СтрШаблон("%1 %2",
			НСтр("ru = 'Заявку можно отметить как выполненную.'"),
			НСтр("ru = 'Для отклонения заявки необходимо указать причину в ""Сообщении сотруднику"".'"));
	ИначеЕсли Не ЗначениеЗаполнено(ОтменяющаяЗаявка) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиБанка",
			"Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РезультатПроверкиНомераСчета",
			"Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
			"Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
		"Доступность", Не ТолькоПросмотр);
		
		ТекстПояснения = УстановитьТекстПоясненияПорядкаВыполнения();
		
		ПроверкаДанныхЗаявления();
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаДокументыПоЗаявкеГлавная",
			"Доступность", Ложь);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияВыполнениеПояснение",
		"Заголовок", ТекстПояснения);
	
	Если ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьБанковскийСчетЗаявкиПояснение",
			"Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаБанковскийСчет",
			"Видимость", Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция УстановитьТекстПоясненияПорядкаВыполнения()
	
	ТекстПояснения = СтрШаблон("%1 %2 %3 %4",
		НСтр("ru = 'Для выполнения заявки необходимо проверить существование данного филиала банка по БИК, корректность номера счёта,'"),
		НСтр("ru = 'создать банковский счёт и изменить способ выплаты зарплаты у сотрудника,'"),
		НСтр("ru = 'после этого заявку можно отметить как выполненную.'"),
		НСтр("ru = 'Для отклонения заявки необходимо указать причину в ""Сообщении сотруднику"".'"));
	
	Возврат ТекстПояснения;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОписаниеДокумента()
	
	Описание = ЗаявкиСотрудниковКлиентСервер.НовоеОписаниеДокументаЗаявки();
	Описание.ПроверятьСвязанныеЗаявки 	= Истина;
	Описание.ДоступнаОтменаЗаявки 		= Истина;
	
	Возврат Описание;
	
КонецФункции

#КонецОбласти