	ЗаявкиСотрудниковФормыКлиент.ОбработчикЗавершенияЗаписиВыполненияЗаявки(Результат, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Функция ЗаявкаГотоваКВыполнению(РезультатВыполненияЗаявки)
	
	Если РезультатВыполненияЗаявки = ПредопределенноеЗначение("Перечисление.РезультатыВыполненияЗаявокКабинетСотрудника.Выполнена") Тогда
		
		Если РезультатВыполненияСвязаннойЗаявки = ПредопределенноеЗначение("Перечисление.РезультатыВыполненияЗаявокКабинетСотрудника.Отклонена") Тогда
			ПоказатьПредупреждение(, СообщениеСвязаннаяЗаявкаОтклонена);
			Возврат Ложь;
		КонецЕсли;
		
		Если Объект.ТипОбъекта <> ПредопределенноеЗначение("Перечисление.ТипыОбъектовИнтеграцияУправлениеПерсоналом.ОтменаЗаявки") Тогда
			Если ДоступенРасширенныйФункционал И Не ЗначениеЗаполнено(Объект.БанковскийСчет) Тогда
				
				ТекстОшибки = НСтр("ru = 'Отсутствует выбранный банковский счет, создайте новый или выберите существующий'");
				ТекстСообщения = НСтр("ru = 'Не выполнены все действия по заявке.'");
				ТекстПредупреждения = СтрШаблон("%1%2%3", ТекстСообщения, Символы.ПС, ТекстОшибки);
				ИнформированиеПользователяКлиент.Предупредить(ТекстПредупреждения);
				Возврат Ложь;
				
			КонецЕсли;
			
			Если ДоступенРасширенныйФункционал
				И Не СпособВыплатыЗарплатыЗаполнен(Объект.Сотрудник, Объект.БанковскийСчет) Тогда
				
				ТекстОшибки = НСтр("ru = 'У сотрудника не указан выбранный банковский счет в качестве места выплаты зарплаты.'");
				ПодробноеПредставлениеОшибки =
					НСтр("ru = 'У сотрудника не указан выбранный банковский счет в качестве места выплаты зарплаты.
					|Измените способ выплаты зарплаты, указав созданный банковский счет.'");
				ТекстСообщения = НСтр("ru = 'Не выполнены все действия по заявке.'");
				ТекстПредупреждения = СтрШаблон("%1%2%3", ТекстСообщения, Символы.ПС, ТекстОшибки);
				ИнформированиеПользователяКлиент.Предупредить(ТекстПредупреждения, ПодробноеПредставлениеОшибки);
				Возврат Ложь;
				
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли РезультатВыполненияЗаявки = ПредопределенноеЗначение("Перечисление.РезультатыВыполненияЗаявокКабинетСотрудника.Отклонена") Тогда
		
		Если РезультатВыполненияСвязаннойЗаявки = ПредопределенноеЗначение("Перечисление.РезультатыВыполненияЗаявокКабинетСотрудника.Выполнена") Тогда
			ПоказатьПредупреждение(, СообщениеСвязаннаяЗаявкаВыполнена);
			Возврат Ложь;
		КонецЕсли;
		
		Если ПустаяСтрока(Объект.ОтветПоЗаявке) Тогда
			ТекстСообщения = НСтр("ru = 'Необходимо указать причину, по которой заявка отклоняется.'");
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения,, "ОтветПоЗаявке", "Объект");
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервереБезКонтекста
Функция СпособВыплатыЗарплатыЗаполнен(Сотрудник, БанковскийСчет)
	
