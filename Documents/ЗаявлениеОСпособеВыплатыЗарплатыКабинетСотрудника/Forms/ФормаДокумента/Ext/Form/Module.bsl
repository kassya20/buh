&НаКлиенте
Процедура СоздатьБанковскийСчет(Команда)
	
	Банк		= ?(РеквизитыБанка = Неопределено, Неопределено, РеквизитыБанка.Ссылка);
	НомерСчета	= Объект.НомерСчета;
	Владелец	= Объект.ФизическоеЛицо;
	
	СуществующийБанковскийСчет = БанковскийСчет(Банк, НомерСчета, Владелец);
	Если Не ЗначениеЗаполнено(СуществующийБанковскийСчет) Тогда
		ПараметрыЗаполнения = Новый Структура("Банк, НомерСчета, Владелец", Банк, НомерСчета, Владелец);
		ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ПараметрыЗаполнения);
	Иначе
		ПараметрыФормы = Новый Структура("Ключ", СуществующийБанковскийСчет);
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьБанковскийСчетЗавершение", ЭтотОбъект);
	
	ЗаявкиСотрудниковФормыКлиент.ОткрытьФормуБанковскогоСчета(ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьСпособВыплатыЗарплаты(Команда)
	
	ПараметрыФормы = Новый Структура("Ключ", Объект.Сотрудник);
	ОписаниеОповещения = Новый ОписаниеОповещения("ИзменитьСпособВыплатыЗарплатыЗавершение", ЭтотОбъект);
	ФормаСотрудника = ОткрытьФорму("Справочник.Сотрудники.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект, УникальныйИдентификатор,,, ОписаниеОповещения);
	
	СотрудникиКлиент.ОткрытьДополнительнуюФорму(
		СотрудникиКлиентСервер.ОписаниеДополнительнойФормы("Справочник.Сотрудники.Форма.ВыплатаЗарплаты"),
		ФормаСотрудника,
		Истина,,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

