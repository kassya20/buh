	// Конец ИнтернетПоддержкаПользователей.Новости.Подключаемый_ПоказатьНовостиТребующиеПрочтенияПриОткрытии

	ОбработкаНовостейКлиент.КонтекстныеНовости_ПоказатьНовостиТребующиеПрочтенияПриОткрытии(ЭтотОбъект, ИдентификаторыСобытийПриОткрытии);

КонецПроцедуры

#Область КассовыеЧекиПодотчетныхЛиц

&НаСервереБезКонтекста
Функция ОписаниеДокументаДляЗагрузкиКассовыхЧековПодотчетныхЛиц()
	
	ОписаниеДокумента = УчетКассовыхЧековПодотчетныхЛиц.НовыйОписаниеДокумента(ОписаниеФормыДляЗагрузкиКассовыхЧековПодотчетныхЛиц());
	ОписаниеДокумента.Номенклатура               = Истина;
	ОписаниеДокумента.Поставщик                  = Истина;
	Если ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		ШаблонСообщения = НСтр("ru = '<a href = ""%1""> Загрузить чеки</a>'");
		ОписаниеДокумента.ДополнительныйТекстБаннера = СтрШаблон(
					ШаблонСообщения,
					"#ЗагрузитьЧекиМК");
	Иначе
		ОписаниеДокумента.ДополнительныйТекстБаннера = НСтр("ru='Загрузить чеки можно на закладке ""Товары"" или ""Прочее"".'");
	КонецЕсли;
	
	Возврат ОписаниеДокумента;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОписаниеФормыДляЗагрузкиКассовыхЧековПодотчетныхЛиц()
	
	ОписаниеФормы = УчетКассовыхЧековПодотчетныхЛицКлиентСервер.НовыйОписаниеФормы();
	ОписаниеФормы.КнопкиЗагрузитьЧеки.Добавить("ТоварыЗагрузитьЧеки");
	ОписаниеФормы.КнопкиЗагрузитьЧеки.Добавить("ПрочееЗагрузитьЧеки");
	Возврат ОписаниеФормы;
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_ОбновитьЧекиКЗагрузке()
	
	// Описан в ОписаниеФормыДляЗагрузкиКассовыхЧековПодотчетныхЛиц
	// Подключается в УчетКассовыхЧековПодотчетныхЛицКлиент.ПодключитьОбновлениеЧековКЗагрузке
	
	УчетКассовыхЧековПодотчетныхЛицКлиент.ОбновитьЧекиКЗагрузке(
		ЭтотОбъект,
		ОписаниеФормыДляЗагрузкиКассовыхЧековПодотчетныхЛиц());
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьЗагрузкуКассовыхЧеков(ИмяСписка)
	
	Если МобильныйКлиентБПКлиент.ДоступноСканированиеШтрихкодов() Тогда
		ДопПараметры = Новый Структура("ИмяСписка", ИмяСписка);
		МобильныйКлиентБПКлиент.СканироватьШтрихкодЧекаКамерой(
			Новый ОписаниеОповещения("ОбработатьОтветСканироватьШтрихкодЧекаКамерой", ЭтотОбъект, ДопПараметры));
	Иначе
		НачатьПроверкуСообщенийСканераЧеков();
		
		УчетКассовыхЧековПодотчетныхЛицКлиент.НачатьЗагрузкуВДокумент(
			ЭтотОбъект,
			Объект.ФизЛицо,
			ОписаниеФормыДляЗагрузкиКассовыхЧековПодотчетныхЛиц(),
			Новый ОписаниеОповещения(
				"ЗаполнитьСодержимымКассовыхЧеков", 
				ЭтотОбъект, 
				Новый Структура("ИмяСписка, СуммаВключаетНДС", ИмяСписка, Объект.СуммаВключаетНДС)));
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура НачатьПроверкуСообщенийСканераЧеков()
	
	ВыполнитьАсинхронно = Ложь;
	ПроверятьТаймаут = Ложь;
	РегистрыСведений.МобильноеПриложениеСканированиеЧеков.НачатьПроверкуСообщений(
		ВыполнитьАсинхронно,
		ПроверятьТаймаут);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСодержимымКассовыхЧеков(АдресСодержимоеЧеков, ДополнительныеПараметры) Экспорт // обработчик оповещения
	
	ЗаполнитьСодержимымКассовыхЧековНаСервере(
		АдресСодержимоеЧеков,
		ДополнительныеПараметры.ИмяСписка,
		ДополнительныеПараметры.СуммаВключаетНДС);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСодержимымКассовыхЧековНаСервере(АдресСодержимоеЧеков, ИмяСписка, СуммаВключаетНДС)
	
	ДобавленныеСтроки = УчетКассовыхЧековПодотчетныхЛиц.ДействияПоЗаполнениюНаСервере(
		ЭтотОбъект,
		АдресСодержимоеЧеков,
		ИмяСписка,
		СуммаВключаетНДС,
		ОписаниеДокументаДляЗагрузкиКассовыхЧековПодотчетныхЛиц());
		
	ЗаполнитьСчетаУчета(ДобавленныеСтроки, ИмяСписка);
	ЗаполнитьПризнакМалоценка(Объект.Товары, Объект.Организация, Объект.Дата);
	ЗаполнитьАналитикиУчета(ДобавленныеСтроки, ИмяСписка);
	
	ОбновитьИтоги(ЭтотОбъект);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСчетаУчета(ДобавленныеСтроки, ИмяТаблицы)

	Если ИмяТаблицы <> "Товары" Тогда
		СтрокиДляЗаполненияСчетовУчета = ДобавленныеСтроки;
	Иначе
		// Счета зависят от номенклатуры, поэтому заполнять для строк без номенклатуры заведомо бессмысленно:
		// они будут определены заново при заполнении номенклатуры
		СтрокиДляЗаполненияСчетовУчета = Новый Массив;
		Для Каждого ДобавленнаяСтрока Из ДобавленныеСтроки Цикл
			Если Не ЗначениеЗаполнено(ДобавленнаяСтрока.Номенклатура) Тогда
				Продолжить;
			КонецЕсли;
			СтрокиДляЗаполненияСчетовУчета.Добавить(ДобавленнаяСтрока);
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокиДляЗаполненияСчетовУчета) Тогда
		Возврат;
	КонецЕсли;
	
	СчетаУчетаВДокументах.ЗаполнитьСтроки(СтрокиДляЗаполненияСчетовУчета, ИмяТаблицы, Объект, Документы.АвансовыйОтчет);
	
	Если ИмяТаблицы = "Прочее" Тогда
		
		Для Каждого Строка Из СтрокиДляЗаполненияСчетовУчета Цикл
			Если Строка.Свойство("СчетЗатрат") И ЗначениеЗаполнено(Строка.СчетЗатрат) Тогда
				БухгалтерскийУчетКлиентСервер.УстановитьСвойстваСубконтоСтрокиПриИзмененииСчета(
				ЭтотОбъект,
				Строка,
				АвансовыйОтчетФормыКлиентСервер.ПараметрыУстановкиСвойствСубконтоТаблицы(ЭтотОбъект, "Прочее", , Истина));
			КонецЕсли;
			
			Если Строка.Свойство("СчетЗатратНУ") И ЗначениеЗаполнено(Строка.СчетЗатратНУ) Тогда
				БухгалтерскийУчетКлиентСервер.УстановитьСвойстваСубконтоСтрокиПриИзмененииСчета(
				ЭтотОбъект,
				Строка,
				АвансовыйОтчетФормыКлиентСервер.ПараметрыУстановкиСвойствСубконтоТаблицы(ЭтотОбъект, "Прочее", "НУ", Истина));
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАналитикиУчета(ДобавленныеСтроки, ИмяТаблицы)
	
	Если ИмяТаблицы <> "Товары" Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Строка Из ДобавленныеСтроки Цикл
		ЗаполнитьДобавленныеКолонкиСтрокиАналитикиУчета(Строка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучениеДанныхЧековЗагруженныхАппаратнымСканером(Результат)
	
	Если Результат.АдресХранилища <> Неопределено Тогда
		АдресСодержимоеЧеков = Результат.АдресХранилища;
		ЗаполнитьСодержимымКассовыхЧековНаСервере(АдресСодержимоеЧеков, Результат.ИмяСписка, Результат.СуммаВключаетНДС);
		//В МК верстка отличается: вместо страниц группы
		Если Не МобильныйКлиентБПКлиент.ЭтоМобильныйКлиент() Тогда
			Если Результат.ИмяСписка = "Товары" Тогда
				Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаТовары;
			Иначе
				Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПрочее;
			КонецЕсли;
		КонецЕсли;
		Если Элементы.ГруппаБаннерПодключенАппаратныйСканер.Видимость = Истина Тогда
			УчетКассовыхЧековПодотчетныхЛицКлиент.СкрытьБаннерПодключенАппаратныйСканер(ЭтотОбъект);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоставщикАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка, ТекущиеДанныеСтроки)
	
	Если ЗначениеЗаполнено(ТекущиеДанныеСтроки.КассовыйЧек) И Не ЗначениеЗаполнено(ТекущиеДанныеСтроки.Поставщик)
		И Не ЗначениеЗаполнено(ТекущиеДанныеСтроки.ПоставщикИНН) Тогда
		
		ЗаполнитьСведенияПоставщикаПоКассовымЧекам(Объект[ПолучитьИмяТекущейТабличнойЧасти()]);
	КонецЕсли;
	
	ПараметрыПроцедуры = УчетКассовыхЧековПодотчетныхЛицКлиент.ПараметрыАвтоПодбораПоставщикаНовый();
	ПараметрыПроцедуры.Элемент = Элемент;
	ПараметрыПроцедуры.Текст = Текст;
	ПараметрыПроцедуры.ПараметрыПолученияДанных = ПараметрыПолученияДанных;
	ПараметрыПроцедуры.Ожидание = Ожидание;
	ПараметрыПроцедуры.Поставщик = ТекущиеДанныеСтроки.Поставщик;
	ПараметрыПроцедуры.ПоставщикНаименование = ТекущиеДанныеСтроки.ПоставщикНаименование;
	ПараметрыПроцедуры.ПоставщикИНН = ТекущиеДанныеСтроки.ПоставщикИНН;
	
	УчетКассовыхЧековПодотчетныхЛицКлиент.ПоставщикАвтоПодбор(ДанныеВыбора, СтандартнаяОбработка, ПараметрыПроцедуры);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСведенияПоставщикаПоКассовымЧекам(ТекущаяТабличнаяЧасть)
	
	КассовыеЧеки = Новый Массив;
	Для Каждого Строка Из ТекущаяТабличнаяЧасть Цикл
		Если ЗначениеЗаполнено(Строка.КассовыйЧек) И КассовыеЧеки.Найти(Строка.КассовыйЧек) = Неопределено Тогда
			КассовыеЧеки.Добавить(Строка.КассовыйЧек);
		КонецЕсли;
	КонецЦикла;
	
	СведенияЧеков = УчетКассовыхЧековПодотчетныхЛицВызовСервера.СведенияПоставщиковКассовыхЧеков(КассовыеЧеки);
	
	Для Каждого Строка Из ТекущаяТабличнаяЧасть Цикл
		Если Не ЗначениеЗаполнено(Строка.КассовыйЧек) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаписьСведения = СведенияЧеков.Получить(Строка.КассовыйЧек);
		Строка.ПоставщикНаименование = ЗаписьСведения.Наименование;
		Строка.ПоставщикИНН = ЗаписьСведения.ИНН;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ИспользуетсяЗагрузкаКассовыхЧеков(ТекущаяТабличнаяЧасть)
	
	Для Каждого СтрокаСписка Из ТекущаяТабличнаяЧасть Цикл
		Если ЗначениеЗаполнено(СтрокаСписка.КассовыйЧек) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
КонецФункции

&НаСервере
Процедура ЗаполнитьПоставщикаКассовыхЧеков(ИмяСписка, ВыбранноеЗначение)
	
	ПоставщикИНН = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "ИНН");
	Если ПустаяСтрока(ПоставщикИНН) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаТовары Из Объект[ИмяСписка] Цикл
		
		Если ЗначениеЗаполнено(СтрокаТовары.КассовыйЧек) И Не ЗначениеЗаполнено(СтрокаТовары.Поставщик)
			И СтрокаТовары.ПоставщикИНН = ПоставщикИНН Тогда
			
			СтрокаТовары.Поставщик = ВыбранноеЗначение;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область БаннерУчетБилетовИПнаОСНО

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьБаннераУчетБилетовИПнаОСНО(Форма)
	
	Элементы = Форма.Элементы;
	Объект   = Форма.Объект;
	
	Элементы.ГруппаБаннерУчетБилетовИПнаОСНО.Видимость = Объект.Билеты.Количество() > 0
		И Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаБилеты
		И ВидимостьБаннераУчетБилетовИПнаОСНО(
			Объект.Организация,
			Объект.Дата);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ВидимостьБаннераУчетБилетовИПнаОСНО(Организация, Период)
	
	Возврат УчетДоходовИРасходовПредпринимателя.ВидимостьБаннераУчетБилетовИПнаОСНО(
		Организация,
		Период);
	
КонецФункции

&НаСервере
Процедура СкрытьБаннерУчетБилетовИПнаОСНО()

	УчетДоходовИРасходовПредпринимателя.СохранитьНастройкуБаннераУчетБилетовИПнаОСНО(Ложь, Объект.Организация);
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры 

#КонецОбласти

&НаКлиенте
Процедура ОткрытьФормуРедактированияСтроки(ВыбранноеЗначение)

	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДанныеСтроки = Объект.Товары.НайтиПоИдентификатору(ВыбранноеЗначение);
			
	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("ТолькоПросмотр",       ТолькоПросмотр);
	ПараметрыФормы.Вставить("ДатаДокумента",        Объект.Дата);
	ПараметрыФормы.Вставить("Организация",          Объект.Организация);
	
	ПараметрыФормы.Вставить("СчетЗатрат",          ДанныеСтроки.СчетЗатрат);
	ПараметрыФормы.Вставить("ПодразделениеЗатрат", ДанныеСтроки.ПодразделениеЗатрат);
	ПараметрыФормы.Вставить("Субконто1",           ДанныеСтроки.Субконто1);
	ПараметрыФормы.Вставить("Субконто2",           ДанныеСтроки.Субконто2);
	ПараметрыФормы.Вставить("Субконто3",           ДанныеСтроки.Субконто3);
	ПараметрыФормы.Вставить("Номенклатура",        ДанныеСтроки.Номенклатура);
	ПараметрыФормы.Вставить("Контрагент",          Неопределено);
	ПараметрыФормы.Вставить("ДоговорКонтрагента",  Неопределено);
	
	ОткрытьФорму("ОбщаяФорма.РедактированиеСчетаЗатрат", ПараметрыФормы, ЭтотОбъект);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПризнакМалоценка(Товары, Организация, Период)
	
	Для Каждого СтрокаТаблицы Из Товары Цикл
		СтрокаТаблицы.Малоценка = ПрименяетсяМалоценка И (СтрокаТаблицы.СчетУчета = ПланыСчетов.Хозрасчетный.ПриобретениеМалоценногоОборудованияИЗапасов);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьДобавленныеКолонкиСтрокиАналитикиУчета(ДанныеСтроки)

	АналитикаУчетаТекст 	= "";
	АналитикаУчетаЗаполнена = Ложь;

	ИспользоватьОднуНоменклатурнуюГруппу = БухгалтерскийУчетВызовСервераПовтИсп.ИспользоватьОднуНоменклатурнуюГруппу();
	СтроковыеПредставленияСубконто = Новый Структура();
	
	Если ДанныеСтроки.Свойство("СчетЗатрат") Тогда
		Если ЗначениеЗаполнено(ДанныеСтроки.СчетЗатрат) Тогда
			АналитикаУчетаЗаполнена = Истина;
			СвойстваСчета 		    = БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(ДанныеСтроки.СчетЗатрат);
			АналитикаУчетаТекст     = АналитикаУчетаТекст + ", " + СвойстваСчета.Код;
			
			Если СвойстваСчета.УчетПоПодразделениям Тогда
				Если ЗначениеЗаполнено(ДанныеСтроки.ПодразделениеЗатрат) Тогда
					ТекстСтроки 		= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеСтроки.ПодразделениеЗатрат, "Наименование");
					АналитикаУчетаТекст = АналитикаУчетаТекст + ", " + ТекстСтроки;
				Иначе
					АналитикаУчетаТекст = АналитикаУчетаТекст + ", <...>";
				КонецЕсли;
			КонецЕсли;
			
			Для Н = 1 По СвойстваСчета.КоличествоСубконто Цикл
				ЗначениеСубконто = ДанныеСтроки["Субконто" + Н];
				Если ЗначениеЗаполнено(ЗначениеСубконто) Тогда
					ПредставлениеСубконто = "";
					ТипСубконто = ТипЗнч(ЗначениеСубконто);
					Если ИспользоватьОднуНоменклатурнуюГруппу И ТипСубконто = Тип("СправочникСсылка.НоменклатурныеГруппы") Тогда
						Продолжить;
					ИначеЕсли Справочники.ТипВсеСсылки().СодержитТип(ТипСубконто) Тогда
						ПредставлениеСубконто = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗначениеСубконто, "Представление");
					ИначеЕсли Документы.ТипВсеСсылки().СодержитТип(ТипСубконто) Тогда
						ПредставлениеСубконто = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗначениеСубконто, "Представление");
					Иначе
						ПредставлениеСубконто = Строка(ЗначениеСубконто);
					КонецЕсли;
					
					СтроковыеПредставленияСубконто.Вставить("ЗначениеСубконто" + Н, ЗначениеСубконто);
					СтроковыеПредставленияСубконто.Вставить("ПредставлениеСубконто" + Н, ПредставлениеСубконто);
					
					АналитикаУчетаТекст = АналитикаУчетаТекст + ", " + ПредставлениеСубконто;
				Иначе
					АналитикаУчетаТекст = АналитикаУчетаТекст + ", <...>";
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	Если АналитикаУчетаЗаполнена Тогда
		ДанныеСтроки.АналитикаУчета = Сред(АналитикаУчетаТекст, 3);
	КонецЕсли;
	ДанныеСтроки.АналитикаУчетаЗаполнена = АналитикаУчетаЗаполнена;

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораАналитикиУчетаНаКлиенте(ВыбранноеЗначение)

	ДанныеСтроки = Новый Структура("СчетЗатрат, Субконто1, Субконто2, Субконто3,
		|ПодразделениеЗатрат, АналитикаУчета, АналитикаУчетаЗаполнена");

	ЗаполнитьЗначенияСвойств(ДанныеСтроки, ВыбранноеЗначение);
	ЗаполнитьДобавленныеКолонкиСтрокиАналитикиУчета(ДанныеСтроки);
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, ДанныеСтроки);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСчетУчетаПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	ТекущиеДанные.Малоценка = ПрименяетсяМалоценка И ТекущиеДанные.СчетУчета = ПредопределенноеЗначение("ПланСчетов.Хозрасчетный.ПриобретениеМалоценногоОборудованияИЗапасов");
КонецПроцедуры

#Область БЭД

&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуЭДО(Команда)
	
	ЭлектронноеВзаимодействиеКлиент.ВыполнитьПодключаемуюКомандуЭДО(Команда, ЭтотОбъект, Объект);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбработчикОжиданияЭДО()

	ОбменСКонтрагентамиКлиент.ОбработчикОжиданияЭДО(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура СостояниеЭДОНажатие(Элемент, СтандартнаяОбработка)
	ОбменСКонтрагентамиКлиент.СостояниеЭДОНажатие_ФормаДокумента(ЭтотОбъект, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьСписокВыбораПрочееОтражениеВУСН(ПерезаполнитьНедоступныеЗначения = Ложь)
	
	Если Не (ПрименяетсяУСН И Не ПрименяетсяУСНДоходы) Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ВидОперации <> Перечисления.ВидыОперацийАвансовыйОтчет.ПокупкаОплатаПрочее Тогда
		Возврат;
	КонецЕсли;
	
	ПрименяетсяОсобыйНалоговыйРежим = УчетнаяПолитика.ПрименяетсяУСНПатент(Объект.Организация, Объект.Дата)
		Или УчетнаяПолитика.ПлательщикЕНВД(Объект.Организация, Объект.Дата);
	
	ДоступныеОтражения = Перечисления.ОтражениеВУСН.СписокВыбора(ПрименяетсяОсобыйНалоговыйРежим, Истина);
	
	СписокВыбора = Элементы.ПрочееОтражениеВУСН.СписокВыбора;
	СписокВыбора.Очистить();
	Для Каждого ЭлементОтражения Из ДоступныеОтражения Цикл
		СписокВыбора.Добавить(ЭлементОтражения.Значение, ЭлементОтражения.Представление);
	КонецЦикла;
	
	Если ПерезаполнитьНедоступныеЗначения Тогда
		
		Для Каждого СтрокаТаблицы Из Объект.Прочее Цикл
			Если ДоступныеОтражения.НайтиПоЗначению(СтрокаТаблицы.ОтражениевУСН) = Неопределено Тогда
				СтрокаТаблицы.ОтражениеВУСН = Перечисления.ОтражениеВУСН.Принимаются;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПараметрыСозданияНовогоДоговора(ИдСтроки)
	
	СтрокаТаблицы = Объект.ОплатаПоставщикам.НайтиПоИдентификатору(ИдСтроки);
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	ПараметрыДоговора = Новый Структура;
	ПараметрыДоговора.Вставить("Организация", Объект.Организация);
	ПараметрыДоговора.Вставить("Владелец", СтрокаТаблицы.Контрагент);
	ПараметрыДоговора.Вставить("ВидДоговора", РаботаСДоговорамиКонтрагентовБП.ВидДоговораПоОбъекту(ДокументОбъект));
	ПараметрыДоговора.Вставить("Дата", ?(ЗначениеЗаполнено(СтрокаТаблицы.ДатаВходящегоДокумента),
		СтрокаТаблицы.ДатаВходящегоДокумента, Объект.Дата));
	
	Возврат ПараметрыДоговора;
	
КонецФункции

&НаСервереБезКонтекста
Функция ОписаниеТипаРеквизитаСделка()
	
	Возврат Метаданные.Документы.АвансовыйОтчет.ТабличныеЧасти.ОплатаПоставщикам.Реквизиты.Сделка.Тип;
	
КонецФункции

#Область МобильныйКлиент

&НаСервере
Процедура МобильныйКлиентАдаптацияФормы()
	
	Если Не ОбщегоНазначения.ЭтоМобильныйКлиент() Тогда
		Возврат;
	КонецЕсли;
	
	МобильныйКлиентБПФормаОбъекта.НастроитьФорму(ЭтотОбъект);
	
	АдаптироватьМККоманднаяПанельФормы();
	АдаптироватьМКШапкаФормы();
	АдаптироватьМКСписокФормы();
	АдаптироватьМККонтекстСписокФормы();
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМККоманднаяПанельФормы()
	
	МобильныйКлиентБПФормаОбъекта.АдаптироватьМККоманднаяПанель(ЭтотОбъект);
	
	МобильныйКлиентБПФормаОбъекта.ПеренестиКомандыВМККомандыФормы(Элементы, Элементы.ГруппаКнопкиКоманднойПанели.ПодчиненныеЭлементы);
	МобильныйКлиентБПФормаОбъекта.ПеренестиКомандыВПодменюМКПоделиться(Элементы, Элементы.ПодменюПечать.ПодчиненныеЭлементы);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКШапкаФормы()
	
	МобильныйКлиентБПФормаОбъекта.АдаптироватьНомерДатаФормаДокумента(Элементы, Элементы.ГруппаНомерДата);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.ГруппаНомерДата);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.Организация);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.ФизЛицо);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.Склад);
	
	Элементы.ЦеныИВалюта.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
	Элементы.ЦеныИВалюта.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.ЦеныИВалюта);
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.ГруппаБаннерУчетБилетовИПнаОСНО);
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаВажное(Элементы, Элементы.ГруппаБаннерЧекиПодотчетныхЛиц);
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаПрочее(Элементы,
		Элементы.ПодразделениеОрганизации);
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаПрочее(Элементы,
		Элементы.ГруппаСостояниеЭДО);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаПрочее(Элементы,
		Элементы.НазначениеАванса);
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаПрочее(Элементы,
		Элементы.ГруппаПриложениеСФоном);
	Элементы.ГруппаПриложениеСФоном.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	Элементы.ГруппаКомментарий.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаПрочее(Элементы,
		Элементы.ГруппаКомментарий);
		
	Элементы.ВалютаДокументаПредыдущийАванс.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	Элементы.ВалютаДокументаПредыдущийАванс.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
	Элементы.ВалютаДокументаПредыдущийАванс.РастягиватьПоГоризонтали = Истина;
	Элементы.ВалютаДокументаПредыдущийАванс.Ширина = 0;
	
	Элементы.ТипИтогаОстаткаАвансов.РастягиватьПоГоризонтали = Истина;
	Элементы.ТипИтогаОстаткаАвансов.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Авто;
	Элементы.ТипИтогаОстаткаАвансов.ГоризонтальноеПоложениеВГруппе=ГоризонтальноеПоложениеЭлемента.Авто;
	
	Элементы.ГруппаИтоги.ЦветФона = ЦветаСтиля.ЦветФонаФормы;
	Элементы.ГруппаИтогиПредыдущиеАвансы.ЦветФона = ЦветаСтиля.ЦветФонаФормы;
	Элементы.ГруппаИтогиПредыдущиеАвансы.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	Элементы.ГруппаИтогиПредыдущиеАвансы.Объединенная = Истина;
	
	Элементы.ГруппаИтогиПоОтчету.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Элементы.ГруппаИтогиПоОтчету.Объединенная = Истина;
	Элементы.ТипИтогаПоОтчету.Ширина = 0;
	Элементы.ТипИтогаПоОтчету.РастягиватьПоГоризонтали = Истина;
	Элементы.ТипИтогаПоОтчету.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Авто;
	Элементы.ТипИтогаПоОтчету.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Авто;
	
	Элементы.НадписьВсегоПоОтчету.Ширина = 0;
	Элементы.НадписьВсегоПоОтчету.РастягиватьПоГоризонтали = Истина;
	
	Элементы.ГруппаИтогиОстаток.ЦветФона = ЦветаСтиля.ЦветФонаФормы;
	Элементы.ГруппаИтогиОстаток.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	Элементы.ГруппаИтогиОстаток.Объединенная = Истина;
	Элементы.ГруппаИтоги.ГоризонтальноеПоложениеПодчиненных = ГоризонтальноеПоложениеЭлемента.Авто;
	Элементы.ГруппаИтоги.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Элементы.ГруппаИтоги.Объединенная = Ложь;
	
	МобильныйКлиентБПФормаОбъекта.ВстроитьЭлементФормыВГруппаМКФормаПодвал(Элементы, Элементы.ГруппаИтоги);
	
	МобильныйКлиентБПФормаОбъектаКлиентСервер.АдаптироватьЭлементыМКФормы(ЭтотОбъект);
	
	МобильныйКлиентБПФормаОбъекта.СкрытьПрочиеЭлементыФормы(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМККонтекстСписокФормы()
	
	МобильныйКлиентБПФормаОбъекта.АдаптироватьКонтекстноеМеню(ЭтотОбъект, "", "ВыданныеАвансы");
	МобильныйКлиентБПФормаОбъекта.АдаптироватьКонтекстноеМеню(ЭтотОбъект, "", "Товары");
	МобильныйКлиентБПФормаОбъекта.АдаптироватьКонтекстноеМеню(ЭтотОбъект, "", "ВозвратнаяТара");
	МобильныйКлиентБПФормаОбъекта.АдаптироватьКонтекстноеМеню(ЭтотОбъект, "", "ОплатаПоставщикам");
	МобильныйКлиентБПФормаОбъекта.АдаптироватьКонтекстноеМеню(ЭтотОбъект, "", "Билеты");
	МобильныйКлиентБПФормаОбъекта.АдаптироватьКонтекстноеМеню(ЭтотОбъект, "", "Прочее");
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКСписокФормы()
	
	ОписаниеФормы = ОписаниеФормыДляЗагрузкиКассовыхЧековПодотчетныхЛиц();
	Для Каждого ИмяКнопкаЗагрузить Из ОписаниеФормы.КнопкиЗагрузитьЧеки Цикл
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			ИмяКнопкаЗагрузить,
			"Заголовок",
			НСтр("ru = 'Сканировать QR чека'"));
	КонецЦикла;

	АдаптироватьМКСписокФормыВыданныеАвансы();
	АдаптироватьМКСписокФормыТовары();
	АдаптироватьМКСписокФормыВозвратнаяТара();
	АдаптироватьМКСписокФормыОплатаПоставщикам();
	АдаптироватьМКСписокФормыБилеты();
	АдаптироватьМКСписокФормыПрочее();
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьМКСписокФормыВыданныеАвансы()
	
	КомандыПоля = МобильныйКлиентБПФормаОбъекта.НовыйОписаниеКомандТабличноеПолеФормы();
	КомандыПоля.ИмяКомандыДобавитьСтроку = "ВыданныеАвансыДобавить";
	
	Элементы.ВыданныеАвансыНомерСтроки.Ширина = 0;
	
	ОписаниеГруппыПоля = МобильныйКлиентБПФормаОбъекта.НовыйОписаниеГруппыТабличноеПолеФормы();
	ОписаниеГруппыПоля.ЭлементГруппаПоля = Элементы.ГруппаВыданныеАвансы;
	
	ОписаниеКолонокПоля = МобильныйКлиентБПФормаОбъекта.НовыйОписаниеКолонокПоляТабличноеПолеФормы();
	ОписаниеКолонокПоля.КолонкаНомерСтроки = "ВыданныеАвансыНомерСтроки";
	ОписаниеКолонокПоля.ВажныеКолонки = 
		"ВыданныеАвансыНомерСтроки,ВыданныеАвансыДокументАванса";
	ОписаниеКолонокПоля.УстановитьВерхниеЗаголовки = 
		"ВыданныеАвансыДокументАванса";
	ОписаниеКолонокПоля.СкрытьКолонки = "ВыданныеАвансыОтступ";
	
	МобильныйКлиентБПФормаОбъекта.ПодготовитьТабличноеПолеФормыДокумента(ЭтотОбъект,
		Элементы.ВыданныеАвансы, ОписаниеГруппыПоля, КомандыПоля, ОписаниеКолонокПоля);
	
