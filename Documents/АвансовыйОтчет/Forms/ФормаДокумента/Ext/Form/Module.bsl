&НаСервере
Процедура РассчитатьАвансыНаСервере()
	
	Если Не ЗначениеЗаполнено(Объект.Организация)
		Или Не ЗначениеЗаполнено(Объект.ФизЛицо)
		Или Объект.ВыданныеАвансы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",        Объект.Ссылка);
	Запрос.УстановитьПараметр("ФизЛицо",       Объект.ФизЛицо);
	Запрос.УстановитьПараметр("Организация",   Объект.Организация);
	Запрос.УстановитьПараметр("Валюта",        Объект.ВалютаДокумента);
	Запрос.УстановитьПараметр("Подразделение", Объект.ПодразделениеОрганизации);
	Запрос.УстановитьПараметр("Авансы",
		Объект.ВыданныеАвансы.Выгрузить(, "ДокументАванса").ВыгрузитьКолонку("ДокументАванса"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВыдачаДенежныхДокументов.Ссылка КАК ДокументАванса,
	|	ВыдачаДенежныхДокументов.Дата КАК ДокументАвансаДата,
	|	ВыдачаДенежныхДокументов.СуммаДокумента КАК СуммаАванса
	|ПОМЕСТИТЬ ВТ_Авансы
	|ИЗ
	|	Документ.ВыдачаДенежныхДокументов КАК ВыдачаДенежныхДокументов
	|ГДЕ
	|	ВыдачаДенежныхДокументов.Ссылка В(&Авансы)
	|	И ВыдачаДенежныхДокументов.Контрагент = &ФизЛицо
	|	И ВыдачаДенежныхДокументов.Организация = &Организация
	|	И ВыдачаДенежныхДокументов.ВалютаДокумента = &Валюта
	|	И ВыдачаДенежныхДокументов.ПодразделениеОрганизации = &Подразделение
	|	И ВыдачаДенежныхДокументов.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РасходныйКассовыйОрдер.Ссылка,
	|	РасходныйКассовыйОрдер.Дата,
	|	РасходныйКассовыйОрдер.СуммаДокумента
	|ИЗ
	|	Документ.РасходныйКассовыйОрдер КАК РасходныйКассовыйОрдер
	|ГДЕ
	|	РасходныйКассовыйОрдер.Ссылка В(&Авансы)
	|	И РасходныйКассовыйОрдер.Контрагент = &ФизЛицо
	|	И РасходныйКассовыйОрдер.Организация = &Организация
	|	И РасходныйКассовыйОрдер.ВалютаДокумента = &Валюта
	|	И РасходныйКассовыйОрдер.ПодразделениеОрганизации = &Подразделение
	|	И РасходныйКассовыйОрдер.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СписаниеСРасчетногоСчета.Ссылка,
	|	СписаниеСРасчетногоСчета.Дата,
	|	СписаниеСРасчетногоСчета.СуммаДокумента
	|ИЗ
	|	Документ.СписаниеСРасчетногоСчета КАК СписаниеСРасчетногоСчета
	|ГДЕ
	|	СписаниеСРасчетногоСчета.Ссылка В(&Авансы)
	|	И СписаниеСРасчетногоСчета.Контрагент = &ФизЛицо
	|	И СписаниеСРасчетногоСчета.Организация = &Организация
	|	И СписаниеСРасчетногоСчета.ВалютаДокумента = &Валюта
	|	И СписаниеСРасчетногоСчета.ПодразделениеОрганизации = &Подразделение
	|	И СписаниеСРасчетногоСчета.Проведен
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументАванса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АвансовыйОтчетВыданныеАвансы.ДокументАванса КАК ДокументАванса,
	|	СУММА(ВЫБОР
	|			КОГДА АвансовыйОтчетВыданныеАвансы.СуммаИзрасходованногоАванса > 0
	|				ТОГДА АвансовыйОтчетВыданныеАвансы.СуммаИзрасходованногоАванса
	|			ИНАЧЕ АвансовыйОтчетВыданныеАвансы.ДокументАванса.СуммаДокумента
	|		КОНЕЦ) КАК СуммаИзрасходованногоАванса
	|ПОМЕСТИТЬ ВТ_Отчеты
	|ИЗ
	|	Документ.АвансовыйОтчет.ВыданныеАвансы КАК АвансовыйОтчетВыданныеАвансы
	|ГДЕ
	|	АвансовыйОтчетВыданныеАвансы.ДокументАванса В(&Авансы)
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка <> &Ссылка
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.ФизЛицо = &ФизЛицо
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.Организация = &Организация
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.ВалютаДокумента = &Валюта
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.ПодразделениеОрганизации = &Подразделение
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	АвансовыйОтчетВыданныеАвансы.ДокументАванса
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументАванса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Авансы.ДокументАванса КАК ДокументАванса,
	|	ВТ_Авансы.СуммаАванса - ЕСТЬNULL(ВТ_Отчеты.СуммаИзрасходованногоАванса, 0) КАК СуммаИзрасходованногоАванса
	|ИЗ
	|	ВТ_Авансы КАК ВТ_Авансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Отчеты КАК ВТ_Отчеты
	|		ПО ВТ_Авансы.ДокументАванса = ВТ_Отчеты.ДокументАванса
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_Авансы.ДокументАвансаДата";
	
	ТаблицаАвансов = Запрос.Выполнить().Выгрузить();
	
	Если ИтогПоОтчету > 0 Тогда
		СуммаРаспределения = ИтогПоОтчету;
	Иначе
		СуммаРаспределения = Объект.ВыданныеАвансы.Итог("СуммаАванса");
	КонецЕсли;
	
	ТаблицаАвансов.Индексы.Добавить("ДокументАванса");
	
	Для Каждого СтрокаАванса Из ТаблицаАвансов Цикл
		Если СтрокаАванса.СуммаИзрасходованногоАванса <= СуммаРаспределения Тогда
			СуммаРаспределения = СуммаРаспределения - СтрокаАванса.СуммаИзрасходованногоАванса;
		Иначе
			СтрокаАванса.СуммаИзрасходованногоАванса = СуммаРаспределения;
			СуммаРаспределения = 0;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ВыданныйАванс Из Объект.ВыданныеАвансы Цикл
		СтрокаАванса = ТаблицаАвансов.Найти(ВыданныйАванс.ДокументАванса, "ДокументАванса");
		Если СтрокаАванса <> Неопределено Тогда
			ВыданныйАванс.СуммаИзрасходованногоАванса = СтрокаАванса.СуммаИзрасходованногоАванса;
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	
КонецПроцедуры

&НаСервере
Функция ИнициализироватьЗапрос()
	
	Если Не ЗначениеЗаполнено(Объект.ФизЛицо) Или Не ЗначениеЗаполнено(Объект.Организация) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДокументСуществует = ЗначениеЗаполнено(Объект.Ссылка);
	
	ВалютаРегламентированногоУчета = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	ДокументВалютный = Объект.ВалютаДокумента <> ВалютаРегламентированногоУчета;
	
	СчетаДт = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПланыСчетов.Хозрасчетный.РасчетыСПодотчетнымиЛицами_);
	СчетаКт = Новый Массив;
	СчетаКт.Добавить(ПланыСчетов.Хозрасчетный.Касса);          // 50
	СчетаКт.Добавить(ПланыСчетов.Хозрасчетный.РасчетныеСчета); // 51
	СчетаКт.Добавить(ПланыСчетов.Хозрасчетный.ВалютныеСчета);  // 52
	СчетаКт.Добавить(ПланыСчетов.Хозрасчетный.ЦифровойРубль);  // 53
	// Для учета операций по корпоративным картам
	СчетаКт.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеСпециальныеСчета);    // 55.04
	СчетаКт.Добавить(ПланыСчетов.Хозрасчетный.ПрочиеСпециальныеСчетаВал); // 55.24
	
	// Счета кассовых операций не по основной кассе.
	КтИсключения = Новый Массив;
	КтИсключения.Добавить(ПланыСчетов.Хозрасчетный.ОперационнаяКасса);     // 50.02
	КтИсключения.Добавить(ПланыСчетов.Хозрасчетный.КассаПлатежногоАгента); // 50.04
	
	ТекДата = ТекущаяДатаСеанса();
	ТекВремя = ТекДата - НачалоДня(ТекДата);
	
	Если ЗначениеЗаполнено(Объект.Дата) Тогда
		ДатаОстатка = Объект.Дата;
	ИначеЕсли ДокументСуществует Тогда
		ДатаОстатка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "Дата");
	Иначе
		ДатаОстатка = ОбщегоНазначения.ТекущаяДатаПользователя();
	КонецЕсли;
	
	НачалоПериода = ДобавитьМесяц(НачалоДня(ДатаОстатка), -12);
	
	Если ДокументСуществует Тогда
		КонецПериода  = ДатаОстатка;
		МоментВремени = Новый МоментВремени(КонецПериода, Объект.Ссылка);
	Иначе
		КонецПериода = ДатаОстатка;
		Если ДатаОстатка = НачалоДня(ДатаОстатка) Тогда // у нового документа и у Рабочей даты время "нулевое"
			КонецПериода = ДатаОстатка + ТекВремя;
		КонецЕсли;
		МоментВремени = Новый МоментВремени(КонецПериода);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка",          Объект.Ссылка);
	Запрос.УстановитьПараметр("НачалоПериода",   НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",    КонецПериода);
	Запрос.УстановитьПараметр("МоментВремени",   МоментВремени);
	Запрос.УстановитьПараметр("Организация",     Объект.Организация);
	Запрос.УстановитьПараметр("ФизЛицо",         Объект.ФизЛицо);
	Запрос.УстановитьПараметр("ВалютаРеглУчета", ВалютаРегламентированногоУчета);
	Запрос.УстановитьПараметр("Валюта",          Объект.ВалютаДокумента);
	Запрос.УстановитьПараметр("Валютный",        ДокументВалютный);
	Запрос.УстановитьПараметр("СчетаДт",         СчетаДт);
	Запрос.УстановитьПараметр("СчетаКт",         СчетаКт);
	Запрос.УстановитьПараметр("КтИсключения",    КтИсключения);
	Запрос.УстановитьПараметр("Подразделение",   Объект.ПодразделениеОрганизации);
	Запрос.УстановитьПараметр("ПустоеПодразделение", Справочники.ПодразделенияОрганизаций.ПустаяСсылка());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Счет
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В ИЕРАРХИИ(&СчетаДт)
	|	И Хозрасчетный.Валютный = &Валютный
	|	И НЕ Хозрасчетный.ЗапретитьИспользоватьВПроводках
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Хозрасчетный.Ссылка КАК Счет
	|ИЗ
	|	ПланСчетов.Хозрасчетный КАК Хозрасчетный
	|ГДЕ
	|	Хозрасчетный.Ссылка В ИЕРАРХИИ(&СчетаКт)
	|	И НЕ Хозрасчетный.Ссылка В (&КТИсключения)
	|	И Хозрасчетный.Валютный = &Валютный
	|	И НЕ Хозрасчетный.ЗапретитьИспользоватьВПроводках";
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	Запрос.УстановитьПараметр("СчетаДт", ПакетЗапросов[0].Выгрузить().ВыгрузитьКолонку("Счет"));
	Запрос.УстановитьПараметр("СчетаКт", ПакетЗапросов[1].Выгрузить().ВыгрузитьКолонку("Счет"));
	
	Возврат Запрос;
	
КонецФункции

&НаСервере
Процедура ПолучитьОстаткиАвансов(Запрос = Неопределено)
	
	Если Запрос = Неопределено Тогда
		Запрос = ИнициализироватьЗапрос();
	КонецЕсли;
	
	Если Запрос = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.СуммаОстатокДт КАК СуммаОстатокДт,
	|	ХозрасчетныйОстатки.СуммаОстатокКт КАК СуммаОстатокКт,
	|	ХозрасчетныйОстатки.ВалютнаяСуммаОстатокДт КАК ВалютнаяСуммаОстатокДт,
	|	ХозрасчетныйОстатки.ВалютнаяСуммаОстатокКт КАК ВалютнаяСуммаОстатокКт
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&МоментВремени,
	|			Счет В (&СчетаДт),
	|			ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.РаботникиОрганизаций),
	|			Организация = &Организация
	|				И ЕСТЬNULL(Валюта, &ВалютаРеглУчета) = &Валюта
	|				И Субконто1 = &ФизЛицо) КАК ХозрасчетныйОстатки";
	
	Если БухгалтерскийУчетПереопределяемый.ВестиУчетПоПодразделениям() Тогда
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
		
		ПараметрыЗапроса = СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Источники[0].Источник.Параметры[3];
		ПараметрыЗапросаВыражения = Новый Массив;
		Если Не ПустаяСтрока(ПараметрыЗапроса.Выражение) Тогда
			ПараметрыЗапросаВыражения.Добавить(Строка(ПараметрыЗапроса.Выражение));
		КонецЕсли;
		
		ПараметрыЗапросаВыражения.Добавить("ЕСТЬNULL(Подразделение, &ПустоеПодразделение) = &Подразделение");
		ПараметрыЗапроса.Выражение = Новый ВыражениеСхемыЗапроса(
			СтрСоединить(ПараметрыЗапросаВыражения, Символы.ПС + Символы.Таб + "И "));
		ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	Выборка = Запрос.Выполнить().Выбрать();
	
	Перерасход = 0;
	Остаток    = 0;
	
	ВалютаРегламентированногоУчета = ОбщегоНазначенияБПВызовСервераПовтИсп.ПолучитьВалютуРегламентированногоУчета();
	
	Если Выборка.Следующий() Тогда
		Если Объект.ВалютаДокумента <> ВалютаРегламентированногоУчета Тогда
			Перерасход = Выборка.ВалютнаяСуммаОстатокКт;
			Остаток    = Выборка.ВалютнаяСуммаОстатокДт;
		Иначе
			Перерасход = Выборка.СуммаОстатокКт;
			Остаток    = Выборка.СуммаОстатокДт;
		КонецЕсли;
	КонецЕсли;
	
	ИтогоОстатокАвансов = 0;
	Если Перерасход <> 0 Тогда
		ИтогоОстатокАвансов = - Перерасход;
	ИначеЕсли Остаток <> 0 Тогда
		ИтогоОстатокАвансов = Остаток;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАвансыНаСервере()
	
	Объект.ВыданныеАвансы.Очистить();
	
	Запрос = ИнициализироватьЗапрос();
	ПолучитьОстаткиАвансов(Запрос);
	
	Если Запрос = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СуммаРаспределения = 0;
	Если ИтогПоОтчету > 0 Тогда
		СуммаРаспределения = ИтогПоОтчету;
	ИначеЕсли ИтогоОстатокАвансов > 0 Тогда
		СуммаРаспределения = ИтогоОстатокАвансов;
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Хозрасчетный.Регистратор КАК ДокументАванса,
	|	СУММА(ВЫБОР
	|			КОГДА &Валютный
	|				ТОГДА ВЫБОР
	|						КОГДА Хозрасчетный.Регистратор ССЫЛКА Документ.РасходныйКассовыйОрдер
	|							ТОГДА ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.РасходныйКассовыйОрдер).СуммаДокумента
	|						КОГДА Хозрасчетный.Регистратор ССЫЛКА Документ.СписаниеСРасчетногоСчета
	|							ТОГДА ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.СписаниеСРасчетногоСчета).СуммаДокумента
	|						КОГДА Хозрасчетный.Регистратор ССЫЛКА Документ.ВыдачаДенежныхДокументов
	|							ТОГДА ВЫРАЗИТЬ(Хозрасчетный.Регистратор КАК Документ.ВыдачаДенежныхДокументов).СуммаДокумента
	|					КОНЕЦ
	|			ИНАЧЕ Хозрасчетный.Сумма
	|		КОНЕЦ) КАК СуммаДокумента,
	|	Хозрасчетный.Период КАК ДокументАвансаДата,
	|	СУММА(ВЫБОР
	|			КОГДА &Валютный
	|				ТОГДА Хозрасчетный.ВалютнаяСуммаДт
	|			ИНАЧЕ Хозрасчетный.Сумма
	|		КОНЕЦ) КАК СуммаАванса
	|ПОМЕСТИТЬ ВТ_Авансы
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный КАК Хозрасчетный
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрБухгалтерии.Хозрасчетный.Субконто КАК ХозрасчетныйСубконто
	|		ПО Хозрасчетный.Регистратор = ХозрасчетныйСубконто.Регистратор
	|			И Хозрасчетный.Период = ХозрасчетныйСубконто.Период
	|			И Хозрасчетный.НомерСтроки = ХозрасчетныйСубконто.НомерСтроки
	|			И (ХозрасчетныйСубконто.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияБухгалтерии.Дебет))
	|			И (ХозрасчетныйСубконто.Вид = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ВидыСубконтоХозрасчетные.РаботникиОрганизаций))
	|			И (ХозрасчетныйСубконто.УточнениеПериода = 0)
	|ГДЕ
	|	Хозрасчетный.СчетДт В(&СчетаДт)
	|	И Хозрасчетный.СчетКт В(&СчетаКт)
	|	И ЕСТЬNULL(Хозрасчетный.ВалютаДт, &ВалютаРеглУчета) = &Валюта
	|	И Хозрасчетный.Организация = &Организация
	|	И ХозрасчетныйСубконто.Значение = &ФизЛицо
	|	И Хозрасчетный.Период >= &НачалоПериода
	|	И Хозрасчетный.МоментВремени < &МоментВремени
	|	И ХозрасчетныйСубконто.Период >= &НачалоПериода
	|	И ХозрасчетныйСубконто.МоментВремени < &МоментВремени
	|
	|СГРУППИРОВАТЬ ПО
	|	Хозрасчетный.Регистратор,
	|	Хозрасчетный.Период
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументАванса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АвансовыйОтчетВыданныеАвансы.ДокументАванса КАК ДокументАванса,
	|	СУММА(ВЫБОР
	|			КОГДА АвансовыйОтчетВыданныеАвансы.СуммаИзрасходованногоАванса > 0
	|				ТОГДА АвансовыйОтчетВыданныеАвансы.СуммаИзрасходованногоАванса
	|			ИНАЧЕ АвансовыйОтчетВыданныеАвансы.ДокументАванса.СуммаДокумента
	|		КОНЕЦ) КАК СуммаИзрасходованногоАванса
	|ПОМЕСТИТЬ ВТ_Отчеты
	|ИЗ
	|	Документ.АвансовыйОтчет.ВыданныеАвансы КАК АвансовыйОтчетВыданныеАвансы
	|ГДЕ
	|	АвансовыйОтчетВыданныеАвансы.ДокументАванса В
	|			(ВЫБРАТЬ
	|				ВТ_Авансы.ДокументАванса
	|			ИЗ
	|				ВТ_Авансы)
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка <> &Ссылка
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.ФизЛицо = &ФизЛицо
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.ВалютаДокумента = &Валюта
	|	И АвансовыйОтчетВыданныеАвансы.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	АвансовыйОтчетВыданныеАвансы.ДокументАванса
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументАванса
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 100
	|	ВТ_Авансы.ДокументАванса КАК ДокументАванса,
	|	ВТ_Авансы.ДокументАвансаДата КАК ДокументАвансаДата,
	|	ВТ_Авансы.СуммаДокумента КАК СуммаАванса,
	|	ВТ_Авансы.СуммаАванса - ЕСТЬNULL(ВТ_Отчеты.СуммаИзрасходованногоАванса, 0) КАК СуммаИзрасходованногоАванса
	|ИЗ
	|	ВТ_Авансы КАК ВТ_Авансы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Отчеты КАК ВТ_Отчеты
	|		ПО ВТ_Авансы.ДокументАванса = ВТ_Отчеты.ДокументАванса
	|ГДЕ
	|	ВТ_Авансы.СуммаАванса - ЕСТЬNULL(ВТ_Отчеты.СуммаИзрасходованногоАванса, 0) > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_Авансы.ДокументАвансаДата УБЫВ";
	
	Если БухгалтерскийУчетПереопределяемый.ВестиУчетПоПодразделениям() Тогда
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
		
		ОтборЗапроса0 = СхемаЗапроса.ПакетЗапросов[0].Операторы[0].Отбор;
		ОтборЗапроса0.Добавить("ЕСТЬNULL(ПодразделениеДт, &ПустоеПодразделение) = &Подразделение");
		
		ОтборЗапроса1 = СхемаЗапроса.ПакетЗапросов[1].Операторы[0].Отбор;
		ОтборЗапроса1.Добавить("Ссылка.ПодразделениеОрганизации = &Подразделение");
		
		ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	КонецЕсли;
	
	ВремяНачала = ОценкаПроизводительности.НачатьЗамерВремени();
	КлючеваяОперация = "ИндексТаблицыСубконто.АвансовыйОтчет_ТаблицаАвансов";
	
	Запрос.Текст = ТекстЗапроса;
	ТаблицаАвансов = Запрос.Выполнить().Выгрузить();
	
	ОценкаПроизводительности.ЗакончитьЗамерВремени(КлючеваяОперация, ВремяНачала);
	
	ТаблицаРаспределенныхАвансов = ТаблицаАвансов.СкопироватьКолонки();
	
	// Сначала подберем документы авансов (с конца) на требуемую сумму (или немного больше).
	СуммаДляРаспределения = СуммаРаспределения;
	Для Каждого СтрокаАванса Из ТаблицаАвансов Цикл
		ВыданныйАванс = ТаблицаРаспределенныхАвансов.Добавить();
		ЗаполнитьЗначенияСвойств(ВыданныйАванс, СтрокаАванса);
		
		Если СтрокаАванса.СуммаИзрасходованногоАванса <= СуммаДляРаспределения Тогда
			СуммаДляРаспределения = СуммаДляРаспределения - СтрокаАванса.СуммаИзрасходованногоАванса;
		Иначе
			// Сумму крайнего документа не меняем, т.к. этот документ станет первым в распределении авансов документа
			СуммаДляРаспределения = 0;
		КонецЕсли;
		
		Если СуммаДляРаспределения = 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ТаблицаРаспределенныхАвансов.Сортировать("ДокументАвансаДата");
	ТаблицаРаспределенныхАвансов.Индексы.Добавить("ДокументАванса");
	
	Для Каждого СтрокаАванса Из ТаблицаРаспределенныхАвансов Цикл
		ВыданныйАванс = Объект.ВыданныеАвансы.Добавить();
		ЗаполнитьЗначенияСвойств(ВыданныйАванс, СтрокаАванса,, "СуммаИзрасходованногоАванса");
		Если СтрокаАванса.СуммаИзрасходованногоАванса <= СуммаРаспределения Тогда
			СуммаРаспределения = СуммаРаспределения - СтрокаАванса.СуммаИзрасходованногоАванса;
			Если Объект.КурсРассчитывается Тогда
				ВыданныйАванс.СуммаИзрасходованногоАванса = СтрокаАванса.СуммаИзрасходованногоАванса;
			КонецЕсли;
		Иначе
			Если Объект.КурсРассчитывается Тогда
				ВыданныйАванс.СуммаИзрасходованногоАванса = СуммаРаспределения;
			КонецЕсли;
			СуммаРаспределения = 0;
		КонецЕсли;
		
		ВыданныйАванс.Валюта = Объект.ВалютаДокумента;
		
		Если СуммаРаспределения = 0 Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьДобавленныеКолонкиТаблиц();
	
КонецПроцедуры

&НаКлиенте
Процедура ПерезаполнитьАвансыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьАвансыНаСервере();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗачетАвансовПриИзменении()
	
	Если Объект.КурсРассчитывается Тогда
		ЗаполнитьИлиРассчитатьАвансы();
	Иначе
		УстановитьЗачетАвансовАвтоматически();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИлиРассчитатьАвансы()
	
	Если Объект.ВыданныеАвансы.Количество() = 0 Тогда
		ЗаполнитьАвансыНаСервере();
	Иначе
		РассчитатьАвансыНаСервере();
	КонецЕсли;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗачетАвансовАвтоматически()
	
	ВключитьЗачетАвансов();
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ВключитьЗачетАвансов()
	
	Для Каждого ВыданныйАванс Из Объект.ВыданныеАвансы Цикл
		ВыданныйАванс.СуммаИзрасходованногоАванса = 0;
	КонецЦикла;
	
	УправлениеФормой(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура КурсРасчетовУправление(Форма)
	
	Объект   = Форма.Объект;
	Элементы = Форма.Элементы;
	
	РасчетыВВалюте = Объект.ВалютаДокумента <> Форма.ВалютаРегламентированногоУчета;
	
	Если РасчетыВВалюте И Объект.КурсРассчитывается Тогда
		Элементы.ВыданныеАвансыСуммаИзрасходованногоАванса.Заголовок =
			СтрШаблон(НСтр("ru = 'Зачтено (%1)'"), Объект.ВалютаДокумента);
	КонецЕсли;
	
	Элементы.ВыданныеАвансыСуммаАванса.Заголовок = ?(РасчетыВВалюте,
		СтрШаблон(НСтр("ru = 'Аванс (%1)'"), Объект.ВалютаДокумента),
		НСтр("ru = 'Аванс'"));
	
КонецПроцедуры

#Область КопированиеВставкаСтрокЧерезБуферОбмена

&НаСервере
Процедура СкопироватьСтрокиНаСервере(ИмяТаблицы)
	
	ОбщегоНазначения.СкопироватьСтрокиВБуферОбмена(Объект[ИмяТаблицы], 
		Элементы[ИмяТаблицы].ВыделенныеСтроки, Объект.Ссылка.Метаданные().Имя);

КонецПроцедуры

&НаСервере
Функция ВставитьСтрокиНаСервере(ИмяТаблицы)
	
	ПараметрыВставки = ОбработкаТабличныхЧастей.ПолучитьПараметрыВставкиДанныхИзБуфераОбмена(Объект.Ссылка, ИмяТаблицы);
	ОпределитьСписокСвойствДляВставкиИзБуфера(ПараметрыВставки);
	ОбработкаВыбораПодборВставкаИзБуфераНаСервере(ПараметрыВставки, ПараметрыВставки.ИмяТаблицы);
	
	Возврат ПараметрыВставки.КоличествоДобавленныхСтрок;
	
КонецФункции

&НаКлиенте
Функция ПолучитьИмяТекущейТабличнойЧасти()
	
	ИмяТекущейСтраницы = Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя;
	ИмяТаблицы = "Товары";
	
	Если ИмяТекущейСтраницы = "ГруппаПрочее" Тогда
		ИмяТаблицы = "Прочее";
	КонецЕсли;
	
	Возврат ИмяТаблицы;
	
КонецФункции

&НаСервере
Процедура ОпределитьСписокСвойствДляВставкиИзБуфера(ПараметрыВставки)

	СписокСвойств = Новый Массив;
	СписокСвойств.Добавить("ВидДокВходящий");
	СписокСвойств.Добавить("НомерВходящегоДокумента");
	СписокСвойств.Добавить("ДатаВходящегоДокумента");
	СписокСвойств.Добавить("Поставщик");
	СписокСвойств.Добавить("Номенклатура");
	СписокСвойств.Добавить("Сумма");
	СписокСвойств.Добавить("СтавкаНДС");
	
	Если ПараметрыВставки.ИмяТаблицы = "Прочее" Тогда
		СписокСвойств.Добавить("Содержание");
	Иначе
		СписокСвойств.Добавить("Описание");
		СписокСвойств.Добавить("Количество");
		СписокСвойств.Добавить("Цена");
		СписокСвойств.Добавить("НомерГТД");
		СписокСвойств.Добавить("СтранаПроисхождения");
		Если ПараметрыВставки.ПоказыватьСчетаУчетаВДокументах Тогда
			СписокСвойств.Добавить("СчетУчета");
			СписокСвойств.Добавить("СчетУчетаНДС");
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыВставки.СписокСвойств = ОбработкаТабличныхЧастей.ПолучитьСписокСвойствИмеющихсяВТаблицеДанных(
		ПараметрыВставки.Данные, СписокСвойств);
	
КонецПроцедуры
	
&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьКомандыВставки(Форма, Доступность)

	Доступность = Не Форма.ТолькоПросмотр И Доступность;
	Элементы = Форма.Элементы;
	
	Элементы.ТоварыВставитьСтроки.Доступность = Доступность;
	Элементы.ТоварыКонтекстноеМенюВставитьСтроки.Доступность = Доступность;
	
	Элементы.ПрочееВставитьСтроки.Доступность = Доступность;
	Элементы.ПрочееКонтекстноеМенюВставитьСтроки.Доступность = Доступность;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборВставкаИзБуфераНаСервере(ВыбранноеЗначение, ИмяТаблицы)
	
	ЭтоВставкаИзБуфера = ВыбранноеЗначение.Свойство("ЭтоВставкаИзБуфера");
	СписокСвойств = Неопределено;
	
	Если ЭтоВставкаИзБуфера Тогда
		ТаблицаТоваров = ВыбранноеЗначение.Данные;
		СписокСвойств = ВыбранноеЗначение.СписокСвойств;
	Иначе
		ТаблицаТоваров = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресПодобраннойНоменклатурыВХранилище);
	КонецЕсли;
	
	КоличествоДобавленныхСтрок = 0;
	
	ДанныеОбъекта = Новый Структура("Дата, Организация, Склад");
	ЗаполнитьЗначенияСвойств(ДанныеОбъекта, Объект);
	
	СоответствиеСведенийОНоменклатуре = БухгалтерскийУчетПереопределяемый.ПолучитьСведенияОСпискеНоменклатуры(
		ОбщегоНазначения.ВыгрузитьКолонку(ТаблицаТоваров, "Номенклатура", Истина),
		ДанныеОбъекта,
		Истина,
		Ложь);
		
	СтрокиДляЗаполненияСчетовУчета = Новый Массив;
	ЕстьОписание = ТаблицаТоваров.Колонки.Найти("Описание") <> Неопределено;
	
	Для Каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		СведенияОНоменклатуре = СоответствиеСведенийОНоменклатуре.Получить(СтрокаТовара.Номенклатура);
		
		ЭтоТаблицаПрочее = ИмяТаблицы = "Прочее";
		ЭтоТаблицаТовары = ИмяТаблицы = "Товары";
		
		Если ЭтоВставкаИзБуфера И СведенияОНоменклатуре <> Неопределено Тогда
			Если ЭтоТаблицаПрочее И СведенияОНоменклатуре.Услуга = Ложь Тогда
				// Пропускаем товары.
				Продолжить;
			КонецЕсли;
			Если ЭтоТаблицаТовары И СведенияОНоменклатуре.Услуга = Истина Тогда
				// Пропускаем услуги.
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		СтрокаТабличнойЧасти = Объект[ИмяТаблицы].Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти, СтрокаТовара, СписокСвойств);
		КоличествоДобавленныхСтрок = КоличествоДобавленныхСтрок + 1;
		
		Если ЭтоТаблицаПрочее Тогда
			Если ЕстьОписание Тогда
				СтрокаТабличнойЧасти.Содержание = СтрокаТовара.Описание;
			КонецЕсли;
			
			СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма;
			
			Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СчетЗатрат) Тогда
				СтрокиДляЗаполненияСчетовУчета.Добавить(СтрокаТабличнойЧасти);
			КонецЕсли;
		Иначе
			Если СведенияОНоменклатуре <> Неопределено Тогда
				СтрокаТабличнойЧасти.СтранаПроисхождения = ?(ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтранаПроисхождения),
					СтрокаТабличнойЧасти.СтранаПроисхождения, СведенияОНоменклатуре.СтранаПроисхождения);
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(СтрокаТабличнойЧасти.СчетУчета) Тогда
				СтрокиДляЗаполненияСчетовУчета.Добавить(СтрокаТабличнойЧасти);
			КонецЕсли;
			
			ЗаполнитьДобавленныеКолонкиСтрокиТаблицыТовары(СтрокаТабличнойЧасти, Объект.СуммаВключаетНДС);
		КонецЕсли;
		
	КонецЦикла;
		
	Если СтрокиДляЗаполненияСчетовУчета.Количество() Тогда
		ЗаполнитьСчетаУчета(СтрокиДляЗаполненияСчетовУчета, ИмяТаблицы);
	КонецЕсли;
		
	Если ЭтоВставкаИзБуфера Тогда
		ВыбранноеЗначение.КоличествоДобавленныхСтрок = КоличествоДобавленныхСтрок;
	КонецЕсли;
	
	ОбновитьИтоги(ЭтотОбъект);
КонецПроцедуры

#КонецОбласти

