			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	НачалоСтадииРазработокНМА.Ссылка КАК Ссылка,
	НачалоСтадииРазработокНМА.ПометкаУдаления КАК ПометкаУдаления,
	НачалоСтадииРазработокНМА.Дата КАК Дата,
	НачалоСтадииРазработокНМА.Проведен КАК Проведен,
	НачалоСтадииРазработокНМА.Организация КАК Организация,
	НачалоСтадииРазработокНМА.Ответственный КАК Ответственный,
	НачалоСтадииРазработокНМА.Комментарий КАК Комментарий,
	НачалоСтадииРазработокНМА.РучнаяКорректировка КАК РучнаяКорректировка,
	НачалоСтадииРазработокНМА.МоментВремени КАК МоментВремени,
	НачалоСтадииРазработокНМА.Номер КАК Номер,
	ВЫБОР
		КОГДА НачалоСтадииРазработокНМА.РучнаяКорректировка = ИСТИНА
			ТОГДА ВЫБОР
					КОГДА НачалоСтадииРазработокНМА.ПометкаУдаления = ИСТИНА
						ТОГДА 10
					КОГДА НачалоСтадииРазработокНМА.Проведен = ЛОЖЬ
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА НачалоСтадииРазработокНМА.ПометкаУдаления = ИСТИНА
					ТОГДА 2
				КОГДА НачалоСтадииРазработокНМА.Проведен = ИСТИНА
