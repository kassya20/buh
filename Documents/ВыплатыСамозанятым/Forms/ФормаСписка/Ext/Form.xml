			<UseAlways>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ВЫБОР
		КОГДА ДокументВыплатыСамозанятым.РучнаяКорректировка
			ТОГДА ВЫБОР
					КОГДА ДокументВыплатыСамозанятым.ПометкаУдаления
						ТОГДА 10
					КОГДА НЕ ДокументВыплатыСамозанятым.Проведен
						ТОГДА 9
					ИНАЧЕ 8
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ДокументВыплатыСамозанятым.ПометкаУдаления
					ТОГДА 2
				КОГДА ДокументВыплатыСамозанятым.Проведен
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ
	КОНЕЦ КАК СостояниеДокумента,
	ДокументВыплатыСамозанятым.Ссылка КАК Ссылка,
	ДокументВыплатыСамозанятым.ПометкаУдаления КАК ПометкаУдаления,
	ДокументВыплатыСамозанятым.Номер КАК Номер,
	ДокументВыплатыСамозанятым.Дата КАК Дата,
	ДокументВыплатыСамозанятым.Проведен КАК Проведен,
	ДокументВыплатыСамозанятым.Организация КАК Организация,
	ДокументВыплатыСамозанятым.СчетОрганизации КАК СчетОрганизации,
	ДокументВыплатыСамозанятым.СуммаДокумента КАК СуммаДокумента,
	ДокументВыплатыСамозанятым.Ответственный КАК Ответственный,
	ДокументВыплатыСамозанятым.Комментарий КАК Комментарий,
	ВЫБОР
		КОГДА ДокументВыплатыСамозанятым.УслугаВТаблице
			ТОГДА "Указывается в списке"
		ИНАЧЕ ДокументВыплатыСамозанятым.Номенклатура
	КОНЕЦ КАК Услуга,
	НаличиеФайлов.ЕстьФайлы КАК ЕстьФайлы,
	ЕСТЬNULL(СтатусыДокументов.Статус, "") КАК Состояние
ИЗ
	Документ.ВыплатыСамозанятым КАК ДокументВыплатыСамозанятым
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ДокументВыплатыСамозанятым.Ссылка = НаличиеФайлов.ОбъектСФайлами}
