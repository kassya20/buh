	ОткрытьФорму("Документ.СчетНаОплатуПоставщика.Форма.ФормаДокумента",,ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияПлатежПоШтрихкодуНажатие(Элемент)
	
	Если ПоказыватьПодсказкуСканироватьQRПлатежа Тогда
		ЗавершениеПодсказки = Новый ОписаниеОповещения("ЗавершениеПодсказкаСканироватьQRПлатежа", ЭтотОбъект);
		ПоказатьВопрос(ЗавершениеПодсказки, 
			НСтр("ru = 'Считайте QR-код в Счете поставщика или в налоговом уведомлении'"),РежимДиалогаВопрос.ОК,,, "Подсказка");
	Иначе
		НачатьСозданиеПлатежаПоQRКоду();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеПодсказкаСканироватьQRПлатежа(Результат, ДопПараметры) Экспорт
	
	НачатьСозданиеПлатежаПоQRКоду();
	ПоказыватьПодсказкуСканироватьQRПлатежа = Ложь;
	СохранитьНастройкуПоказыватьПодсказкуСканироватьQRПлатежа();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьСозданиеПлатежаПоQRКоду()
	
	ЗавершениеСозданияПлатежа = Новый ОписаниеОповещения("ЗавершениеСканироватьQRПлатежа", ЭтотОбъект);
	МобильныйКлиентБПКлиент.НачатьСозданиеПлатежаПоQRКоду(ЗавершениеСозданияПлатежа);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеСканироватьQRПлатежа(ПлатежноеПоручение, ДопПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(ПлатежноеПоручение) Тогда
		
		ПараметрыФормы = Новый Структура("Ключ", ПлатежноеПоручение);
		ОткрытьФорму("Документ.ПлатежноеПоручение.ФормаОбъекта",
			ПараметрыФормы,
			ЭтотОбъект);
			
	КонецЕсли;
	
КонецПроцедуры

// Сохраняет отметку показывать подсказку для текущего пользователя.
&НаКлиенте
Процедура СохранитьНастройкуПоказыватьПодсказкуСканироватьQRПлатежа()
	
	ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекСохранить(
		"МобильныйКлиентБП",
		"ПоказыватьПодсказкуСканироватьQRПлатежа",
		ПоказыватьПодсказкуСканироватьQRПлатежа,
		,
		ИмяПользователя());
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПоказыватьПодсказкуСканироватьQRПлатежа()
	
	Возврат ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекЗагрузить(
		"МобильныйКлиентБП",
		"ПоказыватьПодсказкуСканироватьQRПлатежа",
		Истина,
		,
		ИмяПользователя());
	
КонецФункции

