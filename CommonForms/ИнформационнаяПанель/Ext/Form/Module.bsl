&НаКлиенте
Процедура ДекорацияНовыйУПДНажатие(Элемент)
	
	СписокВыбораОперации = Новый СписокЗначений;
	СписокВыбораОперации.Добавить("УПД_Товары", "Товары");
	СписокВыбораОперации.Добавить("УПД_Услуги", "Услуги");
	
	ОписаниеЗавершения = Новый ОписаниеОповещения("КомандыМК_Создать_Завершение", ЭтотОбъект);
	ПоказатьВыборИзМеню(ОписаниеЗавершения, СписокВыбораОперации, Элемент);

КонецПроцедуры

&НаКлиенте
Процедура КомандыМК_Создать_Завершение(ВыбранныйЭлемент, ДопПараметры) Экспорт

	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбранныйЭлемент.Значение = "УПД_Товары" Тогда
		СоздатьУПДТовары(Неопределено);
	ИначеЕсли ВыбранныйЭлемент.Значение = "УПД_Услуги" Тогда
		СоздатьУПДУслуги(Неопределено);
	ИначеЕсли ВыбранныйЭлемент.Значение = "СчетПокупателю" Тогда
		СоздатьСчет(Неопределено);
	ИначеЕсли ВыбранныйЭлемент.Значение = "Акт" Тогда
		СоздатьАкт(Неопределено);
	ИначеЕсли ВыбранныйЭлемент.Значение = "Накладная" Тогда
		СоздатьНакладную(Неопределено);
	ИначеЕсли ВыбранныйЭлемент.Значение = "Платеж" Тогда
		СоздатьПлатеж();
	ИначеЕсли ВыбранныйЭлемент.Значение = "" Тогда
		//Отступ
	Иначе
		ВызватьИсключение "Неизвестный вид документа";
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДекорацияНоваяНакладнаяНажатие(Элемент)
	СоздатьНакладную(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ДекорацияНовыйАктНажатие(Элемент)
