КонецПроцедуры

&НаКлиенте
Процедура ДекорацияНовыйСчетНажатие(Элемент)
	СоздатьСчет(Неопределено);
КонецПроцедуры

&НаСервере
Процедура АдаптироватьБлоки()
	
	ДоступныеРазделыНаМК = БлокиИнформационнойПанелиКлиентСервер.ДоступныеРазделыНаМК();
	Для Каждого Блок Из ТаблицаБлоков Цикл
		Если ДоступныеРазделыНаМК.Найти(Блок.Имя) = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
				Блок.Имя,
				"Видимость",
				Ложь);
		Иначе
			АдаптироватьБлокиМК(Блок.Имя);
		КонецЕсли;
	КонецЦикла;
	
	Для ИндексСтроки = 0 По ИнформационнаяПанель.КоличествоКолонок() - 1 Цикл
		Для ИндексКолонки = 0 По ИнформационнаяПанель.КоличествоСтрок() - 1 Цикл
			Контейнер = Элементы[ИмяКонтейнераБлока(ИндексСтроки, ИндексКолонки)];
			Контейнер.Ширина = 0;
			Контейнер.Высота = 0;
			Контейнер.РастягиватьПоГоризонтали = Истина;
			Контейнер.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
		КонецЦикла;
	КонецЦикла;
	
	АдаптироватьМКОстаткиДенежныхСредств();
	АдаптироватьМКПокупатели();
	АдаптироватьМКПоставщики();
	АдаптироватьМКПродажи();
	АдаптироватьМККурсыВалют();
	АдаптироватьМКМойНалог();
	
	Элементы.МоиЗадачиВсеМоиЗадачи.РастягиватьПоВертикали = Ложь;
	Элементы.ЗадачиВсеЗадачи.РастягиватьПоВертикали = Ложь;
	
	ДоступноРаспознавание = ПолучитьФункциональнуюОпцию("ИспользоватьРаспознаваниеДокументов")
		И ПравоДоступа("Просмотр", Метаданные.Обработки.РаспознаваниеДокументов);
	СозданиеСчета = ПравоДоступа("Изменение", Метаданные.Документы.СчетНаОплатуПокупателю);
	СозданиеРеализации = ПравоДоступа("Изменение", Метаданные.Документы.РеализацияТоваровУслуг);
	СозданиеПлатежа = ПравоДоступа("Изменение", Метаданные.Документы.ПлатежноеПоручение);
	
	ДоступныПанелиМК = Не ОбщегоНазначенияБП.ЭтоИнтерфейсИнтеграцииСБанком();
	ДоступнаПанельАкселераторыМК = ДоступныПанелиМК
		И (ДоступноРаспознавание Или СозданиеПлатежа);
	ДоступнаПанельАкселераторыМКДокументы = НЕ ДоступнаПанельАкселераторыМК
		И ДоступныПанелиМК;
		
	Элементы.ГруппаАкселераторыМК.Видимость = ДоступнаПанельАкселераторыМК;
	Элементы.ГруппаАкселераторыМКДокументы.Видимость = ДоступнаПанельАкселераторыМКДокументы;
	
	Элементы.ДекорацияНовыйСчет.Видимость      = СозданиеСчета;
	Элементы.ДекорацияНовыйАкт.Видимость       = СозданиеРеализации;
	Элементы.ДекорацияНоваяНакладная.Видимость = СозданиеРеализации;
	Элементы.ДекорацияНовыйУПД.Видимость       = СозданиеРеализации;
	
	Если ДоступнаПанельАкселераторыМК Тогда
		
		Элементы.ГруппаПлатежиПоШтрихкоду.Видимость = СозданиеПлатежа;	
		Элементы.ГруппаРаспознатьДокументыМК.Видимость = ДоступноРаспознавание;
		
		ВыборДоступныхДокументовМК.Очистить();
		Если СозданиеСчета Тогда
			ВыборДоступныхДокументовМК.Добавить("СчетПокупателю", "+ Счет покупателю");
			ВыборДоступныхДокументовМК.Добавить("", "_____________________");
		КонецЕсли;
		Если СозданиеРеализации Тогда
			ВыборДоступныхДокументовМК.Добавить("Акт", "+ Акт");
			ВыборДоступныхДокументовМК.Добавить("Накладная", "+ Накладная");
			ВыборДоступныхДокументовМК.Добавить("УПД_Товары", "+ УПД(Товары)");
			ВыборДоступныхДокументовМК.Добавить("УПД_Услуги", "+ УПД(Услуги)");
		КонецЕсли;
		Если СозданиеПлатежа Тогда
			ВыборДоступныхДокументовМК.Добавить("", "_____________________");
			ВыборДоступныхДокументовМК.Добавить("Платеж", "+ Платеж");
		КонецЕсли;
	КонецЕсли;
	
	МобильныйКлиентБПФормаОбъекта.СкрытьЭлементФормы(Элементы, Элементы.ДекорацияШапкаОтступСлева);
	
КонецПроцедуры

&НаСервере
Процедура АдаптироватьБлокиМК(ИмяЭлементаБлок)
	
	ЭлементБлок = Элементы.Найти(ИмяЭлементаБлок);
	ЭлементБлок.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	ЭлементБлок.Ширина = 0;
	ЭлементБлок.Высота = 0;
	ЭлементБлок.РастягиватьПоГоризонтали = Истина;
	
	ЭлементБлок.ОтображатьЗаголовок = Истина;
	ЭлементБлок.Заголовок = Врег(ЭлементБлок.Заголовок);
	
	ИмяЭлементаЗаголовок = ИмяЭлементаБлок + "_Заголовок";
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		ИмяЭлементаЗаголовок,
		"Видимость",
		Ложь);
	
	ИмяЭлементаОтступ = ИмяЭлементаБлок + "Отступ";
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		ИмяЭлементаОтступ,
		"Отображение",
		ОтображениеОбычнойГруппы.Нет);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		ИмяЭлементаОтступ,
		"РастягиватьПоВертикали",
		Ложь);
	
КонецПроцедуры

