#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Параметры.Свойство("ТипКриптопровайдера", ТипКриптопровайдера);
	
	ГОСТ34122018ViPNetCSPДоступен =
		ОнлайнСервисыРегламентированнойОтчетностиВызовСервера.СобытиеНаступило("ViPNet CSPГОСТ 34.12-2018");
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ВСоответствииС = НСтр("ru = 'В соответствии с'");
	ПриказФНС726245 = Новый ФорматированнаяСтрока(НСтр("ru = 'приказом ФНС России от 27.03.2024 г. N ЕД-7-26/245@'"),,,,
		"https://www.nalog.gov.ru/rn77/about_fts/docs/14718379/");
	ТребуетсяГОСТ34122018 =
		НСтр("ru = 'с 01.04.2026 г.'") + " " + "
		|" + НСтр("ru = 'для обмена с ФНС необходимо использовать криптопровайдер, поддерживающий алгоритмы'") + " " + "
		|" + НСтр("ru = 'шифрования ГОСТ 34.12-2018 и ГОСТ 34.13-2018.'");
	ПолужирныйШрифт = Новый Шрифт(,, Истина);
	Если ТипКриптопровайдера = ПредопределенноеЗначение("Перечисление.ТипыКриптоПровайдеров.VipNet") Тогда
		Если ГОСТ34122018ViPNetCSPДоступен Тогда
			Элементы.ТекстПредупреждения.Заголовок = Новый ФорматированнаяСтрока(
				ВСоответствииС + " ",
				ПриказФНС726245,
				" " + ТребуетсяГОСТ34122018 + "
				|
				|",
				Новый ФорматированнаяСтрока(НСтр("ru = 'Обновите'"),,,, "https://infotecs.ru/products/vipnet-csp/"),
				" " + НСтр("ru = 'ViPNet CSP до версии'") + " ",
				Новый ФорматированнаяСтрока("5", ПолужирныйШрифт),
				".");
		Иначе
			СимволСтрелкиВправо = Символ(8594);
			Элементы.ТекстПредупреждения.Заголовок = Новый ФорматированнаяСтрока(
				ВСоответствииС + " ",
				ПриказФНС726245,
				" " + ТребуетсяГОСТ34122018 + "
				|
				|" + НСтр("ru = '1. При хранении ключей на диске экспортируйте их в формат с расширением .pfx.'") + "
				|" + НСтр("ru = '2. Отключите использование ViPNet CSP через Microsoft CryptoAPI в настройках'") + " " + "
				|" + "(" + НСтр("ru = 'приложение ""ViPNet CSP""'") + " " + СимволСтрелкиВправо + " """ + НСтр("ru = 'Дополнительно'")
				+ """ " + СимволСтрелкиВправо + " """ + НСтр("ru = 'Поддержка работы ViPNet CSP через Microsoft'") + " " + "
				|" + НСтр("ru = 'CryptoAPI'") + """) "
				+ НСтр("ru = 'или удалите ViPNet CSP вовсе, если не планируете использовать для других задач.'") + " " + "
				|" + НСтр("ru = 'Перезагрузите компьютер.'") + "
				|" + НСтр("ru = '3. Установите КриптоПро CSP версии'") + " ",
				Новый ФорматированнаяСтрока(НСтр("ru = '5.0.12000 (R2) или выше'"), ПолужирныйШрифт),
				". " + НСтр("ru = 'При необходимости приобретите'") + " ",
				Новый ФорматированнаяСтрока(НСтр("ru = 'лицензию'"),,,, "https://cryptopro.ru/buy"),
				".
				|" + НСтр("ru = '4. Если ключи хранились на диске, импортируйте ключи из формата с расширением .pfx.'"));
		КонецЕсли;
	Иначе
		Элементы.ТекстПредупреждения.Заголовок = Новый ФорматированнаяСтрока(
			ВСоответствииС + " ",
			ПриказФНС726245,
			" " + ТребуетсяГОСТ34122018 + "
			|
			|",
			Новый ФорматированнаяСтрока(НСтр("ru = 'Обновите'"),,,, "Обновить"),
			" " + НСтр("ru = 'КриптоПро CSP до версии'") + " ",
			Новый ФорматированнаяСтрока(НСтр("ru = '5.0.12000 (R2) или выше'"), ПолужирныйШрифт),
			".");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТекстПредупрежденияОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	Если НавигационнаяСсылкаФорматированнойСтроки = "Обновить" Тогда
		СтандартнаяОбработка = Ложь;
		ОбщегоНазначенияЭДКОКлиент.УстановитьCryptoProCSP(Неопределено, ЭтаФорма);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
