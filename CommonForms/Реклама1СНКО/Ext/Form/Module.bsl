#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.ГруппаПереходВМенеджерСервиса.Видимость = Ложь;
	АдресМенеджераСервиса = "";
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		ЗаписатьСобытиеНаСервере("ОткрытиеФормыВРежимеСервиса");
		Элементы.ДекорацияПереходВМенеджерСервиса1.Заголовок = ТекстИнструкцииПоПереходуНаНКОВСервисе();
		Если ОбщегоНазначения.ПодсистемаСуществует("ТехнологияСервиса.ВнешнийПрограммныйИнтерфейс") Тогда
			МодульПрограммныйИнтерфейсСервиса = ОбщегоНазначения.ОбщийМодуль("ПрограммныйИнтерфейсСервиса");
			Попытка
				АдресМенеджераСервиса = МодульПрограммныйИнтерфейсСервиса.ВнешнийАдресМенеджераСервиса();
			Исключение
				СвойстваВерсииИнтерфейса = МодульПрограммныйИнтерфейсСервиса.СвойстваВерсииИнтерфейса();
				АдресМенеджераСервиса = СвойстваВерсииИнтерфейса.ВнешнийАдресМенеджераСервиса;
			КонецПопытки;
			АдресМенеджераСервиса = СтрЗаменить(АдресМенеджераСервиса, "/hs/ext_api", "");
		КонецЕсли;
	Иначе
		ЗаписатьСобытиеНаСервере("ОткрытиеФормыВЛокальномРежиме");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ДекорацияОписаниеОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если НавигационнаяСсылкаФорматированнойСтроки = "СтатьяНаBUHRU" Тогда
		ЗаписатьСобытиеНаСервере("ПереходКСтатьеНаBUHRU");
		ПерейтиПоНавигационнойСсылке("https://buh.ru/articles/1s-bukhgalteriya-8-ili-1s-bukhgalteriya-nko-8-v-kakoy-programme-udobnee-vesti-uchet-nekommercheskoy-.html");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УзнатьБольше(Команда)
	
	Если ЗначениеЗаполнено(АдресМенеджераСервиса) Тогда
		ЗаписатьСобытиеНаСервере("ПереходКИнструкцииВРежимеСервиса");
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаПереходВМенеджерСервиса;
		Элементы.ГруппаНачало.Видимость = Ложь;
		Элементы.ГруппаПереходВМенеджерСервиса.Видимость = Истина;
		Элементы.ПерейтиВМенеджерСервиса.КнопкаПоУмолчанию = Истина;
	Иначе
		ЗаписатьСобытиеНаСервере("ПереходНаСайтПрограммы");
		ПерейтиПоНавигационнойСсылке("http://v8.1c.ru/buhnpo/");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиВМенеджерСервиса(Команда)
	
	ЗаписатьСобытиеНаСервере("ПереходВМенеджерСервиса");
	ПерейтиПоНавигационнойСсылке(АдресМенеджераСервиса);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ТекстИнструкцииПоПереходуНаНКОВСервисе()
	
	СтрокаИнструкции = НСтр("ru='1. По кнопке ниже перейдите в личный кабинет'") + Символы.ПС + Символы.ПС;
	СтрокаИнструкции = СтрокаИнструкции + СтрШаблон(НСтр("ru='2. Двойным нажатием откройте приложение <b>%1</b>'"), РаботаВМоделиСервиса.ПолучитьИмяПриложения());
	
	Возврат СтроковыеФункции.ФорматированнаяСтрока(СтрокаИнструкции);
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьСобытиеНаСервере(ИмяСобытия)
	
	УстановитьПривилегированныйРежим(Истина);
	ЦентрМониторинга.ЗаписатьСтатистикуОбъектаКонфигурации("ОбщаяФорма.Реклама1СНКО." + ИмяСобытия, 1);
	
КонецПроцедуры

#КонецОбласти