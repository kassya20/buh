#Область ОбработчикиСобытий

Функция ПроверкаПодключенияПроверить(Запрос)
	
	Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния());
	
КонецФункции

Функция ОтчетныеКампанииЗапросыЗапросить(Запрос)
	
	ТекстЗапроса = "";
	Попытка
		
		ТекстЗапроса = Запрос.ПолучитьТелоКакСтроку();
		Возврат ЗапроситьДанныеПриложения(ТекстЗапроса);
		
	Исключение
		
		ЗаписатьИсключениеHTTPСервиса(
			ИнформацияОбОшибке(),
			Метаданные.HTTPСервисы.КалендарьОтчетности.ШаблоныURL.ОтчетныеКампанииЗапросы.Методы.Запросить,
			ТекстЗапроса);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецФункции

Функция ОтчетныеКампанииОтветыПолучить(Запрос)
	
	Попытка
		
		Идентификатор = Запрос.ПараметрыURL["RequestId"];
		Ошибка = ИдентификаторЗапроса(Идентификатор);
		Если ЗначениеЗаполнено(Ошибка) Тогда
			Возврат Ошибка;
		КонецЕсли;
		
		Возврат ПолучитьДанныеПриложения(Идентификатор);
		
	Исключение
		
		ЗаписатьИсключениеHTTPСервиса(
			ИнформацияОбОшибке(),
			Метаданные.HTTPСервисы.КалендарьОтчетности.ШаблоныURL.ОтчетныеКампанииОтветы.Методы.Получить);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецФункции

Функция ОтчетныеКампанииОтветыПодтвердитьПолучение(Запрос)
	
	Попытка
		
		Идентификатор = Запрос.ПараметрыURL["RequestId"];
		Ошибка = ИдентификаторЗапроса(Идентификатор);
		Если ЗначениеЗаполнено(Ошибка) Тогда
			Возврат Ошибка;
		КонецЕсли;
		
		Возврат ПодтвердитьПолучениеДанныхПриложения(Идентификатор);
		
	Исключение
		
		ЗаписатьИсключениеHTTPСервиса(
			ИнформацияОбОшибке(),
			Метаданные.HTTPСервисы.КалендарьОтчетности.ШаблоныURL.ОтчетныеКампанииОтветы.Методы.ПодтвердитьПолучение);
		
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область СообщенияОблачныхПриложений

// Роутер обработки входящих запросов. Запрос всегда содержит ТипЗапроса.
// Поддерживаемые виды запросов описаны в методе ПоддерживаемыеТипыЗапросов()
//
// Запрос на получение данных отчетности должен быть структурой, описаннной в методе
// СообщенияОтчетностиОблачныхПриложений.НовыйПараметрыЗапросаДанныхОтчетности().
// 
// Запрос на обновление статуса и комментария отчета:
// КалендарьОтчетностиКлиентСервер.НовыйПараметрыЗапросаИзмененияОтчета()
//
// Запросы на подключение приложения и получение списка организаций не имеют параметров.
//
Функция ЗапроситьДанныеПриложения(ТекстЗапроса)
	
	ДанныеЗапроса = ДанныеЗапроса(ТекстЗапроса);
	Если ТипЗнч(ДанныеЗапроса) = Тип("Строка") Тогда
		Возврат Ответ(ЗапросыREST.КодСостоянияПлохойЗапрос(), ДанныеЗапроса);
	КонецЕсли;
	
	ТипЗапроса = ДанныеЗапроса.ТипЗапроса;
	ДанныеОтвета = Новый Структура;
	
	Если ТипЗапроса = СообщенияОтчетностиОблачныхПриложений.ТипЗапросаДанныеОтчетности() Тогда
		// Обработка запроса на получение данных отчетности.
		НовыйЗапрос = СообщенияОтчетностиОблачныхПриложений.НовыйПараметрыЗапросаДанныхОтчетности();
		ЗаполнитьЗначенияСвойств(НовыйЗапрос, ДанныеЗапроса);
		// Получение данных отчетности выполняется асинхронно. В ответ будет выдан идентификатор запроса.
		// Клиенту следует через некоторое время обратиться за ответом методом GET
		// на адрес /ReportingCycles/requests/{ИдентификаторЗапроса}
		ИдентификаторЗапроса = СообщенияОтчетностиОблачныхПриложений.ОбработатьЗапросДанныеОтчетностиВФоне(НовыйЗапрос.Отбор);
		ДанныеОтвета = НовыйОтветДанныеОтчетности();
		ДанныеОтвета.Идентификатор = ИдентификаторЗапроса;
		Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния(), ДанныеОтвета);
		
	ИначеЕсли ТипЗапроса = СообщенияОтчетностиОблачныхПриложений.ТипЗапросаСписокОрганизаций() Тогда
		// Обработка запроса на получение списка организаций. Выполняется синхронно.
		ДанныеОтвета = СообщенияОтчетностиОблачныхПриложений.ОтветСписокОрганизаций();
		Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния(), ДанныеОтвета);
		
	ИначеЕсли ТипЗапроса = СообщенияОтчетностиОблачныхПриложений.ТипЗапросаЗаписатьСтатусОтчета() Тогда
		// Обработка запроса на обновление статуса отчета. Выполняется синхронно.
		ДанныеОтвета = СообщенияОтчетностиОблачныхПриложений.ОтветЗаписатьСтатусОтчета(ДанныеЗапроса.ПараметрыОтчета);
		Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния(), ДанныеОтвета);
		
	ИначеЕсли ТипЗапроса = СообщенияОтчетностиОблачныхПриложений.ТипЗапросаЗаписатьКомментарийОтчета() Тогда
		// Обработка запроса на обновление комментария к отчету. Выполняется синхронно.
		ДанныеОтвета = СообщенияОтчетностиОблачныхПриложений.ОтветЗаписатьКомментарийОтчета(ДанныеЗапроса.ПараметрыОтчета);
		Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния(), ДанныеОтвета);
		
	ИначеЕсли ТипЗапроса = СообщенияОтчетностиОблачныхПриложений.ТипЗапросаПодключитьОблачноеПриложение() Тогда
		// Подключение нового приложения. Выполняется синхронно.
		ДанныеОтвета = СообщенияОтчетностиОблачныхПриложений.ОтветПодключитьОблачноеПриложение();
		Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния(), ДанныеОтвета);
	КонецЕсли;
	
	Возврат Ответ(ЗапросыREST.КодСостоянияВнутренняяОшибкаСервера(), Ошибка(Нстр("ru = 'Запрос не может быть обработан.'")));
	
КонецФункции

Функция ПолучитьДанныеПриложения(ИдентификаторЗапроса)
	
	Данные = РегистрыСведений.ВременноеХранилище.Прочитать(
		Новый УникальныйИдентификатор(ИдентификаторЗапроса));
		
	Если Данные = Неопределено Тогда
		Возврат Ответ(ЗапросыREST.КодСостоянияОтсутствуетСодержимое());
	КонецЕсли;
	
	Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния(), ЗапросыREST.ЗначениеВСтрокуJSON(Данные));
	
КонецФункции

Функция ПодтвердитьПолучениеДанныхПриложения(ИдентификаторЗапроса)
	
	РегистрыСведений.ВременноеХранилище.Удалить(Новый УникальныйИдентификатор(ИдентификаторЗапроса));
	Возврат Ответ(ЗапросыREST.КодСтандартногоСостояния());
	
КонецФункции

#КонецОбласти

Функция Ответ(КодОтвета, Данные = "")
	
	Ответ = Новый HTTPСервисОтвет(КодОтвета);
	
	Ответ.Заголовки.Вставить("Accept-Charset", "utf-8");
	Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
	Ответ.Заголовки["Cache-Control"] = "no-cache";
	
	Ответ.УстановитьТелоИзСтроки(ДанныеJSON(Данные));
	
	Возврат Ответ;
	
КонецФункции

Функция Ошибка(ТекстОшибки)
	
	Возврат Новый Структура("Ошибка", ТекстОшибки);
	
КонецФункции

Функция ДанныеJSON(Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ПараметрыJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, " ");
	ЗаписьJSON.УстановитьСтроку(ПараметрыJSON);
	ЗаписатьJSON(ЗаписьJSON, Данные);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция ДанныеЗапроса(ТекстЗапроса)
	
	Если ТипЗнч(ТекстЗапроса) <> Тип("Строка") Или Не ЗначениеЗаполнено(ТекстЗапроса) Тогда
		Возврат НСтр("ru = 'Отсутствует текст запроса'");
	КонецЕсли;
	
	Попытка
		Запрос = ЗапросыREST.СтруктураИзСтрокиJSON(ТекстЗапроса, СвойстваЗапросаТипаДата());
	Исключение
		Возврат НСтр("ru = 'Объект JSON описан неверно'");
	КонецПопытки;
	
	Если Не Запрос.Свойство("ТипЗапроса") Тогда
		Возврат НСтр("ru = 'Не указан тип запроса'");
	КонецЕсли;
	
	ПоддерживаемыеТипыЗапросов = ПоддерживаемыеТипыЗапросов();
	Если ПоддерживаемыеТипыЗапросов.Найти(Запрос.ТипЗапроса) = Неопределено Тогда
		Возврат НСтр("ru = 'Тип запроса не поддерживается'");
	КонецЕсли;
	
	Возврат Запрос;
	
КонецФункции

Функция ИдентификаторЗапроса(ИдентификаторЗапроса)
	
	Если Не ЗначениеЗаполнено(ИдентификаторЗапроса) Тогда
		Возврат Ответ(ЗапросыREST.КодСостоянияПлохойЗапрос(), Ошибка(НСтр("ru = 'Не указан идентификатор запроса'")));
	КонецЕсли;
	
КонецФункции

Функция ИмяСобытияЖурналаРегистрации()
	
	Возврат "ReportingCycles";
	
КонецФункции

Процедура ЗаписатьИсключениеHTTPСервиса(ИнформацияОбОшибке, Метод, ТекстЗапроса = "")
	
	ЗаписьЖурналаРегистрации(
		ИмяСобытияЖурналаРегистрации(),
		УровеньЖурналаРегистрации.Ошибка,
		Метод,
		ТекстЗапроса,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
	
КонецПроцедуры

Функция СвойстваЗапросаТипаДата()
	
	Результат = Новый Массив;
	Результат.Добавить("Начало");
	Результат.Добавить("Конец");
	Результат.Добавить("ПериодСобытия");
	Результат.Добавить("НачалоВыполнения");
	Результат.Добавить("Срок");
	
	Возврат Результат;
КонецФункции

Функция НовыйОтветДанныеОтчетности()
	
	Возврат Новый Структура("Идентификатор", "");
	
КонецФункции

Функция ПоддерживаемыеТипыЗапросов()
	
	Результат = Новый Массив;
	Результат.Добавить(СообщенияОтчетностиОблачныхПриложений.ТипЗапросаДанныеОтчетности());
	Результат.Добавить(СообщенияОтчетностиОблачныхПриложений.ТипЗапросаСписокОрганизаций());
	Результат.Добавить(СообщенияОтчетностиОблачныхПриложений.ТипЗапросаЗаписатьСтатусОтчета());
	Результат.Добавить(СообщенияОтчетностиОблачныхПриложений.ТипЗапросаЗаписатьКомментарийОтчета());
	Результат.Добавить(СообщенияОтчетностиОблачныхПриложений.ТипЗапросаПодключитьОблачноеПриложение());
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти