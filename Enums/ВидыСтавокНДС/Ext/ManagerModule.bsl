#Область ПрограммныйИнтерфейс

Функция ВидСтавки(СтавкаНДС) Экспорт
	
	Если СтавкаНДС = Перечисления.СтавкиНДС.НДС18 Тогда
		Возврат Перечисления.ВидыСтавокНДС.Общая;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС18_118 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ОбщаяРасчетная;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС10 Тогда
		Возврат Перечисления.ВидыСтавокНДС.Пониженная;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС10_110 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ПониженнаяРасчетная;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
		Возврат Перечисления.ВидыСтавокНДС.Нулевая;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
		Возврат Перечисления.ВидыСтавокНДС.БезНДС;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда
		Возврат Перечисления.ВидыСтавокНДС.Общая;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС20_120 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ОбщаяРасчетная;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС22 Тогда
		Возврат Перечисления.ВидыСтавокНДС.Общая;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС22_122 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ОбщаяРасчетная;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС7 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ОбщаяУСН;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС5 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ПониженнаяУСН;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС7_107 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ОбщаяУСНРасчетная;
	ИначеЕсли СтавкаНДС = Перечисления.СтавкиНДС.НДС5_105 Тогда
		Возврат Перечисления.ВидыСтавокНДС.ПониженнаяУСНРасчетная;
	Иначе
		Возврат Перечисления.ВидыСтавокНДС.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

Функция ВидСтавкиДляНоменклатуры(СтавкаНДС) Экспорт
	
	// В номенклатуре мы не храним специальные ставки 5% и 7%,
	// т.к. они не характеризуют саму номенклатуру, а зависят от
	// учетной политики. Поэтому в номенклатуре всегда хранится общая
	// ставка, а при заполнении документов по учетной политике определяется нужная.
	
	ЗапрещенныеВидыСтавокДляНоменклатуры = Новый Соответствие;
	ЗапрещенныеВидыСтавокДляНоменклатуры.Вставить(Перечисления.ВидыСтавокНДС.ОбщаяУСН, Перечисления.ВидыСтавокНДС.Общая);
	ЗапрещенныеВидыСтавокДляНоменклатуры.Вставить(Перечисления.ВидыСтавокНДС.ПониженнаяУСН, Перечисления.ВидыСтавокНДС.Общая);
	ЗапрещенныеВидыСтавокДляНоменклатуры.Вставить(Перечисления.ВидыСтавокНДС.ОбщаяУСНРасчетная, Перечисления.ВидыСтавокНДС.ОбщаяРасчетная);
	ЗапрещенныеВидыСтавокДляНоменклатуры.Вставить(Перечисления.ВидыСтавокНДС.ПониженнаяУСНРасчетная, Перечисления.ВидыСтавокНДС.ОбщаяРасчетная);
	
	ВидСтавки = ВидСтавки(СтавкаНДС);
	
	ЗаменяемыйВидСтавки = ЗапрещенныеВидыСтавокДляНоменклатуры.Получить(ВидСтавки);
	Если ЗначениеЗаполнено(ЗаменяемыйВидСтавки) Тогда
		Возврат ЗаменяемыйВидСтавки;
	КонецЕсли;
	
	Возврат ВидСтавки;
	
КонецФункции

#КонецОбласти
	
#КонецЕсли